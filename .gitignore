# ==============================================================================
# PCRD 專案 Git 忽略配置
# ==============================================================================

# 1. 忽略 PyInstaller 打包生成的巨大暫存與編譯發行檔案
translator/build/
translator/dist/
translator/*.spec
translator/PCRD_AI_Translator.spec

# 2. 忽略 API 金鑰快取與設定快取 (保障金鑰不被公開上傳)
translator/api_cache.json
translator/api_key.txt

# 3. 忽略 Python 自動編譯快取檔
**/__pycache__/
*.pyc
*.pyo
*.pyd

# 4. 忽略暫存測試目錄
temp_repos/
*.log

# 5. 忽略大型資料庫檔案
dashboard/*.db
dashboard/*.db.bak

# 6. 忽略下載的對白 JSON（改用 download_stories_tw.py 下載）
dashboard/story/*.json

# 7. 忽略 icon 資源
dashboard/icon/

# 8. 忽略 scratch 測試腳本（僅供開發除錯用）
scratch/

# 9. 忽略虛擬環境
venv/

# 10. 忽略發行版中的龐大卡面原畫資料夾 (GitHub Pages 上將 Fallback 遠端 CDN)
dist_story_map/card/

# 11. 忽略本地臨時下載的劇照與卡面大圖目錄
dashboard/still/
# 12. 忽略整個打包發佈目錄
dist_story_map/


downloaded_sounds/
dashboard/sound/
tools/
