        "words": "\n",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會將大家的希望……",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "以及勇氣合而為一，",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "擊倒黑之王的！！",
        "unit_id": 112911
