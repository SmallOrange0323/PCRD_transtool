        "voice": "vo_adv_5042302_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "牠的力量又增強了……",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "再這樣下去……",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……確實，",
        "unit_id": 106711,
        "voice": "vo_adv_5042302_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這下是有點不妙呢〜",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n侵蝕所造成的時間壓力也越來越緊迫了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "光憑我們的力量……",
        "unit_id": 112911,
        "voice": "vo_adv_5042302_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這就是極限了嗎……？",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……沒、",
        "unit_id": 113011,
        "voice": "vo_adv_5042302_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒這回事的！！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "步、",
        "unit_id": 112911,
        "voice": "vo_adv_5042302_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "步未？",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 113011,
        "voice": "vo_adv_5042302_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我啊！！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "比別人還要膽小很多，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "跟大家不一樣，一點都不堅強！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這樣的我卻沒有逃走，而是留在這裡……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這都是因為",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n有你們陪著我……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是你們",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "給了我希望！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "連、",
        "unit_id": 113011,
        "voice": "vo_adv_5042302_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "連連、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "連我這種人，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "都會想要盡可能努力了！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "比我還要強了很多的你們應該更……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呀啊！？",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n為、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為為、",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為什麼要抱住我啊日和～！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "步未，",
        "unit_id": 100113,
        "voice": "vo_adv_5042302_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳真的好厲害……！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我……",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能遇見步未妳，真是太好了！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的……",
        "unit_id": 106612,
        "voice": "vo_adv_5042302_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "連看起來",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n比我還要脆弱很多的妳都說到這個地步了……",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那我也不努力不行了啊！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "呵呵。",
        "unit_id": 4611,
        "voice": "vo_adv_5042302_009"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "璃乃，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳身為救世主，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "不能夠輸給她吧？",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是啊！",
