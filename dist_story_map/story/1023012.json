    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──早上的咲戀育幼院。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n綾音靜靜站在房間裡。"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_000"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「怎麼了，綾音？",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_001"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n妳今天莫名地安靜耶。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……沒事，",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒什麼。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「哼嗯～",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_003"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n算了，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這樣也比妳像平時那樣隨便到處亂闖好多了。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n妳偶爾也安靜一點吧。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……在那之後，",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就算看到哥哥",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n或抱住哥哥也都和平時一樣。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那時候",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胸口會撲通撲通地跳，果然不是什麼戀愛吧？　",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……可是，又是為什麼呢？",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n只要看到哥哥，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "感覺就靜不下來……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這種心情，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "到底是什麼呢……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……咦！？",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥！？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「哦，小子。",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_008"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n你說包裹，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "是給綾音的嗎？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n這箱子還真大呢。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒、",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒什麼啦，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……別一直想那些了，",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就和平時一樣吧。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也不想讓哥哥擔心。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "大到夠把我也裝進去的箱子……",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不曉得裡面裝了些什麼？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「等等，綾音。",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_013"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我正在和小子確認寄件人是……」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗、",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉～～！！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「怎、",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_015"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "怎麼了……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "啊，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "為什麼妳已經打開了啊！",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n而且別撲進去箱子裡面啊！！」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好棒喔！",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有好多噗吉！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「不對，",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_017"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我只有一個人，而且就在這裡……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這是什麼啊～～！！」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好棒、",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好棒喔！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n箱子裡面有好多各式各樣的噗吉！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「這、",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_019"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這這、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這是我的弟弟嗎！？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n還是妹妹！？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「我看看……",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_020"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "寄件人是……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音的父母寄的！？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n哦，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "仔細一看，有封信附在箱子上呢。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦！？",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_021"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "給我看給我看！！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……………………",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_022"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「信裡寫了什麼？」",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………太好了～～～！",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_024"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n噗吉、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這是我們的新家人喔！！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「冷、",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_025"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "冷冷、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "冷靜下來，綾音……！",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n總之，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "妳如果要抱緊我，就先把力氣放輕點……！」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這好像是爸爸媽媽",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_026"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "為了不讓我寂寞而寄過來的！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "謝謝你們，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "爸爸、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "媽媽！！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「我知道妳很開心！",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_027"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n所以現在",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "先把力氣放鬆！",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n棉、",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "棉花要爆出來了！！",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "全部都要爆出來了啊～～！！」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「呼……",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_028"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "呼……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n還差一點，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "就要成功爆瘦到",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n連剛結束冬眠的熊都會嚇一跳的地步了……」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對、",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對不起，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "多了新家人讓我太開心，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不小心就……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「我是懂",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_030"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "妳的心情啦……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "所以，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "該怎麼辦？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n現在的櫃子",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "可放不下這麼大的量啊。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "的確……",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_031"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也沒有錢可以買新櫃子……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「嗯～",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_032"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "總之先找別的地方放……」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不行啦，噗吉！",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "家人要一直在一起！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不可以分開！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我知道這樣說很任性，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是只有這一點絕對要遵守！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「但是，以實際面來說……」",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "做一個……櫃子嗎？",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_035"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
