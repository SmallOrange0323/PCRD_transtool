        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是咲戀媽媽她們回來了嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥快去玄關迎接她們！",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_068"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我這裡弄完",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就過去♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯！",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_069"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我的份也麻煩你囉♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「好了，綾音，",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_070"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "快點弄完……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "唔哦！？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n突然抱緊我",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "是怎麼了……」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……………………",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_071"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「……綾音？」",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_072"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………跟你說，噗吉。",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_073"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "最近好奇怪……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只要和哥哥在一起，",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_074"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胸口就會撲通撲通地跳。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n一開始我還以為是錯覺，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n可是這種感覺卻變得越來越強烈了……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "今天也是這樣……",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_075"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥對我溫柔",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n或摸我頭的時候，心臟就會撲通撲通地跳……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「綾音……",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_076"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "那就表示……」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我……",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_077"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "喜歡哥哥……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "比胡桃……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n比咲戀媽媽……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "比誰都還要喜歡哥哥……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n表示，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這不是家人的喜歡，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "而是戀人的喜歡嗎……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「…………那問題",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_078"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我也無法回答。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n這是綾音必須自己找到答案的問題。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是喔……",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_079"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「……只是，",
        "unit_id": 2111,
        "voice": "vo_adv_1023012_080"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "若有一件事要我來說，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n那就是先不論那份情感是如何，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音自己",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "又想怎麼做？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我……",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_081"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "想怎麼做嗎…………",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，哥哥！",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_082"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……咲戀媽媽買了點心伴手禮回來給我們！？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我很想立刻就去，",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_083"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是這裡還沒弄完……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "等吃完點心之後會來幫我的忙！？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "既然這樣，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我就順從哥哥的好意了♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "順便……",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_084"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "抱抱攻擊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n嘿嘿，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要把我抱到餐桌那裡去喔。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "GOGO，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……我胸口",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_085"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "果然會撲通撲通地跳。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然還無法確認",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_086"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這份情感到底是什麼……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但是想待在哥哥身旁的情感，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n是我真正不變的情感……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以哥哥……",
        "unit_id": 102311,
        "voice": "vo_adv_1023012_087"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n現在……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "至少現在，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "讓我待在你身旁喔……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──在與往常不同的氛圍中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n咲戀育幼院度過了中午的時間。"
    }
