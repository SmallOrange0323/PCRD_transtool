[
    {
        "type": "background",
        "background": "500230"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呼、呼……♪",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哈、呼。",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n拜託不要搖人家，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n求求王子先生了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家總覺得全身懶懶的，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n施展魔法之後很容易想睡呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可以讓人家安靜地睡覺嗎……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗚啊……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n呼哈、呼♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "糟糕，人家竟然打了個大哈欠……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "太不優雅了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n會被爸爸媽媽罵的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊～",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "睡了個好覺♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……嗯？",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這裡是哪裡呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好美呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n四周都閃閃發亮的……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是那個吧，叫做冰晶山脈的地方是嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇？",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生不要搖人家了～。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家已經醒來了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生怎麼了？",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n怎麼一副驚慌失措的樣子……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "冷靜一點，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "慌慌張張地也不會發生好事。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不急不急，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生稍微休息一下吧……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不要拉人家的尾巴～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那裡很敏感的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真壞心呢……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n話說回來，到底怎麼了？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯？",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為馬車壞了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n搞不好回不去？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣的話……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生要不要永遠",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n和人家一起在這裡生活呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不錯吧～",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可喜可賀、可喜可賀……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇、哇。",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "放、放過人家的耳朵呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "耳朵和尾巴一樣敏感的，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不能亂摸的唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "摸了會要王子先生",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n負起責任娶人家的唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊啊，人家回想起狀況了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不知為何咱們被繩子綁住，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n然後被馬車載往某個地方。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣對嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "接著",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "發生了什麼事啊……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家使用魔法，結果把馬車吹跑了？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，原本是要鬆綁王子先生的繩子是吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "抱歉呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家不擅長控制魔法的強弱。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是不是吹跑了整台馬車呀？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家得好好反省……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n車伕不知道有沒有受傷呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真叫人擔心。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯嗯……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們因為受到魔法的衝擊，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n而從馬車上摔出來。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "遙遠高處上，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真的有台破了洞的馬車。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們從那裡摔下來，竟然沒事呀？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n在那一瞬間抱住並且保護人家嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝王子先生～",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n果然是王子先生救了人家對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿，跟繪本的故事一樣呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸～……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n為什麼要說那麼冷淡的話？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家會很傷心的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n已經忘記人家了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們上輩子大概是一對戀人唷～。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家覺得是那樣……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家是真步真步王國的公主，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n而您是王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n在這一輩子也能遇見王子先生真是太好了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這次我們一定要幸福唷……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為我們從山崖上摔下來，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n能不能爬上去也不曉得呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您知道現在",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n正是窮途末路的狀況嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "抱歉呀。",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是個樂天派……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然時機有點晚了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但人家還是自我介紹一下好了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家是真步真步王國的公主，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n叫做真步。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "以後請多多指教♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還有，人家擔任【哞哞自衛隊】這個公會的……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n像是隊長一樣的角色。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為其他人都很自由奔放，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n需要一個人來帶領，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以人家就被強迫負責了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天呢～",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也是因為【哞哞自衛隊】的工作，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n來城鎮上的博物館負責戒備。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為最近好像治安變差了。",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n小偷好像潛入了好幾次呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然只是個小小的博物館，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n沒有什麼值錢的東西。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過這是工作，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家還是拼了命做好戒備。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且是和【哞哞自衛隊】的大家一起唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但也因為和夥伴們一起，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家就變得有點鬆懈……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看著博物館裡面古老的紡織品或工藝品，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n開始緬懷太古的文明。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "然後放空做起白日夢……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_047"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n回過神來，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家就在馬車中和王子先生對看著了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家一開始做白日夢就會整個失神，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_048"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真是個壞習慣。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "【哞哞自衛隊】的大家……",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_049"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家突然消失，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "她們一定很擔心。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且這裡氣溫這麼低，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "得趕緊回去才行。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家的耳朵都塌下來了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生也很冷吧，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_051"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n都在發抖了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是沒辦法，",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_052"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生可以摸人家的尾巴取暖唷♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010002_053"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "像圍巾一樣",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n很溫暖吧……♪",
        "unit_id": 101011
    }
]