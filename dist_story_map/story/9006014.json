[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "早上，和平常一樣醒來的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n往大家所在的公會小屋客廳走去。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}！\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "早安！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你終於起床了啊。",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也太會睡了吧～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "早安，",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "昨晚睡得好嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那太好了。",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這一定是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人健康成長的證明。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你就是睡太久才會做那種夢。",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快點清醒。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好，",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "切入正題！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n特別紀念日就快到了～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀！",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡佩可，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要突然在我耳邊大叫啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿，",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為太期待，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不小心喊得太大聲了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且，",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "紀念日又還沒到。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳也太猴急了吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在紀念日來臨前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們來回顧",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這一年發生的事如何？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦，",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽起來不錯。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙應該也經歷了",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們所不知的冒險吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿，",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真令人好奇。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說給我們聽聽吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請告訴我們，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您經歷了什麼樣的冒險吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是在牧場的那場公演吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我有聽說過！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是胡桃和美咲主演的那個吧。",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像還有老鼠……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那時候有張貼漂亮的海報呢。",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "等再次舉辦公演的時候，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家一起去看吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那樣沒問題嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有被抓到吧……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此，",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是和步未小姐還有祈梨小姐一起……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然主人有參與，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那想必是為了正義而行動的吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也就是義賊囉！",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "過程一定精彩萬分。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是跟杏奈小姐、忍小姐",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有霞小姐一起啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n哦哦……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是場波瀾壯闊的冒險。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不愧是主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看你好像也沒變得腰纏萬貫，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n結局應該又是老樣子吧……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵，",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "冒險本身就具有意義了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這就是所謂的浪漫！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你還是一樣被捲進各種麻煩呢。",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該還不只這些吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真好！",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定有美味的露營餐……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "流口水。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣啊，",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和純小姐、碧小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以及優花梨小姐一起……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與大自然對話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓主人更加成長了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然不可能只有單純露營那麼簡單呢……",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然你玩得開心那就好。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是和【破曉之星】還有",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【小小甜心】的成員們一起啊。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今年夏天真的是很忙碌呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然，",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道你是想做一些有夏天感覺的事情，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但真虧你不會游泳還敢去海邊耶……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人應該是和凱留小姐一樣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n覺得和大家待在一起很開心吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "軟綿綿啊……",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總覺得",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有點在意呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此，",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "植物羊先生啊……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望在下哪天",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能有機會和牠見面。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "與真步小姐還有綾音一同大冒險，",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是不錯。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是趟愉快的旅途♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真好！",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n光聽就覺得很興奮！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有呢？還有呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下有聽說鈴、",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "七七香小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還有智小姐三位大顯身手。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我記得",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你好像有帶招募團員的海報回來呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了，我想起來了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽說有人擅自把我畫到同人誌上……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我真的會宰了他喔！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又沒關係♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「喜歡」的祭典──蘭祭！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n聽起來是很棒的活動呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我去拜託克蕾琪塔小姐，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看看能不能增加這類活動！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "茉莉就算了，",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "帶克莉絲提娜去，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不會節外生枝嗎……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有問題嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有主人陪同，",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒有問題的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓你執行了一件辛苦的差事呢。",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就知道你一定能順利達成！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今年冬天，",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又是聖誕節又是過年的，你還是一樣忙呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有過過安穩的聖誕節",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和新年嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人和依里小姐、茜里小姐",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有純小姐一起，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n幫助了兩位天使呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感謝各位",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當時也來拜訪在下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還跟深月小姐、美里老師",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "以及帆稀小姐在溫泉旅館工作……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "寒冬之中",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是辛苦你了♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是喔……",
        "unit_id": 106012,
        "voice": "vo_adv_9006014_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽起來你這一年過得很充實嘛。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說真的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你到底什麼時候休息啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人和大家",
        "unit_id": 105913,
        "voice": "vo_adv_9006014_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都過得很愉快呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這一定是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的人望所致。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們要努力讓明年過得更開心！",
        "unit_id": 105812,
        "voice": "vo_adv_9006014_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "紀念日這段期間，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們要好好慶祝呦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "喔──！",
        "unit_id": 1,
        "voice": "vo_adv_9006014_045"
    }
