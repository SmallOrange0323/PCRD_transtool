[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}跟千歌一起來到了露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "取回",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你記憶的關鍵就潛藏在這裡是吧……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不，",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "別這麼說！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一直以來都是我受到你的幫助嘛。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我會努力",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不要扯後腿的！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯，",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說得也是。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一起加油吧。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "──♪"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "精靈們說很開心能",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "幫上你的忙。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是！",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "接下來要登上的塔相當高對吧？",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我想說路途很長，所以有好好準備而來。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就是啊……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有帶了便當，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "和各種零食當作點心，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不介意的話就在休息的時候……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是抱歉！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一不小心就太",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "興奮了呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "帶我來到這麼重要的地方，",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n還這麼信賴我，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我一高興就……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "首先要做的，",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就是好好登上塔才對！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊……",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣顧慮我的心情……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我買了聽說很好吃的布丁，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請好好期待吧！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "什……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "什麼？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n啊……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "行李飄在空中……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝、",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_013"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "行李好像沒有怎麼樣呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但是，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這到底是……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是",
        "unit_id": 104211,
        "voice": "vo_adv_7016000_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這樣啊……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這裡可是謎之遺跡的入口……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就算發生什麼事都不奇怪呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "小心前進吧……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可惡……",
        "unit_id": 1,
        "voice": "vo_adv_7016000_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "失敗了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但我是不會放棄的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一邊戒備著一邊朝向塔前進的千歌和{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是，兩人都沒有注意到"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n尾隨在他們身後的神祕身影……"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "把那個布丁交出來～！",
        "unit_id": 1,
        "voice": "vo_adv_7016000_016"
    }
]