    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呵呵呵。",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n國王陛下，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這可是笨蛋無法看見的衣服啊。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯、呼……♪",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總覺得，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n已經可以演得很不錯了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這樣的話，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n正式上場應該沒有問題……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……！？",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n噫呀……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥、",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "從什麼時候開始，就在那裡了……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥看、看、看到了嗎……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚哇哇，這樣我就嫁不出去了……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，哥哥問我剛剛在做什麼嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呃那個那個，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "應該怎麼說呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是在練、練習演戲……！",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為哥哥最近，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也都是住在【咲戀育幼院】……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我想說哥哥應該知道，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n應該說哥哥也是在場一起聽過這件事才對……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "由於【咲戀育幼院】這裡，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n經營上大致安定下來了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以不是有講到說，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也要做一些公會名義的工作嗎……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以，那個……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就變成是去訪問一些看護機構和托兒所之類的，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n然後演一些小短劇這樣的工作……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為我會害怕人群，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以本來覺得應該沒辦法參與……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是咲戀媽媽還有大家，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n都稱讚我的演技很好……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、我雖然沒有什麼擅長的事情……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是演戲很有趣……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我總是受到",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "【咲戀育幼院】的大家照顧……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以我、我想努力看看……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我想讓這齣戲，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n演得很成功……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以我才會在沒人看到的地方，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n偷偷練習……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n為什麼要突然拍手呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好可怕……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥說我演得很好嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n在誇獎我呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是正式上場時，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n必須要在大家面前演戲……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我說不定，會因為緊張而演不好……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "所以……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n如果可以的話，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我想請哥哥陪我練習演戲……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我必須習慣，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n把演技展示給別人看……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果是在哥哥面前我會比較安心，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n或是說我就不會怕了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不、不行嗎……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這樣子，是撒嬌過頭了嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "噫呀……！？",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥、哥哥……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你好像、又在發光唷……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎、怎麼回事……？",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚哇，果然哥哥也好可怕……！",
        "unit_id": 102111
    },
    {
        "type": "still",
        "still": "102100801"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇啊……",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n嗚嗚、嗯……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，哥哥……",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_032"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗯、咳、咳……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚、",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咳、咳……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對、對對、對不起……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哭著哭著，話都講不清楚了……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、我先、",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n冷靜下來……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呼、哈……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那、那個……",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_035"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我等一下，要去參加共同練習……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個……",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_036"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n之前話劇社演的戲，評價很好……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "之後有好像是專、專業的……",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_037"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n劇團的星探，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "給了我名片……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "然後我，就分配到了小角色……",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_038"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n今天是參與演出的大家約好要集合，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n一起練習的日子……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是排、排練場的地點，",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_039"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我不知道在哪裡……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇啊……",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_040"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我、我、",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我該怎麼辦才好……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……？",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_041"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就說了，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不要用力摸我頭嘛……！",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過最近，好像也已經習慣了……",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_042"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "被哥哥摸摸頭後，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n就會變得比較冷靜了……♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……！？",
        "unit_id": 102131,
        "voice": "vo_adv_1021008_043"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n為什麼連哥哥，\n也跟著慌張起來了……？",
        "unit_id": 102131
    },
