        "name": "胡桃",
        "words": "\n我會擔心唷……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "現在住在同一個屋簷下，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_088"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我們就是一家人了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果有什麼煩惱的話，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_089"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n要找我聊聊喔……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_090"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n雖然，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我可能不太可靠……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，太陽都要下山了……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_091"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是小孩子應該要回家的時間了呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為練習演戲演到太投入了，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_092"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以都忘記時間過了多久……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我得回去了……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_093"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在家也可以練習……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "再不回去的話，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_094"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n咲戀媽媽會擔心的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊哈哈……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_095"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我剛剛說了「家」呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我已經完全把【咲戀育幼院】，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_096"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n當作我自己的家了呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然，有家可歸是很可貴的事情……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_097"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是，我果然還是想見到真正的父母呀……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "至少，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_098"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我想告訴他們我現在過得很幸福……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然這樣很像在做白日夢……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_099"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果這次的劇作有好的評價，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n而我成為很棒的演員……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "然後可以在很大間的劇場之類的地方，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_100"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n演戲的話……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我那不曉得現在身在何處的爸媽，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_101"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n會不會也能因此找到我呢……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "開玩笑的……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_102"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嘻、嘻嘻……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好了，反正我們回程的目的地一樣……",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_103"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "走夜路也很危險，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以哥哥也和我一起回去吧。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我們就手牽手，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_104"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n肩併肩地回去吧。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "回到那個，",
        "unit_id": 102111,
        "voice": "vo_adv_1021008_105"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我們溫暖的家……♪",
        "unit_id": 102111
    }
]