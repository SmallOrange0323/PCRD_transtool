[
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒家也算上中偏下的有錢人了。",
        "unit_id": 110911,
        "voice": "vo_adv_6038104_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但要是說到紫藤家的話，\n那可是上中之上，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "或者該說超中之超呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "他們家的千金秋乃大小姐，\n是一個什麼樣的人呢？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "難不成真的常常泡鈔票浴之類的嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911,
        "voice": "vo_adv_6038104_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長你在說什麼啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒現在是在討論秋乃大小姐的事耶。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n請你不要突然自我介紹好嗎。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過如果是學長的話，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "感覺在迷路之前，\n就先在人生中迷路了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "然後琪愛兒也一樣就是了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哭哭～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喔～",
        "unit_id": 110911,
        "voice": "vo_adv_6038104_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "想要學長當她的騎士，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以只要一有機會就想給錢？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真令人擔心啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "用錢維繫的人際關係可是一點價值也沒有呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "話說回來學長，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要付多少錢，你才願意把那個位子讓給琪愛兒呢？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼啊太感人了。",
        "unit_id": 110911,
        "voice": "vo_adv_6038104_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "都已經那麼成功了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還繼續在努力。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "如果組織的領導者是這樣的人，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一定會不斷壯大的呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒也趁現在跟她打好關係好了～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "俗稱，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "找出路活動。",
        "unit_id": 110911
    }
]