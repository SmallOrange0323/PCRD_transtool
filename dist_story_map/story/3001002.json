        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下才想讓主人享受豐富的飲食生活。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論何時，吃就是為了活著……",
        "unit_id": 105913,
        "voice": "vo_adv_3001002_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也就是所有事情的基本，不是嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯☆ ",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿說得不錯， ",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是很適合做成匾額掛起來的名言呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "優秀！",
