        "voice": "vo_adv_3001002_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等！？",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳說的是蟲嗎！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說了蟲料理嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "希望只是我聽錯了……！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蟲料理，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就是用了蟲蟲的料理唷～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳一副天使般的笑容說這什麼鬼東西！？",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？吃蟲嗎？為什麼？ ",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真搞不懂妳，妳是笨蛋嗎！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下可是很喜歡這種料理的。",
        "unit_id": 105913,
        "voice": "vo_adv_3001002_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在鄉土料理中，也有以蟲當作材料的點心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n純樸的滋味很受歡迎喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐不喜歡嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "談喜歡還是不喜歡之前， ",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是說我已經搞不懂了啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等一下！",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "ＳＴＯＰ！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真的要吃蟲嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，好像有什麼可怕的東西端過來了！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘿嘿，",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這家店的蟲料理可是大推的唷～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個是～嗯～……？",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這獨特的酸味，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是××××跟×××的沙拉吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～！",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我聽不到，我也不想聽！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的腦袋拒絕理解任何單字！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們先冷靜一下吧！",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n冷靜下來嘛，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好不好好不好♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "平常蟲掉進菜裡不就連盤子都要丟掉嗎？",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～？",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不好好把端上來的菜吃完的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對做菜的人可是很不禮貌的唷？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎喲，小凱留真是……",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小・任・性・鬼♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "住手！ \n拜託不要帶著媽媽那般溫柔的笑容， ",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再用湯匙盛著幾乎保持原狀的蟲接近我！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "宰、宰了妳喔？",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n小心我宰了妳喔……！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎喲，小凱留一開口就是宰來宰去的呢～？",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳宰了我也沒關係……宰掉我後",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要好～好地料理我再吃掉我喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被自己奪走的生命的東西，",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可要不留骨頭地啃食乾淨才合乎禮儀呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳為什麼對食物有那樣異常的執著呢！？ ",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不要我不要我不要，我不想吃蟲、也不想吃人！ ",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，我說話是不是很奇怪！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嚼嚼……",
        "unit_id": 105913,
        "voice": "vo_adv_3001002_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n啊，原來如此。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這還挺美味的呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然對在下來說，",
        "unit_id": 105913,
        "voice": "vo_adv_3001002_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n辛香料有點刺激所以舌頭刺刺痛痛的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是味道可是非常地好呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也請享用吧！",
        "unit_id": 105913,
        "voice": "vo_adv_3001002_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，啊……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊！\n說來你也在啊，",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你很沒存在感呢！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，{player}！",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你神智還正常吧，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拜託說你很正常！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，妳這小不點，不要餵他吃蟲！",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n{player}是很重要的主人吧！？",
