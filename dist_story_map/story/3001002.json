        "voice": "vo_adv_3001002_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是好可愛啊～……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快、快逃啊小不點！",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n會被吃掉的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙擺出要吃掉妳的眼神了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～？",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我不會吃她啦，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然她也可愛到讓我想吃掉她……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，小凱留也想要被我這樣緊緊抱住嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃什麼醋嘛，真是的～♪ ",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來來來，妳來妳來妳來～……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要，被妳的臂力抱住了就跑不了了！",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反～正，妳只是要架住我、餵我吃蟲吧！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n已經被我發現了，不要把我當笨蛋喔！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我才沒有當妳是笨蛋呢～",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔，讓小凱留逃走了呢……",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒辦法，只好來抱抱妳了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嘿咻，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱緊處理～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……",
        "unit_id": 105913,
        "voice": "vo_adv_3001002_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n佩可小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您是不是對人親密過頭了呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我是很容易感到寂寞的人呢。",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，我很高興能跟大家一起坐在餐桌旁熱熱鬧鬧的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，我也介紹了我最喜歡的店家。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是小凱留好像不太喜歡的樣子，真是可惜。",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會反省的，對不起。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳……",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼、哼！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n知道就好？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我啊，",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果是在正常一點的店的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我也就不會這樣抱怨了呀？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是這樣啊～",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是被妳討厭，真是太好了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，過來過來。",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請讓我抱一下吧，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不會弄痛妳的♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～……",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_049"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳，不會餵我吃蟲吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看妳有點可憐，就讓妳抱吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果就這樣順水推舟餵我吃蟲的話，",
        "unit_id": 106012,
        "voice": "vo_adv_3001002_050"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我就會對其他人失去信任了唷？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "蟲明明就很好吃～……",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家都有自己的食物好惡呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣強迫人果然不太好呢～",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡也有蟲料理以外的餐點，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就點這些吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們來一邊吃東西、一邊歡笑，一邊談天說地吧。",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比如說，小凱留喜歡什麼、不喜歡什麼……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好不容易能跟你們相遇。",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果只用今天一天，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就把這個緣份給消化掉了，那就太可惜了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們大家，",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還要一直相親相愛、快快樂樂地一起吃飯。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天的話，",
        "unit_id": 105812,
        "voice": "vo_adv_3001002_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就先滿足於八分飽吧……♪",
        "unit_id": 105812
    }
]