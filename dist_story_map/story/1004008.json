        "voice": "vo_adv_1004008_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明年紀比較大，但卻完全被當成惡整的對象了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你要振作一點呀～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯嗯，不過禊看起來很開心……",
        "unit_id": 190011,
        "voice": "vo_adv_1004008_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n說不定保持現在的樣子也不錯，對吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛的情景，是我依照你和禊的「記憶碎片」",
