        "voice": "vo_adv_1004008_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊覺得這樣很好！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好啦！哥哥就一口氣打開箱子吧！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿咻！打開囉！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呀哈哈哈！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_029"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n是拳擊手套呢！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個木箱果然是嚇人箱。",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "如果是禊的話，",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_030"
    },
    {
        "type": "dialogue",
        "name": "禊",
