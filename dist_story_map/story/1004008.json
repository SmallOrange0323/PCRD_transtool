        "voice": "vo_adv_1004008_032"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "他相信禊會找到箱子，所以才埋在這裡吧！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "呀呼──！",
