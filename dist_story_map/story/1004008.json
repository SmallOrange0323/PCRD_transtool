    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}正和禊在挖地洞時，\n突然被一陣詭異的光線給包圍住。"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗚哇，好刺眼！？",
        "unit_id": 100411,
        "voice": "vo_adv_1004008_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這道光，是之前的……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗚哇哇哇！！",
        "unit_id": 100411,
        "voice": "vo_adv_1004008_001"
    },
    {
        "type": "still",
        "still": "100400801"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，早安──！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n早晨令人神清氣爽呢！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……一大早的太有精神了？",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n是這樣嗎？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊不管早上中午晚上，",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_004"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n隨時都超有精神的！耶耶！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "而且呢～哥哥！你快點看！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這衣服超級帥的吧？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸嘿嘿，這是媽媽買給禊的呢～",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊想要讓哥哥看這件衣服，",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n所以才會叫哥哥過來的～",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，不只這件事情而已！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊還有重要的事情呢！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，你看這個！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_008"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個東西，是這附近的地圖吧？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這是在爸爸的房間裡找到的～",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "然後呀，哥哥看這裡！有個記號呢！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這一定是爸爸畫的記號！",
        "unit_id": 100432
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "既然爸爸特地在這裡畫上記號，",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n表示一定有什麼東西！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "說不定，這裡可能埋著寶藏呢！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥真是太上道了！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那我們趕快去找寶藏吧～！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸～才不會發生什麼事咧～",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_012"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥太愛操心了～",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n我們去找找看呀～",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們已經離目標很近了！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_013"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯……再前面一點嗎？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "應該就在這附近吧……",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？腳下好像有奇怪的聲音……",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……挖！地板開了個洞！？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇啊啊啊！？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好痛痛……",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這是陷阱地洞嗎？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是爸爸挖的嗎？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，你沒事吧？",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊哈哈！真是拿你沒辦法呀，哥哥！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥要振作一點呀～",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊對於地洞陷阱很在行！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "像這種高度的地洞，才不會受傷呢！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過，禊沒想到這裡竟然會有地洞陷阱，",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_019"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哥哥也嚇了一跳吧？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真不愧是爸爸！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n如果是禊的話，可沒辦法挖得這麼漂亮呢！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯……",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_021"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n不過為什麼會在有地洞的地方",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n畫上記號呢？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "奇怪？",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_022"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哥哥，好像有東西埋在這裡呢！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這是什麼東西呀？",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們挖出來看看吧？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿咻、",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_024"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘿咻……",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個東西……是木箱？",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_025"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這是爸爸埋在這裡的嗎？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，要怎麼處理呢？",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊知道了！",
        "unit_id": 100432,
        "voice": "vo_adv_1004008_026"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣的話，禊要對著哥哥打開囉！",
        "unit_id": 100432
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……嗯嗯，這樣呀！",
