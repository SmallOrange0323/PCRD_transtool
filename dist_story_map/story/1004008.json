        "voice": "vo_adv_1004008_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n創造出來的「夢」唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？你做了個好「夢」嗎？",
