        "voice": "vo_adv_1157004_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對吧……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我只有",
