    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "稍、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "稍微努力一點",
