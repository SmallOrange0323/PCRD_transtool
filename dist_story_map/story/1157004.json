        "voice": "vo_adv_1157004_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "果然很漂亮呢……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那兩位煙火師傅，",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n雖然看起來非常可疑……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但手藝真的很棒呢。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n真的",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很謝謝你。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為我忙著處理【哞哞自衛隊】跟偵探的工作……",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你才會努力想辦法",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要讓我輕鬆一下對吧。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "回想起來，",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那時你一直在找我玩耍呢……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊～",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "明明是祕密的驚喜，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我卻因為奇怪的誤會",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而不停地想揭穿它，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n真的很抱歉。",
        "unit_id": 115711
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我還是覺得瞞著我偷偷行動實在不太好喔。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為我",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是你的雇主。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是偵探，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而你是我的助手。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你必須跟我仔細報告才對，",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "或者該說……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔……",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我真是個笨蛋。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n明明很高興",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "他為了我做了這麼多的說……！　",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "算了，",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看在美麗的煙火份上，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這次就原諒你吧……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "奇怪？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n總覺得",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "煙火的光好像……！？",
        "unit_id": 115711
    },
    {
        "type": "background",
        "background": "510160"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "欸嘿嘿……",
        "unit_id": 101431,
        "voice": "vo_adv_1157004_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這本書",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "非常有趣呢。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊！",
        "unit_id": 101431,
        "voice": "vo_adv_1157004_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長好……！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n呃，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是",
        "unit_id": 101431,
        "voice": "vo_adv_1157004_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "以夏天的大海為舞台的",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "推理小說。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然是懸疑故事，",
        "unit_id": 101431,
        "voice": "vo_adv_1157004_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是把大海描寫得很開闊，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讀起來很暢快。",
        "unit_id": 101431
