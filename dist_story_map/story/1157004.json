    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n對不起，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是說得太多",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就會破哏了。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 101431,
        "voice": "vo_adv_1157004_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讀完這本書後，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n感覺連內心",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都變得開闊了呢……",
