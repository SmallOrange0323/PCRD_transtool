        "type": "dialogue",
        "name": "霞",
        "words": "咦！？",
        "unit_id": 101431,
        "voice": "vo_adv_1157004_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你問我",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要不要去……？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "難不成……",
