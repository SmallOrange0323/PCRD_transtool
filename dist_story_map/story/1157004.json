        "name": "愛梅斯",
        "words": "呵呵，",
        "unit_id": 190011,
        "voice": "vo_adv_1157004_079"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看到可愛的學妹鼓起勇氣的模樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就讓人覺得欣慰，想幫她加油呢♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，",
        "unit_id": 190011,
        "voice": "vo_adv_1157004_080"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再繼續把你留下來也不好呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "難得的煙火都要結束了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1157004_081"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500162"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔，",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_082"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好刺眼……！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊……",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_083"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是煙火……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n難不成……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我睡著",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "了嗎……？",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感覺好像做了一場夢……",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_084"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我跟助手先生",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在海邊……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "記不太清楚了……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_085"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總覺得心臟跳得好快……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這究竟",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是什麼樣的感情呢……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不像是偵探，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而像是體驗到身為一個女孩子的感情……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦！？",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_086"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n別、",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "別在意，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我沒事！",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是怎麼了！",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_087"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒有辦法好好面對助手先生……！　",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊……",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_088"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "煙火……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "已經",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "結束了呢……",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔！",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_089"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_090"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你說得對。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看樣子，",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_091"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這股心跳加速的原因，",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就算想破頭也找不到答案呢。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是總有一天──",
        "unit_id": 115711,
        "voice": "vo_adv_1157004_092"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我一定會揭穿這個謎團的。",
        "unit_id": 115711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在煙火結束後，恢復平靜的海邊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n霞懷著無法解開的謎團，感受到一股不可思議的安心感。"
    }
]