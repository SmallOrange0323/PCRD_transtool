        "type": "dialogue",
        "name": "霞",
        "words": "事件本身也是，",
        "unit_id": 101431,
        "voice": "vo_adv_1157004_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不是以恐怖的結局，",
