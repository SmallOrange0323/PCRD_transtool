        "voice": "vo_adv_1157004_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "或是怕讓他失望之類的……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這種事情",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就算想再多也沒用吧……！　",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101431,
        "voice": "vo_adv_1157004_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我要去。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想跟學長……",
