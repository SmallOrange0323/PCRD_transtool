    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這種機會說不定……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不會再有下一次了。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "像是感到害羞，",
