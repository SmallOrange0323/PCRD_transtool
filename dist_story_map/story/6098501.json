[
    {
        "type": "background",
        "background": "501162"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "己の目的を叶えるためには、",
        "unit_id": 107011,
        "voice": "vo_adv_6056501_000"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n時に表へ姿を現し、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "リスクを冒すことも必要不可欠です。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\nそのための準備はもちろん欠かしてはなりません。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "それは……",
        "unit_id": 107011,
        "voice": "vo_adv_6056501_001"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "いえ、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "貴方に聞かせる話ではありませんね。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\nとにかく、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "何事にも準備は大切です。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\nそのことだけをしっかりと覚えておくように。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "いいですね？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "……貴方に会うために姿を見せたわけではありません。",
        "unit_id": 107011,
        "voice": "vo_adv_6056501_002"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "とはいえ、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "直接会話をするというのも",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "悪くはありませんね。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n遠目に観察するだけでは得られない、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "貴重な情報もありますから。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "ええ、",
        "unit_id": 107011,
        "voice": "vo_adv_6056501_003"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "その通り。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "この体は分身です。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\nですが、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "分身といえど",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "本体と感覚を共有する設定にしています。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "なので……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "興味本位で私の頬をプニプニと触らないように。",
        "unit_id": 107011
    }
]