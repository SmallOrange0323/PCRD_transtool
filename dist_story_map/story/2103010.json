    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這些是你登上了我所準備的「塔」……",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n並與夥伴們一同收集的",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "記憶碎片。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是嚮導妖精",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一次次讓你見過的夢境……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對於你來說，",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那是真實的世界……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "而能讓你接受「現實」的準備，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n應該也已經在你的無意識領域中",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "完成了才是。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "簡而言之……",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡是",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一切開始的地方。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n也就是你和「她」，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "第一次接觸的地方……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「——我可終於找到你啦～！",
        "unit_id": 106831,
        "voice": "vo_adv_2103010_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n很抱歉突然對你說這種話，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但我希望你能",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "馬上開始玩阿斯特朗這款遊戲。」",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有關於「現實」的事……",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你有想起些什麼了嗎？",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那麼。",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你想起來",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我是誰了嗎？",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我是——",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒錯……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我就是",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的母親。",
        "unit_id": 191111
    },
    {
        "type": "background",
        "background": "500367"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在喝下了似似花給的新藥後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n已經昏睡整整"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一天一夜了……"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生",
        "unit_id": 100111,
        "voice": "vo_adv_2103010_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "看起來好像很難受的樣子……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不會有事吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然我也很想相信，",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "他會沒事的……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但還是",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "會讓人有點擔心呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "等到",
        "unit_id": 100111,
        "voice": "vo_adv_2103010_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "他變回原本的騎士先生之後……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我想要再和他一起玩，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一起冒險呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯，",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳說的對♪",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……對吧，凱留？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "日和、優衣",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2103010_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我最近在減肥，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n但今天",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我就來做點心給大家吃好了♪",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "耶～♪",
        "unit_id": 100111,
        "voice": "vo_adv_2103010_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n人家想吃餅乾！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個那個，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "凱留妳喜歡吃什麼呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "………………",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼都可以……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "日和、優衣",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2103010_029"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真是的！",
        "unit_id": 190911,
        "voice": "vo_adv_2103010_030"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n妳還要維持這種尷尬多久啦，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "像這樣畢恭畢敬的！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我扯我扯。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "煩死了！",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要扯我耳朵啦笨蛋——！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對不起。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我們這麼吵鬧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們最近這段時間，",
        "unit_id": 100111,
        "voice": "vo_adv_2103010_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n都一直像這樣",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "窩在凱留妳們家裡……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以讓妳不太自在吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們不用在意。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且這裡，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "實際上也不是我的家就是了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯。",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以妳們",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不需要為了我，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n做這麼多的顧慮。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就像妳們所知道的一樣，",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是大惡人的手下，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "協助他支配這個國家甚至還打算毀滅世界。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然因為貪吃佩可網開一面才保住了小命，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但我依舊是個罪人。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我……",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒有資格",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓妳們對我這麼好……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才、",
        "unit_id": 100111,
        "voice": "vo_adv_2103010_038"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才沒有那種事！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "凱留在最後的關頭，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也和我們一起戰鬥了啊！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……嗯。",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_039"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n妳說自己是罪人……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是我們大家，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n都沒有那樣看待凱留妳喔。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且……",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然我沒有問過詳情，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但我想妳一定有自己的理由吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我們怎麼可能會去責備",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n承認了自己犯下的過錯，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且有好好反省的凱留呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉，",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我真的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很不擅長應付這些的人耶……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既不像貪吃佩可那傢伙一樣，",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_043"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "完全不看人臉色就拚了命纏上來。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也不像可蘿仔一樣，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "活在腦子裡只有主人的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "個人小世界。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像這樣會察言觀色，",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_044"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "即使知道了實情，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還能像這樣以平常心對待我……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……真的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是一群乖寶寶中的乖寶寶啊……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_045"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "凱留。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我想稍微換一個話題……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "其實",
        "unit_id": 100111,
        "voice": "vo_adv_2103010_046"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們一直有件事情很想要問妳。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可以嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是、",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是想問什麼啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_048"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是關於雪菲的事情。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……咦？",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_049"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那小鬼，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "發生什麼事了嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_050"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "至今為止，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "她有什麼奇怪的地方嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這、",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_051"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個嘛……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不就這樣？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n長著奇怪的羽毛和尾巴。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再加上腦子裡根本就是個幼童。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n從頭到腳全都很奇怪——",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "至少我是這麼想啦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_052"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "昨天她對似似花",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像一直很有敵意呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她明明就很不怕生的才對……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111,
        "voice": "vo_adv_2103010_053"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那件事，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也有點在意！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n真稀奇呢，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雪菲竟然會這樣。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對吧。",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_054"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n結果直到似似花那傢伙回去以前，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她一直都是那個樣子……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是誰！？",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_055"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "嘿。",
        "unit_id": 191611,
        "voice": "vo_adv_2103010_056"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我和蘿莉老太婆擦肩而過了嗎？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "這還真遺憾。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "如果我能一個人把那傢伙的人頭帶回去的話……",
        "unit_id": 191611,
        "voice": "vo_adv_2103010_057"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "贊恩那煩人的牢騷，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "應該也會少一點吧。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "咦！？",
        "unit_id": 190911,
        "voice": "vo_adv_2103010_058"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你、",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你是誰啊！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n是從哪裡跑進來的！？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "卡里莎！",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_059"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真是的！",
        "unit_id": 100111,
        "voice": "vo_adv_2103010_060"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n你怎麼可以擅自跑進來呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "難不成這傢伙，",
        "unit_id": 190911,
        "voice": "vo_adv_2103010_061"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就是妳們之前說過的敵人嗎！？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "為什麼會知道這裡……！？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哈！",
        "unit_id": 191611,
        "voice": "vo_adv_2103010_062"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n怎麼可能告訴妳啊白癡——！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "公主騎士……",
        "unit_id": 191611,
        "voice": "vo_adv_2103010_063"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就在那張床上對吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "給我去死吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "等等！？",
        "unit_id": 190911,
        "voice": "vo_adv_2103010_064"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……什麼！",
        "unit_id": 191611,
        "voice": "vo_adv_2103010_065"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n只是碎布而已！？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿。",
        "unit_id": 100111,
        "voice": "vo_adv_2103010_066"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們早就知道",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你一定會再來的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以我們為了製造出騎士先生在這裡睡覺的假象，",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_067"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就把碎布塞進了棉被裡偽裝囉……♪",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "竟然給我搞這種無聊的把戲……！",
        "unit_id": 191611,
        "voice": "vo_adv_2103010_068"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "到底把人藏到哪了！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n快！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "公主騎士給我交出來！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能交出去啊白癡——！",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_069"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n快滾回家洗洗睡，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "尿床畫張大地圖自己找吧，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個臭矮子！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "這隻垃圾貓，",
        "unit_id": 191611,
        "voice": "vo_adv_2103010_070"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "還真敢說啊……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n我絕不原諒妳！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n看我扒了妳的皮做成三味線，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "每晚把妳彈得哇哇叫！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "阿澤爾德！",
        "unit_id": 191611,
        "voice": "vo_adv_2103010_071"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n在我把這群傢伙幹掉的期間，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你就給我去把公主騎士找出來！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "呵呵呵。",
        "unit_id": 191911,
        "voice": "vo_adv_2103010_072"
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "就這麼辦吧。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "我也得",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "為了讓卡里莎少對我碎碎念一些，",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "阿澤爾德",
        "words": "\n再加把勁才行呢。",
        "unit_id": 191911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "！",
        "unit_id": 106011,
        "voice": "vo_adv_2103010_073"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還有一個人嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明是個體型這麼大的人，",
        "unit_id": 100111,
        "voice": "vo_adv_2103010_074"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是我完全沒注意到呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……哇哇呀！？",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500367"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "別給我在那邊發呆了！",
        "unit_id": 191611,
        "voice": "vo_adv_2103010_075"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n不只那隻垃圾貓，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我也不會讓妳們幾個活下來的！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "現在先集中精神戰鬥吧，",
        "unit_id": 100211,
        "voice": "vo_adv_2103010_076"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和、凱留！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n另外那邊還有怜在顧著呢！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯！",
        "unit_id": 100111,
        "voice": "vo_adv_2103010_077"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "等等我說你們啊，",
        "unit_id": 190911,
        "voice": "vo_adv_2103010_078"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "別把我的家給毀掉了喔～！？",
        "unit_id": 190911
    }
]