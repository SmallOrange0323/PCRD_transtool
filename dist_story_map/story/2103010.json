    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……稍微，",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "想起來了嗎？",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這是至今為止，",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嚮導妖精",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "幾經多次，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n讓你在夢境中",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看見過的——「現實的景色」。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是的。",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "其他還有……",
        "unit_id": 191111
    },
    {
        "type": "still",
        "still": "700400501"
    },
    {
