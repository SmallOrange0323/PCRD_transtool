    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……這裡是",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的精神世界。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n與嚮導妖精讓你看見的夢境不同，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是將過去的資料復原而成的",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "無意識領域……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……好久不見了。",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n已經有好些日子，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不曾像這樣直接對談了呢。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不過……",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "和一開始我們相遇時相比，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我們倆，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "都變得與當時相去甚遠了呢……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡是",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你曾經就讀過的",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「學校」。",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n既不是月光學院，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "也不是聖德蕾莎女子學院……",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你曾在這裡",
        "unit_id": 191111,
        "voice": "vo_adv_2103010_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "度過了一段時光，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡是你學習、",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "玩樂，",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 191111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "並且和人建立起羈絆的場所……",
        "unit_id": 191111
    },
