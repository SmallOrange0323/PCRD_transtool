        "type": "dialogue",
        "name": "旁白",
        "words": "向{player}等人宣戰的神祕女性「芙蕾雅」。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她身在數不進的魔物大陣後方，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n藉由看不見的力量來指揮魔物。"
