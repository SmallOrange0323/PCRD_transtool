[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吃完魔物料理填飽肚子後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n帶著剩餘食材踏上往蘭德索爾歸途的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可和{player}。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們能順利打倒魔物，",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是可喜可賀呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果讓牠進到蘭德索爾的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那可真的很危險呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不只針對復建計畫，",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也讓我了解到，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有時需把目光關注到",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "城鎮外正在發生的危險。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然我該執行的任務",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是堆積如山，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但很不可思議地內心覺得都有辦法解決呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為我有大家、",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有{player}在我身旁。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當我遇到困難時",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我知道你會幫助我，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你有困難時，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也一定會幫忙。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "作為王女我還有很多需要學習的事，",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但儘管如此，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還是想讓大家還有你幸福……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？　",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這道光……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我以前好像也……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！？",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你好，{player}。",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？　",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒有反應。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是翻譯功能又狀態不佳嗎？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像有溝通成功。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為看你沒反應，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以我有點不安呢。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看了電視的記者會，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "覺得我已經回去了嗎？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為距離回程的飛機還有點時間，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想著不知道能不能見到你，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一邊在街上閒晃著呢。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒想到真的就這樣碰面了，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "已經是命運了呀♪",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然我這麼說",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有一半是開玩笑的啦……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}。\n如果可以的話，距離上飛機還有一些時間，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可以跟我介紹一下你所住的街道嗎？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你所居住的地方，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我還想再多看看。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太好了！",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那我們立刻出發吧。",
        "unit_id": 105831
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是叫做商店街",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的地方對吧！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我知道我知道！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然沒有實地走訪過，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但我在日本的動畫和電影裡有看過呢。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然我的國家也有類似這種地方，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但是每個國家",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都有自己獨特的氛圍，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的很棒呢。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！　",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好厲害！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從那個購物袋",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有青蔥凸出來了耶！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是覺得奇怪，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只是因為那是在我的國家不常見的蔬菜，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以每次在以日本為背景的作品中看到時，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我都覺得很不可思議。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對我來說是不可思議的景象，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但在日本是理所當然的事，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能實際感受到我覺得很開心唷。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的！",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n無論是佐料還是當作食材，都是最棒的食物呢！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "並不是",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為那樣就吃驚的，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只是因為那是在我的國家不常見的蔬菜，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以每次在以日本為背景的作品中看到時，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我都覺得很不可思議。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是日常生活中常見的蔬菜呢。",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得很棒呢。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "欸。",
        "unit_id": 1,
        "voice": "vo_adv_1804004_024"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n那邊那個人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "不是最近來訪日本的什麼公主呀？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊啊，",
        "unit_id": 1,
        "voice": "vo_adv_1804004_025"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "好像是因為騎士大人發言引起話題的那位？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n這樣的人哪可能會出現在這……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真的在這！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "在身旁的男生就是騎士大人嗎……？",
        "unit_id": 1,
        "voice": "vo_adv_1804004_026"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n雖然騎士大人好像有點靠不住的樣子，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n但是感覺氣氛很好呢，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "那兩位。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該不會，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被發現了吧？",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來大家都有看我的記者會呢！",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然很高興，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但是給你添麻煩了，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很抱歉呢……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的嗎？",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝你。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你果然很溫柔呢。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "越來越多人聚集過來了……",
        "unit_id": 105831
