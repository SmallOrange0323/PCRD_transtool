        "name": "貪吃佩可",
        "words": "竟然這麼直接回覆，",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想開玩笑",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n反而變得好害羞了啦……",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 105831,
        "voice": "vo_adv_1804004_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的。",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n今後",
        "unit_id": 105831
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也請多多指教。\n{player}。",
        "unit_id": 105831
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "喂你呀，",
        "unit_id": 190011,
        "voice": "vo_adv_1804004_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這樣下去真的會變成貪吃佩可的騎士吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1804004_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果是你應該可以做得很出色……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然這麼說，",
        "unit_id": 190011,
        "voice": "vo_adv_1804004_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是我講的話也沒辦法傳達給現在的你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這些都只會變成我的自言自語吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說不寂寞是騙人的，",
        "unit_id": 190011,
        "voice": "vo_adv_1804004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了再見面我也會加油的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也要跟貪吃佩可一起加油喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1804004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次見囉。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯……",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_072"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "奇怪？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像感覺吃了好吃的零食呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，{player}",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_073"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像對我說了讓人非常開心的話呢……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，是我的騎士……",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_074"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}……還在睡嗎？",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_075"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像嬰兒般天真無邪的睡臉呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然你現在還沒有成為騎士大人的感覺，",
        "unit_id": 105811,
        "voice": "vo_adv_1804004_076"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n對我來說，你就是我",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最棒的騎士唷。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看著{player}的睡臉，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可打從心底感到十分滿足。"
    }
