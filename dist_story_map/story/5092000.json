        "voice": "vo_adv_5092000_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "充滿各種故事。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "有我喜歡的王道戰記、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "戀愛、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "恐怖、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "喜劇、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "冒險",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "等等。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "任何一種故事都會打動讀者，",
        "unit_id": 100911,
        "voice": "vo_adv_5092000_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "引起某種共鳴。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "最終，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那次的閱讀體驗",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就會成為寶藏。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "此次我所經歷到的是",
        "unit_id": 100911,
        "voice": "vo_adv_5092000_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "千奇百怪、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "九死一生……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就像寶藏一樣每一天。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這個故事有一點長，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但希望各位可以聽我娓娓道來。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "然後但願，",
        "unit_id": 100911,
        "voice": "vo_adv_5092000_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這篇故事也可以成為",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "各位的寶藏──",
        "unit_id": 100911
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那天，{player}跟忍約在鎮上碰面。"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你好。",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不好意思把你叫出來。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但是，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有件事我無論如何都想告訴你。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其實……",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我要暫時離開",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "蘭德索爾了。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太、",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太近了……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你的臉太近了……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "小子！",
        "unit_id": 2411,
        "voice": "vo_adv_5092000_007"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你要對忍做什麼唔呀……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "呃啊。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真是的，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我不是說過了，你虛弱的時候不要衝動啦。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "因、",
        "unit_id": 2411,
        "voice": "vo_adv_5092000_009"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "因為、",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "因為那小子對妳……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n拜託妳",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不要丟下我不管……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "要是被妳丟下了，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我就……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "放心，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我不會丟下你的。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你稍微安靜一下。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……不好意思，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓你看到那麼丟臉的模樣。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這就是我",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要離開蘭德索爾的理由。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如你所見，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我爸爸他現在非常地虛弱。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n發生原因應該是，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "工作的時候過度使用力量。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "都是因為我還不成熟，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不停地造成爸爸的負擔……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳說這什麼話。",
        "unit_id": 2411,
        "voice": "vo_adv_5092000_014"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "只要是為了忍，我可以連命都不要。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n所以妳不要太自責了。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "唔、",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "咕……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸……",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "為了讓弱化的爸爸恢復原來的樣子，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我打算進行世界靈場巡禮。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只要去到充滿靈氣的地方，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸的力量或許就會恢復了。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只是，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我不知道要去多少個地方才夠，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以這應該會是一場",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "漫長的旅途。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗚，",
        "unit_id": 2411,
        "voice": "vo_adv_5092000_017"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "讓妳辛苦了，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你說這什麼話啊，爸爸。",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "為人子女，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是理所當然的啊。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也會覺得寂寞……",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_019"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在不是說那種話的時候。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "為了爸爸，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我必須早日幫他取回力量。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "當然不行啊！",
        "unit_id": 2411,
        "voice": "vo_adv_5092000_020"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不要來打擾我跟忍的兩人之旅唔呀……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你真是……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我這次贊同爸爸的話。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這是我們的家庭問題，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒道理要你陪我們，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n踏上這場不知何時才會結束的旅行。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "事情就是這樣，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然要暫時分離，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但我們一定還會回來蘭德索爾的。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還請",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "務必保重──",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂～！",
        "unit_id": 1,
        "voice": "vo_adv_5092000_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "助手先生──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "出大事了──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呼、",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呼……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "終於找到你了，助手先生！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你聽我說！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我接到一個",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "非～常驚人的委託！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我居然",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "受邀參加那個遭詛咒海盜島的調查隊耶！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "能接到這種大案子，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就表示我身為偵探也出名了吧！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這一定會流芳百世，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n成為名偵探霞",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "系列故事的傑作！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n來吧，助手先生，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "趕緊來準備旅途上的……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……妳好。",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咳，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_029"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯嗯……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳好。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是【哞哞自衛隊】的霞，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是一名偵探。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳好，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我是【惡魔偽王國軍】的忍。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n是一名占卜師。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這位是我爸爸。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喔，",
        "unit_id": 2411,
        "voice": "vo_adv_5092000_031"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不錯呢。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "5年後的成長非常值得期待。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n狗女孩，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "多吃點飯讓各方面好好長大吧。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你不要對初次見面的人說這麼失禮的話。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真不好意思，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還請忘了我爸爸剛剛說的話。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哈哈……",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳別在意……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請妳也忘了我剛剛的醜態吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這就是所謂的雙贏呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不知道嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是現在傳得沸沸揚揚，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n關於蘭德索爾附近藏著",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "大海盜財寶的島嶼啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "被送進那座島的調查隊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都因為海盜的詛咒而全軍覆沒了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這個謠言",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "被傳得繪聲繪影呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "海盜的",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "詛咒……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請問，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那件事，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n可以詳細說給我聽嗎？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳看起來不像是",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對財寶感興趣呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "反正我也必須要跟助手先生說明，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳就一起聽吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那麼，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這件事要回溯到稍早一點說起──",
        "unit_id": 101411
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "──針對此次出現眾多的犧牲者，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n海盜島的發現者高登，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對此回以沉重的沉默。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "比起訴諸言語，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沉默更強烈地說明了",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "詛咒真的存在。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "過去大鬧全世界的海洋，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓眾人墜入恐怖的深淵，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n最強也是最兇惡的大海盜，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "愛德華‧迪德。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聽說這次發現了他埋藏祕密財寶的島嶼，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_040"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n而且那裡還被施加了海盜的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "詛咒。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_041"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說是這麼說～",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "光是傳說中的海盜島，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n聽起來就很可疑了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "更何況還有詛咒……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有點太過加油添醋了吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我因為很在意所以收集了不少情報，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_042"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "結果都跟這個八卦雜誌上的報導沒什麼不同。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這個傳言雖然讓我很感興趣，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_043"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但不是工作的話，就不可能把時間花在這種事情上。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "找助手先生一起散散步，轉換心情吧──",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不好意思。",
        "unit_id": 311,
        "voice": "vo_adv_5092000_044"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我聽說",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在這裡可以找到身為偵探的霞小姐，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n所以特地前來拜訪。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是的，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_045"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我就是霞。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從找尋遺失物到人身調查，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然還有案件調查，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都是我的業務範圍喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒想到",
        "unit_id": 311,
        "voice": "vo_adv_5092000_046"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "傳聞中的名偵探",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "居然是如此纖細的少女……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我太震驚了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_047"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你老實說我看起來不可靠也沒關係喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "富商的隨從要委託我什麼呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "啊！",
        "unit_id": 311,
        "voice": "vo_adv_5092000_048"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "我都還沒報上姓名……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n您是",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "怎麼知道的……？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這個推理很簡單啊。",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_049"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "首先，從你彬彬有禮的柔軟身段，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就可以猜想你有在伺候相當地位的人物。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果是貴族的隨從，你的衣服又稍嫌粗曠了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n從你勻稱的體格，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還有因重度勞動而骨節分明的手判斷，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你應該是商人的隨從吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "……",
        "unit_id": 311,
        "voice": "vo_adv_5092000_051"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "甘拜下風。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "您就如傳聞中的是一位名偵探呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n既然如此，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "我們也可以放心委託了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "霞小姐，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "我們想要邀請您",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "參加海盜島的調查隊。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你說海盜島……",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_052"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "莫非是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "愛德華‧迪德的那個！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "您說得沒錯。",
        "unit_id": 311,
        "voice": "vo_adv_5092000_053"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "啊啊，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "忘了自我介紹。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "我是",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "發現海盜島的商人，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "高登大人的隨從。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_054"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我原本以為那個問題島的事情只是個傳聞，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n沒想到居然是真的……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "詛咒的部分……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "尚且無法判斷是否為詛咒。",
        "unit_id": 311,
        "voice": "vo_adv_5092000_055"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "只是，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "送去調查島嶼的先遣隊……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "全軍覆沒了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_056"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "然而，",
        "unit_id": 311,
        "voice": "vo_adv_5092000_057"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "雖然調查隊無人生還，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n但他們",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "還是有成功發現某塊石板。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "根據那塊石板，",
        "unit_id": 311,
        "voice": "vo_adv_5092000_058"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "可以知道島上設有數個機關，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n以及",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "突破那些機關後，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "就能找到財寶。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "於是，",
        "unit_id": 311,
        "voice": "vo_adv_5092000_059"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "我們決定不要浪費多餘的人力，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n而是要以少數精銳",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "進行調查以尋找寶藏。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "我們邀請了優秀的專家們，",
        "unit_id": 311,
        "voice": "vo_adv_5092000_060"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "如學者及冒險者等，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "能否也請您",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "將您的知識借給我們呢？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "當然。",
        "unit_id": 311,
        "voice": "vo_adv_5092000_061"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "我們承諾發現財寶的時候，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n會分一半出來贈與各位。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說老實話，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_062"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "找到財寶一獲千金！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這種事我完全沒興趣。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是傳說中大海盜的財寶本身，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "會激起我的好奇心呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_063"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我身為偵探的直覺告訴我，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一定會有案件",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "發生！　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我明白了。",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_064"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請務必讓我參加。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "那還真是感激不盡！",
        "unit_id": 311,
        "voice": "vo_adv_5092000_065"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "高登大人",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "也會很高興的。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "不過，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "那裡是非常危險的地方，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "還請做好相當程度的心理準備。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_066"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "偵探是不會走在安全的道路上的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當我決定從事這行時，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我就已經做好心理準備了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "話說回來，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_067"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我可以帶一位助手一起參加嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有他在工作會進行的很順利，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也可以確保人身安全。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "當然。",
        "unit_id": 311,
        "voice": "vo_adv_5092000_068"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "那麼，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "我會如實轉達高登大人的。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "\n日期確定後",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "會再跟您聯絡。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "有任何問題",
        "unit_id": 311,
        "voice": "vo_adv_5092000_069"
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "也請不吝告知。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "那麼，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "隨從",
        "words": "我先告辭了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_070"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "太好了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "太好了！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "終於、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我終於接到大案子了！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我不能繼續待在這裡了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "得趕緊通知助手先生才行！",
        "unit_id": 101411
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "──",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_071"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "事情就是這樣。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很抱歉我擅自決定，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n希望助手先生務必可以跟我同行……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝謝你果斷答應，助手先生！",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_072"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那為了旅行的準備，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們等一下一起去買東西兼開會吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……那個，",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_073"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "霞。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也可以一起參加",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個調查嗎？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……嗯，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_074"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看妳若有所思的眼神，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "應該是有什麼理由吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其實──",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_075"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原來如此。",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_076"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為了幫令尊取回力量，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要進行靈場巡禮啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以這次的海盜島",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是妳說的靈場吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "尚不能斷言。",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_077"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果那是被詛咒的島嶼，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我想它應該",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "會跟世界各地的靈場一樣",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "充滿許多靈力。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "至少",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_078"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我對占卜還有靈能力是很有自信的。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我絕對",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不會妨礙到兩位。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你似乎",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_079"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很信任忍呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n既然你都這麼說了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那就不會錯吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說老實話，",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_080"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我對詛咒這類的東西一竅不通。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果有熟悉此道的人一起同行，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對我的幫助也很大。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那我趕緊",
        "unit_id": 101411,
        "voice": "vo_adv_5092000_081"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "跟那位隨從先生聯絡看看。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "麻煩妳了。",
        "unit_id": 103113,
        "voice": "vo_adv_5092000_082"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太好了呢，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "謝謝妳們，",
        "unit_id": 2411,
        "voice": "vo_adv_5092000_083"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍、",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "霞……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "小伙子就算了。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "此時的四人還不知道，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n之後他們將被捲入滔天案件之中。"
    }
]