[
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔～",
        "unit_id": 128411,
        "voice": "vo_adv_5134302_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這次的夢也不是我想要夢到的……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "下次",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一定要夢到依照作戰計畫將隕石破壞掉的夢才行！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "關於這件事，",
        "unit_id": 128511,
        "voice": "vo_adv_5134302_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我認為剛才或許是因為睡在堅硬的長椅上，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n才導致預知夢的準確度下降了也說不定。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以說祈梨，",
        "unit_id": 128511,
        "voice": "vo_adv_5134302_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然很抱歉，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是能不能讓初音躺在妳的腿上呢？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果她能夠睡個舒服的覺，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "或許就可以夢到好的結果。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥！？",
        "unit_id": 128311,
        "voice": "vo_adv_5134302_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n為什麼我非得做那種事不可啊！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就由小哥代替我去給她躺啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那、",
        "unit_id": 128511,
        "voice": "vo_adv_5134302_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那可不行！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這樣太讓人羨……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不對，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是有可能害她覺得緊張，反而睡不好！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小霞，",
        "unit_id": 128411,
        "voice": "vo_adv_5134302_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "妳怎麼這麼緊張呀？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總之就照祈梨說的，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n躺在你的腿上試試看吧……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕……♪",
        "unit_id": 128411
    }
]