[
    {
        "type": "background",
        "background": "502791"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "終於，明天",
        "unit_id": 126511,
        "voice": "vo_adv_5213104_000"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "「公主小餐館」就要正式登場了呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這樣一來，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "「快閃小餐館」也要告一段落了……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "多少，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還是會有點依依不捨呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "多虧大家的支持，",
        "unit_id": 133111,
        "voice": "vo_adv_5213104_001"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "客人們的反應也很好，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "讓我增添了不少自信。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "料理的手藝，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我覺得也似乎有所提升了呢。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "話雖如此，",
        "unit_id": 129711,
        "voice": "vo_adv_5213104_002"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "兩位。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "在招待客人，端上料理時，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n客人們可曾出現過什麼",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奇怪的舉動嗎？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "或許僅是奴家這桌如此──",
        "unit_id": 129711,
        "voice": "vo_adv_5213104_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "客人將料理納入口中之際，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家瞧見其",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "或是眼眶濕潤、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "雙頰飛紅，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "乃至呼出一縷艷麗之氣。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "哎呀，",
        "unit_id": 133111,
        "voice": "vo_adv_5213104_004"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "連涅妃‧涅羅皇女也是嗎……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "其實",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我這邊的客人也是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "該、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "該怎麼說呢，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "露出了恍惚的表情……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "簡直就像是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就像是",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那個……！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "非常抱歉，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我實在說不下去了……！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是的，",
        "unit_id": 126511,
        "voice": "vo_adv_5213104_005"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我那時候也是如此。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "說到這個──",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我想起來了……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n那時刻在",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "底座上的格言。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那個……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「能令齒頰生香，",
        "unit_id": 129711,
        "voice": "vo_adv_5213104_006"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "尚為半吊子。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n得使裳福奔騰，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "方稱真行家。」",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "哎呀，",
        "unit_id": 133111,
        "voice": "vo_adv_5213104_007"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "沒想到您",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "竟然還能背出來呢。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "如果把「裳福」……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "理解成「衣服」的話，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n就等於格言所說的事發生了……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是這個意思嗎？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "但是……",
        "unit_id": 133111,
        "voice": "vo_adv_5213104_008"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我的技藝",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "仍然很不成熟。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還沒有達到可以自稱",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "真行家的程度。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不──",
        "unit_id": 126511,
        "voice": "vo_adv_5213104_009"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "薇歐莉特公主，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我認為料理",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就是心意",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "與愛情。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "如果是這樣的話，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那妳一定已經是一位",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "行家了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──原來如此。",
        "unit_id": 129711,
        "voice": "vo_adv_5213104_010"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "聽聞用心烹製之料理，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n有時甚至",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "可凌駕廚者之技藝。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "以母親的料理為天下第一者，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "想來亦不在少數。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵呵──",
        "unit_id": 129711,
        "voice": "vo_adv_5213104_011"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "既如此，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若奴家等人亦得品嘗用心款待之佳餚，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n這身裳服或許也要迸裂了呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵，",
        "unit_id": 126511,
        "voice": "vo_adv_5213104_012"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "妳在開玩笑吧……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "咦，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "發生什麼事了嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "哎呀，",
        "unit_id": 133111,
        "voice": "vo_adv_5213104_013"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那個飯糰……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是您親手",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "捏的嗎？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n是為我們做的嗎……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……恁，",
        "unit_id": 129711,
        "voice": "vo_adv_5213104_014"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "將心意",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "注入其中……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "…………\n……",
        "unit_id": 129711,
        "voice": "vo_adv_5213104_015"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…………",
        "unit_id": 126511,
        "voice": "vo_adv_5213104_016"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你的心意，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我很高興。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但是",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "現在……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "因為剛才試吃太多，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "肚子已經飽了……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n之後我會悄悄地",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "一個人享用喔。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我、",
        "unit_id": 133111,
        "voice": "vo_adv_5213104_017"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也是。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那個……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "雖然很想，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "現在就品嚐。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……嗯，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我想做成便當帶走。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
