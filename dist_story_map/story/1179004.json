    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "說起來，",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_045"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才到底跑去哪了～！？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n都說了在這裡等，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "結果根本找不到人～！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n真是的！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家真的很擔心耶！！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……咦？",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_046"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼？",
