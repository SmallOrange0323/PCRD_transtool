    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你有事情",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "想拜託人家嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼意思？",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_047"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n……反正閉上",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "眼睛就對了？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人、",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家知道了……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才的手",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_048"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "碰到頭髮了。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有點癢癢的，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過",
