        "voice": "vo_adv_1179004_044"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這不是秀才嗎！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n太好了……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家還以為找不到你了～！",
