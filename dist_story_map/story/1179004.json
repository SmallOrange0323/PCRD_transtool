        "voice": "vo_adv_1179004_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不好意思～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n買飲料花了不少時間……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？",
