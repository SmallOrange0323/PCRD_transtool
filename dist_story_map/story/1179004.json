        "voice": "vo_adv_1179004_052"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這是什麼？",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_053"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "髮飾……？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你說要是能稍微體驗到變裝的氣氛就好了……",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_054"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你剛剛是去找這個？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "原、",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_055"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "原來是這樣。",
        "unit_id": 101631
    },
    {
