        "voice": "vo_adv_1179004_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在萬聖節玩得這麼開心過！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，你也玩得開心嗎？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那太好了～",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "派對的氣氛也很嗨，真是讚到爆了！",
        "unit_id": 117911,
        "voice": "vo_adv_1179004_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大家約好了明年繼續辦，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "到時候秀才也──",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "奇怪，",
        "unit_id": 117911,
        "voice": "vo_adv_1179004_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "怎麼感覺這麼亮？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "該不會，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "現在要來續攤嗎？",
        "unit_id": 117911
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在換上萬聖節裝飾的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鬧區散步。"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈嚕──！",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才♪",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈哈！",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有必要那麼驚訝嗎♪",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "居然在這裡碰到你，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真是太巧了。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你在散步嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "話說回來，",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你不覺得今天的鬧區很讚嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所有人都變裝了。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "很有萬聖節氣氛的說。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對呀對呀，",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "萬聖節……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的假的？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "奇怪？",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "前一段時間不是才",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "慶祝過萬聖節嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家攝影的時候還穿了萬聖節的衣服耶！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……你說雜誌要在萬聖節發售的話，",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n需要提前攝影？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "原來是這樣，",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才真聰明～！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……不對，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "現在沒時間佩服你了！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "天啊天啊！",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "該怎麼辦秀才！？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "本來想要好好享受萬聖節，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "結果什麼都沒準備～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "難得的節慶，",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不大玩特玩不就太可惜了嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "現在準備",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還來得及嗎～？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……咦？",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才有空嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那就陪人家一起",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "找有賣服裝的店家吧！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要過萬聖節，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "肯定要變裝的嘛！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "全都沒了……",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n變裝的衣服，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "每間店都沒有了啊～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯……",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒有就算了吧。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那我們",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "改變計畫──！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你不是沒其他事情嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和人家來個萬聖節約會吧！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈哈！",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "幹嘛那麼驚訝～☆",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那邊有人在排隊，感覺滿好玩的～！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才一起去看看吧？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇！",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太正點了吧！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這裡的人全都變裝了！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n而且人有夠多～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "播報員",
        "words": "萬聖節遊行",
        "unit_id": 1,
        "voice": "vo_adv_1179004_018"
    },
    {
        "type": "dialogue",
        "name": "播報員",
        "words": "即將開始。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "播報員",
        "words": "\n屆時現場將會十分擁擠，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "播報員",
        "words": "\n觀賞的遊客",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "播報員",
        "words": "請務必多加小心──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要開始遊行了耶！",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n難怪人這麼多～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊！",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n欸欸，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才啊。",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "把手伸出來一下好不好？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要是走散就糟了，",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們要不要",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "牽個手？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家小時候",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和家人",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一起出門的時候，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n為了避免和弟弟走散，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "會把手牽起來～",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "而且你不覺得",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "牽手很有約會的感覺嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那我們",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也去看遊行吧～♪",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家越來越",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "期待了～！",
        "unit_id": 101631
    },
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嘿，秀才。",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不覺得這個遊行",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超讚的嗎？",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有些人的Cosplay超用心的！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇哇！？",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n遊行結束後，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大家突然都開始移動了……",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "喂！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "別擠啊～！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呼……",
        "unit_id": 101631,
        "voice": "vo_adv_1179004_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你～！",
        "unit_id": 101631
    },
    {
        "type": "dialogue",
