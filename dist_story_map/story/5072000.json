    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在盛夏豔陽下的海邊。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n慈樂之音的三人正為了近日即將舉行的演唱會燃起了鬥志。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}，今天很謝謝你！",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "連我們的攝影工作都來支援，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是幫了我們一個大忙！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是啊。",
        "unit_id": 117311,
        "voice": "vo_adv_5072000_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我還不習慣拍攝的工作，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以很緊張……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "多虧有{player}在，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我才能有最自然的表現。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……話說回來，",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你為何會像是理所當然地待在這裡啊？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我並沒有聽說",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生會在這裡呢。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……聽妳這麼一說，",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "確實是這樣。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 117311,
        "voice": "vo_adv_5072000_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我以為他會在這裡是很理所當然的呢。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "連小望和千歌也都不知道嗎！？",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那為何還大大方方地一起工作啊！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呃不，",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "其實我剛才也是很自然地就請他幫忙了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……太誇張了吧，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這位騎士先生的融入力。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣不是很好嗎。",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天的拍攝，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希不知怎地表現得很有幹勁呢！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "姿勢擺得",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "比平時還要吸睛呦。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感覺就好像希望某人的視線能多停留在自己身上一樣♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啥、",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啥！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啥啊～！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳在說什麼啊，小望！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我只是因為",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這次的演唱會服裝是我的得意之作所以特別有幹勁……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我為何非得讓騎士先生一直盯著我看啊！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "紡希？",
        "unit_id": 117311,
        "voice": "vo_adv_5072000_009"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n望她並沒有特別提到",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}的名字喔？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "～～～！",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "千、",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "千歌妳還不是一樣！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n在拍攝中",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一直偷偷觀察著騎士先生的反應！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那、",
        "unit_id": 117311,
        "voice": "vo_adv_5072000_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那種事……！",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n真是的，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "紡希……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請不要把我也給拖下水……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵♪",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "兩位看起來似乎很開心呢。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有{player}在真是太好了。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……不過，說真的，",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "究竟為何{player}會在這裡啊？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "該不會是",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "跟誰來海邊玩之類的、",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "吧？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對方是女孩子？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……應該不是吧？",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那、",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那她是──",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是我。",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_015"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "製作人！？\n製作人小姐！？",
        "unit_id": 1,
        "voice": "vo_adv_5072000_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "女孩子……？　",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是我帶這小子過來的。",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n因為有事情要拜託他。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "至於那邊的粉紅女，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "待會我再來好好聽妳解釋為何會一臉訝異。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚欸！？",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話說回來，妳們三個，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要是以為拍攝工作結束了就可以鬆懈下來，我會很困擾的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳們該不會已經忘了，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n接下來還有一項更重要的工作吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才沒這回事呢，",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "製作人。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "當然",
        "unit_id": 117311,
        "voice": "vo_adv_5072000_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "沒有忘記。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我一直都保持著",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "高度的專注力。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "──慈樂之音的夏日演唱會。",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "觀眾人數是至今以來最大規模，",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "歌曲也全數網羅。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一切就從這裡開始。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們慈樂之音的",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "夏日巡迴演唱會！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "眼神很不錯嘛。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "熠熠生輝的眼神我並不討厭。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對了，之前還沒有問過妳，",
        "unit_id": 117311,
        "voice": "vo_adv_5072000_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n為何",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "巡演是從這裡開始呢？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "製作人小姐。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說得也是。",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這裡只是一般的海水浴場，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n如果是製作人，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我認為應該會選定",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可以盛大地聚集更多人的場所……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……怎麼，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳們還不知道嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "表明想要選定這裡做為巡演起點的人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可是站在那裡的望喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦？",
        "unit_id": 117311,
        "voice": "vo_adv_5072000_030"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n是這樣嗎？",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯。",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n提出這次的巡演計畫時，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我稍微表明了自己的期望。",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……？",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n真難得，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "想不到小望竟然會指定場所……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先不說這個了，妳們三個聽著，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這次的夏日演唱會堪稱是慈樂之音",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不折不扣的集大成之作。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "由我擔任製作人，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就絕不允許隨隨便便的妥協。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "好的！",
        "unit_id": 1,
        "voice": "vo_adv_5072000_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "既然決定了，千歌、",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "紡希！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那我們就立即去做準備吧！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦！？",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "小望……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今天拍攝結束後不就準備收工休息了嗎？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原本是打算這樣沒錯啦，",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只是一聊到演唱會的話題，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我就再也",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "忍不住了！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真沒辦法。",
        "unit_id": 117311,
        "voice": "vo_adv_5072000_039"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "望一旦變成這樣，",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n就算只有她一個人也會埋頭苦練……",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們就直接去做演唱會的事前準備吧。",
        "unit_id": 117311
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼，",
        "unit_id": 117211,
        "voice": "vo_adv_5072000_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們就出發囉！",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好了，妳們兩位，",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "快跑快跑♪",
        "unit_id": 117211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的，",
        "unit_id": 117411,
        "voice": "vo_adv_5072000_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "小望還是老樣子……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "馬上就跑遠了啊。",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那邊交給她們應該不會有問題。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……接下來，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼小子，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們也該談正事了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你知道我為何會",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "找你過來這裡嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈！",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子你還真是天真哪。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你想跟我一起在海邊遊玩嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔呣……",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖說我個人很有興趣想知道你究竟想跟我玩些什麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，我找你來這裡是另有原因的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "相當敏銳嘛。",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這樣事情就好說了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我之所以會帶你來海邊，不為別的，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是想要請你為我做件只有你才辦得到的事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別緊張，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這不是什麼難事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了配合這次的演唱會，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我打算要出一本書，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n用來收錄慈樂之音至今為止的活動紀錄，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也就是",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "慈樂之音的歷史彙整。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……所以說、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呢……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "望、",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "千歌和",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "紡希。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我想讓你貼身採訪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "她們三個。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你覺得不安嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n的確，畢竟你並不是專業的採訪人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣正好。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不需要採訪描述她們「身為偶像所塑造出的形象」。",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讀者所期待的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是慈樂之音毫無掩飾的一面。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就由你去引出她們毫無掩飾的一面吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你辦得到吧？",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我可不會讓你說出「辦不到」這種話喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "她們三個，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論有什麼話都會對你說。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "話雖如此，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "採訪的問題我這邊會準備。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果交給你，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大概只會想到「喜歡吃的食物是什麼？」",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這類的問題吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好啦，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n既然知道自己的任務了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那就快去吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "拜託你囉，",
        "unit_id": 107111,
        "voice": "vo_adv_5072000_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "面對即將到來的夏日演唱會，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了更加深入了解慈樂之音，\n盛夏一幕就此展開。"
    }
]