[
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蘿依尋找著新的工作地點，\n雖然有幾份工作面試沒通過，\n不過被以年輕人為客群的二手衣店錄取，站在賣場裡。"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "歡迎光臨",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n妳在找什麼衣服嗎――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "吶，",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_001"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "店員。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n我想買這件衣服，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "有沒有大一號的尺寸？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "抱歉，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "如果架上沒有的話就沒有了呢――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "這樣啊……",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_003"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "我很喜歡這個設計，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n但這個尺寸對我來說有點太小了，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "怎麼辦……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "吶，",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_004"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "店員？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n妳覺得",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "如果是這種比較合身的穿法，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "還適合嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊……",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼說好呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是不錯啦，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過以姐姐來說，比起緊繃感，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n寬鬆的感覺可能會比較適合妳。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "咦？",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "還有說真的那個設計，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n很難搭配下身，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那樣子沒問題嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "咦……",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_008"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "那個……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "沒，",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_009"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "沒問題的唷！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "因為客人很可愛",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "所以穿什麼都很完美唷！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "呵呵呵，",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_010"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那麼",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "請慢慢看～！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "……",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_011"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "克蘿依。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n可以來這邊一下嗎？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_012"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我說克蘿依～妳啊！",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼事店長。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_014"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "欸！",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_015"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n不是還有",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "更圓滑點的說法嗎！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n妳這樣還算是貼近顧客的接待態度嗎！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊……",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "要巴結客人的意思嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我可沒這麼說。",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_017"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "反正妳，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n也不適合笑咪咪地表現親切，對吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然馬上就被否定的感覺很微妙，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過的確是這樣呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那個呀？",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_019"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n妳那種，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n很沒勁，和人疏離的個性，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我是不介意啦。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "原來不介意啊。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_020"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嗯，",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_021"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "像我們這種主打年輕人客群的店，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n有個性的人才",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "也會比較受歡迎？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "從店長的角度來看是指那個嘛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "THE‧個性。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "對我自己來說，",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_023"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n我想要讓客人有一種",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "來見朋友的感覺",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n也比較會",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "讓人想進來呢。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "但再怎麼說，",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_024"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我們是服務業。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "得讓客人心情變好，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n卯起來購買商品才行。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "因為客人身材不好，",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_025"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "所以應該要把身體的線條藏起來之類的，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n那種多餘的話不需要特別說出來唷。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哎呀，我，沒有說的那麼直接啦。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_026"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "聽起來也差不多唷。",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_027"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不行唷，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這種年紀的女孩子",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "對那方面很敏感的。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_028"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "的確呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "抱歉，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我會注意的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "……什麼嘛，",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_029"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "妳那個。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "在鬧彆扭嗎？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，完全沒有。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_030"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你說得很有道理，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我也很認真的在反省。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我的表情天生就長這樣。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嗯……",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_031"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "像這種類型的孩子",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n原本想說有一個的話應該會很有趣，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "就錄用了――",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "但該不會是我看走眼了呢。",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_032"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n妳還是……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不適合、",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這份工作吧？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_033"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我真的有在反省啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n啊不是，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我正在反省了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "請讓我繼續在這裡上班。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_034"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是嗎？",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_035"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "既然這樣",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "就讓我再多觀察一下吧……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "哎呀，",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_036"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "有新的客人來了喔。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那麼克蘿依，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "交給妳囉。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "遵命。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_037"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n歡迎光臨～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "出現了。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_038"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n又來了啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n已經變成習慣了啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，你來幹嘛。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_039"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這裡是賣女裝的服飾店，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "{player}，我應該把你當作是有那方面興趣的朋友嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_040"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "如果你是認真的話，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那也完全沒問題啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n男裝女裝之類的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "只是為了方便而區分的，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "只要不是可疑的變態之類的話，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我甚至願意幫你加油。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以，我再問你一次。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_041"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你來幹嘛的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "想也是如此。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_042"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n嗯，大概懂了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_043"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "今天也許是最後一天。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然，我是無所謂啦。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_044"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n反正本來就打算兼職嘗試不同的工作，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "只要再找其他地方……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_045"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有一點？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "因為剛剛，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n被罵不適合",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這份工作。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_046"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我的頭要痛了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "再怎麼說，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我都秉持著以客為尊的態度啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你看，因為、",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_047"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "從客人角度來看啊？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n客人都是拿著揮汗賺取的錢，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "或努力存下的零用錢，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n為了尋找自己喜歡的衣服而來到這裡的吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但是這時候隨便地就被釣上鉤，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_048"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n最後買了不適合的衣服的話，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n仔細想想不是有點悲慘。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我不禁就會那麼想……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是嗎。",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_049"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的很溫柔的話，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n就不會",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "被說不適合了吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，但是，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_050"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "謝謝你。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n能夠對我這麼說，感覺稍微被安慰到了唷。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗……",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_051"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "反省，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "轉換心情吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過，話說回來，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_052"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n要判斷適不適合的還是當事人呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "即便被問了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "別人也無從置喙呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_053"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你剛剛迷路了吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我差不多可以休息了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你等一下。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n讓我送你到容易找路的地方――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "店員，",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_054"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "可以打擾一下嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_055"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳是剛剛的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "那個？　",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_056"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "我自己也不是很懂，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "我想說",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "可不可以請店員",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "一起陪我選呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？　",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_057"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……是沒問題啦，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過為什麼？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "因為妳，",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_058"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "是可以信任的。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "而且看到覺得奇怪",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "也會和我說。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊――",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_059"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那件事……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "很抱歉。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "嗯嗯，",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_060"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "沒事啦沒事啦。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "雖然剛剛一瞬間嚇了一跳，",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_061"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n不過比起",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "買了後悔，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "這樣好得多！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "妳能誠實的告訴我是幫了我大忙――！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "啊對了，",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_062"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "能夠告訴我",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "妳的名字嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_063"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我叫克蘿依……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "克蘿依。",
        "unit_id": 1211,
        "voice": "vo_adv_1108005_064"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "今後也請多多指教呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "謝、",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_065"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "謝謝。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我才要請您多指教。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊……",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_066"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那麼，對了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳等一下唷。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n其實我覺得有件衣服",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "很適合姐姐。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我現在就去拿過來。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個，",
        "unit_id": 110811,
        "voice": "vo_adv_1108005_067"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我記得是在這附近……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "克蘿依。",
        "unit_id": 2511,
        "voice": "vo_adv_1108005_068"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我都看到了唷。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，店長……",
        "unit_id": 110811,
