    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在激戰那麼久以後還那麼興奮地宣示勝利，",
        "unit_id": 104311,
        "voice": "vo_adv_5061402_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "當然會變成那樣啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，做得好哦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這場勝利都多虧了妳呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不，",
        "unit_id": 105212,
        "voice": "vo_adv_5061402_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我之所以能戰鬥到現在，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n都是多虧了真琴和真步哦。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳們兩位為我上了課，",
        "unit_id": 105212,
        "voice": "vo_adv_5061402_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而且在戰鬥當中也時常幫助我不是嗎？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這場勝利是大家的功勞，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "對吧♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真有莉瑪的風格呢～",
        "unit_id": 101011,
        "voice": "vo_adv_5061402_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們也是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
