[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？\n唷呼～♪",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻，\n歡迎來到【伊麗莎白牧場】♪",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你又在做運送郵件的工作嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣啊～\n總是這麼努力工作，真了不起呢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是個好孩子～♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然人家也想幫忙，\n不過魔物討伐隊還在附近徘徊……",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大家都交代我\n最近不能出去外頭。",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過要像小鈴一樣二十四小時都窩在房裡，\n人家",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可是會窒息的……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我偶爾會看準討伐隊的人們不在的時機\n到外頭散散步。",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過討伐隊的人們也不是很閒，\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "應該過幾天就會離開了吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "在那之前只能好好忍耐，\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "乖乖躲著",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻。\n靜待好事自然來。",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這幾天應該就會平穩下來了～♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……嗯嗯？\n你說對不起？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n你為",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "什麼要道歉呢？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就算和你同樣是人類的其他人做了過分的事，\n也都不是你的錯哦？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒關係啦。\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我已經習慣",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這種事了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "寄宿在牧場裡的這段期間\n過得太平靜，所以就忘記了……",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "從前總是被當成魔物對待，\n被四處追趕是日常常見的光景。",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "只不過是稍微回到從前的樣子，\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "未來也還充滿希望和和平……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "只要還這麼相信著，我就沒事哦。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以請不要擺出那種表情唷♪",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呀，好刺眼！",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n那、",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那是怎麼回事？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n有什麼在發光……？",
        "unit_id": 105211
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "…………",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_019"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪、",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪？",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（咦，難道說人家迷路了嗎？）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪～，",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "？",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（這裡是哪裡？）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪！莉瑪莉瑪，莉瑪？",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_022"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（啊！",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n在那裡走動的是？）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪～！",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（{player}～！）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，莉瑪莉瑪？",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_024"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（咦，為什麼要逃跑呢？）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪～？\n（你忘記人家了嗎～？）",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪！莉瑪，莉瑪莉瑪",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "？",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（對對，就是我！",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n是莉瑪，不可以忘記哦？）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，莉瑪……莉瑪莉瑪♪",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（嗯，嘻嘻……你好♪）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_028"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪？莉瑪",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "？",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（你在這裡做什麼呢？散步？）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪，莉瑪莉瑪。",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_029"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（我也在散步，",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不過迷路了。）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪，",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_030"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪。",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（因為天氣很好，",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n走著走著太開心就迷路了。）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，莉瑪莉瑪～♪",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_031"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（一回過神來，就到城鎮裡頭了～♪）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪，莉瑪……",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_032"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（不過要是不快點回家……）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，莉瑪～。",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_033"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（別人會以為我逃走了，",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n之後就不會再讓我外出了呢。）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，莉瑪莉瑪。",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_034"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（所以想快點回去。）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪，",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_035"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪～？",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（你知道我回家的路嗎？）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "…………",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_036"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪。莉瑪莉瑪～……",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（嗚嗚。",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n好像聽不懂我的話，雖然這是理所當然的。）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪。",
        "unit_id": 105231,
        "voice": "vo_adv_1052004_038"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪～",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（沒有辦法呢，",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n畢竟我們的種族不一樣。）",
        "unit_id": 105231
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了。",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後，很快就會忘記的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在城鎮裡突然與動物相遇～\n這非常有夢的感覺呢……",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想你也\n很快就會發現是夢了才對。\n",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……應該不會吧♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正啊～",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想今後你也會做好幾次類似的夢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，\n你要多和莉瑪說說話哦。",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就像你剛才夢到的場景……\n那孩子在『那邊』，",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n基本上只能說出莉瑪莉瑪～之類的話。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以你們無法對話",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "，\n基本上只能單方面地說話。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，在『這邊』卻辦得到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們的相遇，\n就像是繪本般的奇蹟……",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要好好珍惜、好好和睦相處哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然種族相異，\n是非常難以跨越的藩籬。",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在歷史上，\n也因此發生過幾次悲劇。",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正因為如此，\n",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們才更要……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我是這麼認為的哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果是引發許多奇蹟的你，\n就能辦到。",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我會",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "替你加油的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，\n這次我就先失陪了。",
        "unit_id": 190011,
        "voice": "vo_adv_1052004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n掰掰",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "～下次見囉♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "{player}～……？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_053"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "怎麼了嗎？\n突然就發起呆來？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_054"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "果然是工作過頭，\n太累了是不是？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_055"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是沒有急事，\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_056"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就在【伊麗莎白牧場】好好休息吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家會好好款待你～♪",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_057"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n會請你吃好多好多",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n點心還有茶。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。\n隨時都非常歡迎你來唷。",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_058"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然牧場在山上，\n來這裡會有些辛苦。",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_059"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "偶爾不要為了工作，來這裡玩玩吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為，\n有一陣子不能見到你……",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_060"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n人家非常寂寞哦。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？\n咦，你說什麼？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_061"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n莉瑪莉瑪～……是？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是在叫我？\n真陽她，",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_062"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n是會叫我莉瑪莉瑪啦……？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等等，停下來啦？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_063"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不要連續莉瑪莉瑪～莉瑪莉瑪～地叫好嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然不懂怎麼回事，\n不過讓人家非常不安……！",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_064"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔、",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_065"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n謝謝",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你停下來。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你是怎麼了……\n總感覺你像是睡迷糊了一樣？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_066"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "難道說，\n你剛才也站著睡著了嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_067"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔，\n好像夢見了不可思議的夢？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_068"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n是什麼樣的夢？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？在夢裡見到我？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_069"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊、啊……？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這麼在意人家，\n在意到連在夢裡也會見到我是吧？",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_070"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "總覺得很開心……",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_071"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n嘻嘻♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我偶爾\n也會做夢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_072"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "早上起床，發現自己變成普通的人類女孩……",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_073"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就像隨處可見的女孩一樣，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n歌頌著極為平凡的幸福日常。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，夢終究只是夢。",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_074"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以夢醒了，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就會感到有點寂寞……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我就只能扮演好自己",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_075"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "，\n在這個現實裡好好活下去。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "偶爾做做夢，\n也不錯對吧……♪",
        "unit_id": 105211,
        "voice": "vo_adv_1052004_076"
    }
]