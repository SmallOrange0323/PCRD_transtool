        "voice": "vo_adv_1180001_062"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哈！",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_063"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這件事我早就明白得很了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……要是她能夠稍微克制點，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n王宮的恩格爾係數也能獲得些改善……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還有呢？",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_064"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我先說清楚，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如果是那種我早就知道的資訊，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可是換不到報酬的喔。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唔嗯……",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_065"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一、",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_066"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一百個！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然早就知道公主殿下吃很多，",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_067"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但這未免也太多了吧……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如此的量，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是要怎麼塞進那身軀裡……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不對！",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_068"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n總、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總之不是這種的！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我要的是更……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "更派得上用場的情報，快說！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯……",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_069"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊♪",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "！",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_070"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "想到什麼了嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "胸部，",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_071"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很大～！",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要論胸部我的比她大啦──！！！",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_072"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n接下來一段時間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克蕾琪塔不斷試圖從{player}兩人身上打聽出情報……"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……呼、",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_073"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呼……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n看、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "看來完全就是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "徒勞無功呢……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "突老～？",
