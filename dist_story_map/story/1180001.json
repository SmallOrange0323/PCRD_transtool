        "voice": "vo_adv_1180001_075"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好啦，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們可以走了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "掰掰～！",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_076"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……哎呀。",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_077"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n差點忘了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們先慢著。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚～？",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_078"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這是金幣……",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_079"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "形狀的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "巧克力。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n給你們",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "回去路上吃吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哇～♪",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_080"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_081"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "真令人意外。",
        "unit_id": 411,
        "voice": "vo_adv_1180001_082"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n原來您也有會對",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "小朋友溫柔的一面。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這才不是",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_083"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳想的那樣。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "只是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然盡是些沒有價值、",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_084"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "無聊至極的情報，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但他們好歹也算是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "提供了資訊給我……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n和這份勞力相對應的報酬，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我還是會支付的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好了，",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_085"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "準備回去了，秘書一號。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n依妳的個性，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n肯定已經將這一帶的清除工程所需指示都處理完畢了吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是的。",
        "unit_id": 411,
        "voice": "vo_adv_1180001_086"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n狀況很順利。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那很好。",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_087"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然如此，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就沒有理由再待在此處了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n而且待處理的一般業務也還積得跟山一樣高……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "最重要的是！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我還得來好好籌備一下作戰計畫呢♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您指的是──",
        "unit_id": 411,
        "voice": "vo_adv_1180001_088"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當然就是！",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_089"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可以給那個天真到不行的公主殿下",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一點顏色瞧瞧的作戰囉～♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是喔……",
        "unit_id": 411,
        "voice": "vo_adv_1180001_090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "受貴族議會所委託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n擔起復興蘭德索爾大任，視錢如命的女商人──克蕾琪塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "她對貪吃佩可的看法產生變化──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那是還需要一些時日才會發生的事了。"
    }
]