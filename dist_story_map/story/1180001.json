[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我的克蕾琪塔之塔啊啊啊──！！！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_000"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──自【憤怒‧軍團】的少年卡里莎，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n進行第一次襲擊後，過了數日。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由克蕾琪塔‧凱許擔任公會長的【里士滿工商會】，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在著手進行把被破壞的建築物及瓦礫清除的工程。"
    },
    {
        "type": "dialogue",
        "name": "工作人員們",
        "words": "嘿咻──！",
        "unit_id": 1,
        "voice": "vo_adv_1180001_001"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "各位，",
        "unit_id": 411,
        "voice": "vo_adv_1180001_002"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那邊的大石柱碎塊",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "請搬到石頭工匠那邊。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n鐵材則請",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "搬到鍛冶場去。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n我已經事先做好安排，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "盡可能將這些資源回收再利用。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "工作人員們",
        "words": "了解──！！",
        "unit_id": 1,
        "voice": "vo_adv_1180001_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唉……",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_004"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……",
        "unit_id": 411,
        "voice": "vo_adv_1180001_005"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唉唉唉…………",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_007"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐。",
        "unit_id": 411,
        "voice": "vo_adv_1180001_008"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n若您想要唉聲嘆氣，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "還麻煩回辦公室進行。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n您這只會妨礙清除工程。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下，我說妳呀！",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n竟把雇主當成礙事者，是什麼意思！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就算您問我",
        "unit_id": 411,
        "voice": "vo_adv_1180001_010"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "什麼意思……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n我不過是陳述事實罷了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "且看。",
        "unit_id": 411,
        "voice": "vo_adv_1180001_011"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n因為克蕾琪塔小姐擋住了通路，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n導致作業人員現在都無所適從。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_012"
    },
    {
        "type": "dialogue",
        "name": "工作人員們",
        "words": "感恩！",
        "unit_id": 1,
        "voice": "vo_adv_1180001_013"
    },
    {
        "type": "dialogue",
        "name": "工作人員們",
        "words": "\n抱歉借過──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唉……",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……剛才他們搬的是……",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n克蕾琪塔之塔",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "裡的水晶吊燈吧……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "正確來說，",
        "unit_id": 411,
        "voice": "vo_adv_1180001_017"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是水晶吊燈的殘骸。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不用特地糾正我的用詞啦！",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唉……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "克蕾琪塔之塔……",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "克蕾琪塔之塔……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總共傾注了10億盧幣建造費，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我心心念念的新公會小屋啊……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊，",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_020"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是的……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為什麼會變成現在這樣！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那個臭小鬼，",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是不可饒恕！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n他好像是什麼【憤怒‧軍團】對吧！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n還有那個，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "超級胡來的公主殿下一行人！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "呃……",
        "unit_id": 411,
        "voice": "vo_adv_1180001_022"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n不只【憤怒‧軍團】，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您連尤絲蒂亞娜陛下也要怪罪嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是呀，",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n沒錯沒錯沒錯！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳仔細想想看？",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "正因為王宮負責的警備體制沒有徹底做好，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n才會讓那種慘無人道的恐怖攻擊有機得逞吧！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這已經可以說是",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "國家執政不力了吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n換句話說，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "完全就是那個公主殿下的責任呀！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n真是令人氣憤哪，不可原諒！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……",
        "unit_id": 411,
        "voice": "vo_adv_1180001_026"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "維持國家治安的中心──",
        "unit_id": 411,
        "voice": "vo_adv_1180001_027"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "【王宮騎士團】被冒牌尤絲蒂亞娜給利用，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n並且在經歷對其的鎮壓戰後戰力大幅削弱……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "但在約兩個月前，",
        "unit_id": 411,
        "voice": "vo_adv_1180001_028"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "【王宮騎士團】原本打算擴增軍備，\n最後該項預算卻遭到削減。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n我記得這可是豪紳議長",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "和克蕾琪塔小姐您所下的決定哪。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔唔",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_029"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我、",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也只不過是，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n遵照議長的命令作帳而已！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我可不想聽妳說什麼",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "因果報應之類的字眼喔！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總～而～言～之！！",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_031"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不找個機會給那個公主殿下一點顏色瞧瞧，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我不甘心！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有沒有什麼好點子……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "葛～格～♪",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_032"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n呀哈哈～♪",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯嗯？",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_033"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "克蕾琪塔小姐？",
        "unit_id": 411,
        "voice": "vo_adv_1180001_034"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n那邊的人",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "有哪裡令您在意嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n……看起來只是一對感情很好的兄妹啊。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……之前妳人不在場，",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n所以可能不知道。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n他們就是我剛提到的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "「超級胡來公主一行人」成員。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唉，",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_036"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真受不了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "公主殿下也真是的……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為什麼要跟那種明顯家教不好的傢伙混在一起呢？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "實在是沒有身為一國之主的自覺哪……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……！",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_037"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼、",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_038"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼哼哼……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我想到～一個好主意了♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下！",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_039"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那邊的兩個人！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n快過來這裡！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚～？",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼──",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_041"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還真就這樣傻傻地",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "跑到我面前來了呀。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n之前你們可給我",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "徹底地大鬧了一場哪。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n本小姐衣服的清潔費，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可不是筆小數目唷？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳～誰～？",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_042"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_043"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n竟然……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "忘了我是誰！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……噢……",
        "unit_id": 411,
        "voice": "vo_adv_1180001_044"
    },
    {
        "type": "dialogue",
        "name": "作業人員",
        "words": "秘書小姐，",
        "unit_id": 911,
        "voice": "vo_adv_1180001_045"
    },
    {
        "type": "dialogue",
        "name": "作業人員",
        "words": "老闆她怎麼了嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "總之……",
        "unit_id": 411,
        "voice": "vo_adv_1180001_046"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n不管她應該也沒關係。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "……就當作她是",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "「很想使壞病」發作吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "好了，",
        "unit_id": 411,
        "voice": "vo_adv_1180001_047"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "各位，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n用不著理會那位可悲的雇主。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n努力趕在今天內，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "完成這一區的瓦礫清除工程吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "工作人員們",
        "words": "了解──！",
        "unit_id": 1,
        "voice": "vo_adv_1180001_048"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……呵呵……",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_049"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n沒料到",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們竟然會不記得我。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n既然如此……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "聽好囉，",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_050"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們兩個？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我要特別告訴",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們一個……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可以發大財的好消息唷。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要不要一起加入呀？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "發……？",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_051"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_052"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n搞、搞什麼，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "竟都露出一臉茫然的表情！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "該不會，",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_053"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "得把話講得更簡單一點，他們才聽得懂……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那麼……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要是幫我的忙，",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_054"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就給你們零用錢喔！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n有聽懂嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可以拿錢喔，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "錢‧",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "錢",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "錢錢～？",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_055"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵呵……",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_056"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "「錢很重要」",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗎。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n確實，這觀念非常正確。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯。",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_057"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n人為了錢，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼都肯做。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……欺騙、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "背叛、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "甚至是骯髒事……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以說呢！",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_058"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我要出錢",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "跟你們買！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n買公主殿下的祕密！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "佩可的～？",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_059"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯，",
        "unit_id": 118011,
        "voice": "vo_adv_1180001_060"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就是這樣！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n僅公主殿下身邊的人才有機會得知的那些缺點！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "弱點！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "壞毛病！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而我願意花大筆錢",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "買這個情報！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯～嗯……",
        "unit_id": 106414,
        "voice": "vo_adv_1180001_061"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "吃很多～很多～！",
