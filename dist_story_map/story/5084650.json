[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生……",
        "unit_id": 105411,
        "voice": "vo_adv_5084650_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "從那之後真的就一直沉睡著呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "小望、千歌……",
        "unit_id": 105411,
        "voice": "vo_adv_5084650_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還有怜大人，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n全都在擔心你喔。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過我是",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒特別感到寂寞啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但是……",
        "unit_id": 105411,
        "voice": "vo_adv_5084650_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是騎士先生不在，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n大家就都沒精神，我不知道該說是對此感到困擾，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n還是說我也因為沒幹勁而感到無聊呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總、",
        "unit_id": 105411,
        "voice": "vo_adv_5084650_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總之我很困擾啦。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n讓女孩子困擾是怎樣啦！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那樣會不受歡迎喔？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不對，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但你受歡迎也會讓我困擾就是了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，剛剛說的不是那樣喔！",
        "unit_id": 105411,
        "voice": "vo_adv_5084650_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我不是那個意思！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "夠了，真是的，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請快點起來。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我會等著你的。",
        "unit_id": 105411
    }
]