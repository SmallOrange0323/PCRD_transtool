[
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還順利嗎，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是抱歉呢。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n讓你得如此頻繁地來負責看照小霧……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是我們首次",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "成功捕捉「闇影」，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以各式各樣的研究所和魔法師都深感興趣。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不僅得處理向王宮報告用的書面資料，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還得應付那些只會出張嘴的傢伙",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "簡直忙不過來。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "時時互探底線，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n偶爾甚至還得勾心鬥角，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真折騰死人了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "累死了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「名偵探小姐！」",
        "unit_id": 101421,
        "voice": "vo_adv_1014007_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哇哇……",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哎唷，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "突然就撲了上來會讓人很困擾喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你和我",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "幾乎含有著相同的質量呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也就是說體重完全一樣。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若妳毫不保留地朝著這飛撲了過來，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我可接不住呀。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「是個困難的問題呢？」",
        "unit_id": 101421,
        "voice": "vo_adv_1014007_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是呢。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "果然對話感覺是有成立的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這可是你的功勞唷，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n自從與你接觸以來，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n小霧的情況開始有了明確的變化。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很明顯地開始有自我，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也開始萌生自主的行為。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖讓人深感興趣，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但依舊不明白道理。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "儘管有試著推理，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但也不知道是不是正確答案。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「闇影」的",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "相關研究一直停滯不前，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n全部都要自己摸索。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「是個困難的事件呢？」",
        "unit_id": 101421,
        "voice": "vo_adv_1014007_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是呀。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔～呣、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n被和自己同張臉同個聲音給搭上話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還真難習慣呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "完全沒有互動時也備感困擾，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但與自己對等的存在",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也讓人有點難受。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對於缺乏自信的我來說，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要一直對著鏡子這種行為",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還真是痛苦。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那全都是裝出來的。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我不管何時都覺得不安，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n總會被困惑或自卑感",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "給動搖。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再怎麼說我也還是個正值青春期、",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才十幾歲的少女呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從獨自進行偵探活動的時期開始，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n為了不被瞧不起總是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "虛張聲勢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「名偵探」不過就是個虛名，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是為了保護脆弱又容易受傷的自己，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所建立起來的形象。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是她、",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧卻……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "像是把深藏在那虛飾之下，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "宛如是我最原始的樣貌給徹底表現出來了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總覺得",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就像是自己心裡最自卑的那面，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n被赤裸裸的給完全揭露出來的感覺呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這可不是在討論喜好喔，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "話說回來。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若被問到喜歡或討厭，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "毫無疑問是喜歡呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n不管是誰，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "必定都是愛自己的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們總是",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "會對與自己相像之事物，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "或是有很多共通點的事物感到親切。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這可是人類的本能，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也是必要的機制。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若無法喜歡自己的話，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那就會連呼吸都做不到唷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總而言之。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n小霧的絕大部分，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n都和我一樣。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "她",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_029"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是我呀。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在自己心中",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所構築的自己",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總會經過美化。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那其實只是由名為自我肯定的形式所裝飾、",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n裝扮出來的假象。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n小霧卻是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從我本身之外，被建構出來的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「我自己」呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就像是從被錄下來那自己的聲音中",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "察覺到異樣感一樣，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "光只是看到些微的差異，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就讓人無法忍受。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唉，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原來我是這麼……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n軟弱又悲哀的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "女孩子啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「名偵探小姐？」",
        "unit_id": 101421,
        "voice": "vo_adv_1014007_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼妳會這樣稱呼我呢……",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔～",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "光待在這個地方，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就感覺腦子會出問題。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可是",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_036"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不管是誰，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n都無法將自己捨去。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我會好好的照顧",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n並且保護你唷……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「非常謝謝妳♪」",
        "unit_id": 101421,
        "voice": "vo_adv_1014007_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……只要稍微被溫柔對待、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n或是受到肯定，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就會輕易的感受到親近感呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這一點，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_040"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也和我完全一樣。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_041"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n怎麼了助手先生？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你那副樣子好像是有什麼話想說呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_042"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧和我，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "行為舉止並不相似？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為我總是偽裝著自己呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "自幼便憧憬嚮往的，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_043"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n扮成自己理想中的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "「名偵探」的角色。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那也是「我」。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n而像小霧這樣，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "虛無縹緲又柔弱脆弱的我",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也一樣是我。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "兩邊都是我，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以都無法割捨。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_045"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "怎麼感覺，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好像變成在討論哲學了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「我……」",
        "unit_id": 101421,
        "voice": "vo_adv_1014007_046"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_047"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n小霧，怎麼了？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「我有辦法，",
        "unit_id": 101421,
        "voice": "vo_adv_1014007_048"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "成為名偵探嗎？」",
        "unit_id": 101421
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然可以。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_049"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n給予迷失、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "困惑的人們一絲救贖之光，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n妳一定能夠成為那種",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "充滿知性又帥氣的「名偵探」。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那可是我自幼便憧憬著，",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就像故事中的主角一樣……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "使人景仰的存在呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在妳眼前的我，就是最好的證明。",
        "unit_id": 101411,
        "voice": "vo_adv_1014007_051"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若怎麼樣妳都無法接受，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那就算要費上再多的唇舌，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也一定會親口說服妳的。",
        "unit_id": 101411
    }
]