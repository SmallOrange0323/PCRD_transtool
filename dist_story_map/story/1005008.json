    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呼嚕、呼嚕……♪",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……嗯、",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯嗯？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這裡，是哪裡啊？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我想想……？",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊～",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "隱約地想起來了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這裡是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "【咲戀育幼院】對吧～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我原本",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "想要消除{player}的記憶，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n而做了過分的事呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "結果{player}，",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_005"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n和我約好會替我保密，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我是獸人的這件事情……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這樣也不必訴諸「攻擊頭部，",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "讓他失憶」",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這種粗暴的手段了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還真的是想了件很愚蠢的事情呢，",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_007"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我這個人。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_008"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "能了解我的心情真是太好了……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "暫時安心了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可喜可賀可喜可賀。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不曉得是不是因為這陣子一直煩惱，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n而導致睡眠不足……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "再加上鬆了口氣的關係，",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n好像不知不覺間",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就睡著了的樣子呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "然後{player}……",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為了不把我吵醒，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n所以把我搬到床上來了吧？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "果然是個",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "溫柔的人……♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿。",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這張，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大概是{player}的床吧。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "總覺得好像",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "能夠聞到{player}的味道……♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯嗯？",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n豈止「總覺得」的程度，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n根本就能",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很清楚地聞到{player}的味道！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "難道說，",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n{player}和我一起睡嗎……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不不不、不行！",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_016"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這種事情是不好的，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n會發生問題的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯嗯？",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_017"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n{player}，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n趴在床的旁邊。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "感覺似乎是在看照睡著的我的期間，",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不知不覺就睡著了呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "把頭靠著床邊，",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_019"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n安穩地睡著了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "耶嘿嘿。",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_020"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n睡相還真～是可愛。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n看著",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就讓人很安心。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "噫呀！？",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_021"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n咦，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "又有什麼東西發光了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這是什麼啊～好刺眼！",
        "unit_id": 100511
    },
    {
        "type": "background",
        "background": "510260"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚～",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不要啦！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我討厭打針～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔啊？",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_023"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n{player}大哥！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為什麼，你會在醫院啊？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哦，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_024"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為正逢季節交替，感冒了啊……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以才會到醫院來看診，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n想拿點藥回去呢。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你這樣不行哦～得小心點才行。",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n健康第一！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_026"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我可不是生病啦！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好像是非得",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "打什麼預防針不可的樣子哦～？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "其實原本應該",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_027"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n要在學校和大家一起打預防針的。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是我",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "因為太討厭打針就到處逃跑。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "面對任何壞人我都不害怕也不會輸，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_028"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但我討厭打針！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒辦法啦！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是爸爸說，絕對不可以不打預防針……",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_029"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "於是就被爸爸抱著，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n強行帶到醫院來了。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚。",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_030"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n爸爸一定是，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n被邪惡組織洗腦了！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果不是這樣的話，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n爸爸是不可能要我做自己不喜歡的事情！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我說得沒錯吧，大哥？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒有錯吧！",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_032"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我就相信是大哥的話一定會了解我的！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以說，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_033"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這一定是邪惡組織的陰謀！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我討厭被打針啦～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚啊啊啊啊，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "虎虎救我—！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦……\n啊，嗯。",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_034"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不需擔心，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_035"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我可是所謂的超健康兒童喔！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "甚至連感冒也沒有過幾次哦，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "欸哼♪",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以說，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_036"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒有必要打預防針！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我就算",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不打什麼針，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n也不會輸給生病的！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我有一直一直，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_037"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n到死掉為止都能保持健康的自信！",
        "unit_id": 100531
    },
    {
        "type": "still",
        "still": "100500801"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚啊啊啊，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_038"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "絕對不要啦！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我說不要就是不要啦～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要我打針根本就不可能，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_039"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n因為那可是要把針刺進手腕裡哦？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n然後讓藥物在身體裡流動哦？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "簡直是惡魔的想法！",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_040"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n好可怕啊～！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不要不要不要，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "絕對不要！",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗚嗚……",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_041"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "怎麼了，大哥？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你說「是英雄的話，就不可以逃避」",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗎？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "話、",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "話雖然是這麼說沒錯啦～？",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那…",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_042"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n大哥，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為了讓打針變得不可怕……",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我希望，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你能握著我的手。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果大哥可以緊緊握住我的手的話，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_043"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我覺得，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "自己就能忍耐那些，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "疼痛和可怕的東西。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "英雄的守則第六條，",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_044"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "「若有同伴如得百人力」。",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "拜託你了，大哥……",
        "unit_id": 100531,
        "voice": "vo_adv_1005008_045"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我希望，",
        "unit_id": 100531
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你能幫幫我。",
        "unit_id": 100531
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵。",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次真的有種，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n辛苦你了的感覺呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你就好像，真的是茉莉的大哥……",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像是哥哥一樣的感覺呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，怎麼樣都好。",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n為什麼你，\n會被在「那邊」的茉莉，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "稱作大哥呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在「這邊」的話，\n她可是像「{player}～」\n這樣子稱呼你的名字呢？",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯……",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從你的記憶看來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好像也有過一段稱呼你為師父的時期呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想應該是相遇的方式不同，",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n讓稱呼的方式也跟著改變了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論如何，",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那孩子似乎將你認為，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是位值得尊敬的長輩呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從她對你的稱呼，",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就能夠知道這點了哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵，",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n為了不要讓她對你印象幻滅，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要對這小朋友溫柔一點哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我想是你的話，應該不用我多說才是……",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個年紀左右的孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可真的是容易受傷到令人驚訝的程度呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "茉莉她呀，\n雖然平常是個既懂事又率直的好孩子……",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但踩到她的地雷的話，可是相當麻煩的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "打針的事是如此，",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n耳朵和尾巴的事也是如此呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那個孩子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只對你……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那既敏感，",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "又不願讓人觸碰的地方，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n卻似乎只願意對你敞開心房。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這就說明，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她有多信賴你哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你可不能，背叛這份信賴哦。",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你對那孩子來說就像是家人、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像是夥伴一樣的存在……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "又或者是，",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n更加尊貴的存在也說不定呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦，",
        "unit_id": 190011,
        "voice": "vo_adv_1005008_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你不懂我說的意思？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這點事情請你自己想想看哦，{player}……♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500121"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯、",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_064"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯嗯……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好像又睡著了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哎呀？",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_065"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "{player}也一起醒來了呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "睡得相當地熟呢～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n夢見了什麼嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我好像",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_066"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "作了一個有{player}",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n出現的夢～♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……哇哇？",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_067"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n為、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為什麼把手放在我的額頭上啊？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真是的，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "隨便就到處亂摸可是壞習慣喔！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然我是沒關係，",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_068"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不如說",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我很喜歡被摸……？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "開心到",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "連尾巴都搖來搖去了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_069"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n一被摸的話，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就會莫名心跳加速，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很困擾的。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_070"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n因為我突然倒下來，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n所以擔心我是不是生病了？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "所以",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_071"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為了量體溫，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n才摸我的額頭嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_072"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n把我搬到床上來以後，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n還叫了醫生過來嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "明明就沒事的～",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_073"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n只是單純睡眠不足，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒有醫生出場的餘地。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_074"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "很不擅長面對醫生。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那些人總是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "馬上就要幫我打針。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100511,
        "voice": "vo_adv_1005008_075"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我很開心你能擔心我。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n{player}，",
