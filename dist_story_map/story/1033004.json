[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喂～伊麗莎白～！",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n跑到哪裡去啦～！？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚哇～",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n妳討厭和我一起搞笑了嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "知道了啦，都是我不好啦！",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我不會強迫妳當我的相聲搭檔了啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "快回來呀，伊麗莎白～！",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我知道搞笑不是靠強迫的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我不是小孩子了，所以很明白的！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是，我和伊麗莎白搭檔的話，就能奪得搞笑界的天下！",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我是這麼相信的，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我……！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……哇呀呀！？",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚喔喔，真是嚇一跳！",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "簡直是從來沒有展現過的驚嚇反應！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n跌了好大一跤，感覺很不真實的啦！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我、我得好好地記住剛剛那個感覺才行……！",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，哎呀？",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n是{player}嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在這草叢裡面幹嘛啊？",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "應該說，老哥來【伊麗莎白牧場】有事嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔，\n因為這條路是捷徑……？",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是沒錯啦。\n但為了防止魔物襲擊牧場的動物，",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這裡可是設置了陷阱喔～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不像平常一樣走山路的話，\n很容易受傷喔？",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且突然有人從草叢裡跑出來的話，\n心臟會凍未條的啦……",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我還以為是魔物，嚇死寶寶啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過呢，我想\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這附近應該是沒有什麼太危險的魔物棲息才對。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，老哥今天也送信來啊？",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "辛苦啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那我來簽收這些信，可以跟我來辦公室嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "…………",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……嗯？",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒事，只是今天也沒有偵探的報告呢～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我正在找離家出走的女兒啦。\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但是一直都找不到，已經有些放棄了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不，不是人類，其實是一隻牛。",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n牠叫做伊麗莎白。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒錯沒錯，\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那是我們公會名字原本的哏啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "伊麗莎白和我就像姊妹一樣一起長大，\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是很和善的牛……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也是我最棒的搞笑搭檔的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是有一天，\n不知道什麼時候就不見蹤影了。",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在牠在哪裡、在做什麼……",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我想盡辦法在找牠，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但都沒什麼結果。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牠真的，\n就像一陣煙一樣消失了。",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我剛剛……\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也是在最後看到伊麗莎白的地方，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n一邊喊著牠的名字，一邊四處找牠。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但連一點痕跡都沒有。\n問其他人，",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n她們都說不記得誰是伊麗莎白。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "實在是很奇怪。\n該不會像偵探……霞小姐說的一樣，",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牠就這樣「消失」了吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……沒事，沒什麼。",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "該怎麼說呢～最近有很多異常的事，很討厭的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真希望能更安穩、更和平地過下去啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在大家覺得困擾\n或是難過的時候還搞笑……",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n可是會被罵說「太白目了～」呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚哇？\n老哥，為什麼突然發光啊？",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "都不事先講一聲，我都嚇到吃手手啦。\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "別看我這樣其實意外地不擅長即興演出啊！",
        "unit_id": 103311
    },
    {
        "type": "background",
        "background": "510140"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇喔喔喔……☆",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_032"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好厲害，有好多沒看過的動物！",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_033"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣回去可以跟故鄉的大家分享了，",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n欸嘿嘿嘿♪",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}，謝謝啊。",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_034"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n謝謝你帶我來動物園。",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搞笑比賽的預選落敗，\n讓我實在很沮喪，",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_035"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天來動物園很適合轉換心情啦♪",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我原本計畫，\n是在比賽中一路過關斬將……",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_036"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我還事先付了\n很多天的飯店訂金。",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_037"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為進入決賽的話，要花上一個月的時間。",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就這樣回去的話很可惜，\n所以我要待在這個城鎮一陣子的啦。",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_038"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牧場的話，有其他員工在應該沒問題。",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且，\n如果在搞笑比賽中，有正式入選的選手棄權的話……",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_039"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n好像就會舉行敗部復活賽。",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我期待有那個機會，\n所以現在應該要準備好很多的哏才行！",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_040"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}身為我的搭檔，",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_041"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也要隨時準備獨家好哏啊……♪",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……硬要老哥陪我，真抱歉啊。",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_042"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n如果真的覺得煩的話也沒關係，",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我可以一個人努力的啦。",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搭檔跑掉也不是",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_043"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "第一次發生的事情了。",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也被說過",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_044"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "「都一把年紀了還搞笑～」，",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不是每個人都可以只做自己喜歡的事情的啦。",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我只是剛好有時間，\n才能過了二十歲還繼續說相聲。",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_045"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一般大家都得為生活打拼。",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_046"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n不紅的搞笑藝人，",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是很難生活下去的啦。",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且我也不是專業的藝人，\n只是個喜歡搞笑的業餘人士而已。",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_047"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然應該要控制在興趣的範圍內就好。",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_048"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但，搞笑是我的夢想……♪",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_049"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n嗯……",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，沒錯的啦。",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "抱歉，拜託不要說那種很難反應的話啦！",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_050"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也不對，聊這麼奇怪的話題，這應該是我的責任啦～？",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "唔～？\n看來逗哏跟捧哏沒有兜起來啊？",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_051"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不行不行，得更加油才行！",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？\n我看起來沒精神嗎？",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_052"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，老實說，\n搞笑比賽的結果不好，我很沮喪沒錯……♪",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_053"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但是臉在笑、心在哭，\n才是一流的喜劇演員的啦！",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_054"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "竟然讓{player}擔心，\n",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_055"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看來我還是太嫩的啦～♪",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "欸嘿嘿。\n好像氣氛變得有點哀愁的啦。",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_056"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "抱歉，我馬上來搞笑一下！",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "等一下，\n我要用眼前的動物來想哏的啦！",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_057"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯……兩隻老鼠、兩隻老鼠，跑得快～♪",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_058"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊！老虎，老鼠，傻傻分不清楚♪",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n啊哈哈☆",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……嗯？",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_059"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n難過的時候",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不用勉強自己笑？",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}真是太人小鬼大了。",
        "unit_id": 103331,
        "voice": "vo_adv_1033004_060"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103331
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "竟然這樣對已經是成年人的姐姐……♪",
        "unit_id": 103331
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以現在不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "之後，\n我就會好好說明的。",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只是呀……\n真陽為什麼會看起來那麼年輕呢？",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "外表完全就像個小學生呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但實際上已經二十歲了吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "人體還真是奧妙呢。\n",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是搞笑帶來的抗老效果嗎……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，據說多笑的話可以恢復青春。",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n皮膚會變得明亮光滑呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯，不過我是妖精，\n所以其實也不需要在意肌膚年齡之類的呢！",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不對，\n我的事情不重要。",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……真陽啊，\n雖然總是在笑，",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但有時候會看起來很寂寞的樣子呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說不定她有什麼很沉重的煩惱。",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要多注意，好好地看著她唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要守護好這位",
        "unit_id": 190011,
        "voice": "vo_adv_1033004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總是帶來幸福歡笑的可愛姐姐喔……♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "{player}～？\n怎麼啦，怎麼發起呆來啦？",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_073"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "該不會因為走山路，\n踩到蛇然後被咬啦？",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_074"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我小的時候也被咬過～\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_075"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那時候發高燒了三天三夜，一直臥床不起啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還好嗎？\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_076"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣啊，這樣就好啊……♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "走山路也應該累啦～",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_077"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n到辦公室來休息一下吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我會好好招待老哥的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天其他人也都外出了，\n我沒有人可以說話，很寂寞呢～♪",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_078"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "動物基本上也不會笑。",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_079"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒有「其他人」的話，我再怎麼搞笑也是很空虛的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然最近\n稍微增加了一些寄住的成員，變得比較熱鬧。",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_080"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？\n如果寂寞的話，搬到城鎮住就好？",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_081"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不，雖然說得簡單……",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_082"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但我不能放著父母親留給我的",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牧場不管的啦。 ",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大人有很多麻煩事要顧啦，\n",
        "unit_id": 103311,
        "voice": "vo_adv_1033004_083"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊哈哈……♪",
        "unit_id": 103311
    }
]