[
    {
        "type": "background",
        "background": "502820"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "蜜桃碰撞淘汰賽",
        "unit_id": 138712,
        "voice": "vo_adv_5214411_000"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "終於在今天落幕了呢。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我感覺已經把",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這輩子的屁股都翹完了……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "雖然一開始覺得很羞恥，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "但後來也漸漸麻木了……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "觀眾席",
        "unit_id": 138812,
        "voice": "vo_adv_5214411_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也是每天都爆滿呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那股狂熱和熱情",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的是",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很驚人呢……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "難怪",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會說",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「寒冬就是盛夏！」呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "原來那句話",
        "unit_id": 138712,
        "voice": "vo_adv_5214411_002"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "是這個意思嗎！？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不愧是美冬教練，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "「美冬也是盛夏！」呢……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果有第三屆的話，",
        "unit_id": 138812,
        "voice": "vo_adv_5214411_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或許會有更多人參賽呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n而我們就是",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「衛冕冠軍」了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n嘿嘿……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗯～",
        "unit_id": 138712,
        "voice": "vo_adv_5214411_004"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "想要守護冠軍寶座，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "但又不是很想……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不過美冬教練倒是看起來幹勁滿滿的樣子。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "聽說下次要設立年少組，",
        "unit_id": 138812,
        "voice": "vo_adv_5214411_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n想讓【小小甜心】那些孩子們",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也來參賽。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "從、",
        "unit_id": 138712,
        "voice": "vo_adv_5214411_006"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "從教育的角度來看沒問題嗎？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n感覺會場上會擠滿變態或可疑人物吧……？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我、",
        "unit_id": 138712,
        "voice": "vo_adv_5214411_007"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "覺得她絕對不會參加的……！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "何況，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "好歹我也是姊姊，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n讓妹妹的臀部被這麼多人看到，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "有點……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 138812,
        "voice": "vo_adv_5214411_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "下次或許會是雙人比賽喔。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n初音＆栞隊與",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若菜＆布武機隊，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們決賽見吧！",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "就說",
        "unit_id": 138712,
        "voice": "vo_adv_5214411_009"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不會參加了～！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "絕對～",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不要",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "辦什麼",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "第三屆啊～！",
        "unit_id": 138712
    }
]