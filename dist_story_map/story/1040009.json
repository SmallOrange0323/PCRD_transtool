    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在一同拯救城鎮的危機時，碧跟{player}加深了彼此的友誼。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}想趁這個氣勢結交更多的朋友，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於是前往碧所居住的精靈之森。"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "HEY YO！",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我的前途！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一片光彩！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n新朋友來！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自然很嗨！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這一切好事緣由！",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n都是因為跟你成了朋友YO！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "HEY YO ",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_002"
    },
