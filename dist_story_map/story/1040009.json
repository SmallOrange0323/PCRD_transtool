        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "WO～W♪",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我們是死黨，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "話匣子闔不上，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "WOW ",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "WOW ",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "YEAH～♪",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀啊啊啊～！？",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n{player}！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原、",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來你在啊！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對不起，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我沒注意到……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實是",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自從之前一起創作主題曲以後，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我就愛上了Rap……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "能跟團長當朋友，",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我很開心……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那股心情化為熱情噴發而出，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n讓我創造出新作品，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以我不由得就哼起來了……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "歌名我也想好了！",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我把它取名為",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "「新‧BB團朋友讚譽曲」……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這個「新」",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不只是指「新歌」的意思，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n也是指結交朋友後，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "進入「新的」禁忌領域的意思，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n是個有一種說不出的可愛感，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我非常滿意的命名！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……呃，",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對不起。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就我一個人講個不停。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "能跟朋友說話真的太開心了，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我才會不由得興奮過了頭……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………\n……………………\n………………………………",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "…………欸嘿嘿。",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒事，",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我只是實際感受",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我跟你真的成了朋友，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以再次感到很開心。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為，",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "平常像剛才那樣突然沒話可說時，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我都會急到亂說話不是嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是，",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對象是你的話，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "似乎也能接受那樣的我，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n所以我就能",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "放心思考接著要說什麼才好。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種事",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "很有朋友的感覺……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "欸嘿嘿。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "難得成為朋友，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n要不要來做點朋友才會做的事！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呃……",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我想想…………",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "翻花繩……",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "平時就在玩了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "接龍……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是不錯……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n但更有朋友感覺的會更好對吧……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "明明是我自己開口的，\n卻還說這種話是也很怪……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過朋友都會做些什麼樣的事啊……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "朋友會一起做的事……",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "國王遊戲！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想玩國王遊戲！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那是朋友會聚集在一起",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嬉鬧遊玩的經典遊戲──",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我不知道在哪聽過這種說法！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "其實……",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我以前曾經想要自己玩，但卻失敗了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "既然已經結交到{player}這個朋友，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n現在肯定玩得起來！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那我們馬上開始吧！",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_023"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我早料到會有這種情況，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以事先準備了籤！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "來吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請看過來！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這麼說來……",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就規則來說，或許是那樣沒錯……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "可是，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "現在的我們",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "應該是勉強玩得起來！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "快",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "來試看看吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那麼，",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請選擇其中一邊吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你要選右邊嗎？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還是選左邊呢……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "喔喔！",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你要選右邊對吧！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n哎呀～",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你的眼光真好！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這樣我就能下一道命令了……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "咦咦……！？",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你還是決定選左邊……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怎、",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怎麼這樣……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真、",
        "unit_id": 104011,
        "voice": "vo_adv_1040009_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真的要選左邊嗎……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "確定了嗎……！？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
