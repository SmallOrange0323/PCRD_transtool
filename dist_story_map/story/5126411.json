[
    {
        "type": "background",
        "background": "502032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一眨眼就要和校園生活道別了呢……",
        "unit_id": 127212,
        "voice": "vo_adv_5126411_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也沒有什麼覺得寂寞的。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為我們有該回去的地方。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯……",
        "unit_id": 127312,
        "voice": "vo_adv_5126411_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也不寂寞喔！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n即使回到月學，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家跟凱留寶也還是朋友這點不會改變，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n想見面的時候也會隨時飛奔過去找妳的！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺妳真的會飛奔過來呢……",
        "unit_id": 127212,
        "voice": "vo_adv_5126411_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也罷，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到時候就聚在一起聊天吧，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n順便把班上的大家都叫來。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 127312,
        "voice": "vo_adv_5126411_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "大家一起來拍照，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "替今天留念吧！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我絕對不要！",
        "unit_id": 127212,
        "voice": "vo_adv_5126411_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我可沒膽子站在超級模特兒旁邊拍照啊。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……呃，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "完全無視我呢。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？",
        "unit_id": 127312,
        "voice": "vo_adv_5126411_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "凱留寶，妳說了什麼嗎？",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要把我們",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "拍得可愛一點喔♪",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "待會也會替你拍的！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呀哈♪",
        "unit_id": 127312,
        "voice": "vo_adv_5126411_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這張雙人合照，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家要當成一輩子的寶物！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n快點，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "凱留寶也比個「耶」吧，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "耶～♪",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……真是的，",
        "unit_id": 127212,
        "voice": "vo_adv_5126411_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道了啦。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我拍就行了吧，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我拍……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "預備～！",
        "unit_id": 127312,
        "voice": "vo_adv_5126411_008"
    },
    {
        "type": "dialogue",
        "name": "凱留、鈴奈",
        "words": "來，",
        "unit_id": 1,
        "voice": "vo_adv_5126411_009"
    },
    {
        "type": "dialogue",
        "name": "凱留、鈴奈",
        "words": "笑一個！",
        "unit_id": 1
    }
]