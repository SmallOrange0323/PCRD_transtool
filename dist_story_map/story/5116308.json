[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "栞小姐，",
        "unit_id": 125311,
        "voice": "vo_adv_5116308_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下突然想到一事……",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位大猿先生",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "牠應該可以",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n用生長在密林裡的植物來製作牙刷吧？",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呃，",
        "unit_id": 125411,
        "voice": "vo_adv_5116308_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "妳是說",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要教大猿刷牙嗎？",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "牠是智力很高的魔物，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果好好教牠，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n或許有可能理解我們的意思……",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "話雖如此，",
        "unit_id": 125411,
        "voice": "vo_adv_5116308_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這也要等到事情全都解決之後",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "再來進行。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓我們以遊俠的身分，",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "先奪回這片森林的平靜安穩吧。",
        "unit_id": 125411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了。",
        "unit_id": 125311,
        "voice": "vo_adv_5116308_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大猿先生，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n既然如此，我們會奉陪到底的。",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 125311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您快冷靜下來吧。",
        "unit_id": 125311
    }
]