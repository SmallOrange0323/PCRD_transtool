[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "閒得發慌的諾維姆與尾狗刀，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n向偶遇的大吾搭話。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "欸欸，",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "大鼓我問你，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你為什麼那麼喜歡打架？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "因為我看比我強的人不順眼……",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_001"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "喂，等一下，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "大鼓是誰啊？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你因為這樣就找人打架嗎？",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_002"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "唉～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "打鼓真是單純啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我單純哪裡礙到你了……",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_003"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "喂，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "慢著！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "打鼓是在叫誰啊！？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "唉～",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_004"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "打噗就是單純這點好啊……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n尾狗刀，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你也多學學人家啊。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦～",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_005"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我應該不太行吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我沒辦法像打噗那樣不思考就行動。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "你們從剛剛就在亂叫些什麼！",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_006"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n我是大吾！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "啊？",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_007"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "抱歉抱歉。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不過，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "等你把很強的人都打倒之後，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "阿噗你要做什麼？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n就不再戰鬥了嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不覺得這樣很空虛嗎？",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "小噗，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "人生不是只有戰鬥喔。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "你～",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_009"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "們～",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "兩～",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "個～",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n肯定是故意的吧！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n你們夠了喔！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "啊哈哈，",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_010"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你發現啦？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "唉呀～",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_011"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們只是想試試，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你什麼時候會注意到。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "從一開始就發現了啦！",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_012"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "你們該不會",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "是專程來找碴的吧？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "別生氣嘛。",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_013"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n得阿吾，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你這樣太激動了喔。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我不叫得阿吾！",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_014"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n你們膽子不小嘛……",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "既然想打架那就來啊！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "冷靜冷靜，",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這就像一種訓練。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "訓練你保持平常心，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "加油，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "太吾。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我不叫太吾！",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_016"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n我受不了了！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "你們皮給我繃緊！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "容易被挑釁",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_017"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "就是你的弱點。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這麼愛生氣，",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_018"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "很容易正中對手下懷喔？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n大吾。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "閉嘴──！",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_019"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "我不是大吾！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "……啊？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "他說他不叫大吾耶。",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_020"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "該不會",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "叫大骨吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "你看，",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_021"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "馬上就中招了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "所以才叫你要冷靜一點……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "嘎啊啊啊啊啊啊啊！",
        "unit_id": 190711,
        "voice": "vo_adv_5111604_022"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "哇！",
        "unit_id": 106114,
        "voice": "vo_adv_5111604_023"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "發飆了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "他超級火大的耶！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "快跑快跑～！",
        "unit_id": 106211,
        "voice": "vo_adv_5111604_024"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "諾維姆與尾狗刀笑著逃離了現場。"
    }
]