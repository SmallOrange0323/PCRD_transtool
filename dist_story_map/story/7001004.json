    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "即使我的種族有所不同",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們依然可以好好相處……",
