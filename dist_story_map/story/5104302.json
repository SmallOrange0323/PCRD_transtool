    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "它好像",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "變得更強了？",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "感覺比剛才戰鬥的時候",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還更難纏了……！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "打倒的敵人變強以後復活這種橋段，",
        "unit_id": 123811,
        "voice": "vo_adv_5104302_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在勸善懲惡的超級英雄秀中可說是經典吧？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好了，",
        "unit_id": 123811,
        "voice": "vo_adv_5104302_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對方還藏著幾張王牌呢？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "最好準備得充分一點，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟那些手牌很快就會用完了♪",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "說得沒錯，",
        "unit_id": 123911,
        "voice": "vo_adv_5104302_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不管敵人變得多強，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n最後贏得勝利的仍然是我們！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "認命吧！",
        "unit_id": 123911
    }
]