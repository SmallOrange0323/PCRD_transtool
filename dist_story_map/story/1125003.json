[
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}為了【new generations】的練習"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n停留在村子裡，並陪同凜進行晨練——"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯？",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_000"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "怎麼了嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "一群人聚在那裡。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "一大早就那麼多人，真是難得呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "「凜」就是",
        "unit_id": 1,
        "voice": "vo_adv_1125003_001"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "那個當偶像的女孩吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "該怎麼辦才好……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "可是，",
        "unit_id": 1,
        "voice": "vo_adv_1125003_002"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "這樣下去村子會出大事的……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……我說，",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_003"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "發生什麼事了嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "聽起來好像和我有關係。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "是啊，",
        "unit_id": 1,
        "voice": "vo_adv_1125003_004"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "不得了！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "告示板上面貼了一張奇怪的紙……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "告示",
        "words": "對「蒼藍劍士凜」提出決鬥。"
    },
    {
        "type": "dialogue",
        "name": "告示",
        "words": "\n若是妳不接受決鬥，村子將會有災難降臨。"
    },
    {
        "type": "dialogue",
        "name": "告示",
        "words": "決鬥不准攜帶同伴，必須要一個人前來。"
    },
    {
        "type": "dialogue",
        "name": "告示",
        "words": "\n時間與地點是——"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……對我提出決鬥",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_005"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "是嗎。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "既然上頭都這麼寫了，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "那我也只能去了呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "不對不對，",
        "unit_id": 1,
        "voice": "vo_adv_1125003_006"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "小姐妳一個人去太危險了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n這個不管怎麼看都是陷阱啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "這個我知道。",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_007"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "但是，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "如果我不去，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "各位可能都會有危險。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "謝謝。",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_008"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不過，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "要是被發現了不曉得會出什麼事，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "還是我自己去吧。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "上頭也有畫地圖，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "這張紙",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我就帶走囉。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "為了以防萬一，",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_009"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "村裡的人們",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n請關緊門窗，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "就算有什麼事也別跑出來外面。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "懂嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1125003_010"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "嗯。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "知道了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n但是，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "妳一個人去真的沒問題嗎……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "沒問題，",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_011"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "放心吧。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "別看我這樣，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "其實我挺強的喔。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我絕對會想辦法解決的。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "要是",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_012"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "卯月和未央",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "問我去哪裡的話，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n你就幫我告訴她們我一個人去練習了。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "那麼，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我先走了。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106011,
        "voice": "vo_adv_1125003_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "找到了找到了！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說你，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又一個人到處閒晃了？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我不是說過別擅自行動了嗎，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你今天不是要陪她們練習嗎？",
        "unit_id": 106011,
        "voice": "vo_adv_1125003_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趕快過來吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對，",
        "unit_id": 106011,
        "voice": "vo_adv_1125003_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你在說什麼啊？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "完全搞不懂你的意思耶？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……喂，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別突然拉著人就走啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你要帶我去哪裡！？",
        "unit_id": 106011
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……真的是這裡沒錯嗎？",
        "unit_id": 106011,
        "voice": "vo_adv_1125003_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然也姑且和村裡的人們確認過了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但這要是搞錯了，不是很不妙嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是不安……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我依約前來決鬥了！　",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_017"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "好了，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "快點出來吧！",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 106011,
        "voice": "vo_adv_1125003_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……喂，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別把頭伸出去啦，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你也給我躲好！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "嘿～",
        "unit_id": 911,
        "voice": "vo_adv_1125003_019"
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "沒想到真的一個人來了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "妳是相當有自信呢？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "還是單純只是個笨蛋呢？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "你是",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_020"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "那個時候的！",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "現在不是正在為了你至今所做的壞事贖罪嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "我這裡可是有一大群的夥伴呢，",
        "unit_id": 911,
        "voice": "vo_adv_1125003_021"
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "我讓那些傢伙幫助我逃獄啦。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "然後啊，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "我想來回敬妳之前的所作所為呢。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_022"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "完全沒有反省的意思呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "那麼，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我就再護送你去一趟王宮騎士團吧。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "妳可別以為事情會有妳想得那麼順利啊！",
        "unit_id": 911,
        "voice": "vo_adv_1125003_023"
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "今天我可是有秘藏的東西。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "咕嚕……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "咕嚕……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "呃、",
        "unit_id": 911,
        "voice": "vo_adv_1125003_024"
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "呃啊，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "呃啊啊啊啊啊……！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "給我看招！！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "！？　",
        "unit_id": 112511,
        "voice": "vo_adv_1125003_025"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "好快……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "唔唔！！",
        "unit_id": 112511
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "嘖……",
        "unit_id": 911,
        "voice": "vo_adv_1125003_026"
    },
    {
        "type": "dialogue",
        "name": "野賊老大",
        "words": "竟然能擋下剛才那招。",
        "unit_id": 911
    },
