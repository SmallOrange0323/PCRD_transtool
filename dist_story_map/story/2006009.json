[
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦，{player}！",
        "unit_id": 103311,
        "voice": "vo_adv_2006009_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n你平安無事啊，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "太好了太好了♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "耶嘿嘿。",
        "unit_id": 103311,
        "voice": "vo_adv_2006009_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牧場除了建築物以外幾乎沒有損害呢，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n真是不幸中的大幸啊。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "馬廄等等的建築也很快就重建完成，",
        "unit_id": 103311,
        "voice": "vo_adv_2006009_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n今天之內應該大致上就能全部恢復原樣了吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n當然，還是有些孩子受傷了就是。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過傷勢並不嚴重，",
        "unit_id": 103311,
        "voice": "vo_adv_2006009_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且還有很優秀的療傷師過來幫忙，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n所以馬上就治好了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "療傷師？",
        "unit_id": 105812,
        "voice": "vo_adv_2006009_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，妳是說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n被稱作治癒師的治療專家對吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在城裡是這麼稱呼的啊？",
        "unit_id": 103311,
        "voice": "vo_adv_2006009_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我記得她好像是隸屬於",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "【墨丘利財團】的優花梨吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "她可真是個優秀到",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "連醫生都會自嘆不如的療傷師呢～♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 103311,
        "voice": "vo_adv_2006009_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n{player}，是你認識的人啊？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那待會再去和她打招呼吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在優花梨她……",
        "unit_id": 103311,
        "voice": "vo_adv_2006009_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n正為了治療大家，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "忙得不可開交呢♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_2006009_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你的人脈真的很廣呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2006009_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家看起來都平安無事，真是太好了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣也就沒有枉費我那麼努力呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，",
        "unit_id": 103311,
        "voice": "vo_adv_2006009_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "總之沒有人喪命呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n畢竟我們都是有生命的物種，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n只要活著，不論多少次都有辦法重新站起來的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我想大家",
        "unit_id": 103311,
        "voice": "vo_adv_2006009_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一定很快就能再次展露笑容的♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔嗚。",
        "unit_id": 103311,
        "voice": "vo_adv_2006009_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n由於我是牧場的經營者、",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n還有很多地方要忙。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我就先失陪囉～？",
        "unit_id": 103311,
        "voice": "vo_adv_2006009_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的，辛苦妳了～♪",
        "unit_id": 105812,
        "voice": "vo_adv_2006009_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……我看看，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n咲戀小姐應該就在這附近才對。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會是哪一位呢？",
        "unit_id": 105812,
        "voice": "vo_adv_2006009_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我沒有見過她，所以認不出來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦，",
        "unit_id": 105812,
        "voice": "vo_adv_2006009_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得你超級誇獎她呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她是{player}喜歡的類型嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～？",
        "unit_id": 105812,
        "voice": "vo_adv_2006009_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不是嘛，你條件得再多過濾一點才行呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果單指長頭髮的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那連我也算在內耶。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是啊。",
        "unit_id": 105913,
        "voice": "vo_adv_2006009_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那並不是錯誤的情報哦。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n咲戀小姐她",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確有著一頭美麗的長髮。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下看看……",
        "unit_id": 105913,
        "voice": "vo_adv_2006009_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下找到了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喂～，咲戀小姐～？",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "200600901"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這是怎麼回事啊！？",
        "unit_id": 102811,
        "voice": "vo_adv_2006009_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "用不著那麼激動，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我只不過是提案而已，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n做出最終決定的還是牧場經營者的真陽。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "再說妳也沒什麼理由",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n插嘴管這件事情吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話是這麼說沒錯，",
        "unit_id": 102811,
        "voice": "vo_adv_2006009_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但這是道義面的問題吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們只不過是單純的義工而已哦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不應該做出一些太踰矩的事情才對。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "砍掉樹木，",
        "unit_id": 102811,
        "voice": "vo_adv_2006009_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n建造蒐集魔力的鐵塔？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n妳們是打算糟蹋這些美麗的景色嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳們不就只是",
        "unit_id": 102811,
        "voice": "vo_adv_2006009_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n想推銷這些高價的魔法裝置而已嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我已經說很多次了，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且資料上也都有寫，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這附近的魔力流動十分的紊亂。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n為了讓它恢復正常，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這是必要的處置哦。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要是不改善環境，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n就毫無效率地使用魔法的話，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這樣成本就太高了呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "況且，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_028"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "景色雖然很重要……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但因為魔物先前已在此作亂的關係，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n附近都已經被嚴重破壞了呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想說的是，",
        "unit_id": 102811,
        "voice": "vo_adv_2006009_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n正因為如此，我們才更不應該",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n繼續加深人為的破壞啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們必須記取過去的教訓放眼未來。",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_030"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n為了找回這一帶的景色，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n設置一座使魔力流動正常化的塔也是必要的吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "如果放任這紊亂的魔力不管的話，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_031"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n就連植被及生態系都會因其影響而產生變化。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n牧場那美麗的景色，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "將會被糟蹋的比現在更嚴重哦。",
        "unit_id": 104811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500150"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好了好了……",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n妳們的對話從剛才開始就沒有交集喵，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "火氣不要這麼大，稍微休息一下喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳究竟是站在哪邊的啊，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_033"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "珠希。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總而言之，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_034"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這個牧場裡還有許多，\n因為遭到襲擊而感到不安的人們……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要是讓他們看見了妳們大聲吵架的樣子，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_035"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n讓他們徒增了無謂的壓力，這樣不太好吧喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……妳這麼說也是呢。",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_036"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真是抱歉，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一和咲戀小姐議論起來，不小心火氣就變大了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然同為千金小姐，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_037"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但妳和秋乃小姐真的很不一樣呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "她本來就和一般人不太一樣啦……",
        "unit_id": 102811,
        "voice": "vo_adv_2006009_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但我聽了美冬的話之後也學習了不少呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "能聽妳這麼說，是我的光榮。",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_039"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我也覺得能跟妳聊這些，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n給了我很好的刺激。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為在我們的公會裡，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_040"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n沒有人願意陪我聊這些麻煩的話題呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "明明這些麻煩事都很有趣呢，",
        "unit_id": 102811,
        "voice": "vo_adv_2006009_041"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對吧♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對啊～♪",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_042"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀，不過這裡有很多遇難的人，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n現在可不是個能覺得開心的時候。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "如果能靠我們討論這些麻煩事，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_043"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n讓事情更有效率地進行，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "減少之後的辛苦的話，那就萬萬歲了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過，人力及物資",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_044"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n蒐集、重建的作業都比我想像中來得順利。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這樣的話，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "應該很快就不需要我們了吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "畢竟我們是外部的公會，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_045"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n介入太深也不太好呢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "義賊雖然會從壞人那裡偷錢來分送，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_046"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但不應該為那些人決定那些錢該怎麼用喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "珠希她那特有的自滿，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_047"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我到現在還是無法理解。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……喔？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "{player}。\n太好了，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_048"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我聽說你下落不明，害我很擔心呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}～♪\n喵哈哈，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_049"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你身邊一如往常的圍繞著很多女孩子呢喵～？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這兩位…",
        "unit_id": 105913,
        "voice": "vo_adv_2006009_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n果然也是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的舊識嗎……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_051"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我和她們是第一次見面呢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我是【墨丘利財團】的珠希喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "請多指教喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "慶祝我們認識，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_052"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n給妳們這個鯛魚燒喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳從哪裡拿出來的啊，",
        "unit_id": 104811,
        "voice": "vo_adv_2006009_053"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n珠希。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2006009_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我開動了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個味道，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳是不是常常在攤販上賣鯛魚燒啊？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哦，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_055"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳知道啊喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這麼說來，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n妳是常常來光臨的常客是嗎喵～？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "非常感謝您平日的照顧，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_056"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n謝謝妳喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鯛魚燒……？",
        "unit_id": 105913,
        "voice": "vo_adv_2006009_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個，請問各位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n妳們公會是在做什麼的呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯～，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_058"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "以金融業為中心四處擴張中喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總之，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "算是什麼都做囉喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這次是看在同是獸人的情誼上，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_059"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n受到【哞哞自衛隊】的邀請而出差前來喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而且因為我也是獸人的關係，戶籍登錄在【動物苑】，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_060"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n互相幫忙是我們的義務喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們獸人啊，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_061"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n很重視這種互相幫忙的精神喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "牧場這邊，也有幾個【哞哞自衛隊】\n的人被派來這裡……",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_062"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為這樣，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_063"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n所以也還有很多其他的獸人來幫忙恢復原狀。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個牧場裡，不分普通的人類與獸人，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_064"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n大家都能和平地居住在一起……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "某種意義上，",
        "unit_id": 104611,
        "voice": "vo_adv_2006009_065"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "算是理想鄉呢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "實在很不希望這裡，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n因為災害而被破壞掉喵。",
        "unit_id": 104611
    }
]