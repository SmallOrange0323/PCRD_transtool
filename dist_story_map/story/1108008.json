[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克蘿依放學後，受學院的同學們邀請，\n列隊走在蘭德索爾的街上，度過了開心短暫的時光。"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可麗餅好好吃。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那麼，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我還有打工，就先到這裡。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是打工，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是志工呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有酬勞的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "克蘿依，",
        "unit_id": 2911,
        "voice": "vo_adv_1108008_002"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n今天謝謝妳陪我們。",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n不嫌棄的話，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "再隨時找我。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "我啊，",
        "unit_id": 3111,
        "voice": "vo_adv_1108008_004"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n今天是我第一次，",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "一邊走路一邊吃東西呢。",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "呵呵，",
        "unit_id": 3111,
        "voice": "vo_adv_1108008_005"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n如果被父親和老師知道的話",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "應該會被罵吧。",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "這下子我們也成了",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "了不起的不良少女吧？",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，我也不清楚。",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，雖然我不知道，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但自己覺得怎樣就是怎樣吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "好、",
        "unit_id": 2911,
        "voice": "vo_adv_1108008_007"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "好帥……",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "不顧他人眼光的生存方式，",
        "unit_id": 3111,
        "voice": "vo_adv_1108008_008"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "簡直就是不良少女啊……",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所――以說啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說了我不是不良少女啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "再說這些難聽的話，我就要因為毀謗而揍妳喔。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "啊，",
        "unit_id": 2911,
        "voice": "vo_adv_1108008_010"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "沒來由的暴力！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "這才是真正的，",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "不良界的象徵啊！",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "出現了！",
        "unit_id": 3111,
        "voice": "vo_adv_1108008_011"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "　",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "終於呢！",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "好帥……",
        "unit_id": 2911,
        "voice": "vo_adv_1108008_012"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "太帥了啊……",
        "unit_id": 2911
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "甚至",
        "unit_id": 3111,
        "voice": "vo_adv_1108008_013"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "好想被打啊……",
        "unit_id": 3111
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦――？",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_014"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "　我是不是交錯朋友了",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那麼。",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n盡情的玩完之後，就盡情的工作吧",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "照慣例到晚上應該都很閒……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呼～啊……",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對了{player}，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "今天會來嗎……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哦――",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "果然……",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "開始頭暈了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "最近太忙了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "一直沒睡飽呢――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n等等休息時間",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "小睡一下吧――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呼啊～呼……",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喵啊啊啊！？",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是{player}啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說啊。",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_023"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n不要在我毫無防備的瞬間出聲好嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n因為會不小心發出像小貓的喵喵聲。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_024"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你來得正好。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "一直在等著你來呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊啊不，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_025"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說的等，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也不是",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個意思啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_026"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "之前的事情啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你看，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "之前在這裡快被老師發現打工的時候，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n你不是救了我嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然很感激，多虧了你我才沒被退學，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_027"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過在那之後見不到你，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒辦法和你道謝，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_028"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯？",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_029"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "　咦？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，等等。",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_030"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n為什麼我，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "現在有點緊張呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這是什麼……",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_031"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是錯覺嗎，心臟些許地錯拍，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也太莫名了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，騙人的吧，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_032"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該不會我…………",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "很在意他？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不不，為什麼啊。",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_033"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "無法理解啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "總之簡單說聲謝謝，然後回去工作才行。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說啊。",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_034"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n前陣子的那件事――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_035"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "　這道光是怎麼回事？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哇哇哇，",
        "unit_id": 110811,
        "voice": "vo_adv_1108008_036"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "漸漸擴散開來了，這是什麼……！",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "咦，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_037"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "{player}。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "什麼，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_038"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "怎麼了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n短期打工不是已經結束了嗎。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊啊，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_039"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "是以客人身分來的意思吧。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n歡迎光臨",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n我已經要回去了，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你慢用――",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_040"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "其實就是早退。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不，今天好像，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_041"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "頭有一點點暈暈的。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "沒問題――",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_042"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n應該說，還是能工作。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不過不小心說溜嘴的話，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_043"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "會讓店長擔心的。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "可能說今天不早退就不給你薪水之類的，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n這種不知算體貼還是職權騷擾的話。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊？",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_044"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n不，沒關係。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "而且那樣有點噁心。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_045"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "真的沒事。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "這種小問題只是因為沒睡飽。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "因為念書啊打工啊還有家事啊，有點太忙了呢。",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_046"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n換成大人的講法就是過勞吧？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n蓋上棉被稍微睡一下就沒事了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯那麼掰掰，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_047"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "先走了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "剛剛的話題就……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯，下次，在遊戲裡說就好――",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "哦……",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_048"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "抱歉，有點暈……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "好難纏……",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_049"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊討厭，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_050"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我知道了啦。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "隨便你吧。",
        "unit_id": 110832
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯嗯……！",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_051"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n這種時候，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "外面的空氣很有療效呢。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n總覺得在走路的時候，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "就好很多了唷。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "咦？",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_052"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "怎、",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "怎麼突然……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "好噁心。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "咦，而且還一臉正經？",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_053"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n那什麼直率的眼神……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "快停下來快停下來，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "會害羞的啦。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n我其實是個很好攻略的人，所以你能不能停下來。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "話說你是要說那個吧。",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_054"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n你想說的是「臉色很好看呢」對吧。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "雖然你剛剛只是少了一個字，但意思就完全不同了呢？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "果然？",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_055"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "多虧了你呢",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "腦袋忽然變清醒了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "噗……",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_056"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "好，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "已經沒事了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n回去煮飯念書好了",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "咦，阿斯特朗？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "　",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "今天先不了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_057"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "對了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你啊，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "在之前的遊戲裡，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n叫了我花子對吧。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "可以注意一下嗎。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我也不是",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_058"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不喜歡自己的名字，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n畢竟是從父母那邊得到的，非常的珍貴。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "只是，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "該怎麼說，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "就是……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "稱呼克蘿依，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_059"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "感覺比較帥。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯，就是這樣。",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_060"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n{player}，今天謝謝你。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n到這裡就行囉，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我家就在這附近――",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "――啊。",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_061"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "弟弟們在玩。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟1",
        "words": "啊！",
        "unit_id": 1,
        "voice": "vo_adv_1108008_062"
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟1",
        "words": "　是姐姐！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟2",
        "words": "耶～！",
        "unit_id": 1,
        "voice": "vo_adv_1108008_063"
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟2",
        "words": "　姐姐歡迎回來！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_064"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我回來了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟1",
        "words": "……？",
        "unit_id": 1,
        "voice": "vo_adv_1108008_065"
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟1",
        "words": "\n姐姐，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟1",
        "words": "這個人是誰？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "喂。",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_066"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n好孩子的話要好好打招呼。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不，不是在說你。",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_067"
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟1",
        "words": "你好！",
        "unit_id": 1,
        "voice": "vo_adv_1108008_068"
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟1",
        "words": "\n姐姐平常",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟1",
        "words": "受你照顧了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯，",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_069"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "真要說的話，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n都是我在照顧他，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不過算了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟2",
        "words": "姐姐，",
        "unit_id": 1,
        "voice": "vo_adv_1108008_070"
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟2",
        "words": "今天很早呢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟2",
        "words": "\n太好了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟2",
        "words": "可以一起玩！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊――",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_071"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "對，呢……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "哈哈。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n那麼要玩些什麼好呢？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子的弟弟2",
        "words": "鬼抓人！",
        "unit_id": 1,
        "voice": "vo_adv_1108008_072"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "雖然是這樣……",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_073"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n說的出口嗎？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "　我真的很難抵抗這種純真的眼神。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n平常也很少陪他們玩……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "……什麼？",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_074"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "喵啊啊啊！？",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_075"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "怎喵突然！？",
        "unit_id": 110832,
        "voice": "vo_adv_1108008_076"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
