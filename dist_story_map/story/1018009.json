        "name": "女學生",
        "words": "妳說示範，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "不是指料理，而是指夫妻的事情嗎～？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_058"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "因為伊緒你們，",
        "unit_id": 211,
        "voice": "vo_adv_1018009_059"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n就像我家爸爸媽媽在做料理一樣呀。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女學生的媽媽",
        "words": "哎呀，討厭！　",
        "unit_id": 411,
        "voice": "vo_adv_1018009_060"
    },
    {
        "type": "dialogue",
        "name": "女學生的媽媽",
        "words": "我家孩子真是的！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女學生的爸爸",
        "words": "哦哦，",
        "unit_id": 311,
        "voice": "vo_adv_1018009_061"
    },
    {
        "type": "dialogue",
        "name": "女學生的爸爸",
        "words": "妳要是再亂說話，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女學生的爸爸",
        "words": "就沒零用錢囉～？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不是，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_062"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們並不是那種關係～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "可是，",
        "unit_id": 211,
        "voice": "vo_adv_1018009_063"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "看起來就像是那樣啊～",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "就像我家爸爸媽媽一樣～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是的！　",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_064"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個應該要說是情侶才對吧～？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_065"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那樣也不對！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你也別笑了，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "快點來說些什麼啦～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "眾人有如集中砲火一般扔出問題懷疑兩人的關係，\n但最後還是品嚐完料理實習中做好的料理，順利結束了教學參觀。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後，伊緒接到了學院長通知預算超支的警告。"
    }
]