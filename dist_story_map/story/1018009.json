[
    {
        "type": "background",
        "background": "500610"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某個週末，伊緒與{player}\n為了月光學院教學參觀要進行的料理實習，\n而外出採買實習用的食材。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯～",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "傷腦筋……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n每個看起來都好好吃，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不禁都被吸引了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我說，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你覺得哪個比較好？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是的！　",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "別連你都那樣說嘛～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果能透過",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這次的料理實習，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n讓學生們喜歡上料理，我會很開心的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為此，必須將美味的食材都準備齊全，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你也一起來",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好好思考吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我和你不同班級，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你還願意陪我，真是幫大忙了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "老師我必須採買整個班級的食材，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n只有一個人真的很不容易，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "正感到困擾呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "能夠和你一起去採買",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n料理實習的東西，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真是非常開心。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "歡迎光臨！",
        "unit_id": 1411,
        "voice": "vo_adv_1018009_007"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n小姐你們，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "接下來是要在家裡",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "自己做料理約會嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦！　",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們不是那種關係。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "他是我的學生，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天是來採買料理實習的東西。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "什麼啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1018009_009"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "原來妳是老師？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "我看你們關係這麼好還一起購物，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "還以為鐵定是情侶呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n你們很常被人這麼說吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "的確是很常有人這麼說……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但是，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們看起來真的像那個樣子嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？　",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你問什麼樣子……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n就是指……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你是我男朋友的意思。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "的確，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "第一個男朋友",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果是像你那麼溫柔的人就好了……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可是，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們是老師與學生呀……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是吧？　",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你也是這麼想的吧……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "不過，",
        "unit_id": 1411,
        "voice": "vo_adv_1018009_013"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "只要你們兩人覺得可以，就都沒問題了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "話說老師，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "我看妳相當猶豫的樣子，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n若是不介意，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "我來幫妳挑選推薦的食材如何？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好的，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "麻煩你了～……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "沒問題，",
        "unit_id": 1411,
        "voice": "vo_adv_1018009_015"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "包在我身上！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "來，",
        "unit_id": 1411,
        "voice": "vo_adv_1018009_016"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "讓你們久等啦！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？　",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這麼多？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "收據的對象請寫",
        "unit_id": 1411,
        "voice": "vo_adv_1018009_018"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "月光學院。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "謝謝惠顧～！",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "買太多了――！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n學院長有給我預算，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我想一定沒問題的吧……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個先撇開不談，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然家長也會來，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但一次的料理實習，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也用不完這麼多的食材。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "難得買到的食材，要是剩下了也不好，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對了！",
        "unit_id": 101811
    },
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就是這樣，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_022"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們開始料理實習的練習吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n總覺得",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和你一起去買東西之後，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就變得想要做料理了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你！　",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那一臉不安的表情",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是怎麼了啊？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你肯定以為",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "老師不會做料理對吧～？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "很遺憾，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_024"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就算是我，也多少會做料理的！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然沒到很擅長，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但自從出社會後，我就開始一個人生活，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n所以還是能做到一定程度的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是真的喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你坐在那邊看好了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我一定會做出讓你吃驚的美味料理讓你嚐嚐的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不對，",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_026"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不是這樣啦！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣不就真的像是在家裡自己做料理的情侶了嗎！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我現在要做的是",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "料理實習的練習！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "當天必須邊做料理邊教學生們怎麼做，不是嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "把多買的食材用來作為實習的",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "事前練習，就是這次的目的！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總而言之！",
        "unit_id": 101811,
        "voice": "vo_adv_1018009_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這裡就交給老師吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
