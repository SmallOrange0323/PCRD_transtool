[
    {
        "type": "background",
        "background": "500201"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怒火中燒的流夏等人，一齊攻入了溪谷洞窟――"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "啊……！？　",
        "unit_id": 1111,
        "voice": "vo_adv_5008006_000"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "是那些傢伙！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "喂～？　",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "魔法師少女和貧弱的陰柔男來了！！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "貧弱的陰柔男？",
        "unit_id": 102711,
        "voice": "vo_adv_5008006_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n竟敢對{player}大人",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n說出如此低俗的話語……！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是那些傢伙傷害了杏奈美眉和{player}……！",
        "unit_id": 101311,
        "voice": "vo_adv_5008006_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我絕對饒不了你們這群螻蟻――！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "惠理子、七七香，稍微忍耐一下吧？",
        "unit_id": 105111,
        "voice": "vo_adv_5008006_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我們得讓那些愚蠢之徒全部從洞窟出來才行。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "否則，就沒辦法好好蹂躪他們了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "打倒以後能獲得特別獎勵的對象就是那些傢伙嗎？",
        "unit_id": 911,
        "voice": "vo_adv_5008006_004"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "哦哦，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "移動龍卷風也在啊，有趣。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "嘿、嘿、嘿，",
        "unit_id": 811,
        "voice": "vo_adv_5008006_005"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "就讓我賺一筆吧～！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "你們這些傢伙！　",
        "unit_id": 1111,
        "voice": "vo_adv_5008006_006"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "還敢大搖大擺的回來，是什麼意思啊！？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "\n是為自己犯下的大罪感到害怕，打算前來謝罪嗎～？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "哼！　",
        "unit_id": 1111,
        "voice": "vo_adv_5008006_007"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "本來的話，你們應該是罪該萬死了！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "但",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "我們也不是惡徒。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "只要你們的夥伴所有人償還罪行，",
        "unit_id": 1111,
        "voice": "vo_adv_5008006_008"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "\n為採掘作業提供勞力的話，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "\n要我一筆勾銷放過你們也可以――！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "少說那種一眼就能看穿的謊言了，惡人！",
        "unit_id": 100911,
        "voice": "vo_adv_5008006_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n你們這些做盡壞事的傢伙，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就由我疾風之冥姬來制裁你們！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "妳說什麼……！？",
        "unit_id": 1111,
        "voice": "vo_adv_5008006_010"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "好大的膽子，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "我就讓你們哭喪著臉求饒！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦哦，",
        "unit_id": 105611,
        "voice": "vo_adv_5008006_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "越沒用的狗越會吠。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你忙著在那亂吠，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "都不曉得現在就是你的人生黃昏期了啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……你們給我把耳朵清乾淨聽好了！",
        "unit_id": 105611,
        "voice": "vo_adv_5008006_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我們所有人，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "會把你們狠狠斬殺到無法再看到明天的太陽！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "杏奈！　",
        "unit_id": 105611,
        "voice": "vo_adv_5008006_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "惠理子！　",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "深月！　",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "七七香！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要上囉！　",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大家盡情地大鬧吧！",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500201"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呵呵……",
        "unit_id": 102711,
        "voice": "vo_adv_5008006_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "各位，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為何要躲得這麼遠呢？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n你們越是逃走，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "地獄的苦痛只會越漫長而已呀。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還是說，",
        "unit_id": 102711,
        "voice": "vo_adv_5008006_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "你們這幫螻蟻希望盡可能地受苦，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n以聊表自己的歉意？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "你們以為做那種事，\n就能償還傷害{player}大人的罪了嗎……？",
        "unit_id": 102711,
        "voice": "vo_adv_5008006_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這群廢物臭蟲，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "消失吧消失吧消失吧消失吧消失吧消失吧消失吧……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "惠理子，",
        "unit_id": 105111,
        "voice": "vo_adv_5008006_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "拜託了，可以至少留下肉片給我嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n否則就沒辦法用來做實驗了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呀哈――！　",
        "unit_id": 101311,
        "voice": "vo_adv_5008006_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "髒東西就是要消毒啊！！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "歐拉歐拉歐拉啊啊啊啊啊！！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我就特別頒發給你們",
        "unit_id": 100911,
        "voice": "vo_adv_5008006_019"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n被我用最強究極殲滅魔法討伐的榮譽吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你們就懷著罪惡之心，",
        "unit_id": 100911,
        "voice": "vo_adv_5008006_020"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "在煉獄盡頭徘徊吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n唔喔喔喔喔喔！！",
        "unit_id": 100911
    },
    {
        "type": "background",
        "background": "500201"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "咕哇！　可、可惡――！",
        "unit_id": 911,
        "voice": "vo_adv_5008006_021"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "這些傢伙是怎麼回事！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n太強了！！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "根根、",
        "unit_id": 811,
        "voice": "vo_adv_5008006_022"
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "根本不是對手啊！！　",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "壞人",
        "words": "嗚哇哇哇！！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我說妳們啊。",
        "unit_id": 105611,
        "voice": "vo_adv_5008006_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這麼有幹勁是沒關係，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但可別搶了我的分喔？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "真是吵……",
        "unit_id": 2511,
        "voice": "vo_adv_5008006_024"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "在～做些什麼啊，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你們幾個？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "貴、貴族大人！",
        "unit_id": 1111,
        "voice": "vo_adv_5008006_025"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你出現了啊，惡人！",
        "unit_id": 100911,
        "voice": "vo_adv_5008006_026"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "大家，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那傢伙就是首領！！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊！　",
        "unit_id": 101311,
        "voice": "vo_adv_5008006_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是雜貨店的那個人……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是這樣啊，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我會被襲擊果然就是那傢伙搞的鬼～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你們這群失禮的傢伙。",
        "unit_id": 2511,
        "voice": "vo_adv_5008006_028"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "在新世界之王面前也太無禮了吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "王？　",
        "unit_id": 102711,
        "voice": "vo_adv_5008006_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是有趣的廢物臭蟲……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "很有弄壞的價值呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哼，",
        "unit_id": 100911,
        "voice": "vo_adv_5008006_030"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這下你那囂張的態度就是最後了！　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "給我死心吧！！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你們幾個。",
        "unit_id": 2511,
        "voice": "vo_adv_5008006_031"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我應該交待過要你們去討伐逃走的人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "這是怎麼回事？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "很抱歉，",
        "unit_id": 1111,
        "voice": "vo_adv_5008006_032"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "是那些傢伙強得太不像話了……！！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "強得太不像話……",
        "unit_id": 2511,
        "voice": "vo_adv_5008006_033"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "是嗎。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "那麼你們，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n還沒見識過真正的強者吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
