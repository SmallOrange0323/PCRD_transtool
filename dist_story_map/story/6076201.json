[
    {
        "type": "background",
        "background": "505035"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "小棉花糖",
        "unit_id": 117811,
        "voice": "vo_adv_6076201_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看到甜食，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不管量有多少都吃得下去，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n除此之外",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就沒有其他專長了嗎？",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我知道忠犬這個詞彙，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n說不定可以讓牠來",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "協助我們一統天下是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "喔喔！",
        "unit_id": 117811,
        "voice": "vo_adv_6076201_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不當忠犬，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "而是當忍犬是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "牠可以輕鬆鑽過狹小通道，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也可以利用牠可愛的外表",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "使敵人鬆懈下來，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n趁隙打倒敵人",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是吧！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "牠的活躍表現值得期待是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "腳程嗎……",
        "unit_id": 117811,
        "voice": "vo_adv_6076201_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那麼就是",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "傳令兵囉！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真不愧是將軍，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這是個好主意是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "連我也",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "追不上的極快腳程，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n有助於",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "迅速",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "傳遞將軍的命令給",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "各領地的家臣！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一統天下的道路",
        "unit_id": 117811,
        "voice": "vo_adv_6076201_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "的確",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "既漫長",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "又艱辛是也……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "日後也可能會遇到",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "令人灰心喪志的事……",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不過，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "到時候，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n小棉花糖的可愛模樣",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就能撫慰",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們的心靈是也！",
        "unit_id": 117811
    }
]