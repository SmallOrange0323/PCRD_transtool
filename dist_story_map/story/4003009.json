        "type": "dialogue",
        "name": "可可蘿",
        "words": "霧好像變得比剛才更濃了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人也要",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "多加小心一點。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼～～",
        "unit_id": 105812,
        "voice": "vo_adv_4003009_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼～～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，笨蛋佩可！",
