    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能會進去啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天就讓我先回去吧。",
