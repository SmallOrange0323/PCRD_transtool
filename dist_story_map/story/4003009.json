        "voice": "vo_adv_4003009_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要想著能吃到世界第一的蛋拌飯的話，",
