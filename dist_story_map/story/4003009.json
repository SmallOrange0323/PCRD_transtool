        "voice": "vo_adv_4003009_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真不愧是小可蘿！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……啊～真是的，",
        "unit_id": 106012,
        "voice": "vo_adv_4003009_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道了啦！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
