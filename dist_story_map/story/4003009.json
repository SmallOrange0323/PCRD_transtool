        "voice": "vo_adv_4003009_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "Let's Go～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然看準了瘴氣消退的時機",
        "unit_id": 105913,
        "voice": "vo_adv_4003009_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "爬到了這裡，",
