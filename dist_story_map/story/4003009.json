        "voice": "vo_adv_4003009_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}還有小可蘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大～家在一起才是【美食殿堂】呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼就一起",
