        "voice": "vo_adv_4003009_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留不想吃『絕世好蛋』嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～好吃的蛋拌飯都已經快準備好了呢～",
