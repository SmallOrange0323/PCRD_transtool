        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就是說，",
        "unit_id": 105913,
        "voice": "vo_adv_4003009_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是取得蛋的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大好時機，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣子對吧。",
