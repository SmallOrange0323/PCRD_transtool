    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "【美食殿堂】吃遍之旅要展開囉～☆",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500414"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本沒有人在加油吧！",
        "unit_id": 106012,
        "voice": "vo_adv_4003009_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來這裡是哪啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為霧的關係，根本什麼路都看不到吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "位於前方的就是",
        "unit_id": 105913,
        "voice": "vo_adv_4003009_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『毒瘴闇稜』。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是充滿有毒瘴氣",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與污泥的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一座小山。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "毒！？",
        "unit_id": 106012,
        "voice": "vo_adv_4003009_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　污泥！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們難道不是來進行吃遍之旅的嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼要來這種地方啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳問得很好喔，小凱留！",
        "unit_id": 105812,
        "voice": "vo_adv_4003009_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這次的目標是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『蛋』喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "居住在這惡劣環境下的",
        "unit_id": 105812,
        "voice": "vo_adv_4003009_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "山中生物呀，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽說在那種環境壓力下",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會讓美味更加熟成，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n進而產下絕品的蛋來喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其中由住在山頂的",
        "unit_id": 105812,
        "voice": "vo_adv_4003009_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『山之主』所產下的蛋，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽說是有著極品美味之稱的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『絕世好蛋』唷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其功效有滋養補身、",
        "unit_id": 105812,
        "voice": "vo_adv_4003009_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "健康無災、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "精神煥發、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "飽肚滿足！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣，",
        "unit_id": 105913,
        "voice": "vo_adv_4003009_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果有著那樣的效果的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就必須讓主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "品嘗看看呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913,
        "voice": "vo_adv_4003009_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "山上有這麼多的瘴氣的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根本就無法接近。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n究竟",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要怎麼做才好呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實",
        "unit_id": 105812,
        "voice": "vo_adv_4003009_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『山之主』現在正逢產蛋期。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在這個時期，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "山上的瘴氣與污泥",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n似乎會難得的減少唷！",
