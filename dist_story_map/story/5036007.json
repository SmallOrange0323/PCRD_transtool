    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "そしてまた、ある日の昼下がり。"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nランドソル王宮城門前に立つ黒鉄の鎧の前に、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n再び二つの影が集っていた。"
    },
    {
        "type": "still",
        "still": "502700001"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "マツリ団員、",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_000"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "トモね～ちゃんといっしょに",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ただいま戻りましたッス！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "おかえり、",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_001"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "トモちゃん",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "マツリちゃん。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n無事でよかったよ。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nさっそく",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "【ドラゴンズネスト】の調査報告をしてもらってもいいかな？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "はい。",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_002"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "船団の構成員のほとんどは、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ギャングやならずものたちでした。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ですが",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "今回の『開拓』は、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ギャングとしての活動ではなく、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n【ドラゴンズネスト】本来のギルド活動のようでした。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ギャングにギルドの手伝いをさせるなんて",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_003"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "すごいことしちゃうッスね、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ホマレさん……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "彼女たちが探していたのは、",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_004"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "遺跡と",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "そこに眠る何か……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "そこで手に入れた物を",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "どう使うかまでは分かりませんけど。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "ふむ……",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_005"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "『島』には文明の痕跡はないって話だったんだけど、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nその口ぶりじゃあ、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "遺跡は存在していたみたいだね。",
        "unit_id": 104711
    },
    {
        "type": "still",
        "still": "502700701"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "したッス！",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_006"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "あと",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "なんか",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ドラゴンみたいなのもいたッス！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "そうそう、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "あの人も一緒にいたッス！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\nなんか",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "仲良しさんみたいだったッスよ。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "そうだったのかい？",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_007"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nそれは興味深いね。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "正確には",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_008"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "遺跡の残骸",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "って感じだったのと、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ドラゴンみたいな生物だね。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "あの『島』は一筋縄じゃいきませんよ。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "管理協会も苦労するはずだ。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "それよりも──",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "ドラゴン族のほうが危険……",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_009"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "とでも言いたそうだね。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ただ、",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_010"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ギャングとしての活動をしていたとしても……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "彼女たちは、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n純粋に悪意だけで",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "動いているギルドではないみたいです……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "すみません、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "かなり私見がはいっちゃってますね。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "いや、",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_011"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "トモちゃんがそう言うのであれば",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "私は信じるよ。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nキミのそういう目利きには、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "いつも助けられているしね。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "カヤさんもイノリさんも",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_012"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "決して悪い人じゃないッス！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "まあ……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ホマレさんは何考えてるかよく分からないッスけど……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "いえ、",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_013"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "気になるところはありますけど、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "あの人とも知り合いでしたし……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nきっと",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "大丈夫だと思います。",
        "unit_id": 103711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "502700702"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ッスね！",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_014"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "　仲良くなれると思うっス！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "なるほど、",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_015"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "少年の知り合いだというのなら",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "そうかもしれないね。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nしかし、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "なんだか二人とも",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "ちょっと見ない間に成長したんじゃないかな。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n特にトモちゃんは",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "出発前よりもずいぶんと大人びて見えるよ。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ッス！",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_016"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "　前よりも",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "頼りがいあるッス！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "そうかなあ？",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_017"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "　自分じゃあよく分からないですけど……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "【ドラゴンズネスト】と",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "あの人のおかげかもしれないですね。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "じゃあ、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "お礼も兼ねて",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ご飯のついでに",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "あの人をからかいにでもいこうか？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "いいッスね！",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_018"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "　",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ちょうどランドソルの料理が恋しかったところッス！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "ふむ、",
        "unit_id": 104711,
        "voice": "vo_adv_5027007_019"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "もうすぐ定時だし、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "よければ私も行こうかな。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n二人の労を",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "ねぎらわないといけないからね。",
        "unit_id": 104711
    },
