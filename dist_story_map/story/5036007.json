    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ジュンさんのおごりですか？",
        "unit_id": 103711,
        "voice": "vo_adv_5027007_020"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "　",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "やった！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nよし、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "マツリちゃん、",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "いつもの店まで競争だよ！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "あ、",
        "unit_id": 100511,
        "voice": "vo_adv_5027007_021"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ずるいッスよトモね～ちゃん！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\n待つッスよ～！",
        "unit_id": 100511
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "で、",
        "unit_id": 106511,
        "voice": "vo_adv_5027007_022"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "どうなんだよボス。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "今回のことは",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "まるでムダ足だったってわけじゃないんだろ？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "ギルドの仕事としてはそうだね～",
        "unit_id": 106711,
        "voice": "vo_adv_5027007_023"
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "でも",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "ドラゴンを探すっていう",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "第一の目的は果たせなかったかな～……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "……管理協会と騎士団に影響力のある貴族たちには",
        "unit_id": 106711,
        "voice": "vo_adv_5027007_024"
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
