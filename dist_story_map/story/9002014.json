        "words": "\n{player}──"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101512,
        "voice": "vo_adv_9002014_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你好～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101512,
        "voice": "vo_adv_9002014_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這是這次的包裹呢。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n辛苦你了～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "謝謝你",
        "unit_id": 101512,
        "voice": "vo_adv_9002014_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "總是遠道而來，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n非常了不起唷～♪",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀？",
        "unit_id": 101512,
        "voice": "vo_adv_9002014_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "表情看起來有點沒精神呢～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是因為漫長的旅程覺得累了嗎～？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來，",
        "unit_id": 101512,
        "voice": "vo_adv_9002014_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "過來這裡吧～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n就在老師的膝蓋上",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "休息一下～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很好很好，",
        "unit_id": 101512,
        "voice": "vo_adv_9002014_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是個乖孩子呢～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為你很認真，",
        "unit_id": 101512,
        "voice": "vo_adv_9002014_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n一定是太過努力了呢～",
        "unit_id": 101512
    },
    {
        "type": "still",
        "still": "504600701"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過",
        "unit_id": 101512,
        "voice": "vo_adv_9002014_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師也受到你這種直率的個性",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很多幫助呢……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你為我創造了閃閃發亮的回憶，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是我自豪的學生呢～",
        "unit_id": 101512
    },
