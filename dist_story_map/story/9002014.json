        "voice": "vo_adv_9002014_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "他好像剛好睡著了。",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n看起來似乎是累了，",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就讓他這樣休息一下吧～",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以",
        "unit_id": 101512,
        "voice": "vo_adv_9002014_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "趁這段時間……",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "懂嗎？",
        "unit_id": 101512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，",
        "unit_id": 101512,
        "voice": "vo_adv_9002014_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "早安～",
        "unit_id": 101512
