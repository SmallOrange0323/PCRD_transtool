[
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在瑪爾傑海岸\n和【墨丘利財團】的珠希與美冬相遇，\n為了釣魚當晚餐搭船出海了。"
    },
    {
        "type": "still",
        "still": "500500001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯──",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "魚完全不上鉤呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為難得來海邊",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "自己煮晚餐的話比較便宜，\n雖然我也理解美冬的想法，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不過我快厭倦了喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "已經想回家了喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不不珠希，",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "在這裡放棄才是最沒效率的唷。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這艘船可不是免費租來的，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n得賺回本才行！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "話說回來，也謝謝{player}，",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n協助我們借這艘船呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "幫了大忙喔！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過……",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣一直釣不到魚的話好無聊喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n啊～啊，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這種時候有貓咪在就好了喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在蘭德索爾的話因為貓咪會來幫忙，",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n如果我能把事情交給貓咪自己去一邊涼快就好了喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "別說些沒道理的話了。",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n海上怎麼可能會有貓呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n又不是夢裡的故事。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "夢裡的故事……",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n說到這個，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "昨天有觀光客\n在海邊說了這樣的事情喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "據說是，",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "從這個瑪爾傑海岸往南的地方，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n有一座「實現願望之島」……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "的樣子喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊啊，",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我也有聽過那個傳聞喔。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n抵達那座島的漂流者，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可以獲得金銀財寶之類的……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "說到底也只是傳聞，\n並不是從實際上去過的人那聽來的喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一定是編出來的故事喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果是我的話，",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "想要用貓咪打造出很多樂園，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n被貓咪包圍著優雅地生活喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然我沒期望到那樣，",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但如果能讓物價變便宜的話我會很開心呢。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過，",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「實現願望之島」",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然不可能存在，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n但像這樣只做著白日夢的話也很開心呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就是啊喵～",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總覺得，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "陽光暖呼呼的，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n好像真的要作夢一樣喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯……",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "從剛剛開始釣竿一點反應也沒有，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n海浪也很平靜，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好像開始……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "變得很想睡呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵……",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好舒服喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n只睡……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只睡一下下",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "午覺就好了喵……",
        "unit_id": 107911
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀，{player}？",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "已經睡著了。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "珠希也躺下去了……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過，算了。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}，太狡猾了竟然先睡喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我也要睡了喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "轉眼之間大家都睡著了呢……",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n因為我是這艘船的船長",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "所以不能睡著……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不能……",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "睡著……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼啊……",
        "unit_id": 108011
    },
    {
        "type": "background",
        "background": "500280"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……嗯",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這裡，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是哪裡喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "睡在沙灘上……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我們什麼時候回到瑪爾傑海岸上的喵……？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "能平安無事歸來就好……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "周圍的景色和瑪爾傑海岸\n完全不一樣喵────！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "美冬、",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "快起來喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n事情糟糕了喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯……",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "幹嘛啦……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "再睡一下……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "欸，",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我、",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "睡著了！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真是太大意了！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這、",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這裡到底是哪裡！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n至少不是瑪爾傑海岸的樣子……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "剛剛搭的船也不曉得去哪了……",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也就是說，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n在睡著的期間船沉了，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n只有我們這麼剛好地抵達這裡嗎？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯……",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不諳水性的我也不可能無意識的游泳，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然這麼說",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但我也沒有溺水的記憶喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好奇妙喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "話說這裡，",
        "unit_id": 108011,
        "voice": "vo_adv_5005000_029"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "到底是哪裡呢……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n不同於瑪爾傑海岸，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n感覺人煙罕至……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "從周圍的地形來看，",
        "unit_id": 107911,
        "voice": "vo_adv_5005000_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好像是島嶼喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "稍微看看這附近有沒有人在，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
