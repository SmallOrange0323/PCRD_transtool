        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這件事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算對在下來說，",
        "unit_id": 105913,
        "voice": "vo_adv_2102010_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也認為",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是正確之事。",
        "unit_id": 105913
    },
