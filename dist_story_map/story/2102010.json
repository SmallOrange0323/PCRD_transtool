        "type": "background",
        "background": "500017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人。",
        "unit_id": 105913,
        "voice": "vo_adv_2102010_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下是",
