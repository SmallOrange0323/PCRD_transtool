        "type": "background",
        "background": "510123"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被晶小姐所委託……",
        "unit_id": 105913,
        "voice": "vo_adv_2102010_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要將被囚禁在『這個世界』的人們，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
