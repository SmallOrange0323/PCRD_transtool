[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咀嚼咀嚼咀嚼♪",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔啊，真好吃～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥怎麼會",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n知道這麼棒的店？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔喔，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "原來哥哥加入了一個叫作『美食殿堂』的公會？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然後這個公會的成立目的是邊走邊吃？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "什麼嘛，好像很好玩！",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真好呢，感覺好悠閒，真令人羨慕♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥問我『璃乃願意的話，要不要也加入～』？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不了，因為我已經加入",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n拉比……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我是說其他公會了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我很感謝哥哥的邀請，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但是我現在想認真地從事那個公會的活動～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我現在要專心於那邊～♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要同時隸屬於好幾個公會",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n雖然也不是不行。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只是我並沒有那麼機靈，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n無法同時兼顧好幾個地方。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以，哥哥要是",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n發現什麼好吃的餐廳……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要偶～爾像這樣推薦給我就可以了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我只要這樣",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就覺得非～常幸福了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "其實我是不能這麼做的，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過下次我們再像這樣來約會吧……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過說真的，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我覺得這家店真的有夠好吃。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "蘭德索爾很大呢。",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為我也很少在自家附近以外的地方閒逛，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以不知道有這家店。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，真是的，這種小蛋糕吃到飽之類的！",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是一家夢幻的店呀～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n一個個蛋糕也都凝聚了設計巧思，好可愛♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "口味也很棒，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好吃到下巴都要掉下來了♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "掉下來……",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我的入學考試落榜了呢……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚嗚……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "吸鼻聲！",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，我沒事的，我沒有哭！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為哥哥的鼓勵，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我已經完全打起精神了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來、來吧，哥哥也請吃蛋糕！",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們難得來吃到飽的店家～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以不吃到撐破肚皮就太可惜了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚哇！？",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥好像",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n在發光喔……？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦咦，這是什麼？",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥難道有著吃了甜食就會發光的",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n奇妙體質嗎……？",
        "unit_id": 101112
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚噎噎～……！",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "抽泣，抽泣！",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n嗚嗚～！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n嗚啊啊啊～……！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……啊嗚？",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n啊，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥午安！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總覺得，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們總是在意想不到的地方見面呢？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "吸鼻聲……",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，沒事，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我不要緊的喔？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然我是稍微哭了一下，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過我並不是哪裡受傷了！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是的，哥哥真是愛演出操心秀呢！",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "表演時間到了呢！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔、唔唔？",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n等等，哥哥？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不要強行用手帕擦我的臉！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔～……",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我是無所謂，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n可是隨便就摸女孩子的臉是不行的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為如果對方化著濃妝，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥就會不小心打開潘朵拉之盒的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n可是總覺得看到哥哥的臉後，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就放心了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥總是……",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n只要我一哭泣，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就會像英雄般地飛奔而來呢。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我明明是個愛哭鬼，但託哥哥的福……",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "最近好像",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n已經不太容易哭了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就連哭得淅瀝嘩啦而得名的哭哭璃乃這個外號，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也沒有人記得了吧。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為託哥哥的福，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "即使只有一點點，我也變堅強了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，哥哥不記得了嗎？",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為我以前是個愛哭鬼……",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以被稱為哭哭璃乃，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還被人嘲笑捉弄。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我總是哭到眼淚掉不停，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_039"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n名字又叫璃乃，所以就變成哭哭璃乃……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為這個外號沒給我什麼好的回憶，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以請哥哥就像平常一樣叫我璃乃。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我已經很少再哭了喔。",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_041"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_042"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不是，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那是不同人……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我知道哥哥常常會提到她，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_043"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不過那個人的外號也很奇怪呢。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯。",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_044"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n那應該不是本名吧，一般來說的話。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但總覺得是個有點親切的外號，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_045"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n命名的品味和我一樣。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我真想見見對方一次呢。",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_046"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……我也有很多事想問她。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯？",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_047"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥問我為什麼在哭？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唉～……我的模擬考試結果太慘了，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_048"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n讓我意志消沉。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我明明很努力",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_049"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n用功讀書……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然我只要在正式考試前再多加努力，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_050"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n漂亮地及格就可以了，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但我今天實在覺得有點鬱悶。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥。",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_051"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果可以的話，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我讀到不懂的部分要請哥哥再教我喔。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "虧我受了哥哥諸多照顧，",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_052"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n如果沒考上的話就太對不起哥哥了……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我會好好地考上給哥哥看的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101131,
        "voice": "vo_adv_1011004_053"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n以後也請繼續替我加油喔，哥哥♪",
        "unit_id": 101131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "考試呢……",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是一個我無法體會的煩惱，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n畢竟我沒有上過學。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那方面的事情也已經被補足，",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n大家似乎也無法再將現實中的煩惱置之度外了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要加油喔，璃乃～，",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我會支持妳的♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n抱歉抱歉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我如果不好好說明，會讓你很困惑吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我重播了你與緣份深厚的人之間",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n特別的回憶，讓你藉此體驗。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為我不是你本人……",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以只能用這種迂迴的方法，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n來幫你整理腦內的記憶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想我暫時還會……",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n讓你不斷地",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n重複做同樣的夢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果沒有任何準備就取回『原本的記憶』，",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你的腦袋會錯亂的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話～說，即使我說明，你應該也聽不太懂吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但希望你現在能先相信我，交給我來處理。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒事的，",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我會努力的，好嗎。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為我也和璃乃一樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n甚至比她還更受了你諸多照顧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我打算以報恩的心態，",
        "unit_id": 190011,
        "voice": "vo_adv_1011004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n盡我最大的努力加油。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥～？",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_066"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥怎麼了，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_067"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n總覺得哥哥好像在發呆～？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "關於剛才那道奇怪的光芒，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_068"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我問了靜流姐後大概了解是什麼情況了……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我就放著不管它，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_069"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如靜流姐說的試著稍待片刻。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥有沒有覺得哪裡不舒服？",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_070"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n要不要喝點茶呢？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯？",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_071"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥說抱歉？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為什麼哥哥要向我道歉？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥說明明是要來鼓勵我的，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_072"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n卻反過來被我照顧，覺得很抱歉……？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊哈哈～。",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_073"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥原來是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n會在意這種事的人嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "而且，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_074"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n一直以來都是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我向哥哥撒嬌。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_075"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我偶爾也會想疼愛哥哥的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會用比蛋糕還要甜膩！",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_076"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有著滿滿鮮奶油的愛情，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n來伺候哥哥喔……☆",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_077"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我不要緊的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n考試結果雖然很遺憾，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過還有下一次機會。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥的事也是，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_078"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我心裡產生了希望，覺得或許會有辦法的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "蛋糕這麼甜又好吃，",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_079"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n今天的天氣也非常好！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以讓我想哭的理由",
        "unit_id": 101112,
        "voice": "vo_adv_1011004_080"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n可是連一個也沒有喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n啊哈哈♪",
        "unit_id": 101112
    }
]