[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "靜流～姐",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "☆",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇喔？",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哈囉璃乃，好久不見！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不能突然從我背後撲上來啦！",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n會嚇到人的♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃？",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n怎麼啦，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n躺在地上的話會把衣服弄髒……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喔♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "危險！？",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果只是兇我一句倒還好，請別打算踩我，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為踩中要害的話可是會死人的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是的，",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n靜流姐還是老樣子很暴力呢～？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "虐待很不好喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳剛才也是轉過身來，",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就朝著我的胸口扎實地揍了一拳吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "害我那一瞬間都停止呼吸了！",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n咳，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咳！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對不起啦～",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我以為妳是盜賊嘛♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "盜賊才不會在這種城鎮裡四處閒逛呢～……？",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是但是，我們必須隨時保持警戒才行。",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為我們可是探索世界之謎的祕密社團【拉比林斯】，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不知何時會被人當成目標盯上喔？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可以的話我真不想連自家人都戒備～",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但我也了解妳的意思啦。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是那個吧，如果吃了藥就要把腸胃通乾淨♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是『備戰狀態』啦～……",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個，我想應該是這附近？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是啊，今天會長很罕見地召集了我們對吧？",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "由於是睽違許久的活動，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我都快要忘記自己隸屬於【拉比林斯】了♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也是～",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是的，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因為我們的會長太懶散了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，為了再見到被不講情理的命運拆散的『弟弟』，",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我要努力解開世界之謎♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也是，",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n為了有一天能再見到『哥哥』，我會傾盡全力♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唉呀！",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我找到會長了喔，靜流姐♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇喔，不愧是弓箭手的好眼力。",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……啊，是那家可麗餅店嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "原來我們家的會長，",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n白天真的是在賣可麗餅過日子呀～？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但她的真實身分其實是！",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n率領祕密社團【拉比林斯】、",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n武功高強的劍士兼大魔法師！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是這種感覺吧～真帥氣呢！",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n好像童話故事♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "最好不要那麼大聲地把【拉比林斯】說出口喔～",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因為這姑且算是個祕密社團啊。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "日安，會長。",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們奉命前來了♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來，歡迎光～臨。",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n請問要點什麼……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "什麼嘛，是靜流與璃乃啊。",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這麼說來我好像是有叫妳們過來，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉抱歉，我忘記了♪",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦～？",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n真是的，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會長還是老樣子，這麼隨性♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "話說，",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n那個啊，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會長您那副打扮是怎麼回事？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "您一身花俏無比的全副武裝，",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n簡直就像是接下來要面臨最終決戰一樣。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們是祕密社團吧？",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這樣不會有點太招搖了嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我之前就有點懷疑了，難道會長您是笨蛋嗎？",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "總之，那應該不是做生意時該穿的服裝吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "咦～很帥氣吧？",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我喜歡紅色系的～",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過託這身打扮的福，客人完全不敢過來！",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n啊哈哈☆",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那是當然的呀，",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n壓迫感強到讓人無法靠近。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這一帶明明是年輕人當作約會景點的時髦地段～",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但會長卻和周遭的風景格格不入喔？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是說啊～……",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_036"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n可能因為這個緣故，總是沒什麼客人上門。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好不甘心！",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_037"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n明明只要吃上一口，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就會知道我們家的可麗餅是最棒的！",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "到底是哪裡沒做好呢？",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_038"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "地點不佳？宣傳不夠？跟不上流行？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該熱賣的東西卻乏人問津，這個世道不對啊，",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_039"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n到底是誰把世界搞成這樣的？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是神明嗎！？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總之我認為您必須把衣服換掉，",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n換成可愛的圍裙之類的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我很擅長裁縫……",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_041"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要不我來替您做一件吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，那真是幫了我大忙！",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_042"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n叫璃乃妳們過來果然是對的～♪",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳們能順便替我招攬客人嗎？",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_043"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "果然還是由年輕女孩來賣，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n比較能吸引客人吧～♪",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個，會長……",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_044"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n如果是找我們辦那種事的話，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n可以請您放我們回去嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "別看我們這樣，其實我們很忙的～",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_045"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n由於剛搬來這座城鎮，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們都還沒安定下來？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，沒問題沒問題。",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_046"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我找妳們還有別的正事，所以別回去～？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我要交代妳們一個小小的祕密任務♪",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想和一位暫稱為『諾維姆』的孩子有所交集。",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_047"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n因為，她似乎與世界之謎有關。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只是，那孩子似乎正被通緝中。",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_048"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在她被其他公會逮住前，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n希望我們能先火速抓到她。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為她是這幅被稱為世界的拼圖中很重要的一片。",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_049"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是喔……",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_050"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看來會長您姑且算是沒忘記",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n【拉比林斯】的活動目的嘛？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好吧，我就接下這個祕密任務。",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_051"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n首先是收集情報吧，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能掌握到那個叫『諾維姆』的孩子目前在哪裡嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔……",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_052"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n一旦決定好要做的事，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "靜流姐就是俐落行動派的呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我當然也會同行，",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_053"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過按照慣例，會長這次也無法一起行動嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯，",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_054"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我有我的立場，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n無法隨意行動。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為我也是被鑲在這個該死世界裡的",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_055"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n『重要拼圖』之一。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要勞煩妳們兩個了。",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_056"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉，我一直都很感激妳們。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "事到如今，您就別說客套話啦。",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_057"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我也理解您的立場，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在彼此利害一致時，我都會協助您的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸嘿，包在姐姐我身上♪",
        "unit_id": 104911,
        "voice": "vo_adv_3006001_058"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唉呀，",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_059"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真讓人興奮呢！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "祕密社團【拉比林斯】總算認真動起來了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "情緒亢奮起來了～！",
        "unit_id": 101112,
        "voice": "vo_adv_3006001_060"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿，我得先來保養弓箭才行♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯，",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_061"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n感謝妳們兩位。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要我獨自應戰的話，",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_062"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n世界實在是太過龐大的敵人，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以需要大家互相攜手合作。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們要讓神明了解偉大人類的潛力。",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_063"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n破解命運，讓這個世界的謎團水落石出吧。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我絕對不會讓謎團就這麼不了了之，",
        "unit_id": 106813,
        "voice": "vo_adv_3006001_064"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n絕對不會。",
        "unit_id": 106813
    }
]