[
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "……唉唉。",
        "unit_id": 16711,
        "voice": "vo_adv_5102308_000"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "看來，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "是我太天真了，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n以為可以輕鬆漂亮地戰勝御久間流的繼承人和收藏家等人。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "沒辦法了，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "接下來就讓我拿出全力吧！",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳還可以變得更強嗎！？",
        "unit_id": 123711,
        "voice": "vo_adv_5102308_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唉……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然一路打到了這裡，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n可是老實說，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我發現我好像有點怕輝美閣下耶。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n看她把魔法斬得七零八落的，就讓我想起了流夏姐啊……",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "天下第一的【暮光流星群】都在喊苦了，",
        "unit_id": 123511,
        "voice": "vo_adv_5102308_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "智妳覺得呢？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要舉白旗投降嗎？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 123611,
        "voice": "vo_adv_5102308_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "老實說，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "輝美小姐的實力",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "更勝於我。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不過，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那絕對不會是我退縮的理由！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "為了蘭德索爾居民大眾的「喜歡」……！",
        "unit_id": 123611,
        "voice": "vo_adv_5102308_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我必須在此",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "挺身對抗才行！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "小智……",
        "unit_id": 123711,
        "voice": "vo_adv_5102308_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……我",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只是因為魔法被斬破",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就有點喪志了。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過是啊，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "畢竟我們要是不在此時撐住，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "直播界就危險了！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好──",
        "unit_id": 123711,
        "voice": "vo_adv_5102308_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要上囉～！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我會讓妳見識見識",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "收藏家的真正實力！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可以的話不要再斬我的魔法了！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗯，",
        "unit_id": 123511,
        "voice": "vo_adv_5102308_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然說了些有的沒的，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過就先不提了吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我也會奉陪到最後的。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "認命吧，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "人氣直播主。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "呵……",
        "unit_id": 16711,
        "voice": "vo_adv_5102308_008"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "有意思！",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "來吧，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "這將會是場最精彩的演出！",
        "unit_id": 16711
    }
]