[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呵呵呵！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我買了新的裁縫組呦～♪　",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要有這個就可以天下無敵，八面玲瓏的大活躍！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯？好像有哪裡說錯了，八面……拉麵？",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "進退兩難的大活躍，唔～嗯？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "算了，怎麼樣都好！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總之，只要有這個新的裁縫組……",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我就能做出任何衣服！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "像是可愛的衣服等等，什麼款式都能做～♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為在這之前，",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我手邊只有媽媽用過的老舊裁縫組……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "針都生鏽了，",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "無法運用自如，還讓我的手指傷痕累累。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過不過，感覺就像因禍得福的虎克船長！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如此這般，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為我的手指包滿繃帶，實在太慘不忍睹……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "常去的店家的人就擔心的問我",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "『手上的傷是怎麼了』～？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不僅聽我訴苦，還把裁縫組便宜賣給我♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "非常感謝那位店員！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我記得是叫紡希小姐？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不只是優秀的服裝設計師，",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n心地也很善良！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "簡直是女神……☆",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我是妳的設計的忠實粉絲！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這份恩情，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會用打工存的錢買下妳的新作品來還♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖說……那家店的衣服價格非常高，",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n實在很難買下手～？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也要努力做裁縫，",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "等到能做出好衣服時……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就拜託會長，請她讓我在店裡販賣吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣的話就會有兼職收入，也能賺回布匹等材料的成本！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，夢想越來越大了～……♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，在那之前得先做會長拜託的圍裙才行。",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要穿上圍裙，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n一定能夠多少減輕一些會長給人的……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "壓迫感。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要會長別穿著一身奇裝異服，",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可麗餅店的生意應該會多少好一點。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可麗餅店賺錢的話，我也能拿到打工費！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一定也可以買好的布料～",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n然後就自己做可愛的衣服來穿吧♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我要打扮得很可愛，把哥哥迷得神魂顛倒～♪",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然有和靜流姐約好不能偷跑的，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n要這麼做也還早得很啦～？",
        "unit_id": 101112
    },
    {
        "type": "still",
        "still": "300600201"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你看你看～",
        "unit_id": 104911,
        "voice": "vo_adv_3006002_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n看這邊，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n再多看姐姐一點～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你看，我在那家店試用了化妝品！",
        "unit_id": 104911,
        "voice": "vo_adv_3006002_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "感覺怎麼樣……？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐有變美嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯！",
        "unit_id": 104911,
        "voice": "vo_adv_3006002_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就是說嘛！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "欸嘿嘿，你真老實～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯！",
        "unit_id": 104911,
        "voice": "vo_adv_3006002_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了你，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐會變得更漂亮！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "最喜歡你了！",
        "unit_id": 104911,
        "voice": "vo_adv_3006002_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n接著一起去挑衣服吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐會讓你心醉神迷的～♪",
        "unit_id": 104911
    },
    {
        "type": "still",
        "still": "300600202"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……嗯嗯嗯！？",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "什、什麼？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦咦咦！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、我才在想好像有什麼嘈雜的聲音……",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n那是靜流姐吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n靜流姐挽著手的人是，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "他們兩個在做什麼呢？",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n總覺得非常有約會的氣氛！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "等等～，不是說好禁止偷跑嗎！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好奸詐！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不，應該說是太過分了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、我明明這麼努力地在忍耐！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n為了成為哥哥『理想中的妹妹』，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n非常踏實地努力著～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然後等到能好好地與哥哥再會時……",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n想讓他稱讚",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我變可愛了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我才會忍著不接近哥哥！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我拼命忍住想向哥哥撒嬌的心情……",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "結、結果靜流姐卻～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不行！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不能懷疑靜流姐，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們擁有同樣目的，都是【拉比林斯】的夥伴！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們是超越血脈之親、情誼深厚的同胞！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不，是家人！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我必須相信靜流姐！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那一定是哪裡搞錯了！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "靜流姐不是會打破約定的人，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n只是偶然遇到哥哥罷了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "靜流姐只是帶著喪失記憶的哥哥",
        "unit_id": 101112,
