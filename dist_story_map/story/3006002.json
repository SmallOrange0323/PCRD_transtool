    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……什麼事，璃乃？",
        "unit_id": 104911,
        "voice": "vo_adv_3006002_063"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n看妳一臉可怕的表情，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳笑起來比較可愛呦～♪",
        "unit_id": 104911
    },
    {
