        "voice": "vo_adv_3006002_084"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就由我來好好向他說明。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "三人一起愉快的做些類似約會的事……",
        "unit_id": 104911,
        "voice": "vo_adv_3006002_085"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "並由我們從中守護",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
