    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們就一起保護弟弟吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我、我知道了。",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_079"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "什～麼嘛，原來是這麼一回事啊♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "靜流姐不是那種會破壞約定、良心被狗吃了的爛人，",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_080"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n真是太好了……♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯。",
        "unit_id": 104911,
        "voice": "vo_adv_3006002_081"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n妳能再多信任我一點的話，我會很開心的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "比起那個，",
        "unit_id": 104911,
        "voice": "vo_adv_3006002_082"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n讓弟弟等的話不太好……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為放那孩子一個人會很危險，",
        "unit_id": 104911,
        "voice": "vo_adv_3006002_083"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們去弟弟身邊吧。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "兩個人一起回去吧♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟那邊，",
