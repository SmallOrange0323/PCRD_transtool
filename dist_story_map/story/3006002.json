    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不！",
        "unit_id": 101112,
        "voice": "vo_adv_3006002_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n靜流姐她只是情緒亢奮了點而已！",
