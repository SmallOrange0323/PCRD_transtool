        "voice": "vo_adv_1230004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我們應該有約定碰面地點在塔下方了吧？",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n時間早就已經過了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他是在做什麼啊……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……好慢！",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_059"
    },
    {
