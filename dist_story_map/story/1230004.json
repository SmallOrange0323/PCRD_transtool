[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那一天的愛梅斯，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在維護以{player}和他的夥伴們的記憶，\n創造出來的假想空間──"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣就好了……",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "檢測結束。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "之後就只剩最後的啟動測試了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果不確實維護，就會讀取到異常的資料，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並發生讓人感到奇怪的現象，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "結果變成像是清醒夢一樣的狀態吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對了，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "該說是設定座標嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我得決定包含那在內的場景位置……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯～？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "該選在哪裡呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過今天就只是測試，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n反正",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也只有我能進來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該可以隨我高興吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只要按照設定來進行就好。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "既然如此……",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就全憑我高興了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "時段和地點像這樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "其他的條件則是……",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我只是偶爾進來，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但{player}和大家所在的世界，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n果然很不可思議呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這不是{player}的樣本嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經設定了配置嗎……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……算了，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正也不是本人。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你不過就只是外表相同的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "假想數據呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "人類時常會在這種交通要地碰面啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "機會難得，我也試試看吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "去稍微遠離一點的地方……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊！",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉喔～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你等很久了嗎～？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒等太久？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……啊～？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛又在幫助別人了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……好了，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "玩笑差不多就此打住，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n測試測試……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "別問那種事。",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我說你啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還沒學會體貼要敏銳這件事嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就連會問這種脫線問題的地方都一模一樣嘛。",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣的話可以當作測試已經成功了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算是吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正確來說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是把像夢境一樣的東西展現給你看的情節測試……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等一下。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n為什麼明明是假想數據，卻會提出那種問題……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你、",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你該不會……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "果然是本人嘛！",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你在這種地方做什麼啊！！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你是",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說真的……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但那種少根筋的回答，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n又是{player}沒錯……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是夠了！",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我說你啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是在的話就說一聲啦！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也是需要做心理準備的啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……你似乎是真的不知道發生什麼事呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唉……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "聽好囉？",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這裡是我一直以來給你看的，像夢境一樣的地方，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而我現在正在測試那個夢境是否有好好運作。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "特地把你叫來測試也很奇怪，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以我有另外準備代替本人的角色……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但不知為何你卻過來了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼會變成這樣呢……",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這只是測試真是太好了啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖說這樣就不得不",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "測試其他的東西就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許是因為",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}的公主騎士力量，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n又變強了也說不定。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或是因為跟我的羈絆也變強了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以他變得更容易過來這邊了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那種事就等測試結束後再調查……",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "欸，你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果有空的話，就配合我的測試吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也沒什麼大不了的，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就是確認那邊世界的重現性之類的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "大概是那樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以主要就是跟我一起到處去玩。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就這麼決定囉，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那我們走吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "首先──",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "510320"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就從這附近開始吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算一個人來遊樂園，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也不太能理解樂趣所在，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但如果有兩個人就會有點不同吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咖啡杯、雲霄飛車……",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你覺得哪個遊樂設施最好玩？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我還期待更有主見一點的回答……",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過聽說凡事就是要試試看，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我會一個一個坐的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要走囉。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯──",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好～冰♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一不小心就興奮過頭了啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n遊樂園相當有趣呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真要說的話，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我一直嚮往的是像這樣在咖啡廳聊天。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過我算是了解到，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那也有那的優點了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我好想在那邊跟小可可蘿來咖啡廳約會啊～",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想一～直看著她吃甜食……♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說的也是呢，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這裡又不是只賣飲料的地方，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要不要也點塊蛋糕看看呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也吃吧，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n畢竟我也不會知道",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "味道有沒有重現。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "來了來了。",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……你點的看起來也很好吃呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n給我吃一口。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你在做什麼啊？",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我會自己吃……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你還是就這樣別動吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊──",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n哈呣、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊呣……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哦～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "挺不賴的嘛，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還不錯。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我自己點的如何呢……？",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊呣……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我的比較甜，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但現在的我可能更喜歡你點的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這裡的測試之後是……",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_037"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，{player}和愛梅斯一起，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n逛了各式各樣的地方。然後──"
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最後是這裡喔，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_038"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你上學的學校。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你度過日常生活的地方，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n必須要仔細測試才行。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這裡……",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_039"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會很花時間的吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要給你看看有趣的東西嗎？",
        "unit_id": 190011
    },
    {
        "type": "still",
        "still": "123000401"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "鏘鏘──♪",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "適合我嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你說點什麼啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你所在的世界，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並沒有身體像我一樣",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的人類，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以你會覺得很怪吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，是嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算是客套話我也很開心。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你最後坐的座位是那邊吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n話說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在的你也不記得了啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你就是在這裡與夥伴們度過的……",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你在學校",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也偶爾會玩阿斯特朗喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n得知這件事後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我相當驚訝啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……以前我",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總是在巨大的你周遭飛來飛去呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現在我變得能夠像這樣和你一起走在這裡，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這個過去只能聽你談論的地方了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是少數能讓我覺得，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n變成這具身體真好的事情之一喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也曾認為自己吃了很多苦頭。",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能像這樣和你一起和平度日，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也覺得我沒放棄真是太好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在阿斯特朗也？",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這麼說來，自從我不受世界修正影響之後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n明明都經過一段時間了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但我完全沒有跟你在阿斯特朗出去玩過呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唉，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "之前發生了很多事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以也完全沒有出去玩的時機就是了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這提案不錯呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然今天的測試也已經讓我轉換心情了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但感覺能體會到跟這不同的趣味……♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我接受",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的邀請。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你會帶我去哪裡呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好期待啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你好好安排路線吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那是當然的吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "邀請我的是你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以你要讓我玩得開心，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明白了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你可別讓我失望喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以你",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼時候有空？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為是你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n想必",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟女孩子有很多約定吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "時間表就由我來幫你決定，",
        "unit_id": 190011,
        "voice": "vo_adv_1230004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟我有自信比你更清楚那些事。",
        "unit_id": 190011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "愛梅斯調查了{player}的行程，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並決定了出遊的日期。然後到了約定的日子當天──"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……好慢。",
