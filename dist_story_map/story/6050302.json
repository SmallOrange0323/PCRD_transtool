    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我說不定意外地很有資質？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是、",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是這樣嗎？",
        "unit_id": 114111
