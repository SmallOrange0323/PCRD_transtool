    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "仕立て屋の仕事が大忙しのありがたいイベント。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "でもこんな形で関わるのは初めてですね……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "当たり前です。",
        "unit_id": 113911,
        "voice": "vo_adv_6050105_001"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "騎士さんが言い出したことですからね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "た～っくさんコキ使いますからね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "覚悟してください。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "なんでそんなにうれしそうなんですか？　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "気味悪いですよ。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ずいぶんと余裕じゃないですか。",
        "unit_id": 113911,
        "voice": "vo_adv_6050105_002"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\nまぁ、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "嫌々やるものでもないですしね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "うん、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "楽しんでやっていきましょう。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "そもそも騎士さんが手伝うなんて言い出すからじゃないですか。",
        "unit_id": 113911,
        "voice": "vo_adv_6050105_003"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "でもまぁ",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "いいきっかけになったのも事実ですよね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "せっかくなので",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "この機会を活かさせてもらいますよ。",
