    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "他知道關於傳說中的魔導書的事情。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我之後也打算要好好的調查那男人，",
