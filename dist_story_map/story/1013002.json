[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}來到鬧區購物時，\n聽到一陣似曾相似的情緒高昂的聲音。"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喵哈──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天可是大豐收呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是太棒了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只是逛逛魔導書和喜歡的創作，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就讓人",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雀躍不已！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "請給我三本那本書！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n收據的名字請寫「暮光流星群」～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "買齊欣賞用、",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "收藏用、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "傳教用共三本是御宅族的義務！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "下一間～是……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯？",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔喔！這不正是{player}隊員嘛，\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "竟然在這裡相遇，真巧啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯嘿嘿，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "問得真好！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "今天",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可是為了尋找喜歡的創作新作品，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而來的定期巡迴喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可不是單純的買東西而已喔！",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "定期巡迴是每天固定的行程！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我的興趣是",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "搜刮喜歡的作品和小物，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n所以會定期來鬧區喔。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "特別喜歡魔法少女，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真想成為漫畫中的魔法少女呀。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "漫畫中的魔法少女，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "平常也只是個普通的女孩，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n但必要時卻能為大家而戰不是嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "又強，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "又可愛，根本是最強的嘛！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚哈──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真讓人受不了啦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以我也要以",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "成為能夠守護大家，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而且最可愛又最強的",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n魔法少女為目標──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊！",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "該不會……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你也對",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法少女有興趣！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唉呀，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為平常幾乎沒有人會這麼冷靜地",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n聽我說這些御宅族的事情，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以嚇了一大跳。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以我想",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你應該有興趣，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼樣？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如何！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你現在現在感覺如何！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就算不問七七香也看得出來喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你一定喜歡魔法少女！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不接受否定答案喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔～！",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我就覺得是這樣嘛──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "很好！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你從今天起不是魔法少女就是魔法少年了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我會幫你準備可愛的服裝和魔法手杖等等的，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n雙人搭檔的魔法少女也很棒對吧～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對了！",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "來想雙人搭檔用的台詞吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚哈──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "來了來了妄想不斷湧出來──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "欸──！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為什麼──？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這發展正精采的說──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你說……",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想服裝什麼的",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "很開心的說。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……但",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你不喜歡的話那也沒辦法呢──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果你改變心意了隨時都歡迎你喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "一如往常的吵鬧呢。",
        "unit_id": 1211,
        "voice": "vo_adv_1013002_023"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "七七香。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "興致真高呢。",
        "unit_id": 411,
        "voice": "vo_adv_1013002_024"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n不會累這點可真厲害。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "我光是和她說話就要精疲力盡了呢。",
        "unit_id": 1211,
        "voice": "vo_adv_1013002_025"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n那個男生，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "居然能跟她混在一起呢──",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "是少數能應和七七香興致的……",
        "unit_id": 411,
        "voice": "vo_adv_1013002_026"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "稀有人種呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "講、",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "講的還真難聽呢──",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒什麼，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "小時候的同學而已。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "明明以前還一起玩過魔法少女家家酒呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不懂這種快樂，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可是人生中的損失喔，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "絕對！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不過呢，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就算別人不了解我也習以為常了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "砰！",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這攻擊似乎對七七香無效！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……別、",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "別用那種表情看我嘛～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我真的沒事沒事喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這是什麼心境轉變！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你說如果兩個人一起的話，被當作笨蛋也不用怕？",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n喔喔……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
