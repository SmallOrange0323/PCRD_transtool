        "voice": "vo_adv_1013002_087"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣就圓滿解決了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過話說回來，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個神秘男……",
