        "words": "噫～！",
        "unit_id": 811,
        "voice": "vo_adv_1013002_075"
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "放過我吧──！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "\n是我的錯～！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但我拒絕！",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_076"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你就留到牢裡反省吧～♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "比起這件事！",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_077"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你從哪知道",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛才那個魔法的？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n那不是普通的魔法對吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "是、",
        "unit_id": 811,
        "voice": "vo_adv_1013002_078"
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "是從一個陌生的男人那裡……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "\n他把這本魔導書交給我，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "\n說可以使用很強大的魔法……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚哇！",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_079"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是沒看過的魔導書！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是什麼，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是哪種魔導書！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "稀有物！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "詳細的事情我也不清楚……",
        "unit_id": 811,
        "voice": "vo_adv_1013002_080"
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "\n他說即使是沒有魔法才能的我，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "也能靠這魔導書加強力量。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "我想說只要用這個，",
        "unit_id": 811,
        "voice": "vo_adv_1013002_081"
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "\n應該就能把一直以來瞧不起我的那些傢伙打飛吧。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "一得意起來，",
        "unit_id": 811,
        "voice": "vo_adv_1013002_082"
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "就以為什麼都能做呢……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯──",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_083"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我也不是不懂你的心情，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但魔法果然還是得用在助人上呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "若是為了守護大家，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_084"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為了人們而使用的話，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n總有一天會得到認同的喔！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼一來，",
        "unit_id": 101311,
        "voice": "vo_adv_1013002_085"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就能給那些瞧不起你的人好看了啊！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "沒、",
        "unit_id": 811,
        "voice": "vo_adv_1013002_086"
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "沒錯呢……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "嗯……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "\n我",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "清醒了。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "搶劫犯",
        "words": "我再也不會做壞事了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "很好！",
