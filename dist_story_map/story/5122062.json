        "words": "對喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "跟平常一樣……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是布丁",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "的杯子喲──",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……………………！！！！！！",
        "unit_id": 100711,
        "voice": "vo_adv_5122062_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有、",
        "unit_id": 100711,
        "voice": "vo_adv_5122062_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有什麼不對的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子吃果凍",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有什麼不對的────！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "…………真的……",
        "unit_id": 100711,
        "voice": "vo_adv_5122062_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗎……？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你沒有在氣說明明是",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "卻對果凍花心了嗎……？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "由宮子自己決定",
        "unit_id": 100711,
        "voice": "vo_adv_5122062_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "吃什麼就好……？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "的確沒錯。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你還真是說了不錯的話喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "話、",
        "unit_id": 100711,
        "voice": "vo_adv_5122062_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "話說在前頭，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家可沒有討厭布丁喲……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "其實，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家是想吃布丁的。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "但是，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "打開冰箱一看發現剛好沒有了……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "而且，",
        "unit_id": 100711,
        "voice": "vo_adv_5122062_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就這麼剛好，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n在宮子眼前，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "剛好有個保存期限到當天的果凍，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n就這麼剛好",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "釋放著希望被吃掉的氣息──",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……嘿嘿嘿～",
        "unit_id": 100711,
        "voice": "vo_adv_5122062_007"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n沒錯喲♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可、",
        "unit_id": 100711,
        "voice": "vo_adv_5122062_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唯獨只有伊莉亞，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "希望能對她保密……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "如果被她發現宮子偷吃她的果凍，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "她一定",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "會大發雷霆的～～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你還真是通情達理喲。",
        "unit_id": 100711,
        "voice": "vo_adv_5122062_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那麼，",
        "unit_id": 100711
