    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您醒過來了呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2015005_050"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是受到偉大的愛梅斯大人差遣而前來的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「嚮導」……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "名叫",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可可蘿。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今後，",
        "unit_id": 105913,
        "voice": "vo_adv_2015005_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您多多指教。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "保護主人的安危，",
        "unit_id": 105913,
        "voice": "vo_adv_2015005_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從早晨到夜晚……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從出生到死亡，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "誠心誠意地照顧主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是在下的職責。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不論何事，還請您儘管吩咐，",
        "unit_id": 105913,
        "voice": "vo_adv_2015005_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "201500502"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人？",
        "unit_id": 105913,
        "voice": "vo_adv_2015005_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您怎麼了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "給您添了什麼麻煩嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這種狀況下，",
        "unit_id": 105913,
        "voice": "vo_adv_2015005_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟該如何是好，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下並不明白。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您……",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "201500503"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "求您了，",
        "unit_id": 105913,
        "voice": "vo_adv_2015005_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您別哭泣――",
        "unit_id": 105913
    }
]