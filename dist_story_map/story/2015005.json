[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才不是夢啦！",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然是在夢裡頭！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我說你啊，",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒事吧！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n吶，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有沒有哪裡會痛？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或是哪裡不舒服！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這樣啊……",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "暫時可以鬆口氣了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我以干涉夢境的方法，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "將你那脫離肉體後差點消失的靈魂",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n硬是回收到了這個地方……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看來是勉強度過這一關了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……讓我再重新打聲招呼吧。",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好久不見了，{player}。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "――說是這麼說，但你應該都忘光了吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就像以往那樣……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你對我有印象嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而且，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明平時在夢境裡都是我單方面在說話而已，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次卻好像有正常對上話了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……原來如此啊。",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是因為這次",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "跟你往常和女孩子們加深羈絆時的夢境有所不同……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的靈魂和精神",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "全都跑到這裡的緣故嗎……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "又或是因為，",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在我一次又一次地向你搭話的時候，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n即使只有一點一滴，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但在你的潛意識中，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n已經漸漸將我的事情給記了下來也說不定呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不對！",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在不是",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "講這種事的時候了啦！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "比起這件事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你到底知不知道你差點就死掉了啊？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒錯。",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為了讓貪吃佩可免於霸瞳皇帝的攻擊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你像平常一樣衝上前去保護了她……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因此，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你受到了致命傷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的身體正中央，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "被狠狠地貫穿了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只有你那即將消失的意識……",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你的靈魂，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想盡了辦法，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才將它像這樣連結到這裡來了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我能夠做的就只有這樣而已。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在的我，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並沒有能夠干涉『那邊』的力量……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你想起來了？",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……等等！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "給我等一下！",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你就算突然發狂似地跑起來也沒有意義啦！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這裡的距離和時間等概念，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和『那邊』是完全不一樣的啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……沒有錯喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n大家……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都以為你死了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "他們正帶著因憤怒與悲傷而失去理智的心，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "忘情地揮舞著武器。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊啊，",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "連可可蘿都哭成那樣了……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n好想馬上把她抱進懷裡，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好好安慰安慰她啊……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "給、",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "給我等一下！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你到底有沒有把人家的話聽進去啊？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果是平時的話，",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你只要從夢境裡醒來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你的意識就會自動回到原本的身體裡……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但就跟我剛剛說的一樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你那個該回去的身體現在已經壞掉了啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這件事你阻止不了啦！",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你現在回去的話，絕對會死的！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "先不管",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們之間令人絕望的實力差距了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再說！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你看看！",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你那個肚子！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為這裡是夢境的世界，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以才不會流血的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但如果你就這樣回去的話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "絕對會死掉的啦！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可……",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是呀！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算治好了他的傷，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也只是讓霸瞳皇帝",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n再重新殺他一次而已吧……！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年。",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我透過了",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "凱留，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n將你原本的『公主騎士』之力還給了你。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n而那股力量，便是你們在這場戰鬥中存活的『關鍵鑰匙』。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……然而依照現況，",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你還無法使用那把鑰匙",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n來解放出你全部的力量。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為我下了一道『安全裝置』……",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n只要解除『安全裝置』，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "將你的『公主騎士』之力",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "完全解放出來。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "再加上，",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果被託付了這股力量的夥伴們",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "和你之間的羈絆也是真實的，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也許……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你們",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就能擁有與千里真那對等的力量了也說不定。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等、",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等一下……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼妳要那麼做啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n妳明明知道這是決戰啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也不是",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "帶著壞心眼才這麼做的啊。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我已經說過這是『安全裝置』了吧？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我所還給你的『公主騎士』之力……",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n確實是",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "{player}你的力量。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n然而，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那卻是『之前的你』所擁有的力量。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那是和『現在的你』",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有些許不同的",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『失去記憶前的你』……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "假設你真的解放了所有的力量，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我也不知道",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "到時『現在的你』會變成怎樣。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或許就因為",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "些微的差異，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n而將那把能夠引出力量的『鑰匙』",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "給弄壞了也說不定。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不僅如此，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "甚至還有可能會因為無法承受副作用，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而導致身體被壓碎。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "最糟的是你有可能會被這個世界",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "認定為『原因不明的錯誤』，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n導致『你』這個存在",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "被徹底削除也說不定。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怎、",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怎麼這樣……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以我才會下一道",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『安全裝置』。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n畢竟就算解除了它，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也不能保證能夠贏過真那……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "承擔著如此巨大的風險……",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真的",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有必要嗎？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "千里真那的確",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有著無與倫比的力量。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但就算是那股力量，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也有極限。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真那的自尊心極強，",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "她無論如何都想保有那孤高的姿態，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因此才會如此孤獨……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n使得她絕對無法超越自己的極限。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以千里真那的願望才不會成真。",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以千里真那才會輸給她的願望。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不但無法改變世界的規則，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "甚至還敗給了這個世界。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒錯，",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_036"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就算少年你不用犧牲什麼……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真那總有一天也會倒下的。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可、",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是呀！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n若是這樣的話，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可可蘿她們不就……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……嗯。",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_038"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n以這個結局來說……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很遺憾的，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n『現在的你』至今所建立起來的羈絆，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "都將會消失吧。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然而，",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_039"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這些都是能夠挽回的東西。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只要『你』",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還能是『你』。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "聽好了。",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_040"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "除了充滿著危險與苦難，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還不見得能夠獲得救贖的",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n道路之外，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年你還有另外一條能走的道路喔。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那就是等待一切都過去，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "靜候全新機會到來的這條道路。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……你想怎麼做？",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_041"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n是賭上『現在的你』的存在，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來守護現在的羈絆。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還是要在這裡闔上雙眼，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓一切重新來過？",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我所能做的，",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_042"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就是把這兩條道路的存在",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "告訴你而已。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……抱歉呢。",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_043"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真要說的話……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "害你捲入了這些事情的本來就是我。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "晶，",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……OK，",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_045"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我知道了。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你就安心地",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "閉上雙眼吧。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n當你下一次睜開眼睛時，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不論世界變成了什麼模樣……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在那個世界",
        "unit_id": 106813,
        "voice": "vo_adv_2015005_046"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "發生的任何事情",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "都不是你的責任。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n別忘了這一點。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n也別因此感到悲傷。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_2015005_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n祝福你的人生、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現實，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都能夠",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "幸福美滿。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "小火開始慢慢蒸……♪",
        "unit_id": 1,
        "voice": "vo_adv_2015005_048"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "途中大火滾一滾……♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n寶貝哭了要忍忍，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "莫揭鍋蓋悶一悶……♪",
        "unit_id": 1
    },
