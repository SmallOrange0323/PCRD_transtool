[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真陽小姐身邊的人",
        "unit_id": 126311,
        "voice": "vo_adv_5120072_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都掛著笑容呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "先不論她說笑話的哏，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n想讓人露出笑臉的這份心情，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很美麗而崇高呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這讓用美",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來為世界的幸福做出貢獻的我，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很有共鳴呢♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "話雖如此，",
        "unit_id": 126311,
        "voice": "vo_adv_5120072_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "以方向性來看，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她給人的感覺比較接近可愛而不是美呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n要怎麼辦才好呢……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對了！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓她戴上",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n以我為原型的頭套如何。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會很好笑？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為什麼啊……？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "莉瑪小姐她……",
        "unit_id": 126311,
        "voice": "vo_adv_5120072_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有著比誰都更加純粹的心呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "軟綿綿的外觀跟毛的觸感……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還有",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "甜蜜的少女心。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該有很多人的身心",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都被她的魅力給療癒了吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是我想想喔……",
        "unit_id": 126311,
        "voice": "vo_adv_5120072_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她興奮起來會吐口水這點，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得不太好呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然可能會有人覺得口水有價值，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "至少要吐得",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n優雅一點比較好吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不對，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我是在說什麼啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "栞小姐。",
        "unit_id": 126311,
        "voice": "vo_adv_5120072_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然她兼具了夢幻與令人憐愛的特質，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是她身上美的本質",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n並不在那裡喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而是像在大自然中盛開的小花一樣，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "蘊含在其中的堅強與溫柔──",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "才是她真正的美吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來如此。",
        "unit_id": 126311,
        "voice": "vo_adv_5120072_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "栞小姐",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "似乎對文學跟圖鑑有興趣呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "聽說她之前",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n很認真地看著徵才情報誌。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "下次",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要不要看看美容的書",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n或是化妝品的目錄呢？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得這樣能打開通往美的世界的大門喔！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "鈴小姐躺在地上睡覺的時候，",
        "unit_id": 126311,
        "voice": "vo_adv_5120072_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看起來真的很幸福呢……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "居然可以如此毫不掩飾地展現真實的自己，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這不是能輕易辦到的事呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n跟雕琢過的美不同，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而是自然的美……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該這麼說吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是，",
        "unit_id": 126311,
        "voice": "vo_adv_5120072_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "懶散的樣子更顯眼這點真的很可惜啊……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不對，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n如果將其發展到極致的話，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "或許能誕生出新的美也說不定。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然我想像不出來，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是我希望她能嘗試看看呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "試著創造出懶散的美！",
        "unit_id": 126311
    }
]