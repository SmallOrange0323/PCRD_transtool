[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}！{player}啊！",
        "unit_id": 1,
        "voice": "vo_adv_1044003_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n快看！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身這姿態！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在是開玩笑的時候嗎！",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你也不是第一次看見妾身的這身姿態吧！？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是妾身啊！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "伊莉亞！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身本來就是大人了啦！",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你看，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "恢復成原來的姿態了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今天早上起床後，",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就變成這身姿態了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而且從醒來到現在，已經過了相當長的一段時間，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n都沒有要變回小孩的徵兆……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "或許妾身是真的恢復原本的姿態了！",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這份喜悅妾身想第一個告訴你啊。",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n於是就跑到你這裡來了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……你很在意是怎麼恢復原狀的嗎？",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也不清楚原因。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也因為這樣，",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓妾身有些不安。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n說不定一不小心，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "又會變回小孩子呢……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "說的也是。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n若能找出明確的原因，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也不會感到不安了。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只不過，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身完全沒有頭緒……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯？",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你問今天早上，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有沒有奇怪的事？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "原來如此。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如有跟平時不同的狀況，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那就是原因吧。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但話是這麼說，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身覺得並沒什麼特別的事呢……？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯～",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今天早上……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今天早上……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n跟平常不同的地方啊……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦哦，",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身想到了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今天早上你出現在妾身的夢裡。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這倒是頭一遭呢。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要說與平時不同的地方，",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也就只有這樣而已。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "一直以來，",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只要你在身邊，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就會恢復成這身姿態呢。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣看來，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那場夢的確很有可能就是恢復原狀的主因。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯？",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你問是什麼樣的夢嗎？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "應該是很棒的夢。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身好像是在很幸福的情況下醒來的……？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對了對了，",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "想起來了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身邀請公會成成員到城裡來，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "參加妾身跟你的結婚典──",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──！？",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒、",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒事！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就跟你說沒事啦！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身才沒夢見你呢！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身說沒夢到，",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就是沒夢到！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "像那種，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身和你看起來那麼幸福的……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身怎麼可能",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "會做那種夢！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "囉嗦，",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你真纏人！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不是跟你說沒事了嗎！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n只好讓你嘗點苦頭了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼、",
        "unit_id": 104411,
        "voice": "vo_adv_1044003_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n誰叫你要深究那種細節，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n所以才會受到這樣的教訓。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊啊，",
        "unit_id": 104412,
        "voice": "vo_adv_1044003_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "又變回小孩的模樣了！？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是剛才的魔法讓魔力流失的關係嗎……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯～",
        "unit_id": 104412,
        "voice": "vo_adv_1044003_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "算了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看來還得繼續再跟{player}你一起，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n找出恢復原狀的方法呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來吧，",
        "unit_id": 104412,
        "voice": "vo_adv_1044003_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今後你可要好好為妾身犧牲奉獻啊。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒錯！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就像是妾身的伴侶那樣。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "…………！！！",
        "unit_id": 104412,
        "voice": "vo_adv_1044003_025"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊莉亞在這之後，\n對自己說出口的話感到無比的害羞。"
    }
]