    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "空花醒來時已是夜晚，身在公會小屋裡。\n她發現不知道為什麼和{player}兩人獨處。"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "為什麼我會在這裡……",
        "unit_id": 109511,
        "voice": "vo_adv_1095004_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！",
        "unit_id": 109511,
        "voice": "vo_adv_1095004_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "難道是虐待狂先生",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "給空花吃了可疑的藥……！？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "然後",
        "unit_id": 109511,
        "voice": "vo_adv_1095004_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "把意識不清的空花帶到房間裡，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n正打算對我做出",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不得了的事情嗎！？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "也就是說空花……",
        "unit_id": 109511,
        "voice": "vo_adv_1095004_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "接下來就要變成大人了……！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……咦？　",
        "unit_id": 109511,
        "voice": "vo_adv_1095004_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不、",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不是嗎？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是、",
        "unit_id": 109511,
        "voice": "vo_adv_1095004_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是因為空花又",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦――",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "的旋轉，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "轉得頭暈眼花",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n所以你只是帶我到附近的公會小屋……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "休息而已嗎？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這、",
        "unit_id": 109511,
        "voice": "vo_adv_1095004_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這麼說來，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我好像有一點模糊的印象……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦？　",
        "unit_id": 109511,
        "voice": "vo_adv_1095004_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可是，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "狀況差不了多少吧……？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你看嘛，",
        "unit_id": 109511,
        "voice": "vo_adv_1095004_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "現在這樣，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這個狀況不就是把我外帶了嗎……！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花今天",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就要羽化成夜之蝴蝶",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "展翅飛翔了……！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗯！　",
        "unit_id": 109511,
        "voice": "vo_adv_1095004_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎、",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎麼了？　",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "房裡的燈突然亮了起來！？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一般這時候",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不是該暗下來嗎……！",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呀啊啊啊啊啊啊啊！！",
        "unit_id": 109511,
        "voice": "vo_adv_1095004_010"
    },
    {
        "type": "still",
        "still": "109500401"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗚嗚，",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "人家不習慣穿和服……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好難行動……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n然後，",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你還要人家穿這樣",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "來服務客人……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過，",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這個腰帶的束縛感還不差……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "應該說很棒！　",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "（流口水）。",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊，",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_013"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "現在得專心工作才行……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "歡迎光臨……",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_014"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "欸欸欸欸！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你、",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_015"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你是虐待狂先生！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你到這種地方來，",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是要羞辱空花的吧……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "（流口水）。",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生對努力服務客人的空花，",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_016"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n發出殘忍的命令……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花雖然不情願，",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_017"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但是身為",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "員工，",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n無法違抗是客人的虐待狂先生……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "被他強迫",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_018"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "做了菜單上沒有的……！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n嘻嘻嘻……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……啊，",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "好的！　",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我又沉浸在妄想裡了！",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "對不起，虐待狂先生，",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "您要點餐了嗎？",
        "unit_id": 104532
    },
    {
        "type": "still",
        "still": "109500402"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你、",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_020"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你的意思是",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "想要點空花嗎！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "如此大膽的點餐……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "該怎麼辦……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "（流口水）。",
        "unit_id": 104532
    },
    {
        "type": "still",
        "still": "109500402"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "所、",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_021"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "所以說，",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是要我把這件和服脫下來給你嗎！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "突然就玩這麼大……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻。",
