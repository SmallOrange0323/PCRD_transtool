    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n是這個意思吧！？　",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻！？",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空、",
        "unit_id": 104532,
        "voice": "vo_adv_1095004_027"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花、",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "絆到腳了……",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生",
        "unit_id": 104532
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "伸出了手，",
