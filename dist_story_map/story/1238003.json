        "voice": "vo_adv_1238003_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難不成，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你害羞了？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是的，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們都已經是一起努力抹煞倦怠的關係了，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你怎麼還這麼純情啊。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒辦法，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我來引導，讓你更好罵出口吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看著我的眼睛。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n別移開視線哦……？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我居然趴在這種地方，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我真是一隻沒規矩的兔子，蹦……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "主人。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你就懲罰一下",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不乖的白雪吧……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "蹦☆",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
