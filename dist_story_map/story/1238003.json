        "voice": "vo_adv_1238003_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n深深地銘刻在",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這顆心和身體上吧，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "蹦♪",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你在遲疑什麼？",
