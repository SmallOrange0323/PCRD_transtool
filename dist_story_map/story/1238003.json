        "voice": "vo_adv_1238003_074"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這個遊戲就到此為止吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……什麼？",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_075"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你說",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "結束得太突然了？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也很想繼續下去啊。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_076"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次只是",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了消除倦怠的遊戲罷了。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然目的已經爽快地達成了，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就沒有理由繼續下去了☆",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_077"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你這個男人……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "出乎意料地高深莫測啊。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_078"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n越了解你",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就越搞不明白呢。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不但沒有讓我對你失去興趣……",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_079"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來……",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_080"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n現在要擔心倦怠，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "似乎有點太早了。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算不依靠這種鎧甲，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_081"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們的關係也沒問題……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是吧♪　",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但只要知道這一點",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_082"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就足以戰勝倦怠期了，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對吧，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子♪　",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──好。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_083"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "收工吧☆",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "離開的克莉絲提娜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n眼神中露出了像是戰勝強敵般的滿意笑容。"
