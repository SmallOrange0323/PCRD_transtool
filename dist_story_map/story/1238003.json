    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "煙消雲散了♪",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──很好。",
