        "voice": "vo_adv_1238003_068"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看人的眼光也磨練了不少……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而我太吃驚了。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_069"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很有當「主人」的天賦啊。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_070"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然還沒有顯露出來，",
