    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n了不起，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你太讓人驚豔了，小子！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你的一句話，",
