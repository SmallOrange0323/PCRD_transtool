    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你沒聽見嗎？",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "主人，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n懲罰我！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n蹦！！！！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……什麼？",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你說",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你還是辦不到？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不管怎麼看都不像兔子？",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n反而比較像百獸之王的風格？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為比平時還要魄力十足，",
