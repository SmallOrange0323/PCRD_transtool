        "voice": "vo_adv_1238003_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n克莉絲提娜我",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可是不唱獨角戲主義。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n既然事情發展到這個地步，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我要把你連同結婚誓約一起毀了！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……什麼？",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你說會好好罵我的，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我等一下？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你是認真的嗎？",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果你是為了活命隨口胡說的話，我是不會接受的！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔……",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這個表情……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你──！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……！！！！",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
