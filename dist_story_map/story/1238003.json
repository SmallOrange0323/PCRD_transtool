        "voice": "vo_adv_1238003_056"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n如果有什麼疑慮，我是希望兩個人可以一起解決……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來完全是",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我自己在唱獨角戲啊。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
