[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "克莉絲提娜說道："
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「接下來我想換個口味」，\n並帶著{player}來到森林裡──"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這裡就不會被人看見了吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然把周圍的人牽扯進來也很好玩……",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但難得這身裝扮嘛。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "接下來，小子。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我想和你單獨玩玩♪",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂喂喂，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你別這麼防備呀。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算是我也沒有偷襲未婚夫的嗜好啊。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──我就直接了當地說了吧。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們來玩飼養遊戲吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n把我當成寵物兔來飼養吧☆",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，沒錯。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你以主人的身分來管教我，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我服從。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n以這身鎧甲來說，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是再適合不過的用途了吧？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你的表情上寫著",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "克莉絲的異想天開簡直是登峰造極呢。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但遺憾的是，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次可不是單純的異想天開哦。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我是有明確的目的的。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……聽說，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在戀人關係之間，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n「無聊」也是大敵，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是天敵吧？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我聽說還有一種可憎的東西",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "叫做倦怠期。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "和你在一起的話，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n無聊也可以是有趣的……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是，隨著相處的時間越長，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不必要的無聊就會變成一件壞事。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以啦。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想透過",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "互相扮演非日常的角色，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n為這段關係注入名為刺激的強效劑，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n一舉剷除倦怠的種子。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……就是這麼一回事。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼樣，小子？",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看在我這顆少女心的份上，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要不要飼養我看看呀♪",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯！",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你理解情況的速度變快了。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n成長相當顯著，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很可靠嘛！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那我們馬上開始吧。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "從這一刻起，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就是你養的兔子。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你就是我的",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "主人☆",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "徹徹底底地讓我服從吧！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……這個嘛。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n建立新關係最快的方式，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n大概就是「取名字」了吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "兔子要是名叫克莉絲提娜，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一點感覺都沒有啊。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "幫我取個寵物名字吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "需要沉思這麼久嗎？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n只要是你覺得適合的名字都可以。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對，沒錯。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n適合我的名字。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "快點取一個！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……大王？",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n確實是像寵物會取的名字啦……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但不像兔子會取的名字吧？",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "魔王……",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n兔兔魔王……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "反而很有兔子的感覺嗎……",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "──哪裡有啊！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也真是的，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n害我都忍不住吐槽了。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這名字也太不柔和了吧！",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我可是兔子喔？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你看清楚，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我這副柔弱又楚楚可憐的模樣。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你的感受力到底是怎麼回事啊。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你那是什麼欲言又止的眼神啊。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n哼，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算了。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我自己取名字吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n把你這個飼主逼到絕境也不是我的本意。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………\n",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……「白雪」。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n「白雪」不錯。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就這麼決定了♪",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽好了，",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "從現在開始，你就叫我白雪吧。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是♪",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是♪",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不對，等一下。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n現在只是取了個名字而已。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你幹嘛用一副大功告成的表情喊個不停啊。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聽好了，才剛剛開始哦？",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n現在要正式進入調教環節了！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼我也……",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "進入角色！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "主人♪",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧，白雪好想被你罵一頓，蹦。",
