        "voice": "vo_adv_1238003_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你害怕得罵不出口？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……怎麼可能！",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你也不想想有多少人",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "被這身裝扮騙了！",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哼。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真掃興。",
