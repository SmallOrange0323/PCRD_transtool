        "voice": "vo_adv_1238003_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你過來一下。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n過來我跟你說幾句話。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你……！",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_066"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……你滿有天分的嘛。",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_067"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也不是白白累積了這麼多經驗。",
