        "voice": "vo_adv_1238003_071"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n想不到你還有這樣的一面。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "…………",
        "unit_id": 123811,
        "voice": "vo_adv_1238003_072"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "～哈哈哈☆",
