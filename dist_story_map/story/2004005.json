[
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "糟糕……！",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可她，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "往這裡過來了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看樣子",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "似乎和【伊麗莎白牧場】的那群人，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n順利匯合了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那群人裡似乎有視力很好，",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n或是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "直覺強大的傢伙在？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的所在之處，已經暴露了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「大概這裡有人存在……",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而可能那個人在操控魔物～」",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n應該是帶有類似這種程度的懷疑吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "糟了！",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我為了操控魔物已經花光了魔力和體力！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要正面迎擊貪吃佩可，果然還是不行嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "still",
        "still": "200400501"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看來妳很困擾呢，",
        "unit_id": 1,
        "voice": "vo_adv_2004005_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n小姑娘。",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……！？",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "克莉絲提娜！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀，竟然直呼名諱嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好啊好啊，很叛逆嘛！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "平常都假惺惺地叫我「克莉絲提娜大人」，",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我還以為妳是個無聊的傢伙呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈哈☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳在這裡做什麼啊？",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是陛下的差遣嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可以說是正確，也可以說是不正確。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n陛下交給我的差事，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n和妳的任務不是同一件事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我因為先前搞出的問題，",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在蘭德索爾也待不下去了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以在城鎮外",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n進行特殊任務。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次似乎弄清楚了",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n祕密社團【拉比林斯】的據點。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "決定要去破壞一番。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且陛下也吩咐我",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "順道過來看看妳的狀況。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來陛下，",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n似乎有些懷疑妳的能力，或是忠誠度呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不然的話，陛下應該會信任地交給妳全盤處理。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也就不會叫我過來看看了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我有在認真做呀。",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我不正按照陛下所說的在做嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但妳看起來就像個一臉快哭出來的迷路小孩呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳果然還是個小鬼啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來妳還不知道當壞人多有趣，",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可沒空跟妳聊天！",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別打擾我，我會好好辦事的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳就這樣向陛下回報吧，滾離這裡！",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳很礙眼呢，克莉絲提娜……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "別歇斯底里的。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣的女生可是不受歡迎的唷～？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，凱留……是吧？",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "先冷靜下來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要不要來場交易？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "交易……？",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒錯，我來幫忙妳的工作。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "具體地來說……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我來對付",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n現在逼近這裡的那位小姑娘。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我漂亮地生擒她。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要殺了她也行喔……雖然她應該挺強的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但終究不是我的對手啦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這對我來說是小菜一碟。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那時候",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳就躲在草叢之類的地方就行了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……真是個叫人感謝的提議呢。",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是，",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n既然叫做交易，那妳也有妳的要求吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳究竟",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想要什麼？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "金錢？",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n財寶？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還是權力？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想要的是情報。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n因為那是這個時代最有價值的寶物啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我希望你告訴我幾個……",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n陛下或是妳之類的人知道，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但我卻還沒掌握到的情報。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳是說，",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要我背叛陛下嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我沒那麼說。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "單純只是希望",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳在可以透露的範圍告訴我一些事。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "反正……",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這只是無聊人生中",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n打發時間用的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "總覺得陛下有些祕密。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為了隱瞞重要祕密的人拚死拚活的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n很笨不是嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我希望可以認同一切，然後戰鬥。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然我也喜歡",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n沉浸在剎那之間的快感。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但時間和人生有限。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那是這個世界上",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n少數的絕對真理之一。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我不想把寶貴的",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n人生時間浪費在毫無價值的事情上。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以說呢，",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我想弄清楚那些還沒釋懷的事情。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我受夠了當別人的棋子。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算我的人生再怎樣乏味無趣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也是僅屬於我的人生。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我原本以為",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳只是一個為了快樂而殺人的人，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒想到妳滿機靈的嘛。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是啊。",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然我是臣服於快樂的奴隸，但絕不想成為他人的奴隸。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就這樣簡單，小姑娘。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……那麼，如何呢？",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不快點做決定的話，可是會來不及的唷？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "比起無法做出決定而後悔，",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n做出決定以後再後悔可是有意義的多了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是姊姊我給妳的誠摯建議。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我知道了。",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n交易成立。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我答應妳開的條件。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我會躲在那附近。",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正在接近這裡的蒂亞娜",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就交給妳對付了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……先說好，",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可別把她殺了唷？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "蒂亞娜？",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈……原來是這樣啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n光是知道這個名字，就足以作為揮劍的回報了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原來如此啊，",
        "unit_id": 107111,
        "voice": "vo_adv_2004005_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "人生真是有趣啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n啊哈哈哈☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "少多管閒事了。",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_051"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……那我先走了，剩下的就交給妳了。",
        "unit_id": 106011
    },
    {
        "type": "still",
        "still": "200400501"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（我也想享受人生呢。",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_052"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃好吃的東西，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n跟好朋友一起聊天說笑……）\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "（可是，",
        "unit_id": 106011,
        "voice": "vo_adv_2004005_053"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我的人生，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n並不屬於我呀！）\n",
        "unit_id": 106011
    },
    {
        "type": "still",
        "still": "end"
    },
