[
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "嗚、",
        "unit_id": 16613,
        "voice": "vo_adv_5100323_000"
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "嗚嗚～～～！",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "\n我真的，",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "可以相信你們嗎……？",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "不，",
        "unit_id": 16613,
        "voice": "vo_adv_5100323_001"
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "這是騙人的……！",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "\n我相信的",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "只有一件事……",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "\n與老爺爺的約定是",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "絕對的……！",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "你也是",
        "unit_id": 123111,
        "voice": "vo_adv_5100323_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "相當頑固呢。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過，",
        "unit_id": 123111,
        "voice": "vo_adv_5100323_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說到決心的堅定程度",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也不會輸！",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咱們",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是來幫助你的！",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真步小姐，",
        "unit_id": 123211,
        "voice": "vo_adv_5100323_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們也……",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "使出全力上吧！",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n為了讓",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "羊先生了解我們的想法！",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是啊，",
        "unit_id": 123111,
        "voice": "vo_adv_5100323_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "綾音小姐。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n都千里迢迢",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "跑來這裡了，",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "必須把咱們的心意──",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好好傳達給羊先生！",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「一定要把我們的心意",
        "unit_id": 2113,
        "voice": "vo_adv_5100323_006"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "傳達過去！」",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯！",
        "unit_id": 123211,
        "voice": "vo_adv_5100323_007"
    }
]