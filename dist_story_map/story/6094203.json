[
    {
        "type": "background",
        "background": "501590"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對大家來說，",
        "unit_id": 122111,
        "voice": "vo_adv_6094203_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "隱居山林居然是一種休閒，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n真是出乎我的意料……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有多數人同歡的形式……！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果團長也在的話，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種時候會給我什麼意見呢……？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒、",
        "unit_id": 122111,
        "voice": "vo_adv_6094203_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "沒錯……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長一定",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "會那麼對我說的……！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n只要活用隱居山林的知識，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就能幫助到大家……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "順利的話，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還能從邊緣人畢業……！？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我盡力試試看！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團、",
        "unit_id": 122111,
        "voice": "vo_adv_6094203_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "團長也不在我身邊，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "著急只會欲速則不達吧……！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "總之，我要先冷靜。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "邊緣人慌慌張張的都不會有好結果。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種時候",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就要凝視著篝火……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "盯……………………",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "冷靜多了……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "在大自然裡維持自然，",
        "unit_id": 122111,
        "voice": "vo_adv_6094203_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "開玩笑的……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呵呵，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我想像出來的團長也很風趣呢。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過多虧如此，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我覺得肩膀的緊張放鬆了不少。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "很、",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "很好！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我要努力保持自然的自己！",
        "unit_id": 122111
    }
]