    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蘿茜，",
        "unit_id": 105811,
        "voice": "vo_adv_9100202_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "萊拉耶爾小姐！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士，",
        "unit_id": 126511,
        "voice": "vo_adv_9100202_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "各位。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n情況",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "怎麼樣了呢？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這個的話，",
        "unit_id": 126011,
        "voice": "vo_adv_9100202_004"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "簡單來說──",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來如此！",
        "unit_id": 126412,
        "voice": "vo_adv_9100202_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126412
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "多虧了騎士先生的朋友們，",
        "unit_id": 126412
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "人質平安無事是嗎？",
        "unit_id": 126412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，",
        "unit_id": 105911,
        "voice": "vo_adv_9100202_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為不知道厄莉絲小姐的魔力保護",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能維持多久，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n得趕緊打倒阿剌克涅女士才行。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然",
        "unit_id": 125811,
        "voice": "vo_adv_9100202_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有涅妃‧涅羅小姐",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n在保護琳德小姐她們，以及居住區的各位，",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但是戰況相當膠著。",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "因此……",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "趕快。",
        "unit_id": 126111,
        "voice": "vo_adv_9100202_008"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n行動吧。",
        "unit_id": 126111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，帆稀！",
        "unit_id": 106011,
        "voice": "vo_adv_9100202_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n路是這邊沒有錯吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "「嗯，",
        "unit_id": 106715,
        "voice": "vo_adv_9100202_010"
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "沒錯沒錯～",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "\n",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "只是──」",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "蜘蛛魔物們",
        "words": "──嘎吱嘎吱嘎吱！",
        "unit_id": 50011
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "「有很多蜘蛛魔物",
        "unit_id": 106715,
        "voice": "vo_adv_9100202_011"
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "從地下的巢穴冒出來呢～",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "\n就像是巢穴前被人放了砂糖的螞蟻那樣，",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "通訊魔法的帆稀",
        "words": "大量地聚集～」",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "除了蜘蛛魔物以外，",
        "unit_id": 105911,
        "voice": "vo_adv_9100202_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還必須提防",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "芙蕾雅",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n和【蠻賊三姊妹】……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誰怕誰啊！",
        "unit_id": 106011,
        "voice": "vo_adv_9100202_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我要把她們全部宰掉，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再把最深處的蜘蛛老大挖出來！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好！",
        "unit_id": 105811,
        "voice": "vo_adv_9100202_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們要打倒阿剌克涅，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "救出小雪菲！",
        "unit_id": 105811
    }
