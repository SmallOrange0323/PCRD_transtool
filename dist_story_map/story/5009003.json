[
    {
        "type": "background",
        "background": "500115"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n大家一起把千歌失控弄亂的廚房、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n大廳給整理乾淨。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌再次陷入昏迷，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n我們依舊不清楚為何她的舉止會變得如此怪異……"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "小胡桃！",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n妳托住餐具架的另一端，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後我們一起搬喔！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一、二、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿咻♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦、嗚啊……？",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呀啊啊……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊啊，抱歉我太粗魯了！",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我好像一口氣太用力了，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嚇到妳了吧？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不、",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不要緊……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對不起，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我很膽小……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "比起那個……",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n妳的工作才是不要緊嗎，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "小望姊姊……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯。",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我剛才用通訊魔法和事務所連絡過了……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我說「夥伴被魔物攻擊，情況緊急！」",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後他們好像就理解了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然我的確……",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是沒有騙人啦，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是不能把歌聲和笑容帶給那些期待我們表演",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而前來的觀眾，實在有點可惜。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓紡希一個人進行補償的企畫，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n為了能夠滿足我們的粉絲而努力著……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感覺之後會被紡希給拚命抱怨呢，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她很愛生氣嘛。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不是的。",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n如果可以的話，她也想趕到千歌身邊，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n她的不滿應該是這個吧。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唉，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到底為什麼事情會變成這樣子啊？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "…………",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉，我竟然唉聲嘆氣！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n偶像的笑容就是生命，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不可以露出陰沉的表情呢！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我要加油！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "微笑微笑～☆",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸、欸嘿……",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真厲害啊，好正向……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我總是畏畏縮縮的低著頭，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以很羨慕……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸嘿，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聽妳這樣說真開心！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能成為小孩子嚮往的人才是偶像……☆",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "小望姊姊，",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "原來妳真的是偶像呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "能像這樣子",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n和偶像說話，感覺好奇妙……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我以為偶像應該是",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "更遙不可及的人……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才不是呢，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "最近會主動接近粉絲的偶像才是主流喔。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為我喜歡的是傳統的理想型偶像，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以一直不習慣……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但時代變了嘛。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只要能接近粉絲，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "連他們的表情都看得到。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n如果無精打采就能幫他們打氣，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "安慰他們。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能夠給予大家在當下想要的東西。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "能夠帶給人笑容。",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我想那大概比被未曾相見過的眾多認同者評價一樣，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n或甚至更寶貴、更有價值呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好厲害……",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n小望姊姊，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "感覺好耀眼啊……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說這些話真讓人害臊呢……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不過我也說不出什麼了不起的話。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為【慈樂之音】是才剛起步、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還默默無名的雛鳥。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "正是因為這樣。",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才不能在這種時候，\n因為莫名的原因栽了跟頭。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我一定要讓千歌恢復原樣，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後回到大家等待著我們的舞台。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好，",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我們也來幫忙……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對吧，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喔，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你剛才是說什麼都願意做嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n呵呵，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要讓你做什麼好呢……♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚啊，",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "小望姊姊露出了邪惡的表情……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……哎呀。",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛才當我沒說。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿嘿，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "被人叫姊姊感覺真害羞。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為我是獨生女，感覺像多了個妹妹一樣，好開心啊。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}也是一樣的感覺吧？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有家人真不錯呢。",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有能回去的家……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個大廳也有佈置聖誕節的裝飾，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n感覺到滿滿幸福的氣氛。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "竟然打擾到了這樣的地方，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "實在是很抱歉。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這不是小望姊姊的錯……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "當然，那個叫千歌的人也沒有錯，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n都是那個叫霧奇的魔物在作怪吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然是我猜測的。",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還有，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那不是魔物，是大精靈。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個……",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_032"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "和魔物不一樣嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不清楚。",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就我來看，它們是一樣的，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n每當我這樣說，千歌總是會反駁我說不一樣……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌說所謂的精靈好像更溫柔，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n會保護世界和人類的存在。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是真的不懂，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "想聽聽專家的意見啊。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "現在是去找算是千歌導師的奶奶過來嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是的……",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_036"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個人是可可蘿因為興趣而前往參拜的神殿中，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n常常見面聊天而結識的朋友……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n可可蘿",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "現在正趕去找她……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "興趣是參拜神殿……",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "和去找醫生叫做鈴莓的女孩一樣，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n現在只能等他們來了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "束手無策只能等待的感覺，",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真難受啊。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呀啊啊啊！？",
        "unit_id": 102311,
        "voice": "vo_adv_5009003_039"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "快住手啊，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不能吃噗吉啊～！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "……！？",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_040"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是綾音的尖叫聲……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "發、發生什麼事了？",
        "unit_id": 102913,
        "voice": "vo_adv_5009003_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我記得那個叫綾音的女孩，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n正在照顧千歌吧……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難道千歌",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "醒來後又開始失控了嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總、",
        "unit_id": 102111,
        "voice": "vo_adv_5009003_042"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總之去看看情況吧……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我好擔心綾音……！",
        "unit_id": 102111
    }
]