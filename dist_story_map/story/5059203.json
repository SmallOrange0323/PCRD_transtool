[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "成功了！",
        "unit_id": 106011,
        "voice": "vo_adv_5059203_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那個龐然大物",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "消失了呢！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣……",
        "unit_id": 105811,
        "voice": "vo_adv_5059203_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就結束了嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 115511,
        "voice": "vo_adv_5059203_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下還是有感覺到氣息。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來應該只是暫時擊退牠了，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但卻沒有打倒牠。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來如此啊──",
        "unit_id": 106011,
        "voice": "vo_adv_5059203_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不完全把牠收拾乾淨似乎是不會結束呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然如此就趕快追上去吧！",
        "unit_id": 105811,
        "voice": "vo_adv_5059203_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果牠跑到村子去就糟了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的……！",
        "unit_id": 115511,
        "voice": "vo_adv_5059203_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕對不能",
        "unit_id": 115511,
        "voice": "vo_adv_5059203_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再讓任何人感到困擾……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要是發生什麼事，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就讓在下來解決一切……！　",
        "unit_id": 115511
    }
]