[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我們就去驅除吸血鬼吧──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n蘭德索爾的和平就由讓我們來守護吧──！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可是，香織。就算知道有吸血鬼，",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也不知道該怎麼打倒他。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n畢竟對手是未知的敵人呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請不必擔心，",
        "unit_id": 101411,
        "voice": "vo_adv_5003001_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為吸血鬼是有弱點的哦。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哦哦～！",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就像真琴對可愛的東西沒輒那樣嗎～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那、那又怎麼樣就算我喜歡可愛的東西！",
        "unit_id": 104311,
        "voice": "vo_adv_5003001_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而且現在又不是在說這個！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說到吸血鬼害怕的東西，首先就是大蒜了。",
        "unit_id": 101411,
        "voice": "vo_adv_5003001_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哈，原來如此，大蒜的味道的確很強烈呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "的確，要是衣服沾上大蒜的味道，",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n再可愛的打扮也白費了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大蒜……好可怕啊。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……看來大蒜也算是我們的弱點呢。",
        "unit_id": 101411,
        "voice": "vo_adv_5003001_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "言歸正傳，大蒜的味道只會讓吸血鬼變弱，但殺不死他的。",
        "unit_id": 101411,
        "voice": "vo_adv_5003001_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n變弱之後，必須再確實刺死他。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "到底怎麼樣才能打倒他啊──？",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n琉球犬矢之拳不行嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "坦白說，吸血鬼害怕的武器還是……白木樁。",
        "unit_id": 101411,
        "voice": "vo_adv_5003001_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n只要用它刺進吸血鬼的胸口，吸血鬼就會立刻斃命。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗚嗚……",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不刺胸口的話不行嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n有點……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "該怎麼說呢，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很殘忍呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為吸血鬼只要心臟沒被破壞就不會死呢。",
        "unit_id": 101411,
        "voice": "vo_adv_5003001_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n更何況敵人可是怪物。要是一時心軟放過他，總有一天會成為麻煩的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，有大蒜和白木樁！",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n只要知道這些弱點，應該就連我們也能對付！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說得也是呢。",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝妳告訴我們哦，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "霞。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "祝妳們有精彩的表現。如果是妳們兩位，一定沒問題的。",
        "unit_id": 101411,
        "voice": "vo_adv_5003001_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "交給我囉～！",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n畢竟我們可是吸血鬼獵人啊～！",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好，那麼我們就一邊尋找吸血鬼，",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n為了對決，取得大蒜和白木樁吧──！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織，關於那件事的話……",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家思考過了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真的光靠那兩件東西就能贏嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦？什麼意思──？",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然霞已經告訴我們打倒吸血鬼的方法了……",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但對手可是『傳說的吸血鬼』吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我覺得應該和普通的吸血鬼不一樣才對……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "的，的確呢……！",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n怎麼突然懷疑起普通的大蒜和白木樁到底有沒有效啊，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n開始不安起來了呢……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是啊，",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織！咱們來收集比它們更厲害的東西吧！",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "更厲害的東西……？",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "比大蒜和白木樁感覺更帥氣更強猛的",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n道具啦！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "OK！那趕快到街上找找看吧──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_027"
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不好意思，有人在嗎──？",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哇──！嚇我一跳──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這不是王子先生嗎♪",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "竟然能在這種地方巧遇，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咱們果然",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "被命運緊緊地繫在一起呢～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你怎麼……原來如此啊，你是在這裡打工呢。",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "既然如此那真是太碰巧了！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們正在找比大蒜和白木樁更厲害的東西，",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_032"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n有賣嗎──？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "薑不行啦！而且它的味道很香啊！",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然槍的攻擊力確實是比較高……",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但普通的武器應該不行吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不好意思呢，王子先生。您還特地告訴我們。",
        "unit_id": 101011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，哪一家店都沒有賣呢……",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_035"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n沒想到厲害的東西……意外地難找啊──",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就是說啊……",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過話說回來，王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣好嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n麻煩您幫忙咱們……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "已經沒事了所以沒關係……？",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，謝謝您囉，王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那就恭敬不如從命囉。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可是，說到比大蒜更厲害的東西，",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n到底是怎麼個厲害法呀？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……啊！我想到一種比大蒜更厲害",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_039"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n的食物了──！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然外觀和味道比大蒜更強烈……",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_040"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但卻非常美味哦──！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那是什麼東西啊？是人家也知道的食物嗎？",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_041"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在我的故鄉裡是常常吃的食物，",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_042"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n大家都管它叫『像苦瓜的東西』──！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "『像苦瓜的東西』！？",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "　",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這名字聽起來好像很厲害呢！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "外觀感覺也比大蒜更厲害，",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_044"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n雖然有獨特的苦味，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但可以經由不同的烹飪手法讓它變美味喔──！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可是，鬧區卻很少有人在賣……",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_045"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我們自己去找吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然有點麻煩，但第一項「比大蒜厲害的東西」",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_046"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就決定是『像苦瓜的東西』了──",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那就這樣吧！",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_047"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過接下來就是比白木樁更厲害的東西了……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯……到底是什麼呢～……",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_048"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_049"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個怎麼樣？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "擀麵棍！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "擀麵棍？那東西比樁厲害嗎──？",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "當然，不只是普通的擀麵棍！",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_051"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是真步真步王國傳統技術製作的",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n『烏龍麵擀麵棍』哦！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真步真步王國的傳統！？",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_052"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "　",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那可真的很厲害呢！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可以打，可以敲，能夠伸長，也能當成武器！",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_053"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n白木樁只能當作武器對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而這個部分，『烏龍麵擀麵棍』可是有各種用途的唷！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "用那個做出來的烏龍麵也是一絕哦……",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_054"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n彈力強勁的彈牙麵條，再沾上精緻高湯熬煮的醬汁吃……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "糟糕，人家想家了啦。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好厲害──！既然有那麼多種用途，",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_055"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n肯定能打倒吸血鬼啊──！哪裡可以取得這種擀麵棍呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "城裡",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_056"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大概沒有在賣吧……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就算是人家的故鄉，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也只有營業多年的烏龍麵老店",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還沿用那種東西……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這個也是不找就拿不到的吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那麼，要打倒『傳說的吸血鬼』的兩種武器，",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_057"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就決定用『像苦瓜的東西』和『烏龍麵擀麵棍』啦！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要是找到這兩種東西，就能打贏吸血鬼了──！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "先從『像苦瓜的東西』開始找吧──",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_058"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有頭緒嗎？",
        "unit_id": 101011,
        "voice": "vo_adv_5003001_059"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然沒有，只要出門就自然會船到橋頭自然直～！",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_060"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "兩位，",
        "unit_id": 101711,
        "voice": "vo_adv_5003001_061"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "出發囉～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n吸血鬼，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "等等我們哦ー！",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
