[
    {
        "type": "background",
        "background": "501033"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在夜晚的海邊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "普蕾西亞正抬頭看著天空──"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "普蕾西亞，",
        "unit_id": 131611,
        "voice": "vo_adv_9012001_000"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原來妳在這裡呀。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 135211,
        "voice": "vo_adv_9012001_001"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n天空。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "星星。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵。",
        "unit_id": 135311,
        "voice": "vo_adv_9012001_002"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n星星，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "非常漂亮呢。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n感覺好浪漫……♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 135211,
        "voice": "vo_adv_9012001_003"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n流口水。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "流、",
        "unit_id": 131611,
        "voice": "vo_adv_9012001_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "流口水……？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n妳、",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "妳的意思是……？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊，",
        "unit_id": 135311,
        "voice": "vo_adv_9012001_005"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "確實♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n星星長得",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "很像糖果和金平糖呢♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原來如此。",
        "unit_id": 131611,
        "voice": "vo_adv_9012001_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "普蕾西亞的感性，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真是厲害──",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "啊！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n剛剛閃過的光芒，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "流星嗎？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這正是流星趕月，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "可謂是風流韻事……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "莉莉，妳知道嗎？",
        "unit_id": 135311,
        "voice": "vo_adv_9012001_007"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n在流星落下前",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "將願望唸三遍的話，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就會實現哦。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這是以前奶奶教我的。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但是──",
        "unit_id": 131611,
        "voice": "vo_adv_9012001_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "流星在一瞬間就會消失呢。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "比眨眼還要短暫的剎那……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "別說唸出來，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就連開口都來不及……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "而且，",
        "unit_id": 131611,
        "voice": "vo_adv_9012001_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "對我來說，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就連要許什麼願望，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "都無法選擇。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n因為想實現的願望、",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "希望被實現的願望",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "太多了……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "莉莉妳真是的，",
        "unit_id": 135311,
        "voice": "vo_adv_9012001_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "太認真了啦♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "只要把腦中瞬間浮現的願望說出來就好了，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "輕鬆一點輕鬆一點。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 135211,
        "voice": "vo_adv_9012001_011"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "很多很多，",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n金平糖。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "之類的？",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊，",
        "unit_id": 135311,
        "voice": "vo_adv_9012001_012"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這個不錯呢♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n雖然流星劃過後就會消失，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n但是肯定",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "會有很多金平糖堆在沙灘上。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "好甜，",
        "unit_id": 135211,
        "voice": "vo_adv_9012001_013"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "好好吃。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n沙子。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n好漂亮。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵，",
        "unit_id": 135311,
        "voice": "vo_adv_9012001_014"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "但是吃太多甜食",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "可不好。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n也別忘記要刷牙喔？",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "了解。",
        "unit_id": 135211,
        "voice": "vo_adv_9012001_015"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n那，",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "下一個。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n願望。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "莉莉。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "好的，",
        "unit_id": 131611,
        "voice": "vo_adv_9012001_016"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "普蕾西亞。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n那麼恕我冒昧，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我也來──",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "願望……",
        "unit_id": 131611,
        "voice": "vo_adv_9012001_017"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然真的有很多。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "但希望總有一天，",
        "unit_id": 131611,
        "voice": "vo_adv_9012001_018"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "能將我們該做的事情，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n好好地",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "完成。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在那之前……",
        "unit_id": 131611,
        "voice": "vo_adv_9012001_019"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "希望與兄長大人、",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "璃亞",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "以及普蕾西亞，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n一起冒險──",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……呼。",
        "unit_id": 131611,
        "voice": "vo_adv_9012001_020"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "璃亞，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "妳也許願了嗎？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵。",
        "unit_id": 135311,
        "voice": "vo_adv_9012001_021"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我的願望──",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "肯定跟莉莉",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是一樣的哦。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 135211,
        "voice": "vo_adv_9012001_022"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n一樣。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "少女們的願望，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "靜悄悄地融入了流星劃過的夜空中。"
    }
]