[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩個人組成騎空團持續進行活動的吉塔與{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n因為逐漸闖出了名堂，\n開始過起了忙碌的日子──"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "委託的貨物都在這裡了。",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n可以幫我確認一下",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "有沒有遺漏嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "我看看……",
        "unit_id": 1411,
        "voice": "vo_adv_1057009_001"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "嗯，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "沒問題。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n謝謝你們。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "來，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "收下這個吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_002"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "我才該道謝，",
        "unit_id": 1411,
        "voice": "vo_adv_1057009_003"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "你們不只收拾了盤踞在路上的魔物，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n還平安將貨物送達……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "王都傳聞中的騎空團，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n我已經見識到你們有多能幹啦。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "真是令人佩服。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嘿嘿……",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_004"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "有什麼需要的話，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "可以再委託我們喔。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n那麼就再見啦！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯──！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_005"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "今天又順利完成一件工作了！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "辛苦啦！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "嗯！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_006"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "因為是高報酬的急件，過程有點辛苦，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "但對方似乎很欣賞我們的表現，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "努力也有代價了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "最近的",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_007"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "客人幾乎都是直接指名我們的，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n也因此",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "更容易接到高難度的委託了，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我們要小心別搞砸了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "回到城鎮後去吃頓大餐，",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_008"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好好休息吧！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "咦……？",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_009"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那片雲……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n還有，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是我的錯覺嗎……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "風好像有點……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不對，",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_010"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不是我的錯覺。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "西北方那片雲",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是雨雲。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "現在風向是東南風，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們往北走的話，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "就勢必得從那片雨雲下通過。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "雖然會走些遠路，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "但我們能不能從東邊繞回鎮上呢？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝。",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_011"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我想說總有一天要上天空飛翔，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n就開始用功研讀氣候相關的知識，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n畢竟這些事情在地上也用得到嘛。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "幸好我有記起來～！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "對啊！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_012"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是因為和你一起努力的關係嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n比起自己一個人讀書，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "跟別人一起讀",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "比較容易記起來呢。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我總有一天要上天空旅行的，",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_013"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n在那之前得好好記住這些知識才行……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "咦……？",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_014"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "喂、",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "喂！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n你看那邊！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "那該不會是……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "果然沒錯！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_015"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是飛空艇……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n又可以在這片大陸上",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "飛行了呢……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不知道上面載了什麼人……",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_016"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我也好想搭搭看喔。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真的嗎！？",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_017"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "呃～呃……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……等一下！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "剛剛不是我聽錯吧……！？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你說請他們讓我們上去，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是什麼意思……！？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}向吉塔解釋，\n最近在開發新型飛空艇的商會，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n跟他有些緣分。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……太讓我驚訝了！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_018"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我本來只覺得你是有點不可思議的人，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n想不到你還認識紫藤商會的人……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……我問你喔？",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_019"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "方便的話，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n可以去幫我問一下，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "能不能讓我搭乘看看飛空艇嗎……？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不行的話，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "讓我近距離看一下也沒關係……！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "拜託了！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_020"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我知道這是強人所難的要求，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我會誠心祈禱",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "奇蹟發生的。",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後過了幾天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}前來拜訪吉塔。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你好！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_021"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "莫非是要談",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "上次那件事嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……結果，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "如何呢……？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過……？",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_022"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "抱歉突然插嘴，",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_023"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n接下來的事情，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我想要親自與妳談，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n兩位不介意吧？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "呃，",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_024"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "請問你是……？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "忘了先自我介紹，",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_025"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我是紫藤商會的成員。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "目前負責執掌",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "使用飛空艇的相關貿易。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你是負責人！？",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_026"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你、",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你好！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "嗯，",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_027"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "妳好。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "今天也是個做生意的好日子呢。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "喂，",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_028"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "真是的！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n你怎麼沒先跟我說負責人會過來啊～！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "那麼我們繼續談吧。",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_029"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "關於兩位提出的要求，我有聽大小姐……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n我是說，跟我們商會關係匪淺的人提起過。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "一開始我以為只是年輕人想要來學習觀摩，",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_030"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n仔細一問才發現，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "居然是最近",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "時常耳聞的騎空團成員要過來啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "你們是",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_031"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "為了擁有自己的騎空艇，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n而積極進行活動的對吧？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是的！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_032"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我知道這是條漫長的道路。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……即使如此，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "總有一天我一定要實現它。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "……妳的眼神十分不錯。",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_033"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "難得有騎空團上門相談，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n對於靠天空做生意的我們來說，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "真是天賜良機。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "於是我們決定……",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_034"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "趁這機會，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n試著讓你們接下",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "飛空艇相關的工作。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "會長也很中意你們的毅力，",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_035"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "並要求我們為",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "大有前途的年輕人提供助力。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "請、",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_036"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "請問……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你的意思是！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "既然你們以騎空團為志業，",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_037"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "那麼在空中留下一些成果，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n我想也不是什麼壞事，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "兩位意下如何呢？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "當然沒問題！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_038"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們很樂意接受！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "那真是太感謝了。",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_039"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "只是，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "有一個條件。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你說條件，",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_040"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "是嗎？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "是的。",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_041"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "你們兩位必須和我們另外聘請來，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n擔任護衛的飛空艇船員交手，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "展現一下實力。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "航行在空中遭遇魔物襲擊時，",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_042"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我希望你們不僅要自保，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n還需要保護其他船員。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "若是你們能證明，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n自己擁有這樣的實力，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "這次協議就成立了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "你們願意接受這條件嗎？",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_043"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……我們沒有理由拒絕。",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_044"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "請多指教了！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "很好。",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_045"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "那麼就約在明天，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "勞駕兩位前往此處。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n我們會在那裡等候。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "明天……？",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_046"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "明天嗎！？",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "那當然囉。",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_047"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "談生意是越快越有好處。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "那麼，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我先告辭了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……哇～",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_048"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "事情來得太突然，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n我想到什麼就說什麼了……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "腦袋到現在都還沒轉過來。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "謝謝你去幫我問。",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_049"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "該怎麼說呢，",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "才沒幾下功夫就決定了好重要的事……",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "不過現在機會就在眼前，",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_050"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n只能盡全力做好能力所及的事情了吧。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "反正今天也沒有工作，",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_051"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "好好休息以備明天的戰鬥吧。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "你也要調整好身體的狀態喔。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "明天",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_052"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們倆一起加油吧！",
        "unit_id": 105711
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與吉塔前往商人他們等候的地點赴約。"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我們已經恭候多時了。",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_053"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n以防萬一，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "最後再讓我提醒兩位一次，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我們船員頗具實力。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "即使如此，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "你們還是要打嗎？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "……是的。",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_054"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "我們已經下定決心了。",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我明白了。",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_055"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "看樣子你們已經做好萬全準備了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "喂──！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "出來吧！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "船員1",
        "words": "嘿！",
        "unit_id": 911,
        "voice": "vo_adv_1057009_056"
    },
    {
        "type": "dialogue",
        "name": "船員1",
        "words": "你們就是自稱騎空團的傢伙啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "請、",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_057"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "請多多指教！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "船員2",
        "words": "我看妳還很年輕，",
        "unit_id": 1111,
        "voice": "vo_adv_1057009_058"
    },
    {
        "type": "dialogue",
        "name": "船員2",
        "words": "妳真的確定嗎？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "船員2",
        "words": "\n要是受傷了我可不管喔？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "船員1",
        "words": "這小子說得沒錯。",
        "unit_id": 911,
        "voice": "vo_adv_1057009_059"
    },
    {
        "type": "dialogue",
        "name": "船員1",
        "words": "多點人手減輕我們的工作負擔是不錯，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "船員1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "船員1",
        "words": "但也因此更加不能對你們放水。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "船員1",
        "words": "我們會認真打喔！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "求之不得！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_060"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "來吧！",
        "unit_id": 105711
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "那麼就……",
        "unit_id": 2511,
        "voice": "vo_adv_1057009_061"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "開始吧！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "喝啊啊啊啊！",
        "unit_id": 105711,
        "voice": "vo_adv_1057009_062"
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "船員1",
        "words": "喔喔！？",
        "unit_id": 911,
        "voice": "vo_adv_1057009_063"
    },
    {
        "type": "dialogue",
        "name": "船員1",
        "words": "哈哈！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "船員1",
        "words": "\n看來妳有兩把刷子嘛，小姐！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "船員1",
