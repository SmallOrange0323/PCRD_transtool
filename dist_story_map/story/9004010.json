        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，",
        "unit_id": 103211,
        "voice": "vo_adv_9004010_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為了準備，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我就先告辭了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n優花梨，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "採買就麻煩妳了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "等等，",
