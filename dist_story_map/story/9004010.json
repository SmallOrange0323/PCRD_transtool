        "type": "dialogue",
        "name": "秋乃",
        "words": "綿密而入口即化的絕佳口感……！",
        "unit_id": 103211,
        "voice": "vo_adv_9004010_012"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這股",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "柔和的味道",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "仿佛能從裡到外地溫暖身心，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但同時又",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "十分濃郁……！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這真是太棒了！",
        "unit_id": 103211
    },
