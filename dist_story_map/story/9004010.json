        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，",
        "unit_id": 103412,
        "voice": "vo_adv_9004010_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "果然很中意呢。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會不會太誇張了？",
        "unit_id": 102811,
        "voice": "vo_adv_9004010_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過也沒關係，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只要秋乃喜歡",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就好♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這真是令人想要分享的味道……",
