    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n走在蘭德索爾的繁華街上──"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這裡有好吃的點心喔～！",
        "unit_id": 100711,
        "voice": "vo_adv_9004010_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "大家快來買喔～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n來拿傳單喔～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112,
        "voice": "vo_adv_9004010_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是哥哥！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n莫非",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥也是來婆婆的店",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n幫忙的嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "活動紀錄……？",
        "unit_id": 100711,
        "voice": "vo_adv_9004010_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "雖然不太了解，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "但好像不好吃。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對呀，",
        "unit_id": 101112,
        "voice": "vo_adv_9004010_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是有點忙沒錯。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過這樣一來，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "婆婆的店就會生意興隆，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我們覺得很開心！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "喔～呵呵呵！",
        "unit_id": 103211,
        "voice": "vo_adv_9004010_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這裡就是優花梨和咲戀",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "推薦的點心店嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是呀。",
        "unit_id": 102811,
        "voice": "vo_adv_9004010_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只不過說要來買這間店的點心，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們家的孩子們就會興奮不已，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這間店就是這麼地廣受好評哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這裡有賣就算每天吃也不會吃膩的",
        "unit_id": 102311,
        "voice": "vo_adv_9004010_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n美味蛋糕唷！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "也有賣和所有茶都很相配的蛋糕……",
        "unit_id": 102111,
        "voice": "vo_adv_9004010_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n人家非常推薦……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯嗯♪",
        "unit_id": 103412,
        "voice": "vo_adv_9004010_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我覺得秋乃一定會很喜歡。",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211,
        "voice": "vo_adv_9004010_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是你呀！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n究竟是多麼美好的珍品呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "既然令我如此地期待，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我也不禁做足了心理準備呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼就來",
        "unit_id": 101112,
        "voice": "vo_adv_9004010_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "試吃一口吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼樣呢？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我很推薦我們家的巧克力哦！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211,
        "voice": "vo_adv_9004010_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那就恭敬不如從命了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……嚼……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嚼……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "──！！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這是……！？",
        "unit_id": 103211
    },
