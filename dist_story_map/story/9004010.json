        "voice": "vo_adv_9004010_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那也是",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃的優點呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n今後也這麼過下去，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "繼續惹出許多騷動……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不對，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "繼續創造出許許多多的邂逅吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "身為會被捲入麻煩的人，",
        "unit_id": 103412,
        "voice": "vo_adv_9004010_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我有點憂鬱呢……",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我說啊，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我們只有你能依靠了哦？",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "接下來，",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "也要請你多多指教了！",
        "unit_id": 103412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在一起排隊買點心之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}收下活動紀錄，"
    },
    {
        "type": "dialogue",
