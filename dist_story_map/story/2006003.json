[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來吧來吧！",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請好好享用吧～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我開動了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真不好意思，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還麻煩身為客人的你們下廚。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別這麼說～，",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我最喜歡做料理了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "昨天晚上",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不小心就在這裡過夜了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就讓我做些拿手菜",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來代替住宿費吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也不用客氣盡量吃！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所有材料都是我一早去市場買回來的呢～，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "全都是新鮮現採的哦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耶嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果能合各位的胃口就好了……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，",
        "unit_id": 102111,
        "voice": "vo_adv_2006003_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我要開動了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好好吃……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嚼嚼。",
        "unit_id": 102311,
        "voice": "vo_adv_2006003_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "味道真是不錯。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n比鈴莓做的料理還要好吃很多。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚。",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，孩子們能吃得開心的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那才是最重要的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為了",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不讓廚藝再一直糟糕下去，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我也有在努力哦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "鈴莓做的料理，",
        "unit_id": 102311,
        "voice": "vo_adv_2006003_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "味道的確是有變好了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只是蛋殼掉進料理裡的次數實在過於頻繁，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這就有點～……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，",
        "unit_id": 102311,
        "voice": "vo_adv_2006003_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可可蘿，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n要再來杯茶嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好意思。",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n謝謝妳，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n綾音小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不准說『小姐』～",
        "unit_id": 102311,
        "voice": "vo_adv_2006003_013"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們既然同住在【咲戀育幼院】的屋簷下，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就已經是家人了哦。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可以叫我",
        "unit_id": 102311,
        "voice": "vo_adv_2006003_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n綾音姐姐哦♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊哈哈。",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不好意思，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下總是表現得這麼疏遠……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒有關係哦。",
        "unit_id": 102311,
        "voice": "vo_adv_2006003_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n畢竟在我們這裡可可蘿年紀最小嘛，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n可以多撒嬌一點沒關係哦。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對吧～，胡桃♪",
        "unit_id": 102311,
        "voice": "vo_adv_2006003_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_2006003_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n可可蘿，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我幫妳剝水煮蛋的殼哦……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈，",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿，\n感覺大家都很疼愛妳呢～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好讓人害羞。",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【咲戀育幼院】的各位，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n妳們如此親切地接納白吃白住的我們……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "十分地感謝。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但這件事之後再說，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼您也在育幼院呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "目前",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就在下所知……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您似乎和主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n被捲進了奇怪的事件裡。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n昨天可可蘿，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n沒有和{player}他們待在一起嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看妳跟他們睡在同一張床上面，",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以我還以為……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不。",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n之前應該有跟您提過，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下去了位於",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遠方的神殿唷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為有件相當在意的事，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以在下去求了愛梅斯大人的神諭。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然後昨晚，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將事情處理完……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n回到育幼院來後，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就看見主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和貪吃佩可小姐同床共枕。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "老實說，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是嚇了在下好一大跳。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原本還想著，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能夠久違地一邊感受著主人的體溫一邊進入夢鄉……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明只想與主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩個人一起睡覺的說。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不是，所以我說……",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還沒出嫁的女孩子，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可不能隨便跑到男孩子的床上唷？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要是真的發生了什麼不好的意外，",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_032"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就太遲了哦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "意外？",
        "unit_id": 102311,
        "voice": "vo_adv_2006003_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我和胡桃",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "在作了恐怖的夢之類的時候，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n也會和哥哥一起睡哦？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這、",
        "unit_id": 102111,
        "voice": "vo_adv_2006003_034"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這樣不行嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "要是哥哥抱著我的話，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我就可以睡得很香呢……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}……",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你這樣會敗壞風紀的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以請你別跟女孩子們太過親密唷？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要是真的發生什麼不好的事情，",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我們就會把你趕出去哦？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果鈴莓小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n覺得羨慕的話，也能夠和我們一起睡……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不不？",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我才沒有覺得羨慕！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我已經不是那種",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n愛和人撒嬌的小孩子了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就算是大人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也會有想要向誰撒嬌的夜晚吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是失禮了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n話題",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "偏離得太遠了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼貪吃佩可小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n會和主人同床共枕呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個嘛～",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n其實我會和{player}睡在同一張床上，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也不是我的本意……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～？",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像有段記憶消失了呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想想哦，",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n昨天，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在山裡發生了這樣子的事情……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個詭異的人物",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "施放了戰略級的大量破壞魔法，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以陷入了前所未有的危機狀態呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在那樣的狀況下，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n兩位竟然都能平安無事呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊啊……",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n昨天晚上，確實發生了一起大爆炸呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐也因為很擔心，",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以前往那裡查看狀況了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "得趕快將{player}平安無事的消息，",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n用通訊魔法傳達給大小姐知道。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說的也是。",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那就請妳跟她連絡，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓她能夠放心吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……只是，",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼我們會得救呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不…，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算貪吃佩可小姐這麼問，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也沒辦法回答您什麼。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "連主人也……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n兩位完全不曉得自己，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是怎麼得救的嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是個謎呢。",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為那時候，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有群實力非常堅強的人在……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想可能是其中的誰，",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_056"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或是好幾個人合力，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n將那個大量破壞魔法擋了下來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可是，",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_057"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的有辦法擋住嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n既然稱為戰略級的大量破壞魔法，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我想它的威力應該足以破壞一整座城鎮才對……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "事實上……",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_058"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就我早上在報紙上看來的報導，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n有好幾座山消失，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "連地形也變貌了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要是被那種魔法打到，",
        "unit_id": 102511,
        "voice": "vo_adv_2006003_059"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n一般人應該就馬上灰飛煙滅了吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～。",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_060"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n連施放魔法的本人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也一副自信滿滿的樣子……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想他應該沒有料到",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_061"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣的攻擊會被擋住，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n或是被閃躲掉吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對方應該也不是這麼好對付的人。",
        "unit_id": 105812,
        "voice": "vo_adv_2006003_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n應該會阻斷一切防禦或逃亡的手段，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n打算確實地將我們殲滅才對哦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼要那麼做……",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想解決掉主人你們的人物，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n到底是誰啊？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺她和貪吃佩可小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎有什麼恩怨的樣子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "每當提及那個人物的時候，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_065"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐就會",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "露出一副平常鮮少看過的凶狠表情呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果能將原委告訴我們的話，",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_066"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或許就能更加了解實情了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至少主人就差點",
        "unit_id": 105913,
        "voice": "vo_adv_2006003_067"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為這件事情而丟失了性命。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下認為主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是該有權利知道的。",
        "unit_id": 105913
    }
]