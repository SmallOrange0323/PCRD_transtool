        "words": "這都是多虧了{player}！",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_061"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n真的是",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "太感謝你了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我原本",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_062"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "非常不安，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n擔心自己是不是不會再成長了……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_063"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我長高了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n嘿嘿嘿……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這麼一來",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我就能",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "繼續長大了……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦……？",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_064"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你問為什麼想長大",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這麼說來",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_065"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是為什麼呢……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "等我",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "長大之後……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……因為{player}",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_066"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總是在摸我的頭，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以我想要反擊……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "覺得被當成小孩子",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "很不甘心……？　",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "！",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_067"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "結果這都是{player}害的啊！",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_068"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我會這樣",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "全是為了{player}……！？　",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才……",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_069"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "才不告訴你呢！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我絕對不會",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_070"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "告訴{player}的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就算你露出難過的表情也沒用！",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_071"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這是只屬於我的",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "祕密！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚……",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_072"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "其實就算告訴他也沒關係啊，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我為什麼會",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這麼害羞呢……！　",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著有好一段時間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n鏡華只要一努力試著長高就會覺得害羞。"
    }
