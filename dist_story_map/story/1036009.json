[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾的街上，\n{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "遇到了心情很好的鏡華。"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這不是{player}嗎。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n午安，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "今天天氣很好呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你說我心情很好……",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "看得出來嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n明天",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "學校要實施身體檢查喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "即使{player}失去了記憶，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n應該也知道身體檢查吧？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……你為什麼一臉困惑呢？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "實在拿你沒辦法。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就由我來教你吧。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所謂的身體檢查，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就是定期測量身高與體重，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n讓大家知道自己跟前一次比成長了多少的行事。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不、",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不用客氣。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n畢竟這點小事",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "知道也是理所當然。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果還有什麼不懂的地方，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可以儘管問我喔。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "唔。",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你是不是把我當成是小孩子？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是錯覺？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那就算了……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呃，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不要那麼自然就來摸我的頭！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "討厭。",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為我懂得很多事情，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n希望你別把我當成小孩子。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你也只有現在",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可以像這樣把我當小孩子了，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這次我就不跟你計較吧。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "竟然問為什麼……",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這不是很明顯的事嗎。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為我的身高會很快長高，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n長到{player}的手無法碰到的地方！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個溫柔的",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "眼神是怎麼一回事！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以你不相信對吧！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你明天也過來這裡！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我會把透過身體檢查",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "得知的成長結果",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "告訴你！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我都有好好喝牛奶，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n至於挑食，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然只有一小部分但也克服了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……雖然這也是",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "多虧了{player}的幫忙。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且媽媽也說了，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n說小孩子總是一晃眼",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就長大了喔！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我很快就會長得比{player}",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還高，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n之後就輪到我",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "來摸摸你了！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天──"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……唉。",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊……",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你來啦。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n跟約好的時間一樣……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你今天沒有遲到呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明明就算遲到也沒關係……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們今天是約什麼事情？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n要繼續玩捉迷藏嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n還是說",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我們去野餐呢！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊嗚……！",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你有好好記得啊……",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "也是呢，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "畢竟{player}是會",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "遵守約定的人……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呃……",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n……沒",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……沒有長高。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我的身高，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "跟上一次測量比，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n幾乎沒有",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "改變。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗚嗚……",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我明明都有好好喝牛奶，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n也努力不要挑食了……！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "難道說，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我已經",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "停止成長了嗎……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我可能會永遠是這個身高，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n只能一直被{player}摸頭……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦……？",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你要幫我嗎……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝、",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n果然{player}就是值得",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "信賴──",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_028"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請不要邊那樣說邊摸我的頭啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "討厭，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你這個人實在是～！",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個，",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然照著你說的跟過來……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不過我們要在這裡做什麼呢？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這個飲料是什麼……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "白白的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且感覺稠稠的，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n裡面是不是還浮著綠色的葉子……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "把從熟悉藥物的朋友那邊",
        "unit_id": 103611,
        "voice": "vo_adv_1036009_031"
    },
    {
        "type": "dialogue",
