[
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "「六角納骨‧",
        "unit_id": 135913,
        "voice": "vo_adv_9077155_000"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "蟻落榫」！",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "「地獄之盾」！",
        "unit_id": 104711,
        "voice": "vo_adv_9077155_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呀哇啊啊啊～！？",
        "unit_id": 100511,
        "voice": "vo_adv_9077155_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──",
        "unit_id": 106011,
        "voice": "vo_adv_9077155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一下！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼情況……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊！",
        "unit_id": 100511,
        "voice": "vo_adv_9077155_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "凱留！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸茉莉！",
        "unit_id": 106011,
        "voice": "vo_adv_9077155_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼那兩個人在打架啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是聽說",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有魔物出現才趕過來的欸！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唉呀，",
        "unit_id": 100511,
        "voice": "vo_adv_9077155_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個是……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n剛剛發生一些事啦……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那是，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "魔物出現的報告，傳到凱留那邊前發生的事……"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "──呼！",
        "unit_id": 135911,
        "voice": "vo_adv_9077155_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔……！",
        "unit_id": 104711,
        "voice": "vo_adv_9077155_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沉重的一擊……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……我不記得",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有得罪這個世界的居民啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "能不能把武器收起來呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們不是什麼可疑的人。",
        "unit_id": 104711,
        "voice": "vo_adv_9077155_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只是作為蘭德索爾的代表，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n來和吉歐‧尼布爾黑爾締結友好關係的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "妳知道蘭德索爾的",
        "unit_id": 100511,
        "voice": "vo_adv_9077155_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "公主殿下，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "和她身邊的",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一位騎士嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我們是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "他們的朋友！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "──話隨便怎麼說都可以。",
        "unit_id": 135911,
        "voice": "vo_adv_9077155_011"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n現在也沒有方法",
        "unit_id": 135911
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "確認妳們說的是真的還假的。",
        "unit_id": 135911
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "如果妳們真的是貪吃公主和騎士公的死黨，",
        "unit_id": 135911,
        "voice": "vo_adv_9077155_012"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就讓我看看吧──",
        "unit_id": 135911
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n把妳們心裡，",
        "unit_id": 135911
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "最深處的骨氣拿出來啊。",
        "unit_id": 135911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不不不不！",
        "unit_id": 100511,
        "voice": "vo_adv_9077155_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一定還有除了打架以外，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可以確認的方式吧，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "絕對有！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "什麼！",
        "unit_id": 100511,
        "voice": "vo_adv_9077155_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這種時候還出現魔物……！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "兩位，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在不是打架的時候了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n先合作",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "把那隻魔物──",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……我理解妳想說的話了。",
        "unit_id": 104711,
        "voice": "vo_adv_9077155_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "【王宮騎士團】的團長，名叫純。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我是八熱八寒、",
        "unit_id": 135913,
        "voice": "vo_adv_9077155_016"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "十六地獄的鬼，剎鬼。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我可不會手下留情──",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "死了也別恨我喔。",
        "unit_id": 135913
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那是我要說的話。",
        "unit_id": 104711,
        "voice": "vo_adv_9077155_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我要認真以對了喔，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "剎鬼……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為什麼又打起來了啊！？",
        "unit_id": 100511,
        "voice": "vo_adv_9077155_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "魔物來了喔，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "魔物！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就在那邊！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就在面前了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n現在不是妳們打架的時候啦啊啊啊～！",
        "unit_id": 100511
    }
]