    },
    {
        "type": "dialogue",
        "name": "鳳子",
        "words": "我就大放送賜予你這權利吧！",
        "unit_id": 134731
    },
    {
        "type": "dialogue",
        "name": "鳳子",
        "words": "謝謝你！",
