        "voice": "vo_adv_4010211_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "畢竟可以和",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "迎接生日",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美貌又更上一層樓的我",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n一直在一起呢？",
