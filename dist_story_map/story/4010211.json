    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一定會成為最棒的生日……♪",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來吧，",
        "unit_id": 100831,
        "voice": "vo_adv_4010211_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要去哪裡由你來決定。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n自由的帶我到",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可以傳遞我閃耀美貌的地方吧……！",
        "unit_id": 100831
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我都這麼充滿幹勁了，",
        "unit_id": 100831,
        "voice": "vo_adv_4010211_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n沒想到你會選這種人煙稀少的地方。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你不想",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "更加傳播我的美貌嗎？",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "！",
        "unit_id": 100831,
        "voice": "vo_adv_4010211_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 100831,
        "voice": "vo_adv_4010211_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來如此。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你比",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "想像中還要貪心呢。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "竟然想將這份光芒",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "占為己有。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我當然",
        "unit_id": 100831,
        "voice": "vo_adv_4010211_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒問題。",
