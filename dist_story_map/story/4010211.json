        "type": "dialogue",
        "name": "鳳子",
        "words": "\n",
        "unit_id": 134731
    },
    {
        "type": "dialogue",
        "name": "鳳子",
        "words": "哇哇，",
        "unit_id": 134731
    },
    {
        "type": "dialogue",
        "name": "鳳子",
        "words": "蛋糕也好大～！",
