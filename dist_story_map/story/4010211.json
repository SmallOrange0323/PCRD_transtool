    {
        "type": "dialogue",
        "name": "鳳子",
        "words": "\n",
        "unit_id": 134731
    },
    {
        "type": "dialogue",
        "name": "鳳子",
        "words": "沒想到是為了幫我慶祝才特地叫我來家裡……",
        "unit_id": 134731
    },
    {
        "type": "dialogue",
        "name": "鳳子",
        "words": "咳咳。",
        "unit_id": 134731
