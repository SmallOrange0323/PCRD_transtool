    {
        "type": "dialogue",
        "name": "雪",
        "words": "獎勵吧。",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "給你今天一整天",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可以和我度過的權利！",
        "unit_id": 100831
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很榮幸吧？",
