        "type": "dialogue",
        "name": "鳳子",
        "words": "到男性的住家打擾，",
        "unit_id": 134731
    },
    {
        "type": "dialogue",
        "name": "鳳子",
        "words": "令人有點心跳加速呢。",
        "unit_id": 134731
    },
    {
        "type": "dialogue",
        "name": "鳳子",
        "words": "\n今天",
        "unit_id": 134731
