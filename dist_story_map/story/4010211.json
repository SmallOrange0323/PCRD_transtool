    {
        "type": "dialogue",
        "name": "鳳子",
        "words": "是蠟燭嗎！",
        "unit_id": 134731
    },
    {
        "type": "dialogue",
        "name": "鳳子",
        "words": "\n好多各式各樣的形狀和顏色……！",
        "unit_id": 134731
