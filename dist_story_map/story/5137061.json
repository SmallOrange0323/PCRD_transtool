        "words": "【破曉之星】的三位成員"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n以及{player}踏上了前往背面世界的路途。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "星星好漂亮呀……",
        "unit_id": 100213,
        "voice": "vo_adv_5137061_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯。",
        "unit_id": 100311,
        "voice": "vo_adv_5137061_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也很久沒有像這樣悠閒地仰望夜空了呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這也是冒險的樂趣呢！",
        "unit_id": 100111,
        "voice": "vo_adv_5137061_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有選擇用魔法陣",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一口氣傳送到目的地是正確的呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就是說呢。",
        "unit_id": 100213,
        "voice": "vo_adv_5137061_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n必須靠著我們的雙腳",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一步步前進才行。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這片天空，",
        "unit_id": 100311,
        "voice": "vo_adv_5137061_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不曉得是否也和志那都",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她們的世界連在一起呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不知道呢……",
        "unit_id": 100111,
        "voice": "vo_adv_5137061_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果有連在一起就好了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生……",
        "unit_id": 100213,
        "voice": "vo_adv_5137061_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯！",
        "unit_id": 100111,
        "voice": "vo_adv_5137061_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一定是連在一起的呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。",
        "unit_id": 100311,
        "voice": "vo_adv_5137061_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "肯定是的……",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "501652"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與此同時。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在志那都管理的世界中……"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………",
        "unit_id": 135614,
        "voice": "vo_adv_5137061_009"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "離開時的紀錄已確認完畢。",
        "unit_id": 135614,
        "voice": "vo_adv_5137061_010"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n未發生「重置」。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……太好了。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……大家都在努力呢。",
        "unit_id": 135614,
        "voice": "vo_adv_5137061_011"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我也得",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "至少做到自己能做的事情。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "透過菲歐所窺見的",
        "unit_id": 135614,
        "voice": "vo_adv_5137061_012"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "「基礎世界」資訊……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "要是活用這些情報，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "或許也能為這個世界帶來變化。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就去嘗試所有能用的方法吧。",
        "unit_id": 135614,
        "voice": "vo_adv_5137061_013"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……埃拉她肯定也在嘗試。",
        "unit_id": 135614
    },
    {
        "type": "background",
        "background": "501651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在埃拉管理的世界中……"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好～想喝赤麥酒喔……",
        "unit_id": 135512,
        "voice": "vo_adv_5137061_014"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……不過，",
        "unit_id": 135512,
        "voice": "vo_adv_5137061_015"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要是說這種話，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n感覺又會被志那都訓斥……！！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "還是來認真工作吧。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "志那都……",
        "unit_id": 135512,
        "voice": "vo_adv_5137061_016"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不曉得她過得好不好呢？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "還有",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "在「基礎世界」的大家也是。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "雖然能待在那邊的時間很短暫，",
        "unit_id": 135512,
        "voice": "vo_adv_5137061_017"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但還真是發生了很多事呢……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "呵呵。",
        "unit_id": 135512
    }
