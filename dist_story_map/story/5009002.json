    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗚嗄啊啊啊！",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500120"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀嗚！？",
        "unit_id": 102913,
        "voice": "vo_adv_5009002_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……咦？　",
        "unit_id": 102913,
        "voice": "vo_adv_5009002_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "剛才把我推開了？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是那個溫柔可人，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "連蟲子都殺不下手的千歌嗎？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗄啊啊啊啊！",
        "unit_id": 104211,
        "voice": "vo_adv_5009002_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　呀啊啊啊啊啊！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦咦，",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好大的聲音……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n牆壁都在隆隆作響了……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為千歌最愛唱歌了，平常都一直鍛練肺活量呢！",
        "unit_id": 102913,
        "voice": "vo_adv_5009002_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚呀，耳朵好痛，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "鼓膜都要被震破了～！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗚嗄嚕嚕嚕嚕！　",
        "unit_id": 104211,
        "voice": "vo_adv_5009002_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咕呀啊啊啊啊啊啊啊！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，咦……？",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n那個人，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不知跑到哪裡去了耶……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "怎、怎麼回事呢……？",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n她剛才",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "發出了像野獸的聲音，動作也很像野獸耶……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、我也不曉得！",
        "unit_id": 102913,
        "voice": "vo_adv_5009002_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "　但我要去追她！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是她那種詭異的行為被粉絲目擊的話，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "偶像生涯就結束了……！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀啊啊啊啊！？",
        "unit_id": 105913,
        "voice": "vo_adv_5009002_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇，",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有尖叫聲……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n剛才的聲音是",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可可蘿……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可可蘿是今天負責下廚的人，",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n現在應該是在廚房煮飯……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦咦，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好像聽到了很大的聲音和尖叫聲……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "似、似乎是千歌失控了？",
        "unit_id": 102913,
        "voice": "vo_adv_5009002_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "到底是怎麼回事～",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "發生了什麼事啊？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我不太清楚……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總之我們去看看情況吧……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽和鈴莓姐現在都不在，",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我要守護【咲戀育幼院】才行……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………",
        "unit_id": 102311,
        "voice": "vo_adv_5009002_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "奇怪，",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n妳、妳怎麼了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "從剛才就一言不發的？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……不說話了。",
        "unit_id": 102311,
        "voice": "vo_adv_5009002_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "唔、",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "妳平常是話匣子，現在不說話感覺好怪……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……從剛才到現在",
        "unit_id": 102311,
        "voice": "vo_adv_5009002_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉都不說話了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦，那個……？",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105911,
        "voice": "vo_adv_5009002_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不可以！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下不知道妳是哪位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過做這種事讓在下很困擾啊！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那些是幫主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有育幼院的大家做的料理！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感、感覺好像真的發出了不妙的聲音！",
        "unit_id": 102913,
        "voice": "vo_adv_5009002_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我先走一步喔！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌～",
        "unit_id": 102913,
        "voice": "vo_adv_5009002_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然不知道妳在做什麼，不過快住手啊！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不可以再給其他人添麻煩了啦～！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚～？",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　怎麼回事，發生了什麼事……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n綾音感覺也變得好怪，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n接二連三的發生怪事……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為什麼……？",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n都快到快樂的聖誕節了，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n明明只要再等一下幸福就會來臨……？",
        "unit_id": 102111
    },
    {
        "type": "background",
        "background": "500115"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…………",
        "unit_id": 104211,
        "voice": "vo_adv_5009002_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌！　",
        "unit_id": 102913,
        "voice": "vo_adv_5009002_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳在做什麼？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚哇，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "衣服被食物殘渣弄得髒兮兮了～……？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105913,
        "voice": "vo_adv_5009002_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您是哪位啊？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可可蘿……",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_030"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那……那個，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這些人好像是",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥認識的人……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105913,
        "voice": "vo_adv_5009002_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來是主人認識的人嗎。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然如此，",
        "unit_id": 105913,
        "voice": "vo_adv_5009002_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這般杯盤狼籍的景象，也許該睜一隻眼閉一隻眼……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然好不容易做的料理被糟蹋，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓在下有股難以忍受的怒氣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哎呀呀，",
        "unit_id": 102111,
        "voice": "vo_adv_5009002_033"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鍋子都打翻了呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "這些",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "都是千歌一個人做的嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉。",
        "unit_id": 105913,
        "voice": "vo_adv_5009002_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個人突然衝了進來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n臉直接往鍋子撞上去。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下還想說到底是什麼事呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嚇了在下一大跳。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個叫千歌的，",
        "unit_id": 105913,
        "voice": "vo_adv_5009002_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就那樣子舔著舔著，把所有料理吃個精光了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明只要跟在下說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就會像平常一樣給她午餐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱、抱歉啊～？",
        "unit_id": 102913,
        "voice": "vo_adv_5009002_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
