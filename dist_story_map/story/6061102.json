        "voice": "vo_adv_6061102_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我還以為這一生與禮服無緣呢。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "終於……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "終於讓我穿到了！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊啊，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "怎麼會這麼漂亮啊……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呵呵，",
        "unit_id": 115812,
        "voice": "vo_adv_6061102_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝你♪",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "穿著漂亮禮服受到稱讚，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "身心都飄飄然！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就好像現在已經在舞會中似的♪",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真的呢。",
        "unit_id": 115812,
        "voice": "vo_adv_6061102_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "竟然可以將盔甲變成如此漂亮的禮服。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真不愧是魔法師婆婆……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊、糟了，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我又說出來了。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣說肯定會惹她生氣的，得格外小心才行。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哎呀！",
        "unit_id": 115812,
        "voice": "vo_adv_6061102_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣也不錯喔。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就算是男孩子，會對漂亮的東西有所憧憬也是理所當然的事。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我想你一定很適合穿♪",
        "unit_id": 115812
    }
]