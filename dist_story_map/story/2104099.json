[
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "透過通訊魔法的項鍊，\n{player}從優衣口中聽說了這幾天發生的事件的來龍去脈。"
    },
    {
        "type": "still",
        "still": "210409901"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……差不多就是這樣……",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n說服克莉絲提娜小姐",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的很不容易呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不對，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "或許最困難的還沒結束。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說服她的籌碼……",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_001"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "同時也是克莉絲提娜小姐目標的",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "霸瞳皇帝……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n當然她是一個壞人，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且還是很強大的人。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以我認為不可以真的釋放她……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過……",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總有一天，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "有機會我還是想和霸瞳皇帝好好談一談。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為什麼她會叫我",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "「草野優衣」這件事，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也讓我很在意呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……畢竟之前那時候，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們除了跟她戰鬥之外什麼也沒辦法嘛……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們原本是在說克莉絲提娜小姐的事情吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "關於我們在蒐集索爾魔珠的這件事，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n她似乎願意提供我們協助了的樣子。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然真正的目的，",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "並不是需要她的協助，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而是為了讓克莉絲提娜小姐，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "遠離蘭德索爾就是了……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟若【憤怒‧軍團】的目標，",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是蘭德索爾和七冠的話，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也覺得就如似似花小姐所說的，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "與其讓他們的目標都集中在同個地方，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n還不如把所有人分散在世界各地",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還比較好。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且若是讓克莉絲提娜小姐",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "知道有這麼難纏的敵人在的話，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n感覺她就會單槍匹馬地衝過去了呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過克莉絲提娜小姐看起來，",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "前陣子好像真的過得很無聊呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "偶爾會喊著「讓我來好好訓練妳們～！」",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就又想",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和我們打起來。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n或是作為協助的追加條件，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "試圖想讓我們也去當偶像之類的……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦？",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們有認真拒絕了唷！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過克莉絲提娜小姐",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "完全不肯放棄就是……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……\n……",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果騎士先生",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你想要看的話……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n只當騎士先生你一個人專屬的偶像的話，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "或許當當看也不錯，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n……之類的……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……呵呵。",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "總覺得好怪呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "像這樣隔著看不到對方表情的距離說話時，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n好像會不小心把平時不敢說出來的話都說出來了呢……",
        "unit_id": 100211
    },
    {
        "type": "still",
        "still": "210409902"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦！？",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n那、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那是……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n……我、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我呀，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對騎士先生……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "…………",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……果、",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "果然……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這句話……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還是",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "先保留吧。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "畢竟……",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這麼重要的事情，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還是想要當著你的面跟你說呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……呃……",
        "unit_id": 100211,
        "voice": "vo_adv_2104099_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生你們那邊，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "又過得怎樣呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n你們在月光學院……",
        "unit_id": 100211
    },
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——兩人間漫長的談話，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後還持續了好一段時間……"
    },
    {
        "type": "background",
        "background": "501040"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……嘻嘻★",
        "unit_id": 192011,
        "voice": "vo_adv_2104099_018"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "「啊，",
        "unit_id": 192011,
        "voice": "vo_adv_2104099_019"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "您好～♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n是我唷★」",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "「您是醒著的嗎？",
        "unit_id": 192011,
        "voice": "vo_adv_2104099_020"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "剛醒？",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這樣啊♪",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n看來間隔縮短許多了呢★」",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "「其實呀，",
        "unit_id": 192011,
        "voice": "vo_adv_2104099_021"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "今天我有個非常獨家的大新聞唷！",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "……啊，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "非常抱歉，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "並不是關於七冠那群人的事情就是了。」",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "「關於可能是最後一位七冠的那個人，",
        "unit_id": 192011,
        "voice": "vo_adv_2104099_022"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n蘭法姐已經前往調查了。",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "而蘭德索爾這邊的話，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n阿澤爾德先生所佈的局，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "也應該差不多快要結束了才是？」",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "「比起這些事——",
        "unit_id": 192011,
        "voice": "vo_adv_2104099_023"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "沒想到沒想到，我呀，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "竟然和騎士先生同學……",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊不對，",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是和騎士同學接觸到了呢♪」",
        "unit_id": 192011
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "「嗯呵呵★",
        "unit_id": 192011,
        "voice": "vo_adv_2104099_024"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n那簡直就是，",
        "unit_id": 192011
    },
