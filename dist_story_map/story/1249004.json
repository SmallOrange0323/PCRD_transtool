        "voice": "vo_adv_1249004_064"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我果然是還沒完全恢復過來吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
