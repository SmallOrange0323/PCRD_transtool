        "voice": "vo_adv_1249004_071"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "肚子也餓了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就帶你去我之前說的，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在小巷內很好吃的那家店吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "由你請客，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你可不能說不要喔。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在樂園自蘭德索爾消失之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n殘留下來的只有空白的未來。"
    },
    {
        "type": "dialogue",
