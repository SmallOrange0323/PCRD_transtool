        "voice": "vo_adv_1249004_068"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就算偶爾會停下腳步，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但還是能朝未來前進。",
