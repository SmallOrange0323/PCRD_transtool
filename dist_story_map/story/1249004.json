[
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接受矛依未的提案，嘉夜放棄了能夠解放「樂園的居民」的力量。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而在過了幾天後，{player}在小巷中"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n遇見陷入了沉思的嘉夜。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……嗯？",
        "unit_id": 106511,
        "voice": "vo_adv_1249004_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哦，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是你啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼了，",
        "unit_id": 106511,
        "voice": "vo_adv_1249004_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "發生什麼事了嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n從樂園的騷動之後，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這邊、這附近的圈子都很和平。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……和平到讓人覺得有點過頭了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還說這種話……",
        "unit_id": 106511,
        "voice": "vo_adv_1249004_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我看你是又來要我請客吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "之前是我請的，",
        "unit_id": 106511,
        "voice": "vo_adv_1249004_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這次該換你請了吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你要請的話我是可以陪你吃飯。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我……",
        "unit_id": 106511,
        "voice": "vo_adv_1249004_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在想些事情。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n從那種大騷動突然變得和平，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n害我跟著沒事做了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該怎麼說啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1249004_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就內心深處有種煩悶的感覺……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n所以就稍微",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "陷入了沉思。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不，",
        "unit_id": 106511,
        "voice": "vo_adv_1249004_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的沒什麼大不了的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n只是",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒有揮拳的機會時，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是會莫名其妙想太多呢……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈，",
        "unit_id": 106511,
        "voice": "vo_adv_1249004_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真不像我呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可能是疲勞還沒完全恢復吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總覺得",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "眼前也在閃爍──",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不對，",
        "unit_id": 106511,
        "voice": "vo_adv_1249004_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是你在發光吧！？",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在街角看到嘉夜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n本打算要向她打招呼，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n卻發現她被不良學生們包圍著。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "──所以說！",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我就說我拒絕了！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n為什麼總是要把我扯進你們跟笨蛋大哥之間的事啊！？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "喂喂，",
        "unit_id": 1,
        "voice": "vo_adv_1249004_010"
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "也沒什麼好生氣的吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "\n只是幫我們傳個話而已啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "妳就想成是在幫助我們嘛，",
        "unit_id": 1,
        "voice": "vo_adv_1249004_011"
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "是幫助人喔，幫助人。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "\n如果是重要的妹妹拜託，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "他也會聽的對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真丟臉。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "明明就在那邊耍狠，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n到了緊要關頭卻是拜託大哥、",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "拜託我……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你們根本沒有揍人的膽識吧？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "妹妹",
        "unit_id": 1,
        "voice": "vo_adv_1249004_013"
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "妳還真老套耶～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "\n時下的打架啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "可不是靠拳頭而是靠人脈喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "對啊對啊，",
        "unit_id": 1,
        "voice": "vo_adv_1249004_014"
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "就是所謂的情報戰。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "用社群媒體之類的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "\n啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "要不然妹妹來也可以喔？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "\n妹妹妳也有",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "練空手道對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是又如何？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "哦，",
        "unit_id": 1,
        "voice": "vo_adv_1249004_016"
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "真的假的？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "我還是第一次聽說耶，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "是哪來的資訊啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "真的真的。",
        "unit_id": 1,
        "voice": "vo_adv_1249004_017"
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "而且妹妹她啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "\n聽說還在空手道的比賽中",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "把對手打到送醫院對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "…………！",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這、",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這些事",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是從哪……？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "私帳啦，",
        "unit_id": 1,
        "voice": "vo_adv_1249004_019"
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "私帳。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "裝得一副不打架的清高模樣，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "\n但結果",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "妹妹妳還是跟我們一樣吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "我們好好相處嘛。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你……",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_020"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果再繼續說下去，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我絕不饒你。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n絕對不會放過你……！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "！",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……學長！？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "啊？",
        "unit_id": 1,
        "voice": "vo_adv_1249004_022"
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "你是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "怎樣啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "\n我們現在",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子１",
        "words": "正在談事情──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "──",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_023"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好耶，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你來得正好！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "快跑！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這邊這邊！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1249004_024"
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "可惡，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "該死……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "\n唔喔，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "那傢伙是怎樣啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "不良分子２",
        "words": "跑有夠快！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "噗、",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_025"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈哈！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那些傢伙跑有夠慢的啦！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n──好啦，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "快點快點！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "跟上我！",
        "unit_id": 106531
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯～",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_026"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "盡情跑了一趟呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "心臟就快爆炸了……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那些傢伙啊，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為也沒什麼真的打過架，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n馬上就喘不過氣來了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "順利甩掉他們了呢！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_027"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這次是我牽著學長的手……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n改天有機會就反過來吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣做過之後其實滿有趣的耶。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就像電影場景一樣，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真刺激。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_028"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長出現真是幫了大忙～",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那些傢伙",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的超級纏人的……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……嗯。",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_029"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的幫了大忙。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我差點氣昏頭，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不知道要做出什麼事來。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "──呼，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_030"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "久違地跑步都流汗了呢～",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n啊哈哈，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長也滿身大汗嘛。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "既然都逃到咖啡廳來了，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就點個飲料吧！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我要",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "多糖咖啡歐蕾！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_031"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長你看！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這間咖啡廳",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有賣肉包耶！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還說是店家手作的，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就點來試試看吧！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其他就……",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_032"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈哈，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "麵類也有很多種耶！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n誇張，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "都是一堆大份量的主餐嘛。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這家店也真奇怪。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只是我啊，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_033"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不管是甜的還是鹹的還是大份量的都喜歡就是了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n讓我對這家店有點一見鍾情耶，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "或許會變成常客吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咖啡歐蕾也很好喝，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_034"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很適合當避難所。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n之後要是再被纏上，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "逃來這邊好像不錯……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……啊哈哈，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_035"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "果然",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "被你聽到了啊。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "──如果是跟學長說的話，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_036"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "已經沒關係了吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我放棄空手道的理由，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其實不只一個。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……瞞著你真抱歉。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "之前",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_037"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是說我害跟我對戰的朋友哭了嗎……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其實啊，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是我害她受傷了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她因此",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_038"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒辦法參加後面的大賽……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我不只是害朋友哭，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我更是奪走了她重要的機會。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那個時候的我……",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_039"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一定很希望有人責備我。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n責備我親手破壞了",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "某人重要的事物。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但受傷的她、",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_040"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "老師跟大家，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n都很溫柔對待我，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "都寵著我……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "明明就是加害者，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_041"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "卻像這樣受人寵愛，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我沒辦法原諒這樣的自己。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以我才放棄了",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "空手道。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……嗯。",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_042"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為沒有人要責備我。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我從那之後，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就一直責備著自己。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_043"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但我家的笨蛋大哥啊……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n直到現在都還是",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "隨意地揮拳，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總是讓人受傷。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "明明",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總有一天會破壞某個人的未來也說不定。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的超級不負責任的，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_044"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還害我被牽連。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n都不知道像那樣被纏上了是第幾次了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真～的",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "超級煩的。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……啊哈，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_045"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝啦。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就像學長幫我一樣，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n小時候幫了我的，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也是大哥的拳頭。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "大哥的拳頭既是給了我未來，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_046"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也是傷害了某人的未來。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我現在",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "已經",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "煩到什麼都搞不懂了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我朋友到現在",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_047"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也還在持續練空手道。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n只有我不管過了多久，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "都還在原地踏步──",
        "unit_id": 106531
    },
    {
        "type": "still",
        "still": "124900401"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "──你看，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_048"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就像這杯咖啡歐蕾一樣。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n既不是咖啡也不是牛奶的感覺，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真適合我。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果繼續這樣下去的話，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_049"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "冰塊也遲早會融光……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n變成沒什麼味道，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "無聊的人吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "──",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_050"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "噗，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那什麼意思啊。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然我認同啦。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只有咖啡的話太苦了，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_051"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只有牛奶的話又太甜了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n又有平衡又有份量。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的很棒呢，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咖啡歐蕾。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "──咦。",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_052"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你的意思是……",
        "unit_id": 106531
    },
    {
        "type": "still",
        "still": "124900402"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……這樣啊。",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_053"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "確實呢。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "像咖啡一樣的苦澀經驗、",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "像牛奶一樣的溫柔經驗，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n並不是只有一種才是正確的。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那兩種",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_054"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "造就了我的未來。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n……是這個意思嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯。",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_055"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果只是持續責備自己，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那就無法往未來前進。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那樣做才沒辦法面對自己的行為……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n只是站著不動而已。",
        "unit_id": 106531
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "──",
