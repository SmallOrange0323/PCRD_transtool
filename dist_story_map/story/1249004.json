        "voice": "vo_adv_1249004_069"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總有種安心感，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n或是說背後變得很溫暖的感覺。",
