        "voice": "vo_adv_1249004_056"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "呼～",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總覺得講完這些話之後，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "變得超級暢快的。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n啊哈哈，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "最近發生過的討厭的事，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "全部都忘光了！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的是太好了，",
        "unit_id": 106531,
        "voice": "vo_adv_1249004_057"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還好談這件事的對象是學長。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……謝謝你。",
        "unit_id": 106531
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──從、",
        "unit_id": 190011,
        "voice": "vo_adv_1249004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從未有過的嚴肅氣氛……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "給我等一下，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你根本就是個厲害的詩人吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "簡直就像浪漫電影的場景耶！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……怎麼可能是嘛。",
        "unit_id": 190011,
        "voice": "vo_adv_1249004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正是你這個人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也只是單純喜歡咖啡歐蕾而已吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你呀，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還真是會自然而然地說甜言蜜語耶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了，",
        "unit_id": 190011,
        "voice": "vo_adv_1249004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "反正人生是很長的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒辦法永遠都在犯錯，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也沒辦法永遠都在做對的事……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不對，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "其實打從一開始",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就沒有什麼東西是對。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嘉夜口中的大哥、",
