    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "愛蜜莉雅大人，",
        "unit_id": 132111,
        "voice": "vo_adv_5152322_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請注意不要直接接觸到。",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我知道了。",
        "unit_id": 131911,
        "voice": "vo_adv_5152322_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "各位，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
