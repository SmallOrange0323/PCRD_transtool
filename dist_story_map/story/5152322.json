    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "牠或許",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "是打算使用那些棘手的小型魔物也說不定呢。",
