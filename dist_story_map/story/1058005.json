    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那該有多好♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷。",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "店員來了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我全部一起點喔～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "麻煩從菜單的這頁開始，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這裡到這裡為止，全部都來一份。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "錢的問題不用擔心，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我有的是錢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我們將一整頭牛的份量，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n全部都吃掉吧……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊！",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n吃肉吃到渾然忘我，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都忘了我有事想要跟{player}商量！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我真是糟糕呢～",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n每次吃飯的時候，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都會將重要的事情忘得一乾二淨♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這都要怪{player}……\n哪裡不去，偏偏帶我來燒肉店",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣令人心動的地方。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我原本只打算在簡餐店，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n輕鬆地跟你聊天而已。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不用那麼拘謹也沒關係啦～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然我是有事商量，但也不是什麼大不了的事。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}，\n真是老實呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是那個啊。",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想要",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n創辦一個公會喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是我因為種種原因，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n沒辦法出入公家機關……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "創辦公會的諸多手續，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想要是{player}能幫我處理就好了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "創辦公會所需的資金和文件，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會準備好。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唯獨向政府機關提出文件這件事，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想拜託{player}幫我去處理……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好不好？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也不是那麼緊急的事情啦，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你可以回家之後再來考慮這件事……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在我們只需盡情享用眼前的美食就好～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "萬歲！",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n肉來啦～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n美味的東西果然很偉大呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論遇到什麼煩惱困難，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺都能一掃而空呢♪",
        "unit_id": 105812
    }
]