    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼嚼！",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好～吃☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "受不了啦！",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為最近都只吃魚而已，所以肉顯得特別美味！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這好吃得犯規啊～！",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這塊肥肉根本就是快樂的結晶嘛！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啪喀啪喀，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吼啊啊～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n美味的成分在舌尖上跳起輪舞曲呢～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "非常感謝，\n{player}！\n",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你告訴了我一間很好的店呢～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這麼隱密的燒肉店，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是沒人介紹，我不可能會發現呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是不能小看，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}對於美食的嗅覺！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵呵，你這個貪吃的孩子……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們真是志同道合，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n個性很合得來呢～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們乾脆結婚吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可不是開玩笑喔～真的真的♪　",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}不管什麼東西都吃得津津有味，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n跟你一起圍著餐桌吃飯很快樂呢～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是啊，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}似乎很受歡迎。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以我不能把你『占為己有。』",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呢",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你的筷子停下來囉！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃飽了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}不要只顧著烤肉，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也要多吃一些啊～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "燒肉會豐富你的人生！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷。",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n已經沒肉可以烤了呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以加點嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你不用擔心！",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我吃掉的份，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我自己會出錢啦♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我在打工的店賺了很多，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n存了不少錢喔～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這些錢，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n原本是要用在武者修行上的軍資。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你看，我的錢包很久沒這麼飽滿了呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "目前看來，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我所存的旅費暫時足夠了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我預計要再去旅行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等到旅費用完了，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會再回來。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "回到蘭德索爾♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使我不在這裡，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你也不能忘記我喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "關於旅行的故事，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會再好好地說給你聽。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等我回來再一起圍著餐桌吃飯吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有跟小可蘿和小凱留，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家一起吃飯喔……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻。",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像變得有點感傷……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我要繼續點餐囉～！",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}也是，\n沒填滿飽肚子不能停下筷子喔☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你看還有頂級牛小排喔，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個名稱也太悅耳了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "神啊、牛啊，感謝你們。",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n父親大人、母親大人，謝謝你們。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我現在非常的幸福～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來吧，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我將這份幸福也分給{player}～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n抱緊處理♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸～？",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，{player}這個害羞鬼！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你果然是男孩子呢……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來我肌膚接觸做得有點過火。",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是{player}畢竟是男孩子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我不收斂一點不行呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻～",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我一定被認為是不檢點的孩子了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "佩可！？",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "綽號被省略了……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光是被叫綽號我就很開心了～",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而綽號竟然又進一步被省略，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像我們的關係變得更好了，我好高興喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "親近感，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n又增加了呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……當然，",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我很幸福喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n特別是最近。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我甚至都在想著……",
        "unit_id": 105812,
        "voice": "vo_adv_1058005_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是能作為『貪吃佩可』一直生活下去的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
