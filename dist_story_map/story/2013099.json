[
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，",
        "unit_id": 105911,
        "voice": "vo_adv_2013099_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請喝水。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下加入了些煮過的藥草，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n喝下它後應該就能恢復點精神才是。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106015,
        "voice": "vo_adv_2013099_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝謝妳，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可蘿仔。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咕嚕咕嚕……♪",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_2013099_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在您喝完它了後，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就到附近進行躲避吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下會帶著妳一起。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟是如此規模的混戰，",
        "unit_id": 105911,
        "voice": "vo_adv_2013099_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就光只是留在此處，想必也相當危險吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該找個相對安全的位置躲藏起來或許較好。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不行，",
        "unit_id": 106015,
        "voice": "vo_adv_2013099_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也要戰鬥。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不能夠只是當個拖油瓶呢。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或許是多虧妳能夠這麼細心照顧我，",
        "unit_id": 106015,
        "voice": "vo_adv_2013099_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我現在好像充滿精神了嘛。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "甚至，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就像是魔力從身體最深處裡湧出，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "簡直快要爆發出來了。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣……",
        "unit_id": 105911,
        "voice": "vo_adv_2013099_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而還請您千萬不要過分勉強了呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "直到不久前，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您都還在與死神拔河呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就說別擔心了嘛，",
        "unit_id": 106015,
        "voice": "vo_adv_2013099_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不會亂來的。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算是我也想要為了妳們",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "做些什麼的嘛。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 105911,
        "voice": "vo_adv_2013099_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……可蘿仔？",
        "unit_id": 106015,
        "voice": "vo_adv_2013099_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不、",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不用擔心的啦，講真的！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳看，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可是這麼有精神的唷♪",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_2013099_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是抱歉……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟一臉鬱悶表露無疑了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105911,
        "voice": "vo_adv_2013099_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是太不中用了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和能夠替各位強化的主人，",
        "unit_id": 105911,
        "voice": "vo_adv_2013099_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還有那處於最前線戰鬥的貪吃佩可小姐她們不同，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就只有在下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺無法派上什麼用場……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊……",
        "unit_id": 105911,
        "voice": "vo_adv_2013099_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若在下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能擁有足以一次就將所有問題解決，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此這般的力量就好了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如同那『七冠』，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有著那媲美於神一般的力量就好了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下所被賦予的，",
        "unit_id": 105911,
        "voice": "vo_adv_2013099_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n盡是些在如此的局面中不具效益，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又微不足道的能力。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "？　",
        "unit_id": 106015,
        "voice": "vo_adv_2013099_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然不懂妳在想什麼。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但有什麼不好，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算妳沒有那種什麼神力。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算在這種狀況下，",
        "unit_id": 106015,
        "voice": "vo_adv_2013099_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是能夠貼心溫柔的陪伴著別人，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我就覺得有這樣的妳在實在是太好了。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_2013099_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真的非常感謝您，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您果然是一位溫柔的人呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "願意如此",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "安慰著在下。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼。",
        "unit_id": 106015,
        "voice": "vo_adv_2013099_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就只是，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不小心把真心話說溜了嘴而已啦。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "喂～",
        "unit_id": 190911,
        "voice": "vo_adv_2013099_019"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "【美食殿堂】的傢伙！　",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "讓人找好久了呀！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我可是追跡著妳們的魔力把整座城都飛過一遍了呢，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n拜託妳們能不能別突然就瞬間移動跑不見呀！？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀啊……？",
        "unit_id": 106015,
        "voice": "vo_adv_2013099_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是在我們的公會小屋裡定居下來的那隻奇怪的妖精！",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是叫涅比亞來著？",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "沒錯，",
        "unit_id": 190911,
        "voice": "vo_adv_2013099_021"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我可是那偉大的『嚮導小妖精』涅比亞大人唷！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就盡情的崇拜我吧！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "先不說這個了！",
        "unit_id": 190911,
        "voice": "vo_adv_2013099_022"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我有事情想要告訴妳們唷，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "現在能說上話嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以是可以……",
        "unit_id": 106015,
        "voice": "vo_adv_2013099_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是妳，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "之後趕快去哪避難吧。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n城中到處都有魔物在搗亂唷，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果被波及到了，",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像妳這種的被人家指頭隨便一戳就會掛掉了喔。",
        "unit_id": 106015
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那種事我知道啦！",
        "unit_id": 190911,
        "voice": "vo_adv_2013099_024"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n雖然我原本已經從這邊的世界到夢的世界去避難了，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但被菲歐……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "被愛梅斯",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "拜託了一些事情呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那傢伙平常，",
        "unit_id": 190911,
        "voice": "vo_adv_2013099_025"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不是都透過夢境來給妳們建議的嗎？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但畢竟是夢，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "所以基本上一覺醒來就全都忘光光了對吧？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "但是。",
        "unit_id": 190911,
        "voice": "vo_adv_2013099_026"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n只有這次，",
