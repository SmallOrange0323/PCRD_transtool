[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我說你呀……",
        "unit_id": 1,
        "voice": "vo_adv_2101004_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂，我說你呀！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500271"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "喂！{player}！",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n{player}！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你給我振作一點啦，{player}！",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我的聲音，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你聽得到嗎……！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……和平常不太一樣，",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "幾乎沒有『連結上了』的感覺……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真令人頭疼呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只能死馬當活馬醫，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "繼續和他講下去試試看了嗎……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……聽好囉？　{player}。",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然我不確定你有沒有辦法理解，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但總之，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我先把現況都告訴你了唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你現在",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經受到了相當嚴重的傷害。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但不是在身體上，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而是在靈魂上。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還記得嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n當時幾乎被霸瞳皇帝殺得剩半條命的你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在這個地方，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "模索路晶跟你說過的話。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我所還給你的『公主騎士』之力……",
        "unit_id": 106813,
        "voice": "vo_adv_2101004_007"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n確實，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是{player}你的力量。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n然而，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那卻是『之前的你』所擁有的力量。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那是和『現在的你』",
        "unit_id": 106813,
        "voice": "vo_adv_2101004_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有些許的不相同的，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『失去記憶前的你』……",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "假設你真的把所有力量都解放了，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那麼到時候，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "『現在的你』又究竟會怎樣誰也不知道。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "或許就因為",
        "unit_id": 106813,
        "voice": "vo_adv_2101004_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那些微的差異，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n那把能引出力量的『鑰匙』",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就因此毀壞了也說不定。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不僅如此",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "甚至你可能會因為無法承受副作用，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "導致身體崩壞了也說不定。",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "最糟的是你有可能會被這個世界",
        "unit_id": 106813,
        "voice": "vo_adv_2101004_010"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "認知為『原因不明的錯誤』，",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n導致『你』這個存在",
        "unit_id": 106813
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "被消滅了也說不定。",
        "unit_id": 106813
    },
    {
        "type": "background",
        "background": "500271"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你為了守護大家，",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以用了那個力量。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這雖然是非常了不起的事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為那個副作用，",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和『原本的你』之間發生了『歧異』。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你之所以會變回嬰兒的狀態，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是因為這個『歧異』的關係。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過嘛，",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "晶所說的最糟的假說……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也就是你被世界消滅的\n這件事幸好並沒有發生，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以還算好的了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "毫無疑問的\n這事態依舊是不容忽視的呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且對可可蘿來說也是個負擔嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對，",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說到負擔，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個被你救下來的女孩子啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她到底是誰啊？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子也像個小寶寶一樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只會在那邊啊嗚啊嗚的！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且這件事雖然好像跟索爾之塔有什麼關連的樣子……",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是那座塔的謎團實在太多了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就連我也完全沒有頭緒呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……不過。",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如果她和你一樣",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "喪失了記憶……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼那孩子不可能沒有困擾才是。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可別對人家太冷淡囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過你現在也不太妙就是了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……啊，",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "明明本來的連結就很不安定了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在的收訊感覺還比剛剛更差了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "差不多，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就連要傳達聲音都到極限了嗎……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之……",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我這邊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也會盡可能去調查看看的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以可能會有一陣子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不能像以往一樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n和你這樣想說上話就有辦法說上話囉……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是，",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要小心一點唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然霸瞳皇帝被打倒了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且乍看之下像是恢復了和平……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但總覺得，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還是有不好的預感。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對啦，",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是直覺啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n對於身為原嚮導小妖精的我來說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這的確很丟臉就是",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但接下來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一定還會發生什麼大事的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "弄個不好，",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許又會演變成要面臨戰鬥了也說不定。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而且是比對上霸瞳皇帝的那一戰，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還要更加激烈的戰鬥。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你可別輸了唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "主角。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "並且，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果願望能夠成真的話……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還希望下一次，",
        "unit_id": 190011,
        "voice": "vo_adv_2101004_023"
    },
