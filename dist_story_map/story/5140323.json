[
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "不錯嘛，",
        "unit_id": 18211,
        "voice": "vo_adv_5140323_000"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "窩囊廢們……",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "能戰到這個地步，老實說小官很「佩服＜驚訝＞」啊……",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "差不多也該使出最後的「全力＜真本事＞」才行呢！？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "哼哈哈哈哈……！",
        "unit_id": 18211,
        "voice": "vo_adv_5140323_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔，",
        "unit_id": 111011,
        "voice": "vo_adv_5140323_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "敵人好像在集氣……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是最後的殺手鐧嗎，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們沒道理要等她呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在就是要出其不意地拿出為了這種時候準備的閃光彈──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嘿咿！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呀嗯！",
        "unit_id": 110811,
        "voice": "vo_adv_5140323_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是現在！",
        "unit_id": 111011,
        "voice": "vo_adv_5140323_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "快逃啊，各位──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒妳怎麼了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "為什麼抱著肚子蹲在地上……？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "噗……",
        "unit_id": 110911,
        "voice": "vo_adv_5140323_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "噗呼呼……！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n剛、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "剛才……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "剛才的妳有聽到嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n地獄的聖女竟然會",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「呀嗯！」",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "地叫……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還真是可愛，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "噗噗噗……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "啊啊！？",
        "unit_id": 18211,
        "voice": "vo_adv_5140323_006"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "揍妳喔，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "混帳！",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n小官怎麼可能會發出那種像是萌系角色的「悲鳴＜聲音＞」啊！？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不對……",
        "unit_id": 111011,
        "voice": "vo_adv_5140323_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但我確實也聽到了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n如果不是妳，那剛剛的「呀嗯」會是誰發出來的？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 110911,
        "voice": "vo_adv_5140323_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那就不是我們的聲音嘛？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喂喂～",
        "unit_id": 110811,
        "voice": "vo_adv_5140323_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n住手吧，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那樣像是在找犯人似的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "會讓教室裡的氣氛變糟啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110911,
        "voice": "vo_adv_5140323_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也是呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n既然她本人堅持不是自己，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n那就當作是這麼回事吧，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "噗～嘻嘻嘻。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "這不就完全是在懷疑小官嗎！",
        "unit_id": 18211,
        "voice": "vo_adv_5140323_011"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "開什麼玩笑，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "小官絕對要洗刷「冤屈＜嫌疑＞」。",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "喂，妳們幾個，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "每人輪流「呀嗯」一聲看看。",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "呀嗯！",
        "unit_id": 110911,
        "voice": "vo_adv_5140323_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呀嗯！",
        "unit_id": 111011,
        "voice": "vo_adv_5140323_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呀嗯。",
        "unit_id": 110811,
        "voice": "vo_adv_5140323_014"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "這不是沒有剛才的「聲音＜呀嗯＞」嗎！",
        "unit_id": 18211,
        "voice": "vo_adv_5140323_015"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "好，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "「再次檢查＜再一次＞」，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "妳們三個這次發出高兩個八度的──",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "太拖了啦，",
        "unit_id": 110811,
        "voice": "vo_adv_5140323_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是要鬧到什麼時候啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "該適可而止吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "啊……？",
        "unit_id": 18211,
        "voice": "vo_adv_5140323_017"
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n喂，「二年級的＜小姑娘＞」？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "妳說的那是什麼話？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "該不會妳",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "知道「真犯人＜真呀人＞」是誰，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "還「擁護＜包庇＞」對方吧！？",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊啊！？",
        "unit_id": 110811,
        "voice": "vo_adv_5140323_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "「真呀人」就是妳吧！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n嫁禍給別人也太差勁了吧，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳這混蛋都不覺得羞恥嗎！？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "萌系角色就給我穿著女僕裝紅著臉喊出「呀嗯」啦！",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哦哦，",
        "unit_id": 110911,
        "voice": "vo_adv_5140323_019"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐難得這麼殺氣騰騰呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n看來面對「地獄的聖女」最後的真本事，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不拿出那樣的氣勢可不行呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來是那樣呢。",
        "unit_id": 111011,
        "voice": "vo_adv_5140323_020"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒辦法了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們也拿出真本事上吧！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n優妮們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使出最終之力上吧！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是啊！",
        "unit_id": 110911,
        "voice": "vo_adv_5140323_021"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n好朋友社，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "使出最終之力上吧！",
        "unit_id": 110911
    }
]