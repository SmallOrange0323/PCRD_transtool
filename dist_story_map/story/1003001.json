[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了修練，\n怜獨自來到森林深處。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝！",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_000"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種程度的話，拿來熱身正好……",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_001"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是魔物的聲音啊……",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有人在傳出聲音的地方……",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個背影是……！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呦，果然是你啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你在這種地方做什麼呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只有你嗎……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我記得這附近的魔物是沒那麼凶暴沒錯……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，就算一個人也總會有辦法的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊，我不是來工作的。",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是為了磨練自己的實力，才來跟魔物戰鬥的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既然你是因工作而來那也沒辦法，",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但不要打擾我修練。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "知道了嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那是剛才在嘶吼的傢伙吧。",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那傢伙我要了！ 那麼再會了！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝！ 哈！！",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_009"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，今天狀況很好。",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這樣的話，再往森林深處前進一點也──",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來他那邊也出現了魔物。",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "機會難得。就讓我見識他的實力吧。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "魔物種類是……即使在這附近，也算是相當弱的傢伙。",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就不用擔心了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "敵人的行動也很慢。只要攻擊那裡的話……",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為何不攻擊那裡呢……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊！ 這樣子拖拖拉拉的，敵人要反擊了！",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過那種程度的攻擊的話輕鬆就能迴避──",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我忍無可忍了！ 呀！",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_015"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "休想得逞！",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "{player}，沒事吧？",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也來幫忙！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就那樣讓你獨自戰鬥的話，",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也會太過在意而無法修練啊。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是你必須自己完成被委託的工作。",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就算我打倒魔物也沒有意義。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我會給你指示，你就聽從我的指示行動。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種魔物在攻擊後，會露出很大的破綻。",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n確實迴避，然後反擊。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "懂了嗎？",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "仔細觀察對手的行動……就是那裡！",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_020"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "做的好！ 有心的話還是做得到的嘛。",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是隨便給你點建議，你就能按照指示行動，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你似乎有天份呢。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好，就趁勢打倒下一隻魔物吧！",
        "unit_id": 100312,
        "voice": "vo_adv_1003001_022"
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……差不多都打倒了。",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也快天黑了，那我們回去吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "用不著道歉。",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也得到了想起初衷的好機會。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我沒做什麼值得你道謝的事。",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我只是給你建議而已。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是對你而言，或許是很好的訓練呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n光是今天不就成長了許多？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你似乎很有天份，",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n往後也持續鍛鍊的話，一定可以練就好身手。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該不該指導你呢？……",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，開玩笑的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n好吧。我很樂意。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你就是一起以索爾之塔最高層為目標的夥伴了。",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n如果是為了讓夥伴變強、我會不惜餘力協助的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……怎麼了嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你、你、",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你在說什麼啊！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這樣捉弄我很不好喔，真是的……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒想到會稱讚我的笑容……",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是……不知為何被你稱讚，不會感到不舒服呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總而言之。為了讓你能成為傑出的騎士，",
        "unit_id": 100311,
        "voice": "vo_adv_1003001_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n今後我也會嚴格地鍛鍊你喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從那天開始，怜的特訓就開始了，\n{player}漸漸地提升了實力。"
    }
]