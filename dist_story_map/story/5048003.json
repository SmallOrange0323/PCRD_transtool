    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是不是",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "害妳太累了？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是的話對不起呀。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "老是不懂得察言觀色……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "鈴奈……",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_049"
    },
    {
