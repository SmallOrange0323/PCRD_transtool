    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "也該裝個樣子給她看看。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……嗯？",
        "unit_id": 100811,
        "voice": "vo_adv_5048003_051"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼了{player}。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n為何盯著我看呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "借鏡子？",
        "unit_id": 100811,
        "voice": "vo_adv_5048003_052"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真拿你沒辦法。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n好吧，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過可別弄壞了喔。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "怎、",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_053"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "怎麼了，{player}？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n為什麼要讓我照鏡子？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "意思是要我整理儀容嗎？",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_054"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "唉，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "好啦，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我照就是了。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "……",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_055"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "什麼嘛，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "明明就沒什麼問題……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "啊。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "在鏡子裡的",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_056"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "是茜里的臉啊。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n對了，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "現在的我……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "外表可是茜里的模樣。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "結果我卻畏畏縮縮，",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_057"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "對他人的反應患得患失……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我明明，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "是想把茜里的優點呈現給大家看……！　",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "快點想想……",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_058"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "像這種時候，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "換成茜里會怎麼做？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我比誰都還要認真看著茜里，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "肯定會明白的。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "茜里她",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_059"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "有著恰到好處的",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "坦率與不造作，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "對誰都一樣有親和力。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我最喜歡這樣的茜里，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "也一直嚮往她的個性。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "像這種時候，",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_060"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "茜里應該不會勉強自己。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n既然如此，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我也該像茜里一樣",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "大大方方地把話說出來。　",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "若是在平常我也許辦不到，",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_061"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "但憑目前茜里的模樣應該沒問題！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n所以……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我也要效法茜里的那份率真，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "和大家一起享受活動！　",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "茜里？",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_062"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "抱歉害妳擔心了，鈴奈。",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_063"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n茜里我啊，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "今天實在太興奮了，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "一個不小心",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "有點high過頭。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n在下一場演唱會開唱前，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "真想先喝點什麼冷飲呢。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "原來是這樣！",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_064"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還想說",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "茜里妳是不是",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n為了什麼原因討厭人家，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "害人家超擔心的～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過這樣的話當然OK！",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_065"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n茜里妳有什麼要求，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不必客氣儘管開口！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "哇～",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_066"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "謝謝妳！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "那麼，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "既然都來參加音樂節，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n我想去看看那些精品。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "雪妳也一起來吧！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真拿妳們沒辦法。",
        "unit_id": 100811,
        "voice": "vo_adv_5048003_067"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不曉得那些精品",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有沒有哪件是配得上我的呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "欸，{player}。",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_068"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n我這裡已經不要緊了，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "你去茜里那頭關心一下她吧。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "茜里雖然比我可靠，",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_069"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "但說不定心裡也覺得很不安。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "而且",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我已經深切體悟到",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "扮演別人是多困難的事情。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "嗯……",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_070"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "還有，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "就是……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "今天",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_071"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "幫了我這麼多，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "真的很謝謝你喔，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "哥哥♪",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "為、",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_072"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "為什麼要驚訝成那樣啦！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我只是覺得",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "茜里應該會這樣說，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n所以才試著模仿一次！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "那麼時候差不多了，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我該回鈴奈她們那裡去了！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我辦到了……",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_073"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "成功地",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "向他道謝了……！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n雖然是透過茜里的身體，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "但這次總算說出口了！　",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "總有一天一定要親口告訴他──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n下定決心的依里，踏出了屬於自己的一小步。"
    }
]