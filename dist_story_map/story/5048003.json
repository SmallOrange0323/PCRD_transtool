[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "音樂節與線下聚的舉辦日當天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n茜里前往線下聚的聚會店家，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n依里則是獨自前往與{player}等人相約的會合地點。"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "嗚嗚……",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_000"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "第一次參加音樂節實在好緊張……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "雖然超級名模的事應該是開玩笑的，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n不過光是想到要跟陌生人一起參加，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我就快要昏倒了。",
        "unit_id": 113712
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才你終於來啦！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈嚕哈嚕～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你這次找了這麼可愛的正妹來，",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "遲到小事一件啦。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不過來的竟然是天使太意外了，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好好笑喔～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是說這衣服也太讚吧？",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "誇張可愛又誇張精緻耶！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸欸欸，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這是哪間店買的啊？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也好想穿穿看喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "呃、",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_004"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "嗯……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這是朋友送的……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "算是、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "手工做的",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "吧……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的嗎！",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "茜里妳認識那麼狂的朋友？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好厲害喔～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "讓雪雪來穿應該也不錯看吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是無意義的問題。",
        "unit_id": 100811,
        "voice": "vo_adv_5048003_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "像我這麼美麗的人",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "穿什麼都是絕配。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就算是路邊的舊報紙跟破手套，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n一讓我穿上都會化為禮服。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "倒是話說",
        "unit_id": 100811,
        "voice": "vo_adv_5048003_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳從剛才就像個老朋友一樣和我們聊，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n但我們是初次見面吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "算了，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看來這應該也是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "拜我的美貌所賜吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈！",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雪雪妳這人真有趣耶！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "笑死～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才扮天使是要笑死誰啦～♪",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不過也說不定跟你意外速配喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "好、",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_010"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "好厲害……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "明明才剛認識就這麼主動積極。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n這就是現充，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這就是所謂的超級名模……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不對，",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_011"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這一定是",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "源自鈴奈自己的人品吧。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "畢竟她不只可愛，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "個性也是既陽光又隨和。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "本來",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_012"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "她應該會跟茜里很投緣，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n由我當替身真是可惜了……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "倒是真沒想到",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_013"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "那傢伙竟然真的認識這麼厲害的人，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n關係還這麼親密。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "嗚嗚，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "在場這麼普通的就只有我了……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸～茜里！",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "茜里妳",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有什麼想看的歌手嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "啊，",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_015"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我的話……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "鈴、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "鈴奈妳想看誰",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我就看誰吧。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "天啊！",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "茜里妳超體貼的耶！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "OK～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那總之我們就去會場吧！",
        "unit_id": 101611
    },
    {
        "type": "still",
        "still": "504800301"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "耶──！",
        "unit_id": 101611,
        "voice": "vo_adv_5048003_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太讚了──！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "耶、",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_018"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "耶……！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "因為第一次參加什麼都不懂，",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_019"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n只好先跟著周遭的人一起喊……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "但、",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "但是人實在好多……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "又好熱……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我能撐到最後嗎？　",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "鈴奈她",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_020"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "看起來早就習以為常了。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "至於雪……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊……",
        "unit_id": 100811,
        "voice": "vo_adv_5048003_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "事實證明即使在這人潮洶湧的環境下，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我的美麗",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "依然絲毫不受動搖！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "咦咦～！",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_022"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "她是哪時跑得那麼遠的！",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n某方面來說她也跟鈴奈一樣不簡單啊。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "雖然是個怪人。",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "音、",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_023"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "音樂節還真是學問不小……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n我這樣，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "真的有融入大家嗎……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "那、",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_024"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "那個，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "像我這樣會不會很突兀啊？",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "說、",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_025"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "說得一副好像你很懂的樣子……",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不過",
        "unit_id": 113712,
        "voice": "vo_adv_5048003_026"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "仔細一瞧，",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "有人在最前排搖頭",
        "unit_id": 113712
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "或者是跳舞，",
