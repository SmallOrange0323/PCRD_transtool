[
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呼……",
        "unit_id": 123211,
        "voice": "vo_adv_5100322_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "總算是來到羊先生面前了，不過……",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "你們",
        "unit_id": 16613,
        "voice": "vo_adv_5100322_001"
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "不可以來這裡！",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "\n我已經",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "不會再聽任何人說話了！",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "\n我要永遠在這裡",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "等下去！",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "因為",
        "unit_id": 16613,
        "voice": "vo_adv_5100322_002"
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "我們已經這樣約好了！",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "\n我哪裡都不會去的！",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不願意聽……",
        "unit_id": 123111,
        "voice": "vo_adv_5100322_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們說話嗎。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過……",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家可不能就這麼照你說的做。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果你的願望，",
        "unit_id": 123111,
        "voice": "vo_adv_5100322_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真的",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是想永遠",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "孤獨生活下去",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也就算了，",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家可不這麼認為。",
        "unit_id": 123111
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "沒、",
        "unit_id": 16613,
        "voice": "vo_adv_5100322_005"
    },
    {
        "type": "dialogue",
        "name": "植物羊",
        "words": "沒有這回事……",
        "unit_id": 16613
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "別擔心！",
        "unit_id": 123211,
        "voice": "vo_adv_5100322_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們絕對絕對",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "會幫助你的！",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n對吧，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉！",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「沒錯！」",
        "unit_id": 2113,
        "voice": "vo_adv_5100322_007"
    }
]