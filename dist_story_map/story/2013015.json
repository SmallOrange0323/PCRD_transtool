    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還真是變得熱鬧了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "所以我才",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這麼討厭你們呀。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們是不知道情緒是為何物的嗎？",
        "unit_id": 106914,
        "voice": "vo_adv_2013015_001"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這可是人生的終點、",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "世界的終結唷……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們就不能靜靜？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過嘛，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也是如此的你們也才讓我懷念起了一些事情就是。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯嗯？",
        "unit_id": 100311,
        "voice": "vo_adv_2013015_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們在哪裡",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "見過面嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "嗯。",
        "unit_id": 106914,
        "voice": "vo_adv_2013015_003"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n僅管妳們幾個大概不記得了就是",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊，",
        "unit_id": 106914,
        "voice": "vo_adv_2013015_004"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "如此一來令人感受到某種命運了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "演員到齊了……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只要能夠跨過這一檻，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我或許就能向前邁進了。",
        "unit_id": 106914
    },
    {
        "type": "background",
        "background": "500783"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "大骨～！",
        "unit_id": 100111,
        "voice": "vo_adv_2013015_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n右邊的敵人就拜託你了，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "左邊就",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "交給我吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "嘎啊！",
        "unit_id": 190711,
        "voice": "vo_adv_2013015_006"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "妳這傢伙一樣，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "也差不多該把老子的名字記起來了吧！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？　",
        "unit_id": 100111,
        "voice": "vo_adv_2013015_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你說也",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "差不多該……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n咦？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們應該是第一次見面的吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "唔喔？　",
        "unit_id": 190711,
        "voice": "vo_adv_2013015_008"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "抱歉，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "講了奇怪的話！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "忘掉它，",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "集中精神在戰鬥上啊！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不不不不，",
        "unit_id": 100111,
        "voice": "vo_adv_2013015_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "忘不掉的啦～♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n只要是有過的羈絆，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就會盡可能不要忘記的呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵。",
        "unit_id": 100311,
        "voice": "vo_adv_2013015_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說的也是呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就像『他』一樣，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖然也有毫無預警就喪失了記憶的時候……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n如果不是如此，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼只要是曾經共築過的回憶",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就絕對不願意輕易失去。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "心與心之間的連結，",
        "unit_id": 100311,
        "voice": "vo_adv_2013015_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "絕不輕易的放手。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剛才的發言我也同意呢。",
        "unit_id": 107011,
        "voice": "vo_adv_2013015_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而那便是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳們所身負的強大。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也是在過去能夠將本應具有決定性實力差距的我們，",
        "unit_id": 107011,
        "voice": "vo_adv_2013015_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所徹底擊倒的理由吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔哇，",
        "unit_id": 100311,
        "voice": "vo_adv_2013015_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嚇我一跳！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n妳，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才是從哪裡冒出來的？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我是不論何時、",
        "unit_id": 107011,
        "voice": "vo_adv_2013015_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "何地都存在著的唷。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並且，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "同時也正在觀察著妳們幾個。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我乃似似花……",
        "unit_id": 107011,
        "voice": "vo_adv_2013015_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n現在",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就讓我和妳們並肩作戰吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "一切如似似花大人所願！",
        "unit_id": 191011,
        "voice": "vo_adv_2013015_017"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我真軌就是粉身碎骨也在所不惜！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是當然。",
        "unit_id": 107011,
        "voice": "vo_adv_2013015_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也還沒有完全恢復，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以你的協助當然是必要的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你就盡情一戰吧，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的『公主騎士』。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "喔喔喔！　",
        "unit_id": 191011,
        "voice": "vo_adv_2013015_019"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "力量不斷湧現出來了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "如此一來我也能盡情使用能力了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "啊啊，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "能感受到似似花大人的愛",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "注入到我的體內了……☆",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請你別用那種會令人感到噁心的表現。",
        "unit_id": 107011,
        "voice": "vo_adv_2013015_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈哈……",
        "unit_id": 100311,
        "voice": "vo_adv_2013015_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "僅管不太明白，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但依舊感謝兩位的拔刀相助。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟是以足以壟罩整個視野的大量魔物為對手，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "戰力能多一名是一名。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣，",
        "unit_id": 100311,
        "voice": "vo_adv_2013015_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如同往常一樣掩護我！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只要身後有妳守望著，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們就不會輸給任何敵人！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯，",
        "unit_id": 100211,
        "voice": "vo_adv_2013015_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果有哪個人受傷了就跟我說，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我會進行治療的！",
        "unit_id": 100211
    }
]