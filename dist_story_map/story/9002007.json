[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唷！",
        "unit_id": 106113,
        "voice": "vo_adv_9002007_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你也來找晶嗎──",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟啊～！",
        "unit_id": 104914,
        "voice": "vo_adv_9002007_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "怎麼了啊弟弟？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難道是……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n太過寂寞想要見到姐姐嗎？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真是的，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就算你不說，姐姐也會去見你的啊～！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "等一下啦靜流姐！",
        "unit_id": 101112,
        "voice": "vo_adv_9002007_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥很困擾啊！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還有，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不要把會長交給妳的食材處理放著不管啊！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還堆積如山耶，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請安心的在廚房工作！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂！",
        "unit_id": 106113,
        "voice": "vo_adv_9002007_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尤其是靜流！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不要用手刀把人砍飛啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然遇到這傢伙是很令人開心，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但他又不是壞人，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不要造成人家麻煩！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "懂了嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對不起，諾維姆。",
        "unit_id": 104914,
        "voice": "vo_adv_9002007_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "聽到弟弟的聲音，我就",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n忍不住失去理智，變成弟弟的姐姐了。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果要講的話，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該是說專心致志呢，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你好，",
        "unit_id": 107011,
        "voice": "vo_adv_9002007_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你正在完成工作賺取薪水吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我所傳授的事情，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若是多少能幫上你的忙，就太好了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這個嘛，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這次我也來委託你工作吧，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你願意接受吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……璃乃、璃乃，",
        "unit_id": 104914,
        "voice": "vo_adv_9002007_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐現在",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "從似似花身上，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n感受到某種大姐姐的味道，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n璃乃",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳身為弟弟的妹妹，覺得怎麼樣呢？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐真擔心啊……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼想都是妳誤會了，",
        "unit_id": 101112,
        "voice": "vo_adv_9002007_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "趕快回去工作。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "謝謝你來送貨！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會長雖然不在，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還是請你在這裡好好放鬆一下唷。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那本書是……",
        "unit_id": 107011,
        "voice": "vo_adv_9002007_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "時機正好呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我有工作要拜託你。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你願意現在",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n為我們製作可麗餅嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "謝謝你。",
        "unit_id": 107011,
        "voice": "vo_adv_9002007_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……就趁現在，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他製作可麗餅的期間，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我們要完成該做的事情唷。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼這本書",
        "unit_id": 101112,
        "voice": "vo_adv_9002007_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是會長說的……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……能用這種方法留下與哥哥之間的重要回憶，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n好開心啊。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……所以說",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳在幹嘛啊？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "靜流姐。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為、因為，",
        "unit_id": 104914,
        "voice": "vo_adv_9002007_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我想要把弟弟製作可麗餅的英姿，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n盡可能地烙印在眼中……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好了，",
        "unit_id": 106113,
        "voice": "vo_adv_9002007_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "專心做這邊的事情啦……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不趕快弄，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙就要做完可麗餅了……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好──的",
        "unit_id": 104914,
        "voice": "vo_adv_9002007_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……諾維姆，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳沒事吧？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "痛嗎？",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我的頭呢，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為是姐姐，所以特別堅固啊。",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個嘛……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "和弟弟之間的回憶",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在這裡像這樣……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個要",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這樣！",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好痛……！",
        "unit_id": 106113,
        "voice": "vo_adv_9002007_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說什麼啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為是姐姐什麼的……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n真是莫名其妙！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "璃乃，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這套衣服是怎麼回事？",
        "unit_id": 106113
    },
    {
        "type": "still",
        "still": "504200201"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是",
        "unit_id": 101112,
        "voice": "vo_adv_9002007_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "和哥哥他們",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在書本世界裡冒險時的回憶！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n在那個一切都十分不可思議的地方，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然很害怕，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "卻有了很棒的邂逅！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "諾維姆的那是……",
        "unit_id": 101112
    },
    {
        "type": "still",
        "still": "505600201"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是大間鎮呢！",
        "unit_id": 106113,
        "voice": "vo_adv_9002007_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和那傢伙、【美食殿堂】",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "以及似似花一起，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n與一隻很大的魚戰鬥了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "非常有趣喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n靜流，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳有什麼樣的回憶嗎？",
        "unit_id": 106113
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個嘛，",
        "unit_id": 104914,
        "voice": "vo_adv_9002007_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我成了黑暗姐姐，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "經過祈禱之後變得更有姐姐之力……",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "總之，",
        "unit_id": 104914
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今年一整年從頭到尾都是弟弟的姐姐唷！",
        "unit_id": 104914
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "謝謝！",
        "unit_id": 101112,
        "voice": "vo_adv_9002007_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚哇。",
        "unit_id": 101112
    },
    {
