[
    {
        "type": "background",
        "background": "500580"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]某天──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n拿掉鼠耳的碧卡拉走在蘭德索爾大街上閒逛時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n碰巧來到了看起來像是在舉辦活動的現場。"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]總、",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_000"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]總覺得氣氛很熱鬧呢……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n小冬，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]你覺得這會是在做什麼呀？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "冬麥斯",
        "words": "[FFFFFFFF]──！",
        "unit_id": 9712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]去看看不就知道，確實啦……",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_001"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n可是那邊感覺大家都是嗨咖耶？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]要是人家闖進那種地方，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]肯定會格格不入啦……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "冬麥斯",
        "words": "[FFFFFFFF]──！",
        "unit_id": 9712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]咦，",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_002"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]人那麼多，反而不會被注意到？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]好像有道理……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那、",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那麼……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]就過去看看好了。",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n畢竟也常聽人說，外出旅遊要放得開……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]大家～！",
        "unit_id": 101611,
        "voice": "vo_adv_5118067_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n玩得嗨不嗨呀～？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]耶～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "觀眾們",
        "words": "[FFFFFFFF]耶～！！",
        "unit_id": 1,
        "voice": "vo_adv_5118067_004"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]嗚噁……",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_005"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]比想像中的嗨咖場面還要更嗨啊……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n這對陰沉角色來說太不同世界了……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]人家開始不舒服了……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]小冬，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我們還是回去吧……？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]趁人家還沒吐出來之前……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "冬麥斯",
        "words": "[FFFFFFFF]──！",
        "unit_id": 9712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]咦，",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_006"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那個在舞台上的人？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n她有什麼地方讓你感到在意……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]那麼，",
        "unit_id": 101611,
        "voice": "vo_adv_5118067_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]就來進入下一個單元吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n閒聊單元結束之後，輪到對戰──",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]不對，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]還是繼續閒聊的單元唷～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "[FFFFFFFF]鈴奈～",
        "unit_id": 1,
        "voice": "vo_adv_5118067_008"
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "[FFFFFFFF]還是要閒聊嗎～？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "觀眾１",
        "words": "[FFFFFFFF]\n已經第三次了耶～？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]呀哈哈，",
        "unit_id": 101611,
        "voice": "vo_adv_5118067_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]沒關係吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]因為人家",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]還有很多話想跟大家聊嘛！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]奇、",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_010"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]奇怪……？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n不知道是不是錯覺……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那個女生，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]一直在偷看後台那邊……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是在確認什麼東西嗎？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]大字報之類的？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]呀喔！？",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_011"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n是、是是是！",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是的，人家就是碧卡──",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]呃、",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]咦……{player}先生？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]{player}表示自己正在幫忙這場活動。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n碧卡拉被一臉慌張的他給叫住後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n便順著其要求移動到了舞台附近的樹蔭下。"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]所、",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_012"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]所以，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那個……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n發生什麼事了嗎？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]根據{player}的說明──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n目前有活動來賓會因為交通狀況而晚到現場，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n現在是鈴奈獨自一人在想辦法撐場面。"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]原、",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_013"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]原來如此……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n所以才會進行三次閒聊單元嗎……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]不、",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]不過……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]為什麼要跟人家說這些事……？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]咦……",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_014"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]咦咦咦咦咦！？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]不不不不行啦，人家辦不到……！！",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_015"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n要跑到那種嗨托邦正中心去，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]人家光是想像就──",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]嗚噁。",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]啊啊，不行，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]身體很明顯地產生了拒絕反應……！",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]雖然平時受到你很多關照，",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_016"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n但頂替別人上台對人家來說，該說責任還是太重大，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]又或者該說過於魯莽……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]總、",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]總而言之人家是辦不到的……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]對不起……！",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]欸？",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_017"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n碧奇的話……？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "冬麥斯",
        "words": "[FFFFFFFF]──！",
        "unit_id": 9711
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是碧奇的話……",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_018"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]就可以辦到……？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]如果是碧奇──",
        "unit_id": 125614,
        "voice": "vo_adv_5118067_019"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]如果是人家的理想，",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]既開朗又活潑的理想陽光角色──",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]如果是碧奇的話──！",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]與此同時，鈴奈正在舞台上開朗地閒聊著，只不過──"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]天啊天啊，",
        "unit_id": 101611,
        "voice": "vo_adv_5118067_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]怎麼辦啦～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n人家已經沒什麼話題好聊了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]腦袋混亂到快爆炸啦！　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]快想想～",
        "unit_id": 101611,
        "voice": "vo_adv_5118067_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]還有什麼可以聊的呀……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]真的得趕快想辦法解決這狀況啊！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n好好的一個活動，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]再這樣下去肯定不行的吧！　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]既然如此，",
        "unit_id": 101611,
        "voice": "vo_adv_5118067_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]要不乾脆開個攝影會？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]或者是握手會？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]啊～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]可是感覺隊伍會排很長！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]畢竟人家得一個人對應所有人！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]討厭啦～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]想得太用力，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]人家的頭痛又要更疼了啦～！　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哈哈！",
        "unit_id": 125611,
        "voice": "vo_adv_5118067_023"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n你們這邊好像在舉辦很好玩的活動啊！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n能不能也讓我參加呢？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]咦？",
        "unit_id": 101611,
        "voice": "vo_adv_5118067_024"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]嗨～♪",
        "unit_id": 125611,
        "voice": "vo_adv_5118067_025"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我是碧奇！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]嗨～♪",
        "unit_id": 101611,
        "voice": "vo_adv_5118067_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]等等，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]誰呀──！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]呃、",
        "unit_id": 101611,
        "voice": "vo_adv_5118067_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]咦？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]秀才",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]的表情看起來在說沒問題……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]也就是說……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]這是來幫忙的人？　",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哈哈！",
        "unit_id": 125611,
        "voice": "vo_adv_5118067_028"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]不認識我也是理所當然的呢！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n不過沒關係，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]只要接下來開始認識我就好囉！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]呀哈～！",
        "unit_id": 101611,
        "voice": "vo_adv_5118067_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]妳說的話也太好玩了吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]那麼，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]立刻就來",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]問問關於妳的各種事吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]各位觀眾，",
        "unit_id": 101611,
        "voice": "vo_adv_5118067_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]事情就是這樣！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]臨時參加的特別來賓",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "[FFFFFFFF]登場囉～！！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]蘭德索爾的大家，",
        "unit_id": 125611,
        "voice": "vo_adv_5118067_031"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]你們好呀！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n我是從東國來的",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]碧奇喔！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n請多指教囉♪",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]在碧卡拉的活躍表現下，活動平安落幕──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n以鈴奈和遲到的來賓為首，活動相關人員"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n都向碧卡拉致上最大的感謝，謝謝她的幫忙。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]之後，這天她的行動獲得口耳相傳，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n碧奇在蘭德索爾內的知名度慢慢提升了──"
    }
