[
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在伊緒於月光學園就任後過了數天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊緒在鈴奈和美咲的班級裡，\n正要開始進行早上的晨會。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天有好消息跟大家報告。",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n有新",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "夥伴加入這個班級。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是轉學生嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "已經決定廢校了，還轉進來，",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "喜好真奇怪呢？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那個轉學生是我的朋友喔。",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n因為他說想要學習，所以我就邀他來了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "大家要和他好好相處喔。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "進來吧。",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦……？",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊～！\n是秀才嘛！",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "轉學生是認識的人，好笑～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我還想不會吧，不過果然真的是你！？",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "話說回來，你也認識鈴奈嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對呀～\n我們可是死黨了。",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是感覺超合拍的那樣？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有認識的人在真是太好了對吧？",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣很快就能適應學校了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和秀才一起學習的話，應該會很開心。",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了，秀才！你來坐人家旁邊！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n如果人家有不懂的地方，教人家～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "等一下，怎麼擅自決定了！",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你要坐在我的旁邊！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "即使對方是鈴奈，\n你也沒什麼可以教人的吧？",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_012"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n就由",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我來教你吧！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "美咲的成績\n和人家也沒差多少吧。",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "反而是人家的成績還稍微好一咪咪。",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n要教秀才的話，應該人家比較適合吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以呢，秀才就坐人家旁邊！ 好，決定了～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "又還沒有決定！\n為什麼要由鈴奈來決定！",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對啊。\n他也很困擾吧。",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這裡就折衷一下，\n",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓他坐在最前面靠近我的位置吧。",
        "unit_id": 101811
    },
    {
        "type": "still",
        "still": "301500201"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為什麼會變那樣！",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_018"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "當然不行！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒錯！\n秀才要坐人家旁邊！",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_019"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以說可不可以別擅自作主？",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯～……你很困擾對吧？",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不趕快決定座位的話，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你也沒辦法坐下來……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣的話，這麼做如何？",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_022"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這傢伙要坐在最了解他的人附近。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這傢伙也還對學校不熟，",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_023"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n有熟悉的人在身邊，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n比較可以安心學習吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "原來如此。真是好主意！",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這是什麼鬼，超好笑～！",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n美咲是天才吧。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那從人家開始喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸，秀才呢～真的是個秀才！",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為他會計算百分比喔？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就算沒有念書，算術也比人家厲害！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這傢伙，可是對我神魂顛倒呢？",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_027"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒辦法，因為我有成熟大人的魅力，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過他真的是很愛慕我！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "他在我動彈不得、",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n很困擾的時候幫了我！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我很",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "感謝他。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嘿～\n小伊緒",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也很厲害嘛。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "鈴奈，妳也不差呀。",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "美咲也很厲害唷。",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_031"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣……\n實在很難作出結論呢。",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_032"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你給我安靜！",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才不要插嘴！",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_034"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總之！你就坐在講台前面！",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_035"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "知道了吧！",
        "unit_id": 101811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那、那人家要坐在旁邊！",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_036"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才座位的左邊！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣的話我要坐你右邊的位子！\n妳有意見嗎！？",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_037"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我沒有……意見呀。",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_038"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯……人家那樣就好唷。",
        "unit_id": 101611,
        "voice": "vo_adv_3015002_039"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……也是。這樣的話就沒問題了。",
        "unit_id": 105011,
        "voice": "vo_adv_3015002_040"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯，就這麼決定！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了～♪\n",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_041"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好，那你坐在講台前面。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，總算解決了♪",
        "unit_id": 101811,
        "voice": "vo_adv_3015002_042"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "那個～我原本坐在講台前面的位置，",
        "unit_id": 1,
        "voice": "vo_adv_3015002_043"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n現在要坐哪裡好呢……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生",
        "words": "這樣我們也得跟著換座位了……",
        "unit_id": 1,
        "voice": "vo_adv_3015002_044"
    },
    {
        "type": "dialogue",
        "name": "伊緒・鈴奈・美咲",
        "words": "…………啊。",
        "unit_id": 1,
        "voice": "vo_adv_3015002_045"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結果整個班級的座位全部都更換了……"
    }
]