[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼～哼哼～♪",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "前進～",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n前往任何地方～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼哼～哼♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥！",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n快點跟上來，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "一個人走很可怕啊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "為什麼",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要稍微保持距離啊？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我不會再使出噗吉全力揮擊了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥可以不用怕啦～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "過來吧過來吧～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們手牽手一起走，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不過，太好了～",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然之前有噗吉陪我，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n但還是會感到不安呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為有人總是",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n叮嚀我說城鎮外面，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n尤其是森林特別危險，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要我不可以接近～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有哥哥陪我一起來，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n感覺可靠多了！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼～哼哼～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「是啊。",
        "unit_id": 2111,
        "voice": "vo_adv_1023002_008"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n你可要好好保護綾音喔，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n{player}小子。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你看，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n噗吉也這麼說！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要乖乖聽噗吉的話喔，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n別看這樣，他可是隻熊呢！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n很可怕喔，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是肉食動物喔♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「喂喂，",
        "unit_id": 2111,
        "voice": "vo_adv_1023002_011"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "別那樣嚇人家啊。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我才不會傷害綾音的朋友，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我可很懂分寸的。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「但是，",
        "unit_id": 2111,
        "voice": "vo_adv_1023002_012"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n{player}小子。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n你為什麼會在森林裡？」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「你可是有點可疑喔。",
        "unit_id": 2111,
        "voice": "vo_adv_1023002_013"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n畢竟這裡，\n可不是能悠悠哉哉散步的地方啊。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就是說啊～",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n城鎮外有魔物到處徘徊耶。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "尤其是這座森林，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n聽說比其他地方更可怕又更危險喔！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "乖孩子可不能接近這裡喔？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我？",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我呀，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n是來採集製藥的材料！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那個啊。",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我是",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "在一個叫做【咲戀育幼院】的地方",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n受人家照顧。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我在那裡交了一個朋友，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n叫做胡桃。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃她，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_019"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "才剛來到育幼院……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n但還不熟悉環境的關係，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以身體不太舒服。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n好像是感冒了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "必須要吃藥。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我現在，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "算是在離家出走……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "沒辦法拿到爸爸媽媽的零用錢，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以沒有錢可以買藥。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_021"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我很擔心胡桃。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n於是偷跑進咲戀媽媽的書房，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n翻了很多書。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "聽說只要蒐集感冒藥的材料再調合，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_022"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就能做出藥來喔♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可以當成材料的植物，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好像就在這座森林裡。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我是來採集那個植物，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "想帶回去的。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然被警告過不能來森林，但我還是來了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽是有說過",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_024"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n胡桃只是感冒了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n只要好好靜養就會好起來……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但我不忍心看胡桃",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_025"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那麼難過的樣子。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為我",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_026"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是比胡桃還大的姐姐呀。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃她，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "和我一樣都是待在育幼院的小孩……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們是家人。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我呀，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "想要珍惜家人。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯？",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_027"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n怎麼了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "難道",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你有什麼意見嗎……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼哼～♪",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n對吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "再多誇獎我！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我是",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "乖孩子對吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "跟你說。",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那個叫做胡桃的女孩子，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "聽說她的爸爸媽媽「消失」了……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n這是咲戀媽媽說的。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我也不太懂那是什麼意思，",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n但是她的家人不見了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以呀。",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_031"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就由我，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n來當胡桃的「姐姐」♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "本末倒……",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯嗯，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "什麼東西？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n別說那麼難懂的詞彙啦！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "難道說",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你在教訓我嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我討厭說教！",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我才沒有做錯！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「喂，",
        "unit_id": 2111,
        "voice": "vo_adv_1023002_035"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "暫時安靜點。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n感覺那邊的樹叢",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n有什麼東西在蠢蠢欲動……」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯？",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_036"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n是什麼啊？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "該不會是……",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_037"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "魔物？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "討厭，好可怕！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "怎麼會？",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_038"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我們明明",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n直到剛才都沒看見任何魔物啊……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "總、總之！",
        "unit_id": 102311,
        "voice": "vo_adv_1023002_039"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n在被發現前快逃吧，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥！",
        "unit_id": 102311
    }
]