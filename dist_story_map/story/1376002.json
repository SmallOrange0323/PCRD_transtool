        "voice": "vo_adv_1376002_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過沒被深究剛剛的力量，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對在下而言倒是好事。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總之，",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在就先順著大家的話吧……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種無視主人，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只把在下當神明的狀況，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是很妥當呢。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位，",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請聽在下一言。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下並非神明大人。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "站在這邊的這位主人",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才是等同於神明的存在，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而在下，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "則是隨從。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "竟然，",
        "unit_id": 511,
        "voice": "vo_adv_1376002_031"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "原來如此！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n那麼",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "神明大人以及……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "這位",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "可以稱作天使大人嗎。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "請聽聽我們的狀況吧！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好意思……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請稍微陪在下演一會戲。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟主人非常重要這件事，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也算是實話……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "我們村子從古早以前，",
        "unit_id": 511,
        "voice": "vo_adv_1376002_033"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n就是在附近的森林裡",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "靠狩獵和採集過生活。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "但是最近",
        "unit_id": 511,
        "voice": "vo_adv_1376002_034"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "森林的狀況不太對勁。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "大量沒見過的魔物住進森林裡，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "我們連靠近都沒辦法靠近。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "要是這種狀態持續下去",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "我們就要餓死了……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大概是因為什麼原因導致魔物狂暴化，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或是來自其他地區的魔物，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才引起了這樣的異常狀態。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但如果對手是魔物，",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "透過公會管理協會，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n提出討伐委託",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是最確實的解決方式……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "不，",
        "unit_id": 1411,
        "voice": "vo_adv_1376002_037"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "那不是普通的魔物。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n我曾經試過一次",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "找自認實力好的村民",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "一起去森林。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "覺得魔物什麼的動手擊退就行了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "然而",
        "unit_id": 1411,
        "voice": "vo_adv_1376002_038"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "結果",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "連打都沒打就跑回來了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "光是看到，身體就在顫抖……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "那個",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "不會是普通的魔物，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "是不能出手的存在。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是普通魔物……？",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_039"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "沒錯，",
        "unit_id": 1411,
        "voice": "vo_adv_1376002_040"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "而且",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "還不只是魔物而已。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n甚至還有大量的村民活靈在徘徊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n光看就覺得是不該存在於世上的光景！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此……",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明白了。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n既然是這樣的話，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請交給在下等人來處理。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "謝謝！",
        "unit_id": 1511,
        "voice": "vo_adv_1376002_042"
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "\n請務必要拯救我們的村子，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "阿姨",
        "words": "拜託了！",
        "unit_id": 1511
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可可蘿和{player}接受了村民的委託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到據說有異常魔物聚集的地帶。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這氣息果然是……",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直以來擔心的問題看來發生了。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔物對人們造成損害的狀況",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有很多形式。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但既然說到村民的活靈，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "恐怕就是……",
        "unit_id": 137611
    },
    {
