        "voice": "vo_adv_1376002_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，為什麼會希望",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人過去呢？",
