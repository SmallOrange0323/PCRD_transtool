[
    {
        "type": "background",
        "background": "501680"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，{player}和可可蘿離開蘭德索爾，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到遠方邊境地帶。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常感謝您",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "陪在下走這一趟。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將父親大人授予的",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「嚮導幼君」的力量",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "進一步提升……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是在下",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "此次的目的。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由於本質上",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是和精靈魔法等類不同的力量，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "亦不曾見過父親大人全力戰鬥。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要確認力量極限，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最好的辦法就是反覆嘗試了。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "反覆使用",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確認當下的感覺，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "直到熟練。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為這是現在",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "提升能力的唯一途徑。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感謝您的關心。",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了成為主人的助力，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下必定",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會練習到運用自如。",
        "unit_id": 137611
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這座森林",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "距離街道有一段距離，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常適合。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "否則一般人目睹訓練的光景，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許會被嚇到。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就立刻開始吧。",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "行使「嚮導老君」之女──",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「嚮導幼君」的權能，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n嘗試「破極創天」的力量吧。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "父親大人",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在七冠等人之中",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "屬於核心存在，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "此為運用其高階權限，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n將領域與法則",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以及整個世界完全破壞，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再重新構築",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的一種……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正所謂禁忌的力量。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "據說過去還是管理者時的厄莉絲，",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會在滿足條件的時候，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了輪迴而將整個世界進行重置。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為原理上",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是相同性質的。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「翻桌子」……",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不愧是主人，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "形容得很巧妙。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下曾聽說創造進行得不順利時，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有時父親大人採取的最後手段，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就是推翻一切。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這項權能，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許就是來源於此。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然，",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將整個世界「翻桌子」這種事，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只有身為長老的父親大人能辦到。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下雖然成長了，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能辦到的",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "規模",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想必還是有限……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前提是能夠將這項權能",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "運用自如才行。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是足以被視為禁忌的力量。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人和我方的幾位",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "千萬不能夠",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被誤捲入其中。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n必須反覆特訓，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "直到能放心安全運用才行。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接下來，",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以「嚮導幼君」之名，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n接引偉大的意志於此──",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「破極創天」！",
        "unit_id": 137611
    },
    {
        "type": "background",
        "background": "501800"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "──看起來如何。",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n依據在下的命令，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "眼前的領域已被破壞",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並重新構築過了。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟、",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱歉，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來是重新構築的過程發生了問題。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這種狀態放著不管",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會出大事……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下立刻修正。",
        "unit_id": 137611
    },
    {
        "type": "background",
        "background": "501820"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次變成一片黑暗的空間……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "必須更明確",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "去想像完成的樣子才行呢。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是草原也不是山，",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而是原本自然的景色……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喝啊！",
        "unit_id": 137611
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總、",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總算是",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "恢復成原本的森林了。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓您見到這麼難看的場面，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是非常抱歉……",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果是父親大人，",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想必能將權能運用得更加自如。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而現在的在下還力有未逮，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來要需要多加鍛鍊。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "啊、",
        "unit_id": 511,
        "voice": "vo_adv_1376002_019"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "啊哇哇哇哇……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n剛、",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "剛剛的魔法……！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道說，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是附近村裡的居民嗎。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "本來以為選了遠離人煙的地方，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是被看見了呢……",
