    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說得也是呢。",
        "unit_id": 137611,
        "voice": "vo_adv_1376002_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎是真的有困擾，",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那就不能裝作沒看見。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請帶路",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到您的村莊吧。",
        "unit_id": 137611
    },
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，可可蘿和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在村民的嚮導下造訪了邊境的村子。"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "大家，",
