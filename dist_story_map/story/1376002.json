    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔術。",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請放心──",
        "unit_id": 137611
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "小、",
        "unit_id": 511,
        "voice": "vo_adv_1376002_022"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "小姑娘……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "不對，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "您、",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "您肯定是神明大人！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n",
