[
    {
        "type": "background",
        "background": "502280"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吉歐‧提格尼亞大夢想樂園園區內。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一字排開的攤販前。"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "起初，",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_000"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我還有點不安。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n但是在貪吃佩可公主所提議的夏日祭典上，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n大家似乎都玩得很盡興呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好的，",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_001"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我也是這麼想，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "所以過來稍作視察。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "聽說，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還有從蘭德索爾遠道而來的攤販呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來，",
        "unit_id": 101811,
        "voice": "vo_adv_9009010_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "感謝購買。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n我會確實地把感想",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也轉述給製作的孩子們知道的～♪",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "哎呀，",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "伊緒。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n妳也來了呀。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳好♪",
        "unit_id": 101811,
        "voice": "vo_adv_9009010_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n前些時候承蒙妳關照了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "祭典，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "舉辦得相當盛大呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是的。",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_005"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n大家齊心協力，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "把活動辦得非常熱鬧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵。",
        "unit_id": 101811,
        "voice": "vo_adv_9009010_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "其實我也想為祭典出一份力，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n所以製作了點心造型的氣球。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在美咲她們的幫助下，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n用魔力讓氣球浮了起來……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "萊拉耶爾，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳也拿一個吧♪",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "謝謝妳，",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_007"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "伊緒。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n真是輕飄飄的",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "可愛氣球啊。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就像吉歐‧提格尼亞",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "的雲朵一樣。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101811,
        "voice": "vo_adv_9009010_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "聽到妳這麼說真是開心呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對了，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有幾種不同的氣球，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "請再多拿幾個吧～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "飄起來是很平常的事……",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_009"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "看來，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "並不是這樣呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n高度",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好像一點一點地",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "在上升……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這應該",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不是我的錯覺……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_010"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "好神奇啊……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是這個氣球的關係嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也許是我的學生們",
        "unit_id": 101811,
        "voice": "vo_adv_9009010_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "弄錯了製作方法。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "她們總是",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "會犯一些很有創意的錯誤呢♪",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不過，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣子很危險……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我得把氣球回收才行。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_012"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "的確……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "從這些氣球上",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "能隱約地",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "感覺到魔力。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不過。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還滿",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "有意思的……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我可以留著這些氣球嗎？",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_013"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n呵呵，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不靠自己的力量而飄浮起來，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還真是神奇呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯，",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_014"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "看起來是這樣呢，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n不過沒關係的。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n從高處",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "可以很清楚地",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "看到夏日祭典的情形呢。",
        "unit_id": 126511
    },
    {
        "type": "background",
        "background": "502040"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "再讓我多享受一下",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_015"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "空中散步……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不對，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是視察的",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "樂趣。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦、",
        "unit_id": 101811,
        "voice": "vo_adv_9009010_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦咦！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真、",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的不要緊嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n要是突然颳起大風的話……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "哎呀，",
        "unit_id": 126511,
        "voice": "vo_adv_9009010_017"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "才剛提到──",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就來了一陣強風……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "之後，為了追上被風吹跑的萊拉耶爾，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和伊緒最終"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n跑了很長的一段距離。"
    }
]