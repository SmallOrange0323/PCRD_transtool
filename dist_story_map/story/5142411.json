[
    {
        "type": "background",
        "background": "500881"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "終わってしまいましたね、",
        "unit_id": 127911,
        "voice": "vo_adv_5132411_000"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "クリスマス。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "こうして撤収作業を見てると、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "いっそう実感させられます……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "でも、",
        "unit_id": 127911,
        "voice": "vo_adv_5132411_001"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "こんなに寂しく思えるのは、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "それだけ楽しかったという証ですよね！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "そうですね。",
        "unit_id": 6111,
        "voice": "vo_adv_5132411_002"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "私もトラブルを前に",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "右往左往するクレジッタさまを",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\nたくさん見ることができ、",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "とても満足しました。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "その歪んだ愉悦は心の中にしまっておきなさい！",
        "unit_id": 128011,
        "voice": "vo_adv_5132411_003"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "でもまあ、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "たしかにクリスマスのたった一日のために",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n必死に準備してきたのですから、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "やはり寂しさはありますわね。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "──本当にそれだけでしょうか。",
        "unit_id": 6111,
        "voice": "vo_adv_5132411_004"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "何か言いまして？　",
        "unit_id": 128011,
        "voice": "vo_adv_5132411_005"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "秘書１号。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "いいえ、",
        "unit_id": 6111,
        "voice": "vo_adv_5132411_006"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "何も。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "……秘書１号の減らず口は後で塞ぐとして。",
        "unit_id": 128011,
        "voice": "vo_adv_5132411_007"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下が寂しい思いをされているのは由々しき事態。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nというわけで",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下にはこの後少しお付き合い願いますわ。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "え、",
        "unit_id": 127911,
        "voice": "vo_adv_5132411_008"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "いいですけど、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "いったい何を……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "今回協力していただいた方を招いて打ち上げですわ！",
        "unit_id": 128011,
        "voice": "vo_adv_5132411_009"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\nしんみりいい話で終わるのもアリですが、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "陛下にはやはり",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "笑顔でいてもらいませんと！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "クレジッタさまのポケットマネーですので、",
        "unit_id": 6111,
        "voice": "vo_adv_5132411_010"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "どうぞ好きなだけ",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "飲み食いしてください。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "ふん、",
        "unit_id": 128011,
        "voice": "vo_adv_5132411_011"
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "そんな言葉でわたくしが慌てると思いまして？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "お金なんて使ってなんぼ、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "クレジッタ",
        "words": "使ったらまた稼げばいいだけですわ！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "……えへへ、",
        "unit_id": 127911,
        "voice": "vo_adv_5132411_012"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "結局最初から最後まで、",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\nクレジッタさんに頼りっぱなしですね。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "それならお言葉に甘えて、",
        "unit_id": 127911,
        "voice": "vo_adv_5132411_013"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "いっぱい楽しませてもらいます☆",
        "unit_id": 127911
    }
]