[
    {
        "type": "dialogue",
        "name": "紡希、千歌",
        "words": "……☆\n……♪",
        "unit_id": 1,
        "voice": "vo_adv_5110322_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不會吧，",
        "unit_id": 124811,
        "voice": "vo_adv_5110322_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌和紡希",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼會在這種地方……",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "冷靜點，望。",
        "unit_id": 124911,
        "voice": "vo_adv_5110322_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳看，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只要仔細觀察，就會知道她們是假的，沒錯吧？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……真的耶。",
        "unit_id": 124811,
        "voice": "vo_adv_5110322_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為之前發生的事，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我好像變得有點緊張兮兮的。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 125014,
        "voice": "vo_adv_5110322_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算是冒牌貨，",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "外觀看起來還是妳的夥伴吧？",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡可以交給我來應付喔？",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……不，",
        "unit_id": 124811,
        "voice": "vo_adv_5110322_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒有關係。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "或者應該說，讓我一起參戰吧。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌和紡希已經夠倒楣了，",
        "unit_id": 124811,
        "voice": "vo_adv_5110322_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "竟然還做出她們的冒牌貨？",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "開什麼玩笑！",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們上吧，",
        "unit_id": 124811,
        "voice": "vo_adv_5110322_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘉夜、",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "矛依未！",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我要讓它瞧瞧",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "偶像生起氣來的可怕模樣！",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好、",
        "unit_id": 125014,
        "voice": "vo_adv_5110322_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好喔……",
        "unit_id": 125014
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯～",
        "unit_id": 124911,
        "voice": "vo_adv_5110322_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "看來像她這類型的人被激怒，或許才是最可怕的。",
        "unit_id": 124911
    }
]