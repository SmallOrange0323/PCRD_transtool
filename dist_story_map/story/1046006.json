        "words": "！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "惡德伊",
        "words": "\n你這小子不要妨礙我！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵，喵，",
