    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈，大收獲喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n是惡德伊商會靠惡劣手段所存的錢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "將這些發送出去的話，不僅能讓惡德伊嚐到苦頭，",
        "unit_id": 104611,
        "voice": "vo_adv_1046006_060"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n也能讓城鎮裡的大家開心喵！ ",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以，發送……",
