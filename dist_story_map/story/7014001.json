    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "保護了我……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "太好了……！",
        "unit_id": 103411,
        "voice": "vo_adv_7014001_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n妳平安無事就好。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這種時候",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "互相幫助是很重要的，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "請妳不要太在意喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這、",
        "unit_id": 105011,
        "voice": "vo_adv_7014001_028"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這麼說好像也是呢！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……優花梨小姐，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "妳果然很厲害。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "遇到突如其來的魔物攻擊，不僅迅速反應保護了我，",
        "unit_id": 105011,
        "voice": "vo_adv_7014001_029"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n還一擊就打倒魔物……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這就是還兼具了強大韌性的",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "了不起的淑女吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，",
        "unit_id": 103411,
        "voice": "vo_adv_7014001_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不過",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那並不是因為我特別強喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而是因為我想到美咲有危險，",
        "unit_id": 103411,
        "voice": "vo_adv_7014001_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以才發揮出比平常更強大的力量。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這一定就是那種危急時刻所使出的蠻荒之力",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "之類的吧，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "比起這個，",
        "unit_id": 103411,
        "voice": "vo_adv_7014001_032"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我們先繼續往前進吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "如果繼續慢慢來，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可能又會遭受魔物的攻擊也說不定。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯，",
        "unit_id": 105011,
        "voice": "vo_adv_7014001_033"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我知道了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……我一定要向優花梨小姐",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "再多學習一些東西才行。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美咲以炙熱的眼神看著優花梨。"
    }
]