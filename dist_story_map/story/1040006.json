[
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "午安，{player}！",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個……關於BB團的活動，今天做什麼好呢……？",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不過，今天有一件事情令我很在意……",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還好。只是有點在意而已……",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今天早上，森林入口的某棵大樹倒下了。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那棵樹會倒下，",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n有可能是某個部分的結界損壞了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，那個，在這個森林和人類的城鎮，",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n佈有讓魔物們十分討厭的結界。如果結界被破壞，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "魔物就會出現在森林和城鎮……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……？剛才的是魔物的叫聲……是從哪裡傳出來的……？",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_005"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_006"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀，{player}！",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你、你竟然為了保護我……",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n背部受到攻擊了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你說你沒事……？",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但、但你看上去不太好啊！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}，對方又攻過來了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我、我也要戰鬥！\n",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然對手看起來很強，但兩人聯手的話……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是……！",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚……",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "碧急忙往{player}身後跑。\n正當{player}想著，碧應該順利逃掉了的時候……"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不！",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_014"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我不會丟下你，自己一個人逃跑的！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我只是退到方便射箭的距離而已！ ",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_015"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我最重視的BB團和…… ",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n{player}，必須由我來守護！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "現在要……擊敗對方才行！",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_016"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n使用特殊的箭……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼……",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_017"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "看招……！",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_018"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "退魔之箭！",
        "unit_id": 104011
    },
    {
        "type": "background",
        "background": "500190"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "太好了，",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_019"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "射中了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怎麼樣……",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_020"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我做到了吧……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇、",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_021"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哇啊，完全沒有用啊……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呀！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n牠、牠朝這邊衝過來了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗚……！請等一下……那個地方是！",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_022"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對了！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "{player}！\n請按下那邊的開關！",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_023"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "……？",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "剛才按的就是之前在BB團的特訓時使用過的，",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_024"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n「突破極限交朋友的絕命賽」的開關！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n只要一按，木樁就會飛過來……！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "木樁直接打中魔物，並將牠打落深淵了……"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼、",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_025"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼、好不容易……打贏了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊，{player}……",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_026"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n謝、謝謝你……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊哈哈……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "腳還在發抖……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哆哆嗦嗦的……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……你是BB團的團長……",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_027"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n如果你不在的話，就再也交不到朋友了……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請答應我你不會消失不見…… ",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_028"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n就算我因為你的保護而獲救， ",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我、也不會很開心……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "好的！因為BB團是……",
        "unit_id": 104011,
        "voice": "vo_adv_1040006_029"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "永垂不朽的！",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和碧\n兩人相視而笑……"
    }
]