[
    {
        "type": "background",
        "background": "501610"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那是在接近要回到蘭德索爾的日子裡──某個下午所發生的事。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "開心的假期",
        "unit_id": 122511,
        "voice": "vo_adv_1225004_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也要結束了嗎。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總覺得還玩不夠呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在度假村該做什麼才好……",
        "unit_id": 122511,
        "voice": "vo_adv_1225004_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還真是懷念當初為此而煩惱的時候呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話說回來，",
        "unit_id": 122511,
        "voice": "vo_adv_1225004_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天天氣真好呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "放眼望去都是一望無際的藍天……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓人感覺……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太過耀眼",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "了……",
        "unit_id": 122511
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有了。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總算找到你了。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真沒想到",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡會是這樣的人山人海。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我好像有點太小看夏天的海邊了。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼了？",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你那樣盯著我看，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也還是會害羞的……",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是、",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是這樣……",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗎？",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那還真是……",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "多謝誇獎。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "選這件真是選對了呢。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你今天邀請我。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n感覺可以好好放鬆轉換心情呢。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "最近因為在忙要學習的事還有重要的事。",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這之間的空檔",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "又被帶著到處打招呼或是去露臉。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "忙到連停下來喘口氣的時間都沒有，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是卻完全索然無味的日子。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可是，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在那樣乏味無趣的夏日行程裡，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n能有一天放鬆滋潤一下也不錯吧？",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這也是多虧了……",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你邀請我來海邊的關係吧。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n為了遵守今天的約定，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺自己比平常還來得更努力。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "連我都覺得自己有點太現實了。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好了，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不開心的話題就到此為止。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好不容易來到海邊，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "得要盡情享受才行呢。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說起來，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我剛剛好像有在對面那邊看到攤販。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我說，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們一起去吃剉冰吧。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼？",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我會吃剉冰有這麼讓人意外──",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "抱歉在您玩得正開心時打擾。",
        "unit_id": 1,
        "voice": "vo_adv_1225004_014"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "怜小姐。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……是父親的僕人嗎。",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有什麼事？",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我應該說過今天有其他安排了吧。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但是，",
        "unit_id": 1,
        "voice": "vo_adv_1225004_016"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "老爺希望您回去。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n所以吩咐我來接您。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很抱歉，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我已經先跟朋友有約了。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "父親對此故意增加的作業和要事，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也都處理好了。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣子，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有什麼問題──",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "詳細情況我並沒有詢問。",
        "unit_id": 1,
        "voice": "vo_adv_1225004_018"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n但是，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "如果您在意您的朋友，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n還請您跟我一同回去。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣……",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是在威脅我嗎？",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "還請您做出明智的決定。",
        "unit_id": 1,
        "voice": "vo_adv_1225004_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是現在",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不遵從父親的命令，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就會給他造成麻煩，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是這個意思嗎。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果反抗後只有我一人要負責倒是還好。",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n可是，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要避免危害到他才行。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我知道了。",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要去哪裡就去吧。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "{player}，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的很抱歉。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來今天的約定……",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我是無法遵守了……",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這次失約我一定會補償你的。",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……抱歉。",
        "unit_id": 122531
    },
    {
        "type": "background",
        "background": "510352"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當天晚上──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}接到了怜的聯絡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於是到了車站前等候。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在這個時間還願意過來。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天因為我的關係讓你跑來跑去的，很抱歉。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "事情剛剛處理完了喔。",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……沒什麼重要的事，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是有高層要來視察和聚會，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以帶我去露個臉罷了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "「令嬡真是亭亭玉立啊」……",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼的，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "盡是那種老掉牙的社交辭令，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和阿諛奉承的對話。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那些只能諂笑的無趣時間，到底該怎麼打發掉呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "像那樣的場合，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我去不去都沒有差別。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n儘管那樣，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "父親卻還是硬要我同行……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就只是為了他的面子而已。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對於不聽自己的話、舉止輕浮的放蕩女兒，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他就算是用項圈也想把人拴著吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……實際上，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果只牽扯到我一個人的話也是可以無視掉。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是在我出門之前告知，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就可以和{player}調整這次出門的目的地，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n或是把約定改到其他天去。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明可以這樣子做，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "卻故意等我們抵達海邊……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "特地展示出",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他隨時有辦法把我帶回去這件事。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n然後……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再藉由奪去我的快樂，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想順勢讓我屈服也說不定。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……如果是這樣，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那他還真是非常成功呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "心裡越是抱持著希望而滿懷期盼，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "被破壞時就越是絕望痛苦。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……謝謝你。",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼說都有點難呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從這裡去海邊的話，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "回來就已經是大半夜了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那個時間點還在外遊蕩的話，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會被父親的人阻止吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難得你特地邀請我。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這可不行。",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟我可是背叛了滿心期待的你啊。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也是，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不知道心裡有多麼地期待……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這樣啊。",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也很期待嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n對於今天",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要和他去海邊的這件事。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以才把少少的空檔時間湊起來，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n連泳裝",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也買了新的。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不知道該買哪一件才好，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為此而煩惱、",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "挑選著……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "然後被你誇說很適合。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "光是那一句話，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我就覺得至今為止的努力都有了回報。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果會變成這樣……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那麼說不定打從一開始，就沒有獲得任何東西還比較好。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只要沒有期望……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就不會感覺到",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "自己心中的渴望了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊哈哈……",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你都特地過來了，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我還這樣一臉陰沉的話，會讓你擔心吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……嗯，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是還有下次的話，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n去山上說不定也不錯呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今年夏天看來是已經沒辦法去了呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就像我剛剛說的，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我只能擠出今天這一天了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n為了今天，我已經把其他的空閒時間都減少掉了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "況且，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在可以去的地方什麼的……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不對……",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不只限海邊也沒關係嗎……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣的話，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我好像有想到一個地方。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不好意思，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我稍微離開一下。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不管怎麼樣，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "失敗了頂多也就跟原本一樣。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很值得一試。",
        "unit_id": 100331
    },
    {
        "type": "background",
        "background": "510302"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "士條同學，",
        "unit_id": 1,
        "voice": "vo_adv_1225004_048"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "妳來了啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n那麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "這一位……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "就是妳說的那位朋友吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是的。",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這次這麼突然地拜託妳，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n妳還願意答應我，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的很謝謝妳。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "別這麼說。",
        "unit_id": 1,
        "voice": "vo_adv_1225004_050"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n我平時在校也受到妳很多幫助。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n若能稍微報答妳就太好了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "不過，",
        "unit_id": 1,
        "voice": "vo_adv_1225004_051"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "沒想到士條同學會有事拜託我。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n……這件事我會藏在心裡的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "妳就放心吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "我已經交代好了，",
        "unit_id": 1,
        "voice": "vo_adv_1225004_052"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "請拿著這個貴賓證。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n那麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "我就先告辭了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……下次，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_053"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我要好好跟她道謝才行。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比起這個，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你有把我說的東西都帶來了嗎？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 100331,
        "voice": "vo_adv_1225004_054"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們就先分頭行動。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "待會再會合吧。",
        "unit_id": 100331
    },
    {
        "type": "still",
        "still": "122500401"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是飯店附設的泳池。",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_055"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我拜託班上的同學，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "請她特別幫我們包場。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "飯店老闆女兒的直接請託，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_056"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他們也不能隨便敷衍了事吧。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也多虧這樣，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們才能來使用這座泳池。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_057"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該怎麼說……",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡的氛圍真是獨特呢。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "跟海邊或水上樂園都不同，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個……",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我、",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_058"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也是第一次，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來到這種地方。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就算有點緊張也不奇怪對吧？",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也是動作有點僵硬不是嗎？",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_059"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "跟充滿一堆陌生人的海邊相比，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這裡要安全得多了呢。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有警衛在巡邏。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "更重要的是，比起父親的所作所為，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_060"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我這點程度的任性是可以被允許的吧。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊哈哈，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "心情感覺有點舒暢呢。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_061"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我還真沒想到自己會在一天內，\n穿上同一件泳裝兩次。",
        "unit_id": 122531
    },
    {
        "type": "still",
        "still": "122500402"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……其實",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_062"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我當時已經放棄了。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在海邊的那時候。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我之前應該也有跟你說過……",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_063"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我父親是很嚴厲的人。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我只被允許行進在父親鋪設好的軌道上。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天的事也是這樣。",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_064"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒有辦法遵守和你的約定，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n而認為是無可奈何的犧牲……",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n於是當下一個勁地覺得",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "自己只能忍下來。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_065"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你邀請了我對吧？",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你跟我說，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在就去海邊。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那一句話，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_066"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對我而言……",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然這麼說可能有點誇張，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但是卻拯救了我。",
        "unit_id": 122531
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "122500401"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明我應該會選擇不要放棄的，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_067"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n可是在不知不覺間，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我卻想要放棄眼前的東西。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是你，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓我注意到了這點。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的夏天",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_068"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就在此時此刻。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不會再放開手了。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n──不會再放開，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和你一起找回的這個夏天。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……說起來，",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_069"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今年還沒有吃到呢。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說吃什麼……",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_070"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說到夏天，",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當然就是剉冰啊。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n畢竟我們在海邊的時候沒有吃到嘛。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我",
        "unit_id": 122531,
        "voice": "vo_adv_1225004_071"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很喜歡喔。",
        "unit_id": 122531
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "藍色夏威夷口味的。",
        "unit_id": 122531
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1225004_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剉冰好吃嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_1225004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怜居然會拜託人，還真是讓人意外呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看來她和你在一起的時候，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可能也多少有點改變了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只能依靠自己。",
        "unit_id": 190011,
        "voice": "vo_adv_1225004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對於在那樣的世界裡一路生活過來的怜來說，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n和他人接觸時的態度",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就像是保護自己的殼一樣。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如同珍珠一般，",
        "unit_id": 190011,
        "voice": "vo_adv_1225004_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "用厚厚的硬殼將自己包裹起來……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n再把自己體內小小的珠核",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "養成大大的結晶。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但那樣子，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是要一直將自己隱身在海裡、很辛苦的生活方式。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對怜來說，",
        "unit_id": 190011,
        "voice": "vo_adv_1225004_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你是少數不需要隔著殼",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "面對的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可能是唯一的一個人吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n有一個這樣的人存在，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會是多麼大的救贖呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以，",
        "unit_id": 190011,
        "voice": "vo_adv_1225004_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在那個孩子不再需要殼之前，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就請你陪在她的身邊吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1225004_078"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見啦。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501610"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我……",
        "unit_id": 122511,
        "voice": "vo_adv_1225004_079"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是睡著了嗎。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我記得本來是要決定今天的行程……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我問你，",
        "unit_id": 122511,
        "voice": "vo_adv_1225004_080"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這次的度假……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n和我一起有開心嗎？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我覺得",
        "unit_id": 122511,
        "voice": "vo_adv_1225004_081"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "非常開心喔。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和你一起在度假村到處玩、",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在海邊跌倒……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n以及海上揮劍過招，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有那天晚上看到的煙火。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只要一閉上眼，",
        "unit_id": 122511,
        "voice": "vo_adv_1225004_082"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就會馬上浮現在我的腦海裡。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這些回憶，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我肯定會無數次地",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在腦中回想。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 122511,
        "voice": "vo_adv_1225004_083"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然淨是些我想都想不到的事呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣或許也很好吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為你看，",
        "unit_id": 122511,
        "voice": "vo_adv_1225004_084"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比起和大家一樣的慣例行程，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "度過一個只屬於我們的夏天，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺會更加記憶深刻吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了，",
        "unit_id": 122511,
        "voice": "vo_adv_1225004_085"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想到了一件事。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們今天試著不安排行程，直接出發怎麼樣？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一起走在路上、",
        "unit_id": 122511,
        "voice": "vo_adv_1225004_086"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看著相同的東西……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "去尋找符合我們兩人風格的度假方式吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "大口吸入藍天下的澄澈空氣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n怜跟{player}談起了今天的安排。"
    }
]