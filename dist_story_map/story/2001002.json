[
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下開動了。",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還請",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "慢用唷～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是抱歉呀，還得讓你們在移動中吃飯。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在準備馬車的這件事上，耗費太多的時間……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n弄到最後，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不得不匆匆忙忙的上路了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "貌似這陣子，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "附近有一點不太安穩呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以決定在短期間內，往附近城鎮避難的人也有不少，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "導致連台馬車也難求的狀況。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是不行呢～",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "安排的不夠周全……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明明大小姐就常常叮嚀著我說，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n『先做好萬全準備，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "再開始行動。』了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟是要搬家嘛，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有輛馬車是必須的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人與在下也並沒有其他的預定，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就算得多花上一點時間，也不會有什麼困擾。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哈哈。",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "多給妳們添麻煩的這事兒，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在這次工作結束前，都會包吃包住來補償給妳們的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以請放心，多吃一點吧～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請用請用，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不用客氣唷。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是我特地早起做的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還有三明治唷♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有勞您了。",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真是抱歉，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沾了主人的光。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人與在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所持有的盧幣所剩已不多……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可說是得餐風宿雨，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不為過的情況。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯嗯。",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "才會像那樣找工作做對吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣不行唷～{player}。",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你可是人家的哥哥呢，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不再振作一點可不行。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓妹妹能夠好好地溫飽，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可是做哥哥的義務喔？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是，",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不是主人的妹妹。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個三明治，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像有股獨特的味道呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我雖然是個女僕，但其實不太擅長料理呀，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難不成不合妳們的胃口嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有這回事。",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還不太習慣這地方的調味方式而已。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嚼嚼♪",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "他也正津津有味地吃著呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如、",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果真的不好吃，不用勉強自己吃下去唷？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "只是距離目的地的宅邸，還有約半天以上的行程。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果可以的話，還是填飽一點肚子會比較好呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這麼說來！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有一個能讓料理，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "變得更好吃的小咒語唷～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "先像這樣兩手，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比出愛心的形狀……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n嘿呀，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "變得更好吃吧☆",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼特殊的魔法嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒有唷，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就只是個小咒語。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然大概是心理作用，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但應該會稍微變好吃一點的唷♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哈……",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就只是心理作用而已嗎……",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "200100201"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦呀，",
        "unit_id": 105911,
        "voice": "vo_adv_2001002_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下吃到一半的三明治，竟失去了蹤影。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是您把它吃掉了嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}。\n還有很多三明治，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n怎麼可以搶走別人的呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不是{player}吃掉的嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那這麼說來，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難不成是我的小咒語有類似破壞光線的威力。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n竟能把三明治，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "轟到化成灰去了？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嚼嚼，",
        "unit_id": 106112,
        "voice": "vo_adv_2001002_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嚼嚼嚼。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……嗯？",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哦呀？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有個女孩子喔？",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n看起來在伸手",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "偷拿走三明治的樣子呢……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個～……？",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n您好～，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請問您是哪位呢？",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呣咕！？",
        "unit_id": 106112,
        "voice": "vo_adv_2001002_032"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n咳咳，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咳咳咳！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "發生什麼事了嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n空箱裡……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難不成，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有偷渡客嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "與其說偷渡客，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還是該說是坐霸王車呢……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n嗯～，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真讓人困擾呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該怎麼辦呢……",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在租借馬車時所簽的契約上，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n有寫到不能承載超過一開始申請的人數呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣，還得再多繳一份額外的費用呀。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看起來又還只是個小朋友。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就這樣把她扔出車外，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好像也挺可憐的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……那個呀，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "小妹妹？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你躲在那裡面，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是想要做什麼呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "人、",
        "unit_id": 106112,
        "voice": "vo_adv_2001002_038"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "人家才不小啦！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "人家，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "才一點都不小喔！？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼看都很小隻呢……",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個呀，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "坐霸王車是不對的唷。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我們不會對妳做什麼的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可以把妳的情形告訴我們嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳應該是離家出走的吧。",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_040"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "年紀看起來跟小綾音差不多小……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n像妳這樣的小孩子也不可能是一個人出來旅行嘛。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該怎麼辦才好呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所、",
        "unit_id": 106112,
        "voice": "vo_adv_2001002_041"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以我說！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n別一直說人家小呀～！？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯嗯？\n啊！",
        "unit_id": 106112,
        "voice": "vo_adv_2001002_042"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳這傢伙！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我可認得妳喔！　",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "之前在哪裡有見上過一面！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯？",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳說和鈴莓嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃……",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_044"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但妳不是【咲戀育幼院】的孩子吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "應該不是吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那個啊，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳是不是把我和誰搞混了呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對對對，",
        "unit_id": 106112,
        "voice": "vo_adv_2001002_045"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "鈴莓！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n就是那個名字！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n狹路相逢，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看來也是天注……！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂！",
        "unit_id": 106112,
        "voice": "vo_adv_2001002_046"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妳這傢伙，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "記得我嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃～……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哇哇，",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請不要那樣搖人家啊！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可不能在車上這麼亂晃呀，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不小心馬車可是會翻的唷！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯嗯？",
        "unit_id": 106112,
        "voice": "vo_adv_2001002_049"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂喂喂？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "沒搞錯吧，",
        "unit_id": 106112,
        "voice": "vo_adv_2001002_050"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是你！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n在叫你啦，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你在這鬼地方幹什麼呀？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不論在哪都完全找不著你的蹤跡，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可讓人多操心呀～！？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_2001002_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難不成妳也和主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "認識嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知道為什麼總是到處和女孩子有所相識呢……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "閃邊，",
        "unit_id": 106112,
        "voice": "vo_adv_2001002_052"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我不認識妳！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n礙事啦！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "比起這個，",
        "unit_id": 106112,
        "voice": "vo_adv_2001002_053"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "重要的是你啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這些日子以來，你在哪裡做了些什麼事啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我找你可找很久了呀～公主騎士……！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "【公主騎士】？",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_054"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是【公主騎士】的相關人士嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也是所屬於",
        "unit_id": 102511,
        "voice": "vo_adv_2001002_055"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "【公主騎士】旗下的公會，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n【咲戀育幼院】的人就是了……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該不會",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是和這有什麼關係，所以在哪裡見過面嗎？",
        "unit_id": 102511
    }
]