    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "要不要再像這樣",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "一起出來走走？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "看著正在努力著的你，",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_062"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "讓我也覺得",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "自己要更努力呢！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你真的",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_063"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n是個非～常了不起又努力的人呢！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯嗯，",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_064"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你可以對此深深感到自豪喔。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我也要和你看齊才行。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "做出很厲害的事情自然會想讓人誇獎呀。",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_065"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "就算再多稱讚你一些",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也不為過呢。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我也要",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_066"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n以成為像你一樣",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "了不起又努力的人為目標！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "為此，",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_067"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "也得先治好妳路痴的毛病才行呢～",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真是的！",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_068"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n不要偏偏挑在這種時候出現嘛！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "帕克壞心眼！",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_069"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n你這呆瓜！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "三人的笑聲回響在公園之中。"
    }
