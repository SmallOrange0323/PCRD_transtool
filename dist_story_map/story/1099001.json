    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "午後的蘭德索爾街上，\n有名四處東張西望的銀髮少女。"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呃……",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_000"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "剛剛在這裡右轉……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咦？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "走到和剛才不一樣的地方了？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_001"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "先回去剛才的地方……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "等等，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "剛才是從哪裡來的……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯～",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_002"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "到底是哪裡呢？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我是",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "右撇子，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "感覺應該會選右邊……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可是",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這如果不問剛才的我，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n又沒自信能確定",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真的是這樣……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咦？",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_004"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "啊、{player}！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "居然在這種地方碰到，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真是非～常巧呢。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "{player}才是，",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_005"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n在這種地方做什麼……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "啊，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我知道了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你迷路了呢。",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_006"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "所以，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你因為不安",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "才來和我搭話的對吧。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──喂喂，莉雅。",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那怎麼可能啊，",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "別說那種奇怪的話了。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "唔，",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_008"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "帕克！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n你說奇怪的話是什麼意思？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "還有什麼意思，",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_009"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n這個人",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "是在擔心形跡可疑的莉雅。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "所以才會來跟妳搭話的，這還用說嗎。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我、",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_010"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我才沒有形跡可疑呢！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "只是",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "稍微有點",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "迷路而已。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "只是稍微有點",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_011"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "分不清東西南北而已。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "她逞強的樣子很可愛對吧，",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_012"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "我的女兒。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "你不這麼認為嗎？",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "帕克！",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_013"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "是是，別生氣別生氣。",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_014"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "再說，",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "這還不是莉雅的錯。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "妳不是要證明偶爾不依賴我，",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_015"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n也能自己一個人好好振作嗎？",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "然而，",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_016"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n我看著卻一直覺得忐忑不安。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "因為",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_017"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "來這裡有一段時間了呀，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我想",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也不能總是",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "依靠帕克和拉姆她們……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "這想法是很了不起，",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_018"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "但是太危險了。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "不過，",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "這個嘛……",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "啊，",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "我想到好主意了。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "我說你。",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_019"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n現在有時間嗎？",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "可以陪一下莉雅嗎？",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "等等，",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_020"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "帕克真是的，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n你不可以麻煩{player}啦。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "這是折衷方案啊，",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_021"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "折衷方案。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "莉雅今天也不想依賴我吧？",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n既然如此，",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "只能拜託這個人了不是嗎？",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯～",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_022"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n可是，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那樣子感覺",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不會有點狡猾嗎……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "別在意別在意。",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_023"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "那麼，",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "你的意思如何呢？",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "願意接受嗎？",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "妳看，",
        "unit_id": 2611,
        "voice": "vo_adv_1099001_024"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "這個人是好人啊。",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "那",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "莉雅就拜託你了～♪",
        "unit_id": 2611
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真是的，",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_025"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n帕克真是想說什麼就說什麼……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "對不起，",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_026"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "把你給捲進來了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "你如果有其他事情的話，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不用在意我沒關係……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是嗎？",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_027"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "真的沒有其他事情嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n這樣啊……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那我就不客氣地麻煩你囉。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "其實",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_028"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "一個人走路有點寂寞，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我也開始想要找個人陪我說話了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "事情就是這樣。",
        "unit_id": 109911,
        "voice": "vo_adv_1099001_029"
    },
    {
        "type": "dialogue",
