[
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被怜約出來的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了車站附近的鬧區與她會合。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗨，",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉啊。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是我約你出來的，讓你久等了吧？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是嗎？",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就好。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天把你約出來是因為……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也收到了吧？",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是mimi發送的這個通知。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n今天是我和你在阿斯特朗傳奇裡相遇的紀念日。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以，我想說可以和你聊聊。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺從那以後已經過了很久了。",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛認識的時候，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的態度也不是很好……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓我道歉吧。",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的很抱歉。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n當時的我",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "身心都還不夠成熟……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我曾經以為自己只要有優衣和日和就夠了。",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我好像錯了。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在我就明白了。",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n遇見許多人，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "經歷過許多事，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "造就了現在的我。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就像你為我所做的一樣",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喔。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我之所以能比當時更有所成長，",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n多虧了在阿斯特朗傳奇中的經驗……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不對，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是多虧遇見了",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不曉得是不是因為精神層面多了一些餘裕。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n感覺自己最近在學校裡的表現也不錯呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在回想起來，",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當初開始玩阿斯特朗傳奇，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n大概是想要逃避現實吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而現在，",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和大家……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有你所在的那個地方，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n對我來說是無可取代的。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這一切",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "肯定是因為有你在。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我想",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再一次感謝你。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總覺得",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這麼鄭重地互相道謝",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n有點難為情呢。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓我上了一課。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和你待在一起時，",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我覺得甚至能認識一個",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n從未意識到的嶄新自己。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就像這樣。如果對你來說，",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也能是這樣的存在，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我會很高興的。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為此，",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們有必要更加了解彼此。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "下次一起去釣魚吧。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "釣魚就像是人生的縮影……",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "肩並肩一起放下釣魚線，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們應該就能更了解彼此。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論是海釣",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是溪釣……",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n當然，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要在阿斯特朗傳奇裡釣也可以。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "去任何你想去的地方吧。",
        "unit_id": 100331,
        "voice": "vo_adv_9006007_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n天涯海角我都奉陪。",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100331
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好期待呀。",
        "unit_id": 100331
    }
]