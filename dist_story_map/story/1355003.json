[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}去了埃拉的複製品世界觀光後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他跟埃拉約定好"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "會為她導覽基礎世界作為回禮。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天就是他們約定好的日子，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而──"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咦～～～～！？",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_000"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n今天開始的旅行，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大家都來不了嗎！？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這樣啊……",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_001"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好可惜。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但如果是非處理不可的事情，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那就沒辦法了呢！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n大家一起出門的機會",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也不是只有這次♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好──！",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_002"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n今天要連大家的份一起享受喔！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生，",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_003"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你會陪我吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就當作是下次大家一起去之前的預習，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "得要盡情享受才行呢！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哦！",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_004"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好可靠的回應～！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那就請多指教囉，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈哈！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好久沒逛逛",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_005"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "基礎世界了。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好期待啊，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是不是有很多變化呢？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n還想去買買伴手禮～",
        "unit_id": 135511
    },
    {
        "type": "background",
        "background": "502670"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "已經離市中心有段距離了……",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_006"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n騎士先生，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我們的目的地",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是在這附近嗎？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯嗯，",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_007"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "沿著這條路走一小段，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "再轉彎？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n哇，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要走這麼窄的小巷啊～",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯嗯，",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_008"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "因為右手邊可以看到招牌──",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n是在這一帶吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "走吧，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊，",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_009"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "有了有了，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就是那間店！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我看看……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "陶藝教室",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "「黏土的微笑」。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "上面說",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "隨時歡迎參加",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "陶藝體驗！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哦～",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_010"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "蘭德索爾也有作坊啊～！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這就是這次的目的地，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "雖然薩拉薩利亞",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_011"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也有幾間陶作坊，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但還真的沒有做過呢……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "能順利做出來嗎？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "話說回來，",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_012"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "為什麼選陶藝？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n是因為",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生喜歡嗎？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咦，",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "麥酒！？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n……不對。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以陶器跟麥酒",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "有關囉。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "原來如此，",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_014"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "口感柔和，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "會產生細緻的泡沫，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n香氣也更加豐富……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "可以讓普通麥酒的滋味",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "提高層次！？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "居然能做出這種夢幻的杯子！",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_015"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我突然就有幹勁啦♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_016"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我的手不巧，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n不曉得能不能順利做出來，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯嗯，",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_017"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "一起努力看看吧！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不好意思──！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "你好，",
        "unit_id": 1411,
        "voice": "vo_adv_1355003_018"
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "歡迎光臨。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "是預約的{player}先生吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "\n等你很久了～",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "只有兩位嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "店長，真對不起！",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_019"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n因為其他人",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "都突然有排不開的急事。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "今天就我們兩個人，麻煩你了！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "這樣啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1355003_020"
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "我知道了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "那麼",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作室的店長",
        "words": "請往作坊走。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，兩人準備挑戰陶藝教室──"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "原來如此──",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_021"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n要在這個不斷轉動的東西上用黏土塑形啊。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n嗯嗯……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "為了特別好喝的麥酒，加油吧──！",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_022"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "呃……",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_023"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "總之只要塑形就好了吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "明明只是這樣，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "看起來很簡單卻好難……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "唔唔唔……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "像這樣……",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_024"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "轉轉",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "轉……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咦，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊、啊、啊啊～～～！",
        "unit_id": 135511
    },
    {
        "type": "still",
        "still": "135500301"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗚哇……",
        "unit_id": 135511,
        "voice": "vo_adv_1355003_025"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "失敗了！",
        "unit_id": 135511
    },
    {
