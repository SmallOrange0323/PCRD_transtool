[
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吉歐‧格黑納某處。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n抽獎遊戲的攤販前。"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "來喲，",
        "unit_id": 1411,
        "voice": "vo_adv_9009007_000"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "蘭德索爾的抽獎攤販來囉～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n吉歐‧格黑納的各位，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "要不要",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "來試試手氣呀！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哦，",
        "unit_id": 129711,
        "voice": "vo_adv_9009007_001"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "抽獎呀……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "於吉歐‧格黑納不曾見過之物，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真是吸引人。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──皇女。",
        "unit_id": 129612,
        "voice": "vo_adv_9009007_002"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "那個……",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "沒抽中的話，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "是拿不到什麼好東西的。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "既然，",
        "unit_id": 129612,
        "voice": "vo_adv_9009007_003"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "都要花錢──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我覺得",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "拿去買點其他東西，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "會更好。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真是的，默涅呀，",
        "unit_id": 129711,
        "voice": "vo_adv_9009007_004"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "別說掃興之事。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "花錢於這般遊戲上，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "所為非是得失，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "而是興致。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "……我，",
        "unit_id": 129612,
        "voice": "vo_adv_9009007_005"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "不是很明白。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "要有玩心。",
        "unit_id": 129711,
        "voice": "vo_adv_9009007_006"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "抽了籤，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "揭曉結果那一刻……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正是",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "樂趣之所在。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵呵……",
        "unit_id": 129711,
        "voice": "vo_adv_9009007_007"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不愧是騎士閣下，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此言甚妙。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "於結果揭曉之前，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "懷抱著或許能得到獎品",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "的夢想。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n人們想必",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "便是為此付出金錢的吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "夢想──",
        "unit_id": 129612,
        "voice": "vo_adv_9009007_008"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這個，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "我也不太明白。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_9009007_009"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那麼默涅，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝便去抽一個試試吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n親身體驗乃是最佳的學習呀。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "來吧──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "也來一同遊玩吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "謝謝惠顧！",
        "unit_id": 1411,
        "voice": "vo_adv_9009007_010"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n不管有沒有中獎",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "都不要埋怨啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "……這是？",
        "unit_id": 129612,
        "voice": "vo_adv_9009007_011"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n前端",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "是金色的。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哦哦！？",
        "unit_id": 1411,
        "voice": "vo_adv_9009007_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "真的假的！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n小姑娘，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這可是頭獎啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "獎品是現在蘭德索爾",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n最流行的新型遊戲機喔～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "遊戲、",
        "unit_id": 129612,
        "voice": "vo_adv_9009007_013"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "機……？",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵呵……",
        "unit_id": 129711,
        "voice": "vo_adv_9009007_014"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "心無所求而抽",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "方得好結果呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那麼店主啊，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家所抽之籤呢？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊，",
        "unit_id": 1411,
        "voice": "vo_adv_9009007_015"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳沒抽中呢。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n來，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "給妳洗碗刷。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……竟然如此。",
        "unit_id": 129711,
        "voice": "vo_adv_9009007_016"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實在遺憾……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "遺憾──？",
        "unit_id": 129612,
        "voice": "vo_adv_9009007_017"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n皇女，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "不是買下了",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "夢想嗎？",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這與那",
        "unit_id": 129711,
        "voice": "vo_adv_9009007_018"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "乃兩回事……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……果然，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "所謂夢想不過泡影罷。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然出現了這樣的一幕，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但涅妃‧涅羅等人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n還是盡情地享受了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "似乎帶有東國文化氛圍的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n夏日祭典。"
    }
]