        "words": "可是，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們不會輸的！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "姊姊並不是一個人哦！",
        "unit_id": 108611,
        "voice": "vo_adv_5009301_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那傢伙對噗吉做了這麼過分的事，",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就由我來處罰它吧♪",
        "unit_id": 108611
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然我很害怕，……",
        "unit_id": 108511,
        "voice": "vo_adv_5009301_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但我也會戰鬥的……！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n竟敢奪走別人重要的回憶，",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n這種事是絕對不能做的啊……！",
        "unit_id": 108511
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們二個……",
        "unit_id": 108411,
        "voice": "vo_adv_5009301_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你們了！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "記憶的大精靈霧奇！",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我一定要打倒你，",
        "unit_id": 108411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "取回記憶！",
        "unit_id": 108411
    }
]