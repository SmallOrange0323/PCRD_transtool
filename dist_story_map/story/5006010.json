[
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "だいたい、",
        "unit_id": 1911,
        "voice": "vo_adv_5005010_000"
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "何もかもが思い通りになるこの島で、",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "\n一体何が不満だったのだ……",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "\nワシに逆らった者は",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "お前らが初めてだぞ！",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "あんな、",
        "unit_id": 1911,
        "voice": "vo_adv_5005010_001"
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "外の不自由な世界の",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "\nどこが面白いと言うのだ！",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "島クジラ……",
        "unit_id": 107911,
        "voice": "vo_adv_5005010_002"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "お前は間違ってるにゃ！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n願いが叶わないなら面白くない？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nそんなことはないにゃ。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "思い通りにいかないから、やりがいがあるにゃ。",
        "unit_id": 107911,
        "voice": "vo_adv_5005010_003"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "あたしはこのメルクリウス財団のみんなと、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n島にいるよりもっと面白おかしく人生を生きてみせるにゃ！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "ミフユ",
        "words": "そう。",
        "unit_id": 108011,
        "voice": "vo_adv_5005010_004"
    },
    {
        "type": "dialogue",
        "name": "ミフユ",
        "words": "夢は、",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "ミフユ",
        "words": "叶えてもらうものじゃないわ。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "ミフユ",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "ミフユ",
        "words": "私たちの手で掴むものよ。",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "あなたのちっぽけな幻想で満足できるほど、",
        "unit_id": 103411,
        "voice": "vo_adv_5005010_005"
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n私たちの欲望は、小さなものじゃないもの！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "そうですわ。",
        "unit_id": 103211,
        "voice": "vo_adv_5005010_006"
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\nあまり見くびらないでくださいませ。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "私たち……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "メルクリウス財団の欲望を！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "おおおお愚か者どもめ……",
        "unit_id": 1911,
        "voice": "vo_adv_5005010_007"
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "\nワシをコケにした報い、",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "死で受けてもらうぞ！",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "さあ、来ますわ！",
        "unit_id": 103211,
        "voice": "vo_adv_5005010_008"
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "　戦いの始まりですわよ！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "ぐああああっ！",
        "unit_id": 1911,
        "voice": "vo_adv_5005010_009"
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "　そ、",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "そんなバカなああああ……！",
        "unit_id": 1911
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "や、",
        "unit_id": 103211,
        "voice": "vo_adv_5005010_010"
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "やりましたわ！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "　島クジラに勝ちましてよ！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "これも、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "{player}さまのお陰ですわ！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "島クジラ",
        "words": "ぐおおおおおっ！",
        "unit_id": 1911,
        "voice": "vo_adv_5005010_011"
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "あれ？",
        "unit_id": 103411,
        "voice": "vo_adv_5005010_012"
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "　何かしら？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n沈んでいく島クジラが、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n何かを背中から一斉に吹き出してる……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "あいたっ！　",
        "unit_id": 107911,
        "voice": "vo_adv_5005010_013"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "固くてちっちゃな……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "これは……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "キャットコインにゃ！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "ミフユ",
        "words": "このコインは実在してたのね……",
        "unit_id": 108011,
        "voice": "vo_adv_5005010_014"
    },
    {
        "type": "dialogue",
        "name": "ミフユ",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "ミフユ",
        "words": "もしかしたら、",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "ミフユ",
        "words": "昔にこの島に漂着した\n海賊のお宝だったのかも！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "なんだか、思いがけず儲かっちゃった！",
        "unit_id": 103411,
        "voice": "vo_adv_5005010_015"
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "でも、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "ユカリ",
        "words": "それより問題は……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "ミフユ",
        "words": "これで、",
        "unit_id": 108011,
        "voice": "vo_adv_5005010_016"
    },
    {
        "type": "dialogue",
        "name": "ミフユ",
        "words": "本当にランドソルへ帰れるのかってことよね……",
        "unit_id": 108011
    }
]