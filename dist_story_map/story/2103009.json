[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在卡里莎與阿澤爾德襲擊了蘭德索爾的翌日——"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我回來了～！",
        "unit_id": 100111,
        "voice": "vo_adv_2103009_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "歡迎回來～！",
        "unit_id": 106414,
        "voice": "vo_adv_2103009_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012,
        "voice": "vo_adv_2103009_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "歡、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "歡迎…………",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵，",
        "unit_id": 100211,
        "voice": "vo_adv_2103009_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我回來了，騎士先生。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有大家，我們回來了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【破曉之星】的各位。",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "歡迎回來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n各位從索爾之塔的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "探索回來了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "幫人跑腿也真辛苦呢～",
        "unit_id": 190911,
        "voice": "vo_adv_2103009_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。",
        "unit_id": 100311,
        "voice": "vo_adv_2103009_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不過比預期中的還要更早一些，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就找到目標的物品了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100211,
        "voice": "vo_adv_2103009_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "等我一下唷。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n騎士先生，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你的手擦傷了呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我馬上幫你治療……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不愧是優衣小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是優秀的恢復魔法。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然主人臉上的鞋印和瘀青，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下與凱留小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n已經先行處理過了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "鞋、",
        "unit_id": 100111,
        "voice": "vo_adv_2103009_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "鞋印？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且還有瘀青……",
        "unit_id": 100311,
        "voice": "vo_adv_2103009_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們不在的時候，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n究竟發生了什麼事情？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……原來是這樣啊！",
        "unit_id": 100111,
        "voice": "vo_adv_2103009_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那個叫卡里莎的孩子，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "又跑來找騎士先生麻煩了呀……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然因為拉比林斯達的協助，",
        "unit_id": 100311,
        "voice": "vo_adv_2103009_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "逃過了一劫……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但我實在不覺得他們會就此打退堂鼓。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n得想些",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對策才行……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "果然，",
        "unit_id": 100211,
        "voice": "vo_adv_2103009_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還是得讓騎士先生變回原來的模樣",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "才行嗎……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是啊。",
        "unit_id": 100111,
        "voice": "vo_adv_2103009_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n雖然他好像有漸漸地回想起",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "與我們之間的回憶……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但還是缺少了像是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "面對戰鬥時的經驗之類的。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不僅是強化能力",
        "unit_id": 100311,
        "voice": "vo_adv_2103009_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和公主型態而已。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果他能想起我所傳授給他的劍術，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我想多少",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對他守護自身安危也有所幫助。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位是為了……",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "尋找似似花小姐所需的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n「為了醫治主人的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "藥物材料」，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n才會前往索爾之塔的對吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯。",
        "unit_id": 100111,
        "voice": "vo_adv_2103009_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且我們對卡里莎說的那句",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "「那邊早就已經是空殼了啊」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也很在意。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以我們才會想說，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "塔的內部是不是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "發生了什麼變化呢～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……雖然，",
        "unit_id": 100311,
        "voice": "vo_adv_2103009_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們並沒有明白地宣揚過……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但我們【破曉之星】的公會目標，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是要踏破索爾之塔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且塔內，",
        "unit_id": 100211,
        "voice": "vo_adv_2103009_019"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "或許有著能找回騎士先生的記憶的線索也說不定。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再加上，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只要能收集完索爾魔珠並且登上塔頂，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就能實現願望……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們曾在夢中，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "聽過這樣的啟示……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「願望」……",
        "unit_id": 106012,
        "voice": "vo_adv_2103009_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是，",
        "unit_id": 100111,
        "voice": "vo_adv_2103009_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "在我們去過的範圍內，都沒有什麼奇怪的事情唷。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不僅和以前一樣",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "充斥著非常強大的魔物，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就連通往塔頂的那扇門，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也依舊被關得緊緊的……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……",
        "unit_id": 100311,
        "voice": "vo_adv_2103009_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不過，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果要說",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有什麼奇怪的事情……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……？",
        "unit_id": 106414,
        "voice": "vo_adv_2103009_023"
    },
    {
        "type": "dialogue",
        "name": "日和、優衣",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_2103009_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……？",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n塔還是一如往常，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "同時各位也找到",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "目標的道具了吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而各位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為何會露出",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此困惑的神情呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個。",
        "unit_id": 100311,
        "voice": "vo_adv_2103009_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n其實……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……嗯？",
        "unit_id": 190911,
        "voice": "vo_adv_2103009_027"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n又有客人來了？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可能是貪吃佩可吧？",
        "unit_id": 106012,
        "voice": "vo_adv_2103009_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "門沒有鎖哦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……咦！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留？",
        "words": "打擾了。",
        "unit_id": 106011,
        "voice": "vo_adv_2103009_029"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦咦？",
        "unit_id": 100211,
        "voice": "vo_adv_2103009_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n有兩個",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "凱留……！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留、",
        "unit_id": 106414,
        "voice": "vo_adv_2103009_031"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留～！？",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說啊，",
        "unit_id": 106012,
        "voice": "vo_adv_2103009_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不要擅自拿別人的樣子來用啦，似似花！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……失禮了。",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我不太想以這個樣貌",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "大搖大擺地走在大街上。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "！",
        "unit_id": 106414,
        "voice": "vo_adv_2103009_034"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗚……！",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……雪菲小姐。",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似似花小姐不是可疑人物……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許算是吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但她並非是敵人喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "乖～乖。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "似似花小姐。",
        "unit_id": 100111,
        "voice": "vo_adv_2103009_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個藥已經做好了嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這還真是迅速呢。",
        "unit_id": 100311,
        "voice": "vo_adv_2103009_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n從我們將物品交給妳之後，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "甚至",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還不到半天……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他所專用的「新藥」……",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "其製作理論，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "早已經準備好許久了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剩下只要能夠取得所需的基本素材，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼調和藥品本身也不需耗費多少時間。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「新藥」……！",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此一來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人便能恢復成……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來的模樣了？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哇啊～",
        "unit_id": 100211,
        "voice": "vo_adv_2103009_040"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的嗎……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我並不保證",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "絕對會恢復。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n儘管我已經竭盡我的所能了……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟這事沒有先例。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且就算稱為藥，",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這並非是從植物或昆蟲，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n又或是從魔物之中的成分所萃取出來之物。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n真要歸類的話，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該算是魔法的產物。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔法的產物……？",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們幾個，",
        "unit_id": 100311,
        "voice": "vo_adv_2103009_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接受似似花的委託前往塔內尋找的東西——",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當時他所誤食的，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個小水晶。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……！",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……妳說那個水晶，",
        "unit_id": 106012,
        "voice": "vo_adv_2103009_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我記得是貪吃佩可從寶物庫拿出來的東西……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "竟然在塔裡也有……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "結果，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個東西",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是什麼啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那個水晶……",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是超高密度的情報體。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n說是「被固化的混沌」或許更加妥當。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "昏蹲……？",
        "unit_id": 106414,
        "voice": "vo_adv_2103009_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要將用這種材料所製成的藥物，",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n再次投藥給主人的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "意思嗎……？",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "210300901"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……讓我按部就班來說明吧。",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "首先，",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_051"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請各位先想像一顆表面出現無數龜裂的玻璃珠。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這顆玻璃珠就是{player}",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「精神退化之後的靈魂」。",
        "unit_id": 107011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "210300902"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "接著……",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當他偶然地吞下了貪吃佩可所帶來的水晶，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n將其吸收到了體內，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這時「靈魂」上的部分龜裂被填滿了……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n形成了不完全、",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "且帶了點瑕疵的球體。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而被稱為「公主型態」的",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "全新的強化力量，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也是在此階段被發現的……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但由於這些龜裂尚未被完整填滿，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n且仍舊歪曲著，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因此精神狀態才會毫無變化。",
        "unit_id": 107011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "210300903"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這次",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是以我的變化能力，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n加上深月",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所提供的病歷為基礎，對水晶進行了調整……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n好能夠將龜裂填補完全，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並將歪曲導正。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呃……",
        "unit_id": 100111,
        "voice": "vo_adv_2103009_055"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然我聽不太懂，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但總而言之，這是個很厲害的魔法道具對吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "確實是。",
        "unit_id": 100311,
        "voice": "vo_adv_2103009_056"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "然而水晶的來源不明這點，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "多少使人有些不安就是……",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這個水晶。",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_057"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n八九不離十",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是米奈娃的………………",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而，",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_058"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "米奈娃的「本體」，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如今究竟在何處呢……？　",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100211,
        "voice": "vo_adv_2103009_059"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "似似花小姐？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……就如同我方才所說的，",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我已經把我所有該做的事都做完了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在深月的基礎研究中，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有數據",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "詳細紀錄了他",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "正常時的",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n生命跡象和魔力型態，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這點倒是萬幸。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而說實在的，",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_061"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟也沒經過臨床實驗……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n因此這項投藥的嘗試與否，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "最終還是要",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "交由各位來判斷了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_062"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我推測，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該會是種相當強硬的暴力療法吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n至少，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "短時間內都得絕對靜養了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "得絕對靜養……",
        "unit_id": 100211,
        "voice": "vo_adv_2103009_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿、凱留",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_2103009_064"
    },
    {
        "type": "dialogue",
        "name": "日和、怜",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_2103009_065"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……？",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_066"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你真的",
        "unit_id": 106012,
        "voice": "vo_adv_2103009_067"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可以嗎……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這可能有危險也說不定……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生……",
        "unit_id": 100211,
        "voice": "vo_adv_2103009_068"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呵呵。",
        "unit_id": 100111,
        "voice": "vo_adv_2103009_069"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不論什麼時候，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生都還是一樣，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒有變過呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在你休養的這段期間，",
        "unit_id": 100311,
        "voice": "vo_adv_2103009_070"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們必定會守護你的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你就安心吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那……",
        "unit_id": 106012,
        "voice": "vo_adv_2103009_071"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你就趕快給我吃下去，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後趕快治好你的問題啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這樣子一來，",
        "unit_id": 190911,
        "voice": "vo_adv_2103009_072"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我就終於能從這傢伙的「玩具」中畢業了呢。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_073"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這藥品……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管已經是粉末狀了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您需要配杯水嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_074"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……葛格？",
        "unit_id": 106414,
        "voice": "vo_adv_2103009_075"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，",
        "unit_id": 100211,
        "voice": "vo_adv_2103009_076"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你沒事吧……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……？",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_077"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "別太經常去跟他說話，",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_078"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n同時也別去搖醒他比較好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "短時間內，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "讓他靜靜地保持沉睡即可。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明白了。",
        "unit_id": 105913,
        "voice": "vo_adv_2103009_079"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請跟著在下到床鋪上去吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了避免您跌跤，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請確實地握好在下的手。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……你聽好了，{player}。",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_080"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你吞下了這個藥，",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_081"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "陷入沉睡的期間，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n想必會有某個人，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在你的夢境中現身才是。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但那個人，",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_082"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "儘管並非是你的敵人……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然而也不是你的夥伴。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因此你絕對……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不得完全相信對方。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼……",
        "unit_id": 107011,
        "voice": "vo_adv_2103009_083"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "晚安了，{player}。",
        "unit_id": 107011
