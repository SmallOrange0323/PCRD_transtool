    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊哈哈哈！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你變得充滿了男子氣概啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣啊這樣啊。",
