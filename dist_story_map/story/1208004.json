        "voice": "vo_adv_1208004_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥就戴上這副太陽眼鏡吧。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n都玩成這樣了，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "乾脆把這些都穿上，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n痛痛快快地大笑一場吧！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就算你半途求饒，我也不會放過你喔！",
