    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "流夏與{player}為了尋求福氣而到處閒逛。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不知不覺間，天色漸漸暗下來了。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔，",
        "unit_id": 120811,
        "voice": "vo_adv_1208004_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "已經這麼晚了啊。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "逛了一整天，\n我們拿到的福氣有",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "護身符和熊手。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這些收穫還挺不錯的嘛。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然還想再找個一件，",
        "unit_id": 120811,
        "voice": "vo_adv_1208004_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但今天就先到此為止。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n差不多",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "該去吃晚飯了吧。",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦？",
        "unit_id": 120811,
        "voice": "vo_adv_1208004_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真、",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真的耶，",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼？這代表福氣已經來了嗎？",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗚、",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗚哇──！",
        "unit_id": 120811
    },
    {
        "type": "background",
        "background": "510303"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哎呀，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是小哥啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "新年快樂。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "請多指教啦。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對了，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在這裡遇到你也是種緣分，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你能不能幫我一點忙？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別擔心，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不會害你的。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n這對你來說",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "算是賺個小紅包的好機會。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "其實我是受父母所託，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "接下來要去買福袋。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但那是",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "一人只能買一袋的限量商品。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果有小哥在，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "除了我這袋之外，還能夠再買一袋。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果小哥",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒打算要買限量福袋，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能不能幫我個忙？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可以嗎！",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "謝謝你啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那我們",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就快去買吧。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是福袋已經賣完，那可就沒戲唱了。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "託小哥的福，我們順利買到福袋啦。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n謝謝你。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對了對了，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "關於答謝你的紅包，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥就從福袋裡面",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "拿個你喜歡的",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "東西吧。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "比起",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "福袋的內容物本身，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我更想享受開福袋的興奮感。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但若",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "福袋裡有好東西，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那當然是最好的。",
        "unit_id": 105632
    },
    {
        "type": "background",
        "background": "510130"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好啦，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那就來進行久候多時的",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "開袋儀式吧。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "首先是……",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是個錢包啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而且這不是真皮嗎？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n一開始就讓人充滿了期待啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "然後，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_014"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這是……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "遊戲軟體嗎？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n哦，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是去年發售的熱門作品啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我不太清楚，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但這算是中大獎吧？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這個福袋可能挺不錯的啊。",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "結果話才剛說完……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "唔哇……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這毛衣",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "的設計",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還真是不得了啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n而且這不是情侶裝嗎？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這東西",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要給誰穿啊……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這頂毛線帽的顏色",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不也很扎眼嗎？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還有",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這副太陽眼鏡，也很……",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "拜託下個東西別太糟……",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_017"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "喔，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這是很棒的杯子呢。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n似乎是",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "著名品牌的商品。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好啦，接下來是……",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這下確認過所有內容物了，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但真的是玉石不分啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種雜亂的感覺",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "很有福袋的韻味，也挺不錯的啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好啦，小哥，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你要拿什麼走？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不用客氣，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就挑你喜歡的東西吧。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦～！",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "偏偏挑這件毛衣！？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n明明還有遊戲跟很不錯的雜貨啊？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你真的不用跟我客氣喔，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什……",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來這招啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要穿上這東西嗎……？",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這實在",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "很令人傷腦筋啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯～",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真拿你沒辦法啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就陪你穿吧！",
        "unit_id": 105632
    },
    {
        "type": "still",
        "still": "120800401"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊哈哈哈哈哈！",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，",
