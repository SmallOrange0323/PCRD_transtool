    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真沒想到新年才剛開始，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我就能笑成這樣啊。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這點子不錯耶。",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "只要穿著這個，肯定能生意興隆！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥也把這穿去學校吧。",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣一定能成為班上的大紅人。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n啊哈哈哈哈！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不開玩笑了，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難得有這個機會，",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n要不要也來穿穿看其他的傻氣配件啊？",
        "unit_id": 105632
