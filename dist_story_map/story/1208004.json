    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊哈哈哈哈！",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊～真是有趣。",
        "unit_id": 105632
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "能被拿來當成搞笑的哏，",
        "unit_id": 105632,
        "voice": "vo_adv_1208004_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n對這種令人失望的商品來說，也算是得償所願吧。",
