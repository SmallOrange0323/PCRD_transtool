        "type": "dialogue",
        "name": "媞雅",
        "words": "你的記性還不錯嘛。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……呵呵。",
        "unit_id": 193211,
        "voice": "vo_adv_2215097_051"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n怎麼啦？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n難道你想說，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "是我在說謊嗎？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我才沒說謊呢。",
        "unit_id": 193211,
        "voice": "vo_adv_2215097_052"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不過──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我才不告訴你。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "這可是值得紀念的",
        "unit_id": 193211,
        "voice": "vo_adv_2215097_053"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "第一個猜謎喔？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n你可要認真地找到答案喔。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "唔……！",
        "unit_id": 193211,
        "voice": "vo_adv_2215097_054"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n這、",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "這個",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就不用了啦……！",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "──提示？",
        "unit_id": 193211,
        "voice": "vo_adv_2215097_055"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "提示嘛……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "……老實說，",
        "unit_id": 193211,
        "voice": "vo_adv_2215097_056"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "對我而言，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我幾乎已經把答案講出來囉。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "比方說，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就拿今天的內容來說──",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "──我究竟是什麼東西的化身呢，",
        "unit_id": 193211,
        "voice": "vo_adv_2215097_057"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "之類的。",
        "unit_id": 193211
    }
]