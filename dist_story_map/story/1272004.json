    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "時間終於來到畢業典禮的前一天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}也來幫凱留收拾行李。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼……",
        "unit_id": 127212,
        "voice": "vo_adv_1272004_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣行李就收拾得差不多了吧。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝謝你，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是幫大忙了。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "轉眼之間就要畢業了啊……",
        "unit_id": 127212,
        "voice": "vo_adv_1272004_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n結果",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你到最後都沒有學會任何魔法呢。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 127212,
        "voice": "vo_adv_1272004_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好強的光！！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你有學過這種魔法嗎～～～！？",
        "unit_id": 127212
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "各位國中生們～！",
        "unit_id": 6932,
        "voice": "vo_adv_1272004_003"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "\n歡迎各位來參加椿丘高中的",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "校園參觀日！",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "\n",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "還請好好參觀，",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "當作未來升學時的參考～！",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "咦，",
        "unit_id": 6932,
        "voice": "vo_adv_1272004_004"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "{player}，你怎麼會在這裡？",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "\n你應該",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "不是校園參觀日的執行委員吧？",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "嗯？",
        "unit_id": 6932,
        "voice": "vo_adv_1272004_005"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "你有邀請認識的國中生來參觀？",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "\n",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "……啊，",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "該不會",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "是躲在那根電線桿後面，",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "一直偷看這邊的女生吧？",
        "unit_id": 6932
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……咿！",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_006"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那……",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_007"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那種事我怎麼可能辦得到……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就連同年紀的人都是我不認識的了，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "更不可能向年長的人搭話……！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……你說謝謝",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_008"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我今天過來？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那是因為你一直吵著要我來，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我才過來稍微看一下罷了……！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "好……",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_009"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "好了，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我們趕緊去校內參觀吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你可要好好幫我帶路喔。",
        "unit_id": 106031
    },
    {
        "type": "background",
        "background": "510210"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……這、",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_010"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這裡",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就是你就讀的高中嗎。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n看起來",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "明明跟國中沒什麼不一樣……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "感覺",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "卻完全不同。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……咦，",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_011"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你問我是不是很緊張？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "才……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "才沒有這回事。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "喔，",
        "unit_id": 6632,
        "voice": "vo_adv_1272004_012"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "你帶著一位很可愛的國中生呢。",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "原來{player}有妹妹嗎？",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "咦，",
        "unit_id": 6632,
        "voice": "vo_adv_1272004_013"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "她不是妹妹？",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "那樣的話，",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "難不成是比你小的女朋友嗎～？",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "咦",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_014"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "啊哈哈，",
        "unit_id": 6632,
        "voice": "vo_adv_1272004_015"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "抱歉抱歉，只是開個玩笑♪",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這……",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_016"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這我知道。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "這樣啊～",
        "unit_id": 6632,
        "voice": "vo_adv_1272004_017"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "真的是",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "不好意思呢。",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "啊，",
        "unit_id": 6632,
        "voice": "vo_adv_1272004_018"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "裁縫教室好像有提供制服可以試穿喔，",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n有興趣的話要不要去看看？",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_019"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我不要！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "啊……",
        "unit_id": 6632,
        "voice": "vo_adv_1272004_020"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "等等，",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "妳要去哪裡啊～！？",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "抱歉，",
        "unit_id": 6632
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "我好像惹她生氣了……",
        "unit_id": 6632
    },
    {
        "type": "background",
        "background": "510180"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "唉……",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_021"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……沒有，",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_022"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不是這樣的。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n也幫我跟剛剛那個人道歉，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我只是怕生而已。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……你不用露出一臉抱歉的表情啦。",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_023"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這怎麼想",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "都是我不好。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……啊～",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_024"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "糟透了……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這是之後會陷入強烈自我厭惡的狀況啊……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……我",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_025"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "並沒有勉強自己過來。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "能夠被你邀請，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我也……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "覺得很高興。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過，",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_026"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我其實沒有打算升上高中呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……我現在在學校",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_027"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就過得一點也不開心了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "畢竟是義務教育，就只能忍耐。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "如今好不容易快要脫離苦海，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "為什麼我還得繼續上學不可？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然這麼說，",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_028"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但我也不是有什麼其他想做的事情。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我只是不想要因為大家都去讀高中……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就覺得",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "自己也要去罷了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "與其在那邊抱怨不想讀書，",
        "unit_id": 106031,
        "voice": "vo_adv_1272004_029"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "或是上學很麻煩，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n那還不如從一開始就不要去。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
