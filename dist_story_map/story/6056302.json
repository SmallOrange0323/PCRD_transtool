[
    {
        "type": "background",
        "background": "501162"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "金槍鮪……",
        "unit_id": 106012,
        "voice": "vo_adv_6056302_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一開始還想說只是貪吃佩可嘴饞想吃，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過要是能捕到，一發致富也不是夢想對吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n據說能賣到一千萬盧幣……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘻嘻，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這筆錢該怎麼花才好呢？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這主意挺不錯的嘛♪",
        "unit_id": 106012,
        "voice": "vo_adv_6056302_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然有一千萬盧幣能花，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那種十層木盒的超豪華年菜也能盡情地點個夠。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不過嘛，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大半應該都會進到貪吃佩可的胃裡就是了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚……",
        "unit_id": 106012,
        "voice": "vo_adv_6056302_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "儲蓄的確是很重要沒錯……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n想不到你平常一副懵懵懂懂，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n偶爾也會說些說服力十足的好話耶……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有一千萬盧幣",
        "unit_id": 106012,
        "voice": "vo_adv_6056302_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的確是能夠遊遍天下的秘境……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣豈不是跟平常做的事沒有兩樣嗎！？",
        "unit_id": 106012
    }
]