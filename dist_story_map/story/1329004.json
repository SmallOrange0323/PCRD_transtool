[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聖誕節告一段落，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "面對年末，鬧區開始充滿活力。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n前來幫助當地居民們收拾聖誕裝飾的伊緒"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n獨自一人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "抬頭看著聖誕樹。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……聖誕節，",
        "unit_id": 132912,
        "voice": "vo_adv_1329004_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的結束了呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "解決了吐舌鬼的大騷動，",
        "unit_id": 132912,
        "voice": "vo_adv_1329004_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n又去幫忙了弗洛艾和聖誕老人……",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今年的聖誕節發生了好多事情，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真的很忙碌呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "欸欸，",
        "unit_id": 416,
        "voice": "vo_adv_1329004_002"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "聖誕老人送的禮物，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "你們收到什麼了？",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "收到新玩具了喔～！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我收到娃娃了！",
        "unit_id": 415,
        "voice": "vo_adv_1329004_003"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嘿嘿，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "好可愛～！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "要好好珍惜才行！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 132912,
        "voice": "vo_adv_1329004_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "看見孩子們收到禮物後興奮的模樣，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好像能夠再次感受到，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我們真的成功守護聖誕節了呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "很好，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也要努力進行善後工作才行！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀，",
        "unit_id": 132912,
        "voice": "vo_adv_1329004_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "又見面了呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你也是",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來幫忙收拾聖誕裝飾的嗎？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 132912,
        "voice": "vo_adv_1329004_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有好好來進行善後工作真了不起～♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為馬上就要到年末了，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為了能轉換心情，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n得收拾乾淨才行呢。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來吧，",
        "unit_id": 132912,
        "voice": "vo_adv_1329004_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "努力收拾囉～！",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n裝飾的時候和收拾的時候，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "都同樣是聖誕節的珍貴回憶♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為了明年也能平安度過聖誕節，",
        "unit_id": 132912,
        "voice": "vo_adv_1329004_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n邊遙想著未來",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "邊將拿下來的裝飾仔細收好。",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣的話，",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "明年的聖誕節一定也能愉快的度過♪",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……咦，",
        "unit_id": 132912,
        "voice": "vo_adv_1329004_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀？",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總覺得",
        "unit_id": 132912
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "突然變得好刺眼……",
        "unit_id": 132912
    },
    {
        "type": "background",
        "background": "510110"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你，",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n為了鎮上舉辦的聖誕派對",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "學校借出體育館作為場地了，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但卻面臨志工人手不足的問題。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你真的幫了大忙。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來，",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也給你。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n是聖誕派對的重頭戲，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "聖誕蛋糕喔♪",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一邊和大家一起享用，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一邊休息一下吧。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為之前都是和家人一起度過，",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "像這樣還真是新鮮♪",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和大家一起熱鬧度過聖誕節也很不錯呢！",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和家人以外的人度過聖誕節，",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n有種特別的印象呢。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "感覺比平時更加浪漫美好……",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "和重要的人一起度過的話，",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "應該可以成為美好的回憶吧，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有這種感覺……",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有一天",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你也會和重要的人",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n一起創造美好的聖誕節回憶嗎？",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……還是說，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "已經經歷過了？",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然有點在意，",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n但老師追問的這麼深入也不合適呢。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……話說，",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "光顧著聊天，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n都忘記蛋糕的存在了。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "趕快",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "開動吧。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我開動了♪",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊姆……",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "甜甜的真好吃～！",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "鮮奶油的甜味和草莓的酸味是最棒的搭配呢♪",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "其實",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我最喜歡",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "草莓鮮奶油蛋糕了。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "喜歡到小時候會說",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "「聖誕老人給我的禮物我想要蛋糕！」",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這種程度喔。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n如果能吃到兩個蛋糕就太幸福了！",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我那時候",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是認真這麼想著。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "現在的話，",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "蛋糕還是一個就夠了。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "變成大人後，",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也收不到聖誕老人的禮物了……",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "老師～！",
        "unit_id": 131,
        "voice": "vo_adv_1329004_022"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "聽我說聽我說～！",
        "unit_id": 131
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀，",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我記得你們是",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "附近小學的孩子們。",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "怎麼了嗎？",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有什麼想說的？",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "聖誕老人是存在的對吧？",
        "unit_id": 231,
        "voice": "vo_adv_1329004_024"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n老師你知道吧？",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我覺得存在啊。",
        "unit_id": 101832,
        "voice": "vo_adv_1329004_025"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "聖誕老人怎麼了嗎？",
        "unit_id": 101832
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那個啊，",
        "unit_id": 131,
        "voice": "vo_adv_1329004_026"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "大哥哥們都說",
        "unit_id": 131
    },
    {
        "type": "dialogue",
