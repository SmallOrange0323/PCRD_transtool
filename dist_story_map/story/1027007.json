        "name": "惠理子",
        "words": "我被稱為「破壞者」，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "街道上每個人都害怕我……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "每個人都討厭我……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您面對這樣的我，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n{player}大人還是",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "把我當成一個",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "普通女孩看待。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有危險的時候，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還會保護我……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "明明比我還弱……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是令人困擾的人……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "面對一堆沒用的禮物，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_032"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也會開心收下……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "願意原諒愛嫉妒的我……",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_033"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還幫助昏倒了的我……",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_034"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在他的身邊，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_035"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我不是「破壞者」，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n而是一個普通的女孩……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……我，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_036"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "最喜歡……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您了……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "無論您",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_037"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是不是我",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "命中注定的人，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這都不重要。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_038"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "最喜歡您了……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這才是最重要的。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "並不是因為您是我命中注定的人，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_039"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "所以才喜歡您的……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為我最喜歡",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人了，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "所以您是我命中注定的人。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "偽惠理子",
        "words": "嘖！",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_040"
    },
    {
        "type": "dialogue",
        "name": "偽惠理子",
        "words": "被發現了嗎。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "偽惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "偽惠理子",
        "words": "本來打算就這樣令你迷失在森林，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "偽惠理子",
        "words": "再吸取養分……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "偽惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "偽惠理子",
        "words": "這樣的話就將你變成屍體，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "偽惠理子",
        "words": "成為我們的養分！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不單是想要迷惑{player}大人，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_041"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n竟然還想要襲擊他……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "必須要好好懲罰妳們這種不懂規矩的傢伙呢。",
        "unit_id": 102711
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哼，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_042"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "太簡單了……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然變身成「破壞者」的樣貌，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我真希望",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳能稍微抵抗一下呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_043"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您不必感謝我。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n除去膽敢傷害{player}大人的東西，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n對我來說是理所當然的事情。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為，",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_044"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人是",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我命中注定的人……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好、",
        "unit_id": 102711,
        "voice": "vo_adv_1027007_045"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好害羞……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "先走一步了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "惠理子希望自己對{player}而言，\n同樣也是他命中注定的人……"
    }
]