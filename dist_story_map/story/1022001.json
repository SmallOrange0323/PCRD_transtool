[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦、咦？",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n應該是這一帶沒錯……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為聽說有超便宜的雜貨店所以我才到這裡來……",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但到處都看不到符合的店家啊。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怎、怎麼辦……？",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n都來到這裡了，也不想就這麼放棄。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "找誰問路看看好了……！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可、可是要和陌生人搭話……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不，我不能一直這麼怕生！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只是問個路而已，小事一件！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，有人來了！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n向那個人問問看！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那、",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那……那個！！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "路人",
        "words": "哇，嚇到我了！",
        "unit_id": 311,
        "voice": "vo_adv_1022001_007"
    },
    {
        "type": "dialogue",
        "name": "路人",
        "words": "\n有事嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊啊啊啊，抱、抱歉！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n都是我害你嚇一跳！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我沒想到會發出那麼大的聲音來……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "欸，那……那個，店……",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不對！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我不知道路怎麼走……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "欸、欸……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "今、今天是個好日子……感謝您百忙中前來……",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "――我幹嘛這麼正式問候啊！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊、不是，不是那樣的……",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n其實是……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "欸……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還、還是算了！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n什麼事都沒有！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼……失敗了……",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n明明只是問路而已，為什麼我會這麼緊張呢？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "下、下一個！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n下一個人一定要好好問清楚！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "正好下一個人過來了！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n這、這次一定要成功……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請問！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……啊啊啊啊！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我沒事幹嘛這麼大聲！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "為什麼我沒辦法從失敗中學到教訓呢……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊……是、是的！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我有問題！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你願意聽我說嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對、",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對不起！我發出這麼大的聲音！！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n真抱歉！！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，聲音又太大了……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那……那個呀。",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我的名字叫依里――",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，不對！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n現在不需要自我介紹！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就是，那個……路超便宜的――",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_021"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不是！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我在找一間店……那個……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還是沒事了！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_022"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "對不起！",
        "unit_id": 102211
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇！竟然追了過來！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "為、為什麼？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n不要過來！",
        "unit_id": 102211
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "到、到底為什麼要跟上來啊！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這樣的話……我就全力逃跑！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "噠噠噠噠――",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_025"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還在追我！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_026"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等等！你到底想幹嗎！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哈？還沒聽我說有什麼事……？",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n就為了這個理由！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我剛剛已經說沒關係了啊！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你、你很纏人耶！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_028"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n沒理由這麼認真吧！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "因為我好像很困擾……？",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_029"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "的、的確是很困擾……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但就算那樣也很纏人耶！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我只是想問路！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我在找超便宜的雜貨店！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……？",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_031"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你、你要幫我帶路……？",
        "unit_id": 102211
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "托你的福，我順利買到東西了……",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_032"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n但這樣堅持要聽我說話的人，你還真是第一個。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我很不擅長和別人交談……",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_033"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n尤其如果對象是男性的話，我就會很緊張，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n緊張到說不好話……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸？現在我很正常地在說話……？",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_034"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……咦？這麼說起來……？",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_035"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "因為你實在太煩人了，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我才煩躁到都忘了緊張。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "現、現在已經不生氣了！",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_036"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然你很纏人……但也是托你的福才能找到店鋪。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "一旦說過話之後，好像就能正常說話了。",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_037"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這還真是我第一次，能和男性這樣說話……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "吶、吶……",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_038"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n你叫什麼名字？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……這樣喔。",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_039"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n如、如果你願意，下次再……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還還還、",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_040"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還是算了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n再見！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸欸！？",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_041"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n為什麼又追上來了！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……因為話說到一半？",
        "unit_id": 102211,
        "voice": "vo_adv_1022001_042"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我剛剛已經說沒事了啊！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n不用連這種時候都這麼堅持啦――！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "依里意外地找到一位可以正常說話的對象。"
    }
]