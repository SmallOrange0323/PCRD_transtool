[
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳究竟想要做什麼？",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "若是我被這麼問到──",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我會說，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我想做一本有滿滿回憶的相簿。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "收集許多所謂",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "青春的一頁，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n把它們集結成冊──",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "再把厚厚的相簿，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n收藏在心中的棚架，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "讓我隨時都能拿出來玩味。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣的話，在很～久以後的將來，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n當變成老婆婆的我",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "打開這本相簿的時候──",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就不會說出「早知道就那樣了」、",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n「要是年輕的時候有那樣該有多好」等等，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "而是沒有後悔地",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「呵呵」",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一聲露出笑容──",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我想要留下很多很多",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_006"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "能讓我面露笑容的璀璨回憶。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "人生只有一次，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要是過得無聊就太無趣了。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我已經決定好了，當我被可愛的孫子們守候著躺在床上，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n準備前往天國的時候，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在出發的那一刻我要說──",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「嗯，玩得真開心！」",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "今天，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我歌頌了青春。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "歌頌了",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "名為偶像的青春。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我所體驗到的視野，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所看見的景色。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就和總是在舞台上發光發熱、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "賣力歌舞的歌姬一樣。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "感受眾多熱情的視線與接受如雷歡呼，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_013"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n只有臉蛋和身材的超級美少女，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n今天，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "進化成會唱會跳的超級偶像了。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "帶著兩名伴舞直接上場正式表演，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_014"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n以只能靠即興發揮的外行人來說，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我覺得算表演得不錯了。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐表演了不知道在哪練的華麗迴旋，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐想跟著轉結果閃到腰，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "讓大家笑翻了。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n至於我呢──",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "──嗯，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_016"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "至於我啊，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為我是天才嘛？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然只是憑印象模仿慈樂之音她們，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n但成果應該蠻上相的吧。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在望望本人面前雖然有點緊張，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_017"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但靠著現場氣氛、氣勢和超強心臟還是給它切嚕過去了。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "表演完之後，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家又叫又跳的。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n保守一點也可說是盛況空前！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真是感人喵～",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "結束。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "如果問我想不想再來一次，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_019"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大概會是「嗯～",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "讓我再考慮一下喔～」",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣，有點猶豫。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n但就今天而言，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我想抬頭挺胸大聲地說──",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，玩得真開心！",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_020"
    },
    {
        "type": "background",
        "background": "500732"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "琪愛兒。",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_021"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "琪愛兒？",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_022"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "怎麼了，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_023"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "在這裡發呆？",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "其他同學都在忙著收拾囉。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_024"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊、",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是希爾修女老師啊……",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "日安。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊、沒有啦，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_025"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只是稍微沉浸在餘韻裡。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我在想剛才的表演",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的是一次很棒的體驗。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n讓人不由得",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "開始思考起人生與生涯規劃了呢。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "偶像啊……",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_026"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n之前覺得半路出家會很辛苦，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以壓根兒沒考慮過，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但就今天大家的反應來看，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "似乎也不失為一種選項呢。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "這樣嗎。",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_027"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "這個話題，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "我們明天到輔導室再好好聊聊吧。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n老師會給妳一些",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "比較實際的建議。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_028"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我想，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "現在應該已經在業界引起騷動了吧？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家一定在問那位超切嚕的超級美少女到底是誰？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真傷腦筋，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_029"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "越來越引人注目了呀……",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n這下不好了呢，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "會不會被熱情過頭的粉絲包圍啊？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "妳們怎麼看，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "兩位伴舞？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "……咦、",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_030"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "奇怪？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只剩{player}學長？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n兩位伴舞，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "通稱優妮＆克蘿依上哪去了？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "現在",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_031"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "優妮在擔任我們學院的學生代表，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n負責接待學會來的貴賓。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "先不論平日表現，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_032"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "她畢竟值得是本校驕傲的名譽博士。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "想必能在貴賓面前",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "充分展現聖德蕾莎女子學院的教學成果。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦……",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_033"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n先不談優妮學姐幾乎沒在我們學校的課堂上學到東西的問題，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "讓她去接待那些理科老師沒問題嗎？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不會起衝突吧？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "學院",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_034"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "很湊巧地要在明天",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "添購博士之前申請的昂貴圖書。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "雖然只是湊巧而已，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "博士她還是拍胸脯保證「沒問題」。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "敗給物質欲望了嗎……",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_035"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "克蘿依的話，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_036"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "則是請她到現場負責指揮收拾工作了。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "因為布置時的好表現，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "獲得了大會營運委員的一致肯定。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n當我跟她說大家有困難，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "她就說著「真沒辦法」然後起身幫忙了呢。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "敗給人情壓力了嗎……",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_037"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "琪愛兒，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_038"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "妳還在做什麼？",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "沒事的話就早點回去吧。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喔，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_039"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好……",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_040"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我可以回去嗎？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不用幫忙收拾？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "當然，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_041"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "妳想要幫忙也是可以。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "實際上，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "其他學生也都是主動去幫忙的。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哦～",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_042"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣子啊……",
        "unit_id": 116311
    },
    {
        "type": "background",
        "background": "501280"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聖學祭結束後的操場，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_043"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n正在進行撤除各式帳篷和裝飾的作業。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒有留下激情與餘韻，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_044"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n只感受到祭典後忙著收拾的倉促與寂寥。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "讓人真正體認到",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_045"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "祭典",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "已經結束了啊。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "其他人一定也是這麼想的吧？",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_046"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以才會特地自願參加不擅長的肉體勞動，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n想要再多感受一下祭典的餘溫。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "今天這青春中寶貴的一頁，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_047"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也都不想這麼快結束。",
        "unit_id": 116311
    },
    {
        "type": "background",
        "background": "500732"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣啊……",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_048"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦、",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_049"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那學長，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們呢？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要回去了嗎？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "…………",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_050"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我想也是！",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_051"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就等優妮＆克蘿依她們，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家再一起回去吧！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那～",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_052"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們就隨便找個缺人手的地方去幫忙吧。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "…………",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_053"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯？",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_054"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼了嗎，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "老師？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "不，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_055"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "沒什麼。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "話說回來，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_056"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "不知道妳們有沒有聽過？",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n其實以前聖學祭",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "還會舉辦「後夜祭」喔。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "後夜祭。",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_057"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是喔～",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是做什麼的？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "在閉幕式結束，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_058"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "家人及來賓都回去之後，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "會將收拾工作整理出來的廢棄物",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "集中到操場去燒。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就像營火那樣！",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_059"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好像很好玩！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "那是很嚴肅",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_060"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "莊重的儀式。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "我想想……",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "會由我們老師宣揚主的教誨，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "還會請各位同學合唱學院聖歌喔。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "……我收回剛剛的話。",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_061"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n好不好玩有待商榷。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯？",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_062"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "然後呢？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "為什麼現在",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒有那個活動了？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "嗯……",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_063"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "簡單來說，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "是安全上的考量。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "我記得是因為在幾年前，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_064"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "收到過",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "「天都黑了還不放我寶貝女兒回家是在幹什麼！」這樣，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n來自一部分家長的抱怨。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "太苦了！",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_065"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n原來那時候就有難搞的怪物家長啊。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "請注意自己的發言。",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_066"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n家長們說的也有道理。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "不過，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_067"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "說實話，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "我個人是覺得很可惜。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n畢竟那是段能和同儕分享心中不捨，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "難以言喻的時間。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "用妳們年輕人的話來說，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "大概是",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "「超感動」……",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "這樣吧。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "老師我呀，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_068"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "並不討厭後夜祭呢。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "好了，",
        "unit_id": 3211,
        "voice": "vo_adv_1163001_069"
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "一不小心聊太久了。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n現在不是不挑場合散播感動的時候，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "\n",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "那麼，",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "女性教員",
        "words": "兩位再會。",
        "unit_id": 3211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哦～",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_070"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "後夜祭啊……",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒有，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_071"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只是聽完剛才的話，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n讓琪愛兒有了一些想法。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "剛才老師說是因為讓那些掌上明珠太晚回家",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_072"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n才會被抱怨對吧？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那也就是說，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_073"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n只要後夜祭不要辦在晚上就行了吧？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "…………",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_074"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "……嗯。",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_075"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就這樣，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我決定了。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n嚮往燃燒殆盡的少女琪愛兒，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在此自行下定一大決心！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "目標是，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_076"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "舉辦後夜祭（不是晚上版）！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒錯，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_077"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "後夜祭。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n既然學院不辦就由我們自己辦。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n祭典幹事就由琪愛兒擔任！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～☆",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好帥～",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_078"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不愧是學長！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我就知道你一定會這麼說！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "既然學長一言既出，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那麼就請學長做切嚕做馬！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒有啦，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_079"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我應該……",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n認真地說，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "謝謝學長，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "感激不盡。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這樣說才對……",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_080"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嘿嘿。",
        "unit_id": 116311
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我想要，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_081"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "創造許許多多快樂的回憶。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我想要，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_082"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在青春這個季節玩個徹底。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "神聖學院的祭典，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_083"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還想要",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "再延長一下子。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那麼我──",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_084"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那麼琪愛兒我，",
        "unit_id": 116311,
        "voice": "vo_adv_1163001_085"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就要給它切嚕到底，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不留一絲遺憾。",
        "unit_id": 116311
    }
]