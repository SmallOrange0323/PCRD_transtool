    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "～為什麼啊！我這個笨蛋！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可別以為我只有被侵蝕的份喔……？",
