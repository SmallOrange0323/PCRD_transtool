    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我一定會理解這所有一切的……！",
