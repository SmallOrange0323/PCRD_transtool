[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與{player}重逢後過了幾天，在某個日子，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拉比林斯達和璃乃跟靜流"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一起賣力地製作著可麗餅。"
    },
    {
        "type": "still",
        "still": "121200101"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓您久等了。",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這是",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抹茶紅豆奶油口味！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "謝謝妳～！",
        "unit_id": 1,
        "voice": "vo_adv_1212002_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然後這一份是──",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_002"
    },
    {
        "type": "still",
        "still": "121200102"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "！！",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_003"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "啊！",
        "unit_id": 1,
        "voice": "vo_adv_1212002_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對不起！",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我馬上為您重做一份……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……靜流、璃乃。",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我想先讓妳們自己顧店，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以拜託妳們嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們是沒什麼問題……",
        "unit_id": 104914,
        "voice": "vo_adv_1212002_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會長，",
        "unit_id": 101112,
        "voice": "vo_adv_1212002_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳還好嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不久之前是沒什麼問題啦。",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但保險起見，我去幫自己做個檢查，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n妳們就先做新的可麗餅給客人吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "了解！",
        "unit_id": 101112,
        "voice": "vo_adv_1212002_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳要保重喔，",
        "unit_id": 104914,
        "voice": "vo_adv_1212002_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會長！",
        "unit_id": 104914
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好了……",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "總之我就先幫自己診療一下吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不知道結果",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是吉是兇……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯……",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒有異狀啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……這真是奇怪極了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒有異狀的異狀嗎……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果目前為止都沒有痕跡和變化，",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就不是由我這個本體，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n而是與我相關的外部因素所導致的現象……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "菲歐，妳在嗎～？",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很抱歉這麼突然，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但我想跟妳確認一下跟少年有關的事情……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "晶！",
        "unit_id": 190011,
        "voice": "vo_adv_1212002_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "太好了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想找妳確認一件……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……發生什麼事情了？",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從不久前開始，",
        "unit_id": 190011,
        "voice": "vo_adv_1212002_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就沒辦法連接上{player}被隔離出來的精神了！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以前明明沒有",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "發生過這樣的事情，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "為什麼突然……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "隔離？",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原來他需要採取這麼嚴重的處置嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n而且妖精竟然無法主動與玩家接觸……？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但這個功能應該沒有發生異常啊……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且包括他的精神在內，",
        "unit_id": 190011,
        "voice": "vo_adv_1212002_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我從這裡什麼都感應不到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "晶，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可以請妳那邊調查一下這件事嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "當然沒問題。",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我馬上來嘗試與少年接觸。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n如果知道了什麼，我再跟妳分享情報。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "拜託妳了！",
        "unit_id": 190011,
        "voice": "vo_adv_1212002_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……狀況似乎糟糕到超乎預期啊。",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "希望少年他沒事……",
        "unit_id": 106812
    },
    {
        "type": "background",
        "background": "500360"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你好～！",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有人在嗎～？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……都沒人在？",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有少年在啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但這真是太好了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n他有在好好睡覺。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "肉體是平安的……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "打擾一下囉。",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒想到，",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我居然會有把七冠的權能用在擅自闖入民宅的這一天……",
        "unit_id": 106812
    },
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗨，少年。",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你睡得真香啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……不對。",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這不是在睡覺。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這已經不是那個層級的狀態了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就讓我看看吧。",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看看你身上發生了什麼事情。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n開始連線──",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──咦？",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "連不上去……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這怎麼可能。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "既然如此，就算有點強硬，我也要連線上去！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──！",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唔！",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這邊主動發出的連線",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一點都不穩定……！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n而且間隔越來越大了！　",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "再這樣下去就糟了……！",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n至少暫時先把公主騎士之力，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "回收到我這邊──",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗚",
        "unit_id": 106812,
        "voice": "vo_adv_1212002_036"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗚唔……",
        "unit_id": 106814,
        "voice": "vo_adv_1212002_037"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "糟糕！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n少年！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "行不通嗎……",
        "unit_id": 106814,
        "voice": "vo_adv_1212002_038"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可惡！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n怎麼會發生這種事情……",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年的座標……",
        "unit_id": 106814,
