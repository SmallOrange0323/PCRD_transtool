        "voice": "vo_adv_1212002_041"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我無論如何都會完成對「你」的分析……！",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106814
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我怎麼能",
