[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "糟了～遲到了遲到了！",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "討厭，",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我真是笨蛋！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n明明已經睡過頭沒時間了，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還顧著一直打扮！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可是可是，",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "睡亂的毛髮完全整理不好呀！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n而且只要去城鎮附近，就有可能被人看見～？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "可不能就一副邋遢的樣子，\n連平常都很容易被人誤會了！",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是不像普通人類一樣打扮，\n說不定又會被當成魔物，被弓箭攻擊也說不定～！",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這次沒問題了吧，\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家可是有用現在流行的時尚風格做打扮！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而且為了預防被人誤會攻擊，\n姑且也帶了武器和防具來保護自己！",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "討厭。實在不想這樣小心翼翼的呢，",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n為什麼人家的外表和其他女孩子不一樣呢？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "明明人家所說的話，還有內心，都和一般人類一樣！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唉呀～就算哀怨也沒有用……",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n畢竟生來就是這樣了，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而且也有人願意接受這樣的我。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "【伊麗莎白牧場】的大家，\n也把我當成一般的人類對待，愛護著我……",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過總是被保護、被好好對待，讓我很不好意思。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "【伊麗莎白牧場】的工作，\n我也會幫忙。",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這一次，只要把採伐的木材運送到指定的地方就行了吧。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然木材很重……",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，我很有力氣，所以沒問題♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唉呀……！？\n糟了",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "，不小心撞到人了！？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "對不起，都怪人家太趕了……",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n沒事吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n有沒有受傷？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，對不起哦～……　",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呃，站得起來嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "讓人家拉你一把，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘿咻♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，如你所見人家渾身軟綿綿的呢！",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這身毛皮成了柔軟的緩衝，完全沒受傷哦？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你看，還穿著鎧甲，防禦很完美♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻，謝謝你擔心我♪",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？\n啊啊，我叫莉瑪。",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為有點工作，正在去蘭德索爾的路上～",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你，叫做{player}對吧？\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "請多指教～♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……你，並不怕我吧。",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_019"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真是怪人……",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大家看到我的時候，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n大部分都會大喊『有魔物！』就逃跑了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "更過分的時候，還會說『看我解決妳～！』接著就被攻擊呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不是不是，人家不是魔物哦？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "至少，人家自認為是個普通人類……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n只不過是外表和大家有點不同而已。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "像我這種存在，",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_022"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "似乎非常稀有……\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不是普通人類、不是獸人、不是精靈族、更不是魔族，\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而是連在其他世界也沒有類似例子的特別種族。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，真陽替我做了很多很多調查……",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊啊，真陽是保護我的人，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n同時是【伊麗莎白牧場】的經營者。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔？",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_024"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n你正在送信去牧場的路上？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊啊，這裡是連接蘭德索爾和牧場的街道呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你是隸屬於運送郵件的公會的人嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不是？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是以個人身分承接工作的啊，這樣啊？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "工作辛苦了。\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻。撞到你真的很抱歉……那封信，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就由我替你送去【伊麗莎白牧場】吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。我只要把木材搬運到城鎮附近後，",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n接著也要回牧場呢。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我就順便替你送信吧。",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_028"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還得特意爬上山到牧場去，很辛苦對吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我也進不了城鎮內……",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_029"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n工作結束後，得立刻回去才行。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不然",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人們會大喊『魔物侵入城鎮了！』之類的，引起大騷動呢",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "放心吧。\n人家不是山羊，不會把信吃掉的。",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_030"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "會好～好送到牧場的。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？因為是自己承接的工作，",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_031"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以想要親自送信過去？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n真認",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "真呢～嘻嘻♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哦唷。\n人家都忘記快遲到了，",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_032"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "得繼續趕路才行。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "抱歉哦，原本要給你賠罪的……",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_033"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n下次再說，好嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "應該還會再見面吧？\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052001_034"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家總覺得很中意你呢♪",
        "unit_id": 105211
    }
]