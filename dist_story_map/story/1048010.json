    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "果然鎧甲穿起來才讓人安心呢～♪",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過話又說回來，",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "秋乃那傢伙……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "說什麼",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "「我是不懂妳那究極的效率還是什麼的，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但妳太亂來了！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n明天去休息一天！」",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嘛。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我一說我摧毀了強盜集團，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "連珠希和優花梨她們",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n也默默地拿了健康檢查手冊給我。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真是的，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "大家都太愛操心了啦。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……算了，",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_003"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "感覺是不差啦。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "反正公會好像也會把這視為有薪假，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n偶爾就悠哉地",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "度過自己的時間吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "──沒錯！",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n來度過這享受家庭代工的時間吧！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……啊啊～～",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "感覺真平靜～～♪",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不但能活動身體，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還能鍛鍊精神，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且居然還會賺到錢……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "果然",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "做家庭代工真是太棒了！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我好想",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就這樣一直做下去～♪",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "美冬小姐～",
        "unit_id": 412,
        "voice": "vo_adv_1048010_007"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "檢查看起來是沒什麼大問題，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n但是，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "姑且還是請妳暫時等到",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "所有結果都出來為止。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n不然，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "妳也可以在那邊的床上睡覺……",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "咦……",
        "unit_id": 412,
        "voice": "vo_adv_1048010_008"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "妳為什麼要穿鎧甲？",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n而、",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "而且還在做家庭代工？",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦……",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣很普通吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "不，那個……",
        "unit_id": 412,
        "voice": "vo_adv_1048010_010"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "我想可能不太普通。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為我正在靜養，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "才會穿這樣做家庭代工啊。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n想一下就知道了吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "那個……",
        "unit_id": 412,
        "voice": "vo_adv_1048010_012"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "我完全不懂妳的意思，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n可以請妳說明一下嗎？",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "待在醫院裡要好好靜養。",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n所以",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不可能讓人穿著鎧甲，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "做需要活動身體的家庭代工。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳想說的就是這些吧。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "是、",
        "unit_id": 412,
        "voice": "vo_adv_1048010_014"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "是啊。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "首先",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是關於活動身體這部分，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我要",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "活動雙手才會感到放心。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n所以這樣做",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對我來說就是休息。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "原、",
        "unit_id": 412,
        "voice": "vo_adv_1048010_016"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "原來如此。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "接著是家庭代工……",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這是",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n為了",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "替剛才說的活動雙手這項行為",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "賦予一個目的才做的。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "別看我這樣，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我一邊在靜養，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "一邊還有在賺錢喔。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "也不是不能理解……",
        "unit_id": 412,
        "voice": "vo_adv_1048010_018"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "吧？",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "並且，",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "想完美地進行這種家庭代工，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n需要轉換心態……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "正因如此，我才會",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "穿上鎧甲",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "來做家庭代工啊！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "只有這點我無法理解～～！！",
        "unit_id": 412,
        "voice": "vo_adv_1048010_020"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "算、",
        "unit_id": 412,
        "voice": "vo_adv_1048010_021"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "算了，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "我就睜一隻眼閉一隻眼吧。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "對了，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "還有事必須通知美冬小姐。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "唉呀，",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是什麼事？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "剛才櫃台",
        "unit_id": 412,
        "voice": "vo_adv_1048010_023"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "來了一個男生說要探訪美冬小姐妳。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n他說是來看檢查的情況的，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n所以我想應該很快就會過來了。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "…………！？",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_024"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "怎、",
        "unit_id": 412,
        "voice": "vo_adv_1048010_025"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "怎怎、",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "怎麼了嗎，美冬小姐！？",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n妳把家庭代工做的人偶給捏碎了耶！",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "男、",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "男男、",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "男生……？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個男生……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是什麼樣的人……？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "那個，",
        "unit_id": 412,
        "voice": "vo_adv_1048010_027"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "是個黑髮穿著披風的男生。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n還有……",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯，",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_028"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我已經知道是誰了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……應該說",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "仔細想想，會來見我的男生，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就只有{player}嘛。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我、",
        "unit_id": 104811,
        "voice": "vo_adv_1048010_029"
    },
    {
