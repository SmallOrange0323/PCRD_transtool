[
    {
        "type": "background",
        "background": "509015"
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你居然會邀我來場生日約會，",
        "unit_id": 105032,
        "voice": "vo_adv_4010235_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "以你而言還算蠻機靈的嘛♪",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "身為一位又變得更成熟的淑女，我特地前來奉陪，",
        "unit_id": 105032,
        "voice": "vo_adv_4010235_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n要是沒給我最棒的約會，我可不會饒過你喔！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 105032,
        "voice": "vo_adv_4010235_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "畢竟是這傢伙規劃的，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "八成只會去遊戲中心或懷舊點心店這種地方吧。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "想享受很有氣氛的、",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "在電視劇裡看過的成熟約會，應該很難……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊……",
        "unit_id": 105032,
        "voice": "vo_adv_4010235_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要牽手啊？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……嗯，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒關係啊，我不介意！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我才沒有害羞呢！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "又不是小孩子了！",
        "unit_id": 105032
    },
    {
        "type": "background",
        "background": "510390"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哦……",
        "unit_id": 105032,
        "voice": "vo_adv_4010235_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我還以為你會帶我去玩玩遊戲或吃吃喝喝，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n但原來你也知道這種氣氛不錯的地方啊。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是說……",
        "unit_id": 105032,
        "voice": "vo_adv_4010235_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你之前",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也曾經讓我見過美麗的櫻花道。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你其實比我以為的還要懂得製造浪漫嘛♪",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "氣氛營造得很完美喔。",
        "unit_id": 105032,
        "voice": "vo_adv_4010235_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你接下來要給我什麼驚喜呢？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呀……！",
        "unit_id": 105032,
        "voice": "vo_adv_4010235_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這個是",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "皇冠……？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呵呵，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "居然懂得送我首飾當生日禮物，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "很有品味嘛……♪",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嚇我一跳……",
        "unit_id": 105032,
        "voice": "vo_adv_4010235_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我還以為他會跟平時一樣摸摸我的頭，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n把我當小孩子對待的……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呵呵，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "看來這傢伙",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n也以自己的方式努力地為我規劃了成熟的約會呢。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……但是……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "謝謝。",
        "unit_id": 105032,
        "voice": "vo_adv_4010235_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "今天的你，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "表現得非常好喔♪",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但是，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你有點太刻意要讓自己成熟點了，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "表情很僵硬呢。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你平常的表情就是最棒的，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "把臉頰",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "借我摸一下吧！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "看我～",
        "unit_id": 105032,
        "voice": "vo_adv_4010235_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "的，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "揉揉捏捏～♪",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……呵呵，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "果然你就是該這樣才對♪",
        "unit_id": 105032
    }
]