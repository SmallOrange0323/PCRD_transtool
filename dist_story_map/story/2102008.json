    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要記得幫我和你媽媽說一聲喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "深月醫生～",
        "unit_id": 415,
        "voice": "vo_adv_2102008_007"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "真的很謝謝妳～！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……",
        "unit_id": 416,
        "voice": "vo_adv_2102008_008"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "可是，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "深月醫生……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n我們家",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "沒什麼錢……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n而且被魔物破壞掉的屋子，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "現在也還在修……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "所以做為交換，",
        "unit_id": 415,
        "voice": "vo_adv_2102008_009"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "請讓哥哥和我",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n當醫生的『實驗品』吧！　",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "拜託妳了！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嗯！",
        "unit_id": 416,
        "voice": "vo_adv_2102008_010"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n我們",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不管是多痛的打針，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n還是多苦的藥，都會忍耐下來的！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……嗯嗯。",
        "unit_id": 105111,
        "voice": "vo_adv_2102008_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你們都是乖孩子呢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我很高興喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……不過。",
        "unit_id": 105111,
        "voice": "vo_adv_2102008_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我現在想要測試的藥品，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是成人用的……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n所以等你們再長大一些後，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "再拜託你們囉♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦，",
        "unit_id": 105611,
        "voice": "vo_adv_2102008_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小鬼頭們！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果你們要回去了，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就把這些東西也帶上吧！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "哇！",
        "unit_id": 415,
        "voice": "vo_adv_2102008_014"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "是魚呀～！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "竟然有這麼多，",
        "unit_id": 416,
        "voice": "vo_adv_2102008_015"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "真的可以嗎！？",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不小心釣得太多了一點嘛。",
        "unit_id": 105611,
        "voice": "vo_adv_2102008_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們幾個人也吃不完呢，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你們就當幫我一個忙，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "拿走吧！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "流夏小姐，",
        "unit_id": 415,
        "voice": "vo_adv_2102008_017"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "謝謝妳～！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我們會多吃一點，",
        "unit_id": 416,
        "voice": "vo_adv_2102008_018"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "然後趕快長大的！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n這樣就能當醫生的『實驗品』了！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今天來看診的患者，",
        "unit_id": 102711,
        "voice": "vo_adv_2102008_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那幾個孩子就是最後的了……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您辛苦了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "謝謝妳，惠理子……",
        "unit_id": 105111,
        "voice": "vo_adv_2102008_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓妳來幫我。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不客氣，",
        "unit_id": 102711,
        "voice": "vo_adv_2102008_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "深月。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "和霸瞳皇帝的戰鬥剛結束時，",
        "unit_id": 102711,
        "voice": "vo_adv_2102008_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n城內到處都是傷患……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "幾乎就像是野戰醫院一樣的慘狀。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但這一陣子，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "似乎終於平靜下來了的樣子呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這也是",
        "unit_id": 105611,
        "voice": "vo_adv_2102008_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "『醫生』的技術不錯的緣故嘛。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "下城區這邊的人們也相當信賴你……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼樣？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n要不要乾脆別當什麼密醫了，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "改做一個普通的醫生如何？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那就是光明醫師",
        "unit_id": 101311,
        "voice": "vo_adv_2102008_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "了呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇呀，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好刺眼～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然是可貴的機會……",
        "unit_id": 105111,
        "voice": "vo_adv_2102008_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但還是讓我拒絕吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "畢竟我的本質，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "果然還是想做實驗和研究呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這次會像這樣出手助人，",
        "unit_id": 105111,
        "voice": "vo_adv_2102008_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n也只是想要試試看",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我所累積的知識與藥品，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "究竟能派上多少用場而已。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n其他的……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "其他的……",
        "unit_id": 105111,
        "voice": "vo_adv_2102008_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果我說是被{player}的\n爛好人所傳染了",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也說不定的話……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n惠理子會露出怎樣的表情呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唷呵呵呵呵……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "話又說回來",
        "unit_id": 100911,
        "voice": "vo_adv_2102008_028"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呀……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不但我等宿敵之『組織』的活動音訊全無，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n沒想到就連那個『暮光之都』的情報，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也是虛假的……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "如此平穩的日子，",
        "unit_id": 100911,
        "voice": "vo_adv_2102008_029"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我這魔瞳都快被倦怠的浪潮給吞沒，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n蒙上一層灰了呀！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "究竟何處有著小說的靈感……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "非也，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "究竟哪裡有",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "憾動心靈之事呀……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "簡單說",
        "unit_id": 101311,
        "voice": "vo_adv_2102008_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是閒到發慌笑死人！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "根本笑不出來啊……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有沒有什麼有趣的事情呀喵～？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有趣的事情嗎……",
        "unit_id": 102711,
        "voice": "vo_adv_2102008_031"
    },
