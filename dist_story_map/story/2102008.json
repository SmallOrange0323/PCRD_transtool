    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為還含有一些魔物的毒，",
        "unit_id": 105111,
        "voice": "vo_adv_2102008_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n所以要痊癒還得花點時間……",
