[
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "トモたちとの激闘の末、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nカガミが自らの正体を明かし逮捕されたことにより、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nランドソルは一時、騒然となった。"
    },
    {
        "type": "background",
        "background": "500580"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "──それから二日後。ランフェス最終日。"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nランドソルはある程度落ち着きを取り戻していた。"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "ナナカとリンはランフェスを楽しむべく、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n{player}と共に、再び会場を訪れたのだった。"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "や～",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_000"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "いろいろとあったけども！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nこうして平和になったフェスを見て回れるなんて幸せですぞ～！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ま、",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_001"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そだね。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "とはいえ……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n配信界隈の方はまだ結構ごたついてるっぽいけど。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "無理もないけどね。",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_002"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "トップ配信者が急にいなくなったんだから。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nけど、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "これから、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "新しい時代が始まって……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nまた新しい人気配信者が生まれるんだろうね。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "今度は問題起こしたり、",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_003"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nナナカの魔法を斬ったりしないゲーム実況者に\n頂点に立ってほしいもんだね。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "……って、",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_004"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あれ。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あそこにいるのは……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "あああ、",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_005"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "どうしよう……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n見て回りたいところがたくさんある……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ゲーム展示会で最新ゲームのチェックもしたいし……",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_006"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nそれからフィギュアの展示も行われてるらしいから見てみたいな……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "……なんかはっちゃけてんね、",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_007"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "トモ。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "はっ！？　",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_008"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "リンさん！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nそれに、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ナナカさんとあなたも……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ここで会うなんて奇遇だね、",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_009"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "トモ殿！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nいろいろ気になってるところあるっぽいけど、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nそれなら私たちと一緒に行かない？　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "絶対楽しいからさ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ああ、",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_010"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "いや……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "お誘いしてもらえるのはうれしいですけど……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n【王宮騎士団（NIGHTMARE）】として、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nフェスの警備にあたっているところなので……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "遊びに行くわけには……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "そのことについては気にしなくてもいいさ。",
        "unit_id": 104711,
        "voice": "vo_adv_5102008_011"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n遊びに行きたいのなら許可するとも。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ジュンさん！　",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_012"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "いいんですか……！？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "ああ。",
        "unit_id": 104711,
        "voice": "vo_adv_5102008_013"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "もちろん。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "というか、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "遊んできてほしい。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nトモちゃんはフェスでの任務を本当に頑張ってくれたからね。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n存分に楽しんでくるといい。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "おお！　",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_014"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "それはよかったですな～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "トモ殿！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "……ところで、",
        "unit_id": 104711,
        "voice": "vo_adv_5102008_015"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "ちょうどよかった。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nカガミちゃんについて、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "君たちにも伝えておこうと思ってね。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "逮捕されたカガミちゃんだが、",
        "unit_id": 104711,
        "voice": "vo_adv_5102008_016"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nもちろん、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "これまでの自らの犯行を認めている。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n今までにやってきたことを心から悔いているようだ。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "それと……",
        "unit_id": 104711,
        "voice": "vo_adv_5102008_017"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "トモちゃん宛の言付けを預かっている。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "私に……？",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_018"
    },
    {
        "type": "dialogue",
        "name": "カガミ",
        "words": "……トモちゃんにはランドソル一の剣士になれるだけの才覚がある。",
        "unit_id": 16712,
        "voice": "vo_adv_5102008_019"
    },
    {
        "type": "dialogue",
        "name": "カガミ",
        "words": "\n好きなものを心の支えに、",
        "unit_id": 16712
    },
    {
        "type": "dialogue",
        "name": "カガミ",
        "words": "剣の道を進んでほしい。",
        "unit_id": 16712
    },
    {
        "type": "dialogue",
        "name": "カガミ",
        "words": "\n応援しているよ。",
        "unit_id": 16712
    },
    {
        "type": "dialogue",
        "name": "カガミ",
        "words": "君のファンより……",
        "unit_id": 16712
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "……とのことだ。",
        "unit_id": 104711,
        "voice": "vo_adv_5102008_020"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "……ありがとうございます。",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_021"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n応援されたからには……頑張らないと、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ですね。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "うん。",
        "unit_id": 104711,
        "voice": "vo_adv_5102008_022"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "私も応援しているよ。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "……それにしても。",
        "unit_id": 104711,
        "voice": "vo_adv_5102008_023"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "さっきから思っていたんだが……\nずいぶんと晴れ晴れとした顔をしているね、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "トモちゃん。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "そうですか？　",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_024"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "だとすれば……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n自分に素直になろうと決めたからかもしれません。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "自分の好きなものは、",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_025"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "好きだと言おうって！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "そうか。",
        "unit_id": 104711,
        "voice": "vo_adv_5102008_026"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "フェスではいろいろと大変だったと思うけど……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\n同時に、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "トモちゃんにとっていい経験になったようだね。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "今回は本当にお疲れさま。",
        "unit_id": 104711,
        "voice": "vo_adv_5102008_027"
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "\nさあ。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "ジュン",
        "words": "遊んでくるといい。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "はいっ！　",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_028"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "それじゃあ、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "まずは……！",
        "unit_id": 123611
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "サークル主",
        "words": "……あっ。",
        "unit_id": 1,
        "voice": "vo_adv_5102008_029"
    },
    {
        "type": "dialogue",
        "name": "サークル主",
        "words": "先日のシャイニー★トモに似てる方。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "サークル主",
        "words": "\nまた、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "サークル主",
        "words": "いらしてくれたんですね。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "はい。",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_030"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "あの本が、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "どうしても欲しくて来たんですけど……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nまだ、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "置いてあったりしますか……？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "サークル主",
        "words": "あ、",
        "unit_id": 1,
        "voice": "vo_adv_5102008_031"
    },
    {
        "type": "dialogue",
        "name": "サークル主",
        "words": "全然あります。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "サークル主",
        "words": "\nえへへ……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "サークル主",
        "words": "どうしても欲しい、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "サークル主",
        "words": "なんて初めて言われました。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "サークル主",
        "words": "\nはい、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "サークル主",
        "words": "どうぞ。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ありがとうございます……！",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_032"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nふふっ。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "初めて魔法少女の同人誌買っちゃった……♪",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "それもまさか自分のなんて……！",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_033"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nある意味では役得かも……！　",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "改めて見ても、",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_034"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "表紙からかなり力が入ってるね！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nこの決めポーズ再現がすごすぎる……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "トモ殿は、",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_035"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "本当に魔法少女が好きなんですなあ。",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nムフフ……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "これはナナカちゃんの\n魔法少女秘蔵コレクションが火を噴く時かもしれませんぞ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "えっ、",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_036"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "見たい……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nというか、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ナナカさんと魔法少女トークをしてみたい……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "……ついこの間は魔法少女とか興味ないって言ってたのにね。",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_037"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nま、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "なんかうれしそうだし、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "いっか。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "で、",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_038"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "次はどこ行く？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n一応、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "最後まで付き合うよ。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "え、",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_039"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "じゃあ、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "今度は……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "そうして、トモはナナカたちと一緒に会場を見て回り、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n思う存分、楽しんだのだった。"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "や～",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_040"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "すっかりフェスを満喫しましたなぁ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n『魔法少女セリイちゃん』のハロウィンバージョンフィギュアを\nたっぷり眺めたり、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "企業ブースをいろいろ見て回ったり！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "同人誌も結構買ったね～",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_041"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nナナカはどんなのゲットしたの？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ふっふっふ……",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_042"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "気になっちゃう？　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "じゃあ、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "お見せしよう！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nじゃじゃんっ！　",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "『ドングリレンジャーvsトワイライトキャラバン』！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "いや。",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_043"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "どう考えても負けでしょ、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あたしの。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nオーバーキル過ぎる。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ナナカ一人相手だろうと手も足も出ないっての。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "大丈夫！　",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_044"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "こういうvsものはたいてい、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nなんやかんや共通の敵が現れて共闘するパターンだから！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ちなみに！　",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_045"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ランドソルでは割とナマモノが許されてる風潮だけど……",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nトーゴクとかの同人誌即売会では相当センシティブらしいよ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nこっちのとはいろいろと違いがあるから、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "その辺は気をつけるように！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "まあ、",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_046"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あたしたちは描かれてる側で描く側じゃないから、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n気をつけるもなにもないんだけど。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "覚えておきはするよ。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "それはそれとして……",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_047"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nフェスはどうだった、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "トモ？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "……楽しかったです。",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_048"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n本当に、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "胸がいっぱいになるくらいに……楽しかった。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そか。",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_049"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "なら、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "良かったんじゃん？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "……そうだ。",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_050"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "前にも誘ったけどさ。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nあたしたち、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "時々ゲーム会やってるって言ったでしょ？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "興味あったら、",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_051"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "いつでも来てくれていいからさ。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nまた一緒にゲームやろーよ。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "好きなんでしょ、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ゲーム。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "……一度断ってしまったのに、",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_052"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "いいんですか？",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nゲームの面白さが理解できないなんて、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n失礼なことまで言ってしまったのに……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そんなのどうでもいいって。",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_053"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n４人対戦のゲームがあるんだけどさ。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n３人で協力してヨリヨリを倒そう。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "３人がかりでも勝てるかどうか！",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_054"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n魔王みたいな強さだからね、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "ヨリ殿ってば！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "そこまで……！？",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_055"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nけど……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "挑みがいがあって、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "楽しそうだ……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "じゃ、",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_056"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "決まりね。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "今度、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "みんなで遊ぼう。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "そんじゃあ、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "疲れたし、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "あたしはそろそろ帰る。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\n帰って、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "寝る。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "いや、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "違うな。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "寝て、",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "帰る。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ナナカ、",
        "unit_id": 123511,
        "voice": "vo_adv_5102008_057"
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "またベッド出して。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "ギルドハウスまで送ってって。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "リン",
        "words": "\nなんならここから近い【自警団（カォン）】の方でもいいからさ。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "全く、",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_058"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "世話が焼けますな～",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nま、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "リン殿ってば今回のフェスじゃいろいろ頑張ったからね！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n全然、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "送ってあげるよ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "では、",
        "unit_id": 113311,
        "voice": "vo_adv_5102008_059"
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "そういうわけでおさらば！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\n帰ったら同人誌やら、",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "同人魔導書やら整理しなきゃ！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "ナナカ",
        "words": "\nその時間も楽しいんだよね！",
        "unit_id": 113311
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "……二人とも、",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_060"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "行ってしまった。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n……私たちも、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "そろそろ帰ろうか。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "……うん。",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_061"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "私もそう思う。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n大切なことに気付けたからね。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "私は、",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_062"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ゲームが好きだ。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "コスプレだって、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "漫画だって。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nそして、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "なにより……",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "魔法少女が大好きだ。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "もしかすると、",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_063"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "大人になるにつれて、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\n好きなものが変わったりもするかもしれない。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "\nけれど、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "それはそれで構わないのだと思う。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "大事なのは……",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_064"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "好きだという気持ちに素直になること。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "私は、",
        "unit_id": 123611,
        "voice": "vo_adv_5102008_065"
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "私の好きをつらぬく。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "これからも、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "トモ",
        "words": "ずっと──",
        "unit_id": 123611
    }
]