    },
    {
        "type": "dialogue",
        "name": "怪物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怪物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是魔物……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "大家要小心喔！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "先下手為強！　日和，我們出手吧！",
        "unit_id": 100312,
        "voice": "vo_adv_3007001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇哇！　等一下呀，怜！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "優衣，請妳幫忙支援！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "騎士先生，我們該怎麼辦……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "明白了！首先，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是停止魔物的行動對吧！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這個是最後了！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看我的！",
        "unit_id": 100312,
        "voice": "vo_adv_3007001_006"
    },
    {
        "type": "background",
        "background": "500230"
    },
    {
        "type": "dialogue",
        "name": "怪物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怪物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼……大家辛苦了！",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "果然來到這裡之後，強勁的魔物也增加了呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是啊，但我們也已經變強了。",
        "unit_id": 100312,
        "voice": "vo_adv_3007001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "證據就是我們也收集了相當多的魔珠。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n還差一點點就可以達到目標了。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "對呀！如果是我們4人的話，",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n一定可以抵達索爾之塔的頂峰喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "然後……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在塔頂之上，實現願望……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_010"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……今天，又做了一樣的夢……",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "(在夢中出現的那些人是誰……？",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有，在索爾之塔的塔頂能實現願望的事情……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我一直以為，那只是給小孩子聽的童話故事而已……)",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "(雖然我只能朦朧地想起她們的身影，",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但對於在夢中的我來說，那些人",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n似乎是非常重要的存在……)",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（如果真的有機會能碰面……還真想看看她們呢……）",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唉呀！",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喔喔！真抱歉。",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真抱歉！兩位都沒事吧？",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒事的。我們只是稍微互撞了一下。",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就好了。不小心就看著塔頂看到出神……",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也是在盯著索爾之塔看的時候，",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不知不覺就移動了身體……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也是因為仰望著高塔，",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n而沒注意到四周環境。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以請您不要介意。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這麼說來，",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們都是在仰望著這座塔呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總會有些稀奇的事情呢……",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呀，忘記了報上自己的名字。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我是――",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "來人呀！有小偷呀！",
        "unit_id": 411,
        "voice": "vo_adv_3007001_024"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "呿！大聲叫吵死人啦！放開我，妳這個女人！",
        "unit_id": 811,
        "voice": "vo_adv_3007001_025"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "嗚嗚！",
        "unit_id": 411,
        "voice": "vo_adv_3007001_026"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "誰可以幫我把錢包搶回來……！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "通通給我滾開！不滾開的傢伙，我可是不會輕易放過你的啊！",
        "unit_id": 811,
        "voice": "vo_adv_3007001_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "居然在這種地方搶東西……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個小偷，往我們的方向過來了耶……",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我說兩位。小偷就由我們來抓吧！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "辦、辦得到嗎…？",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然是和我無關的閒事啦。",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……但是，如果對方打算朝我們這裡硬碰硬，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那我只好採取相應的手段了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "什麼！？不想受傷的話就快給我讓路！",
        "unit_id": 811,
        "voice": "vo_adv_3007001_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "首先停止他的行動吧！",
        "unit_id": 100312,
        "voice": "vo_adv_3007001_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n然後就交給我們來！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我試試看……！喝啊！",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_035"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "嗚喔！",
        "unit_id": 811,
        "voice": "vo_adv_3007001_036"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "妳想跟我打嗎！還真有膽量呢！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚呀！",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_037"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "對、對不起！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "幹得好，那傢伙停下腳步了！",
        "unit_id": 100312,
        "voice": "vo_adv_3007001_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看我的！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "咳喔～！！",
        "unit_id": 811,
        "voice": "vo_adv_3007001_039"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "最後由我來收尾！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_040"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就請你把錢包還來囉！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚喵喵喵呀～！！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "啊～！！",
        "unit_id": 811,
        "voice": "vo_adv_3007001_041"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "跟我走吧！",
        "unit_id": 711,
        "voice": "vo_adv_3007001_042"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n我會好好地審問，看看你有沒有犯下其他的罪！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "小偷",
        "words": "嗚……可惡……！",
        "unit_id": 811,
        "voice": "vo_adv_3007001_043"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "真的很感激妳們……！",
        "unit_id": 411,
        "voice": "vo_adv_3007001_044"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這份恩情改天一定會回報！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "兩位真厲害！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_045"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣就一切搞定！勝利勝利（V字手勢）！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯，太好了呢……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_046"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真沒想到會那麼順利……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說得沒錯……但你的牽制行動相當準確。",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯～，妳的名字是……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼說來我還沒自我介紹吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我是怜。請多指教。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我是優衣。",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_048"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜妳們的攻擊也很厲害呢。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我是日和！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_049"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感覺我們的行動有如不是初次合作般的順利呢！　想起來就和在夢境中所見的一樣呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "夢……那麼說來，妳們兩位為甚麼仰望那座塔呢？",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_050"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個阿，",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_051"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "其實我，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天雖然是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n第一次看見索爾之塔，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但在夢裡面",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n已經看好多次了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "夢中……那個，",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_052"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "是不是有和誰一起",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n在各種各樣的地方冒險……然後……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……為了能實現願望，以索爾之塔的塔頂為目標。",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_053"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n妳是想這麼說吧，優衣。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜，為甚麼妳會……！？",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_054"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……當然囉。我也做了一樣的夢啊。",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_055"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一而再再而三，做了很多次呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣的話，會不會怜和優衣就是在夢中與我一同結伴冒險的人呢！？",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_056"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這就很難下定論囉。",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_057"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不過，我們3人看到的夢是一樣內容的可能性很高。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼那麼，我們就確認看看它是不是一樣的吧！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_058"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "與夢中相同，我們大家一起變強……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "以索爾之塔的塔頂為目標……！",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_059"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這想法不差。我們做了相同的夢，",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_060"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n一定有其意義所在。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然我從一開始就打算即使獨自一人也要前往塔頂，不過如果有夥伴的話就更放心了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那就這樣決定了！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_061"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n今後請多多指教！　優衣！　怜！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我才是要請你們多關照。日和。優衣。",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_062"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我今天之內就會完成公會設立的手續。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！　請多關照。日和。怜！",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_063"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，公會名稱和公會長要怎麼辦呢？",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_064"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很遺憾我不是適合領導別人的那塊料。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這個位置就讓給妳們兩位的其中一人吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也不適合當公會長……",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_065"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和，可以拜託妳擔任嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可以喔～那接著就是決定公會名稱對吧！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_066"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……「黎明之星」，",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_067"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "之類的……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼樣？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我覺得這個不錯呀。",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_068"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和妳呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我認為很好！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_069"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "只是……感覺好像忘了什麼重要的事情……",
        "unit_id": 100111
    },
    {
        "type": "still",
        "still": "300700101"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "重要的事情……？",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_070"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……那個，妳是指之前提到的，騎士先生……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳好～。",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_071"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……你是來看索爾之塔的嗎？　為什麼呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊～！　我想起來了！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_072"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n當時還有一個人在啊！　我們的夥伴！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……為什麼這麼重要的事情，會把它給忘了……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是這樣……不知為何沒有想起他的事情。",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_073"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n明明在夢中見過很多次……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難道，你就是夢中的那個他嗎……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果是的話就很令人高興了但……",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_074"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "夢中的事情，你還能想起多少？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "依稀朦朧是嗎……",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_075"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但如果有那個可能性的話，就得確認一下。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我希望你和我們一起組隊，以索爾之塔的塔頂為目標邁進。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或許你和我們所見的夢境相同也說不定。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "而且如果你和我們在一起，",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_076"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n說不定也能想起夢境內容之外的其他事情……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你……意下如何呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了～！　嘿嘿，今後請多多指教喔！　騎士先生！",
        "unit_id": 100111,
        "voice": "vo_adv_3007001_077"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "請多指教囉。",
        "unit_id": 100311,
        "voice": "vo_adv_3007001_078"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯……再一次多多指教喔。騎士先生。",
        "unit_id": 100211,
        "voice": "vo_adv_3007001_079"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以夢境為契機而相遇、聯繫在一起的4人冒險譚，\n即將從這個地點開始──"
    }
]