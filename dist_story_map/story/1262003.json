[
    {
        "type": "background",
        "background": "500950"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "旅行最終日的隔天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n收拾完回程行李的伊莉亞垂頭喪氣地，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n望著原本裝著番茄汁但已空空如也的玻璃杯。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……唉。",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒想到會變成如此意料之外的旅行。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……真是令人感到鬱悶啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "難道幹勁十足地來蜜月旅行這種事就是個錯誤嗎……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "帶了那麼多行李，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "結果幾乎都沒用到。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "特地寫好的行程表和確認清單",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n也是一個都沒有完成。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……雖說如此，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "令人心滿意足的鄉村料理、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "眺望美麗的景色、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n被人民們感謝、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還品嚐到了極品的番茄汁。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這絕非是段糟糕的時光。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這裡是片非常好的土地、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這次也是很好的旅行。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "和那傢伙……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "卻什麼事都沒做到。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如果沒辦法獲得",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "內心唯一想要的東西……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那麼除此之外的東西妾身都不需要啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼。",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真不是支配者該有的",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "膚淺想法啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "越是去想那傢伙的事情，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就會越是失去支配者該有的樣子。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……既然如此，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "乾脆──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──唔嗯。",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "回去古城吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n……「眷屬」啊。",
        "unit_id": 126211
    },
    {
        "type": "background",
        "background": "500142"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯……",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "已經入夜了啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在馬車上晃呀晃的，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就不小心睡著了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔嗯。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然現在已經恢復了原本的模樣，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不過在小孩子狀態的時候還是有些勉強自己，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以可能有點累了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──要是",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這趟旅程全部",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都只是一場喧鬧的夢就好了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "大概到哪裡了？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n太陽也下山了，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是不是差不多也要到蘭德索爾了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣啊。",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "似乎還會花點時間呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這下",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "該在哪裡提出那件事呢……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n說到底，要怎麼提出來比較好？　",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身都不知道自己有這麼膽小呢。",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n明明蘭德索爾已在不遠處，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "旅行就要準備進入尾聲了──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎麼了，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "突然停下馬車……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "瀑布……？",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "知、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "知道了知道了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "從馬車上下去就行了吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不用這樣蹦蹦跳跳！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你是兔子嗎！",
        "unit_id": 126211
    },
    {
        "type": "background",
        "background": "501372"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──這、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這不是……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "猶如幻境一般的美景嗎。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "飄在空中的月亮",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也映照在水面上飄著呢……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真沒想到在蘭德索爾附近",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "能看到如此絕景……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這就是所謂的",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "燈下黑吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你記住妾身說的話了啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n真是聰明的傢伙呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你這傢伙啊……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……天上的月亮",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "和水面上的月亮。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就像在照鏡子一般相似的模樣，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "卻絕對不會有任何交集，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n在遠方相互照映著彼此──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "簡直就跟妾身",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "和這傢伙一樣啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……吶，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n知道「吸血鬼無法渡過流水」",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這件事嗎？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有謠言說",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是吸血鬼的弱點之一。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "其實",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "並沒有這回事。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如果無法渡過流水，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n那就會連沐浴都沒有辦法呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身到最近……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "似乎理解了",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這句話真正的意思。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "流水",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所指的──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也就是區隔不同種族或身分，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那道看不見的邊界。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "站在流水兩側的人",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "肯定互不相容。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "支配者和人民。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吸血鬼和人類。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "主人",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "和眷屬……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你和妾身……",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "肯定也是這樣的吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今後你如果繼續和妾身待在一起，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就算沒有香水之力，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n也會有許多危難降臨到你身上。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "然後",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "即使如此……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你還是會一副無所謂的樣子……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "跟在妾身身旁吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "眷屬啊。",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身對於這樣的你……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n感到無比憐愛，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也感到無比恐懼。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過是出來旅行而已，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就遇到了那種事對吧？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n如果妾身跟你一起私奔的話……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "感覺我們彼此",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "遲早有一天會變得很奇怪。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以乾脆……",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_031"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "跟妾身……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……試試？",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_032"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "究竟在說什麼──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊！？",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你要做什麼！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你不放手嗎……！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你打算帶妾身去哪裡！？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不不不、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_034"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不用來到岸邊",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也能欣賞景色吧～！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "等一下，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "連等都不等嗎！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "算了，不等也沒關係！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但你至少",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "告訴妾身要做什麼吧！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不要不說話！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣會讓人很不安啊！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咦咦！",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_035"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "把妾身帶來這種地方……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n究竟是想要試什麼？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "玩、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_036"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "玩水……？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──停、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "停下！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你要去哪裡！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "該不會",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是打算在這個瀑潭游泳吧！？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不是不太會游泳嗎！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……你說水沒有那麼深？",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_037"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "即、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "即使如此，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "像這樣腰部以下都泡到水裡……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n要是感冒了怎麼辦。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你還不快點回來嗎！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……你、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_038"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_039"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如果讓雙腳",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "踏入眼前的流水裡……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n如果走到那傢伙的身邊……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那傢伙就無法",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_040"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "再回到一般人的生活。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而妾身──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也將不再是支配者、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不再是單純的主人了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……眷、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_041"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "眷屬啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身呢──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔！",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_042"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊啊啊～～～！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n只、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只不過是水而已，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "又能對妾身怎麼樣──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_043"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好冷！？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "才不會冷呢！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "很快",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就會習慣了！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好了，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在那邊等著不要動！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──什麼流水！",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_044"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "什麼邊界！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "支配者應有的模樣？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這種事情",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "由妾身來決定！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n做決定的人才正是支配者不是嗎！　",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的自由，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_045"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "由妾身支配。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這可不是任何人能奪走的！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "流水這種小事，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身可是──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不會屈服的！！　",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……如、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_046"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如何。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣就滿意了嗎。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "結果你",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是想嘗試什麼？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……啊？",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_047"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "該、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "該不會你……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n為了確認妾身說的迷信，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就做出了這種事？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──唔哈哈哈、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_048"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊哈哈哈！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊哈哈哈哈！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身不是說了只是謠言嗎！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為了這個，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你還特地",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n像這樣泡到水裡……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔哈哈哈哈！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哈哈哈哈哈！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是的，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_049"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你還真是個有趣又奇怪的傢伙啊！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n如果這個謠言是真的，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身因此而出了什麼事的話，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你打算怎麼辦？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯。",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_050"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "結果",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也沒發生什麼事呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看來是杞人憂天了呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼……",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_051"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "主人和眷屬，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "我們一個個",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都全身溼透了呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣的話，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要做的事情就只有一個。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你說",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是吧？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_052"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "太天真了！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你剛剛手邊",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在製作水槍這種事，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身早就看穿了！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "反正等一下",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_053"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "會回到妾身的城堡了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "既然如此，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那就讓你全身從頭到腳都濕透吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身就證明給你看──",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_054"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "流水什麼的妾身才不怕！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呼──",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_055"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "一開始覺得水很冰涼刺骨，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "習慣之後就很舒服。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n夜風吹拂在溼透的肌膚上……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "感覺別有一番風味呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "涼爽而帶有濕氣、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_056"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在月光下呈現出藍色調的夜色……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n如果黑夜有香氣，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "或許就是這個味道呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n要是有這種香水，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "想必會很適合現在的妾身吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_057"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "夜晚真好。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n安靜、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "溫柔……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有時溫暖、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有時寒冷。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "夜晚的寂靜",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_058"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "正是妾身所鍾愛、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也是必須由妾身所支配的事物。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾之眷屬啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你也這麼認為嗎？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──唔？",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_059"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哎呀、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哎呀哎呀哎呀……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒有在看天上的月亮，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "反而是對妾身看入迷了啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_060"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這就是所謂",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "美貌水靈動人的吸血鬼呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n再加上月光的妝點……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "簡直是難以用言語形容的美麗對吧？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你似乎很喜歡妾身這副模樣，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_061"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但若是被這樣盯著看……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那個……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n稍微，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有點難為情。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "噯，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_062"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身並不是要怪你盯著妾身看……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但你的視線，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是否有點太沒分寸了？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……不過，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_063"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "終於有一件像蜜月旅行的事情了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n雖然無法否認",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "戲水什麼的有點像小孩子在玩耍──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但不知為何，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_064"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這令人感到十分地神清氣爽。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不是作為支配者，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也不是以主人的身分……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就只是妾身",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "照著妾身自己的想法來行動。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這種自由的感覺，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_065"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "已經多久沒有過了呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真想乾脆",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "把身上的裝束全數褪去。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在那傢伙面前",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不能做出這麼不知羞的事情……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_066"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這也是多虧那傢伙",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "帶著妾身……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n越過了流水前往對岸呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "邂逅從未見過的景色，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_067"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "正是旅行的醍醐味。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n名為自由的未知絕景……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n確實映入了",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的眼簾。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……妾身",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_068"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "得向你道謝才行。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你讓妾身見到了",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在活過的漫長時光中都從未見過的景色。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵，",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_069"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒錯呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也許就是那樣呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……來吧，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今晚",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就原諒你那沒有分寸的視線吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n把妾身的美豔姿態，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好好地烙印在眼裡吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不論經歷多少歲月、",
        "unit_id": 126211,
        "voice": "vo_adv_1262003_070"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "多少危難……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n即使有事物會將妾身和你分隔開來，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也絕對不要忘記喔。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……妾身所選的",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "頭號眷屬啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在溫柔的月光下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n伊莉亞和{player}盡情戲水後，"
    },
    {
        "type": "dialogue",
