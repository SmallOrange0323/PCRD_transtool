        "voice": "vo_adv_9002004_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "配送加油啊！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "再見了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在【龍族巢穴】諸位成員的目送下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}前往原本的配送地點。"
