    {
        "type": "dialogue",
        "name": "旁白",
        "words": "手上拿著神祕書本，{player}走進巷子──"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "呦呦，這位小哥。",
        "unit_id": 811,
        "voice": "vo_adv_9002004_000"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "如果想要通過這裡，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "就把該交的東西交出來吧。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n你明白的吧？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "就是過路費啊。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "什麼？",
        "unit_id": 811,
        "voice": "vo_adv_9002004_001"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "真是有膽子啊。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "反抗我會有什麼後果，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "現在讓你的身體知──",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喝啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_9002004_002"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "唔呀啊啊啊～～！？",
        "unit_id": 811,
        "voice": "vo_adv_9002004_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唷！",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你在這幹嘛？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哦～",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那個啊……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "原來如此呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不要在意。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是我們這裡的事情啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所謂的幫派嘛，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "會握有很多不同的情報啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯……",
        "unit_id": 106611,
        "voice": "vo_adv_9002004_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "居然在這裡見到你～♪",
        "unit_id": 106711,
        "voice": "vo_adv_9002004_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "欸，老大。",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這本書……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是那東西耶。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n好像很有趣，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我們也來試試吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好～",
        "unit_id": 106711,
        "voice": "vo_adv_9002004_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "交給我吧～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這樣才對嘛！",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_011"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是這樣，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以借用一下囉。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不會做什麼壞事的啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是很重要的工作吧……",
        "unit_id": 106611,
        "voice": "vo_adv_9002004_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳看好囉～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我一定會比老大表現得更好的──！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "唉唉……",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_013"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n這股幹勁，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果不是白忙一場就好了……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對了，",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "說來說去，在我們進入艾爾皮斯島時，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n祈梨那傢伙也",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很有幹勁對吧。",
        "unit_id": 106511
    },
    {
        "type": "still",
        "still": "301700201"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那時",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "多虧了你，好好發洩了一番。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n身體深處湧現出了",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "空前絕後的強大力量……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "光是回想，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就覺得亢奮起來了啊！",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "欸，",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你會再把力量借給我們吧！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只要跟死黨在一起，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "感覺無論是什麼對手老娘都不會輸的！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嘉夜～☆",
        "unit_id": 106711,
        "voice": "vo_adv_9002004_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哦！",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "很快呢，老大！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……嗯？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "東西呢？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊嗚嗚……",
        "unit_id": 106611,
        "voice": "vo_adv_9002004_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好累啊～",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈……",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_020"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "照這樣看來，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "似乎全都是讓祈梨做的啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還給你吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "佔用你的時間抱歉啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然是插了其他公會隊伍，",
        "unit_id": 106511,
        "voice": "vo_adv_9002004_021"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但我們",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也受了你諸多關照嘛。",
        "unit_id": 106511
