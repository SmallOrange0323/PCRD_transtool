        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "\n我們的友情之力滋味如何啊？",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "玩具王！",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "太厲害了！",
        "unit_id": 116713,
        "voice": "vo_adv_5068322_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們成功了！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n你很帥氣喔，",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "無敵好朋友號！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "可、",
        "unit_id": 14912,
        "voice": "vo_adv_5068322_002"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "可惡……！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我居然會輸……！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n這就是",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "人類跟玩具之間的",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "真正友情嗎……！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "不，",
        "unit_id": 14912,
        "voice": "vo_adv_5068322_003"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "不可能……",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "是妳們錯了！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n我才是",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "真正的玩具……",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "真正的朋友……！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n唔喔喔喔喔喔…………！！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦、",
        "unit_id": 116911,
        "voice": "vo_adv_5068322_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦……？",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n珠希……？",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "她應該在工廠才對吧，為什麼？",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而",
        "unit_id": 116713,
        "voice": "vo_adv_5068322_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而而",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且連我也在喔〜！？",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "難道我是因為太想交朋友，",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "才終於把自己變成朋友……？",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不，",
        "unit_id": 116911,
        "voice": "vo_adv_5068322_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不可能……",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這會是玩具王扭曲的友情所創造出來的",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "幻影嗎……？",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "居然辦得到這種事情……",
        "unit_id": 116911,
        "voice": "vo_adv_5068322_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們不能讓玩具王再繼續大鬧了！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n再加把勁就行了。",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好了，",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們的宗旨是……",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "碧、美冬",
        "words": "零事故、",
        "unit_id": 1,
        "voice": "vo_adv_5068322_008"
    },
    {
        "type": "dialogue",
        "name": "碧、美冬",
        "words": "無傷亡、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "碧、美冬",
        "words": "效率全開！",
        "unit_id": 1
    }
]