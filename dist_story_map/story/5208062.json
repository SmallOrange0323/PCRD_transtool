[
    {
        "type": "background",
        "background": "502630"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在成功轉移至獵犬座α的世界後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n怜與志那都會合了。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……",
        "unit_id": 108912,
        "voice": "vo_adv_5208062_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n大家都照著自己的步調",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "朝未來邁進了呀。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是啊，",
        "unit_id": 135612,
        "voice": "vo_adv_5208062_001"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "其中尤其讓人期待的，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "果然就是小孩子呢。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n只要聽到他們的笑聲，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就會讓我也覺得很幸福……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊哇哇～！",
        "unit_id": 133212,
        "voice": "vo_adv_5208062_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n桃紅色的棉花糖",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好可愛喔～♪",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……呀啊！？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "哎呀，",
        "unit_id": 135612,
        "voice": "vo_adv_5208062_003"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "妳沒事吧？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "好乖好乖，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "妳沒哭呢，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "真是堅強。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯！",
        "unit_id": 133212,
        "voice": "vo_adv_5208062_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "莫妮卡不會哭！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n可是大姐姐，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對不起，不小心撞到妳……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……咦？",
        "unit_id": 108912,
        "voice": "vo_adv_5208062_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n莫妮卡……？",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊……",
        "unit_id": 133212,
        "voice": "vo_adv_5208062_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "棉花糖掉到地上，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n都沾到沙子了……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗚嗚嗚。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "啊啊，",
        "unit_id": 135612,
        "voice": "vo_adv_5208062_007"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "抱歉。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那我們去那邊的攤販",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "買棉花糖吧。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "或是妳想吃",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "很甜很甜的餡蜜也可以喔。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "等等，志那都！",
        "unit_id": 108912,
        "voice": "vo_adv_5208062_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "耶～",
        "unit_id": 133212,
        "voice": "vo_adv_5208062_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真的嗎！？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n莫妮卡最～～～喜歡甜食了♪",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼……！？",
        "unit_id": 108912,
        "voice": "vo_adv_5208062_010"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……怜。",
        "unit_id": 135612,
        "voice": "vo_adv_5208062_011"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n妳從剛才開始就不太對勁喔？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……原來如此。",
        "unit_id": 135612,
        "voice": "vo_adv_5208062_012"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在妳的世界，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她是位凜然的軍人，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n而且很討厭被當成小孩子。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "喜歡甜食這件事也一直隱瞞著啊。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n跟這世界的她相當不同呢。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "也就是說，",
        "unit_id": 135612,
        "voice": "vo_adv_5208062_013"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "比起基礎世界的她，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n這世界的她，行為跟年齡比較相符。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這樣比較像是小孩子，非常可愛不是嗎？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……妳這麼說",
        "unit_id": 108912,
        "voice": "vo_adv_5208062_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或許是沒錯。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但先等一下，",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我記得莫妮卡她……",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "喂～",
        "unit_id": 111,
        "voice": "vo_adv_5208062_015"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "莫妮卡，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "來比拍紙牌吧！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "今天我一定要贏過妳，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n把至今為止輸的份",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "都贏回來！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊哈，",
        "unit_id": 133212,
        "voice": "vo_adv_5208062_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "莫妮卡會反過來打敗你喔♪",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不過，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "別讓我說那麼多次好嗎！？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n不要叫莫妮卡，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要叫",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "莫妮卡姐姐！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "莫妮卡可是17歲的大姐姐喔！",
        "unit_id": 133212,
        "voice": "vo_adv_5208062_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哼哼！",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "什麼……",
        "unit_id": 135612,
        "voice": "vo_adv_5208062_018"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她竟然17歲了……？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "究竟哪個世界的她比較符合年紀？"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n怜和志那都為了這個問題煩惱了近一個小時。"
    }
]