        "voice": "vo_adv_1036011_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n肯定會變成你們重要的紀念吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "希望將來……",
        "unit_id": 190011,
        "voice": "vo_adv_1036011_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們兩個人能一起欣賞那些照片。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼",
        "unit_id": 190011,
        "voice": "vo_adv_1036011_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天就到此為止吧。",
