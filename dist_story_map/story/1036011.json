[
    {
        "type": "background",
        "background": "500181"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鏡華在精靈之森的深處，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n找到了迷路的{player}。"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的，",
        "unit_id": 103611,
        "voice": "vo_adv_1036011_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為什麼只是去洗手間都可以迷路啊！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n是因為你總是在發呆對吧？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你這人實在",
        "unit_id": 103611,
        "voice": "vo_adv_1036011_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "令人很不放心耶！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……早知道我就陪你一起去了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不、",
        "unit_id": 103611,
        "voice": "vo_adv_1036011_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不是喔，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我沒辦法跟進洗手間喔！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這你懂吧？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……懂的話那就算了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "唉。",
        "unit_id": 103611,
        "voice": "vo_adv_1036011_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼你也該回去了。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n因為很擔心，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我會把你送去精靈之森出口。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呃，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果要從這裡出去……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？",
        "unit_id": 103611,
        "voice": "vo_adv_1036011_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "太陽的方向",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "跟平常不一樣……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好、",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好亮……！",
        "unit_id": 103611
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……呼。",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯？",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "什麼啊，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是{player}嗎。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n因為突然來搭話，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我還以為是哪個變態呢。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "開玩笑的。",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "{player}的聲音，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我已經聽得很熟悉了，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以不會弄錯。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你說我為何那麼",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "沮喪？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……難道，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你是在擔心我嗎？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然其實並不是沮喪……",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你要聽我說說嗎？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我……",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "接下來要去參加宣傳照的",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "攝影會。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n媽媽擅自",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "幫我應徵了兒童模特兒的招募會，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且不知為何中選了……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為媽媽",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "似乎很高興地表示",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "「可以作為很棒的紀念」，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以讓我無法拒絕，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就一路拖到了今天。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "唉……",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n模特兒什麼的",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "太害羞了，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我根本做不到……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦……",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦咦！？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我、",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我才不要給你看！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "絕對不要！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就算你咬著手指裝可憐，",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不行的事情就是不行！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n請不要用這種小孩子撒嬌的方式！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為、",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "為什麼你要跪在地上！？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n難道",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是要跪地磕頭嗎！？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你要對小孩子做到那種地步嗎！？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我、",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我知道了，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你可以來看！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我讓你跟我一起過去啦，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以請不要在這種地方對我磕頭！",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "討厭……",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "實在是拿你沒轍耶。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你可以跟我一起去，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但是相對的千萬不要妨礙我喔！",
        "unit_id": 103631
    },
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇……",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好多大人……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我原本以為是",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "更小規模的攝影會。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "啊，",
        "unit_id": 1131,
        "voice": "vo_adv_1036011_019"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "妳就是",
        "unit_id": 1131
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "今天擔任模特兒的女孩子吧！",
        "unit_id": 1131
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊，",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是的……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請多多指教。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n今天要受各位照顧了。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "喔，",
        "unit_id": 1131,
        "voice": "vo_adv_1036011_021"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "是個很認真的孩子呢。",
        "unit_id": 1131
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n請多多指教。",
        "unit_id": 1131
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "那麼，",
        "unit_id": 1131,
        "voice": "vo_adv_1036011_022"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "這是攝影用的服裝，",
        "unit_id": 1131
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n能麻煩妳去另一邊換上嗎。",
        "unit_id": 1131
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n會有造型師陪妳過去。",
        "unit_id": 1131
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇……",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "純白色，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且輕飄飄的",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "漂亮服裝……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "等等，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這不是新娘禮服嗎！？",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我只有聽說",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是宣傳照用的服裝。",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "結果竟然是新娘禮服，",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎麼會這樣……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這麼漂亮的衣服",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真的適合我嗎……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總覺得",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "突然開始覺得不安……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n還有好多不認識的人……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且在室外，",
        "unit_id": 103631,
        "voice": "vo_adv_1036011_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "周圍的人們也全都在看……",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103631
    },
    {
        "type": "dialogue",
