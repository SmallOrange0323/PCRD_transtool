    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你看著我的眼睛再說一次？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n……還記得就好，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就不再多說什麼了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，穿著新娘禮服露出笑容的鏡華，",
        "unit_id": 190011,
        "voice": "vo_adv_1036011_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真的是很可愛呢～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也好好展現出了值得信賴的一面。",
