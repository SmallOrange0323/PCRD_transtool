        "type": "dialogue",
        "name": "凱留",
        "words": "到此結束。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n下次見面時……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我和{player}就是敵人了吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_060"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最後有了個很棒的回憶。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是這樣，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對我這無能的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "缺陷品來說就足夠了――",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇哇！？",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_061"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　什麼啦，{player}！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n突然靠過來！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_062"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　因為我突然沉默，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以你很在意？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊哈哈。",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_063"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你這個人真是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不曉得該說你敏感",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是遲鈍呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}。",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_064"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你果然",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是個好人呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你的那種地方……",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_065"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……我覺得很不錯。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以，",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_066"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你沒有記憶",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或許會過得很辛苦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n今後或許",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會發生一些艱難的事情……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但請你要活下去喔。",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_067"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n約定好囉？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後啊，",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_068"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總有一天……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是說總有一天喔？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……總有一天",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_069"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要再像這樣一起輕鬆地冒險喔。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "如此說完，凱留便迅速地下山\n不見了人影。"
    }
]