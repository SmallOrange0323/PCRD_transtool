[
    {
        "type": "background",
        "background": "500212"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "凱留像是要逃離{player}一般\n離開了蘭德索爾。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉。",
        "unit_id": 106012,
        "voice": "vo_adv_1060012_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我到底",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在做什麼啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不知不覺就走到這裡來了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012,
        "voice": "vo_adv_1060012_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡沒什麼人，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n正好可以練習操縱魔物，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也好。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟現在不太想見到{player}。",
        "unit_id": 106012,
        "voice": "vo_adv_1060012_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不知道該用什麼表情和他說話……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――吼喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "馬上就依照我的希望跑出魔物了呢。",
        "unit_id": 106012,
        "voice": "vo_adv_1060012_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你就來當我的練習對手吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來吧，",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "受我支配吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "成為我的奴隸吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　為什麼？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n公主騎士的權能",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有效！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼……！？",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是我沒辦法順利使用能力",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "被陛下給知道的話，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是會被罵的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦！？　{player}！？",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你、你",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼會出現在這種地方！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯嗯！",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　這個感覺……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你替我強化了吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "用攻擊魔法上吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喝啊啊啊！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――吼喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼～",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嚇死我了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n{player}，你為什麼會在這裡？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "收集魔石的打工？",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n哼、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼嗯～。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又再做些奇怪的事情了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的～",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就是不想見到你",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n才離開蘭德索爾，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣不都沒意義了～！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　這裡因為魔物化石釋放魔力的關係，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n導致魔物變得凶暴很危險？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來如此。",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n剛才我會無法操縱魔物",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是這個原因吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n太好了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說，",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "化石產生魔力",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "導致魔物變凶暴，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真是有違常理呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你就在這種危險地方",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "繼續打工嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……因為被拜託了所以要加油？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好吧，",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也來幫忙。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n趕快收集完魔石，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後回去蘭德索爾吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼～",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "爬到相當高的地方了呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你看這裡，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有很多像魔石的東西掉在地……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂、",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，{player}，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你看那個！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那個大到誇張，類似石像的東西！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就是你說的",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物化石吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那裡正在",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "散發出邪惡的魔力。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沐浴在那種環境下，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物當然會變凶暴，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那邊的石頭也是",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "變質而成的魔石吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――吼喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物馬上就",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "成群地冒出來了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在不是撿魔石的時候啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吶，{player}，",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "麻煩你幫忙強化了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讓我們迅速解決掉吧！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯嗯……！",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就用這力量一口氣上吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看招！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――吼喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這些傢伙也真悲慘呢～！",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在不知不覺間被狂暴化、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有操縱。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就由我來",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "解放這些可悲的傢伙吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只要破壞那個化石就解決了吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喝啊啊啊啊！！",
        "unit_id": 106011
    },
    {
        "type": "background",
        "background": "500212"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼♪",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　就這點程度……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼會！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過是個化石，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "受到我魔法的攻擊",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "居然毫髮無傷！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――吼喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘖！",
        "unit_id": 106011,
        "voice": "vo_adv_1060012_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　只會按照指示去做的人偶！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n主人的命令",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
