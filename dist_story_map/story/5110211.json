[
    {
        "type": "dialogue",
        "name": "ペテルギウス",
        "words": "魔女よ……",
        "unit_id": 11511,
        "voice": "vo_adv_5017211_000"
    },
    {
        "type": "dialogue",
        "name": "ペテルギウス",
        "words": "魔女よ！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "ペテルギウス",
        "words": "　魔女ヨ！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "ペテルギウス",
        "words": "　魔女ヨォォ！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "ペテルギウス",
        "words": "\nワタシに愛を……",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "ペテルギウス",
        "words": "寵愛ヲォォ……！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "……完全に",
        "unit_id": 109911,
        "voice": "vo_adv_5017211_001"
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "狂気にのまれているわね。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "ラム",
        "words": "狂うなら勝手にしろと言いたいところだけど、",
        "unit_id": 109811,
        "voice": "vo_adv_5017211_002"
    },
    {
        "type": "dialogue",
        "name": "ラム",
        "words": "\nそうも言ってられないみたい。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "はい。",
        "unit_id": 109711,
        "voice": "vo_adv_5017211_003"
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "あの狂気に引きずられるかのように、",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "\n魔女教徒が、",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "あきらかに強くなっています。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "二人とも、",
        "unit_id": 109911,
        "voice": "vo_adv_5017211_004"
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "あれを見て！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "あ、",
        "unit_id": 109711,
        "voice": "vo_adv_5017211_005"
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "あれは……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "ラム",
        "words": "まさか、",
        "unit_id": 109811,
        "voice": "vo_adv_5017211_006"
    },
    {
        "type": "dialogue",
        "name": "ラム",
        "words": "あれがシャドウ……！",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "ペコリーヌが言っていたわ。",
        "unit_id": 109911,
        "voice": "vo_adv_5017211_007"
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "\n人の姿をした",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "特殊な魔物が居るって。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "でもまさか、",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "レムとラムの姿にそっくりなんて……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "しかも、",
        "unit_id": 109711,
        "voice": "vo_adv_5017211_008"
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "魔女教徒たちと同じように、",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "\n大罪司教に支配されているようです！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "魔物とはいえ、",
        "unit_id": 109711,
        "voice": "vo_adv_5017211_009"
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "レムたちの姿をした存在を",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "\n魔女教徒にするだなんて……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "レム",
        "words": "絶対に許しません！！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "ラム",
        "words": "……さすがにラムも、",
        "unit_id": 109811,
        "voice": "vo_adv_5017211_010"
    },
    {
        "type": "dialogue",
        "name": "ラム",
        "words": "\n冷静さを保っていられそうにないわね！",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "二人とも！",
        "unit_id": 109911,
        "voice": "vo_adv_5017211_011"
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "\n私が援護するから、",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "エミリア",
        "words": "思いっきりやっちゃっていいわよ！",
        "unit_id": 109911
    }
]