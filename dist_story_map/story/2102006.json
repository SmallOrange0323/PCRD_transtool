[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——在受到了【憤怒‧軍團】襲擊的隔日。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可以王女的身分，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n傳喚了貴族議會的議長．豪紳侯爵到了謁見之廳。"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "尤絲蒂亞娜陛下，",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_000"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "今日的您依舊如此美麗呢。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那麼，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "關於今日的議題……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起這件事，",
        "unit_id": 105812,
        "voice": "vo_adv_2102006_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "豪紳先生！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那到底是怎麼一回事！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你竟然把{player}他們抓起來了……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "呣呣？",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_002"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n……關於這件事嗎？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哎呀這個嘛，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "我只能說這是一場令人遺憾的誤會啊。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你說那是誤會……！",
        "unit_id": 105812,
        "voice": "vo_adv_2102006_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光憑這樣就把他們送到地牢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那也太超過了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n哪可以這樣！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……然而陛下。",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_004"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "名為「雪菲」的那名少女",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "是一名通緝犯也是事實。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "同時儘管是未遂，",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_005"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "然而『暗殺王族』可乃重中之重的罪刑。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n吾輩那些將「雪菲」與她的同夥逮捕的部下們，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n僅是依照律法忠實地履行了他們的職責而已。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是……！",
        "unit_id": 105812,
        "voice": "vo_adv_2102006_006"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……嗯。",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_007"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n那名為「雪菲」的少女的通緝也已經解除了……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "倘若如此做法，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "仍舊無法緩和陛下您的怒氣的話。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那還請您",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_008"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "儘管將吾輩的項上人頭給摘下來吧。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦、",
        "unit_id": 105812,
        "voice": "vo_adv_2102006_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦……！？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "部下的過失，",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_010"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "就如同於吾輩的過失！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "如此一來身為議長的吾輩，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "要擔起全部的責任也是理所當然的……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "然而",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_011"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "還萬萬拜託您了呀，陛下！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n對於那些部下們，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "還請您務必高抬貴手……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n他們的身後，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "還有盼著他們歸去的家屬們呀……！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "豈能這樣，",
        "unit_id": 4312,
        "voice": "vo_adv_2102006_012"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "豪紳議長！",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "若議長有什麼閃失的話，",
        "unit_id": 2511,
        "voice": "vo_adv_2102006_013"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "那這個蘭德索爾的議會該如何是好……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "還請您網開一面呀，",
        "unit_id": 4312,
        "voice": "vo_adv_2102006_014"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "尤絲蒂亞娜陛下！",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n我等下人一同，",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "都給您跪了……！",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那、",
        "unit_id": 105812,
        "voice": "vo_adv_2102006_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也不是說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的有那麼生氣",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是想要怎樣啦……！",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……真受不了……",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_016"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……果不其然，小鬼就是太天真了。",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_017"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "只是稍微裝模作樣一下，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "馬上就被糊弄過去了。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……不過，",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_018"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "正是因為如此，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n把那種黃毛丫頭，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "繼續留在轎上也才有意義……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎唷哎唷",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀呀。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n您好啊，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "豪紳議長。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……女商人。",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_020"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "我可沒有印象有准許妳這種人能進到王宮裡來呢？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當然、",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那當然。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n議長您沒有印象那是理所當然的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n畢竟給予我出入許可證的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是陛下嘛。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……哼。",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_022"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n真是夠了，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "陛下淨是愛做些閒事來添亂子。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "所以才說小孩子……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哎呀！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵呵。",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n議長您的憤慨，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我自然也是感同身受。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "然而正是如此……",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以如同我們一般，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n『理解做人處事道理的大人們』，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "才有幸能撿到一些小便宜。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "和利用壓倒性的恐怖與智謀，",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "佈下獨裁制度的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那位『前陛下』統治時截然不同……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我這話說得還有三分理對吧，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "議長？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_026"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n聽不太懂妳想說什麼呢。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "吾輩",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "為當今陛下忠實的下臣。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "倘若妳",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_027"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "是打算侮辱我等之君王的話……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那麼要我在此對妳判下不敬之罪也不是難事喔？",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n克蕾琪塔・凱許。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵呵呵～",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_028"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "豈敢豈敢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我豈有那膽量，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "因此還讓我速速向您報個告就告辭。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "向我們",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_029"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "【里士滿工商會】所依賴的委託，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n蘭德索爾市街",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "7、8號區在內的重建，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "已經完成了唷。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "另外，",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "前幾天發生在廣場的魔物騷動所造成的殘磚破瓦也都撤走了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這邊會派遣人員，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "並在可行範圍內盡早重建。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "畢竟那塊區域，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是市民們休憩的場所嘛。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……哼。",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_031"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "儘管是個令人嗤之以鼻的女商人……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n然而那俐落的手腕，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "倒還真有兩把刷子。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "過獎了過獎了，",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_032"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "能得您的賞識是我的榮幸♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "儘管是稍稍",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "讓底下的員工們『努力』了一些就是。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但畢竟是非常時期嘛……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵呵呵♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "像【墨丘利財團】那樣",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_033"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n只打著理想的名號，實質卻是乳臭未乾的小丫頭們的公會，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "若想學會我的手腕，說到頭來也是不可能的嘛？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……哼。",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_034"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n就看在妳口中那自豪的手腕上，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "我就再給妳個工作機會吧。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀哎呀♪　",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不論是何等的委託，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我們都會欣然接下的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n畢竟為了再次建起克蕾琪塔之塔，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可還得再給它好好賺個好幾筆才行呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "也不是什麼難事。",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_036"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n我希望妳能替我找些做慣了骯髒事的人們。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n得要盡快，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "並且盡可能多一點人。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哦哦？",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_037"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n正如同您所說的，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這的確並不是什麼難事……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "然而豪紳議長，",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_038"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您不是有個精銳的兵隊直屬於您麾下嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n若我沒記錯，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "似乎被稱為【黃金之手】來著？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "那是當然，",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_039"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "【黃金之手】乃為我等所引以為傲的一把利刃。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n但我們那敬愛的陛下，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "在方才",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "對我等\n下達了如此的命令——",
        "unit_id": 191411
    },
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "昨天攻擊了王宮和廣場的人，",
        "unit_id": 105812,
        "voice": "vo_adv_2102006_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是一群叫做【憤怒‧軍團】的犯罪公會的精銳士兵。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他們那群人，",
        "unit_id": 105812,
        "voice": "vo_adv_2102006_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在今後或許還會對蘭德索爾進行恐怖攻擊也說不定。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了守護這座城鎮……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也包括得要重建【王宮騎士團】在內，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我希望議會的大家能夠對這件事做出一些對策！",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "陛下那對這座城鎮的一心一意，",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_042"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "著實高尚且美麗。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "我等",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "自然得全力回報她的期望才行。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "……呵呵。",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_043"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n竟然主動",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "給予吾輩用公費充實自己兵卒的機會……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n真是的，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "陛下可還真是善解人意呢。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當然，",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_044"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您說的是。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n能有這位善良的陛下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還有賢德的貴族議長大人在位，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那可真是我們一般老百姓們",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "三生有幸之事。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哈啊～",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_045"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "原來如此原來如此……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n看來是不想要",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "弄髒自己那潔白亮麗的雙手。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n然而同時卻又想",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有雙能夠做骯髒事的手嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "議長大人。",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_046"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n您的委託，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這邊鄭重且慎重地承接下來了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "若您是要找做慣了骯髒事的人才，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我這心裡也有個底。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "嗯。",
        "unit_id": 191411,
        "voice": "vo_adv_2102006_047"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "可給我盡快找來",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "啊。",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "——之後，克蕾琪塔為了與無賴們交涉，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n朝著蘭德索爾鬧區的最深處出發了。"
    },
    {
        "type": "background",
        "background": "500892"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "豪紳議長……",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_048"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "他說這次事件的犯人，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n是名為【憤怒‧軍團】的人們呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……把我的克蕾琪塔之塔給炸掉的，",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_049"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那個欠揍的死小鬼。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……我絕對",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不會原諒他！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我一定要連同他所屬的公會",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "全都一塊炸得粉碎……！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為此，",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_050"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "比起質得更重於量！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "並且得盡速！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n得要先和我手底下那些無賴們交涉，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n然後再從王宮把情報和錢全都挖出來才行！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們這群傢伙！",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_051"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n上工啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "小混混們",
        "words": "……\n……",
        "unit_id": 1,
        "voice": "vo_adv_2102006_052"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……什！？",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_053"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這是怎麼回事！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "全、",
        "unit_id": 118011,
        "voice": "vo_adv_2102006_054"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "全身被變得像是翡翠一般結晶化了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
