        "voice": "vo_adv_1031004_051"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n太不可思議了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n該不會在靈界，我們的深層意識是同步的吧？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？要我像夢裡面一樣通靈讓幽靈附身？",
