        "voice": "vo_adv_1031004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就可以藉此還原世界的真實面貌。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要加油喔♪",
