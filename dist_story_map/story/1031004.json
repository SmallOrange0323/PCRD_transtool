[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在蘭德索爾散步時，\n遇到了忍。"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，{player}。",
        "unit_id": 103111,
        "voice": "vo_adv_1031004_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你好。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還有……大家好。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，大家指的是，",
        "unit_id": 103111,
        "voice": "vo_adv_1031004_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n依附在{player}身邊的幽靈們。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}身邊，",
        "unit_id": 103111,
        "voice": "vo_adv_1031004_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n總是有許多幽靈依附著。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "熱熱鬧鬧地真不錯呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……咦？完全看不到也聽不到？",
        "unit_id": 103111,
        "voice": "vo_adv_1031004_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，對了，普通人是看不見他們的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因為我是靈媒，所以可以很清楚地看到。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，如果可以的話，讓我…………",
        "unit_id": 103111,
        "voice": "vo_adv_1031004_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀！？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這、這道光是怎麼回事……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呀啊啊啊────！？",
        "unit_id": 103111,
        "voice": "vo_adv_1031004_005"
    },
    {
        "type": "background",
        "background": "510302"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，{player}。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你好。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n好巧呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "今天你們一群人要出門嗎？",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，糟糕。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n在{player}周圍的那些是幽靈。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為可以看得非常清楚，",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_009"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n讓我不小心以為是現實中的人了。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……是的。今天也有很多幽靈跟著你喔。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而且都是女性的幽靈。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你果然一如既往非常受歡迎呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一點都不恐怖喔。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n她們好像都很喜歡你，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而且會保護你呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……你問是怎樣的幽靈嗎？",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我想想……要用話語來形容還真難呢……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對呀。跟著{player}的幽靈，",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n數量多到好像你的陽氣會",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "被她們吸光一樣。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "怎麼了，突然這麼慌張？",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n……你怕陽氣被吸光？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣呀。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那可能要告訴幽靈們，",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n不要吸取你的陽氣會比較好呢。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對了，",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那我來招魂。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}直接和幽靈們",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "交談一下如何呢？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我讓幽靈附身在我身上喔。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n接下來開口說話的不是我，是幽靈們。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "…………",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_018"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "{player}～♪",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_019"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "人家一直都好想見你唷～☆",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "咦？你不知道人家是誰？",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_020"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "真是沒禮貌～！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n人家一直都在保護你耶～！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "人家呀～",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_021"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n是{player}你的",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "曾祖母唷！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "{player}的安全，就交給背後靈老婆婆我，",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_022"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n人家會好好地保・護・你♪",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "等等！",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_023"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n要保護{player}的，是我！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "我是誰？我是對你一見鍾情的女警幽靈。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_024"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "如果有誰想殺害你，本女警會逮捕他的！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "這樣的話，要是{player}受傷了，",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_025"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n我這個護士會幫你治療唷～",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "我會幫你打針的～",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "呵呵呵，{player}的周圍，",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_026"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n真是充滿了麻煩……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n再也找不到這麼有趣的取材對象了……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "以這個取材內容執筆寫一本名作，拿下小說的新人獎……",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_027"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "哎呀，但是我已經死了……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "大哥────！",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_028"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n小的就算死也會保護大哥的！",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "啊，雖然小的已經死了……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "逼逼……嘎嘎……我是生化人，雖然是幽靈。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_029"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n{player}也會，變成，機器人幽靈……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……總之靈媒通靈就到這裡結束了。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯嗯……",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我父親說，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「就算是幽靈，這麼多女人環繞在小伙子身邊真是讓人不爽。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我要詛咒他去死」。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸你太小孩子氣了。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而且{player}是個好人，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我、我也……",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……咦！？",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n爸爸你認真的嗎？",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個……",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我父親說，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「那讓我來",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "當小伙子和幽靈女孩們之間的橋樑」。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他說，",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n「用我的通靈能力來讓小伙子可以看見這些幽靈們。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "比起現實中的女孩，小伙子和幽靈相親相愛比較好。嗯」。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還說「但交換條件，就是不准接近忍」……",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我父親說「不要客氣！哪一個女孩是你的菜呀？」……",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我父親說「喔！交給我吧！」……",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_038"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "等、等一下，爸爸。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_039"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還是讓幽靈轉世投胎比較好。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_040"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我來幫{player}做祓除儀式。",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "聽好了喔。",
        "unit_id": 103131,
        "voice": "vo_adv_1031004_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n接下來我要幫你驅邪，",
        "unit_id": 103131
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n把那些幽靈女孩們的事忘得一乾二淨吧。",
        "unit_id": 103131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊哈哈～！",
        "unit_id": 190011,
        "voice": "vo_adv_1031004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "太有趣了～！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n如何呢？這是我給你的禮物！ ",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛的情景，是我依照你和忍的「記憶碎片」，",
        "unit_id": 190011,
        "voice": "vo_adv_1031004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n創造出來的「夢」唷，是「夢」！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你有嚇一跳嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過呢，原來你不只受到人類女孩的歡迎，",
        "unit_id": 190011,
        "voice": "vo_adv_1031004_044"
