    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "剛剛好像昏了過去呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n{player}，你還好嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？你剛剛做了夢？",
        "unit_id": 103111,
        "voice": "vo_adv_1031004_050"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n幽靈附身在我身上的夢？",
