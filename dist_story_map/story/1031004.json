    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我不是很清楚「那邊」的世界，所以嚇了一跳～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "出乎意料呢～",
        "unit_id": 190011,
        "voice": "vo_adv_1031004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我還以為知道你優點的女孩，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只有我……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑的啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多的「記憶碎片」，",
        "unit_id": 190011,
        "voice": "vo_adv_1031004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就會再讓你做「夢」的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
