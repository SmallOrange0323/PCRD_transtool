        "words": "辛苦了～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "平時更嚴格喔。",
        "unit_id": 116011,
        "voice": "vo_adv_6061205_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過真琴她呀，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n都會很～小心謹慎，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不讓大家受傷。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "她真是個",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "既溫柔",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "又可靠的夥伴呢～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 116011,
        "voice": "vo_adv_6061205_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果真的累了，",
