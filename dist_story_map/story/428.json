        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼哈哈哈！",
        "unit_id": 104411,
        "voice": "vo_adv_0000428_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n再更崇拜妾身一點也無妨唷，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這位女教師！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n吾乃傳說的吸血鬼，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "伊莉亞‧奧恩斯……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……唔。",
        "unit_id": 104412,
        "voice": "vo_adv_0000428_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "方才的戰鬥，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "把妾身好不容易才留下來的魔力消耗殆盡了嗎？",
        "unit_id": 104412
