        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "儘管這連零頭都稱不上……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但總算是還以顏色啦！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "伊莉亞，",
        "unit_id": 101811,
        "voice": "vo_adv_0000428_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "妳好厲害耶！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
