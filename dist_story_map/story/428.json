    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是的，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "最後還是用個精光了啊……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀？　",
        "unit_id": 101811,
        "voice": "vo_adv_0000428_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "又讓老師驚訝了！",
        "unit_id": 101811
