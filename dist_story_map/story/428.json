        "voice": "vo_adv_0000428_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別黏過來！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n話說回來應該由比妳年長的妾身",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來當老師才合適吧！",
