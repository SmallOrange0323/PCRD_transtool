[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "動身調查之後的隔天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可可蘿自己一個人煩惱不已。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是忍不住自個兒跑出來了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下居然控制不了力量，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "進而傷到大家……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一想到",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "萬一往後又發生那種事，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在令人害怕……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "後來凱留小姐",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就臥床不起了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想必是因為她身體不適",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻又勉強自己吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她的身子出狀況，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許也是在下害的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "黑色精靈",
        "words": "…………"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從未見過的",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "黑色精靈……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您究竟是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "何方神聖呢……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "黑色精靈",
        "words": "…………"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "？",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是在下多心了嗎，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像變得比先前還大了……？　",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "強大到在下控制不住的",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "力量……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會連貪吃佩可小姐和凱留小姐都……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然大家",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要在下別放在心上……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可是現在的在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不僅幫不上忙，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還反倒傷害了他們……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該如何是好……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "歡",
        "unit_id": 1411,
        "voice": "vo_adv_5058003_010"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "迎光臨、歡迎光臨！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n我們店很便宜喔～！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "那位小妹妹，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "要不要參考看看？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_011"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "妳是第一次到這座鎮上來嗎？",
        "unit_id": 1411,
        "voice": "vo_adv_5058003_012"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "既然這樣，叔叔就給妳打個折扣，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "今後還請多多關照",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n妳怎麼啦？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "一臉悲傷的模樣……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……不。",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n什麼事……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也沒有……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "啊，",
        "unit_id": 1411,
        "voice": "vo_adv_5058003_014"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "難不成妳迷路了是嗎！？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "等等喔，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "叔叔現在去找人來──",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "小妹妹！？",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎又被人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "給遺忘了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明在下天天上門買東西，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和那位先生聊過很多次才是。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣子，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "簡直就像是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只有在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n漸漸從這座城鎮消失似的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "傷害貪吃佩可小姐和凱留小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還遭到鎮上街坊",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "淡忘。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……假如",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "情況沒有改善，\n就連貪吃佩可小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跟凱留小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都忘掉在下的話。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……假如",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n傷到了主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或是被主人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遺忘的話。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "下相當悲傷",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又害怕……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "僅是想像就撕心裂肺……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜託",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來人告訴在下……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在究竟發生了什麼狀況……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到底該怎麼做才好呢！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！？",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n愛梅斯大人……！？",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………",
        "unit_id": 190011,
        "voice": "vo_adv_5058003_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人！",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "太好了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉喔，",
        "unit_id": 190011,
        "voice": "vo_adv_5058003_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小可可蘿……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳一定很痛苦、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很難過吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……請您告訴在下，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n究竟發生了什麼事！？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……小可可蘿，",
        "unit_id": 190011,
        "voice": "vo_adv_5058003_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳的存在似乎正逐漸消滅。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的、",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "存在……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小可可蘿……",
        "unit_id": 190011,
        "voice": "vo_adv_5058003_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳知道何謂「消失」吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是、",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是原本應該存在這個世界的人物",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n忽然消失無蹤的現象──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下記得是這樣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "消逝的人不會留在任何紀錄裡，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就連記憶也……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒錯，",
        "unit_id": 190011,
        "voice": "vo_adv_5058003_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "發生在妳身上的現象，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n極度接近「消失」。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
