        "type": "dialogue",
        "name": "可可蘿",
        "words": "也許會讓貪吃佩可小姐、凱留小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "甚至是主人……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身受重傷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是因為比誰都重要，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_067"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才不想加害他們。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "況且……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "指引主人",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_068"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是在下的使命。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓主人獲得幸福，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即是在下的幸福。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如今在下",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_069"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不但無法讓主人幸福，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還會傷害到他。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣的在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有資格當一名隨從。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小可可蘿……",
        "unit_id": 190011,
        "voice": "vo_adv_5058003_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……縱使",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人不記得在下了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "依然能期望主人得以幸福，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能不斷地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "向上天祈求這份幸福。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "光是這樣，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_072"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就已心滿意足。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……妳心意已決了，",
        "unit_id": 190011,
        "voice": "vo_adv_5058003_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我知道了。",
        "unit_id": 190011,
        "voice": "vo_adv_5058003_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那我就",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不再多說了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_076"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您一直從旁守護著",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……拜託妳，",
        "unit_id": 190011,
        "voice": "vo_adv_5058003_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不要感謝我。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我一定",
        "unit_id": 190011,
        "voice": "vo_adv_5058003_078"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "早就知道，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳會做出這種選擇。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然而，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我卻……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "完全束手無策……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對不起，",
        "unit_id": 190011,
        "voice": "vo_adv_5058003_079"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "小可可蘿。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論多少次，我都要跟妳道歉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我會祈禱妳",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "能夠獲得",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "幸福的……！",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_080"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_081"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該動身了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肯定做了美食等著在下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下得細嚼慢嚥，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_082"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好好地用心品嚐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "──品嚐這最後一次，",
        "unit_id": 105913,
        "voice": "vo_adv_5058003_083"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與各位一同享用的美食。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "眾人入睡後的寂靜夜晚。"
    }
]