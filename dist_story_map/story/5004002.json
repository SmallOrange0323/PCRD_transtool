[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了幫助【咲戀育幼院】的生計，\n鈴莓開始在海之家打工。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然原本還對不太習慣的工作感到煩惱，\n但之後也漸漸變得有趣了起來，\n鈴莓今日也滿心雀躍地出門工作了。"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼，",
        "unit_id": 102511,
        "voice": "vo_adv_5004002_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "今天我也去海之家打工了哦♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "路上小心～……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "路上小心！",
        "unit_id": 102311,
        "voice": "vo_adv_5004002_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n家裡的事情就不用操心了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我們會把家事處理得妥妥當當的！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "工作加油哦，",
        "unit_id": 102111,
        "voice": "vo_adv_5004002_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鈴莓姐……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸嘿嘿。",
        "unit_id": 102311,
        "voice": "vo_adv_5004002_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n來送鈴莓出門吧，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……♪",
        "unit_id": 102111,
        "voice": "vo_adv_5004002_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "慢著慢著，",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "用餐時離席是很沒禮貌的喔？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒錯～",
        "unit_id": 102511,
        "voice": "vo_adv_5004002_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要先把早餐的碗盤收拾乾淨喔。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳們用不著這麼盛大地為我送行啦，",
        "unit_id": 102511,
        "voice": "vo_adv_5004002_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n又不是",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這輩子都不會再見。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我出門囉♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好。",
        "unit_id": 102111,
        "voice": "vo_adv_5004002_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "路上小心喔",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "，鈴莓姐……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸嘿嘿。",
        "unit_id": 102311,
        "voice": "vo_adv_5004002_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "鈴莓",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "的心情看上去不錯呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n海之家的工作，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有那麼開心嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "鈴莓姐",
        "unit_id": 102111,
        "voice": "vo_adv_5004002_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "最喜歡工作了嘛……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n而且",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "最近又這麼悶熱，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n感覺待在海水浴場附近",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就能感受到涼爽舒適的空氣……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼。",
        "unit_id": 102311,
        "voice": "vo_adv_5004002_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只有鈴莓可以去真狡猾～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們也想去海邊玩啊？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "跟可可蘿她們去買東西時，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n也難得幫我們買了泳裝了啊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不行～只有妳們幾個孩子去太危險了。",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要去的話等我這邊的工作有空檔再帶妳們去，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n妳們不可以擅自跑去，知道嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好吧……",
        "unit_id": 102111,
        "voice": "vo_adv_5004002_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咲戀媽媽一直在工作，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n感覺根本沒有「有空檔」的一天啊……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就是說啊～",
        "unit_id": 102311,
        "voice": "vo_adv_5004002_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不能光等待哪天有空，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不自己騰出時間的話就永遠去不了海邊了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "既然如此",
        "unit_id": 102111,
        "voice": "vo_adv_5004002_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我們也在能力所及的範圍內，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "一起幫忙處理咲戀媽媽的工作吧……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為想要趕快跟大家一起去海邊，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也好想看看鈴莓姐姐工作的樣子……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊，我也想看！",
        "unit_id": 102311,
        "voice": "vo_adv_5004002_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "鈴莓這麼冒失，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n真擔心她能不能好好的工作……♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不行～",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳們會打擾她工作的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊討厭，咲戀媽媽只會說「不行不行」的！",
        "unit_id": 102311,
        "voice": "vo_adv_5004002_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個……",
        "unit_id": 102111,
        "voice": "vo_adv_5004002_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n咲戀媽媽的臉色怎麼有點不好，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n沒事吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "一定是因為鈴莓姐姐，",
        "unit_id": 102111,
        "voice": "vo_adv_5004002_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不像以往一樣一直在身邊，所以感到寂寞了吧……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯～果然給人這種感覺嗎。",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不知為何有一種鬱悶感……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "看鈴莓一副相當開心的模樣，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就會",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "讓我想很多。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然她是自願來這裡工作的……",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但身為我的女僕為我工作，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n會不會其實有什麼不滿呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "她應該也有很多自己想做的事情吧。",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n陪著我工作，讓她辛苦又很不自由。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n她明明",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還處於享受青春時光的年紀的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "妳居然在想這些啊，",
        "unit_id": 102311,
        "voice": "vo_adv_5004002_025"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真傻耶，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "鈴莓有跟妳說過任何抱怨的話嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_5004002_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n別擔心，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n鈴莓姐姐",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "最喜歡咲戀媽媽了……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這一點我是相信的啦。",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真討厭……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n感覺像最要好的姊妹",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要出嫁似的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我在意這種事",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也真是太不成熟了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "？　怎麼了嗎，",
        "unit_id": 102311,
        "voice": "vo_adv_5004002_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咲戀媽媽？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……不好了。",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我剛剛瞄到",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "今早發行的報紙。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳們看，",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n上面寫說「瑪爾傑海岸發生異變！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "　奇妙的魔物出沒中！」……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我記得",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓打工的地點是瑪爾傑海岸沒錯吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這可不行，我得馬上去把鈴莓叫回來才行！",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n她應該還沒走遠吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓～！",
        "unit_id": 102811,
        "voice": "vo_adv_5004002_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n妳可不能過去，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在海邊很危險啊……！",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好，",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "到了♪",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵。",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "偶然共乘到了同方向的馬車，\n真是幫了大忙。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一下子就到海邊來了～",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這世上還是有好人存在的。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在更衣室裡把泳裝換好，",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "準備完畢。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n店長好像還沒到的樣子，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但事先把鑰匙交給我了……",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那就在開店前，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我先把店裡打掃一下吧？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大概是因為還早，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n海邊一個人都沒有呢……",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "昨天海之家也是一直門可羅雀，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒事做挺無聊的。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "除了剛好來海水浴場玩的【美食殿堂】",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那些人之外，就沒有其他人了……",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為什麼會這樣呢，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明明是海水浴場的旺季啊？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然本來就不太想給陌生人看到自己穿泳裝的樣子，",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_040"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這樣反倒是好事……",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但都沒有客人光顧的話，",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n什麼也沒做卻領工資，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "心裡也是會過意不去的。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "今天就",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_042"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "來努力招攬顧客上門吧。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n看看情況也要中午了，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "馬上到城鎮上去做個宣傳吧……",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "唉呀？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……咦？",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n奇怪，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "岸邊有什麼東西在動？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那、",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_044"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那是什麼？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　魔物？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個是……？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難道是，{player}？",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_045"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你是{player}對吧……？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "果然沒錯？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}你全身溼答答的又有海藻披在身上，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n看起來很像是什麼",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謎之生物呢～？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊！？",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "　嚇、嚇死我了！",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請不要發出那種奇怪的聲音啦！",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過，這個聲音確實是……{player}對吧？",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你全身溼答答的，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在這種地方做什麼呢……？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個……你沒事吧？",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n為什麼會",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "倒在這種地方呢？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊啊，",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "全身都是海水……",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我有毛巾，幫你擦乾淨吧。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "擦擦♪",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "話說，",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_051"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}受了不少傷呢……",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n幫、",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "幫你施展恢復魔法吧？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿，",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_052"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "打起精神來……☆",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有、",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_053"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有效果嗎？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還有",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哪裡痛嗎？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不不，",
        "unit_id": 107711,
        "voice": "vo_adv_5004002_054"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請別客氣。",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "話說回來，到底發生什麼事了……？",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請你說明一下，",
        "unit_id": 107711
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我來幫忙！",
        "unit_id": 107711
    }
]