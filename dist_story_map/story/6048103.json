    {
        "type": "dialogue",
        "name": "依里",
        "words": "七七香",
        "unit_id": 113811,
        "voice": "vo_adv_6048103_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "又開朗又溫柔，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是個非常好的人，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但個性卻",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "相當鮮明呢……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "一開始",
        "unit_id": 113811,
        "voice": "vo_adv_6048103_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "聽說是",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個惡名昭彰的公會",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還有點害怕呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "果然",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "得要實際見到面、說到話，才能夠明白啊！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n就這個層面上來說，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "今天",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "有參加真是太好了。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "七七香呢，雖然只是",
        "unit_id": 113811,
        "voice": "vo_adv_6048103_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "自稱魔法少女，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但就連這方面都對自己的",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "「喜好」這麼認真，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n讓我非常敬佩，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "覺得很棒呢！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你、",
        "unit_id": 113811,
        "voice": "vo_adv_6048103_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你在胡說什麼啊！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "可是，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如果試著放開到那種程度，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n個性是不是也會有點改變呢……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "算了，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "果然還是沒辦法啦！",
        "unit_id": 113811
    }
]