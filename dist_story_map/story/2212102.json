        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n即使是高貴偉大的我，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n也有許多僅憑一己之力無法解決的問題。",
        "unit_id": 134713
    },
