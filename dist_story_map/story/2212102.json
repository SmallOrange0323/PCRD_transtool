    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "日和……",
        "unit_id": 134713,
        "voice": "vo_adv_2212102_023"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "…………",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "這樣的話，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "那個，",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n妳願意",
