        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n前陣子",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "踏上旅程離開了吉歐‧格黑納。",
