    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "稍微聽我說嗎？",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我所統治的吉歐‧格黑納",
        "unit_id": 134713,
        "voice": "vo_adv_2212102_024"
    },
    {
        "type": "dialogue",
