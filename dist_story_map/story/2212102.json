    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "怎麼會～！　",
        "unit_id": 134713
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我絕對會為妳找到門的，",
        "unit_id": 100111,
        "voice": "vo_adv_2212102_022"
