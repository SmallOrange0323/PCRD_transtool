    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要不要來聊聊天",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "轉換心情？",
