[
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天的休息時間，{player}等人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正熱絡地聊著畢業旅行的話題。"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊～",
        "unit_id": 127312,
        "voice": "vo_adv_5126003_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家真的好期待畢業旅行喔～♪",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們一起同組吧！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "當然，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "凱留寶也是♪",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鈴奈，",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳滿心期待是沒問題，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不過在畢業旅行之前，還有一個活動喔。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？",
        "unit_id": 127312,
        "voice": "vo_adv_5126003_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還有什麼活動啊？",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "會是文化祭嗎？",
        "unit_id": 102711,
        "voice": "vo_adv_5126003_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還是運動會！？",
        "unit_id": 101112,
        "voice": "vo_adv_5126003_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "應該是遠足是也♪",
        "unit_id": 103011,
        "voice": "vo_adv_5126003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是期末考喔。",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈等人",
        "words": "！！！",
        "unit_id": 1,
        "voice": "vo_adv_5126003_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……好，",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這公式很完美。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這邊的應用題也答對了！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "狀態很不錯呢──",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼，",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有什麼不對嗎？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然我並沒有特別喜歡念書，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是想說既然都來學校上課了，實際投入後",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺還滿有趣的。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呵呵，",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "照這樣子繼續努力下去，搞不好可以拿到不錯的成績。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我從沒想過自己會這麼期待考試呢──",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好……",
        "unit_id": 127312,
        "voice": "vo_adv_5126003_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好帥氣！！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "等、",
        "unit_id": 127312,
        "voice": "vo_adv_5126003_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "等等，人家也要……！！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了，要不要大家一起念？",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "惠理子寶，妳們也一起來嘛！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我是無所謂啦，",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是妳們的程度到哪裡呢？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果程度差太多，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算一起讀書，效率也會很差。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了，",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡剛好有本題庫，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不如就來稍微做個測驗吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "由我出題，請大家回答。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "首先，第一題！",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n「請用可笑至極來造句。」",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好，有誰要回答？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好～的！",
        "unit_id": 127312,
        "voice": "vo_adv_5126003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我的造句是──",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n「吃飽飯後如果馬上跑步真的是可笑至極！」",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，那是危險至極，不是可笑至極！",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃飽後若馬上去跑步對消化很不好，千萬不可以這樣做喔！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呵呵，",
        "unit_id": 102711,
        "voice": "vo_adv_5126003_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這很簡單。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我的造句是",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "「除了我以外竟然有臭蟲膽敢接近{player}大人，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n簡直可笑至極，我要親手狠狠暴打他們一頓。」",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呃，意思雖然對了，但這私心也太可怕了！",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……唔，妳在瞪我嗎！？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好的，",
        "unit_id": 103011,
        "voice": "vo_adv_5126003_020"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我的造句是",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n「要是切腹了，就可笑至極是也！」",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼情況啊！！？",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所謂的可笑至極，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是過於愚蠢或滑稽的意思。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正確的造句範例有「不讀書就想在考試拿高分，簡直可笑至極」。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好，下一題！",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n「哺乳類、",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鳥類、",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "爬蟲類、",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "兩棲類和",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魚類，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這些因為具有相同特徵而被稱為什麼動物？」",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "答案是「脊椎動物」！",
        "unit_id": 102711,
        "voice": "vo_adv_5126003_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "順帶一提，人類的脊椎是由",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "頸椎七節、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "胸椎十二節、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "腰椎五節、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "骶骨和",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "尾骨\n所組成，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "若熟悉其構造，要破壞人體可謂輕而易舉……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不，雖然是正確答案，但是補充說明也太可怕了！！",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯～",
        "unit_id": 127312,
        "voice": "vo_adv_5126003_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家的答案是～",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "「全都是努力活著的動物」！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很棒的答案！！",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但完全答錯了！！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔……",
        "unit_id": 101112,
        "voice": "vo_adv_5126003_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "全都有「類」這個字呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這也就是說，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "答案是「會住在一起的動物」！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為俗話說「動物以類居」！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "俗話說的應該是「物以類聚」！",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是這個才不是答案！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "答案是「脊椎動物」喔。",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "簡單來說，就是指擁有脊骨的動物。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，接下來是最後一題。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「請將下列的語言翻譯成諺語。",
        "unit_id": 127214,
        "voice": "vo_adv_5126003_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\nNo pain, no gain.」",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請確實回答。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "直譯的話",
        "unit_id": 101112,
        "voice": "vo_adv_5126003_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是指沒有痛苦就無法有所穫得吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我知道了！",
        "unit_id": 101112
    },
    {
