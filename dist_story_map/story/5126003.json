        "type": "dialogue",
        "name": "凱留",
        "words": "給我等一下───！！！",
        "unit_id": 127212,
        "voice": "vo_adv_5126003_070"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你……",
        "unit_id": 127212,
        "voice": "vo_adv_5126003_071"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們是來準備考試的吧～～！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們到底",
        "unit_id": 127212,
        "voice": "vo_adv_5126003_072"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是在想什麼啊，手上滿是零食和遊戲！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且還穿成這樣……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們是打算舉行睡衣派對嗎！！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒錯！",
        "unit_id": 101112,
        "voice": "vo_adv_5126003_073"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我負責採購零食！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n有洋芋片、巧克力、軟糖和棉花糖！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n全都是凱留喜歡吃的零食！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣吃會胖啊！",
        "unit_id": 127212,
        "voice": "vo_adv_5126003_074"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我帶來了古今中外、",
        "unit_id": 103011,
        "voice": "vo_adv_5126003_075"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "全國各地所盛行的遊戲！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有將棋、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "撲克牌、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "花牌豬鹿蝶！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n壓軸則是浴衣桌球大戰是也！！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別鬧了～～～～～！！！",
        "unit_id": 127212,
        "voice": "vo_adv_5126003_076"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鈴奈等人",
        "words": "呀啊啊啊──！！！？",
        "unit_id": 1,
        "voice": "vo_adv_5126003_077"
    },
    {
        "type": "background",
        "background": "500952"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好……",
        "unit_id": 127312,
        "voice": "vo_adv_5126003_078"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好過分喔，凱留寶～",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "突然就施展魔法……",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "唔，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦！？",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "睡衣不見了！",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n這是老師使用的變裝魔法……？",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊，",
        "unit_id": 127212,
        "voice": "vo_adv_5126003_079"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我偷學起來那個魔法了，因為我是天才嘛。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快把零食和遊戲收起來！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們要來念書了！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦～",
        "unit_id": 127312,
        "voice": "vo_adv_5126003_080"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "難得來到凱留寶的房間，",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n竟然要念書，這樣太可惜了吧……",
        "unit_id": 127312
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說你們……",
        "unit_id": 127212,
        "voice": "vo_adv_5126003_081"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該不會不知道吧？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次的考試如果不及格，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就必須參加補習喔！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n而且",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "補習和畢業旅行都是在同一天！！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "換句話說，",
        "unit_id": 127212,
        "voice": "vo_adv_5126003_082"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果考試不及格就不能去畢業旅行了！！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "鈴奈等人",
        "words": "咦咦咦──！！！？？？",
        "unit_id": 1,
        "voice": "vo_adv_5126003_083"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在這之後，多虧有凱留徹底的指導，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n鈴奈他們才能夠勉強以及格分數通過考試。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "總算可以去畢業旅行的一夥人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n揚聲歡呼，並將凱留拋了起來。"
    }
]