    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "背面世界「吉歐‧提格尼亞」──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了守護這個出現了魔物的世界，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n今天{player}也和克蘿茜一同合力戰鬥。"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "火箭拳！！",
        "unit_id": 126412,
        "voice": "vo_adv_1264001_000"
    },
    {
        "type": "background",
        "background": "501660"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "呼！",
        "unit_id": 126414,
        "voice": "vo_adv_1264001_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這麼一來這邊就沒問題了呢。",
        "unit_id": 126414
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126414
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "魔物們，",
        "unit_id": 126414
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不能做壞事喔～！",
        "unit_id": 126414
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生那邊也結束了呢。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "辛苦了──！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是的！",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "畢竟不是什麼難以對付的魔物。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n而且",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你剛剛才幫我充好電呢！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊！",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n不過",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "如果可以的話",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可以再幫我充電嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "大家都說",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "運動過後就會有點餓對吧？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n現在的我也",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "肯定是這種感覺！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "所以騎士先生，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "給我點心～♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "話說回來……",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n總覺得魔物的數量比之前更多了呢？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n今天也是一大群過來。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "該不會！",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n「吉歐‧提格尼亞」在魔物之間很受歡迎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n已經幾乎都過來了之類的！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "咦──！",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n是這樣嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來如此原來如此～",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那麼，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生的世界裡大家都很忙呢。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n每天都要跟很多魔物戰鬥吧。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嗯──",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是什麼樣子呢～？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n騎士先生所在的世界。",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "一起？",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "…………",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊啊──！？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這樣啊這樣啊說得也是！",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n過去親眼見識就好了呢！？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我都沒有想過！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "畢竟",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_014"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我是騎士！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n所以從來都沒有想過",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n要離開萊拉耶爾殿下身邊！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好──！",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n那麼，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我們趕快走吧！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n去向萊拉耶爾殿下請求許可！",
        "unit_id": 126411
    },
    {
        "type": "background",
        "background": "501720"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "妳想去騎士他們的世界……？",
        "unit_id": 126511,
        "voice": "vo_adv_1264001_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是的！",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n和騎士先生一起♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士。",
        "unit_id": 126511,
        "voice": "vo_adv_1264001_018"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n是你勸說克蘿茜的嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……原來如此。",
        "unit_id": 126511,
        "voice": "vo_adv_1264001_019"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n發生了這種事呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那個，",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "萊拉耶爾殿下？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n果然不行嗎～？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_1264001_021"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "克蘿茜。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n妳對騎士他們的世界",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "很有興趣的心情我明白了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "確實，",
        "unit_id": 126511,
        "voice": "vo_adv_1264001_022"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我們幾乎完全不了解",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那邊的世界。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n已知的只有",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "騎士他們提供的情報。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我也",
        "unit_id": 126511,
        "voice": "vo_adv_1264001_023"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "正在思考",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是否需要派送使者過去。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……也許這是個好機會。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那麼那麼？",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_024"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這樣的話……？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我允許妳去拜訪",
        "unit_id": 126511,
        "voice": "vo_adv_1264001_025"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那邊的世界。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "太好了～♪",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_026"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n萊拉耶爾殿下，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "謝謝您！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵，",
        "unit_id": 126511,
        "voice": "vo_adv_1264001_027"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不用客氣喔。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n而且有句話說，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "百聞不如一見。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "增廣見聞",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "肯定",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也會對妳有些幫助。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……不過。",
        "unit_id": 126511,
        "voice": "vo_adv_1264001_028"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我有一個",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "條件。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "妳是騎士──",
        "unit_id": 126511,
        "voice": "vo_adv_1264001_029"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是皇家裝備的守護者，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n「吉歐‧提格尼亞」防衛的主力。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我無法允許妳",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "長時間離開。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……所以，",
        "unit_id": 126511,
        "voice": "vo_adv_1264001_030"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "要在換日以前回來。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這就是條件。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "妳可以保證做到嗎？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "當然！",
        "unit_id": 126411,
        "voice": "vo_adv_1264001_031"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我一定會遵守",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "和萊拉耶爾殿下之間的約定喔！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
