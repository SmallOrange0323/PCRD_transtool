[
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n起床囉～？",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500242"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，嗨──呵！",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "早安，睡得好嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那個，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你知道現在的狀況嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你睡迷糊了呢～呆頭呆腦的呀～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那個呢……我們接下燒肉店的委託前往貝利奧火山，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n想取得木炭和罕見食材的事情你還記得嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們的登山途中還一起開心地吃午餐呀～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "然後呢～烤肉的香氣呢……",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n把魔物吸引了過來～結果就演變成戰鬥了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "後來你就受到魔物的攻擊而暈倒啦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對不起呀～",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "魔物的數量實在太多了，我沒有好好保護你呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你有沒有哪個地方不舒服呀？",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我會幫你按摩一下的～好乖好乖♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我也先幫你包紮一下了，只是些輕傷呢。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "繼續勉強登山也沒意義，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n應該回到城鎮裡接受正規的治療才是呢……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以我們就下山了呀～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過距離城鎮實在很遠呢～",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且我還得揹著你前進，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以就走到日頭都下山了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為在夜晚的山路前進非常危險，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我打算今天就在這裡睡一晚～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "由於我們沒有準備過夜的道具，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以只能躺在地面上睡覺了……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我是有找個洞窟躲到裡頭，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以至少還能夠擋風遮雨吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我已經很習慣睡在野外了。",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在成為【哞哞自衛隊】的一份子前，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我可是一直都隨便找個草叢還是橋下過夜呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我有跟你說過嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我本來是為了觀光而來到蘭德索爾的……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過發生了一些事情，所以沒有辦法回到故鄉啦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不知道為什麼，我來到這地區所用的移動方式──",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n「傳送門」被禁止使用了。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我已經好幾次申請回國了～不過一直都沒有獲准呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "實在是搞不懂狀況呢。",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以說呢，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n在能夠回到故鄉之前只好在這個城鎮裡生活囉～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我算是受到【哞哞自衛隊】的保護，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以食衣住方面都有保障了～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "也因為這樣，我還蠻習慣睡野外的啦～",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過你很虛弱，我擔心你會感冒呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你冷不冷？",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要我陪你一起睡嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～開玩笑而已啦……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "話說回來在剛剛襲擊我們的魔物裡，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n也有那個罕見食材的魔物呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我有打倒牠取得食材，所以任務已經達成了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "接下來只要平安回到城鎮裡就好了～",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以你可以放心好好休息～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯。",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n謝謝你擔心我呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過沒問題的～我的優點就是充滿活力呀～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "添麻煩？",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "才沒有這種事情呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我才想要向你道歉呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "原本你就是因為我的緣故，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n才會與這些麻煩的事情扯上關係吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以你一點都不需要覺得過意不去～",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "自己一個人的話感覺很孤單，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但是多虧有你在，幫了我大忙呢。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我呀……",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n對於孤單、安靜這種事情，真的很不行～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈～我們的臉和身上都是煤灰呢～",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不過因為是在火山所以也沒辦法～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "剛好旁邊就有泉水，我們到那邊洗洗身子吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然沒有準備換洗衣物，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過只要把衣服洗一洗吊起來，到早上應該就乾了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在那之前就算全裸也沒問題的呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸，問題很大？",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我可是沒問題呢～難道你在害羞嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣啊……",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為我做事粗枝大葉的，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以常常惹霞生氣呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒有關係，反正也沒必要勉強改變自己的個性呀～",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對吧～比起消除缺點，應該更要去發展優點才是呀～！　",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "船到橋頭自然直啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀。",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_032"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一直吵你真是對不起。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你看起來很想睡了……",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_033"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n時間也已經蠻晚了～你回去再睡一覺比較好呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我稍微去洗洗身子喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～你說不習慣在野外睡覺所以睡不著？",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_034"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我可以唱搖籃曲給你聽呦～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我在故鄉時每天晚上都會和大家一起唱，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_035"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以很熟這首歌呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但在蘭德索爾，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_036"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n會被其他人唸，說在晚上唱歌會吵到鄰居～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過現在只有我和你而已，沒關係呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就算遠離故鄉，",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_037"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但是我身體裡依然留著沖繩人的血～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不管周圍怎麼想、不管發生什麼事……",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_038"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我都是與爺爺奶奶留著相同血液的暴風女孩呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我要唱歌囉～",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_039"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "覺得吵的話，要跟我說呦～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "晚安，好好休息吧～",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_040"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017007_041"
    }
]