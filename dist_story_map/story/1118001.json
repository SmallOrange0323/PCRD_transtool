[
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新年將至，貪吃佩可和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了買備受好評的豪華年菜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n大老遠地來到了大江戶町。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那間店",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該在這附近才對……",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n聽說會大排長龍，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但都還沒看到來排隊的人呢。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊！！",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n該不會已經全部賣完了吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說的也是，",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不確認",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就放棄也太性急了。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "俗話說好酒沉甕底嘛，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們就期待還買得到吧！",
        "unit_id": 111811
    },
    {
        "type": "background",
        "background": "500670"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔，",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明應該就是這間店……",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "卻沒有任何客人呢。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "小姑娘，",
        "unit_id": 611,
        "voice": "vo_adv_1118001_004"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "莫非妳是來買年菜的？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯！",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們是從蘭德索爾來的，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然已經賣光了嗎？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "蘭德索爾！",
        "unit_id": 611,
        "voice": "vo_adv_1118001_006"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那還真是千里迢迢呢……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n實在抱歉讓妳白跑一趟，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n我們今年做不成年菜了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老婆婆妳是這裡的店員嗎？",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "做不成年菜",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是什麼意思？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我們的供貨商",
        "unit_id": 611,
        "voice": "vo_adv_1118001_008"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "今年受到魔物襲擊，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n特選的食材都送不過來了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣啊……",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_009"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我姑且",
        "unit_id": 611,
        "voice": "vo_adv_1118001_010"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "有將停賣消息公佈到大江戶町內，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "但由於事出突然，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "還來不及通知到",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n蘭德索爾那裡，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不好意思啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不不、請妳別這麼說！",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒關係的！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種事稍微查一下就能知道了，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不是老婆婆的錯啦！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "妳能這麼說真是太感謝了。",
        "unit_id": 611,
        "voice": "vo_adv_1118001_012"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "對了，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "讓妳空手而歸我會很過意不去的，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n帶幾道料理回去吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "雖然不是那種拿出來賣，",
        "unit_id": 611,
        "voice": "vo_adv_1118001_013"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n只是我做來",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "自己吃的簡單料理，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n但也很好吃喔。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能得到美味料理",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是很讓人感激啦，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但真的可以嗎？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "難得的新年卻見不到客人的笑容，",
        "unit_id": 611,
        "voice": "vo_adv_1118001_015"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n讓我很空虛呢，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "妳就帶回去吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "而且，",
        "unit_id": 611,
        "voice": "vo_adv_1118001_016"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "這或許是我最後一次",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n為客人做料理了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼……",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "根據業者的說法，",
        "unit_id": 611,
        "voice": "vo_adv_1118001_018"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "採集年菜所需食材的地點，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n最近開始有很多魔物出沒。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "還說別太指望今後的貨源。",
        "unit_id": 611,
        "voice": "vo_adv_1118001_019"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n再加上，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我也上年紀了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n雖然對客人們很抱歉，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "但我差不多是時候退休了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼這樣……",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "輪到我們出場？",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說得沒錯呢！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我們把擾人的魔物吃光光吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像能為小可蘿和小凱留",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "帶很棒的伴手禮了！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "魔物的話，",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們確實有辦法解決呢。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吃著美味食材長大的魔物感覺就很好吃！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然決定了，",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就立刻出發吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "等、",
        "unit_id": 611,
        "voice": "vo_adv_1118001_025"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "等一下！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我有點不太明白，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n小姑娘妳們打算做什麼？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老婆婆，",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們會去採集食材。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果可以，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能麻煩妳為我們做年菜嗎？",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "以這種方式結束營業，也太寂寞了。",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不、",
        "unit_id": 611,
        "voice": "vo_adv_1118001_027"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不過，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "但是……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "光靠小姑娘你們兩人，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n能完成這麼危險的事嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒問題！",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別看我們這樣，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們可是吃過各式各樣危險的魔物哦！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "吃、",
        "unit_id": 611,
        "voice": "vo_adv_1118001_029"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "吃過？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "魔物嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n我是有聽說過能吃，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "沒想到是真的啊……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請別在意這些小事！",
        "unit_id": 111811,
        "voice": "vo_adv_1118001_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能列一份年菜的食材清單給我們嗎？",
        "unit_id": 111811
    },
    {
        "type": "background",
