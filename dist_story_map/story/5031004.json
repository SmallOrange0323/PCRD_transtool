        "name": "咲戀",
        "words": "前幾天洽談時，",
        "unit_id": 102811,
        "voice": "vo_adv_5031004_070"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "鈴莓她……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們的服務員對您失禮了――",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊哈哈。",
        "unit_id": 1111,
        "voice": "vo_adv_5031004_071"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "無論是誰都有失敗的時候呢。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "她也盡她所能地努力過了，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n還請轉告她",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不用介意。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "話說回來，",
        "unit_id": 1111,
        "voice": "vo_adv_5031004_072"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "競速賽的氣氛很熱烈呢。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊。",
        "unit_id": 102811,
        "voice": "vo_adv_5031004_073"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像有不少我認識的人也去參加了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也聽了不少實況轉播，聽得很開心呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳不去加油沒關係嗎？",
        "unit_id": 1111,
        "voice": "vo_adv_5031004_074"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n現在比賽已經進行到4區了……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不、",
        "unit_id": 102811,
        "voice": "vo_adv_5031004_075"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我得把該做的事做好才行……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "只有鈴莓選手一個人被前面的選手拉開了距離，",
        "unit_id": 1,
        "voice": "vo_adv_5031004_076"
    },
    {
        "type": "dialogue",
        "name": "實況",
        "words": "\n究竟她還有沒有機會獲勝呢──！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "…………",
        "unit_id": 102811,
        "voice": "vo_adv_5031004_077"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……那位女僕小姐",
        "unit_id": 1111,
        "voice": "vo_adv_5031004_078"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "好像也參加了呢。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哈哈，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我每年都很期待競速賽的轉播，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n有認識的人參加的話",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "總覺得很開心。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "前幾天",
        "unit_id": 1111,
        "voice": "vo_adv_5031004_079"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "多虧有像她那樣的人在，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我才能",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "平靜的和妳進行洽談。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "看到她一心一意的樣子，",
        "unit_id": 1111,
        "voice": "vo_adv_5031004_080"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就回憶起我的初衷，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n感覺自己也還得多加油一點才行。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我今天是想告訴妳這些……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這麼說……",
        "unit_id": 102811,
        "voice": "vo_adv_5031004_081"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是的。",
        "unit_id": 1111,
        "voice": "vo_adv_5031004_082"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "關於向育幼院出資一事，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n請務必讓我參與。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "所以，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳就快點去幫她加油吧。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……非常感謝您！",
        "unit_id": 102811,
        "voice": "vo_adv_5031004_083"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……先失陪了！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了去幫鈴莓加油，咲戀全力地奔跑了起來。"
    }
]