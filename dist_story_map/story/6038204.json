[
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯，",
        "unit_id": 110811,
        "voice": "vo_adv_6038204_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "基本上，我們學校也都是有錢人的千金小姐。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但那個叫秋乃的學姐，很明顯完全是不同的等級。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她到底是怎麼樣的人呢？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n除了她那很特殊的笑聲以外。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "難不成真的會燒一疊一疊的鈔票來取暖嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯～",
        "unit_id": 110811,
        "voice": "vo_adv_6038204_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是，這話輪得到你來說嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n說是這麼說，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你最近好像比較少迷路了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你再多多迷路，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n然後哭著衝進我們店裡了不就好了？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就這麼辦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是哦，",
        "unit_id": 110811,
        "voice": "vo_adv_6038204_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "給錢是嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，那就收下來不就好了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這有什麼好困擾的？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n被收編為騎士？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那就去啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不然我代替你去好了？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過要一輩子跟那個人在一起啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有點痛苦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "生病的話會算職災嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的假的。",
        "unit_id": 110811,
        "voice": "vo_adv_6038204_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "都賺成這樣了，還想繼續提升自己，好誇張。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我真心感到尊敬。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我要偷學她的生存方式。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "大小姐的說話語氣我也會。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n把「的呢」",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "加在句尾就好啦。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "輕鬆獲勝的呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是名媛的呢。",
        "unit_id": 110811
    }
]