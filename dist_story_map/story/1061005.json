[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}走在人潮來來往往的蘭德索爾大街上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n此時一個熟悉的少女咆哮聲，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n傳進了他的耳裡……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不過──"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍～！！！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_000"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "男子1、男子2",
        "words": "呀啊啊啊啊啊啊～！！！",
        "unit_id": 1,
        "voice": "vo_adv_1061005_001"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "剛才那是怎麼回事！？",
        "unit_id": 1,
        "voice": "vo_adv_1061005_002"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "有人飛出去了耶……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "差不多到此為止好了。",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哼哼，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如何！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要認輸了嗎！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "男子1、男子2",
        "words": "我、",
        "unit_id": 1,
        "voice": "vo_adv_1061005_004"
    },
    {
        "type": "dialogue",
        "name": "男子1、男子2",
        "words": "我認輸～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男人1",
        "words": "已經足夠了我很明白了是我們不對～！",
        "unit_id": 811,
        "voice": "vo_adv_1061005_005"
    },
    {
        "type": "dialogue",
        "name": "男人2",
        "words": "非常抱歉我不該勒索他人的～！",
        "unit_id": 911,
        "voice": "vo_adv_1061005_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "很好！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然有反省，就原諒你們！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n今後別再當什麼壞蛋了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "記得要當個好人啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "男子1、男子2",
        "words": "好的～！",
        "unit_id": 1,
        "voice": "vo_adv_1061005_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……？",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你最近還好嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我過得很好喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "關於這點你別擔心！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我下手當然有放輕啊？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……雖然不太能保證有輕到多少啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該沒事吧？",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟他們也算是有保住了小命。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "比起那種事！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你在這做什麼啊？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "幫我？",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你果然是個好人啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我可不會被那種傢伙給打敗啊！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不過",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還是謝啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你有這份心意就很夠了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我四處旅行，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一邊和那剛才那種壞蛋戰鬥！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n畢竟只要不斷打倒壞蛋們，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我總有一天就能成為全世界最壞的壞蛋啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還有就是……",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我正在尋找魔物！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是個強到不行的不妙傢伙！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n如果你有什麼情報，就告訴我吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "萬事拜託啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……光只有我對你提出要求好像有點那個啊。",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "欸，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你有沒有什麼想要我做的事？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒錯。",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟我們也一起戰鬥了不少次，你算對我有恩。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以我想報恩！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "事情就是這樣。",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你有什麼要求就儘管說吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就下次再會囉！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "欸欸，別騙人啦！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總有什麼吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "像是讓你煩惱的事之類的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來來，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "擠壓一下你的腦袋瓜好好想！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如何？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有想到什麼嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……沒有？",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的沒有嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n畢竟生活起居大小事",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大多由可可蘿包辦了？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不是說那種啦，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是更加……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "類似世界危機那一類的事啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "以你那個性，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n照理說會又被什麼糟糕傢伙給牽扯進邪惡野心裡啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……總覺得，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我現在是不是看起來很像在勒索人啊？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不行不行！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我又沒有打算讓這傢伙覺得困擾！　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還是算了！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛才那些話你忘了吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣簡直就像我是壞蛋一樣……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……不對，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣或許正好？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n反正我確實是壞蛋……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔～嗯……",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你要去哪～？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n該不會是想逃離我吧……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的是嗎！？",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好～",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我改變主意了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在你老實交代出煩惱之前，我都不會放你走的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n畢竟我可是壞蛋啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好啦！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快從實招來！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n早說早解脫！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔喔！？",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "什麼什麼？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快告訴我！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那還真是傷腦筋！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……喂。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你剛才那是在指我吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n即使是我也聽得出來好嗎！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "搞什麼……",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n畢竟你常常被捲進麻煩事裡，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我才會想說要是有什麼困擾，我可以幫忙。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "結果目前什麼狀況也沒有喔……",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但這樣也好啦。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和平是最好的……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "了解！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然你這麼說，就交給我吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那麼從現在起，就請你多指教啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……好～",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我會加油～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……怎麼？",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_035"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你說「之後」，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是「從現在起」吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "放心吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我會有一段時間都負責陪在你身旁的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你很擅長找出有煩惱的人，所以只要和你在一起，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也會更容易發現壞蛋的存在，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這下正好呢！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "走吧！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "出發去找有煩惱的人和壞蛋囉！",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這麼說來……",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我說你啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n平時到底是如何發現有煩惱的人啊？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也想像你一樣找到很多壞蛋。",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但那些傢伙",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都躲起來做壞事，要找出來不是很容易啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然這樣說有點廢話，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但要當擊敗壞蛋的大壞蛋，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n首先得要有做壞事的對象給我擊敗才行得通啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "從這角度來看，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算沒有幫助對象，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也可以用各種途徑當上好人，真好哪。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "舉例來說……",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "像是幫忙撿垃圾，維持道路美觀之類的啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這種事即使是為了自己而做，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "結果上也能幫助到其他人吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且，你明明是已經拯救了這邊世界的英雄，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n到現在也還是想去幫助有困難的人。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你真的很了不起耶！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不需要自己把姿態擺這麼低啦！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你很了不起喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這一點不稍微拿捏一下分寸，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_045"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n可是會容易被壞蛋逮到機會利用的喔。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我則是從以前開始就會故意把架子擺大一點。",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_046"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n即使如此──",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "唉……",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊？",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你說那個人，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是指那邊的大叔？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "他就只是站在房子前而已吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "等等啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別突然就跑走啦～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "怎麼回事，",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_050"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "你們是……？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大叔，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你有沒有什麼困擾啊？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這傢伙",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在這方面的直覺很準喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "是啊，",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_052"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我確實是煩惱到快想破頭了……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n還有，別叫我大叔。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我才20幾歲。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我是",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_053"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "負責指揮這一帶區域整頓工程的人，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "而最後只剩下",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "拆除這棟豪宅的工作沒完成而已。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "然而，",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_054"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "負責的師傅們卻在拆除工程進行到一半時生病，來不了……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "下一個工程",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "預定明天開始，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "但其他師傅們",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "又沒空過來協助。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "現在我得獨自拆除這座大到不行的房子嗎……",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_055"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我正這樣想，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "在這邊傷透腦筋哪。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真是辛苦啊……",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_056"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "話說回來，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你真的很厲害耶……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n如果是我，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該會什麼也沒發現就路過這個人啊……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過這次的事，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_057"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "感覺不是你有辦法解決的問題。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這棟房子超級大的，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要趕在今天內拆除，恐怕辦不到吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……也是啦。",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_058"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你肯定會這麼說的啊。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "雖然",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_059"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我很感謝你的好意，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n但光靠在場的我們幾個，是不可能完成這工作的。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "看來我只能",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "乖乖地延後工期了……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "既然如此，就交給我！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_060"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你們兩個",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "儘管放心吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不用加個小字！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_061"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你的感謝我就心領了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "難道",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_062"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "妳會使用魔法？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "除此之外根本不可能解決這狀況。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "畢竟",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "這棟房子大到原本計畫要用炸彈拆除，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "炸藥都已經搬進去了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "沒那麼輕易就能拆掉的。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "魔法？",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_063"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你錯了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我可是有這傢伙！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "顯現吧，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_064"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天樓霸斷劍──！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "從地面冒出了一把劍！",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_065"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "不過，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "這樣果然算是魔法吧……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們倆離遠一點！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_066"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "房子什麼的，看我輕鬆砍壞啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n正好裡面也放了炸藥！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喝啊啊啊啊──！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "先、",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_067"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "先等等！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "可以先確認完炸藥的量再動手吧──！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咦？",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_068"
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔咿──！！！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_069"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "沒事吧～！？",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_070"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "所以我才警告妳啊……！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "啊，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "不過房子確實被打壞了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "真是幫了大忙……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "現在這狀況這樣說對嗎……？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我沒事──！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_071"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "{player}──！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_072"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n能幫到那個人真是太好了──！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "那孩子都被炸飛了還一邊回話耶……",
        "unit_id": 2511,
        "voice": "vo_adv_1061005_073"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "你的朋友究竟是怎麼回事啊……？",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔～！",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_074"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "下次見啦～！！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "像這樣被轟飛，",
        "unit_id": 106113,
        "voice": "vo_adv_1061005_075"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就讓我想起和{player}他們敵對的那時候……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n人生會發生什麼事，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還真是難預料呢。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──不曉得是否由於幫助到有困難的人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n矛依未帶著爽朗的笑容飛向了天空另一端，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而{player}也露出微笑揮手送別。"
