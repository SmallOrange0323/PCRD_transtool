    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在街上走著的時候，\n剛好遇見了莫妮卡。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯？",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是閣下啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "現在要去買東西嗎……？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這麼熱的天辛苦了啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "最近天氣真的是越來越熱，",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "走在外面真的很辛苦……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好想沖個涼啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這、",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是什麼，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這道光芒是什麼！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好耀眼……！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗚啊啊啊啊！！",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_003"
    },
    {
        "type": "background",
        "background": "510190"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然在特殊部隊時也有受過水中訓練，",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但我還是第一次在學校上游泳課呢。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這種學生泳衣",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也是第一次穿，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但活動起來相當方便，很不錯呢。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喂{player}，在做什麼呢？",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "老師不是說為了安全要兩人組成搭檔的嗎？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下就是",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我的搭檔，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不要發呆了，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好好地跟上來！",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過，",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "說起搭檔……",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "令人不由得想起特殊部隊的訓練呢。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "危險的訓練中都必須要組成搭檔。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那時候常常",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "進行潛水訓練，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n測試我們能夠潛在水中幾分鐘……",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好令人懷念啊。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對了，",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然那麼懷念，不如試試久違的潛水吧。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我可以潛很長時間喔？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是嗎！",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下有興趣啊！",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯嗯，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然不是特別值得誇耀的事情，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但我特別讓閣下就近看看吧。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果是外行人模仿的話會很危險。",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是我",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "受過專業的訓練。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "讓我證明給閣下看，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這對我來說根本不是問題。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那麼，我要開始了。",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n要好好看著喔。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯……雖然很久沒潛了，但感覺好像也沒有生疏。",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣下去的話，說不定還可以破自己的紀錄呢。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "哼哼哼。",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_015"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "潛了這麼長時間的話，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n{player}也一定很吃驚吧。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "一定要讓他",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "清楚見識到我的厲害！",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……嗯？",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼回事？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n{player}也潛下來了？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "做、",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "做什麼！？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n為什麼要抱著我……！？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "為什麼要拉我上去！？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不對，",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "比、",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "比起那個……你的手……！？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "　\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不、",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不要隨便亂摸！",
        "unit_id": 105332
    },
    {
        "type": "background",
        "background": "510190"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "噗哈！",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……閣、",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣、閣下！",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你在做什麼啊！？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n大庭廣眾之下做這種事，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我絕不會善罷──",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什、",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n以為我溺水了……？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣呀……",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "潛水的時間太長讓閣下擔心了。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如、如果是這樣的話，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這次我就不跟你計較了。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是呢！",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n在觸碰女性的身體時，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "請多注意一些！",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我理解閣下是救人心切……",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就像剛才那樣，碰到比如",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "胸、胸……胸部之類，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這、這樣奇怪的地方，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我有可能會反射性地出手保護自己的。",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……怎、",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼了，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下表情怎麼那麼意外？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你以為碰到的，",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是背……",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗎？",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔……",
        "unit_id": 105332,
        "voice": "vo_adv_1053004_025"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔唔唔……！",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105332
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你說誰是洗衣板啊啊啊啊！",
        "unit_id": 105332
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？",
        "unit_id": 190011,
        "voice": "vo_adv_1053004_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是我給你的禮物！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話雖如此，",
        "unit_id": 190011,
        "voice": "vo_adv_1053004_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算莫妮卡再逞強，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不管怎麼看還都是小孩呢，因為體形……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，這也就是她的可愛之處。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多的「記憶碎片」，",
        "unit_id": 190011,
        "voice": "vo_adv_1053004_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就會再讓你做「夢」的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看過自己與許多女孩子的「夢」之後……",
        "unit_id": 190011,
        "voice": "vo_adv_1053004_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你就能找出這世界的真相了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要加油喔♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1053004_030"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯……？",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_031"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這裡是？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我到底怎麼了……？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "{player}，發生了什麼事？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "睡著了……？",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_032"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n……閣下也是，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "剛剛也睡著了，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們居然一起在路上睡著了……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過，做了一個很有趣的夢呢。",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_033"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n夢裡我和閣下在游泳池裡，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "上著游泳課呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……閣下也做了同樣的夢？",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_034"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n那還真是不可思議。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "居然兩人做了同樣的夢……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果是熟悉的地方還好，",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_035"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "居然夢到完全不知道的地方啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就算是偶然的話也太巧了吧……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼？",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_036"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你覺得夢裡的地方很懷念",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……的確，我也有這樣的感覺。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看起來不像是普通的夢呢。",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_037"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n以我作為軍人的直覺告訴我",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有點不對勁。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且再怎麼說，",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_038"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "以普通的夢來說有些部分很奇怪。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n既然那是夢，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我不必維持那種幼兒體型也好吧，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n起碼也得是前凸後翹的那種……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果那樣的話，",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_039"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "被閣下摸到，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n也不會誤以為摸到背──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……沒、沒事，沒什麼！",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_040"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "忘了吧！在夢中的一切，通通給我忘記！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "關、",
        "unit_id": 105311,
        "voice": "vo_adv_1053004_041"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "關於這件事情，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我會調查清楚的！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下就忘得一乾二淨就好了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n明白了嗎！絕對喔！",
        "unit_id": 105311
    }
]