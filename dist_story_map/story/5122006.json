    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不用擔心，",
        "unit_id": 126711,
        "voice": "vo_adv_5122006_081"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n祕密魔物已經全部回收完了。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "牠幫我們省下了把海水用回去的功夫呢。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而且，",
        "unit_id": 126711,
        "voice": "vo_adv_5122006_082"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我們",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也總算可以動了。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n……看來是個絕佳的時機呢。",
        "unit_id": 126711
    },
