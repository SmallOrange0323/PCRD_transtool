        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你們很恨我們吧……",
        "unit_id": 126811,
        "voice": "vo_adv_5122006_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這也是理所當然的……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "揭露了你們重要的祕密，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真的很抱歉……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不，",
        "unit_id": 102511,
        "voice": "vo_adv_5122006_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不是這樣的……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們",
        "unit_id": 102511,
        "voice": "vo_adv_5122006_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是想來道謝……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "優花梨、秋乃",
        "words": "道謝……？",
        "unit_id": 1,
        "voice": "vo_adv_5122006_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下跟大家",
        "unit_id": 105913,
        "voice": "vo_adv_5122006_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都得到了救贖。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這都是多虧了秋乃小姐、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "優花梨小姐、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似似花小姐、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……",
