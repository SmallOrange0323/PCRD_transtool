        "type": "dialogue",
        "name": "告白者6",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "告白者6",
        "words": "而且是用很難擦掉的筆。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
