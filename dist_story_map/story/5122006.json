        "voice": "vo_adv_5122006_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這是……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "什麼意思……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "意思就是，",
        "unit_id": 104311,
        "voice": "vo_adv_5122006_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "多虧你們聽了我們的祕密，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓我們得救了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "祕密被歸還的時候，",
        "unit_id": 105913,
        "voice": "vo_adv_5122006_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下一開始覺得很羞恥……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感到無地自容……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以言行舉止",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就不由得變得很奇怪。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是……",
        "unit_id": 105913,
        "voice": "vo_adv_5122006_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在那之後",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己一人獨處時……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……",
        "unit_id": 105913,
        "voice": "vo_adv_5122006_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "忽然發現",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "心情變得很輕鬆。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "原來讓別人知道自己的祕密，",
        "unit_id": 104311,
        "voice": "vo_adv_5122006_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "比起廢棄祕密，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "還要更加、",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "更加地……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "令心靈感到平靜。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們的祕密",
        "unit_id": 104311,
        "voice": "vo_adv_5122006_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很沉重吧……？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "感謝你們",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "一起背負了那些祕密。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "被歸還祕密的人們",
        "words": "謝謝你們。",
        "unit_id": 1,
        "voice": "vo_adv_5122006_018"
    },
    {
        "type": "dialogue",
        "name": "被歸還祕密的人們",
        "words": "謝謝……！",
        "unit_id": 1,
        "voice": "vo_adv_5122006_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨、秋乃",
        "words": "……！",
        "unit_id": 1,
        "voice": "vo_adv_5122006_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們就是想說這件事，",
        "unit_id": 102511,
        "voice": "vo_adv_5122006_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸嘿嘿，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以大家一起過來了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "優花梨、秋乃",
        "words": "各位……\n各位……",
        "unit_id": 1,
        "voice": "vo_adv_5122006_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要有信賴關係，",
        "unit_id": 126611,
        "voice": "vo_adv_5122006_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "共享祕密就可能建立起情誼。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……看來就是這麼一回事呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "似似花……",
        "unit_id": 126711,
        "voice": "vo_adv_5122006_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來龜豬一鳴驚人",
        "unit_id": 126611,
        "voice": "vo_adv_5122006_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也沒有做錯呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳還真是堅持啊～",
        "unit_id": 126811,
        "voice": "vo_adv_5122006_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……是啊，",
        "unit_id": 126711,
        "voice": "vo_adv_5122006_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n看來是這個樣子呢。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以呢，",
        "unit_id": 126611,
        "voice": "vo_adv_5122006_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "島鯨。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在看起來",
        "unit_id": 126611,
        "voice": "vo_adv_5122006_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n用不著你多事，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "人類也能靠自己",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n互相分享祕密，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "加深彼此的情誼喔？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "那──又──！",
        "unit_id": 10412,
        "voice": "vo_adv_5122006_030"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "那又怎麼樣──！！",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "共享祕密",
        "unit_id": 10412,
        "voice": "vo_adv_5122006_031"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "就會讓雙方都受到傷害，這是事實吧！",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n看啊！",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "實際上那些傢伙不都動彈不得嗎？",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "虛弱成這樣，",
        "unit_id": 10412,
        "voice": "vo_adv_5122006_032"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "哈！",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n還談什麼",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "信賴、",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "情誼。\n到底有什麼臉",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "說能夠承擔祕密──",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………是這樣嗎？",
        "unit_id": 126611,
        "voice": "vo_adv_5122006_033"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "什麼？",
        "unit_id": 10412,
        "voice": "vo_adv_5122006_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你確定",
        "unit_id": 126611,
        "voice": "vo_adv_5122006_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真的是這樣嗎？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "一直動來動去是在做什麼……",
        "unit_id": 10412,
        "voice": "vo_adv_5122006_036"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "小丫頭，",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "妳是在嘲弄我嗎！？",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……咦？",
        "unit_id": 126811,
        "voice": "vo_adv_5122006_037"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n等一下喔，這麼說起來……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "似似花……",
        "unit_id": 126811,
        "voice": "vo_adv_5122006_038"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n明明妳也跟我們一起",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "聽到了大家的祕密，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但怎麼就妳一個人",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "很有活力的樣子……？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "──！",
        "unit_id": 126711,
        "voice": "vo_adv_5122006_039"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n聽妳這麼一說……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "為什麼！？",
        "unit_id": 10412,
        "voice": "vo_adv_5122006_040"
    },
    {
        "type": "dialogue",
        "name": "島鯨",
        "words": "\n為什麼只有妳沒受到傷害！",
        "unit_id": 10412
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這只是我的猜測。",
        "unit_id": 126611,
        "voice": "vo_adv_5122006_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就像我跟秋乃你們說過的一樣，",
        "unit_id": 126611,
        "voice": "vo_adv_5122006_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我是所有人公認的祕密主義者。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
