    {
        "type": "dialogue",
        "name": "和正",
        "words": "告解？",
        "unit_id": 6411,
        "voice": "vo_adv_5122006_056"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "每個人都向她告解心中埋藏的祕密，",
        "unit_id": 126711,
        "voice": "vo_adv_5122006_057"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "以得到她的赦免。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也就是說，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是在淨化祕密魔物。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "告白者1",
        "words": "我失業了，",
        "unit_id": 414,
        "voice": "vo_adv_5122006_058"
    },
    {
        "type": "dialogue",
        "name": "告白者1",
        "words": "而且是在一年前。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "告白者1",
        "words": "\n可是我對家人說不出口……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……哼嗯。",
        "unit_id": 126611,
        "voice": "vo_adv_5122006_059"
    },
    {
        "type": "dialogue",
        "name": "告白者2",
        "words": "男朋友送我５萬盧幣的戒指，",
        "unit_id": 411,
        "voice": "vo_adv_5122006_060"
    },
    {
        "type": "dialogue",
        "name": "告白者2",
        "words": "被我弄丟了……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "告白者2",
        "words": "\n我現在普通地戴著的，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "告白者2",
        "words": "其實是在100盧幣商店買的戒指……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……哦。",
        "unit_id": 126611,
        "voice": "vo_adv_5122006_061"
    },
    {
        "type": "dialogue",
        "name": "告白者3",
        "words": "感覺會破壞我的公眾形象，",
