    },
    {
        "type": "dialogue",
        "name": "告白者1",
        "words": "我要告解……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "那個小房間裡，",
        "unit_id": 6411,
        "voice": "vo_adv_5122006_054"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "到底",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "在進行什麼事……？",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "大家在對似似花",
        "unit_id": 126711,
        "voice": "vo_adv_5122006_055"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "告解祕密。",
