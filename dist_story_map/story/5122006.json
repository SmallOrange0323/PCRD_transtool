        "words": "打壞了圍堵海水的擋牆！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n海水……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "會逐漸滿起來啊！？",
