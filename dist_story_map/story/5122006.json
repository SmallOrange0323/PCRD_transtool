    {
        "type": "dialogue",
        "name": "告白者3",
        "words": "\n其實",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "告白者3",
        "words": "我跟這傢伙",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "告白者3",
        "words": "根本就沒有多要好。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "告白者3",
        "words": "我們已經在一起這麼久了，",
        "unit_id": 3311,
        "voice": "vo_adv_5122006_063"
    },
    {
        "type": "dialogue",
        "name": "告白者3",
        "words": "牠卻連眼睛都不肯跟我對上。",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "告白者3",
        "words": "\n對這傢伙來說，",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "告白者3",
        "words": "我搞不好只是牠的棲木……！",
        "unit_id": 3311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……下一位。",
