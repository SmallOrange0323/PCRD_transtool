        "type": "dialogue",
        "name": "似似花",
        "words": "\n卻還得意洋洋地",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "刻意跑來告解這件事，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
