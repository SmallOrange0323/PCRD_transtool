    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當和平的蘭德索爾發生事件時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就會有位詠唱魔法咒語的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正義夥伴現身——"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "迷霧，",
        "unit_id": 101411,
        "voice": "vo_adv_1122001_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "理論， ",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真實！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n魔法緞帶，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "螺旋！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "魔法偵探Misty★霞",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_001"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "用魔法的力量開始搜查！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "什麼！？",
        "unit_id": 811,
        "voice": "vo_adv_1122001_002"
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "\n妳這傢伙",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "是怎樣啊！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "呵。",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_003"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "就如同報上的名號一般，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "只是個微不足道的魔法偵探。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n在我面前引起事件",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "是你運氣太差了呢。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "給我乖乖地束手就擒吧！",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_004"
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "嘖！",
        "unit_id": 811,
        "voice": "vo_adv_1122001_005"
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "打扮成那種莫名其妙的樣子！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "\n什麼魔法偵探啊！　",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "給我滾開……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "受不了，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_006"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "真是不死心耶。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "給我後悔自己犯下的愚蠢行為吧……！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "不論是什麼謎題都能一口氣解決！",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_007"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "用愛的力量逮捕犯人☆",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "——迷霧纏束！",
        "unit_id": 112211
    },
    {
        "type": "still",
        "still": "112200101"
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "唔呃～！？",
        "unit_id": 811,
        "voice": "vo_adv_1122001_008"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "見識到了吧。",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_009"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n你是無法逃離",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "本魔法偵探的手掌心的。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "逮捕犯人，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_010"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這樣事件就圓滿解決了☆",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "可、",
        "unit_id": 811,
        "voice": "vo_adv_1122001_011"
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "惡……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "居然會被這種打扮莫名其妙的傢伙……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "……",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_012"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "可以請你別一直提我的打扮嗎？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n就算再怎麼習慣，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "但我自己還是覺得很難為情啊！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "再說，",
        "unit_id": 811,
        "voice": "vo_adv_1122001_013"
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "什麼魔法偵探啊！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "盜賊",
        "words": "\n這不是根本就沒有半點偵探的要素嗎！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "……咦？",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_014"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "……助手先生。",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_015"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n我希望你能老實回答我……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我現在",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_016"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "該不會……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "不像個偵探吧？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "也就是說，我不是偵探對吧……？",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_017"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "算了，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "沒關係。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "看你那反應就能察覺得出來了。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這、",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這樣啊……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "真是個不會說謊的人呢，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_018"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "你呀。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "千萬可別小看我的觀察力喔。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "光是你剛才轉移視線，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我就能清楚了解你的想法了。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "不好了。",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_019"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這樣可不好啊……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我最近的確",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_020"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n有太過依賴魔法少女的力量的傾向。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "只要我變身成魔法少女後再逮捕犯人，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_021"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n不曉得為什麼，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "犯人就會老老實實地自己招供呢。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這打扮很受犯人歡迎，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "應該這麼說嗎？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "而且，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_022"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這個身體能力。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "就連平常不擅長打鬥的我，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n也能用迷霧之彈反擊襲擊而來的敵人，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "逃走的犯人",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "則是可以用迷霧纏束拘捕。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "然後在事件都順利解決之後，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_023"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n再擺出招牌姿勢回應小孩子們的歡呼聲。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "粉絲福利可不能少呢。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這樣啊，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_024"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n我像這樣重新回顧之後，發現……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "——這樣根本就不是偵探啊！",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_025"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "如果是給兒童看的娛樂作品的話，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_026"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "或許我還能接受有這種偵探。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "至少",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "現在這樣和我的目標，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "也就是用知識與邏輯來解決事件\n的偵探",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "相差甚遠啊……！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "好，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_027"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我決定了！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我要將魔法少女",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_028"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "封印起來！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "你、",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_029"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "你別那麼露骨地露出那種悲傷的表情啊！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "雖然說是封印，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "但並不是我要放棄的意思。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "應該說是我",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_030"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "想再重新審視一下自己的原點吧……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "再說！",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_031"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n你可是我這個偵探",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "雇用的助手喔？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n這點你可別忘了！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "好了，助手先生，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_032"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "有事件正在呼喚我們啊！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我們走吧！",
        "unit_id": 112211
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然是",
        "unit_id": 101411,
        "voice": "vo_adv_1122001_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這麼說。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是事件",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也不是隨便說有就有的呢。",
