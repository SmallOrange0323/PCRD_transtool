        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "魔法偵探",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "Misty★霞！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "……唔、",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_076"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "嗯。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這樣事件就解決……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "了吧？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "剛才那個變身成像魔物一樣的人，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_077"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n以及那個戒指……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "還有幾個",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "讓人在意的點呢。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "……才不好啦。",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_078"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "不對，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_079"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "沒有人受傷是真的太好了，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "那當然。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "但是",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我果然還是變身了啊！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n才剛決定不變身，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "結果就馬上破戒了！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這些全都是",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_080"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n因為你這個助手行動太魯莽了啦！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "你這個人",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_081"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "真是讓人受不了。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "……",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_082"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "不過，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "嗯，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "也沒什麼。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n我並不後悔自己變身了。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "因為那全是",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_083"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "為了要保護你啊。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "要是那時候沒變身，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_084"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "而讓你受傷的話，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "那才真的會讓我後悔吧。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "所以，",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_085"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "那個……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "你是正確的。",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_086"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "但是，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "你要是能稍微",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n讓我別那麼擔心的話，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我會很高興的。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "因為你是",
        "unit_id": 112211,
        "voice": "vo_adv_1122001_087"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "魔法偵探Misty★霞",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n重要的夥伴啊，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "對吧？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "即使{player}正在被霞教訓，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但仍感受到了她的擔心，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以及確實信任自己的情感。"
