    {
        "type": "background",
        "background": "510390"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我跟你說哦，{player}。",
        "unit_id": 104032,
        "voice": "vo_adv_1221004_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "察覺到了一件非常驚人的事……！",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這在BB團的活動中",
        "unit_id": 104032,
        "voice": "vo_adv_1221004_011"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也稱得上是最大發現！",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n以哥白尼般的想像力來形容也不為過……",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我是這麼覺得的！",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "聽我說明一下！",
        "unit_id": 104032,
        "voice": "vo_adv_1221004_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我們一直以來，",
        "unit_id": 104032
    },
