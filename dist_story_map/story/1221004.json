        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為很久沒有機會",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這麼悠閒了……",
        "unit_id": 122111
