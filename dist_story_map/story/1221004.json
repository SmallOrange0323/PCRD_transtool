        "type": "dialogue",
        "name": "碧",
        "words": "\n都是自己主動出擊交朋友的。",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也就是",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "地動說。",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "然後這次呢！",
        "unit_id": 104032,
        "voice": "vo_adv_1221004_013"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我想提議的",
        "unit_id": 104032
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "和之前完全相反……",
