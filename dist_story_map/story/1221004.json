    {
        "type": "dialogue",
        "name": "碧",
        "words": "怪了？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n感覺營火突然變旺了……",
        "unit_id": 122111
