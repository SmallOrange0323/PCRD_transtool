    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "兩人獨處的時光。",
        "unit_id": 104032
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1221004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "邊緣人樂園啊～",
        "unit_id": 190011,
        "voice": "vo_adv_1221004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要說很像碧的風格那的確是很像。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1221004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你不覺得她比以前更積極了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像是願意讓其他人進入自己的領域之類的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果要和對方展開接觸，",
        "unit_id": 190011,
        "voice": "vo_adv_1221004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就得做好被觸碰到的心理準備呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n一直窩在自己的殼裡，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n再怎麼交流都會給人一絲不悅感的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "碧一定也",
        "unit_id": 190011,
        "voice": "vo_adv_1221004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開始理解到了這點。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是否出於主動這就另一回事了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……所以說，",
        "unit_id": 190011,
        "voice": "vo_adv_1221004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "往後也請你好好陪伴著她吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟第一個在碧的殼上敲出裂縫的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並非其他人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而是你啊。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "501592"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "唔，",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_062"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "唔～嗯……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怪了，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不知不覺間我好像睡著了呢……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……咦，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你也是？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呵呵，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們一樣呢。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……哦，",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_063"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "牛奶剛好也溫好了。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請等一下。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我馬上就做熱巧克力。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼……",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_064"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呼……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗯，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真好喝。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "怎麼樣？",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_065"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "合你的胃口嗎？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "呵呵，",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_066"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那太好了……！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……我總覺得很不可思議。",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_067"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為過去我做的都是一人份的熱巧克力，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n從來都沒問過其他人關於口味的感想這種事……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "真的很不錯耶……",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_068"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "露營……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n和我一直以來的隱居山林",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "感覺完全是兩回事。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "而且啊……",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_069"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "兩人露營",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "和多人露營……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "雖然一樣是露營，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "卻有著天壤之別……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就連思考的事都完全不同。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "或許因為這樣，",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_070"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n讓我覺得",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "自己面對自然的態度也有所轉變了。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "變得更為單純……",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_071"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n讓我心想，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "啊啊，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來這是一件這麼快樂的事啊……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這種事，",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_072"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是所謂的換了個觀點吧。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "已經熟悉的事也還是會改變的呢。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……像這種改變，",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_073"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "往後也會繼續增加嗎？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……！",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_074"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "嗯……！",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_075"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n在不斷變化的每一天中，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n讓我們珍惜永恆不變的事物……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不想改變的事物一起走下去吧♪",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "圍著營火，悠閒談天的碧和{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n燦爛的星空，一直照耀著這兩人樂在其中的身影。"
    }
]