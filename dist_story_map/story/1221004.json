    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這還是第一次呢。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n和你就兩個人一起露營。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "畢竟上次",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "一個不小心就變成多人露營了。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不知道為什麼，這反倒讓我嚇了一跳。",
        "unit_id": 122111,
        "voice": "vo_adv_1221004_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為有BB團活動的關係，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "該說是沒有那種陌生的感覺嗎。",
