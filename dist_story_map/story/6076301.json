    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "蓬鬆柔軟還暖呼呼的，又超級可愛，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "簡直就是最強的設計嘛，誇張～♪",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以是要做成寫實風小棉花糖包包嗎？",
