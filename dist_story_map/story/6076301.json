        "voice": "vo_adv_6076301_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也和秀才所想的一樣！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "第一次見到小棉花糖時，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就把牠當成頭飾戴在頭上了！",
