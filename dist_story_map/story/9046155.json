[
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好壯闊的景色啊……",
        "unit_id": 106411,
        "voice": "vo_adv_9046155_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "名符其實的無人踏足之地呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "明明剛才還在雪山跋涉，太不真實了。",
        "unit_id": 106411,
        "voice": "vo_adv_9046155_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n放眼望去，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "四周一片荒野與黃沙……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我們",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "確定要繼續前進嗎……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯！",
        "unit_id": 105811,
        "voice": "vo_adv_9046155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為了沒見過的食材，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算是世界盡頭，還是九霄雲外！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不論再遠，都要向前邁進！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們的目的不單是這樣吧。",
        "unit_id": 106011,
        "voice": "vo_adv_9046155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡佩可滿腦子都只想著吃。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106011,
        "voice": "vo_adv_9046155_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "天氣突然變熱了呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能夠揮別光回想就冷死人的山，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我是還蠻高興的啦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽說貓咪怕冷，",
        "unit_id": 105811,
        "voice": "vo_adv_9046155_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也是比較喜歡溫暖的地方對吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要擅自下結論啦！",
        "unit_id": 106011,
        "voice": "vo_adv_9046155_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟寒冷相比是好一些。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "溫差這麼劇烈還是讓人有點……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真希望這個差距能再收斂一點。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟在雪山中",
        "unit_id": 105911,
        "voice": "vo_adv_9046155_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "經常仰賴凱留小姐的魔法，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或許有部分是出於大顯身手後的疲勞所致呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對了，",
        "unit_id": 105911,
        "voice": "vo_adv_9046155_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您用在下的膝枕",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍事休息吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也對此讚譽有加，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說能夠把所有疲憊一掃而空、恢復活力呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "膝枕？",
        "unit_id": 106011,
        "voice": "vo_adv_9046155_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在這種地方躺妳腿上啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還是算了吧…………",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺好丟臉。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不如讓我來躺膝枕吧♪",
        "unit_id": 105811,
        "voice": "vo_adv_9046155_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以嗎",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼是精力充沛的妳要去躺啊！",
        "unit_id": 106011,
        "voice": "vo_adv_9046155_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可蘿仔也不要一臉其實也不是不行的樣子！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵。",
        "unit_id": 106411,
        "voice": "vo_adv_9046155_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感情真好呢……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這種團結的感覺，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "戰鬥時也活用於團隊合作上了呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "既然如此……",
        "unit_id": 106411,
        "voice": "vo_adv_9046155_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n現在的我",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對【美食殿堂】的大家來說，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "能夠派上用場嗎……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對了！",
        "unit_id": 105811,
        "voice": "vo_adv_9046155_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳第一次參加這種長途旅行，應該累了吧。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要不要用小可蘿的膝枕治癒一下呀？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106411,
        "voice": "vo_adv_9046155_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我並沒有感到十分疲憊……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不用客氣的。",
        "unit_id": 105911,
        "voice": "vo_adv_9046155_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不久前",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是幾乎每天都會在",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的膝上撒嬌嗎。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對呀，",
        "unit_id": 105811,
        "voice": "vo_adv_9046155_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在的話",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不只小可蘿的膝枕，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n連我的膝枕也",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起買一送一唷！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼買一送一啊……",
        "unit_id": 106011,
        "voice": "vo_adv_9046155_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我開始頭痛了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "白癡佩可她們說的話，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳不用太當真沒關係。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃、",
        "unit_id": 106411,
        "voice": "vo_adv_9046155_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n不過",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "難得如此…………",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "買一送一",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也令人在意。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可以借我躺一下嗎……？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 105911,
        "voice": "vo_adv_9046155_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "當然沒問題。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請到這邊來──",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "突然幹嘛呀，",
        "unit_id": 106011,
        "voice": "vo_adv_9046155_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這咆哮聲……！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位，",
        "unit_id": 105811,
        "voice": "vo_adv_9046155_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是在空中！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請往天空看！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是……！",
        "unit_id": 105911,
        "voice": "vo_adv_9046155_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n飛龍嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好龐大的身軀。",
        "unit_id": 106411,
        "voice": "vo_adv_9046155_024"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n好像往這邊來了……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "牠的眼神，",
        "unit_id": 105811,
        "voice": "vo_adv_9046155_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來是把我們當作敵人了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也許我們在不知不覺中",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "踏入了牠的地盤！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也就是說，",
        "unit_id": 106011,
        "voice": "vo_adv_9046155_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "無法避免一戰嗎……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然一想到會流汗就懶得動，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但也只能忍耐了吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也拜託妳囉，雪菲！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要在下等人同心協力，",
        "unit_id": 105911,
        "voice": "vo_adv_9046155_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就能克服所有困難。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
