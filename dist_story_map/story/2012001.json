[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當蘭德索爾正舉行著豪華的慶典，\n同時，那場激戰也正如火如荼展開，在另外一頭……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【惡魔偽王國軍】做為據點的古城裡，\n忍和宮子正過著極為乏味的時光。"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好無聊喲～",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "無聊無趣沒事幹",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "來～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "早知道這麼無聊的話，",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就不聽忍說的，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "去瞧瞧城裡的祭典就好了呢。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是因為妳說沒有賣布丁的攤販，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所以本來才沒有什麼興趣的說。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊啊～一",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "說到布丁就突然好想吃布丁喲……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n布丁、",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁、",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "肚子餓了啦～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我要吃布丁啦～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不知為何，",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍的爸爸，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n越看越像新推出的布丁來的……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "白皙又綿密的新口感，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "流口水……♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喂，",
        "unit_id": 2411,
        "voice": "vo_adv_2012001_004"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "住手！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n別用那眼神瞧人呀，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "老子可沒被女孩子生吞活剝還會開心的興趣呀。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵。",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n若把這種玩意兒吃下肚了，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可是會鬧肚子疼的唷，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "宮子。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喂我的寶貝女兒呀，",
        "unit_id": 2411,
        "voice": "vo_adv_2012001_006"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳這評語會不會對爸爸我有點太冷淡了？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n多擔心一下啊，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n老子如果真不小心變成了這可愛布丁小鬼的養份妳也沒關係嗎！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然是有關係。",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但宮子似乎也挺無聊的樣子，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以你就陪陪她吧……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我必須集中精神在占卜上頭，",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒有餘裕能夠顧及到她了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔？",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍還真是喜歡占卜呢。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n和宮子對布丁的愛相比可以說是不分上下來的～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不不不。",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "宮子的那份愛，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "可說是世上最強的呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "哇咿～",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "被稱讚了耶！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n可以多讚美人家喲～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子心情可是非常好的呢☆",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "單純的小鬼還真好呢……",
        "unit_id": 2411,
        "voice": "vo_adv_2012001_012"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n啊啊～",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍以前小時候，明明就只要爸爸稍微誇獎了她一下，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n就會開心的像小天使一樣蹦蹦跳跳的呢……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好乖好乖。",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n爸爸你就別哭了～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "讓宮子來安慰你喲♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喂！",
        "unit_id": 2411,
        "voice": "vo_adv_2012001_014"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "別用妳那沾滿食物屑屑的手摸老子啦！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嘻嘻～♪　",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "吶～忍的爸爸，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍她從以前就這麼喜歡占卜的嗎？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n那就和宮子一樣來的，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子也是從出生以前",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就一直超超超喜歡布丁的喲～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗯～。",
        "unit_id": 2411,
        "voice": "vo_adv_2012001_016"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "應該說是忍她從很小的時候開始，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n就能看得到普通人看不見的東西了嘛……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n所以當然的，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就越來越懂那方面的事囉。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那真是太好了喲！",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_017"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "因為這樣，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍才能",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "和宮子跟忍的爸爸說話了喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "而且也多了好多的朋友了喲，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人生一片光明的喲～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哈哈。",
        "unit_id": 2411,
        "voice": "vo_adv_2012001_018"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "能遇見願意這麼說的傢伙，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n對忍來說，或許是件很棒的事呢……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n從今以後，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "也別忘了和我家寶貝女兒好好相處呀。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "呵呵呵～！　",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍的爸爸竟然會一臉正經的說話耶，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好怪喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不用你拜託，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子也會一直和忍好好相處下去的，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n不管是活著或掛了，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "還是轉生了也都不會變的喲～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "噓……",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n你們兩位，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請稍微安靜一下。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "怎、",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_021"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "怎麼了嗎？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳的表情好恐怖喲……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要、",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_022"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要吃布丁嗎？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不管是誰只要吃了布丁",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "都會笑咪咪的喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不……",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "照這麼看來，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "大概是沒有什麼閒情逸致可以吃點心了呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這一陣子，",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "占卜出來的結果總是環繞著不妙的氛圍，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但如今總算是逐漸明朗了……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一股驚世駭俗的黑暗，",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n正以異常的速度擴大，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "並且逐漸壟罩蘭德索爾城。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是個相當不妙的徵兆。",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n當初是為了避開危機",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "才會躲藏於這古城之中，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n然而若只是繼續觀望，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "將會跌落那導致毀滅的萬丈深淵也說不定。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這、",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_027"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這是怎麼一回事！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子聽不懂那種好難的話喲～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有不妙的預感，",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以想要去一探究竟……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "簡單來說就是這樣。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n宮子，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "妳可以幫我去叫伊莉亞起來嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我負責去",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "聯絡依里和茜里。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "得招集我們的夥伴，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "並且整頓好裝備，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n面對如此的大難必須有所處置。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "若這麼繼續放任不管，",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "想必會",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "演變成難以收拾的事態吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "哦～",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_031"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "久違地，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "【宮子與她愉快的布丁軍團】終於要全員集合了呢！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是【惡魔偽王國軍】。",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n可不能擅自地將名字改得那麼奇妙喔，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這樣替公會取名的",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "伊莉亞可是會哭泣的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚喵～",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_033"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "但是鵝魔餵亡國雞很難念的嘛～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n叫布丁軍團的話",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子還比較喜歡呢，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "聽起來很好吃我覺得很好呀！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "別再講那些奇怪的話了，",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "趕緊動身吧……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "宮子。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "說到吃點心！　",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_035"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就想到布丁！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "哇哈哈哈☆",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……。",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_036"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "咿！",
        "unit_id": 100711,
        "voice": "vo_adv_2012001_037"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "忍的表情又變得好可怕了呀！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "我會認真會努力去辦的，所以不要生我的氣啦。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子可是只要出手就不得了的孩子來的～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我並沒有生氣。",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_038"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我這張可怕的臉可是與生俱來的，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對吧？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "胡說，",
        "unit_id": 2411,
        "voice": "vo_adv_2012001_039"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "小時候的妳呀，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n可曾是笑容超可愛的小天使呀，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "老子講真的",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "沒在騙人。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "照片",
        "unit_id": 2411,
        "voice": "vo_adv_2012001_040"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "可是有好好地保存珍藏下來了，之後再給妳瞧瞧啊。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n那一舉一動可說真是可愛呀。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n還說過『我長大以後要和爸爸結婚！』",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這種話勒♪",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……。",
        "unit_id": 103111,
        "voice": "vo_adv_2012001_041"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哎呀。",
        "unit_id": 2411,
        "voice": "vo_adv_2012001_042"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "在我們家小天使的表情，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "變得連惡魔都要逃跑的可怕表情前，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n趕緊認真行動吧。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n老子我也",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "總～覺得有種不太妙的氣息呀……",
        "unit_id": 2411
    }
]