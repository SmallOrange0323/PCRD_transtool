[
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是",
        "unit_id": 122511,
        "voice": "vo_adv_5096322_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們嗎……！？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n以水棲魔物而言，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "出的招式還真奇怪呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜，可是妳看！",
        "unit_id": 122411,
        "voice": "vo_adv_5096322_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n對面穿的是平常的衣服，",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過我們現在穿的可是泳衣耶！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊……",
        "unit_id": 122511,
        "voice": "vo_adv_5096322_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但那個情報",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和現在有關係嗎？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有呀──！",
        "unit_id": 122411,
        "voice": "vo_adv_5096322_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "肯定是我們比較強！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為這裡是海邊，",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是要穿泳衣嘛！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……為什麼呢……",
        "unit_id": 122611,
        "voice": "vo_adv_5096322_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n居然感覺很有說服力……！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那是因為妳被氣勢給蒙混過去了喔，",
        "unit_id": 122511,
        "voice": "vo_adv_5096322_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不過呢，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳說我們比較強這件事，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我當然是同意的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來來來，優衣、",
        "unit_id": 122411,
        "voice": "vo_adv_5096322_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n讓牠徹底見識一下",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們真正的力量吧──！",
        "unit_id": 122411
    }
]