[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？\n在那邊看書的人是……？",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "果然是{player}！\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "喂～！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你在看什麼書啊？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦！ 那不是我的寫真集嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n為什麼你在看！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……咦？\n你想要了解關於偶像的事情嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難道是為了我……？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來如此……可是這本寫真集也有泳裝照，",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n被認識的人看到還是會有點害羞。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你看，剛好從下一頁開始就是泳裝――",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "等、等等！",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不行看啦！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "拍攝這張的時候我有點胖，好害羞啊……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n沒收！這本書我就沒收了！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，顧著跟你說話，我都忘了要去工作……！",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我再不去要遲到了！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，對了，下週你有空嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我下次的休假",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還沒有什麼計劃……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n方便的話要不要一起去玩呢？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可以嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "太好了！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就這樣約定了喔！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一週後――――"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "阿，{player}！",
        "unit_id": 711,
        "voice": "vo_adv_1029002_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？你問我是誰……是我啊！ 望！",
        "unit_id": 711,
        "voice": "vo_adv_1029002_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也、也是啦，我這個樣子難怪你認不出來。",
        "unit_id": 711,
        "voice": "vo_adv_1029002_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n其、其實呢……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我胖、胖了……",
        "unit_id": 711,
        "voice": "vo_adv_1029002_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我因為有點吃太多，",
        "unit_id": 711,
        "voice": "vo_adv_1029002_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以就變胖了一點～",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n在那之後，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我又稍微吃得太多，就又變胖了一點～",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n在那之後，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我又吃得……那個……更多了一點……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為變得太胖，害羞得不敢見人，",
        "unit_id": 711,
        "voice": "vo_adv_1029002_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以今天才穿著鎧甲來。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這是之前工作時所穿的服裝。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "像這樣用鎧甲遮住的話，雖然還能走在外面……",
        "unit_id": 711,
        "voice": "vo_adv_1029002_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但也不能一直穿成這樣對吧。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而且我還有偶像的工作……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這、這樣下去我……",
        "unit_id": 711,
        "voice": "vo_adv_1029002_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不就得引退了！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n怎麼辦～！？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？你說只要瘦下來就好了……？",
        "unit_id": 711,
        "voice": "vo_adv_1029002_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n減肥啊……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n說、",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說的也是呢！放棄前至少得先努力過才行！",
        "unit_id": 711
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……你幫我買了減肥的書啊？",
        "unit_id": 711,
        "voice": "vo_adv_1029002_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那麼就讓我來試試各種減肥的方法吧！",
        "unit_id": 711
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼呼…",
        "unit_id": 711,
        "voice": "vo_adv_1029002_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "…",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "累死了…",
        "unit_id": 711,
        "voice": "vo_adv_1029002_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "…\n穿著鐵製的全身鎧甲跑步……實在太辛苦了……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "書上寫著「在高山上跑步的運動效果更好」？",
        "unit_id": 711,
        "voice": "vo_adv_1029002_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我確實常聽人說在氧氣稀薄的地方訓練的話，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n成效會比較好……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我懂了。",
        "unit_id": 711
    },
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼呼……",
        "unit_id": 711,
        "voice": "vo_adv_1029002_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼呼……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "累、累死了……穿著鐵製的全身鎧甲，",
        "unit_id": 711,
        "voice": "vo_adv_1029002_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n在這麼高的山路上跑步……感覺快、快死掉了……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……就、就這樣跑到那邊的山頭嗎？",
        "unit_id": 711,
        "voice": "vo_adv_1029002_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚～哇，我知道了啦……",
        "unit_id": 711
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼呼……呼呼……呼呼……",
        "unit_id": 711,
        "voice": "vo_adv_1029002_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "熱死了",
        "unit_id": 711,
        "voice": "vo_adv_1029002_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "！\n竟然穿著鐵製的全身鎧甲來到火山，要死了啦！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "書上寫著「流汗的話，就能變瘦」？",
        "unit_id": 711,
        "voice": "vo_adv_1029002_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來如此，跟桑拿同一種原理啊……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "既然如此我去桑拿就好了嘛～！",
        "unit_id": 711
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為什麼突然要來餐廳呢？\n為了瘦身不是應該不能吃東西嗎？",
        "unit_id": 711,
        "voice": "vo_adv_1029002_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「蘋果減肥法」？\n",
        "unit_id": 711,
        "voice": "vo_adv_1029002_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來如此，蘋果的糖質比較少，即使吃了也不會變胖啊。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n既然瘦身的書都這麼寫了，那就不會錯了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……你說接著來試試「香蕉減肥法」、「豆腐減肥法」、",
        "unit_id": 711,
        "voice": "vo_adv_1029002_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n「碳水化合物減肥法」和「蛋糕減肥法」？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我、我懂了。我來試試看喔。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嚼嚼嚼嚼……\n嚼嚼嚼嚼嚼嚼嚼嚼……",
        "unit_id": 711,
        "voice": "vo_adv_1029002_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n嚼嚼嚼嚼嚼嚼嚼嚼嚼嚼嚼嚼……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚～我已經吃不下了……",
        "unit_id": 711,
        "voice": "vo_adv_1029002_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣就會瘦一點……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n嗚，根本不可能瘦下來嘛！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為什麼我途中都沒注意到呢！？\n只要你說的，我都會不自覺地相信呢……",
        "unit_id": 711,
        "voice": "vo_adv_1029002_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n讓我來試試其它的減肥方法吧。",
        "unit_id": 711
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "書上寫著「游泳是全身運動，所以最適合減肥」？",
        "unit_id": 711,
        "voice": "vo_adv_1029002_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要游、游泳嗎！？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "穿、穿著鐵製的全身鎧甲游泳實在是……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、",
        "unit_id": 711,
        "voice": "vo_adv_1029002_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我知道了啦！ 這也是為了減肥……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n嘿！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咕嚕咕嚕咕嚕…………咳咳！",
        "unit_id": 711,
        "voice": "vo_adv_1029002_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我、我要沉下去了啦！快、快救我……咕嚕咕嚕咕嚕……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咳咳……",
        "unit_id": 711,
        "voice": "vo_adv_1029002_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真、真是太慘了……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n果然不能太相信減肥的書呢。",
        "unit_id": 711
    },
    {
        "type": "background",
        "background": "500201"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼呼……呼呼……呼呼……呼呼……",
        "unit_id": 711,
        "voice": "vo_adv_1029002_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、我都穿著鐵製的全身鎧甲跑步了，",
        "unit_id": 711,
        "voice": "vo_adv_1029002_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n還爬上懸崖、砍倒了大樹……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這、",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣一來該瘦了不少吧……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我明明還穿著鎧甲，你怎麼可能知道我瘦了！",
        "unit_id": 711,
        "voice": "vo_adv_1029002_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n真是的……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎、怎麼會～！我都做那麼多運動了～！",
        "unit_id": 711,
        "voice": "vo_adv_1029002_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n……鎧甲怎麼可能瘦？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n對喔，不脫下鎧甲怎麼會知道……啊哈哈。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你、你說脫下來看看！？",
        "unit_id": 711,
        "voice": "vo_adv_1029002_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n笨、笨蛋！色狼！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我瘦了嗎",
        "unit_id": 711,
        "voice": "vo_adv_1029002_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "？\n穿著鎧甲的話，我也看不見自己的身體……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n嗯……啊，從這個縫隙也許可以看到。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 711,
        "voice": "vo_adv_1029002_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看、看不太清楚呢。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這個縫隙能不能弄大一點呢？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n把這裡拉開的話――",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？啊……",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我難道因為搞錯，所以把鎧甲扣環扯掉了！？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好、好害羞！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不要看啦！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇～！\n被看到這麼胖的樣子……我已經嫁不出去了啦！",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你、你說看起來沒什麼改變……？",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒那回事！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為我明明就增加了1公斤啊！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……跟往常一樣可愛？\n你是說真的嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這、這樣啊。",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_049"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那我就不用勉強自己瘦下來――",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃，你、你說我很可愛……！？",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n咦，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不是……那個，呃……！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "…………～～～～！！！",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_051"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我我、我、我果然還是努力減肥好了！",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_052"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我只想給你看到我最可愛的樣子……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒事！我什麼都沒說！",
        "unit_id": 102911,
        "voice": "vo_adv_1029002_053"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我去慢跑了喔。我、我自己去也沒問題！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓我一個人靜一靜！",
        "unit_id": 102911
    }
]