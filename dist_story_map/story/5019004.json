        "voice": "vo_adv_5019004_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "魔物？　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像又不是……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你好你好。",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你、",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你是",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "誰……？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊！",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n難道是……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雨神大人？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不、",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不會吧？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……嗯。",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？　",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我說對了嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為什麼雨神大人會在這種地方？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為了讓明天能舉辦活動，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "希望你能幫忙調節一下天氣……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶吶。",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_010"
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "……？",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你從剛才就一臉難過的樣子，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "發生什麼不開心的事了嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們語言不通啊～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "剛才不自覺就跟你搭話了。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "抱歉～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "因為見不到朋友……",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_015"
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "因為見不到朋友，",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_016"
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "我很難過……",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦！？",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n說話了！？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們竟然能夠對話，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太狂了吧！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n明明不是人類，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但你竟然能說人話耶，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你精通兩種語言嗎！？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "難道這就是所謂的",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "遭遇未知生物",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吧！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好狂啊啊啊啊！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家好像",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "正在經歷超不得了的經驗耶～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶吶，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "反正這麼難得，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "能和你聊一聊嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n你說的那位朋友，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是指這島上的誰嗎？",
