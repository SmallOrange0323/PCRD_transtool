    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "一起進入沉眠。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦！　",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_039"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像一直在玩，感覺好開心！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不用上課和寫作業，真讓人羨慕～！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "上、",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_040"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "課……？",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n我不懂你說的那是什麼，",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "不過我和晴吉總是在一起。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "人類們",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_041"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "也一直默默的守護我們。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n那讓我很開心。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "可是……",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_042"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "當春天我甦醒時，",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "只剩下我一個人。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n是因為之前我們吵架，",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "還沒和好就陷入沉眠，",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n所以他才沒有醒來嗎？　",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "他已經",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "不會陪我玩了嗎……",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "我好想快點見到晴吉……",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_043"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "\n希望他不會討厭我……",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雨吉～",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_044"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家也很了解",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你的心情喔～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "為什麼？",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_045"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我是來這座島",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_046"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "工作的。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n島上的人們，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "邀請我過來！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_047"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我和跟我一起來的朋友",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "起了一點爭執。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "等明天的活動結束後，我能休假一陣子，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_048"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "本來打算要大肆地渡假一番……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "鈴奈也",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_049"
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "和朋友分道揚鑣了？",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯～",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_050"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n大概類似吧～？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那位朋友",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_051"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和我讀同間學校，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過學校有可能會廢校。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是不是很扯？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "廢校是指",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "學校會不見的意思！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要是那樣子的話，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_052"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們就不能再像之前那樣一起玩了嘛！？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今年說不定是",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n我和朋友",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一起渡過的最後的暑假了……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們……",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_053"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "當初是不是不來這座島比較好啊……？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "雨吉",
        "words": "……",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_054"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_055"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家是模特兒，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n哪有不接工作的道理嘛。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "唉～～～",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_056"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "為什麼事情會變成這個樣子呢～～～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_057"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才～！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "讓你擔心了嗎？",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_058"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "抱歉～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家沒事。",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_059"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "只是來冷靜一下。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我已經反省過了，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "覺得自己說得有點太過分～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶吶！　",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_060"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了，你聽我說！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "鏘鏘！",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_061"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n這孩子",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是那個雨神大人！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n是不是超可愛的！？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_062"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你是全力在搞笑嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我現在完全笑不出來～？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你看，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是他啊～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯，奇怪？",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_063"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n真的不見了。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真是奇怪啊。",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_064"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n剛才雨吉還在這裡的。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n他好像很難過的在哭～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "他說雖然大家稱呼他雨神大人，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_065"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是那並不是他的真名。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "而且他竟然沒有自己的名字！　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "很驚人吧？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_066"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家就",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "幫他取了「雨吉」這個名字！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對對，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_067"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還有啊，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n他明明是精靈，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是他聽得懂人話耶！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n雖然只有一下下，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但我們一起聊天了喔！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_068"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們聊了什麼嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個嘛～～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "――就是這樣～",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_069"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是所謂的越吵架感情越好？　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "實在有夠催淚的不是嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才你對那樣的友情",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_070"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有什麼想法？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超深情的～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你不覺得嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家和美咲！？",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_071"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯～",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_072"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你那樣說好像也是～……？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為我們老是吵架……？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過。",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_073"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "其實我們只是想要鼓勵、",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和讚美彼此呢～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？　",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_074"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這麼說來……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "剛才美咲說的……",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_075"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n因為人家想說活動可能會中止而沮喪，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以她是想要鼓勵我嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣啊～……！",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_076"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家，",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_077"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像老是在想工作的事情呢～？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "明明平時馬上就會注意到的，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "結果今天好像超煩躁。",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
