    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "不是。",
        "unit_id": 11611,
        "voice": "vo_adv_5019004_021"
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "\n他和我一樣，",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "是精靈。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "\n人類都稱呼他是",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "晴神大人。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雨神大人和",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "晴神大人啊～",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你說是人類這樣稱呼他，",
