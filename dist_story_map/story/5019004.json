        "voice": "vo_adv_5019004_033"
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "我覺得不錯。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "\n雨吉和",
