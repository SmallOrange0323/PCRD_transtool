        "type": "dialogue",
        "name": "雨神大人",
        "words": "總是在一起，",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "不需要互相稱呼名字。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "原來是這樣啊～",
        "unit_id": 110011,
        "voice": "vo_adv_5019004_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n那麼，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "既然是朋友，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "取個只屬於你們兩人的暱稱不是很好嗎？",
