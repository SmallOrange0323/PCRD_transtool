        "voice": "vo_adv_5019004_024"
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "沒有。",
        "unit_id": 11611
    },
    {
        "type": "dialogue",
        "name": "雨神大人",
        "words": "\n因為我們",
        "unit_id": 11611
