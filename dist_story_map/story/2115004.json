        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就無法打開塔頂的門。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n比起這個，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "現在……",
        "unit_id": 129012
    },
