    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就是因為有這種東西……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……？",
        "unit_id": 129012,
        "voice": "vo_adv_2115004_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "無法破壞……？",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n被嚴密地，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "保護著……？　",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不對。",
        "unit_id": 129012,
        "voice": "vo_adv_2115004_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這是……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "最重要道具設定。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n無法廢棄，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也不存在破壞時的資料嗎……",
