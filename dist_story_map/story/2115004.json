        "voice": "vo_adv_2115004_004"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小厄莉絲……",
        "unit_id": 123311
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "親眼見到就覺得真的超不妙的。",
        "unit_id": 123311
