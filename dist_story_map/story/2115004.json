        "voice": "vo_adv_2115004_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n似乎，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
