    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也就是說，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一般手法無法破壞啊。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "算了，",
        "unit_id": 129012,
        "voice": "vo_adv_2115004_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也罷。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n只要欠缺一個，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "草野優衣那些人",
