[
    {
        "type": "background",
        "background": "502640"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}收到剎鬼的邀請，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了參加祭典而在前一天來到了鬼族的村莊。"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "………………",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_000"
    },
    {
        "type": "background",
        "background": "502430"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……別在那偷偷摸摸的，",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_001"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "騎士公。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n快出來吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "別小看我啊。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_002"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n如果想玩跟蹤遊戲的話，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "至少得將自己的氣息消除吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "還是說騎士公。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_003"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n你──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "是喜歡看我的屁股嗎？",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "那麼，",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_004"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就抬頭挺胸跟過來吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這也不是什麼",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "需要隱瞞的事。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就算騎士公一起來",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也無妨。",
        "unit_id": 135912
    },
    {
        "type": "background",
        "background": "502400"
    },
    {
        "type": "dialogue",
        "name": "幽靈女孩",
        "words": "嗚嗚……",
        "unit_id": 214,
        "voice": "vo_adv_1359001_005"
    },
    {
        "type": "dialogue",
        "name": "幽靈女孩",
        "words": "嗚嗚、",
        "unit_id": 214
    },
    {
        "type": "dialogue",
        "name": "幽靈女孩",
        "words": "嗚嗚……",
        "unit_id": 214
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "似乎是最近才剛來到這的。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_006"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "因為她的樣貌，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "讓我有一點在意……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "所以我才會過來看看情況。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "幽靈女孩",
        "words": "花……",
        "unit_id": 214,
        "voice": "vo_adv_1359001_007"
    },
    {
        "type": "dialogue",
        "name": "幽靈女孩",
        "words": "花在哪裡……？",
        "unit_id": 214
    },
    {
        "type": "dialogue",
        "name": "幽靈女孩",
        "words": "\n我好想要，",
        "unit_id": 214
    },
    {
        "type": "dialogue",
        "name": "幽靈女孩",
        "words": "可以讓人幸福的花……",
        "unit_id": 214
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……花嗎。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_008"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "看來她是在變成幽靈以前，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就在找花了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n只不過，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "這裡可是吉歐‧尼布爾黑爾。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "幾乎所有花都是枯的。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不用那麼麻煩。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_009"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雖然非常少見，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "但偶爾也會有鮮花漂流過來。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n鬼族這裡，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "現在正好有一朵花。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "只要在明天的祭典上取得優勝，",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_010"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n就能得到那朵鮮花。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "反正那種東西也不適合我，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "所以我打算送給這傢伙。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不是每個鬼都會破壞小鬼所堆的祈福石堆啊。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_011"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也就是俗話說的，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "人間處處有溫情什麼的。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "幽靈女孩",
        "words": "嗚嗚……",
        "unit_id": 214,
        "voice": "vo_adv_1359001_012"
    },
    {
        "type": "dialogue",
        "name": "幽靈女孩",
        "words": "嗚嗚嗚……",
        "unit_id": 214
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "哭累就躲起來了嗎……",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_013"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我們也回去吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "明天的祭典，",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_014"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "你也要參加哦。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "騎士公。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "要是敢睡過頭，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我就去把你叫起來。",
        "unit_id": 135912
    },
    {
        "type": "background",
        "background": "502640"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是到了隔天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "祭典當日。"
    },
    {
        "type": "dialogue",
        "name": "鬼族族長",
        "words": "你們，",
        "unit_id": 7412,
        "voice": "vo_adv_1359001_015"
    },
    {
        "type": "dialogue",
        "name": "鬼族族長",
        "words": "給我聽好了！",
        "unit_id": 7412
    },
    {
        "type": "dialogue",
        "name": "鬼族族長",
        "words": "\n",
        "unit_id": 7412
    },
    {
        "type": "dialogue",
        "name": "鬼族族長",
        "words": "今天就是期盼已久的祭典。",
        "unit_id": 7412
    },
    {
        "type": "dialogue",
        "name": "鬼族族長",
        "words": "應該有很多人都是為了今天而進行鍛鍊的吧。",
        "unit_id": 7412,
        "voice": "vo_adv_1359001_016"
    },
    {
        "type": "dialogue",
        "name": "鬼族族長",
        "words": "\n",
        "unit_id": 7412
    },
    {
        "type": "dialogue",
        "name": "鬼族族長",
        "words": "我希望",
        "unit_id": 7412
    },
    {
        "type": "dialogue",
        "name": "鬼族族長",
        "words": "大家都能把實力盡情發揮出來。",
        "unit_id": 7412
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "以此碎岩儀式，",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_017"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "來宣告祭典正式開始！",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "──喝啊！",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "啪噹！"
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "唔喔喔喔喔喔！！",
        "unit_id": 1,
        "voice": "vo_adv_1359001_018"
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "\n徒手將岩石劈成了兩半──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "不愧是剎鬼大人。",
        "unit_id": 1,
        "voice": "vo_adv_1359001_019"
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "居然能劈得那麼漂亮……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "\n今年的祭典",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "肯定會非常成功！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鬼族裁判",
        "words": "一決勝負……",
        "unit_id": 1,
        "voice": "vo_adv_1359001_020"
    },
    {
        "type": "dialogue",
        "name": "鬼族裁判",
        "words": "上啊",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鬼族裁判",
        "words": "上啊上啊上啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "喝啊！",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_021"
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "哦哦，",
        "unit_id": 1,
        "voice": "vo_adv_1359001_022"
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "被扔飛了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "\n飛得比屋頂還高！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "今年的決勝招式是抓投嗎！",
        "unit_id": 1,
        "voice": "vo_adv_1359001_023"
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "\n剎鬼大人那豪邁的相撲",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "依然讓人看得入迷啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "騎士公。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_024"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n你有吃飯了嗎？",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "不吃是會累倒的哦。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "你的身體構造",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "跟我可不同啊。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "只是？",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_025"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n……啊啊，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "你很在意那邊的弩弓嗎。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "別在意。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_026"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n那就類似試膽用的東西。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "這位客人，",
        "unit_id": 1,
        "voice": "vo_adv_1359001_027"
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "請不用擔心！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "\n吊起來旋轉的弩弓",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "沒那麼容易射中的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "\n……偶爾會射到就是了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "沒錯。",
        "unit_id": 1,
        "voice": "vo_adv_1359001_028"
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "畏懼不會命中的箭矢",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "可稱不上是豪傑！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "\n必須要毫不在意地大吃大喝、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "開懷大笑！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "\n……射中會很痛就是了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "別在那叫來叫去的。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_029"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n俗話說",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "槍打出頭鳥。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "來，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "吃吧吃吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "唔喔喔喔喔喔！",
        "unit_id": 1,
        "voice": "vo_adv_1359001_030"
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "合體！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "騎馬打仗──！！",
        "unit_id": 1,
        "voice": "vo_adv_1359001_031"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我去去就回。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_032"
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "看啊！",
        "unit_id": 1,
        "voice": "vo_adv_1359001_033"
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "剎鬼大人在馬上跳躍移動，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "\n接連取下敵人的首級！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "\n這就是剎鬼大人的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "單槍匹馬‧",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "八艘跳躍！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "祭典差不多到尾聲了……",
        "unit_id": 1,
        "voice": "vo_adv_1359001_034"
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "\n哎呀，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "活動真是充實呢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "\n雖然膝蓋中了一箭！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "喜歡祭典的鬼族",
        "words": "哈哈哈！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "看來這次也會是剎鬼大人獲得優勝呢！",
        "unit_id": 1,
        "voice": "vo_adv_1359001_035"
    },
    {
        "type": "dialogue",
        "name": "情緒高昂的鬼族",
        "words": "\n哇哈哈哈哈！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咚！"
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "痛痛痛，",
        "unit_id": 4911,
        "voice": "vo_adv_1359001_036"
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "真不好意思……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "\n我沒有好好看路……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "哎呀，",
        "unit_id": 4911,
        "voice": "vo_adv_1359001_037"
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "真是謝謝你……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "哈哈，",
        "unit_id": 4911,
        "voice": "vo_adv_1359001_038"
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "算是吧……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "\n不過，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "我得要走了……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "\n……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "不好意思，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "先",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "觀光客？",
        "words": "失陪了。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "花……",
        "unit_id": 1,
        "voice": "vo_adv_1359001_039"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "花在哪裡……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我好想要，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可以讓人幸福的花……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "怎麼了嗎，",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_040"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "騎士公。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "祭典的閉幕式已經結束，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也拿到獎品的鮮花了。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "謝啦。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_041"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n今晚",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就把花拿給那個幽靈小鬼好了──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "剎鬼大人，",
        "unit_id": 1414,
        "voice": "vo_adv_1359001_042"
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "抱歉打擾了！",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "\n",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "似乎有賊人入侵了我們的寶物庫盜取東西……！",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "啊……？",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_043"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "說清楚一點。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "好像是趁著祭典中警備較弱時入侵的。",
        "unit_id": 1414,
        "voice": "vo_adv_1359001_044"
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "\n被偷走的是「返魂靈玉」……",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "\n應該",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "是來自外界的人所下的手……",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "靈玉……",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_045"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "強行把死者變成殭屍的那個嗎。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n如果是吉歐‧尼布爾黑爾的人，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n才不會為了這種東西",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "與鬼族敵對。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "另外，",
        "unit_id": 1414,
        "voice": "vo_adv_1359001_046"
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "雖然這只是傳聞……",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "但是最近，",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "\n似乎有異世界的客人",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "在村莊周圍徘迴搜索。",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "\n",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "也有人看到",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼的部下",
        "words": "對方用不可思議的道具在抓捕幽靈。",
        "unit_id": 1414
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……嘖。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_047"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "太專注在祭典上，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "被搶先一步了嗎。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "太大意了……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "什麼……？",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_048"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n你說你剛才有撞到那個觀光客？",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n而且",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "他離開時你還有聽到很像那個幽靈的聲音？",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……還真是被小看了呢……",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_049"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "喂。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "把能動員的人",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "全都叫過來。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n就算要把三途川的水全部抽乾，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "也要追到那個賊人。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "等追到以後。",
        "unit_id": 135912,
        "voice": "vo_adv_1359001_050"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "在祭典結束後的宴會開始前──",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "先把這筆帳給算個清楚。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "把幽靈連同「返魂靈玉」都一起偷走的犯人。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n對於這起可能會演變成重大問題的事件，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n剎鬼下定決心一定要親自解決。"
    }
]