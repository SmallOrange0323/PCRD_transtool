[
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "好，",
        "unit_id": 106832,
        "voice": "vo_adv_5201052_000"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "今天要做什麼樣的可麗餅",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "才好呢？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不論在什麼情況下都要創作新口味的可麗餅，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我這個人啊，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "還真是可麗餅攤商的典範呢～！",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……奇怪？",
        "unit_id": 106832,
        "voice": "vo_adv_5201052_001"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n車裡好像有什麼東西……",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是錄音筆？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是因為前陣子的汽車追逐戰而掉出來的嗎？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "裡面錄了什麼來著……",
        "unit_id": 106832,
        "voice": "vo_adv_5201052_002"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "引發危險的可能性～",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "看來沒有。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就來播放吧。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是誰？",
        "unit_id": 1,
        "voice": "vo_adv_5201052_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在我做的角色模型上加了裝飾品。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n顯而易見地增加太多了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣看起來豈不是很突兀？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "比起那種事，",
        "unit_id": 1,
        "voice": "vo_adv_5201052_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有誰能陪我在測試用場景裡進行模擬戰鬥？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我想實際確認一下戰鬥數據。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "我來陪妳吧，",
        "unit_id": 1,
        "voice": "vo_adv_5201052_005"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "克莉絲。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n另外，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "傳送門實裝完畢了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "麻煩妳確認一下。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n因為妳即使被卡在牆壁裡",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "也不會有問題。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊～",
        "unit_id": 1,
        "voice": "vo_adv_5201052_006"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "糟糕。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n好像有東西對場景造成負荷了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n是哪個物件啊～？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "都是因為妳太講究多餘的細節了。",
        "unit_id": 1,
        "voice": "vo_adv_5201052_007"
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n讓我看看程式碼……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "是這個和",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "那個互相干涉了吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "真那",
        "words": "\n拜託妳別害我多花力氣做這種事。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "各位，",
        "unit_id": 1,
        "voice": "vo_adv_5201052_008"
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "可別忘了寫進度報告。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "\n……不過在場，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "宙",
        "words": "沒一個會乖乖聽話的人吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "七冠們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5201052_009"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這是……",
        "unit_id": 106832,
        "voice": "vo_adv_5201052_010"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "以前的……",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……真令人懷念。",
        "unit_id": 106832,
        "voice": "vo_adv_5201052_011"
    },
    {
        "type": "still",
        "still": "520105201"
    },
    {
        "type": "dialogue",
        "name": "七冠們",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5201052_012"
    },
    {
        "type": "dialogue",
        "name": "七冠們",
        "words": "「潛入‧阿斯特朗　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "七冠們",
        "words": "七個願望與創世之殘響」",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "你是否擁有呢──",
        "unit_id": 106831,
        "voice": "vo_adv_5201052_013"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "太陽與星星的祝福。",
        "unit_id": 106831
    }
]