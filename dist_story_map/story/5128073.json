[
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好啦，",
        "unit_id": 127512,
        "voice": "vo_adv_5128073_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然正式開始在新家的生活了……",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是我有一件事",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "得要先跟你討論好才行。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "今天的晚餐是燉菜……",
        "unit_id": 127512,
        "voice": "vo_adv_5128073_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不對，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是要說你跟其他女孩子的相處方式啦！",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也能理解，",
        "unit_id": 127512,
        "voice": "vo_adv_5128073_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你因為工作和公會活動，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n會有必須要跟其他女孩相處的時間。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "去遠方冒險時，",
        "unit_id": 127512,
        "voice": "vo_adv_5128073_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也有可能會不在家，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有時候說不定也會在外面用餐。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這種時候，",
        "unit_id": 127512,
        "voice": "vo_adv_5128073_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不用刻意顧慮也沒關係哦。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算是我，也有因為工作而不能待在你身邊的時候。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "關於這點，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就讓我們彼此尊重吧。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉……",
        "unit_id": 127512,
        "voice": "vo_adv_5128073_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個啊，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然我知道你沒有什麼不好的企圖，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但還是希望你劃清界線啦。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "畢竟，",
        "unit_id": 127512,
        "voice": "vo_adv_5128073_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我是你的妻子啊。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n待遇上可不能跟其他女孩相同吧？",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "無論是何時、",
        "unit_id": 127512,
        "voice": "vo_adv_5128073_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "跟誰、",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "做了什麼事都沒關係。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "即使如此，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最後還是要好好地",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "選擇我喔。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要把身為你妻子的我，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "擺在第一順位。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……坦白說，",
        "unit_id": 127512,
        "voice": "vo_adv_5128073_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是希望比流夏還優先。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要求到這種程度的話就不公平了，所以我會忍耐的。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，",
        "unit_id": 127512,
        "voice": "vo_adv_5128073_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不小心就說了些奇怪的話。",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總之，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想傳達的就是這些，",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127512
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就拜託你囉？",
        "unit_id": 127512
    }
]