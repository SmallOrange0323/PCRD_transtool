        "voice": "vo_adv_2104001_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n現在蘭德索爾的議會制度，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "變成這樣了呀……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……謝謝你，{player}。",
        "unit_id": 106412,
        "voice": "vo_adv_2104001_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你能幫我放在那邊嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是啊……",
        "unit_id": 106412,
        "voice": "vo_adv_2104001_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n說不定，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我正渴望著能獲得多點情報呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "畢竟在前陣子，",
        "unit_id": 106412,
        "voice": "vo_adv_2104001_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我連想正常讀懂文字",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "都不太能如願嘛。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n所以，能像這樣增加知識，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我覺得很愉快呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你也一樣，",
        "unit_id": 106412,
        "voice": "vo_adv_2104001_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "偶爾一起來讀讀書如何？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n如果有看不懂的字，我可以教你……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只要你不介意的話。",
        "unit_id": 106412
    },
