        "type": "dialogue",
        "name": "雪菲",
        "words": "那、",
        "unit_id": 106412,
        "voice": "vo_adv_2104001_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那種事情！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……沒發生過吧、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "應該……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來佩可仔，",
        "unit_id": 106012,
        "voice": "vo_adv_2104001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳又把工作都推給似似花做了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這樣總有一天會露餡的啦。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呀哈哈，",
        "unit_id": 105812,
        "voice": "vo_adv_2104001_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用擔心啦，小凱留♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可是有乖乖得到出宮許可的唷！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我說，",
        "unit_id": 106412,
        "voice": "vo_adv_2104001_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那種事沒發生過對吧……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……啊嗚嗚……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天我是有事情",
        "unit_id": 105812,
        "voice": "vo_adv_2104001_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "想要拜託大家才過來的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿是出門了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～",
        "unit_id": 106012,
        "voice": "vo_adv_2104001_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳找可蘿仔的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她還在裡面睡覺喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "其實呀，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她之前的傷……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105912,
        "voice": "vo_adv_2104001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您來了呀。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下這就",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "立刻去替您準備",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "茶和點心和飯糰……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿？",
        "unit_id": 105812,
        "voice": "vo_adv_2104001_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總覺得妳的臉色有點……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊！",
        "unit_id": 106412,
        "voice": "vo_adv_2104001_027"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n不行呀，媽……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐！　",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳得躺好才行！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剛才",
        "unit_id": 106012,
        "voice": "vo_adv_2104001_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她又差點喊出「媽媽」了對吧……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嘖，",
        "unit_id": 190911,
        "voice": "vo_adv_2104001_029"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真可惜……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……原來如此。",
        "unit_id": 105812,
        "voice": "vo_adv_2104001_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳前陣子戰鬥時受的傷還沒治好啊……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常抱歉。",
        "unit_id": 105912,
        "voice": "vo_adv_2104001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n發燒和暈眩，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遲遲沒有好轉……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是那個叫卡里莎的臭小鬼幹的好事嗎？",
        "unit_id": 190911,
        "voice": "vo_adv_2104001_032"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "都是那傢伙搞的，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "害得窗戶碎滿地，地板也破了洞……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n可惡，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我絕對不會原諒那傢伙！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯……",
        "unit_id": 105812,
        "voice": "vo_adv_2104001_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我原本是想",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拜託大家接下護衛的工作呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來小可蘿，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得要留下來看家比較好呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的☆",
        "unit_id": 105812,
        "voice": "vo_adv_2104001_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們大家",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起去上學吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "上、",
        "unit_id": 106012,
        "voice": "vo_adv_2104001_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "上學！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實呀，",
        "unit_id": 105812,
        "voice": "vo_adv_2104001_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是公務的一環呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n主要是希望能和",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "城內生活的人們再多多交流。",
