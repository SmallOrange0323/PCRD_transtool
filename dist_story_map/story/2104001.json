    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說呀，太太，",
        "unit_id": 106012,
        "voice": "vo_adv_2104001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看看那孩子們，妳怎麼想？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "難以想像不久前，",
        "unit_id": 190911,
        "voice": "vo_adv_2104001_009"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n他們還是會把別人當成玩具的小寶寶們呢……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對呀對呀。",
        "unit_id": 106012,
        "voice": "vo_adv_2104001_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在反倒是一臉",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "「我一個人也什麼都能辦到～」的表情～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "已經不會再「吧噗吧噗」地叫了嗎？",
        "unit_id": 190911,
        "voice": "vo_adv_2104001_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "明明就很適合的說～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我說妳們兩個啊……",
        "unit_id": 106412,
        "voice": "vo_adv_2104001_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "能不能稍微安靜點？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我想要集中精神",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在看書上啊。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吧噗吧噗～♪",
        "unit_id": 106012,
        "voice": "vo_adv_2104001_013"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀、呀～♪",
        "unit_id": 190911,
        "voice": "vo_adv_2104001_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "夠、",
        "unit_id": 106412,
        "voice": "vo_adv_2104001_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "夠了喔！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳們別鬧了……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈☆",
        "unit_id": 105812,
        "voice": "vo_adv_2104001_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳們好像玩得正開心呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "公、",
        "unit_id": 106412,
        "voice": "vo_adv_2104001_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "公主殿下。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n您今日氣色甚好……",
