[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先～生。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n歡迎來到咱們",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n【哞哞自衛隊】的城堡……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家把公會之家",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n稱呼為城堡。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "內部的裝潢也到處都有那種感覺……",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然其他人都不喜歡～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為大部分的人喜歡野外風格♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大家可能都外出了，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n現在誰也不在。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這裡的孩子們都很自由奔放……",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n今天正好沒有什麼工作，所以還好。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但這麼安靜，人家有點寂寞呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n很不錯吧，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n空間這麼寬廣……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為咱們是個大家族，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n沒有這麼大的土地面積的話，沒辦法容納所有人。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也有些孩子討厭狹窄的地方呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "畢竟原本咱們獸人呢，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是生活在和大自然一體的環境下……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n實在不習慣這樣擁擠髒亂的城鎮。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大家喜歡有開放感，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n又寬敞的地方。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但人家就好像是所謂溫室裡的孩子……",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "從小時候，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就常關在房間裡頭。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以反而在森林中會感到不自在，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且衣服也容易髒掉。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家怎麼可以",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n讓客人一直站著呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "請在那邊",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n隨便坐吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家去準備茶和點心♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不要摸那邊的抱枕喔。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那些就像是【哞哞自衛隊】的大家用來佔地盤的東西，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n或者算是私人物品，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大概就是那樣的感覺。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果自己的抱枕一沾上其他人的氣味，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n有的孩子就會抱怨呢……",
        "unit_id": 101011
    },
    {
        "type": "still",
        "still": "101000601"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這裡、這裡。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n到人家的專屬空間來吧♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊哈哈。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不錯吧，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n只有人家的空間很豪華吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "畢竟……人家擔任",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n【哞哞自衛隊】的公會長，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然覺得不大搭調……",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過專屬空間可以隨意佈置，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以人家就按照喜好盡情弄得豪華絢爛。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只有這裡",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n像繪本中的城堡吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生到那裡坐吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家回來了～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n亞瑟、高文、蘭斯洛特♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯？",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，那是玩偶的名字。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那裡擺了很多玩偶。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大家～",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n和王子先生問候吧♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "喜歡～♪",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n超喜歡的，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n很可愛吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有些從老家拿來的，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也有些是到處買來的……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還有自己做的，然後就越來越多了♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀～",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生先打招呼了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是好有禮貌呀♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝王子先生。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很多人不能理解人家的喜好，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還會露出訝異的表情……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生如此接納人家，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家真是太高興了♪",
        "unit_id": 101011
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家的興趣是裁縫……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家常常自己",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n做衣服或玩偶唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家也做一件給王子先生如何？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就這麼辦。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "剛剛人家的魔法吹飛了王子先生，還弄髒了衣服呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就當作是賠償衣服……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家來縫件適合王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n充滿荷葉邊的漂亮衣服♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果王子先生不覺得麻煩的話，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n可以讓人家量尺寸嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然觸摸到男人",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n有些害羞……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但人家之前就很想嘗試做男裝了♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可以嗎？",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家太開心了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生人真好……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那……",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "地下室有大浴場，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n先在那裡把泥巴洗乾淨比較好吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家會準備好替換的衣服。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n而且也正好是這個時間了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n我們順便吃午餐如何呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓人家",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n盛情地『款待』王子先生……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓我們",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n盡情地聊天吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總覺得都在講人家的事而已。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家也想知道王子先生的事。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為您是人家命中註定的王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……王子先生？",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還想說怎麼都沒回話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n原來睡著了呀？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生一定很累了……",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為是王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以都一直忙著幫助有困難的人吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就像第一次邂逅時，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生想要幫忙人家一樣。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然力不從心……",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n馬上就累垮了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n有時候也會被這世間的險惡給擊垮。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但因為是王子先生，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n一定沒有問題的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只要那份溫柔持續地散發光輝……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "對人家來說，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_047"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生是世界上最理想的對象♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊……？",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_048"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎麼了？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_049"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不能倒到人家這裡來呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家會動彈不得呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是的。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_050"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真愛撒嬌……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好唷。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_051"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n躺在人家的膝蓋上，好好休息吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "唱催眠曲給王子先生聽吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010006_052"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真的是",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n可喜可賀、可喜可賀呢……♪",
        "unit_id": 101011
    }
]