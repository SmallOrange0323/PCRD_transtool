        "words": "喔～",
        "unit_id": 117511,
        "voice": "vo_adv_5074301_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "巨大身軀能使出強烈攻擊，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n再加上什麼傷勢都能立刻復原的再生能力。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還真是棘手呢。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能這麼冷靜分析是很可靠啦，",
        "unit_id": 117611,
        "voice": "vo_adv_5074301_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但這種怪物真的打得倒嗎？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳知道嗎？",
        "unit_id": 117511,
        "voice": "vo_adv_5074301_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "醫生擅長救人的知識與技術，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但這同時也表示，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "熟知與其相反的手段喔。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳好像若無其事說出了可怕的話，",
        "unit_id": 117611,
        "voice": "vo_adv_5074301_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但現在聽起來十分令人安心，好神奇啊。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好啦，",
        "unit_id": 117511,
        "voice": "vo_adv_5074301_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "開始動刀吧。",
        "unit_id": 117511
    }
]