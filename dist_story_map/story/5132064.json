[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在聖誕節活動的準備進行期間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克蕾琪塔一個人在會場環顧著。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呼，",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖說最初還想過會變得怎樣，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但總算是逐漸成形了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "照這個情況的話，",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一定會讓陛下高興的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n看來這個活動很有希望。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "接下來只要等到當天就好了吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……不行呢。",
        "unit_id": 1,
        "voice": "vo_adv_5132064_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n完全不行☆",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔唔……！？",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "開口挑剔我活動的妳，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n是哪裡來的哪位啊！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "暴發戶女，",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳是這場活動的負責人嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯、",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯，正是如此！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然不知道妳究竟",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n是什麼來路不明的人，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但妳還真是一副臭屁的樣子！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話說，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳擅自在到處看什麼？非相關人士是禁止進入的喔！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "首先要把這個紀念碑移到其他地方。",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "聽我說啊！？",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為什麼我得聽來路不明的人講的話啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我差不多要叫警衛了喔，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "根本不知道是怎麼回事，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……哎呀？",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎呀哎呀？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這張臉……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我好像有在哪看過啊。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那是在我還沒和陛下相遇前的事。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n是我作為御用商人",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "進出王宮時的事……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是在聖誕樹附近放什麼紀念碑，",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n會變成人潮堵塞擁擠的原因吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n會造成不必要的混亂喔？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "把看點分散",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來確保人流的動線吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是說怎樣？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "造成混亂才是妳原本的目的嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那倒也不賴。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為鬥爭也是祭典的一種啊☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "才、",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "才才不是！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "皇家主辦的聖誕節活動，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n才不可能考慮那種野蠻的事吧！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "什麼嘛，",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那還真遺憾。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳看看，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "相較於攤販的數量，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "飲食的空間可不夠喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也有很多難以邊走邊吃的品項，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳好好安排一下吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "垃圾桶的數量也不夠呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難得的美麗活動，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n到處是垃圾也很掃興。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要是也在垃圾桶上裝飾一下，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n景觀的問題應該就也能解決了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂，",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "流動廁所的數量太少了喔！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n別低估大型活動的人潮了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然如此有必要把需改善點全找出來呢。",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "快替我帶路。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟別看這樣，我也是很忙的啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……啊！",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不由得就聽進去了，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但我也並不是毫無對策地在進行！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可以別自顧自地說個不停嗎！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我有確實製作企劃書了，",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對相關各處的安排也很完美喔！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳可別小看我啊，",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我看了也知道，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳相當能幹，並且正在嘗試認真做出好東西。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可是啊，",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳有不足的地方。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那就是",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "企劃活動的經驗值，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有站在客人的立場思考。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "單論經驗，",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那並不是一朝一夕能成就的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只能靠累積而來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳不是能夠盡情想像",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n該怎麼做來讓客人",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感到開心嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔，",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然很不甘心……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但事情正如妳所說呢。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我作為主辦人，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "經驗值可能確實不足。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話說回來，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就妳這份洞察力和知識……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳究竟是何方神聖？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒什麼，",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就是個路過的製作人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可沒有想篡奪妳的活動啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧，",
        "unit_id": 107111,
        "voice": "vo_adv_5132064_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "跟我來，暴發戶女！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我就來指導妳如何舉辦活動吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是夠了！",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n喂，警衛！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n警衛人呢～！！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被克莉絲提娜檢查的幾天後──"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔唔……",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_025"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然不甘心，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但照著那個人的建議去做後，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n會場改善得彷彿重獲新生……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不愧是【王宮騎士團】的前副團長──",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_026"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可以這麼說吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……唉，真是的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n那時沒有馬上想起她的身分實在是失策呢……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話說回來，",
        "unit_id": 118011,
        "voice": "vo_adv_5132064_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為什麼那麼身處腥風血雨中的人物，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n會去當什麼",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "偶像製作人呢……？",
        "unit_id": 118011
    }
]