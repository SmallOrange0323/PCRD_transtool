        "voice": "vo_adv_5150067_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "差不多該來讓我聽聽妳的煩惱了！",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不論是怎樣的煩惱，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐都會解決的喔♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只限問手足相關的煩惱喔？",
