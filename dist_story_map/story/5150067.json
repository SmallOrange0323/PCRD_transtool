        "voice": "vo_adv_5150067_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "唉……",
        "unit_id": 131711,
        "voice": "vo_adv_5150067_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呃，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我很煩惱……",
        "unit_id": 131711
