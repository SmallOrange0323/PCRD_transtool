    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我的妹妹涅比亞喜歡惡作劇，讓我很困擾。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我該怎麼辦才好？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯嗯，",
        "unit_id": 117111,
        "voice": "vo_adv_5150067_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "原來如此呢～",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我懂，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我明白",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個煩惱喔。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所謂的弟弟或妹妹，",
        "unit_id": 117111,
        "voice": "vo_adv_5150067_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "總之就是會想和和姐姐撒嬌呢。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n他們會有想引起注意的心情喔。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "涅比亞",
        "unit_id": 117111,
        "voice": "vo_adv_5150067_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會不會是想",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n以惡作劇的形式",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來引起姐姐──也就是愛梅斯妳的注意呢？",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是",
        "unit_id": 131711,
        "voice": "vo_adv_5150067_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那樣嗎……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一定是",
        "unit_id": 117111,
        "voice": "vo_adv_5150067_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "吧。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我認為互相理解",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那樣的心情是很重要的呢。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……互相理解",
        "unit_id": 131711,
        "voice": "vo_adv_5150067_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "意思是針對不該做的事情卻只一味制止的話，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "彼此會無法疏通對吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是那很困難呢。",
        "unit_id": 131711,
        "voice": "vo_adv_5150067_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n由我",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "自己講也有點怪，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但我很彆扭。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感覺會花一些時間啊──",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐手刀喔。",
        "unit_id": 117111,
        "voice": "vo_adv_5150067_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 131711,
        "voice": "vo_adv_5150067_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐手刀",
        "unit_id": 117111,
        "voice": "vo_adv_5150067_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "會解決一切的。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "解決……",
        "unit_id": 131711,
        "voice": "vo_adv_5150067_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一切……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐手刀",
        "unit_id": 117111,
        "voice": "vo_adv_5150067_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是會傳達姐姐心情的",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "萬能攻擊。",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n要是愛梅斯也學會這招，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就也會是出色的姐姐喔♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳剛剛是不是說了攻擊？",
        "unit_id": 131711,
        "voice": "vo_adv_5150067_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就請妳教我吧……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵♪",
        "unit_id": 117111,
        "voice": "vo_adv_5150067_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要精通姐姐之道",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然漫長又險峻，",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但就交給姐姐我吧♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "給我等著，",
        "unit_id": 131711,
        "voice": "vo_adv_5150067_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n作為妳的姐姐，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我會把這招練到極致的。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
