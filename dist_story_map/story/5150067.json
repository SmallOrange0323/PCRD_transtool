    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "希望妳可以多多幫我替他導覽這部分呢♪",
        "unit_id": 117111
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我可沒有勇氣把姐姐當成觀光勝地來介紹。",
