    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "──以上",
        "unit_id": 118011,
        "voice": "vo_adv_5132101_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "便是聖誕節活動的進度報告。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "準備狀況十分順利，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "再過一些時間，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n將會再麻煩陛下進行視察。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然要勞煩您親自走訪，",
        "unit_id": 118011,
        "voice": "vo_adv_5132101_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但我敢保證，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "在聖誕節當天，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n一定獻給陛下",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "最棒的聖誕節！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "辛苦了，",
        "unit_id": 105812,
        "voice": "vo_adv_5132101_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "事情能夠順利進行，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "實在是太好了♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我自己",
        "unit_id": 105812,
        "voice": "vo_adv_5132101_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然很喜歡享受活動，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是一但要我自己舉辦，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就完全不知道該如何著手……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以，",
        "unit_id": 105812,
        "voice": "vo_adv_5132101_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把事情交給克蕾琪塔處理，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來是正確的決定呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是，",
        "unit_id": 118011,
        "voice": "vo_adv_5132101_005"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "非常感謝陛下的誇獎！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "本次活動是由皇家主辦，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n所以除了不要丟皇家的臉，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "更重要的，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n是要讓陛下",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "能夠開心地享受活動，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我們會用心努力準備的！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對了，",
        "unit_id": 118011,
        "voice": "vo_adv_5132101_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下參加活動所需穿著的服裝也將於近期完成！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "相信會是一件適合陛下，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "惹人憐愛且豪華亮麗的服裝！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝、",
        "unit_id": 105812,
        "voice": "vo_adv_5132101_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "請放心。",
        "unit_id": 6111,
        "voice": "vo_adv_5132101_008"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "我也有先看過設計圖，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "成品是不會像克蕾琪塔小姐那樣，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "充滿暴發戶興趣的服裝。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "喂！",
        "unit_id": 118011,
        "voice": "vo_adv_5132101_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那邊不要給我多嘴！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "比起那個，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "警衛相關事項是否都安排好了呢？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "一切都依計畫進行。",
        "unit_id": 6111,
        "voice": "vo_adv_5132101_010"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不過，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "雖說是皇家主辦的活動，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n但警衛的人數是否會有點太多了呢？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "天真、",
        "unit_id": 118011,
        "voice": "vo_adv_5132101_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "太天真了！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "依據我的調查，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n在蘭德索爾的聖誕節，一定會發生什麼問題。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一定會發生的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的確",
        "unit_id": 105812,
        "voice": "vo_adv_5132101_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有聽過這個傳聞。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n每次都發生出人意料之外的事情，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很不得了的樣子。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過，那也只是過去的事！",
        "unit_id": 118011,
        "voice": "vo_adv_5132101_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "由我推動的聖誕節，絕對不容許發生類似的慘事！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5132101_014"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "「聖誕哭泣寶貝　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "為誰存在的幸福之日」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501070"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不知為什麼，",
        "unit_id": 6111,
        "voice": "vo_adv_5132101_015"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就在剛才，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "似乎感覺到有旗立起來的樣子。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812,
        "voice": "vo_adv_5132101_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只是發生一點問題的話……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不可以！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣想對克蕾琪塔小姐不好意思！",
        "unit_id": 105812
    }
]