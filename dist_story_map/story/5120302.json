[
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "無法徹底將吸收的魔力納入呢。",
        "unit_id": 126211,
        "voice": "vo_adv_5120302_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是因為對自身無法控制的力量出手",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "才會變成這個樣子。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n用雪的說法來講，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就是",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不美麗吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "別擅自學我說話啊。",
        "unit_id": 126311,
        "voice": "vo_adv_5120302_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以說，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞有什麼打算？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n……贏得了嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳是在跟誰說話。",
        "unit_id": 126211,
        "voice": "vo_adv_5120302_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身可是統御黑夜之人。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那雪呢？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳果然害怕起來了嗎？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳是在跟誰說話呀。",
        "unit_id": 126311,
        "voice": "vo_adv_5120302_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我可是統御美麗之人呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵……",
        "unit_id": 126211,
        "voice": "vo_adv_5120302_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那就好。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雪，咱們上，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "可別掉以輕心了！",
        "unit_id": 126211
    }
]