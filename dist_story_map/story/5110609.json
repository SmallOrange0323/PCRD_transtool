[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了埋伏{player}等人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n諾維姆與尾狗刀在街上執行監視任務。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "唔……",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "好無聊喔！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那些傢伙們完全沒有現身！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我已經煩躁得快受不了，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "感覺現在就想衝出去大鬧一番！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "冷靜點，諾維姆。",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_001"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "像這種時候就要吃這個。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n來，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "給妳紅豆麵包和牛奶。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "又是這個！",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_002"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我早已吃膩了說！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "食物什麼的，明明還有其他很多選擇，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n為何每次都只有紅豆麵包和牛奶啊！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳不知道嗎？",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "從以前開始，在監視時，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "一直都是吃紅豆麵包和牛奶。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "要是吃了這之外的食物──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "可是會死的喔？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "咦，",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_004"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "騙人……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這是騙人的吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_005"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "騙人的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你、",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_006"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你這個傢伙……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "真是夠了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "別做這種白費力氣的事！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n還不快給我住手！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好啦好啦。",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_007"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這時候",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果有公會小屋",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就好了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果有個據點，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "監視也會輕鬆許多。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你只是想要",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_008"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "偷懶而已吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不過也是，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "一般都會希望有個",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "公會小屋的嘛。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "沒錯！",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_009"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我希望有棟就算我大鬧特鬧，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "也不會弄壞的小屋！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我倒是希望妳不要在室內胡鬧。",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "至於我嘛，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果可以有間隔音效果良好的個人房間，我就很開心了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喂！",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_011"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你這是在說我很吵嗎！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我並沒有這麼說喔。",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "話說回來，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這對現在的我們來說，或許是天方夜譚吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "為了執行任務，",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_013"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們得到處東晃晃西晃晃。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "平時也沒辦法結交工作夥伴，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "甚至享受冒險的樂趣。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "……仔細想來，",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_014"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我們根本沒有辦法好好享受這遊戲的樂趣，是吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "雖說因為有任務在身，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "但總覺得有點寂寞……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_5110609_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這也是沒辦法的事。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這種場合我們必須忍耐啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這我知道。",
        "unit_id": 106114,
        "voice": "vo_adv_5110609_016"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "不過，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我真心期望總有一天，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我們可以坦率地享受玩遊戲的樂趣。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "諾維姆不禁遙想起未來的日子。"
    }
]