    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "？",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n總覺得",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "好刺眼。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n甘蔗燈",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
