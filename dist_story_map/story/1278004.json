    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "──因為偶發的門出現率上升，",
        "unit_id": 127812,
        "voice": "vo_adv_1278004_000"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "魔物從其他世界的湧入",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n增加為以前的數倍。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "由於不曉得堵住門的方法，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n推測損害無法歸零，但──",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "各地居民們認知的提升、",
        "unit_id": 127812,
        "voice": "vo_adv_1278004_001"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "相互扶助組織的設立、",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n與蘭德索爾方面的合作……",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "這些都在進行當中，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n所以我想今後狀況會持續改善的",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……以上是我的報告。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "──好的，",
        "unit_id": 126511,
        "voice": "vo_adv_1278004_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "烏爾姆。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n騎士他們不必說，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "今後要是也能持續增加和",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n吉歐‧格黑納的交流就好了呢。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "是的。",
        "unit_id": 127812,
        "voice": "vo_adv_1278004_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼……",
        "unit_id": 126511,
        "voice": "vo_adv_1278004_004"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "辛苦妳了。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n好好休息吧。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "我先告辭了，",
