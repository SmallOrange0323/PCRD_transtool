        "voice": "vo_adv_1278004_012"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n討厭啦──騎士先生，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n我一直都很認真啦──",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……畢竟，",
