        "voice": "vo_adv_1278004_013"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n我總不能讓主人丟臉，",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n所以多少會",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "好好做喔。",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……嗯。",
        "unit_id": 127812,
        "voice": "vo_adv_1278004_014"
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "\n那是──",
        "unit_id": 127812
    },
    {
        "type": "dialogue",
        "name": "烏爾姆",
        "words": "……",
