    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來出一個方案吧☆",
        "unit_id": 107111
    },
