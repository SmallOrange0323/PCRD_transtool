        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "贏了的話就可以獲得免費可麗餅……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n相對地，輸了的話",
        "unit_id": 107111
