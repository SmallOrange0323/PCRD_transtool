    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在因明天就要迎來７周年而喧鬧的蘭德索爾的街角，再稍微離遠一點的地方。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有兩名客人來訪拉比林斯達的可麗餅店。"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "歡迎光臨～！",
        "unit_id": 106812,
        "voice": "vo_adv_9010007_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要不要來點好吃的可麗餅～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "咦，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊哈哈，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是稀奇的二人組呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "經營得真是勤快啊，",
        "unit_id": 107111,
        "voice": "vo_adv_9010007_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可麗餅店。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳居然在店裡招待客人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "世上真是無奇不有。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那當然，",
        "unit_id": 106812,
        "voice": "vo_adv_9010007_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我偶爾也是會認真工作的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟明天是值得紀念的７周年啊～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n妳們就來見識一下可麗餅店長的本領吧！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "雖然這麼說，",
        "unit_id": 107011,
        "voice": "vo_adv_9010007_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但來客看起來很少呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真不留情～！",
        "unit_id": 106812,
        "voice": "vo_adv_9010007_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒辦法啊，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳看那邊的攤販！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n大夢想樂園的經理在開外賣吉拿棒店！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n另一邊",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是銀章魚商會拿出真本事在賣章魚燒耶？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈！",
        "unit_id": 107111,
        "voice": "vo_adv_9010007_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n普通口味的可麗餅根本不是對手☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "徹底輸了呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "迷宮女王。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要說這種話不如來幫幫我！",
        "unit_id": 106812,
        "voice": "vo_adv_9010007_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "七冠同心協力的話，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n銷量",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也許能夠",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "稍微提升吧？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "完全無法理解。",
        "unit_id": 107011,
        "voice": "vo_adv_9010007_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要說的話",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "設攤位置這些問題",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都是因為妳計算失誤吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "自作自受。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "跟妳說，",
        "unit_id": 106812,
        "voice": "vo_adv_9010007_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "想說這樣下去事態不妙，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我事到如今",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n才在構思周年慶限定的特別可麗餅。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但是想不出一個滿意的點子～",
