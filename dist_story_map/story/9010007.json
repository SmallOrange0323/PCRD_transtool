    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "弟弟可麗餅」",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "ver.1.7.1",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喔！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n很厲害吧～！？",
        "unit_id": 106812
    },
