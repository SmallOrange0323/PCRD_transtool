        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不行的話",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "每個都用７萬盧幣來買。",
        "unit_id": 107011
