    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要用７萬盧幣來購買可麗餅的新優惠。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "名字就叫",
        "unit_id": 107111,
        "voice": "vo_adv_9010007_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「決鬥可麗餅」",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "吧☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這可是會大賣喔？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "駁回。",
        "unit_id": 106812,
        "voice": "vo_adv_9010007_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼不怕死的人，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一定比我的客人還要少好不好。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我說啊，",
        "unit_id": 106812,
        "voice": "vo_adv_9010007_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "似似花有想法嗎？",
        "unit_id": 106812
    },
