        "name": "靜流",
        "words": "等一下！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個人，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不就是我的弟弟嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳　",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "說　",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我　",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "的　",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "弟　",
        "unit_id": 102711
    },
    {
