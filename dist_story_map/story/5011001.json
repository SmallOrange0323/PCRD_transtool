        "voice": "vo_adv_5011001_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人並沒有姐姐。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "難道說……",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_019"
    },
