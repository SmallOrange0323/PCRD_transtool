    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "你們感情真好真讓人羨慕，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104911,
        "voice": "vo_adv_5011001_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這裡有賣酒呀！？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "正在找這瓶利口酒呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是巧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也正在找加入巧克力中的\n利口酒。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "它的味道很香，是我喜歡的酒類……",
        "unit_id": 102711
    },
