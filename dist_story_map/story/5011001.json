        "voice": "vo_adv_5011001_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "但是{player}人生中的女孩子，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n有姐姐一個人就足夠了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我要請妳在這裡放棄了！",
        "unit_id": 104911
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
