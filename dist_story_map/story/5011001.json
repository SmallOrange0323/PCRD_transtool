        "voice": "vo_adv_5011001_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這裡",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "似乎只放了一瓶呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是啊，",
        "unit_id": 104911,
        "voice": "vo_adv_5011001_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而且上頭還寫了僅剩上架品。",
        "unit_id": 104911
    },
    {
        "type": "still",
        "still": "501100102"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我無論如何都需要這瓶酒。",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "若是少了這個，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我的巧克力會無法完成。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那點我也一樣啊！",
        "unit_id": 104911,
        "voice": "vo_adv_5011001_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我想把那個巧克力送給那位大人吃！",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也一樣，",
        "unit_id": 104911,
        "voice": "vo_adv_5011001_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "想給弟弟吃好吃的巧克力啊！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然是給弟弟的巧克力，可以不需要這麼講究呀！",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n可以請妳把這瓶酒讓給我嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "無論用什麼手段",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "都絕對要在情人節裡，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "讓{player}大人\n吃到巧克力才行啊！",
        "unit_id": 102711
    },
    {
        "type": "background",
        "background": "500610"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "靜流",
