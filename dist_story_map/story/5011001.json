    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因料理的話題而興趣相投的靜流與惠理子，\n兩人有說有笑地逛著店內。"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對了對了，",
        "unit_id": 104911,
        "voice": "vo_adv_5011001_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在咖哩中加入這個的話，",
        "unit_id": 104911
