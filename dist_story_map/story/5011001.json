        "type": "dialogue",
        "name": "靜流",
        "words": "算了，沒關係。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n既然這樣，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要不要用做巧克力來比賽？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳說做巧克力！？",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯。",
        "unit_id": 104911,
        "voice": "vo_adv_5011001_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "讓{player}吃下我們做出來的",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n巧克力。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "讓{player}說好吃的人，",
        "unit_id": 104911,
        "voice": "vo_adv_5011001_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就能獨占他。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "很簡單吧？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要接受妳的提案讓人很不愉快……",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不過，好吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我接受這場比賽！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為了{player}，",
        "unit_id": 104911,
        "voice": "vo_adv_5011001_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我會盡全力的！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對{player}大人知悉透徹的我來說。",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_032"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n是絕對不會輸掉這場比賽的！",
        "unit_id": 102711
