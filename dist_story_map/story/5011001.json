    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不可饒恕……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不可饒恕――！！",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳這個要破壞我和命運之人關係的無禮之徒！！",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n無論是這瓶酒！　",
        "unit_id": 102711
