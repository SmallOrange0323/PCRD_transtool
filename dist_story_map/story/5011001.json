    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為我和{player}是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n有命運的紅線連結的姐弟呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "妳說……",
        "unit_id": 102711,
        "voice": "vo_adv_5011001_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "命運的紅線……？",
