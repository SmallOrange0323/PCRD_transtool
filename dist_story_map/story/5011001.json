        "type": "dialogue",
        "name": "惠理子",
        "words": "還是那位大人！　",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我都不會讓給妳的！！",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳說得還真過分呢……",
