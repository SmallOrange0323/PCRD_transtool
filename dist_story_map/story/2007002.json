[
    {
        "type": "background",
        "background": "500151"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼。",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總算可以鬆一口氣了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n原本在牧場周遭徘徊的魔物",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也差不多都趕走了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉呀～",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "飛空艇非常活躍呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "火力甚至有點大過頭了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哼哼♪",
        "unit_id": 103211,
        "voice": "vo_adv_2007002_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n對吧對吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n妳可以再多誇獎一點也無妨！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃，",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳可別太得意忘形了唷～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖說這次還好順利解決了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但是飛空艇還只是試驗階段的實驗機種吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果因為失去控制而發生了無法收拾的事態，",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那可就慘了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "實際上，",
        "unit_id": 103411,
        "voice": "vo_adv_2007002_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就是因為機體在途中故障才會墜機就是了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還以為死定了呢～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "每次都這樣啦。",
        "unit_id": 103411,
        "voice": "vo_adv_2007002_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n不知道這算不算勞災呀，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我已經受夠這黑心企業（公會）啦。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "別再碎碎念了，",
        "unit_id": 104811,
        "voice": "vo_adv_2007002_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n還得拜託妳先替大家進行治療呢……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "優花梨。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "比起魔物的攻擊，",
        "unit_id": 104811,
        "voice": "vo_adv_2007002_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n或許因為飛空艇墜落而造成的災害還比較嚴重呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈。",
        "unit_id": 104611,
        "voice": "vo_adv_2007002_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n還真是走一步退兩步",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "的感覺喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可是呢……",
        "unit_id": 104611,
        "voice": "vo_adv_2007002_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n估算下來，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "牧場的重建約花上一星期就可以完成了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "從結果來看，",
        "unit_id": 104611,
        "voice": "vo_adv_2007002_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "幾乎沒有人員受傷。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "也算是告",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "了個段落的感覺喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "辛苦大家啦～",
        "unit_id": 103311,
        "voice": "vo_adv_2007002_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n都是多虧了【墨丘利財團】，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n還有其他人來幫忙重建。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不管怎麼感謝你們都不夠呢，",
        "unit_id": 103311,
        "voice": "vo_adv_2007002_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n非常謝謝你們♪",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不必道謝！",
        "unit_id": 103211,
        "voice": "vo_adv_2007002_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這是出身高貴的人的義務唷，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n對吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "的確是這樣呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊～……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，真折騰死人啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是嘛，",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大家都沒出什麼事就好。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呃、",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "佩可小姐？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可可蘿和{player}回來之後……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在太陽下山以前，",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一塊回【咲戀育幼院】吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n畢竟，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "孩子們也很擔心吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "牧場的重建工作，也還沒全部完成，",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n一直在這打擾人家工作也不太好。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n且在入了夜之後，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要走山路也很困難呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "了解～",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一直以來受到妳的關照了呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咲戀。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿她們……",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n記得好像",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說是要去，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小栞的姐姐所在的那個精靈族村莊呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我本來也想和她們一塊去的，",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但又不能不處理這些魔物……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這些魔物",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是比想像中還要強呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "解決起來可費了不少功夫啊。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "其實有一些令我在意的事。",
        "unit_id": 104811,
        "voice": "vo_adv_2007002_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這一次，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "在牧場週遭徘徊的魔物……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n妳們不覺得，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好像都是沒見過又有著奇特造型的魔物嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦，",
        "unit_id": 103211,
        "voice": "vo_adv_2007002_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "完全沒有仔細去看所以不知道呀，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哦呵呵呵呵♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可沒有在問秋乃呦。",
        "unit_id": 104811,
        "voice": "vo_adv_2007002_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "該怎麼說……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n就像將多個魔物給合成起來，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "有著奇妙的形狀呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個該不會也是因為大量破壞魔法的影響，",
        "unit_id": 104811,
        "voice": "vo_adv_2007002_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "才產生的新種魔物吧？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "曾經聽說如果魔力受到擾亂，",
        "unit_id": 104811,
        "voice": "vo_adv_2007002_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "或是被強力的破壞魔法直擊的話……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n會造成生態系的影響，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n也可能會有一些奇珍的魔物冒出來到處橫行。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不……",
        "unit_id": 103311,
        "voice": "vo_adv_2007002_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n那些魔物雖然說相當罕見，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但曾在牧場的附近看過的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且是在被大量破壞魔法直擊",
        "unit_id": 103311,
        "voice": "vo_adv_2007002_029"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "以前的事了喔。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但一年中也不一定會",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "看到幾次。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯……",
        "unit_id": 104611,
        "voice": "vo_adv_2007002_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n是在這附近，特有、變種的感覺喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "珍貴的動物或魔物，大多都可以高價售出喵，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "早知道抓起來就好了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "又在盤算那種事……",
        "unit_id": 103411,
        "voice": "vo_adv_2007002_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n買賣生物之類的事，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "總會讓我覺得不太心安呀。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n而且管理上也得費番功夫，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我覺得大概是做不成什麼好生意呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "唔。",
        "unit_id": 104811,
        "voice": "vo_adv_2007002_032"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n發生突變的情況，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "大多都會因為不適應環境，很快就滅絕了。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也許有保護的必要也說不定呢。",
        "unit_id": 104811,
        "voice": "vo_adv_2007002_033"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n以研究素材來說相當珍貴，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "轉賣給研究所說不定還有個好價錢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "育養那些魔物所花費的資金，",
        "unit_id": 104811,
        "voice": "vo_adv_2007002_034"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就讓牠們自己來賺。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這也挺合理的呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "感覺挺划算的呢。",
        "unit_id": 104811,
        "voice": "vo_adv_2007002_035"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n或許可以認真來實行看看",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "奇妙的魔物捕捉作戰也不錯呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳們",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還真的什麼都會想到做生意呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n【墨丘利財團】",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是充滿活力啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就隨妳們高興吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不關我們【咲戀育幼院】的事。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "之後就各奔東西吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然這次我們站在同一陣線，",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但我們本來",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就不是同一個公會呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是啊。",
        "unit_id": 103211,
        "voice": "vo_adv_2007002_039"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n今後也讓我們以良好的競爭關係",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "再好好切磋琢磨一番吧，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n咲戀♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但以我個人的角度來說，",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可是完全不想和妳這傢伙再扯上任何關係了呢……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位～！",
        "unit_id": 105913,
        "voice": "vo_adv_2007002_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好意思來晚了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人回來了♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哎呀。",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n{player}一行人，好像回來了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～！",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}你們，\n歡迎回～來～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有喔！",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有好好地打招呼真是個好孩子呢，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "乖唷～乖喔～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦、",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這話怎麼說得好像我老爹一樣呢……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然大家都和樂融融的唷～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "別擔心啦♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說來精靈族的村莊情況怎樣呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家都還好嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811,
        "voice": "vo_adv_2007002_047"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n姊姊她也依舊活蹦亂跳的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "總之是安心了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯。",
        "unit_id": 105913,
        "voice": "vo_adv_2007002_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n村莊的方面，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎沒有受到什麼災害的影響。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大量破壞魔法……",
        "unit_id": 105913,
        "voice": "vo_adv_2007002_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可說是相當不自然地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只在特定的範圍內",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "造成了損害呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣啊～",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在大量破壞魔法的爆炸前後，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n周圍好像都被設置了結界呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以破壞力",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "才沒有波及到特定範圍以外的地方吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是如此。",
        "unit_id": 105913,
        "voice": "vo_adv_2007002_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "此外，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也從栞小姐的姐姐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "初音小姐那，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n聽到了一些重要的情報唷",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來特地前往了一趟精靈族的村落，",
        "unit_id": 105913,
        "voice": "vo_adv_2007002_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是正確的決定。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "重要的情報？",
        "unit_id": 104611,
        "voice": "vo_adv_2007002_054"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "什麼什麼，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好像聞到一筆大生意的味道了喵♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913,
        "voice": "vo_adv_2007002_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不太清楚能不能賺到錢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是聽說",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有一位占卜師，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在大量破壞魔法轟炸下來之前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就已經預知到災難將要發生。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是因為",
        "unit_id": 105913,
        "voice": "vo_adv_2007002_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位占卜師的事前警告，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n才讓精靈族村莊受到的損害",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "得以降到最小。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不論是大量破壞魔法，",
        "unit_id": 105913,
        "voice": "vo_adv_2007002_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是之前魔物們的失控，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也都是因為他們在事前就得知了消息，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才能成功避掉損害吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為這番話相當可疑，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以他們一開始也半信半疑的就是了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而當實際看到了",
        "unit_id": 105913,
        "voice": "vo_adv_2007002_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大量破壞魔法的炸裂之後……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "初音小姐說",
        "unit_id": 105913,
        "voice": "vo_adv_2007002_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『早知道也把",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n預知內容告訴牧場的大家就好了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "』\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感到",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相當懊悔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "占卜？",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_060"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n的確聽起來相當可疑呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n如果真的能預知未來的話，那就真的很驚人了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "照理來說，",
        "unit_id": 102811,
        "voice": "vo_adv_2007002_061"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "預知未來是一種不管用什麼魔法都不可能辦到的奇蹟唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真令人在意呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還想要",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "問得更清楚一點呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正因如此，",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_063"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "施放了大量破壞魔法的「那男人」，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n將我所有一切都奪走的尤絲蒂亞娜……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他的一舉一動，\n都讓人覺得他能夠預知未來。",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_064"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣看來，",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那個占卜師可能也跟「那男人」擁有相同的力量也說不定？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這其中或許會有什麼關聯，",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n看來必須去調查看看呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_067"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的可以預知未來的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n至少當「那男人」又打算做些什麼壞事時，能事先知道也說不定。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那傢伙的力量，",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然看起來被削弱了不少的樣子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但仍不能大意呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了不再讓他",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_069"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能夠加害於他人……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不讓任何人再因此而落淚，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該要有所準備才行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "找尋並拜訪那名占卜師，",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "把話給問清楚吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總是被人給壓著欺負也很鬱悶，",
        "unit_id": 105812,
        "voice": "vo_adv_2007002_071"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該是輪到我們，主動向「那男人」出擊的時候了。",
        "unit_id": 105812
    }
]