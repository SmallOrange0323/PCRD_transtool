    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ありがとうございます。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "やっぱり褒められるとうれしいものですね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "たとえそれが騎士さんだとしても。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "は？　",
        "unit_id": 113911,
        "voice": "vo_adv_6050107_001"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "なに言ってるんですか。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "別にそういう意図はないんですけど……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "って、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ああ。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n妖艶って言いたいんでしょうか。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "そういうことにしておいてあげます。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ええ、",
        "unit_id": 113911,
        "voice": "vo_adv_6050107_002"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "そうですとも。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "何せレイ様の凛々しさをところどころに取り入れましたからね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "え？　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "騎士さんも着たいんですか？　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "いや、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "さすがにこのままじゃ……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "かわいいって言っておけばいいと思ってます？",
        "unit_id": 113911,
        "voice": "vo_adv_6050107_003"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "って、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "騎士さんはそういうこと考えませんよね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "本当は",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\nかっこいいって言って欲しいところですけど……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "ありがとうございます。",
        "unit_id": 113911
    }
]