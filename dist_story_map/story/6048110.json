    {
        "type": "dialogue",
        "name": "依里",
        "words": "拉菲……",
        "unit_id": 113811,
        "voice": "vo_adv_6048110_000"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "走了呢……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "結果到最後都匆匆忙忙地，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "沒辦法和她好好地悠閒相處啊。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "畢竟又變成天使了呢。",
        "unit_id": 113811,
        "voice": "vo_adv_6048110_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然沒辦法使出像那孩子一樣的魔法，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過去試著做些",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我能做到的事或許也不錯呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……對啊，",
        "unit_id": 113811,
        "voice": "vo_adv_6048110_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "發生一堆事件，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "都沒怎麼和那孩子玩到呢。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n下次要緊緊跟在她身邊陪她一起玩，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "免得她又胡亂使出魔法！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "……除了是以朋友的身分外，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "同時也是以姐妹的身分、",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呦。",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "別說了！",
        "unit_id": 113811,
        "voice": "vo_adv_6048110_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "一想到還會有那樣的遭遇就覺得很恐怖啊！",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "雖然有負責監督的弓箭待在身邊，",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "應該沒問題才是……",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 113811
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真希望她能好好成長呢。",
        "unit_id": 113811
    }
]