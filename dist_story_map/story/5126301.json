[
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸～欸～",
        "unit_id": 127311,
        "voice": "vo_adv_5126301_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "傳說中的魔物……",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "記得是叫阿爾杰什寶？",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣一看",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像氣炸了欸……？",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n牠是那個嗎，",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "有起床氣的類型～？",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都已經睡了800年，",
        "unit_id": 127211,
        "voice": "vo_adv_5126301_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就繼續睡下去啦！！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真是的，",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼要在這個時間點醒來……",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是因為我敲響了鐘呀……",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……真、",
        "unit_id": 127211,
        "voice": "vo_adv_5126301_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是沒辦法呢！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n看來我好像",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也稍微有一點責任，",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就來盡一下",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的義務吧！",
        "unit_id": 127211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也會幫忙的！",
        "unit_id": 127311,
        "voice": "vo_adv_5126301_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "阿爾杰什寶，",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然很抱歉，",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但要請你再回去睡覺覺囉！",
        "unit_id": 127311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好，",
        "unit_id": 127211,
        "voice": "vo_adv_5126301_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們上吧！！",
        "unit_id": 127211
    }
]