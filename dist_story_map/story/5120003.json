[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隨著與各地的魔物們進行交流，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n伊莉亞身為「傳說的吸血鬼」的地位與名聲也漸漸提升。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在這樣的情況中，雪則是──"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真令人無法接受。",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是這鎮上的那些魔物啊！",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "大家",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都不停喊「伊莉亞伊莉亞」把她捧得高高在上。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "明明擁有如此美貌的我就離它們這麼近耶！",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我說，",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你也這麼想對吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n是這麼想的吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵♪",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n真不愧是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一直待在我身邊看著我的美貌的人。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "給你可以",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "更靠近看我的權利喔……♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真奇怪？",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是因為最近都沒什麼讓你看我的美貌嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那你會鬧彆扭也是難免的呢♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "下次我會留時間給你，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "讓你可以單獨",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "仔細地欣賞我的美貌。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "所以說呢，",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我打算讓這城鎮的魔物們",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都知道我的美貌！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不……",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "光是這樣也很無趣呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "既然都要做了，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就招集大量被我的美貌所俘虜的僕人，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "打造「雪的美麗樂園」吧♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你當然",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也會幫忙我對吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼了？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "眼神游移不定的……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是我太過耀眼讓你不敢直視了，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你的心情我非常了解。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那我們走吧！",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就用我的美貌",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來篡奪這座城鎮吧♪",
        "unit_id": 126311
    },
    {
        "type": "background",
        "background": "501980"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "欸，",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那邊的魔物。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如何？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你不覺得我很美嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "咦？",
        "unit_id": 1611,
        "voice": "vo_adv_5120003_011"
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "\n這個人類突然在說什麼啊……？",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來看看",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這光滑的肌膚有多美麗。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很細緻",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "又滑順對吧……♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果願意成為被我的美貌所俘虜的僕人，",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就可以讓你摸摸看喔……♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如何？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你無法抗拒這個魅力吧……？　",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "喂喂，",
        "unit_id": 1611,
        "voice": "vo_adv_5120003_015"
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "這肌膚也太柔嫩了吧……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "\n妳這樣子",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "根本無法抵擋天敵的攻擊啊！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什麼！？",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_016"
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "得讓皮膚變得更堅硬才行啊！",
        "unit_id": 1611,
        "voice": "vo_adv_5120003_017"
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "\n妳這樣",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物１",
        "words": "在野外可活不下去喔……！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……呵。",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看樣子",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "它對美的感覺似乎和我們差太多了呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也是有這種情況呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "去找下一個吧！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗨，",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那邊的魔物。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你來看看我的秀髮。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看看可以為這座灰暗的城鎮",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "增添明亮色彩的亮麗光澤。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如何？",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你是不是想成為我的僕人了？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這次肯定沒問題。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "無論是什麼樣的魔物",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都會瞬間迷上我的秀髮。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "唉呀，",
        "unit_id": 1611,
        "voice": "vo_adv_5120003_023"
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "這稀薄的毛髮是怎麼回事？",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "\n毛髮如果不更濃密一點，可是會被笑的喔。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "毛髮要濃密！？",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_024"
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "真是的，",
        "unit_id": 1611,
        "voice": "vo_adv_5120003_025"
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "真拿妳沒辦法。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "\n我把我的毛髮分給妳一點吧。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊……",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "謝謝。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "再見啦，",
        "unit_id": 1611,
        "voice": "vo_adv_5120003_027"
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "光滑無毛的人類小姐。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物２",
        "words": "\n等妳毛髮長得夠濃密了再來吧。",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "……嗯……",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哎呀，",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_029"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我真是，竟然這麼地冒失。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "忘記了我的美貌",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "並不是只有外表而已。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我在磨練自己的過程中，",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_030"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "學會了充滿魅力的動作舉止。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "用那樣的動作舉止來訴說我的美貌，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n肯定比較容易讓魔物們了解。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這次真的要上囉！",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_031"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n就用我完美的身材擺出",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n祕藏的姿勢來決勝負！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "魔物３",
        "words": "妳的觸手不夠，觸手不夠啊。",
        "unit_id": 1611,
        "voice": "vo_adv_5120003_032"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我怎麼可能會有什麼觸手啊……！？",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_033"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔",
        "unit_id": 126311,
        "voice": "vo_adv_5120003_034"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "～嗯……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這城鎮太奇怪了……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n沒想到魔物們",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會這麼",
