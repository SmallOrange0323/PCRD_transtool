        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "必須阻止她才行呢……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……傳說的吸血鬼之力",
        "unit_id": 126211,
        "voice": "vo_adv_5120003_074"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是嗎。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n感覺可信度真是越來越高了呢……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是……",
        "unit_id": 126211,
        "voice": "vo_adv_5120003_075"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這真的",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
