    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與流夏乘著沙上船朝著被告知的漁場前進。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "行進得還滿順的啊。",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來操縱方式",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "和在水上沒有太大的差別呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "地形的影響",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "比想像中還要來得大呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "每次經過沙丘就會跳起來的感覺，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也和在海上很相似。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "話又說回來，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "陽光很強烈呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你要好好補充水分喔。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你有躲在陰影處",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好好保存體力呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呵呵，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你也已經",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是個獨當一面的釣客了呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我還不要緊。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別擔心，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這就和盛夏的海釣差不多。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我已經習慣了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "話雖然這麼說，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但這搖晃的幅度有點太大了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n簡直就像是在暴風雨中……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你快抓牢！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是危險啊。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我都沒注意到那種地方",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "居然會有岩石。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要比喻的話，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這裡就像是潛藏著許多暗礁的水域。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這下可不能鬆懈了呢……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我先專心掌舵，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "麻煩你注意周圍。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在沙上行駛一段時間後，兩人終於穿越了岩石區，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n接著眼前出現了遼闊的流沙地帶。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們終於穿越岩石區了呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哦",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當然沒問題了……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是想這麼說，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但似乎被你看出來了呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "炎熱的天氣加上操縱不熟悉的船，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_010"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓我開始頭暈了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我稍微休息一下，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "馬上就……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_011"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這水真是冰涼呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n是在剛才的市場",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "買的嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你叫我",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_012"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也要舔這個？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是要透過岩鹽補充礦物質啊。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你還挺可靠的嘛。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_013"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這該不會是……",
        "unit_id": 127612
    },
    {
        "type": "background",
        "background": "502060"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_014"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不過",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "身為一家之主，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是會希望",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n他能再稍微有點擔當呢。",
        "unit_id": 127612
    },
    {
        "type": "background",
        "background": "501530"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "難道",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_015"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是神燈精靈",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "聽了我當時說的話，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以把那個當成願望替我實現了？　",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊啊……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我已經",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不要緊了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那個，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我想問個問題，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n有沒有",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "感受到",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什麼奇怪的感覺？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊哈哈……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_017"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒事，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我只是有點在意而已。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n如果是錯覺就算了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這聲音……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_018"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是獵物出現了呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就讓我們",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來盡情地釣魚吧！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯？",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_019"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "怎麼了？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n有忘了什麼事嗎……？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊啊，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_020"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那條繩子嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你不是說",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你討厭那種的嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_021"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你討厭的並非用繩子",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "互相扶持",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這件事。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那是為什麼……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "沒有必要一起死",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是嗎。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來如此，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你希望",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "至少讓對方得救",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是嗎。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然這麼說，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但雙方用繩子繫住彼此，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "掉下去的機會",
        "unit_id": 127612
