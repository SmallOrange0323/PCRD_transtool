    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與流夏釣上大獵物後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人以大字形的姿勢躺在甲板上。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_050"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "辛苦了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "哈哈，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然很想",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "豎起大漁旗，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n但是身體",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大概暫時動不了了……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "喂，",
        "unit_id": 911,
        "voice": "vo_adv_1276002_051"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "應該就是那個了吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "喂～！",
        "unit_id": 811,
        "voice": "vo_adv_1276002_052"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "小姐～！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "小哥～！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n你們沒事吧～？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你們……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_053"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不是回去了嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "因為",
        "unit_id": 5313,
        "voice": "vo_adv_1276002_054"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我們很在意你們的情況，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n所以就一起來看看了。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "唔喔喔！？",
        "unit_id": 911,
        "voice": "vo_adv_1276002_055"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n這什麼鬼啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "好強啊～！",
        "unit_id": 811,
        "voice": "vo_adv_1276002_056"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n根本是大豐收耶！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "託你們的福。",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_057"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "雖然這麼說，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是我",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "暫時受夠流沙釣了……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "至少讓我們來幫忙",
        "unit_id": 911,
        "voice": "vo_adv_1276002_058"
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "把東西搬到市場去吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "話又說回來，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "漁夫1",
        "words": "真不愧是小姐耶……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這不是我一個人的功勞，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_059"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是因為",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有我們兩人的力量。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "嘿嘿，",
        "unit_id": 811,
        "voice": "vo_adv_1276002_060"
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "小哥你很行嘛。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n對你刮目相看了。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "\n好，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "漁夫2",
        "words": "剩下的就交給我們，你們好好休息吧！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_061"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就恭敬不如從命。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "先稍微休息一會。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "辛苦了。",
        "unit_id": 5313,
        "voice": "vo_adv_1276002_062"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "釣得開心嗎？",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_063"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還算滿開心的。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這不重要……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我說你，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在我們出船釣魚前，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你是不是也使用了力量？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "啊哈哈，",
        "unit_id": 5313,
        "voice": "vo_adv_1276002_064"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "果然",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "被發現了啊。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還說什麼「果然」啊！",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_065"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n真是的，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你這是什麼意思？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "不過",
        "unit_id": 5313,
        "voice": "vo_adv_1276002_066"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "就我所見，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "效果似乎非常好啊。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這麼說是沒錯……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_067"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是拜託你",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別隨便玩弄",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "人心。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "這樣啊……",
        "unit_id": 5313,
        "voice": "vo_adv_1276002_068"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n抱歉，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "原來我傷害到",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "釣客的自尊了啊。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "自尊？",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_069"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你在說什麼？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我在說的",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是那傢伙的事情。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n是因為我說過",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "希望他能可靠點……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "我使用力量",
        "unit_id": 5313,
        "voice": "vo_adv_1276002_070"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "是針對「希望能釣到很多獵物」",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "這句話喔。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n這是妳自己說過的話，妳不記得了嗎？",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我嗎……？",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_071"
    },
    {
        "type": "background",
        "background": "501530"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好，",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_072"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "出發！",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n希望能釣到很多獵物！",
        "unit_id": 127612
    },
    {
        "type": "background",
        "background": "501530"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "確實",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_073"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "有說過呢……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "咦？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真的只有這樣嗎？",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n其他什麼都……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "是的。",
        "unit_id": 5313,
        "voice": "vo_adv_1276002_074"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n我是有使用力量讓魔物大量出現，",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "\n但並沒有做其他任何事……",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣啊……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_075"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原本的他，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就已經",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是那麼可靠了啊。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "然而，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我卻擅自認為",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那是神燈精靈的力量……",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呵呵……",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_076"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這個嘛。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我只是想說",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我的修行",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還遠遠不夠呢。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "不過妳看起來",
        "unit_id": 5313,
        "voice": "vo_adv_1276002_077"
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "倒是很高興的樣子呢。",
        "unit_id": 5313
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你要記住啊？",
        "unit_id": 127612,
        "voice": "vo_adv_1276002_078"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "特地把這種話說出來，",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可就太不解風情了。",
        "unit_id": 127612
    },
    {
        "type": "dialogue",
        "name": "神燈精靈",
        "words": "咦～？",
        "unit_id": 5313,
        "voice": "vo_adv_1276002_079"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在爽朗笑容的圍繞下，載著一行人的沙上船"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n朝著市場前進。"
    }
]