[
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "哼，",
        "unit_id": 14011,
        "voice": "vo_adv_5050321_000"
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "像妳們這等傢伙",
        "unit_id": 14011
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "可沒有資格當我的對手啊。",
        "unit_id": 14011
    },
    {
        "type": "dialogue",
        "name": "鬼魂教父",
        "words": "\n妳們的對手是它們。",
        "unit_id": 14011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔，",
        "unit_id": 114111,
        "voice": "vo_adv_5050321_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "出現那麼多敵人還真麻煩。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果被敵人數量牽制就危險了，",
        "unit_id": 114011,
        "voice": "vo_adv_5050321_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n一起合作打倒它們吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "馬修",
        "words": "我們也會幫忙的！",
        "unit_id": 5712,
        "voice": "vo_adv_5050321_003"
    },
    {
        "type": "dialogue",
        "name": "休茲",
        "words": "現在的我們",
        "unit_id": 5912,
        "voice": "vo_adv_5050321_004"
    },
    {
        "type": "dialogue",
        "name": "休茲",
        "words": "可不會輸給這種傢伙！",
        "unit_id": 5912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果是現在的我們，",
        "unit_id": 113911,
        "voice": "vo_adv_5050321_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一定能夠展現默契十足的聯手攻擊！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "立刻將它們收拾乾淨吧！！",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "鬼怪們",
        "words": "喔──！！",
