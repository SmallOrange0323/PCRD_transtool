    {
        "type": "dialogue",
        "name": "栞",
        "words": "莉瑪",
        "unit_id": 103811,
        "voice": "vo_adv_6040405_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "力氣很大，很可靠呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一直都只有我單方面受到她的幫助，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然想報答她，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但要換我來揹莉瑪果然很困難呢……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果送她可愛的飾品之類的，",
        "unit_id": 103811,
        "voice": "vo_adv_6040405_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "她似乎會很高興呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "送蘋果形狀的墜飾怎麼樣？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n下次我想自己做來",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "送給她。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦？",
        "unit_id": 103811,
        "voice": "vo_adv_6040405_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "　要、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要我騎在莉瑪身上戰鬥嗎？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然好像真的可以好好戰鬥的樣子……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還有沒有其他的想法呢？　",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有可能讓莉瑪開心的想法。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就算鍛鍊身體，",
        "unit_id": 103811,
        "voice": "vo_adv_6040405_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要揹起莉瑪應該還是很困難……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不、",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不對！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "　凡事都要挑戰呢！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "　我想要在身體狀況不錯時\n好好訓練看看！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "　",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "　你是在開玩笑的嗎？",
        "unit_id": 103811
    }
]