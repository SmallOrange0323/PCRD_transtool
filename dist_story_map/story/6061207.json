    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "總算是結束了～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話說回來，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家的邀約您都不曾拒絕，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n讓王子先生",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "吃了不少苦頭……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是抱歉。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是啊。",
        "unit_id": 116011,
        "voice": "vo_adv_6061207_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然有辛苦的地方，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不過也有",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "很多很多",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "快樂的事呢～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家不會再愧疚煩惱了。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "謝謝您，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生……",
        "unit_id": 116011,
        "voice": "vo_adv_6061207_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您既然這麼說，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "表示下次還可以再邀約您囉？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果是這樣，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那咱們就是命運共同體，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "無論到哪裡去，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都要陪著人家喔，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還請多多指教。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您又說了會讓人開心的話。",
        "unit_id": 116011,
        "voice": "vo_adv_6061207_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也是覺得",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只要有王子先生在身邊，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家就能比平時",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "更加賣力。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今後",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "也請繼續跟人家一起做些",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "開心的事喔～",
        "unit_id": 116011
    }
]