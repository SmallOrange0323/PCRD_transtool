[
    {
        "type": "background",
        "background": "501161"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好吧，雖然歷經一番折騰，",
        "unit_id": 112011,
        "voice": "vo_adv_6056304_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過能像這樣迎接新年真是太好了。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "關於接下來的一年，我是抱著一半不安",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟一半期待……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼您有什麼新年目標嗎？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……唉，",
        "unit_id": 112011,
        "voice": "vo_adv_6056304_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還真像是你會說的話耶。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好吧，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然你都這麼強調了……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接下來這一年，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大家也一起無憂無慮地過吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天的你",
        "unit_id": 112011,
        "voice": "vo_adv_6056304_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼特別地懂事啊！？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過也對，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為了確保今後也能吃到美味的食物，的確是有必要節約開銷。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "希望貪吃佩可別提出什麼，吃魔物節省伙食費之類的主意……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 112011,
        "voice": "vo_adv_6056304_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我啊……？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我的話嘛……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "希望今年，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也能繼續跟你們一起……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算、",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，還是當我沒說吧！！",
        "unit_id": 112011
    }
]