[
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以志那都留下的線索為根據，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n怜與{player}登上陡峭的山路。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖說應該已經爬了很遠，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但目的地還在前方啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從山頂刮下來的風……",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n看來志那都所說的情報是正確的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我……",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能夠變得像她一樣強嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要耗費多少時間，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "才能得到那麼強的力量……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在志那都回到原本的世界之前，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n來得及向她詳細打聽真是太好了。",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "501370"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是在志那都返回自己的世界前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與怜和{player}三人一起釣魚時的事……"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……怜，",
        "unit_id": 135613,
        "voice": "vo_adv_1288003_004"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n我有件事",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "想告訴妳。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是關於星素之力的事。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……若根據我確認過的記錄，",
        "unit_id": 135613,
        "voice": "vo_adv_1288003_005"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n「我的世界的怜」",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "曾有獨自覺醒風屬性的經歷。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "雖然詳細條件不明……",
        "unit_id": 135613,
        "voice": "vo_adv_1288003_006"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n但不論在哪個輪迴中，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她克服的考驗都是相同的。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n在基礎世界，或許也能引發類似的現象。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "考驗所需的東西有兩個，",
        "unit_id": 135613,
        "voice": "vo_adv_1288003_007"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就是妳祖父遺留的劍……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "以及將作為考驗場所的山。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n只要去爬我將告訴妳的那座山就好。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "要是克服考驗，",
        "unit_id": 135613,
        "voice": "vo_adv_1288003_008"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "妳就能更進一步發揮屬性之力了吧。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "但是，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "在沒能克服考驗的輪迴中……",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n不論哪次，妳都捨棄了劍，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "並再也不曾拿起。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……我能說的話",
        "unit_id": 135613,
        "voice": "vo_adv_1288003_009"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "就到此為止。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n之後妳就用自己的眼睛看，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "並親身去理解吧。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……如果是妳，一定能夠克服。",
        "unit_id": 135613
    },
    {
        "type": "background",
        "background": "500200"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……志那都說，",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不同世界的我，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n透過祖父遺留下來的劍覺醒了力量。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我過去一直以為這是一把平凡無奇的劍……",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但現在我能明白，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這把劍",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "寄宿著風屬性之力。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……在體力消耗過度之前登頂吧。",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我稍微加快一下步調喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "到達目的地了呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "接下來才要正式開始。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……果然如此。",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你看，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我帶來的",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這把劍……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯。",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "跟剛才我拿出來向你展示時相比，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n風屬性之力越來越強了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "跟劍一起遺留下來的祖父的札記中，",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n有關於考驗的傳說記述。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "札記寫道，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "強風的呼喚者，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "將會與",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "暴風之龍相見……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……來到這裡後我就明白了。",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這把劍",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "似乎是挑戰考驗的關鍵。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是為了匯集風之力，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "並呼喚暴風之龍用的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "麻煩你，",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "強化我吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "調整好呼吸……",
        "unit_id": 128811,
        "voice": "vo_adv_1288003_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "掌握風旋轉的流動……",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "於空中起舞的風啊……",
        "unit_id": 128811,
        "voice": "vo_adv_1288003_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n聚集到我的劍上，",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "化為狂暴的暴風雨吧……！",
        "unit_id": 128811
    },
    {
        "type": "background",
        "background": "500203"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……看來第一階段多半是成功了。",
        "unit_id": 128811,
        "voice": "vo_adv_1288003_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "屬性之力的匯集與釋放……",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "與志那都的修行幫上忙了呢。",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "暴風之龍",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好像要出現了！",
        "unit_id": 128811,
        "voice": "vo_adv_1288003_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "做好戰鬥的準備……",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "暴風之龍",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是那隻魔物",
        "unit_id": 128811,
        "voice": "vo_adv_1288003_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "引起這陣暴風的嗎……！",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種程度……",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔！？",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不只是暴風！？",
        "unit_id": 128811,
        "voice": "vo_adv_1288003_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這陣混雜了魔力的風……",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不行……！",
        "unit_id": 128811,
        "voice": "vo_adv_1288003_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你的",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "聲音……",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "漸漸聽不清楚……",
        "unit_id": 128811
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊！",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡是……！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "變身恢復了……？",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且我們……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你！",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不是在溪谷跟龍戰鬥……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "惡夢……？",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才是在做夢嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔……",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……抱歉，",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的記憶",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "似乎有點混亂。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你。",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……我正好",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想要整理思緒的時間。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我在這個地方",
        "unit_id": 100311,
        "voice": "vo_adv_1288003_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "詢問他之後所得知的是，",
        "unit_id": 100311
    },
    {
