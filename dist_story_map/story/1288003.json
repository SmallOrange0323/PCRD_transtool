    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n把我的全力，",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和你的全力",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
