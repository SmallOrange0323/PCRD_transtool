        "voice": "vo_adv_1288003_072"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這還真是相當",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "猛烈啊……！",
        "unit_id": 128811
    },
