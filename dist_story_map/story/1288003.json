    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "與跟志那都修行時徹底相反……",
        "unit_id": 128811,
        "voice": "vo_adv_1288003_071"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不是控制住風之力，",
        "unit_id": 128811
