        "name": "怜",
        "words": "\n",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你的極限不只有這種程度吧……？",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我一定會牢牢接住的……！",
        "unit_id": 128811,
        "voice": "vo_adv_1288003_073"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以……",
