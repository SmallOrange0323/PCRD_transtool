    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]",
        "unit_id": 2415,
        "voice": "vo_adv_6124402_000"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]噗哈～！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]外面世界的空氣好新鮮啊！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]嗯？",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]怎樣？小伙子。",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]看你一臉茫然的樣子。",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]有什麼不滿嗎？",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]啊啊！？",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]",
        "unit_id": 2415,
        "voice": "vo_adv_6124402_001"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]哼哼！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]這不是你的腦袋能理解的對吧！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]稱呼我為「從地獄歸來的超級搖滾老爸大人」",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]也可以喔～？",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]怎樣啦，",
        "unit_id": 2415,
        "voice": "vo_adv_6124402_002"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]一臉感傷的樣子。",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]你這傢伙擺這種臉給我看，我只覺得噁心！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]趕快收起你那掃興的表情！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]聽懂了沒！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]平常的我",
        "unit_id": 2415,
        "voice": "vo_adv_6124402_003"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]是將靈魂固定在骷髏頭上的，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]實際上就像是活著一樣喔！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]所以也能跟美女互相碰觸，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]也能談戀愛，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]也能結婚喔～♪",
        "unit_id": 2415
    }
]