        "voice": "vo_adv_9079155_018"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "咕……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "嘎喔……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "──我果然還是",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
