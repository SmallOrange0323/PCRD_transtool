    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好可怕啊……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚嗚～",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "已、",
        "unit_id": 135614,
        "voice": "vo_adv_9079155_005"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "已經",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "沒事了……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "呃……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那個，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "妳是……？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我叫胡桃。",
        "unit_id": 102111,
        "voice": "vo_adv_9079155_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我迷路了，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "結果",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "遇到了這群殭屍……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "只好裝成殭屍，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總算撐到現在……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "原來還有這種",
        "unit_id": 135614,
        "voice": "vo_adv_9079155_007"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "可能嗎……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n好厲害的演技啊……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不，",
        "unit_id": 102111,
        "voice": "vo_adv_9079155_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒有啦……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為是生死關頭……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n如果是同樣的情況，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我想姐姐也能",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "裝成殭屍或其他人的。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不，",
        "unit_id": 135614,
        "voice": "vo_adv_9079155_009"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這對我來說太……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不過",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "「變成其他人」",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "嗎……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……說起來，",
        "unit_id": 135614,
        "voice": "vo_adv_9079155_010"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "性格和我那個世界的胡桃差很多啊。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n她正處於叛逆期，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "非常任性……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "她的雙親束手無策，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n甚至曾經還來我的道場",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "跟我諮詢如何管教她。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不過，",
        "unit_id": 135614,
        "voice": "vo_adv_9079155_011"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這個世界的胡桃看起來",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是個謙虛又乖巧的孩子……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "想必她的雙親是和胡桃一起",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "過著安穩的日子吧。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……得把她安全送回",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "鎮上才行。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚，",
        "unit_id": 102111,
        "voice": "vo_adv_9079155_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是魔物……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對了。",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "只要再次利用演技",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "矇混過去就好……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 102111,
        "voice": "vo_adv_9079155_013"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "好厲害，",
        "unit_id": 135614,
        "voice": "vo_adv_9079155_014"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "好逼真的演技……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "該不會",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "真的想靠這樣矇混過去吧……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "姐姐一定也可以的。",
        "unit_id": 102111,
        "voice": "vo_adv_9079155_015"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我、",
        "unit_id": 135614,
        "voice": "vo_adv_9079155_016"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我也要嗎！？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "可是……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "胡桃說過，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "「只要拚命去演，就能變成另一個人」。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n只要能領悟出那個感覺，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "或許能幫我克服不擅長交談的問題……？　",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這或許會成為",
        "unit_id": 135614,
        "voice": "vo_adv_9079155_017"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我改變的第一步。",
        "unit_id": 135614
