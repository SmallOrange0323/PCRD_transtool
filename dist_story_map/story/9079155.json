        "name": "志那都",
        "words": "啊，",
        "unit_id": 135614,
        "voice": "vo_adv_9079155_003"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "危險，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "差點就砍到妳了……",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那個，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "沒受傷吧……？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒、",
        "unit_id": 102111,
        "voice": "vo_adv_9079155_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒有。",
