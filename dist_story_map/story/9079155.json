        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "謝謝妳，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "胡桃……！　",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "咕、",
