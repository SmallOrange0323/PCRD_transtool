[
    {
        "type": "background",
        "background": "501950"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "賺錢真開心喵♪",
        "unit_id": 125111,
        "voice": "vo_adv_6114205_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我想下更多更多功夫賺更多錢喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要提高業績……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你覺得該找誰商量比較好喵？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "超完美的人選喵！",
        "unit_id": 125111,
        "voice": "vo_adv_6114205_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "去拜託美冬，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n應該就能飛躍性地提升咖啡廳的工作效率喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然感覺工作量會跟著增加，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "希望你也一起努力喵♪",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對了喵，",
        "unit_id": 125111,
        "voice": "vo_adv_6114205_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "生意方面的事情，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n去拜託秋乃果然才是最好的選擇喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就去借艘",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "飛空艇，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n幫忙發店頭傳單怎樣喵？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "肯定會大賣的喵♪",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這麼說來，",
        "unit_id": 125111,
        "voice": "vo_adv_6114205_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "她最近熱衷於咖啡喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "搞不好是不錯的人選……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還是算了喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n假如聽了優花梨的意見，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "感覺不久之後會變酒館喵。",
        "unit_id": 125111
    }
]