    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}！\n這邊，這邊♪",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這間店",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有蛋糕吃到飽喔～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，吃到飽是多麼悅耳的詞啊……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是吃得太多，會被拒絕往來，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以我決定一點一點地吃～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也是懂得拿捏分寸的喔？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n選了哪種蛋糕呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔，不愧是美食家！",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "待會可以讓我每個都試吃一小口嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔耶，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}真是好人☆　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以喜歡上你嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個也『可以喔』嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再帶點羞澀會更可愛喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸～？",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會把{player}的份留下喔，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是個可以忍耐的孩子……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只是試吃，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一口就好！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就一點點啦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "給我吃嘛～好不好♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總而言之！",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們的公會【美食殿堂】",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "終於要開始活動了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣一來公會限定的店也能進去了～",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我的夢想又擴張了♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "申請創辦公會時，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n得到{player}不少幫助呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在政府機關時，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也闖了禍～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的給你添麻煩了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}也",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n註冊成為公會的一員了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果你想參加公會限定的活動～",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就盡情地用我們公會的名義吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "公會在蘭德索爾人們的生活中早已根深蒂固，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不加入公會的話，會有許多不便之處。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比如說只能使用部分的公共設施。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，營運公會用的資金",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我會準備好的所以你大可放心。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看來我不多找幾份打工不行呢～",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "武者修行之旅",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n看來也要延後了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總而言之。",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n蘭德索爾人口眾多，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也是有公會在進行大規模的活動……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像是同好會的公會",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也是蠻多的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們【美食殿堂】也是屬於後者，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以幾乎沒有強制性。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果覺得厭倦了，要解散還是退出都取決於你，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總之輕鬆參與就好了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們公會的主旨",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n暫定是『邊走邊吃』。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n主要是一起吃晚餐喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這樣一如往常地展開我們的活動。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今晚還要跟小可蘿和小凱留",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n更仔細地說明喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我得到{player}",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n特別多幫助呢……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "作為謝禮，我請你吃蛋糕♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次的聚會，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就是為了這個目的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嘻嘻，跟你商量創辦公會的事項……",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算不是在吃晚餐的時候，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也很開心能經常跟{player}見面喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "公會也順利創辦了，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然事情告一段落讓我感到寂寞。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是啊，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我大致上都很閒！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "找個時間再一起約會吧，{player}♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n當成約會的……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就像我每次巡迴我想吃的店一樣。",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}如果有想做的事，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要跟我說喔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論多少件，我都會陪你做喔。",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不管怎麼說，\n我們都成為了同一個公會的夥伴。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們就如同家人一樣，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可以這樣想嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能和他人建立起羈絆，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是件難能可貴的事呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "擁有能回去的家。",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有家人們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n和睦地圍著餐桌等你回去吃飯。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}。\n我啊……",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "算了，現在還是不要跟你說這件事。",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我已經在給你添麻煩了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以不能再把你捲入我這邊的紛爭之中。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "能兩人一起享用香甜可口的蛋糕，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就已經是我最大的幸福了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "若是再要求更多，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那未免太過貪心了呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我的事姑且不提……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "倒是{player}的記憶恢復了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起剛遇見你的時候，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_041"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我覺得你現在已經可以養活自己了～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哼哼。",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "重要的地方還是想不起來嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_043"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然著急也沒用……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但你還是會感到焦慮吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然被他人忘記是件悲傷的事，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但忘記他人也是很痛苦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是真有一個像這樣",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n操弄他人記憶和內心的兇手存在的話。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那絕對是無法饒恕的壞人。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個壞人",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "究竟為何要做這樣的事呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "開～玩笑的。",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "任意評判他人的善惡，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不是件好事情。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們來吃甜食，\n轉換一下心情吧。",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你看笑容都會變得柔和了喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼♪",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_049"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好甜喔，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺活過來了呢……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_050"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要是記憶恢復的話。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像現在我們一起吃的蛋糕的味道也會… …",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和我一起\n相處的點點滴滴。",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說不定全部都會消失。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到了那時，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們會重新再相遇… …",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再來創造",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n滿滿的幸福回憶就好了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們會再次相見，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後再一起吃蛋糕吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無論多少次，我們都會重拾重要的羈絆，",
        "unit_id": 105812,
        "voice": "vo_adv_1058007_055"
    },
    {
        "type": "dialogue",
