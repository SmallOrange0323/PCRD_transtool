[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "茜里非常介意{player}說過的「很不像平時的茜里」。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了找回初衷，也為了變得更加可愛，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n茜里為此再次展開特訓，和{player}約定好要碰面。"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……很不像茜里、",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這話到底是什麼意思呢……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……茜里想成為世界上最可愛的人。",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "既然這樣，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "「茜里的風格」",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就是可愛了吧……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥說很不像平時的茜里，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就表示茜里變得不可愛了，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是嗎……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好不容易以為自己",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n離變成世界最可愛的夢想更近一步了……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "該怎麼辦才好呢……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n謝謝你答應過來。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我們",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "快點開始特訓……啊！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對、",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對不起。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里沒站穩……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可能是因為",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "最近想了很多事情，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n所以沒怎麼睡好……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "說的……",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也是。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n對不起，明明是茜里拜託哥哥的。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但是今天就先休息吧。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……其實",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里很想要兩個人一起特訓，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但現在的茜里完全不了解自己，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n做了特訓",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "也只會給哥哥添麻煩而已。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……特訓",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n做特訓時的茜里，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就有「像茜里」了嗎？　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "已經完全不知道該怎麼辦才好了……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "說到底，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "為什麼茜里不惜做特訓，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n也要成為世界上最可愛的人呢……？　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果是了解「茜里的風格」的哥哥，",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n是不是就明白什麼了呢？　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那個，",
        "unit_id": 100611,
        "voice": "vo_adv_1006011_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有件事想問……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "奇怪？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你是不是在發光呀……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這不是……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我的錯覺……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇……！",
        "unit_id": 100611
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥～！",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "在這邊喔～♪",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "謝謝哥哥來聽茜里的演奏。",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n多虧了哥哥的支持，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里今天才能",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "贏得個人組的優秀獎～♪",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿。",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不過，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里認為這一切",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n要歸功於哥哥陪同下的許多練習♪",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……所以",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里想好好向哥哥道謝♪",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不過，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "在大庭廣眾下有些害臊……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "希望你可以到平時的那座公園來……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那裡人潮稀少，",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "腹地寬廣，不用在意路人的目光，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥就可以",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "盡情聆聽茜里的薩克斯風演奏了♪",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "太好了……",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那我們",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "立刻出發吧♪",
        "unit_id": 100631
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿。",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這裡果然讓人很放鬆呢。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里在這裡和哥哥一起",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "做了好幾次這種事和那種事，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里才能把薩克斯風吹得越來越熟練呢。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里覺得",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "在這裡",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n最能向哥哥表達出自己的謝意，所以……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……所以，",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我要開始演奏囉♪",
        "unit_id": 100631
    },
    {
        "type": "still",
        "still": "100601101"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯……",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呼……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "口頭表達謝意並不困難，",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但茜里強烈的情感",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是無法用言語完整表達出來的……",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "乘著和哥哥一起特訓出來的",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "薩克斯風音色，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n表達出",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里滿滿的感謝之意……！　",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請你仔細聽了，",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_025"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥……！",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "會很努力的……！　",
        "unit_id": 100631
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呼……！",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "你覺得怎麼樣？",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿，",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "被哥哥誇獎了♪",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "其實",
        "unit_id": 100631,
        "voice": "vo_adv_1006011_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里比發表會的時候還要緊張呢。",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但是，看見哥哥很喜歡的樣子，",
        "unit_id": 100631
    },
    {
        "type": "dialogue",
