[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夏天的某一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n從異世界來的來訪者降臨在"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n離蘭德索爾的城鎮不遠的地方。"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這裡充滿了「未知」。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_000"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "挺令人雀躍的呢。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_001"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n雀躍到已經迎來死亡的我都能切身體會。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "因為我什麼都沒說就跑出來了，",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_002"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "愛梅斯是不是正在生氣呢？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "想把我放在能看管的地方，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是理所當然的啊。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但是──",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_003"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這是難得的「異世界」。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n要我別去品嚐掛在面前的未知果實，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我實在辦不到。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我說，",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_004"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你不這麼覺得嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "似乎難以用言語來溝通呢。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_005"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n魔獸……",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不對，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "在這個世界",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是稱為魔物吧。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "牠看起來很興奮。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_006"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "會是把我當成食物了嗎。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然有這麼年幼的少女在面前，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "會那樣想也是沒辦法的──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1612
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "啊，",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_007"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "既然並未馬上襲擊我，可猜想是在等待夥伴吧。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這個情況，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "可以說是野獸的本能嗎。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "儘管將我當成了食物，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "卻也不忘要提防我呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "好啦，",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_008"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "該怎麼做才好呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖說降臨到身上的危險，應當自己處理掉才是……",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然我早有預期，",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_009"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但我的力量果然被限制了啊。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n這似乎是個比我想像得還要攸關生死的狀況──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──但是善行果然就要從日常開始累積呢。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_010"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "做得漂亮。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_011"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "託你的福得救了喔。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_012"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "要是你沒路過的話，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n脆弱的我",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "想必就要變成可憐的悲劇主角了吧。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你為什麼要疑惑地歪頭呢？",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_013"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "啊──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你是覺得沒看過我嗎。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那樣讓我很寂寞啊。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_014"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我明明那麼盡力",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "照顧你了呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "重新自我介紹一次吧。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_015"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我的名字是艾姬多娜。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n也被稱為「強欲的魔女」喔──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不過是在我之前待的那個世界就是了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你會覺得不可思議也是沒辦法的事。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_016"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n對你而言，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我才是從異世界──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不對，",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_017"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這個世界已經有他們幾個先例了嗎。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那麼讓你覺得不可思議的是「魔女」吧。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n畢竟也不是很常出現的存在呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你似乎不怎麼忌諱那個單字呢。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_018"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看樣子魔女",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "在這邊的待遇不太一樣。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "至少，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不太像是連說出口都會讓人顧忌的存在。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……那是什麼？",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_019"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "哦……",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "嗯……",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "變身之後守護和平。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n很受小孩子歡迎。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "有時候會背負過於嚴苛的命運。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然難以理解……",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_020"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但是我",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "希望務必能看一次呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "好啦──",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_021"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你從險境中拯救了我。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然要說是謝禮也有點牽強，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n但如果你有想知道的事，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我可以回答一次",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你的任何問題。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "別看我這個樣子，",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_022"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我知道很多事情喔。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "關於你會想要的東西，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我也大概都理解了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不用客氣。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_023"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "順從你的慾望──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──等一下。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_024"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你真的想知道那個嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "只要你渴望，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我甚至都做好公布世界的祕密的準備了呢？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你該不會是因為想不到問題，",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_025"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "所以隨便問我吧？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──你很有趣呢。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_026"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我能理解愛梅斯執著你的理由了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我也",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "對你產生興趣了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "先把要給你的謝禮往後延，",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_027"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你覺得這樣如何？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我對你有個提案。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "啊，",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_028"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "請不要戒備我。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n我完全不可疑，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不如說對你而言我是站在你那邊……",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "咦？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "可以嗎？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你不要求任何代價？",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_029"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是不是缺乏",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "警覺心跟慾望之類的東西啊？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "乾脆地同意魔女的提議──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "讓我更中意你了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那麼──",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_030"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "希望你讓我",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "暫時與你同行。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "沒什麼啦，",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_031"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你不用想得太複雜。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我也可以幫忙",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你接下來要做的事情。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我對你這個人類有興趣。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_032"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我想透過觀察你，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n與你共同行動，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "來更理解你這個人。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是強欲啊。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "當然沒問題。",
        "unit_id": 132012,
        "voice": "vo_adv_1320001_033"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n魔女是說話算話的喔。",
        "unit_id": 132012
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──嗯。",
        "unit_id": 132011,
        "voice": "vo_adv_1320001_034"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "大海",
        "unit_id": 132011,
        "voice": "vo_adv_1320001_035"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "嗎。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然我就這樣在你的帶領下來到了這裡，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n但是感覺陽光似乎太過強烈了呢……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這片海有盡頭嗎？",
        "unit_id": 132011,
        "voice": "vo_adv_1320001_036"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n它的盡頭與哪裡相連呢？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "有沒有",
        "unit_id": 132011,
        "voice": "vo_adv_1320001_037"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "能渡過這片海的交通工具呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "而且，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "海中應該有各種生物存在。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我也想要可以窺視海裡的道具……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──抱歉。",
        "unit_id": 132011,
        "voice": "vo_adv_1320001_038"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "但是這是我的本性啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那麼，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你可以告訴我",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你到這個地方來的目的嗎？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我可以問那個單字的意思嗎？",
        "unit_id": 132011,
        "voice": "vo_adv_1320001_039"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……原來如此，",
        "unit_id": 132011,
        "voice": "vo_adv_1320001_040"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "是工作的意思嗎。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n你要在這裡做什麼呢？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "撿垃圾？",
        "unit_id": 132011,
        "voice": "vo_adv_1320001_041"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n在這個沙灘？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "你說沙灘，",
        "unit_id": 132011,
        "voice": "vo_adv_1320001_042"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "這裡放眼望去都是沙灘耶……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "一整片嗎？",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "──原來如此。",
        "unit_id": 132011,
        "voice": "vo_adv_1320001_043"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "只不過，",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "不巧的是我並不擅長肉體勞動啊。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "雖然很遺憾，我沒辦法幫上……",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "……我說不定，",
        "unit_id": 132011,
        "voice": "vo_adv_1320001_044"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n犯下很大的錯誤了呢。",
        "unit_id": 132011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了觀察{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n艾姬多娜開始打起工來。"
    }
]