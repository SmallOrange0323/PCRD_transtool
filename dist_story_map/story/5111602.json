    {
        "type": "dialogue",
        "name": "旁白",
        "words": "準備執行任務的諾維姆和尾狗刀，在出發前去找了跳躍王。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "教授，",
        "unit_id": 106114,
        "voice": "vo_adv_5111602_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "借我一下",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那個！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n你的跳躍之力！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "拜託了──",
        "unit_id": 106211,
        "voice": "vo_adv_5111602_001"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "唉……",
        "unit_id": 107311,
        "voice": "vo_adv_5111602_002"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "好吧，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "既然是為了任務，那也沒辦法……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "唉～",
        "unit_id": 106114,
        "voice": "vo_adv_5111602_003"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "阿斯特朗沒有這個，很不方便呢～",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "會覺得阿斯特朗不方便的，",
        "unit_id": 106211,
        "voice": "vo_adv_5111602_004"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我想只有諾維姆而已，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "我答應借給你們。",
        "unit_id": 107311,
        "voice": "vo_adv_5111602_005"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n但是，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "不許你們拿來亂用。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "嗯！",
        "unit_id": 106114,
        "voice": "vo_adv_5111602_006"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我知道！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n再見！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "……嗯。",
        "unit_id": 107311,
        "voice": "vo_adv_5111602_007"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "我警告過了喔。",
        "unit_id": 107311
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯～",
        "unit_id": 106211,
        "voice": "vo_adv_5111602_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這真的很方便呢～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我沒辦法使用就是了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "嘿嘿～！",
        "unit_id": 106114,
        "voice": "vo_adv_5111602_009"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "有我在很不錯吧！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "……哦，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "發現目標，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "搭檔，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我們上！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "OK，",
        "unit_id": 106211,
        "voice": "vo_adv_5111602_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "準備上工～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "──好！",
        "unit_id": 106114,
        "voice": "vo_adv_5111602_011"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這次也很輕鬆呢！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "嗯，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "話說回來……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "應該差不多了吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "的確。",
        "unit_id": 106211,
        "voice": "vo_adv_5111602_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那就麻煩妳了，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "好！",
        "unit_id": 106114,
        "voice": "vo_adv_5111602_013"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "包在我身上！",
        "unit_id": 106114
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯，",
        "unit_id": 106211,
        "voice": "vo_adv_5111602_014"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "時間剛好。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n也還沒開始排隊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "嘿嘿，",
        "unit_id": 106114,
        "voice": "vo_adv_5111602_015"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "剛出爐的菠蘿麵包很受歡迎，居然這麼簡單就買到了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n真是太棒了！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n好～",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那來找個景色優美的地方再開動吧！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哦，",
        "unit_id": 106211,
        "voice": "vo_adv_5111602_016"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好主意。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那就麻煩妳了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "要跳囉！",
        "unit_id": 106114,
        "voice": "vo_adv_5111602_017"
    },
    {
        "type": "background",
        "background": "500540"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我說諾維姆，",
        "unit_id": 106211,
        "voice": "vo_adv_5111602_018"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這地方景色確實不錯……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n但妳不覺得太冷了嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "為",
        "unit_id": 106114,
        "voice": "vo_adv_5111602_019"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "什麼啊──！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我怎麼可能會想來這種地方……",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "嗯？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "有紙條……？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "「這是你們亂用的懲罰，",
        "unit_id": 106211,
        "voice": "vo_adv_5111602_020"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "在那裡好好反省一下。」",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "唉呀～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "被發現我們拿跳躍之力來買東西了……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "教、",
        "unit_id": 106114,
        "voice": "vo_adv_5111602_021"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "教授───！！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "諾維姆的吶喊，傳遍了寒冷的雪山……"
    }
