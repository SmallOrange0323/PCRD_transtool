[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "有一天……\n{player}\n在『王宮』正門前看見了正在嘆氣的純。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和她蠻親近的{player}感到擔心，\n出聲叫了她。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唉，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼會變成這樣……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我到底做了什麼呢……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n啊啊，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你好呀。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "告訴你好幾次別接近『王宮』了不是嗎。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這裡住了很多身分高貴的人，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總是戒備森嚴。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "隨便在這附近閒晃的話，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n會被當作是可疑份子，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而被丟進牢房的喲。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然無知不是一種罪，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但很不幸的，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只要有嫌疑就處罰是『王宮』的方針。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為我知道你是好孩子，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不會不由分說地就動粗。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但在必要時刻，我可是不會遲疑的，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為我有守護『王宮』的義務。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唉……",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊沒事，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n明明在跟人說話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "竟然還嘆氣真是沒禮貌。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……你再為我擔心嗎，少年。",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你果真是個",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "溫柔的好孩子呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其實最近……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "任職團長的我和",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n【王宮騎士團（NIGHTMARE）】的同伴們相處的不太好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "光看我的外表就知道，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我是個習武的人，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以從以前開始就",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "難以親近別人。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但最近",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "開始有了可以親近聊天的對象了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像是副團長的克莉絲、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "新人小智、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n見習的茉莉等等……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "工作結束後一起吃飯、",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n休假時則一起出去買東西等等。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我是第一次和別人感情這麼好，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以很開心。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我從小就",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "像這樣身穿著鎧甲，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n基本上別人都會有點怕我……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n其實我不會做什麼壞事，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且也想盡量溫和一點。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總而言之。【王宮騎士團（NIGHTMARE）】的大家，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n對我來說",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "都是難能可貴的夥伴。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n難得能夠放心交流的，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "無法取代的朋友。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是……",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n最近、",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我總覺得好像被大家避開。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然從以前開始，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其他團員就會",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "跟我保持一定距離，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但最近連小智跟茉莉也",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "開始疏遠……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只要我打招呼，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "他們就會被我嚇一大跳，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很快地說完",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "『早安……』",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n之類的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咕噥一陣後就逃走。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那些孩子看著我的眼神，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就像嚇壞了的小動物一般。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "到底為什麼呢……",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也不清楚理由，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還是我到底做了什麼呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n心裡完全沒底，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就算想問個清楚，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也沒有搭話的機會。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "大家",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看到我之後都怕到躲得遠遠的……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不知道是為什麼。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n讓我感到不安又難過，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "變得一直唉聲嘆氣。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年你知道",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "大家疏遠我的原因嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n到底是做錯了什麼呢，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為什麼大家那麼怕我呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝、",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝謝……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n老實說，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你願意跟平常一樣普通地跟我說話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對我來說像是救贖一般。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "果然是這麼一回事呀……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果換成",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "更可愛一點的鎧甲怎麼樣呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是我",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "擔任『王宮』警衛，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n外觀必須要有一定的威嚇感。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且小智他們",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "應該也已經習慣了這身打扮……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總覺得應該",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不是因為盔甲和頭盔而害怕。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……嘻嘻。",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n和少年談過後，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "稍微冷靜了一點。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然還是不清楚大家疏遠我的原因。",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但希望可以好好的問清楚事情原委，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果是因為我做了什麼事，\n就好好道歉，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "修補我跟大家的關係。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為獨自一人真的",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很寂寞呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年……",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可以的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果之後碰巧在哪裡見面，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "想請你聽我說說話。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只是請你傾聽我的煩惱跟抱怨，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就輕鬆了不少。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然可能會造成少年的麻煩，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還是拜託你了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……唔？",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n發生了什麼事，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "『王宮』的內部似乎正在騷動。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "噫噫噫！",
        "unit_id": 711,
        "voice": "vo_adv_5006000_031"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n救、救救我！　",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "不要殺我啊啊啊啊！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗚哇？　怎、怎麼了？",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n發生了什麼事，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "快報告現在的狀況！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "啊、咦……？",
        "unit_id": 711,
        "voice": "vo_adv_5006000_033"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n噫噫噫、",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "不要靠近啊！",
        "unit_id": 711
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "啊啊啊，不要亂來呀！",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n怎麼突然對伙伴刀劍相向？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n到底發生了什麼呀，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你認不出我嘛？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "鎧、鎧甲！　",
        "unit_id": 711,
        "voice": "vo_adv_5006000_035"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "有好多的鎧甲！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n原以為是夥伴，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "結果鎧甲都是怪物……！？",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "鎧甲……？",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n鎧甲怎麼了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "冷靜下來！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "從頭開始說清楚！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "嗚、嗚哇哇哇哇！",
        "unit_id": 711,
        "voice": "vo_adv_5006000_037"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n救救我啊啊啊啊！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……啊啊，",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "逃走了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然不清楚狀況，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但還真丟人呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n身為必須保護『王宮』的騎士，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "竟擅離職守到處逃竄。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……少年。",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然還不清楚詳細情況，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但似乎是發生了異常事件。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n守護『王宮』的和平是我們的責任，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可不能放置不管。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我趕緊去",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看看『王宮』內部的情況。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n說不定會有危險，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年你就快回去吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "今天就先這樣吧，少年。",
        "unit_id": 104711,
        "voice": "vo_adv_5006000_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……謝謝你",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "聽我說話。",
        "unit_id": 104711
    }
]