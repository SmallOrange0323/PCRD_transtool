[
    {
        "type": "background",
        "background": "501250"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "莉瑪等人通過了真琴的防身術課程後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n接下來學習的是教養課程。"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "今天要上的課是插花。",
        "unit_id": 1514,
        "voice": "vo_adv_5061004_000"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "美感對於淑女而言是不可或缺的素質，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n今天要請各位",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "透過花來培養對美的品味。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔唔，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "插花",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還真是困難呢……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "哼哼，",
        "unit_id": 1214,
        "voice": "vo_adv_5061004_002"
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "莉瑪小姐還真沒天分呢。",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "\n這裡只要",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "用這朵花……",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "妳看！",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好、",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好厲害！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "協調的程度和剛才簡直天差地別！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝妳，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這真是太棒了！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "那、",
        "unit_id": 1214,
        "voice": "vo_adv_5061004_004"
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "那是當然。",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "今後我也會讓妳好好見識我有多優秀的，",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "\n妳就盡量努力跟上我吧！",
        "unit_id": 1214
    },
    {
        "type": "background",
        "background": "501240"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "今天",
        "unit_id": 1514,
        "voice": "vo_adv_5061004_005"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "要請各位學習茶敘的禮儀。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n茶會是淑女的社交場合，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n請各位仔細學習，以免在茶會上貽笑大方。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呃，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "茶葉應該差不多悶好了吧……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "杯子也忘記預熱了！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要快點才行，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好燙！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "莉瑪小姐，冷靜點。",
        "unit_id": 419,
        "voice": "vo_adv_5061004_007"
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "請喝一口這杯茶吧",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "。",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好好喝──！",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我還是第一次喝到這麼好喝的紅茶！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n啊，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "聞起來也很香，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "感覺冷靜下來了呢……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "那太好了。",
        "unit_id": 419,
        "voice": "vo_adv_5061004_009"
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "來，",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "不要慌張，重新從頭來一遍吧。",
        "unit_id": 419
    },
    {
        "type": "background",
        "background": "500660"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "各位，",
        "unit_id": 1514,
        "voice": "vo_adv_5061004_010"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "至今為止真是辛苦妳們了。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n通過了許多課程的妳們，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "已經是位傑出的淑女了。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "接下來將進入最終選拔。",
        "unit_id": 1514,
        "voice": "vo_adv_5061004_011"
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "\n選拔的結果會在日後通知各位，",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "瑪莎",
        "words": "今天就先暫時解散。",
        "unit_id": 1514
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗚嗚，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要跟大家分別",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "還真是寂寞呢……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "哎呀哎呀，",
        "unit_id": 1214,
        "voice": "vo_adv_5061004_013"
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "竟然對競爭對手說這種天真話。",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "\n",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "不、",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "不過呢，",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "跟妳一起度過的課程，",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "參加者１",
        "words": "的確是有些開心哦。",
        "unit_id": 1214
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "莉瑪小姐，",
        "unit_id": 419,
        "voice": "vo_adv_5061004_014"
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "多虧了妳我才能努力到今天。",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "\n",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "雖然還不曉得結果會是如何，",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "參加者２",
        "words": "但我們之後再見吧！",
        "unit_id": 419
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我也真的很開心哦。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n之後大家再於此相聚吧！",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好了，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那我們走吧……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個從窗戶窺探外面的身影，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是羅伊德先生。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n原本最後還想跟他打聲招呼的……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為什麼明明大家都順利結束了課程，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n他卻一副如此難受的表情呢……",
        "unit_id": 115812
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哈～",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_019"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這段日子看到的一切都好耀眼，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "而且所有事都很刺激，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n簡直就像是一場夢呢。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果能通過選拔，那我當然會很高興，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n但我的願望已經充分實現，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我已經沒有遺憾了。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也是呢，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "都來到了距離夢想舞臺，只有一步之遙的地方，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "果然",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "會想參加舞會看看呢。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但是在那之前，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_022"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我想先回牧場跟大家聊天，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n好好放鬆一下呢～",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "其、",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "其實",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這兩天，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我的變身無法解除……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我想大概是試製品的副作用吧。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我也不希望做什麼奇怪的事，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_024"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "結果反而導致沒辦法變身，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以我想暫時保持這個樣子。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果是這副模樣，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大家應該不會發現是我，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n所以有點擔心突然回去",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "有沒有問題呢……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……說得也是，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "根本沒什麼好擔心的呢。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "沒錯，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然我認為沒問題……",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但為什麼這份不安，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "卻沒有消失呢？",
        "unit_id": 115812
    },
    {
        "type": "background",
        "background": "500156"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦，",
        "unit_id": 103311,
        "voice": "vo_adv_5061004_028"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "歡迎的啦，老哥！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那邊的小姐是……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唔哇，",
        "unit_id": 102611,
        "voice": "vo_adv_5061004_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "又～帶著新的女孩子，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且好像還是位千金小姐呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是怎樣？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難道你身上會分泌吸引女孩子的液體嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "鈴，",
        "unit_id": 103813,
