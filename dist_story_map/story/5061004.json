        "voice": "vo_adv_5061004_076"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "同時",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我也重新認識到了，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n野獸的模樣或許",
