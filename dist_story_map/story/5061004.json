    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也並沒有那麼糟呢。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "因為我明白了，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_077"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大家",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "並不是以外表，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n而是以一位名為「莉瑪」的女孩子",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "來看待我。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "或許",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_078"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "外表的美麗，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n並不是那麼重要的事呢。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呵呵，",
