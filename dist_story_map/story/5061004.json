    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n重新",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好好審視我自己的。",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在獲得了新的發現後，莉瑪作為一位少女又有了進一步的成長。"
