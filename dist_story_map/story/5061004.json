    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪不在還真是可惜的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "因為那孩子",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一直很嚮往這種閃閃發光的世界呢，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n她一定會很希望妳能教她各種事吧。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……咦？",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_061"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就是說啊～",
        "unit_id": 102611,
        "voice": "vo_adv_5061004_062"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "少了那個毛茸茸的牧場，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n感覺有些寂寞呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "吶，",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_063"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "在這裡的莉瑪，",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "是個怎麼樣的女孩呢？",
        "unit_id": 115812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "莉瑪她",
        "unit_id": 103813,
        "voice": "vo_adv_5061004_064"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是個開朗、溫柔，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且比誰都更有少女心的女孩子哦。",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只不過，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為有些原因，",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以沒什麼機會出現在別人面前……",
        "unit_id": 103813
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但是",
        "unit_id": 103311,
        "voice": "vo_adv_5061004_065"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "莉瑪莉瑪是個非常善良的女孩的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n一開始看到或許會有些驚訝，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但她跟莉瑪小姐絕對能成為好朋友的。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對啊～",
        "unit_id": 102611,
        "voice": "vo_adv_5061004_066"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "莉瑪她",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "對像我這樣的懶惰鬼也很溫柔呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n在工作的時候，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還會順便撿橡子來給我哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為她太溫柔了，",
        "unit_id": 102611,
        "voice": "vo_adv_5061004_067"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "害我一不小心就會依賴她呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我雖然平常沒說出口，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但其實我非常感謝她哦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以",
        "unit_id": 102611,
        "voice": "vo_adv_5061004_068"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我現在正在讀莉瑪可能會喜歡的書，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我想等她回來以後，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "跟她好好聊聊呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n啊～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真希望她趕快回來～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……",
        "unit_id": 115812,
        "voice": "vo_adv_5061004_069"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "吶，莉瑪小姐，",
        "unit_id": 103311,
        "voice": "vo_adv_5061004_070"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要是可以的話請妳再來玩吧。",
