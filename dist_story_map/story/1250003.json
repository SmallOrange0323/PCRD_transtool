    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看來最好還是換個地方！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n從高處比較好吧？",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "既然如此，",
        "unit_id": 124812,
        "voice": "vo_adv_1250003_067"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那裡也許很適合！",
        "unit_id": 124812
    },
    {
        "type": "background",
        "background": "500590"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 124812,
        "voice": "vo_adv_1250003_068"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果是能眺望全鎮的這裡，",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看來應該能把力量傳遞給大家。",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是啊，",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_069"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡再適合不過了！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們馬上動手吧！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喔，",
        "unit_id": 124911,
        "voice": "vo_adv_1250003_070"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "說的、",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也是……",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘉夜，",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_071"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳怎麼了？",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳該不會是",
        "unit_id": 124812,
        "voice": "vo_adv_1250003_072"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "變卦不想放棄",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "了吧？",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是這樣啦。",
        "unit_id": 124911,
        "voice": "vo_adv_1250003_073"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我只是",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "到了最後一刻，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "感到有點寂寞而已。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我一直抱持著龍人族的痛苦記憶，",
        "unit_id": 124911,
        "voice": "vo_adv_1250003_074"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n而且只專注看著身為幫派成員，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "以及",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "打手的「現在」。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 124911,
        "voice": "vo_adv_1250003_075"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "拜那傢伙所賜，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我覺得",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "和祈梨一起前進的未來，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n好像",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也不錯。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……對啊。",
        "unit_id": 124812,
        "voice": "vo_adv_1250003_076"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也多虧用這份力量奮戰到底，",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n而堅定了自己要貫徹身為偶像的任性。",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "慈樂之音的三人成為頂尖偶像的未來，",
        "unit_id": 124812,
        "voice": "vo_adv_1250003_077"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "以及",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所有粉絲的理想未來。",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為了實現這些未來我必須努力下去，",
        "unit_id": 124812,
        "voice": "vo_adv_1250003_078"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是這份力量",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓我下定決心的呢。",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別、",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_079"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別說這種話啦……",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也是",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_080"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為有了這份力量，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n才能毫不迷惘地朝著成為世界第一大壞蛋的未來前進。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這麼一想，",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_081"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "等到我和尾狗刀站上大壞蛋的頂點之時，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n回想起這件事，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我絕對會感到寂寞……",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哈哈，",
        "unit_id": 124911,
        "voice": "vo_adv_1250003_082"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "抱歉，說出這種不像我會說的話。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "趁我們還沒改變心意的時候，快動手吧！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "用我們最後的力量",
        "unit_id": 124812,
        "voice": "vo_adv_1250003_083"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "盛大華麗地裝飾吧！",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好，",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_084"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這下和樂園的戰鬥也結束了！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要上囉！",
        "unit_id": 125012
    },
    {
        "type": "still",
        "still": "125000301"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳們兩位，",
        "unit_id": 124812,
        "voice": "vo_adv_1250003_085"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要把手再伸長一點！",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n做這種動作還感到害羞，會顯得很遜喔！",
        "unit_id": 124812
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我知道啦！",
        "unit_id": 124911,
        "voice": "vo_adv_1250003_086"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我會盡情地華麗釋放！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔！",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_087"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我會氣勢十足地伸長手臂，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抓住未來！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "嗯？",
        "unit_id": 1411,
        "voice": "vo_adv_1250003_088"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這是……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "光芒",
        "unit_id": 311,
        "voice": "vo_adv_1250003_089"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "正在灑落……？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "太不可思議了，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不過，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "這是道溫柔的光芒。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "……",
        "unit_id": 1,
        "voice": "vo_adv_1250003_090"
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "為什麼呢，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n我變得想要再次挑戰",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "已經放棄的新事業了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "\n好，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人",
        "words": "我要立刻重新擬定計畫書！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職人見習生",
        "words": "……可惡，",
        "unit_id": 1,
        "voice": "vo_adv_1250003_091"
    },
    {
        "type": "dialogue",
        "name": "職人見習生",
        "words": "我明明因為師傅太嚴厲而逃跑，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職人見習生",
        "words": "他的臉卻浮現在我眼前。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職人見習生",
        "words": "\n現在立刻去道歉吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職人見習生",
        "words": "我這次要腳踏實地地努力，提升自己的技藝，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職人見習生",
        "words": "\n然後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職人見習生",
        "words": "絕對要成為一流的工匠！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "有志成為女演員的人",
        "words": "沒錯，",
        "unit_id": 1,
        "voice": "vo_adv_1250003_092"
    },
    {
        "type": "dialogue",
        "name": "有志成為女演員的人",
        "words": "落選個一、兩次又不算什麼！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "有志成為女演員的人",
        "words": "\n我是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "有志成為女演員的人",
        "words": "未來的知名女演員，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "有志成為女演員的人",
        "words": "怎麼能因為這種事認輸！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "有志成為女演員的人",
        "words": "\n我要立刻",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "有志成為女演員的人",
        "words": "展開訓練，準備下一次的甄選！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真不可思議……！",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_093"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家都變得樂觀積極了。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我明明沒有親眼見到，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "卻有這樣的感覺！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣的話……！　",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘉夜、",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_094"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "望，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "最後再加把勁！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要傾注全力喔！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "嘉夜、矛依未、望",
        "words": "上啊！",
        "unit_id": 1,
        "voice": "vo_adv_1250003_095"
    },
    {
        "type": "background",
        "background": "500590"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……用盡",
        "unit_id": 106113,
        "voice": "vo_adv_1250003_096"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "全部力量了嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是啊，",
        "unit_id": 106511,
        "voice": "vo_adv_1250003_097"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "已經連一點都不剩了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我挺喜歡那身裝扮和",
        "unit_id": 102913,
        "voice": "vo_adv_1250003_098"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "設計，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n果然還是會覺得有點寂寞。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們已經將能做的事情全部做完了。",
        "unit_id": 106113,
        "voice": "vo_adv_1250003_099"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n再來，只能相信這些住在蘭德索爾的傢伙們了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以蘭德索爾灑落光之雨的日子為分界，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再也沒有出現被囚禁於樂園中的人。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天，眾人依舊朝向未來邁進。和珍視的人與事物一起邁進──"
    }
]