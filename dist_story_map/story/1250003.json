[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在「幸福的卡里斯瑪」事件結束之後，矛依未依舊精力充沛地"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了解放浮現樂園餘波的居民而四處奔走。"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔哇～",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "天都已經黑了！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n時間未免過得太快了！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖說嘉夜和望同樣也有所行動……",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但樂園的餘波還是一直出現，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "光是四處奔走，今天一天就結束了。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓我再次",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "體會到",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "人們無法從回憶中逃離",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "笨蛋，",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_003"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我怎麼可能會在這種地方放棄！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n別小看壞蛋了！",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過啊，",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "照這樣下去真的會沒完沒了……",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只要人們持續放不下回憶，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們的活動永遠無法結束。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要是就這樣持續把時間耗在解放上，",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我成為世界第一大壞蛋的未來，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也會漸行漸遠。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我到底",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "該如何是好……",
        "unit_id": 125012
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "今天也開始進行解放吧──",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "妳聽說了嗎？",
        "unit_id": 411,
        "voice": "vo_adv_1250003_008"
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "食堂的老闆",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "已經康復了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "哎呀，是這樣嗎？",
        "unit_id": 611,
        "voice": "vo_adv_1250003_009"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "聽說那個人也像道具店老闆那樣",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n變得無法工作，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我一直很擔心他。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "他那裡還有一個年幼的孩子，",
        "unit_id": 411,
        "voice": "vo_adv_1250003_010"
    },
    {
        "type": "dialogue",
        "name": "主婦",
        "words": "真是太好了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "具有相同症狀的人似乎還有很多，",
        "unit_id": 611,
        "voice": "vo_adv_1250003_011"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "希望大家都能早日康復。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……喂，",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你有聽到剛才的對話吧？",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我記得食堂的老闆",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "應該還沒解放……",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有可能！",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我們去看一下情況吧！",
        "unit_id": 125012
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "爸爸～",
        "unit_id": 211,
        "voice": "vo_adv_1250003_014"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "快點快點！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我要丟下你了喔！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "喂喂，",
        "unit_id": 4911,
        "voice": "vo_adv_1250003_015"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "妳不要太興奮了。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "這樣會跌倒吧？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "因為",
        "unit_id": 211,
        "voice": "vo_adv_1250003_016"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我很高興爸爸恢復健康了嘛！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "……啊，",
        "unit_id": 4911,
        "voice": "vo_adv_1250003_017"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "原來是這樣啊。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "抱歉，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "爸爸",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "太丟臉了……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "爸爸，",
        "unit_id": 211,
        "voice": "vo_adv_1250003_018"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "你是生病了吧？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "這也是沒辦法的事。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "……不對，",
        "unit_id": 4911,
        "voice": "vo_adv_1250003_019"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "那才不是生病。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "\n爸爸我之前啊，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "無法從自己所珍視的回憶中",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "脫身。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "我想要永遠待在這裡。",
        "unit_id": 4911,
        "voice": "vo_adv_1250003_020"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "那是個會讓我產生這種想法，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "非常幸福的時光。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "那麼，",
        "unit_id": 211,
        "voice": "vo_adv_1250003_021"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "為什麼你能夠回來呢？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "這是因為啊，",
        "unit_id": 4911,
        "voice": "vo_adv_1250003_022"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "有妳在我的身邊喔。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "我？",
        "unit_id": 211,
        "voice": "vo_adv_1250003_023"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "是啊。",
        "unit_id": 4911,
        "voice": "vo_adv_1250003_024"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "我想要看見妳長大成人的未來，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "我想要和妳一起創造新的回憶。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "我產生這個想法後，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "就自然而然地從回憶中成功脫身了。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "原來是這樣啊。",
        "unit_id": 211,
        "voice": "vo_adv_1250003_025"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "那我會永遠待在爸爸的身邊，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "爸爸要永～",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "遠",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "看著我喔♪",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "好，",
        "unit_id": 4911,
        "voice": "vo_adv_1250003_026"
    },
    {
        "type": "dialogue",
        "name": "父親",
        "words": "當然沒問題。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……原來那個大叔",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_027"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的是自行從回憶中脫身的。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不對，",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為我們得到了特別的力量，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n感覺似乎有點麻痺了……",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說起來，人類",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算沒有什麼特別的力量，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也都擁有",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "開拓未來的力量。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "即使",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "獨自一人前行會有困難，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n和他人一起的話，說不定就能辦到。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我有",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀這個夥伴，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n他的存在",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "成了我邁向未來的力量。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對那個大叔來說",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是自己的孩子，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n其他還有",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "兄弟姊妹、",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "朋友和",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "戀人，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不對，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "說不定並不侷限於人類。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "寵物、興趣和",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "工作，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為珍視的事物",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因人而異嘛。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "人類",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為了邁向未來，",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "某樣珍視的事物",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是不可或缺的。",
        "unit_id": 125012
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和某位珍視的人，",
        "unit_id": 125012,
        "voice": "vo_adv_1250003_034"
    },
    {
