[
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾某處。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n戳糖片的攤販前。"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那麼，",
        "unit_id": 126411,
        "voice": "vo_adv_9009008_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我要卯足全力上囉～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "喝啊～！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "該用多少力氣好難調節呢～？",
        "unit_id": 126411,
        "voice": "vo_adv_9009008_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n就算把輸出力道調到最低，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "也會整個碎掉～",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵呵……",
        "unit_id": 1,
        "voice": "vo_adv_9009008_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那邊那位機械人族的小姑娘。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妳好像很傷腦筋呢？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 126411,
        "voice": "vo_adv_9009008_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這個聲音是♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法少女，",
        "unit_id": 101311,
        "voice": "vo_adv_9009008_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香登場！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "只要稍微違反規則，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就會立刻失去資格的戳糖片。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我來拯救在陌生異世界的攤販前",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "苦戰的少女了～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "妳好～七七香！",
        "unit_id": 126411,
        "voice": "vo_adv_9009008_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖然我不太清楚狀況，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n但是妳",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "會教我戳糖片的訣竅，對吧？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "正是如此！",
        "unit_id": 101311,
        "voice": "vo_adv_9009008_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我馬上就來示範給妳看喔～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所謂的戳糖片，",
        "unit_id": 101311,
        "voice": "vo_adv_9009008_007"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是用針",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "從糖片上",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "把圖案，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也就是形狀，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "給戳下來的遊戲……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "宛如",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "欣賞心愛的模型時一樣，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n以溫柔的手法來對待它是很重要的喔。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哦哦，",
        "unit_id": 126411,
        "voice": "vo_adv_9009008_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "真的漂亮地把圖案弄下來了！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這個",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "也可以用鑽頭來弄嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯嗯。",
        "unit_id": 101311,
        "voice": "vo_adv_9009008_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n「只要是頭尖尖的東西用什麼都可以吧」",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這種草率的想法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "可以判斷成最大的敗因呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "唔～",
        "unit_id": 126411,
        "voice": "vo_adv_9009008_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "說是這麼說，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "但我已經沒有辦法再把力道調小了……",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對了！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "只要找一個又大又堅固，",
        "unit_id": 126411,
        "voice": "vo_adv_9009008_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n即便我用力戳也不會碎掉的糖片就可以了吧！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "今年的夏日祭典可能沒有辦法了，",
        "unit_id": 126411,
        "voice": "vo_adv_9009008_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n但明年我要成為擺攤的一方，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "用超大片的巧克力當成糖片，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n讓大家用鑽頭來挑戰的戳糖片攤販♪",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "多麼驚人的想像力──",
        "unit_id": 101311,
        "voice": "vo_adv_9009008_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這就是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "異文化交流所產生的雙重螺旋！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼小建議",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "都顯得太庸俗了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "用妳的鑽頭",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "突破巧克力吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這時就該說這句！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "對吧♪",
        "unit_id": 126411,
        "voice": "vo_adv_9009008_014"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n如果真的能夠實現的話，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生也要來玩哦！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，和七七香交流過後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克蘿茜想好了明年夏日祭典的目標。"
    }
]