    {
        "type": "dialogue",
        "name": "望",
        "words": "伊莉亞真的是個很不可思議的人耶。",
        "unit_id": 111611,
        "voice": "vo_adv_6029104_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一下是小孩，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一下又變成大人，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "說話的方式也很特別。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她到底是什麼樣的人呢……？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "吸血鬼……",
        "unit_id": 111611,
        "voice": "vo_adv_6029104_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你是指，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會吸人血的",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她看起來不像是那麼可怕的人啊……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難不成你曾經",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "被她吸過血嗎……？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦咦咦？　",
        "unit_id": 111611,
        "voice": "vo_adv_6029104_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "她是你的主人",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗎？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你能不能再說詳細一點？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你問我為什麼……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "下次要寫吸血鬼的歌的時候，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "搞不好可以當作參考啊！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有稱號感覺好酷喔！",
        "unit_id": 111611,
        "voice": "vo_adv_6029104_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "統御黑夜之人……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聽起來好像每天晚上都在熬夜耶？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我得告訴她，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "熬夜可是肌膚的大敵喔！",
        "unit_id": 111611
    }
]