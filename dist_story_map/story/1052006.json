[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "似似花～妳在哪～？",
        "unit_id": 105211,
        "voice": "vo_adv_1052006_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，找到了！",
        "unit_id": 105211,
        "voice": "vo_adv_1052006_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這棵",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "樹，是似似花對吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……嗯。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我應該完美地變化成了樹木才對，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為什麼妳能看穿呢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯～感覺氣味不同？",
        "unit_id": 105211,
        "voice": "vo_adv_1052006_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不知道為什麼，就是認得出似似花♪",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原來如此。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就算外表完美地變化，嗅覺卻沒辦法也欺騙過去嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "值得參考。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n看來我的變化能力，尚有改良的餘地呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n如果要可以完全變化，我必要再努力一點。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "至少，要達到『前世』的我的程度……",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只能辦到如此不徹底的變化的話，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n可配不上變貌大妃之名。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "前世？\n變貌大妃？",
        "unit_id": 105211,
        "voice": "vo_adv_1052006_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我聽不太懂……\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052006_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個，從那之後，我思考到了很晚。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我果然還是想變成人類的外貌。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "用這個外貌，在人類的世界裡實在難以生存。",
        "unit_id": 105211,
        "voice": "vo_adv_1052006_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不過人家並不是希望捨棄這個外表。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……就算變化之後，還可以變回來嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可以。應該說要變換成另一個肉體，",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n對現在的我來說還有點困難。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "光是只將妳的外表暫時修改成人類的樣子，就精疲力竭了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣啊。\n那麼就當作嘗試，",
        "unit_id": 105211,
        "voice": "vo_adv_1052006_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能請妳幫我變身嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然有點害怕～\n不過這種機會，說不定遇不到第二次了。",
        "unit_id": 105211,
        "voice": "vo_adv_1052006_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好的。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，請妳摸我的手。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在開始我要干涉妳的肉體，使之產生變化。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這也是我第一次替他人施術，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所以要是產生誤差就不好意思了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家聽不太懂……\n那個，會不會痛？",
        "unit_id": 105211,
        "voice": "vo_adv_1052006_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n好可怕！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然，有產生劇痛的可能性。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這是將肉體像黏土一樣重塑。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而這原本是不可能的，所以還請妳忍耐一下些許的負擔。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯……\n那就",
        "unit_id": 105211,
        "voice": "vo_adv_1052006_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "拜託妳了，似似花。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好的。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我以變貌大妃之名，賜予妳奇蹟吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……唔。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n嗯，大概就是這樣吧。",
        "unit_id": 107011
    },
    {
        "type": "still",
        "still": "105200601"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "…………",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個，\n已經，變化完成了嗎？",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n總覺得不太有真實感……？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是的。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要是有事先準備好鏡子就好了呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "感覺如何呢？有沒有哪裡會痛？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不會，沒問題。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊，不過有點冷！",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哈、哈啾☆",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯。由於妳的外貌變化成人類的樣子，",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n原先來自毛皮的保溫效果就消失了呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "事實上，以沒有毛皮來說，妳穿的衣服算是相當單薄。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過我姑且替妳把裝備的鎧甲等等，",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n依照比例縮小、調整好了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "幫上大忙了～要是直接穿著原本的鎧甲就會鬆掉了呢。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哇～……能完全看到肌膚呢，總覺得很害羞～♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哦唷唷？\n身體的大小改變後，有點難維持平衡……？",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "感、感覺劍也變得很重。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_028"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n在這個狀態下，戰鬥是辦不到的呢。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是的。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n請盡可能地避免粗魯的舉動。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在不穩定的狀態下，",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我想受到一點刺激就會變回原本的樣貌了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n因為本來就是半強迫地使肉體產生變化。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我知道了，我會小心。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_031"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "……唷，好像有腳步聲？",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_032"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n這不是魔物，是人類的腳步聲？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻，耳朵和之前一樣好～♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是的。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我參考了獸人的外貌，還留著原本的耳朵。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要是完全變化成普通人類……",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "和原本的肉體相差甚遠的話，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n會有產生身體機能不完全的可能。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔。\n的確感覺和小栞還有小鈴一樣呢。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_035"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "比起這個，\n似似花，妳先躲起來比較好哦。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_036"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "妳不太想被其他人看見對吧？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "畢竟人家的外表變得像人類一樣了，\n應該不會嚇得人喊『有魔物～』才對。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "由人家來好好說服接近的人，替妳把人趕走♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是幫了忙呢。",
        "unit_id": 107011,
        "voice": "vo_adv_1052006_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "勞妳費心了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不會啦。\n畢竟似似花實現了人家的夢想呢。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_039"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "最～喜歡妳了。\n我們當好朋友吧。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_040"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果想要什麼謝禮，就盡管說吧♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？似似花？",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_041"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n啊啊",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "，又變成樹木躲起來了吧……？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "哦唷。\n得好好應對接近的人才行。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_042"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個，請問是哪位？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？\n啊！",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_043"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n唷呼",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "～♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "欸，好過份！",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_044"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n為什麼會說出這種話呢，就好像第一次見面一樣……？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（啊，對了，人家的身體變化了呢。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_045"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n認不出我是莉瑪嗎？）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯！\n怎麼了嗎？",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_046"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "怎麼擺出驚慌失措的表情……？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？\n為什麼要道歉，還說認錯人了……？",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_047"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（這樣啊。\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_048"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "他不知道我就是莉瑪呢。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n因為我變成了人類的樣子。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（雖然就是同一人～\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_049"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "但會不會覺得我是『像莉瑪的其他人』？）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（怎麼辦。\n是不是只要說出自己是莉瑪就好了呢？",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_050"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n在繪本裡，要是真實身分被發現就會變回原本的樣子了。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（也不知道變回原樣的契機是什麼，\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_051"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "做任何行動前得小心謹慎才行。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "預防萬一，對他也隱藏真實身分好了。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（之後再詳細問問似似花，\n會因為什麼契機變回原本的樣貌。）",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_052"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（……哦唷，他一臉懷疑地看著我！",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_053"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n我想",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "想～？）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那個，\n你在找那個叫莉瑪的女孩子嗎？",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_054"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n有什麼事？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "唔。\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_055"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "叫莉瑪的女孩子似乎很煩惱，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n【伊麗莎白牧場】的大家都很擔心？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以大家才會拜託你……",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_056"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n來看看狀況嗎？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣啊～\n抱歉，讓你們擔心了。",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_057"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過沒事哦，我很有精神啦♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊……\n那個，",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_058"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家認為那位叫莉瑪的女孩子也很有精神哦？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "為什麼能這麼斷定嗎？\n你這麼問會讓人家有點困擾～？",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_059"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就、就是女人的直覺？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦？\n你要去哪裡？",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_060"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "咦，要去找叫莉瑪的女孩子？",
        "unit_id": 105212,
        "voice": "vo_adv_1052006_061"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家就在這裡……啊，現在外表是這樣～？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊啊真是的，該怎麼辦才好～！？",
        "unit_id": 105212
    }
]