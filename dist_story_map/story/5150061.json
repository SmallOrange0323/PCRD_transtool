    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 131811,
        "voice": "vo_adv_5150061_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "找～到涅比亞了♪",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呃，",
        "unit_id": 190912,
        "voice": "vo_adv_5150061_001"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "帆稀！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呃！",
        "unit_id": 131811,
        "voice": "vo_adv_5150061_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是什麼反應～？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "記得我跟涅比亞應該沒怎麼說過話耶～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就算不說話也知道啦，",
        "unit_id": 190912,
        "voice": "vo_adv_5150061_003"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "因為妳有種奇妙的氣勢。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "氣勢……",
        "unit_id": 131813,
        "voice": "vo_adv_5150061_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "又來了……",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "一旦成為像我這樣的惡作劇專家，",
        "unit_id": 190912,
        "voice": "vo_adv_5150061_005"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就會本能地明白能不能對對方",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "惡作劇並當作玩笑收場。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "希望妳告訴我作為參考，",
        "unit_id": 131811,
        "voice": "vo_adv_5150061_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有誰感覺是不能惡作劇的呢～？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯～",
        "unit_id": 190912,
        "voice": "vo_adv_5150061_007"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "像深月或惠理子那樣吧，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "感覺就會笑著把我做成標本。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯嗯。",
        "unit_id": 131813,
        "voice": "vo_adv_5150061_008"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊，",
        "unit_id": 190912,
        "voice": "vo_adv_5150061_009"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還有花凜也有點不妙呢。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "愛惡作劇的人無法忍受因為規則或嚴肅的事而被責備。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "誒～",
        "unit_id": 131811,
        "voice": "vo_adv_5150061_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那美里之類的是目標啊？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是啊，",
        "unit_id": 190912,
        "voice": "vo_adv_5150061_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "感覺她就會面帶笑容地原諒任何事吧。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不過，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "總覺得被原諒有點不對勁呢～",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我個人覺得，",
        "unit_id": 190912,
        "voice": "vo_adv_5150061_012"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "對於惡作劇",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "做出很棒的反應，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n直接對我發怒才剛剛好啊。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此，",
        "unit_id": 131811,
        "voice": "vo_adv_5150061_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "惡作劇之道也是很深奧的呢～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "話說，",
        "unit_id": 190912,
        "voice": "vo_adv_5150061_014"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳問這種事是想做什麼？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為我們",
        "unit_id": 131811,
        "voice": "vo_adv_5150061_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也有一個叫祈梨的",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "孩子會稍微惡作劇，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以我就想，這應該能當成對策吧～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "順便問一下，那妳有答案了嗎？",
        "unit_id": 190912,
        "voice": "vo_adv_5150061_016"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "關於對策。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一邊因為規則或嚴肅的事責備她，一邊用會原諒一切的笑容把她做成標本。",
        "unit_id": 131811,
        "voice": "vo_adv_5150061_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……抱歉，",
        "unit_id": 190912,
        "voice": "vo_adv_5150061_018"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "祈梨。",
        "unit_id": 190912
    }
]