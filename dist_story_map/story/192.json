[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什、",
        "unit_id": 106011,
        "voice": "vo_adv_0000192_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們到剛剛為止都還不是在這種地方的吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是有誰對我們施了什麼轉移魔法嗎？",
        "unit_id": 105811,
        "voice": "vo_adv_0000192_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過嘛，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "往前走走看就知道了嘛！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哇！　",
        "unit_id": 106011,
        "voice": "vo_adv_0000192_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "笨蛋！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一點防備也沒有就一頭栽進去不是很危險嗎！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是呀，",
        "unit_id": 105811,
        "voice": "vo_adv_0000192_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "完全沒有可怕的感覺唷？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "甚至，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該說是有一種讓人很懷念的感覺……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的確，",
        "unit_id": 106011,
        "voice": "vo_adv_0000192_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟妳說的一樣，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也這麼覺得。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "該說像是自己看著自己一樣嗎……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡是我們的心靈投影？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "類似這樣的感覺？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "藉由探求追尋",
        "unit_id": 105911,
        "voice": "vo_adv_0000192_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那埋藏於自身內部最深處的記憶，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "進而能將那蘊藏的力量解放，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下曾聽過如此的傳聞。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是要認真面對自己，",
        "unit_id": 105811,
        "voice": "vo_adv_0000192_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「妳要變得更厲害。」",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對自己這樣講的意思？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼我們就出發試試看吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看招啦～☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以說",
        "unit_id": 106011,
        "voice": "vo_adv_0000192_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要就那樣一頭栽進去了啊！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吼，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是愛給人添麻煩～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_0000192_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人也一同出發吧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105911
    }
]