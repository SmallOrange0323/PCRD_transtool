[
    {
        "type": "background",
        "background": "500440"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天早上。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "綾音等人和變得親近的普烏人民相約再見後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n踏上回到蘭德索爾的歸途。"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「真的耶～",
        "unit_id": 2113,
        "voice": "vo_adv_1232004_000"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n普烏那群人願意告訴我們安全的回程路，",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "真是幫大忙了。」",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「真是的，",
        "unit_id": 2113,
        "voice": "vo_adv_1232004_001"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "既然有這種道路，",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "就該把這條路該寫在地圖上吧。",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n什麼",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "『前往普烏的路途非常險峻』",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "啊。",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n這個冒險家其實是偷偷潛入的吧？",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我們拜他所賜，吃足了苦頭耶。」",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………",
        "unit_id": 123211,
        "voice": "vo_adv_1232004_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…對不起啦？",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是我無論如何都想來，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "耍起性子……",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「不不不！",
        "unit_id": 2113,
        "voice": "vo_adv_1232004_003"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這不是綾音的錯啦。",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n畢竟",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我也想要知道自己的起源。」",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不過，",
        "unit_id": 123211,
        "voice": "vo_adv_1232004_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們到頭來還是一無所知……",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我的任性",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "只是讓你們遭遇危險，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "最重要的噗吉起源",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也沒有半點收穫……",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「綾音……",
        "unit_id": 2113,
        "voice": "vo_adv_1232004_005"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "妳別露出這種表情啦……」",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可",
        "unit_id": 123211,
        "voice": "vo_adv_1232004_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為這趟冒險的緣故，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉全身",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "變得髒兮兮，",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還傷痕累累……",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你一定很痛吧……",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對不起……",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「……我一點都不痛。",
        "unit_id": 2113,
        "voice": "vo_adv_1232004_007"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "妳不用這麼溫柔地撫摸我啦。」",
        "unit_id": 2113
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你騙人……",
        "unit_id": 123211,
        "voice": "vo_adv_1232004_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很痛吧。",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「…………」",
        "unit_id": 2113,
        "voice": "vo_adv_1232004_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……奇怪？",
        "unit_id": 123211,
        "voice": "vo_adv_1232004_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "總覺得",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "懸崖的另一頭好刺眼……？",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n太陽……？",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對……",
        "unit_id": 123211
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這是什麼光……",
        "unit_id": 123211
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "星期日午後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}家的門鈴響了。"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………！",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_011"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「別這樣，綾音！",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_012"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我求求妳千萬不要做這件事！",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "小、",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "小子，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "沒事沒事！",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我們沒事，你快幫我趕走綾音！」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………！！",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_013"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「綾音！",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_014"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "喂，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "不要把我交出去！",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n都說我死都不要了！",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n就算你找小子幫忙，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "討厭的東西就是討厭──」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………！",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_015"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「妳說不行？",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_016"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "不管噗吉說什麼，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這件事妳絕不退讓？",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "……呃，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "她在用有別於平時的堅定眼神，盯著我看啊！」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「不對，",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_017"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "就算綾音再三拜託，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我也不會退讓喔？",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我堅決拒絕。",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "請恕我拒絕『那個』！",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n聽好了，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "妳敢做『那個』看看。",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我就要和綾音絕交！」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………！！！！",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_018"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「什麼！？",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_019"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "喂，我都說要絕交了……",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "妳現在",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "完全無視我，要把我交給小子啊！？」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「啊──",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_020"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "這樣啊。",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "想必妳是不知道絕交的意思吧？",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我明白了，我來告訴妳。",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "首先妳把我放下來，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "先坐在那裡。",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "聽好了，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "所謂的絕交啊，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "是這世上最難受最恐怖──」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「呃，喂，綾音，",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_021"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "聽我說話啊──！",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "喂！",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "不要……",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "讓小子看到我的背後啊！」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……嗯！",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_022"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「……小子，",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_023"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "你這傢伙注意到了啊……」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「啊～啊，",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_024"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "對啦！",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我也沒有要隱瞞的意思。",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我的背上",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "現在全是冰淇淋。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「咦？",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_025"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "你問為什麼？",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "今天啊，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我本來要和綾音一起",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "觀賞人偶劇。",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n所以我們直到剛才都待在劇場。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「可是，就在公演開始前。",
        "unit_id": 102331,
        "voice": "vo_adv_1232004_026"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "隔壁小毛頭拿著的冰淇淋",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "沾到了我身上。",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音才會慌張地跑到這裡來，",
