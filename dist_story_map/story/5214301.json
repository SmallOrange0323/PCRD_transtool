[
    {
        "type": "dialogue",
        "name": "倭",
        "words": "妳們兩人的表情",
        "unit_id": 130011,
        "voice": "vo_adv_5214301_000"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "很不錯。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不過，",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "還是有所不足──",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我就讓妳們見識一下，",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "靠氣勢也無法跨越的高牆是什麼樣子吧。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "倭小姐……",
        "unit_id": 138811,
        "voice": "vo_adv_5214301_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "明明只是舉起劍而已，",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就有如此驚人的壓迫感……！",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好令人畏懼的氣場啊。",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這麼強大的人",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "非常少見呢……",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "唔、",
        "unit_id": 138711,
        "voice": "vo_adv_5214301_002"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗯嗯！",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "就是說啊！",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n姊姊可是熬過了很多生死關頭，",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n跟普通人的等級",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "還是不太一樣呢！",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "明明處在危機之中，",
        "unit_id": 138811,
        "voice": "vo_adv_5214301_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n但總覺得若菜小姐",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好像有點高興呢……？",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊，",
        "unit_id": 138711,
        "voice": "vo_adv_5214301_004"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "咳咳。",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "總之栞小姐，",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我們卯足全力戰鬥吧。",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "如果露出丟臉的一面，",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可是會被姊姊罵的……！",
        "unit_id": 138711
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……呵呵。",
        "unit_id": 138811,
        "voice": "vo_adv_5214301_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我明白了。",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓我們全力以赴，",
        "unit_id": 138811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "抬頭挺胸地戰鬥吧！",
        "unit_id": 138811
    }
]