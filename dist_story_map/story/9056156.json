        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……原來如此。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若真有此事，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
