[
    {
        "type": "background",
        "background": "505035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這件制服",
        "unit_id": 117911,
        "voice": "vo_adv_6076302_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "很酷很有型，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超～帥氣的對吧！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家覺得非常喜歡喔，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才覺得呢？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n適合人家嗎？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果有特別喜歡的部分快告訴人家嘛！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呀哈──！",
        "unit_id": 117911,
        "voice": "vo_adv_6076302_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "圖上這孩子，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "名叫南瓜吉喔！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "博士",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "拿制服的設計給人家看時，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家覺得可以再可愛一點，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n所以就設計了一個圖標加進去！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超可愛又帥氣對吧！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個啊，",
        "unit_id": 117911,
        "voice": "vo_adv_6076302_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "博士所製作的",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "妖魔用武器喔。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n好像還附加了很厲害的功能呢？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "像是可以變形成方便享用大蛋糕的叉子之類的！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才果然也是這麼認為嗎？",
        "unit_id": 117911,
        "voice": "vo_adv_6076302_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真～的很適合人家對吧！",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "無論是這個蝴蝶結",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還是翅膀裝飾，",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "都是人家很喜歡的地方。",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n你要不要再靠近一點看呢？",
        "unit_id": 117911
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不用客氣喔～♪",
        "unit_id": 117911
    }
]