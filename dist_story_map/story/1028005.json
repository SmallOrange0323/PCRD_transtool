[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼？",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n父親大人請等等，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能請您再說一次嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n剛才聽不太清楚呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會不會是使用通訊魔法的術士出了什麼差錯呀……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒有錯。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我敬愛的父親大人，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是不可能說出那種陳腐惡德商人才會說出的話呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "討厭啦，我可是一直都很尊敬您哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最喜歡、最喜歡您了，真的真的♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "然後呢，父親大人……",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n非常抱歉，能請您再說一次嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，抱歉！",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n能不能請您稍等幾秒鐘？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像有認識的人向我搭話……",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是真的，並不是拖延時間的策略。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個，",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n{player}，有什麼事？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就像你看到的，我正在忙哦？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話說回來。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你為什麼會在這種地方啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是從哪裡進來的呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯哼……只不過是路過啊，",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "聽到我的聲音，覺得有點在意，所以過來看看？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你看起來總是那麼悠閒呢，令人羨慕。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我並不是在挖苦你哦……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然這是我自己選擇的道路，",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過像你一樣輕鬆地活著似乎比較好呢～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我偶爾會這麼想。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真想要普普通通地享受青春。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "先不說這些了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這裡使用了通訊魔法……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是為了和遠方取得聯繫所建的設施哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我正在通話中，不可以隨便闖進來。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n魔法術式會被擾亂，然後通話就會中斷的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n通訊魔法受到管理，只限定公家機關能夠使用。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個設施也是由【公主騎士】……，",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也就是王宮直屬的公會所營運的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而我的公會也算是\n【公主騎士】旗下的附屬公會。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "使用的時候能打點折扣哦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是並不是免費的，所以要盡量長話短說。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真討厭，實在是太不方便了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你不這麼覺得嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "通訊魔法啊～",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n得仔細地計算時間以及座標，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n並且雇用專門施術的術士準備好幾天哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "根據不同情況，有時使用傳信鴿或者雇用信差還比較快。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是通訊方式能夠讓大家隨身帶著走……",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n能更輕鬆地和遠方交談就好了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我有看過那種內容的小說哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "既然人類能夠想像，那麼在現實中肯定有實現的可能哦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這並不單單只是夢想，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就由我投資通訊魔法，使技術發達光大吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果是技藝高超的魔法師，就能夠單獨使用通訊魔法呢。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "然後把那種技術簡化，接著廣泛地流通～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊，我似乎嗅到了商機。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉呀。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "先不說這些了，{player}……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你有什麼話要對我說嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "接下來我得和父親大人交涉很長的時間，",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以沒有辦法和你說話。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我在和父親大人通話哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他曾經是手段高明的實業家，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過現在他將很多事都過繼給我，然後就退休了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他幾乎像是用錢買來的一樣，強硬取得了貴族的地位，",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還順帶得到了城池和領地。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他現在已經鬥志全消，過著優雅的下半生哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒關係。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我正好想暫時冷靜一下……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你向我搭話，剛好幫上忙了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n總覺得呢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你都是在我感到困擾的時候過來搭話呢♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咳咳。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n先不說這些了，再這樣聊下去，會被父親大人懷疑的……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我要回到通話中了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "父親大人？",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n喂喂～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉讓您久等了♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……您還是認為沒有什麼利益所以無法投資嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這一點啊，就當作是支援您可愛的女兒吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我呢，想要做些會被世人誇讚的善事哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我知道啦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不論是什麼善事，甚至是志工，都會牽扯上利害關係是吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我沒打算要浪費資金。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會將資金發揮到最大效用的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一張嘴什麼話都能說？",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說的也是呢～正是如此。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會做好企畫書寄過去的，還請您仔細過目。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一定要看哦，絕對會讓您投資的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真討厭……",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n可愛的女兒都這樣懇求您了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n您就說好然後接受女兒嬌縱的請求不是很好嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊～是是。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我知道啦，光會縱容並不是疼愛是吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過啊，我可還算是個小孩哦……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。再見，快要超過規定的通話時間了……",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "今天就先談到這裡吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n掰掰～您要注意健康哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……真討厭。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_041"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊～實在有夠煩人！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n怎麼了，{player}？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不不，我和雙親的關係都很好哦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_043"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也非常敬愛父親大人。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只不過他實在是個令人火大的交易對象呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最近呢……【咲戀育幼院】，",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n經營得有點不太順利。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以才向父親大人請求援助哦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_045"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只不過，他目前似乎完全沒有投資的打算。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是，像我們這種沒有多少人信賴，更沒有績效的弱小公會，",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_046"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就算要請一般人投資，應該誰也不會多看一眼吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只要有所幫助，就算是自己的雙親也得好好利用呢～",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過算了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_047"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n{player}，要是你等等有空，就稍微陪陪我吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一起去附近的咖啡店吃點甜點吧。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_048"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我已經累積了過多的壓力，幾乎快爆發了啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就只有糖分能夠排解這份焦躁了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "接下來也得推敲要交給父親大人的企劃。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_049"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你有想給點什麼意見嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對手畢竟是我的親人……",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_050"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n很容易就會氣急敗壞，然後失去冷靜。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以想要聽聽第三者的意見。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_051"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我擁有的就只有年輕，還有時間……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就只能夠活用和金錢同樣貴重的時間了呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可以陪我吧？{player}。",
        "unit_id": 102811,
        "voice": "vo_adv_1028005_052"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……只要和你說話，我就會覺得很放鬆呢。",
        "unit_id": 102811
    }
]