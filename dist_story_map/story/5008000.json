[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與杏奈一同在蘭德索爾踏上旅途，\n兩人持續走在漫長的道路上。"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔唔，",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "明明已經走相當久了，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "卻沒見到像是溪谷的景色……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "空著肚子也無法戰鬥，",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這的確是",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n應該盡速解決的問題。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唔唔唔……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但是，",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這苦難也不會持續太久的……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n只要去溪谷洞窟，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "所有問題就能解決了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這雖是條苦難之路，",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但我們要堅忍熬過，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我相信這張傳單",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "一定能拯救我們的困境！",
        "unit_id": 100911
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不久前——"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可惡啊～！　",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我這個疾風之冥姬，\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "竟然會陷入找打工的窘境……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真是我這輩子最大的失誤！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒想到",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "蘭德索爾附近的通緝犯，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n都變得異常安分。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒有通緝犯的話，",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就很難靠獎金來賺錢了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼可能每個傢伙都洗心革面老老實實地生活啊……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯？　",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼了，吉格魯特？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你好像拿著什麼傳單？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n希望我看這個？　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "什麼什麼……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "附三餐！　",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_008"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "住宿設施完善！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "有前輩們親切細心的指導，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n是個大受好評如在家般舒適的陽光職場――",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎、",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "怎麼會有這麼優渥的待遇！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這種打工真的有可能存在嗎！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "工作地點在哪裡！？",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "溪谷洞窟？　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我沒聽過這地方呢。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_011"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我打算去應徵這份工作。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這條件這麼好，如果不快點去，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "說不定就會沒有職缺了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是嗎！　",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_012"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這麼說的話，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我就能得到",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這裡所寫的介紹朋友的獎勵了吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "一天增加5000盧幣……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "簡直像做夢呢！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "天下沒有白吃的午餐，",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_013"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你是想這麼說嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n哈哈哈！　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特真愛操心！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼我們就一起去吧！",
        "unit_id": 100911
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗚嗚～",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_014"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "話說回來，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還沒有到嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "真的是累了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦咦？　",
        "unit_id": 101311,
        "voice": "vo_adv_5008000_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "杏奈美眉？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n還有這不是{player}嘛！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "敬禮！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哦哦，",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_016"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這聲音不就是和我結成同盟的",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "七七香嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n難道說，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "七七香也是來打工的？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "打工？　",
        "unit_id": 101311,
        "voice": "vo_adv_5008000_017"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是喔～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是要收購古文書唷。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我得到消息說溪谷洞窟發掘出古文書。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而聽說那個古文書，",
        "unit_id": 101311,
        "voice": "vo_adv_5008000_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "記載了很稀有的情報呢～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也就是說，",
        "unit_id": 101311,
        "voice": "vo_adv_5008000_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那很有可能有很高的價值！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔呼呼，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我有預感",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這是一獲千金的機會～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "問得很好！",
        "unit_id": 101311,
        "voice": "vo_adv_5008000_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚嗚，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我為了這個把我珍藏的模型拿去典當了啦～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我的計畫是用這筆錢當資金來賺取大錢，",
        "unit_id": 101311,
        "voice": "vo_adv_5008000_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n然後再把她們",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "給贖回來！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等著我喔，我的老婆們！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "――才想說來了群吵吵鬧鬧的人，",
        "unit_id": 105611,
        "voice": "vo_adv_5008000_022"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "原來是你們啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n連{player}也在一起，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你們要做什麼？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哎呀，",
        "unit_id": 101311,
        "voice": "vo_adv_5008000_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "流夏姐？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這不是流夏嗎！　",
        "unit_id": 100911,
        "voice": "vo_adv_5008000_024"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳在做什麼？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我在散步，途中睡了午覺啊。",
        "unit_id": 105611,
        "voice": "vo_adv_5008000_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n悠閒地散步",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "也走遍了這塊大陸的各個地方。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳有這麼閒嗎……",
        "unit_id": 101311,
        "voice": "vo_adv_5008000_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳該不會",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是在尋找暮光之都的線索？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好認真！　",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳真是太認真了，大姐頭！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我說過別叫我大姐頭吧。",
        "unit_id": 105611,
        "voice": "vo_adv_5008000_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是你們幾個太不認真了而已。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
