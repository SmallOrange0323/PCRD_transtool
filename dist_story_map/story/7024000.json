        "voice": "vo_adv_7024000_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我使用變身魔法變身吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n再多加強觀察力吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳！",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_026"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不就是偶爾跟在陛下身旁的馬屁精魔法師嗎！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳怎麼會出現在這裡！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107011,
        "voice": "vo_adv_7024000_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等等！",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_028"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n幹嘛無視我啊～！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因為得知你也會來這座塔。",
