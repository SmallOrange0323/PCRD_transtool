    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "藏有{player}記憶線索的露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有一個人正呆愣在入口處眺望著塔。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這就是",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "露娜之塔……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "靠近看才曉得……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "根本沒有人告訴我",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "它這麼巨大啊！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚嗚，",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真是的……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這種肉體勞動",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n根本不是由我來做的事……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要不是陛下的命令，",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我絕對不會來這種地方！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這點",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你真的明白嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼，",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你明白就好。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n明白就好。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就算陛下現在身處",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_005"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "無法親自來調查的狀況，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n提出要來調查的人",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n不就是克蕾琪塔小姐您自己嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒辦法啊，",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n又不行讓忙碌的陛下離開王都。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "話說",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "讓王族參與危險的冒險本來就是件奇怪的事情……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以說！ ",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "身為陛下忠臣的我，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n克蕾琪塔‧凱許才會像這樣親自出馬！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是因為重建事業告一段落，",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_008"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "已經沒有任何有竄改價值的帳簿",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n這樣好賺工作的關係嗎？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒有錯……",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "個鬼！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳在說什麼啊，秘書一號！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我才不會做這種事呢！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "………………",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "最近沒有。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這次是因為！ ",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_010"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下親自特別拜託我",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "「這樣的話，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "{player}就拜託妳照顧囉☆」",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可是奉命在身！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下如此看重我的忠義，",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我怎麼可以拒絕！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "很難想像這是",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_012"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "由一個本來打算阻止她，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "結果被說服，自己跑去負責調查的人",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "口中說出的話……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚……",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我本來的確想阻止，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是看到陛下露出那樣遺憾的表情，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳也知道吧……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過陛下還指示",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_014"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "「機會難得，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就替我去好好享受冒險吧☆」",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然如此……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這個冒險真的是能讓人享受的嗎？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚……",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不管能不能樂在其中。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這可是為了陛下。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我要努力！ ",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "加油！ ",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "克蕾琪塔～！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "嗯，",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_016"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "您就好好加油吧。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下，",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳怎麼一副事不關己的樣子……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "等一下，克蕾琪塔小姐……",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_018"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n您剛才",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是在和誰說話？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還用說嗎？秘書一號，",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_019"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當然是和妳……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼！？",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_020"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有兩個祕書1號？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n怎麼回事！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不對……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然有兩個人那其中有一個應該叫2號……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "1號和2號",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_021"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "誰的薪水比較高呢……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "當然人手是越多越好……",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_022"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不過……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "現在不是開玩笑的時候呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這、",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_023"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這究竟是怎麼回事！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "難道是露娜之塔的魔物……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "呵……",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_024"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "妳還是不夠格呢。",
        "unit_id": 6111
    },
    {
