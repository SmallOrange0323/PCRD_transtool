        "voice": "vo_adv_7024000_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "另外我也有想確認的事情",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以決定與你們同行。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要好好感謝我喔。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼？",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n陛下指名的人明明是我……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼！ ",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "難不成",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳是打算來搶功勞的！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只是調查塔的話",
        "unit_id": 107011,
        "voice": "vo_adv_7024000_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "明明交給我一個人就好了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為什麼",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要和這樣賊頭賊腦的人一起……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是的……",
        "unit_id": 107011,
        "voice": "vo_adv_7024000_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你這個人",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真的是缺乏危機意識耶。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "聽好了， ",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "首先你要有自覺你是什麼樣的存在……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等等！ ",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_033"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "區區一個魔法師",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n膽敢說我賊頭賊腦……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳真是一副高姿態的樣子呢！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "很遺憾，",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_034"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "賊頭賊腦之事屬實。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "誒誒！ ",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "秘書一號！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "妳有什麼問題嗎？",
        "unit_id": 107011,
        "voice": "vo_adv_7024000_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "克蕾琪塔‧凱許。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "明明還在試用期，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "高姿態的人應該是妳吧？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚，",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_037"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那不過是妳擅自決定的！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我已經作為",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下的忠臣被交辦任務了喔！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不過是調查一座塔，靠我們幾個根本綽綽有餘……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "話雖如此，",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_038"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "單靠我們的確有戰力不足的疑慮。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n也會浪費無謂的時間。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "讓這位魔法師同行，",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_039"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n對我們來說",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "也比較有效率吧？",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n克蕾琪塔小姐。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔……",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳說的是沒錯啦……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "討厭的東西就是討厭啊！",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_041"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "講出來了……",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "算了，",
        "unit_id": 107011,
        "voice": "vo_adv_7024000_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "先不管這些無聊的事……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "既然我也參與",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這次的調查，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就一定會讓它成功。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "首先就請妳",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "告訴我上次調查的情報吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳無論如何都要跟上來是嗎……",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_044"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊，真討厭，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "為什麼會變成這樣……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "好啦，",
        "unit_id": 6111,
        "voice": "vo_adv_7024000_045"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n別再像小孩子鬧脾氣，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "快點完成調查吧。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 107011,
        "voice": "vo_adv_7024000_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 107011,
        "voice": "vo_adv_7024000_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒什麼。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然淨是些不如意的事，",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_048"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但這是陛下親自下的命令。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我克蕾琪塔‧凱許，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "無論如何都會將它完成！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "請您等著我的好消息！！",
        "unit_id": 118011,
        "voice": "vo_adv_7024000_049"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n尤絲蒂亞娜陛下～！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "露娜之塔的調查"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就在克蕾琪塔下定決心的同時拉開了序幕。"
    }
]