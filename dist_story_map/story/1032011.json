[
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了找尋適合公會經營的產品，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "秋乃和{player}\n來到了山腳下的村莊。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "話說，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們今天是為了買進",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n市場上不太常見的稀有蘑菇，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n才特地大老遠地跑來這裡……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "最關鍵的蘑菇",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "竟然一朵也沒有──！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "不好意思啊這位小姐。",
        "unit_id": 511,
        "voice": "vo_adv_1032011_002"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n最近這裡氣候不佳，無法去採集蘑菇。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "不過，",
        "unit_id": 511,
        "voice": "vo_adv_1032011_003"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "這種蘑菇本來就很稀少，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "我也沒辦法向妳保證下次會有。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎、",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎麼會……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……不，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "錯過今天的話，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "暫時就抽不出時間再過來了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n而且我作為商人的直覺，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也告訴我不能錯過這個機會。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對了，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒有的話",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就自己去採集就好啦！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們出發囉，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "這、",
        "unit_id": 511,
        "voice": "vo_adv_1032011_007"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "這可不行！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "那座山上雖然沒有魔物，但很容易迷路。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n外行人隨便進去的話……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "啊，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "喂──！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "快回來啊──！",
        "unit_id": 511
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "──那位村民",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是這麼說的，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "原來如此，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "當地人說的話",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "果然沒錯呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我又",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "學到一課了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "正是如此！",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是抱歉，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這是不能將錯就錯的事呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我自己一個人就算了，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還總是給你添麻煩，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真是對不起……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人……",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那該不會",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是我們要找的蘑菇吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還真是僥倖！",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_012"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這麼快就有收穫了……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "蘑菇會像這樣發光嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀──！",
        "unit_id": 103211
    },
    {
        "type": "still",
        "still": "103201101"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "唉……",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_013"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我又搞砸了。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為了感謝你平時對我的照顧，",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n今天本來要招待你去一個能看見美麗星星的景點，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那個地點位於山中，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "直升機卻只能飛到山腳下……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "儘管如此",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我還是想和你一起看星星，於是爬上了山，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n然而",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還是和往常一樣迷路了。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "本來想說搭直升機就能到，",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也就沒準備登山用的裝備，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n最後腳還痛得不行",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "得讓你背著我。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "唉……",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是丟臉。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n{player}大人，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真的很對不起你……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那、",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_018"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那才不是重點呢！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "重點是我給你添麻煩了啊！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那才是問題所在啊。",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這就代表",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我沒有絲毫成長……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "知道自己是個做事衝動的人，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n也因此常常製造很多麻煩，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我很清楚這點。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以，為了彌補這些缺點，",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我很努力地",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "磨練自己。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "特別是我那異常嚴重的路痴，",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我已經盡力嘗試克服它了……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "然而，",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_023"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "最後卻還是像這樣給你添了麻煩。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真的好丟臉……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……或許吧。",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過，在那天到來之前，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n一定",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還是會重複發生像現在這樣的事。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而你是",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_025"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一定會諒解我的吧。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n但是，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一想到你或許有一天，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "會對這樣的我感到厭煩，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我就",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "忍不住害怕。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……抱歉，",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我變得很懦弱呢。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n明明你也和我一樣難受。",
        "unit_id": 103231
    },
    {
        "type": "still",
        "still": "103201102"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人……",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你真的很溫柔呢。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "決定了！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "離開這裡之後",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要更加努力。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我發誓再也不會犯下這種錯誤了！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這、",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_028"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這麼依賴他人是可以的嗎……？",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我肯定會因為太過逞強，凡是都決定獨自解決，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n至今為止的數次失敗都是這樣來的。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過，",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_029"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "除了你以外，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還有誰會願意",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "幫助我嗎？",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……你這麼說的話，",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就肯定是那樣吧。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n實際上，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你也總是像這樣幫助著我。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我就相信你說的，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "等著那一刻到來吧。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好了，",
        "unit_id": 103231,
        "voice": "vo_adv_1032011_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "到這裡就行了。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "接下來我可以自己走。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們就",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "先來渡過這個難關吧！",
        "unit_id": 103231
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1032011_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是讓人在意的一段內容呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "秋乃給人一種勇往直前，無論何時都不會煩惱的印象，",
        "unit_id": 190011,
        "voice": "vo_adv_1032011_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n竟然也會有那樣消沉的一面呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1032011_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這也難怪。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她也是個正值青春的女孩子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n有煩惱和缺點也是理所當然的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過對秋乃而言，",
        "unit_id": 190011,
        "voice": "vo_adv_1032011_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "遇見你是她的幸運呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她的那一面，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許只有你才見得到吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不論何時，",
        "unit_id": 190011,
        "voice": "vo_adv_1032011_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你都要堅定地站在她那一邊喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見啦──",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗯……",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_037"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "奇怪？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我單手握著蘑菇做什麼？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是討厭，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我竟然在這種地方睡著，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也太不像話了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n而且不知不覺",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就天黑了呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這下真的麻煩了……",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_038"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人，你看。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "星空真漂亮！",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500522"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就在剛才，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_039"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我夢見自己為了看星星而走進山裡。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還是和往常一樣迷了路，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也沒看到星星就是了。",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_040"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你也做了相同的夢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過我也真是的，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_041"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "連在夢裡都能迷路，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "果真是不折不扣的大路痴呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "吶，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_042"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "夢裡的你",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對我說，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n一定會有人願意幫助我……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但真的是這樣嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還是感到很不安……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……能聽見你這句話，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_043"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是太好了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "謝謝你，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣我就放心了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們合力",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "想辦法下山吧──",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "噓，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_044"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "稍微安靜一點，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你沒有聽到什麼聲音嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這個聲音是……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "靠近我們的腳步聲和",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "人聲？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不只是聲音，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_045"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還有光線朝著我們靠近！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是公會的大家！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n因為擔心我們遲遲沒回去，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "她們就跑來找我們了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_046"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就和你說的一樣。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n確實有珍貴的夥伴，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "願意幫助",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如此不可靠的我呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們回到大家身邊吧，",
        "unit_id": 103211,
        "voice": "vo_adv_1032011_047"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n今後也請與",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "公會的夥伴們，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一同多多協助我哦。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "秋乃胸懷對夥伴們的感謝，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "向著她們飛奔而去。"
    }
]