[
    {
        "type": "background",
        "background": "501612"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聽到要舉辦煙火大會的怜和{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了觀看煙火而在晚上來到了海邊──"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真是人山人海呢……",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然有聽說這裡很適合觀看煙火，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不過大家所想的都是一樣的嗎。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不管怎麼看，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "放眼望去都是情侶呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也不是說",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我沒有想到會這樣……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是不管是誰",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都牽著手或勾著手，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那邊的兩個人",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "甚至還摟在一起……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他、",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他們難道不在意周圍的視線嗎？　",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我、",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們兩個，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是不是也牽個手會比較好呢？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可是，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為周圍的人都這樣，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以就順勢而為的話……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔……",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在這種氛圍下，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不知道為什麼總有種很不舒服的感覺。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……這對我來說，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "似乎是有點太過刺激了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "去找個",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "安靜點的地方的確是很好……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不過，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你有想到要去哪裡嗎？",
        "unit_id": 122511
    },
    {
        "type": "background",
        "background": "500287"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在海灘附近",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有這樣的地方啊？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看起來都沒有人在呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "稍微離遠一點就安靜了很多呢。",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼吸起來",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺比剛剛還要輕鬆多了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這說不定是這次度假裡，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n第一次能夠悠閒度過的時間呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺在今天之前，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都一直跟你到處東奔西跑。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的是不管有多少時間都不夠用呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明最一開始的時候，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我還在問說",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該做什麼才好。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在回頭想想簡直是不敢相信。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真虧你能找到這樣的地方呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵……",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確是呢，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就像你說的那樣。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為我們說好了，要過個只有我們兩人的假期嘛。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你看，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "天空中……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有這麼多的星星。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n像這樣的畫面，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該說是夢幻般的景致嗎？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說起來，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "度假村的導覽手冊上，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也有做特集介紹呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "星空和大海的寂靜，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "浪漫的氣氛，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是表白心意的最佳助攻……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "………………",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "星、",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "星空還真是漂亮呢……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "大海也是……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "海浪",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看起來閃閃發光……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真漂亮，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……對、",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n在開始放煙火之前，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我去買些吃的吧？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "等等，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我去買就好……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "人走掉了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這次度假，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你都一直對我很好……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "讓我稍微回報一下也沒有關係吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "老實說……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n能有這樣獨自冷靜的時間真是太好了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒想到",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我居然會不知道該跟他說什麼才好。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明以往都沒有過話講一講突然停下來的狀況。",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為什麼今天，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "卻忍不住沉默了？　",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唉……",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不行。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "腦中盡是浮現一些不必要的雜念。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n怎麼樣都無法靜下心來。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原本還以為自己一個人可以靜一靜的。",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在他回來之前，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "得想想辦法才行……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "咦──？",
        "unit_id": 1111,
        "voice": "vo_adv_1225003_026"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "那邊那位小姐，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "妳自己一個人嗎？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "方便的話，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "要不要去喝點什麼啊？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不用了。",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我正在等人。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "好嘛好嘛，",
        "unit_id": 1111,
        "voice": "vo_adv_1225003_028"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "講話不要這麼冷淡嘛！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "對了，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "帶妳在等的人也跟我一起去怎麼樣？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "我啊，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "知道有個地方",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "能夠更清楚地看到煙火喔。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我完全沒有興趣。",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你的邀請只會造成我的困擾。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "拜託妳啦！",
        "unit_id": 1111,
        "voice": "vo_adv_1225003_030"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n妳聽我說一下話也好吧？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……搞什麼啊，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個男的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我都這樣子拒絕了，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他卻完全沒有打算要走。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來他也沒有想要聽我說的話……",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n再繼續重複這種毫無意義的問答，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我的耐心也快要消磨光了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你再這樣子",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "纏著我的話──",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "啊？",
        "unit_id": 1111,
        "voice": "vo_adv_1225003_034"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "什麼啊這位小兄弟。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n你沒看到",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "我現在正在講重要的事嗎？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "你和這位小姑娘是什麼關係？",
        "unit_id": 1111,
        "voice": "vo_adv_1225003_035"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n如果只是朋友的話，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "可以稍微離遠一點嗎？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……夠了。",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們走吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n跟這種人講話",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也只是浪費時間──",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "重要的人……？",
        "unit_id": 1111,
        "voice": "vo_adv_1225003_037"
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "呿，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "搭訕男子",
        "words": "居然有男伴。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……真是個災難。",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝你。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "給你添麻煩了呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是你沒有過來的話，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我說不定",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已經讓那個男的吃點苦頭了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……你有注意到",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我把手放在劍柄上了，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以也這麼想嗎？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你看到了啊……",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n又讓你操多餘的心了呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以說，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛剛的事……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉。",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然是為了應付那個場面，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n卻害得你說謊了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n什麼重要的人──",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說謊……？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那是……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說……",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是重要的人，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是這麼想的……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是嗎？　",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒事。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他說的是作為夥伴。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "才沒有什麼戀愛方面的意思吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那種事，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在各處景點觀光的時候我早就知道了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n會這樣子想的，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就只有我而已吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "…………可是。",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可是，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為什麼……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的心卻跳個不停呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……你啊，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_050"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "老是說些會讓人誤會的話呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_051"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你一直說那些話……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算是我，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是會不小心就當真呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不知道",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_052"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你是抱著什麼樣的想法，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n而找到這個地方的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是你的那份溫柔將我給帶了出來。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這次的度假……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是從更久以前開始的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……今年",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_053"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個夏天，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是在你的帶領下開始的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果沒有你的話，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是不會過得這麼快樂的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可是，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_054"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "等這次度假結束後……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "又會回到跟往常一樣的生活中吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個夏天，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_055"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是永遠都不會結束就好了呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果沒有任何束縛的這次度假",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_056"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能永遠持續下去的話……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要是能和你一直在一起，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會有多好呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我說。",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_057"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果、",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "假如。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有你在我身邊的話，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_058"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就這個樣子",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一直在一起──",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──我，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_059"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛剛是在說什麼？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n想跟他一直在一起……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想要這樣跟他說……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_060"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是的……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是不想要回去。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n連家裡的瓜葛都能忘掉……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n和他一起度過的這次度假",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "實在是太開心了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_061"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那是因為……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想從纏繞在身上的束縛逃離。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是包含著迷惘和逃避想法的",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沉重情感。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱持著這種心情無法跟他走在相同的道路上。",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_062"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我想要變得更強，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "強到能斬斷迷惘、不再留戀……！　",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣的話，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_063"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "到了那時候……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想我就能開口告訴他了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_064"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在那之前……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要埋藏在我的心裡。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你……",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_065"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛剛那些話你都聽到了嗎？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_066"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "已經沒事了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "大概是被度假的歡樂氛圍影響，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以有點累了吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_067"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總有一天……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n當我能自信地決定自己前進的道路時……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "到時候，",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_068"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果你還願意在我身邊的話……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要是能再跟我說一次你剛剛的回答，我會很開心的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在那一天到來之前……",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_069"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想做一個不會讓你丟臉的人。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是非得這麼做才行。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是",
        "unit_id": 122511,
        "voice": "vo_adv_1225003_070"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了能夠配得上毫不猶豫地對我說……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會跟著我的你。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "將心中埋藏的想法化為動力，怜再次下定了決心。"
    }
]