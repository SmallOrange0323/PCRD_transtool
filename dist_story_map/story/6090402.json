    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "なあオマエ、",
        "unit_id": 106113,
        "voice": "vo_adv_6056402_000"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ネネカ見なかったか？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "アイツってコロコロ変身して、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "すぐ勝手にどっか行くんだよな。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nなんか今回も小難しいこと考えてるみたいだし。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "あんなちっこい見た目してるのにな。",
        "unit_id": 106113,
        "voice": "vo_adv_6056402_001"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "アタシも最初は驚いたぞ！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "変身できるんだし",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "自分の身長でも伸ばせばいいのに……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ってうおおお！？　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ネネカ、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "いつからそこにいたんだ！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "……いや、",
        "unit_id": 106113,
        "voice": "vo_adv_6056402_002"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "さすがに今回はないだろ。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ない……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ないはず……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ないよな？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "でも",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ネネカならありえそうだな、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "うん……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "オマエも気をつけろよな！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nいつどこで何してるか、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "分かんないヤツだからな、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ネネカは！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "まあそうだな。",
        "unit_id": 106113,
        "voice": "vo_adv_6056402_003"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "いつもなに考えてるのか全然分からないけど、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "仲間にいれば頼りになるのは確かだな！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n今回は味方で助かったよ……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "前は色々大変だったんだぞ！？",
        "unit_id": 106113
    }
]