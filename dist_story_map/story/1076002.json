[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後。\n【美食殿堂】一行人依照計畫，\n享受著這趟「迷人的南國之旅」。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "麻、麻煩您了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下說",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「好了」之後，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就請放開手。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可以嗎，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說「好了」之後，……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哈咕！？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇啊，咕嘟咕嘟！？",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主、",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n剛剛的「好了」",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不是真正的「好了」的意思……！？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，",
        "unit_id": 107811,
        "voice": "vo_adv_1076002_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒事吧！？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們在幹嘛啊……？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咳、",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咳、咳！？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海水跑進鼻子裡了，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "刺刺的，好痛！？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗚嗚。",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這附近因為腳還踩得到地，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "本來覺得應該是不會溺水的……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真傷腦筋，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比想像中的還不會游呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然能漂浮在水上，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但因為有波浪沒辦法隨心所欲的行動。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n換氣也很難，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不出幾秒就被水淹沒了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 107811,
        "voice": "vo_adv_1076002_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還以為你們",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是在淺灘玩得很盡興。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……原來你們不會游泳嗎？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉……",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然在下和主人，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了今天一直都在特訓。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不僅研讀了游泳的教學書，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還在床上",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做了踢水練習。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呵。",
        "unit_id": 107811,
        "voice": "vo_adv_1076002_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那樣的行為叫作紙上談兵哦，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "理論和實際是不一樣的。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐所言甚是……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該怎麼辦呢，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果不會游泳的話，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感覺來海邊的樂趣就少一半了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也～是。",
        "unit_id": 107811,
        "voice": "vo_adv_1076002_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……可蘿仔過來，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}也來這邊一下。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可她……",
        "unit_id": 107811,
        "voice": "vo_adv_1076002_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很好，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒意義地精力充沛游去很遠的地方，不在附近呢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯？",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼了嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n照著您的吩咐，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們靠過來了……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 107811,
        "voice": "vo_adv_1076002_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很好很好。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們兩個人，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先不要動哦。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……哈唔？",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您剛剛對我們做了什麼……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 107811,
        "voice": "vo_adv_1076002_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我剛剛施加了一點魔法哦。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這是我自己開發出來的魔法，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "目前還沒正式命名就是了。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是收集海裡面也存在的氧氣……",
        "unit_id": 107811,
        "voice": "vo_adv_1076002_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算跟你們說明理論也聽不懂吧。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果要比喻的話，",
        "unit_id": 107811,
        "voice": "vo_adv_1076002_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是讓人能像魚一樣",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在水裡自由自在移動的魔法～",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那樣的感覺？",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會、",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會變成魚嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n皮膚會被鱗片包覆之類的……？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就說了只是比喻啦。",
        "unit_id": 107811,
        "voice": "vo_adv_1076002_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "百聞不如一見，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就當作被我騙",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "進去大海看看。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那就能理解我指的「像魚一樣」",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是什麼意思囉。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉……",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐說的是，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會相信您並遵從指示做的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔喔……？",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個非常棒呢！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n明明身於海中，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻完全不覺得呼吸困難！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n竟然能夠像踩在陸地上一樣，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在海裡面散步呢！",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐所說的，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來是這個意思……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就像是魚一樣能在水裡四處移動。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在身體周圍",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有用魔法",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "延展出的空氣膜，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n維持這個狀態……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此能夠呼吸，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這樣嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明在水中，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "皮膚卻沒有濕掉的感覺……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n即使張開眼睛，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海水也不會進到眼睛裡。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀呀……",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為只是薄膜，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也會受到水流的影響呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要小心不能離開主人太遠，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "得注意才行。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蹬一下",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海底……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人～",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可可蘿來到您的身邊了♪",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無法出聲呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為在水裡所以也沒辦法，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然很想將",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這份感動分享給主人的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即使不依靠語言，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n用舉止和表情",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好像也能夠交流呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……♪",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們的想法是一樣的呢，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人也希望",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起分享這份感動。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在這個無法傳遞聲音的大海裡，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "希望至少",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能牽著手",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "傳遞些什麼……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如您所願。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n來，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請牽住在下的手。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦……？",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把手伸向了周圍游來游去的魚呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一看到會動的東西就有反應，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n簡直就像是小嬰兒一樣。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓魚逃掉了，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人真是的……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一臉失望的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是不會逃跑的……",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請抓住",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可可蘿的手吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人的手掌，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在海裡也很溫暖。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請看看周圍。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有不曾看過的魚，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "活生生地在眼前游來游去呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "周圍像是",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "五顏六色森林的是，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "珊瑚礁嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼都好繽紛好漂亮……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這樣的美景，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下難以言喻。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能來到海邊真是太好了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對於凱留小姐所施予的神奇魔法，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n得好好道謝呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇哇，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "維持姿勢好難呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像是散步在沒有重力的",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遙遠宇宙中，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n某顆星球上的感覺。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "即使和喪失記憶的主人提到宇宙等等的事物，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可能也不理解",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是什麼意思吧？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為在下的故鄉",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在深山裡……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讀了很多書，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總是一直在幻想呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在我們的頭頂上，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n延伸到",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比在天空還更遙遠的那端，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所謂的大宇宙……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "比陸地廣大好幾倍的大海，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n以及那不為人知的",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "黑暗深海底……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "深山中所沒有的，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這世界裡的神秘事物……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n陌生的人們所居住著的，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各式各樣的國度……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在孤單的夜裡，心中浮現這些畫面，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n天馬行空地想像著，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以此獲得慰藉。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了侍奉主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遠離故鄉……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "見識到了許多，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n比當初所想像",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還要更棒更美好",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的景象。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 107611,
        "voice": "vo_adv_1076002_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然這麼說",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也許會覺得困惑……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過主人，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的謝謝您♪",
        "unit_id": 107611
    }
]