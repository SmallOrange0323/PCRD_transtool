[
    {
        "type": "background",
        "background": "500041"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "似似花和{player}忘卻了時間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n沉浸於撲克牌的樂趣中。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哎呀，",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "已經過掉不少時間了呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n一不小心我竟像個孩子一樣沉迷於打牌。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好啊，",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我正好有點渴了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n請把那邊的玻璃杯拿給……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼回事？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "玻璃杯發出了奇異的光芒……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不明的",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "發光現象……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這還……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "讓人──",
        "unit_id": 115011
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "恭賀新喜，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "新年快樂。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我是來家庭訪問的。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "快點開門。",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n外面十分寒冷呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "戒心",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還真重啊。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這說明你有一定程度的危機意識，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我反倒安心了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "大過年的，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也不打算和你做無謂的鬥爭。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只是來拜個年，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "然後，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "簡單地做個家庭訪問而已。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了你著想，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是別廢話快點把門打開吧？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只要我動動手，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不要說這道門鎖，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要把你家所有東西全打開都不是什麼難事。",
        "unit_id": 107031
    },
    {
        "type": "still",
        "still": "115000401"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呼，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真暖和……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n室內真是舒服多了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "啊，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不需要招待我。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我已經事先確認過",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你父母都不在家了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的到訪讓你很驚訝吧。",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你真的把我說的",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n「在現實見面將會是第一次也是最後一次」",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當真了？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "竟然輕易相信敵人的說詞，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_011"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你真是善良過頭了呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那之後",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在阿斯特朗的戰鬥",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也沒能分出勝負。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所以那次頂多算平手哦、",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "平手。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……你現在心裡應該在想，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我為什麼",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "會來這裡吧？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是愚蠢的問題。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我說過了吧，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只是來做家庭訪問的。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "快去把考試卷和成績單拿來。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n七冠的時間",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可是非常寶貴的。",
        "unit_id": 107031
    },
    {
        "type": "still",
        "still": "115000402"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……嗯，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比我想像中的還差呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所有成績都是中等的中、",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "優良的中。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你都快變成「中等」的化身了呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你最近的考試成績也不太理想……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是沉迷在阿斯特朗的世界裡，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "疏於學習了吧？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是誰的錯呢？",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不會是我的錯吧？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你不是",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也忙著與克莉絲和拉基拉基交手嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n真是的，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "竟然對一個學生這麼過分……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在這種時代還禁止他人玩遊戲",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就太愚蠢了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但請你注意分寸。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再這樣下去，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你能去的大學就所剩無幾了喔。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你有考慮過",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "升學的事嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來是沒考慮過呢。",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這麼重要的事，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你需要謹慎思考才行，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但剩下的時間已經不多了吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "打算繼續升學的話，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在就應該馬上開始備考了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n打算就讀職業學校、",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或是想直接就職，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也需要與父母和班導師商量，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再選擇適合自己的路。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這關乎到你今後的人生，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是非常重要的決定。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還請你別太草率對待。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "才不是「真像」，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我本來就是老師。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "升學的事",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就說到這裡吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你在現實生活中，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有任何不安或是煩惱嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n放眼未來固然重要，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但現下也",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "同樣馬虎不得喔。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若校園生活或健康狀況出現了任何問題，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n都可能影響你的未來。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在我看來……",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你有點",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "遊戲成癮了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "除了遊戲以外，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你在學校裡有朋友嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你是學生，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還是多試著",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "融入校園生活會比較好。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我能理解以遊戲為中心的社交圈很有趣。",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但高中生活，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是只有現在才能體驗的珍貴時光。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你若不好好享受，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "等長大時後悔也來不及了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "接下來，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對了，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是關於健康方面……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在畢竟是寒假期間，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有些不健康的生活作息我就先不追究了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若是懶得在寒冷的冬天運動，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n至少要好好吃三餐。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你吃過年菜了嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那就好，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "每道年菜",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都飽含著各自的寓意。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在吃下它們的同時理解其背後的故事，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也不失為一種學習手段。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你有打算吃七草粥嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這可不好啊。",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "確實，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在充斥著美味食物的現代，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n七草粥或許不算是吸引人的食物。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "據說七草有避邪的功效，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還富含營養價值。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "像你這種年輕人，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "本來就時常飲食不均衡。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不趁這個機會",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好好補充營養，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n可無法成長茁壯喔？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你剛才說的話我就當作沒聽見。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n可不會有第二次機會喔？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "下次再說出這種話，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我會捏造關於你的負面傳聞，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n散播至世界各地，讓你徹底失去在社會上的立足之地。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "知道了嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼有氣無力的？",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_037"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那就再重來一次……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "知道了嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……很好。",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請你今後",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "多加注意。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……話說回來，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你能分別說出「春七草」有哪些嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你在說什麼？",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我什麼也沒聽──",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……唉，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算是七冠，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也奈何不了",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "肉體的生理現象呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們來吃飯吧。",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n廚房",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "稍微借我用一下。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "感到榮幸吧，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "今天就特別",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n讓你嚐嚐我親手做的料理。",
        "unit_id": 107031
    },
    {
        "type": "still",
        "still": "115000403"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……久等了。",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_044"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是七草粥。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還很燙，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請小心慢用。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你的母親",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在網路上訂購了年菜，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n卻唯獨沒有買七草呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以今年",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就由我來做給你吃。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "做菜這種事，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要具備正確的知識與食譜，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n誰都能辦得到。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再怎麼誤會，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也別把我和晶混為一談。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比起這個，味道如何？",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好吃嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是嗎……",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_048"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是太好了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話說回來，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_049"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「七」這個數字",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不僅在日本，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "連在西洋也具有特別的意義。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在你的身邊，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該也存在不少被冠以「七」的事物吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n七曜、",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "七福神、",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "北斗七星、",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "七種工具……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以說，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_051"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "被七冠招待七草粥，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是相當特別的體驗喔。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "感到光榮吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……呵，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然不是。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你覺得我有可能為了講這麼無聊的笑話，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n大費周章地做料理嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你吃了我精心準備的粥，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所以在敗給我之前，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都請無病無災喔。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哎呀，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你這副表情，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是懷疑我在食物裡動了手腳嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "別開玩笑了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "難得的新年，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就算是我",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也想好好放鬆一下呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過……",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "倒也不能說沒有動過",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n想抓住你的胃，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n再把你變成我私有物的念頭。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 107031,
        "voice": "vo_adv_1150004_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我現在要詢問你在校外的交友關係。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我有點在意",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你的女性交友狀況……",
        "unit_id": 107031
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好啦好啦，新年快樂。",
        "unit_id": 190011,
        "voice": "vo_adv_1150004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還有辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真的辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要不是正處於這個時期，",
        "unit_id": 190011,
        "voice": "vo_adv_1150004_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和似似花可是碰不到面的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n機會難得，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我稍微瀏覽了一下情報喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒想到剛過新年就碰上七冠在家門口埋伏，",
        "unit_id": 190011,
        "voice": "vo_adv_1150004_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我都替你捏了把冷汗呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，",
        "unit_id": 190011,
        "voice": "vo_adv_1150004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "似似花到底在盤算著什麼？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n竟然對敵人做出這種雪中送炭的行為……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不太可能是真心當你的老師吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "千萬不能大意，",
        "unit_id": 190011,
        "voice": "vo_adv_1150004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也不能全盤相信她，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但至少以現階段來說，她似乎還沒有害人之心……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或許她背地裡有著什麼陰謀，",
        "unit_id": 190011,
        "voice": "vo_adv_1150004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但至少和你在一起時\n的開心模樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看起來不似作假呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然不知道似似花的企圖，",
        "unit_id": 190011,
        "voice": "vo_adv_1150004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但和她接觸",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也能讓你有所成長。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "把握住這個機會變強，",
        "unit_id": 190011,
        "voice": "vo_adv_1150004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓她大吃一驚吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今年也繼續多多指教啦──",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……剛剛到底",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_065"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "發生了什麼事？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我竟然如此輕易地",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "喪失了行動能力。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你有看到吧？",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_066"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "麻煩和我說明情況。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "是。",
        "unit_id": 1,
        "voice": "vo_adv_1150004_067"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有備份才能防患未然。",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_068"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是理所當然的。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在我們睡著的期間，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有遭受到任何的攻擊、",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n或是",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有任何人前來交涉嗎？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "沒有，",
        "unit_id": 1,
        "voice": "vo_adv_1150004_069"
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "在我的監控範圍中，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花的分身",
        "words": "\n沒有出現任何類似的異狀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣啊。",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_070"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也就是說，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只是單純讓我們睡著而已。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真令人費解……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不對，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果說對方的真實目的不是讓我們睡著，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n而是讓我們做夢呢？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "根據我夢中的情報……",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_071"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我突然出現在你家門口，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "煮了頓飯給你吃。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……什麼啊，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是個意義不明的夢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你也是嗎？",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_072"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "和他人做相同的夢……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很有意思呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這應該和我們的突然昏睡",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有些關聯。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我還是猜不透讓我們做那個夢的目的。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這件事明顯缺乏情報，",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_073"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n再繼續推測下去",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也得不到結論。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話說回來，",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_074"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在夢中，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們吃了某種開運食物呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "把這個夢當作啟示，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n晚餐去吃些吉利的食物吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "恐怕",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_075"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你今年也將面臨殘酷命運，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "絕不可能無病無災吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_076"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你也不能因此停止祈願喔。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "心願",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有時也能顛覆命運。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 115011,
        "voice": "vo_adv_1150004_077"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們走吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n去祈求度過一個無災無難的一年。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人結伴前往因新年而熱鬧的商店街。"
    }
]