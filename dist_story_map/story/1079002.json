        "voice": "vo_adv_1079002_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}──！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你來的正好啊喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "欸，幹嘛逃走啊喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "給我站住喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呵，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "抓到了喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n要是我把手放開你就會逃掉，所以保持這樣和你說喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們一起來找貓形貝殼吧喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真的有啊喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我親眼見過的喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在比起攤位我更想找貓形的貝殼！",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就在剛才來買鯛魚燒的客人，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我看到他戴著有貓型貝殼串在一起的裝飾品呢喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那種貝殼呀",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "聽說可以帶來幸福呢喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不僅是貓的形狀",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還能帶來幸福真是太讚了喵～♪",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哎～呀，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你是逃不掉的喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我是不會放手的喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們一起來找貓形貝殼吧喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我啊，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓生活中充斥著喜愛的東西便是我的信條啊喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而貓形貝殼就是其中之一喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "來吧，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "快一起到海邊找找喵～♪",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "貓形貝殼快出來吧喵～",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我會把你弄的漂漂亮亮的喵～♪",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我也希望{player}可以努力幫忙找找呢喵～",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我的幸福人生就仰賴你了喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "貓形的貝殼……",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "該是把它作成墜飾好呢、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還是胸針比較好呢喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "把貝殼弄到手我的攤位，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "客人們一定會連日擁進，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n搞不好沒多久就能成為有錢人了……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我也會用謝禮好好報答{player}的喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我做的鯛魚燒",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "會特別為你做個優惠的喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊，",
        "unit_id": 211,
        "voice": "vo_adv_1079002_016"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "是鯛魚燒姐姐！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳在這裡做什麼？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哦，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是一直跟我買鯛魚燒的小女孩啊喵！",
