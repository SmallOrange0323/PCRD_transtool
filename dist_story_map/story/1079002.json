    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵啊！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "討厭啊喵──！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "變得濕答答的喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_041"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我討厭水啊喵──！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "毛都糾纏在一起啦喵──！　",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "棘刺蟹",
        "words": "喀擦喀擦──",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
