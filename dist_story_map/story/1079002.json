        "type": "dialogue",
        "name": "？？？",
        "words": "喀擦喀擦──"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "欸！？",
        "unit_id": 211,
        "voice": "vo_adv_1079002_033"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "剛才，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "是不是有聽見什麼聲音……！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "呀啊啊啊啊啊！",
        "unit_id": 211,
        "voice": "vo_adv_1079002_034"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "這是什麼啊！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "明明剛才都還是岩石的啊！",
