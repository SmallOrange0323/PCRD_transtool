    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n還有海膽外殼、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "和珍珠貝……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然都很漂亮也很值錢，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但我只想要那個貓形的貝殼啊喵！",
        "unit_id": 107911
