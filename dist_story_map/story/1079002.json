    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在瑪爾傑海岸熱鬧的海灘開放活動中，\n{player}悠閒地走在沙灘上。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喂──！",
