        "voice": "vo_adv_1079002_037"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "剛才撿到的貝殼不見了……！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "怎麼辦，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "跑到哪裡去了…！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "危險啊喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_038"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這邊交給我，妳先逃開吧喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "棘刺蟹",
        "words": "咕嘟咕嘟咕嘟──",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵啊！？",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_039"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是什麼啊！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "感覺被噴到什麼了喵！",
