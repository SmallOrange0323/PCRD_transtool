    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼……呼……",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_044"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不知不覺",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "魔物就倒下了啊喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "姐姐！",
        "unit_id": 211,
        "voice": "vo_adv_1079002_045"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳沒事吧！？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我沒事的喵。",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_046"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而且，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "貝殼也是",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "安然無恙的喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "哇，",
        "unit_id": 211,
        "voice": "vo_adv_1079002_047"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "好厲害！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳還把掉下的貝殼",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "給撿回來了呢！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "能找到它真是太好了呢，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "姐姐！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_048"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我要把它送給妳喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "咦？",
        "unit_id": 211,
        "voice": "vo_adv_1079002_049"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "但是……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "這不就是姐姐很想要的貝殼嗎……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我不會介意的喵。",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_050"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為最初撿到的人是妳呀。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只要帶著這個，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳就會變得幸福起來了喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊，",
        "unit_id": 211,
        "voice": "vo_adv_1079002_051"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝妳……",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "真的是非常可愛的貝殼呢。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我要拿去給媽媽瞧瞧！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "那就再見囉，姐姐！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_052"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要再過來攤位這邊玩啊喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "囉嗦喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_053"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "貝殼我再去找就好了喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我、",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_054"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我才沒有哭呢喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這不過是、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "泡泡跑進眼睛裡去了而已喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "都給那孩子留下可怕的回憶了，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_055"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以這樣就好喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "況且，",
        "unit_id": 107911,
        "voice": "vo_adv_1079002_056"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那孩子還會過來買鯛魚燒的，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這樣我也會很高興喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然把非常想要的貝殼給送了出去，\n珠希還是依然一臉滿足的樣子笑了起來。"
    }
