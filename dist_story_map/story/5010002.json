    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人，看著參拜的客人們，\n把紙投入在神殿準備的篝火中。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚呀！",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　妳看看，怜！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n來參拜的隊伍已經排得這麼長了！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "上一次來這裡，好像是小時候的事了吧。",
        "unit_id": 108911,
        "voice": "vo_adv_5010002_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒想到竟然會有這麼多人來。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "除夕連街道都變得很安靜呢。",
        "unit_id": 108811,
        "voice": "vo_adv_5010002_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n為了準備新年，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "很多店家都休息了。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還聽說",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "出現了扒手和順手牽羊的災情唷。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不只要淨化願望，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "遇到有困難的人也得幫助他們才行呢！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊。",
        "unit_id": 108911,
        "voice": "vo_adv_5010002_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過呢，日和……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊一二，",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "三四，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "五六，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "七八……！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "二二！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　三四！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　五六！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　七八！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和。",
        "unit_id": 108911,
        "voice": "vo_adv_5010002_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可以打擾一下嗎？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯？",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　什麼什麼，怜？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　該不會已經找到有困難的人了！？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是的。",
        "unit_id": 108911,
        "voice": "vo_adv_5010002_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在先冷靜下來。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n像這樣太亢奮的話，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "連我們也會靜不下來的……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呵呵，",
        "unit_id": 108811,
        "voice": "vo_adv_5010002_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜也是沒多久前就開始坐立難安了呢。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是但是！",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　如果發生什麼事的話想馬上飛奔過去！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為不知道何時何地會有誰發生了什麼事嘛！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然是這樣說……",
        "unit_id": 108911,
        "voice": "vo_adv_5010002_011"
    },
    {
        "type": "dialogue",
        "name": "小孩的聲音",
        "words": "嗚哇啊啊啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_5010002_012"
    },
    {
        "type": "dialogue",
        "name": "小孩的聲音",
        "words": "　媽媽！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩的聲音",
        "words": "　爸爸！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有聽到剛才的聲音嗎！？",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　有人在哭泣！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "得去幫忙才行！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊！",
        "unit_id": 108811,
        "voice": "vo_adv_5010002_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "　日和！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們也一起去吧！",
        "unit_id": 108911,
        "voice": "vo_adv_5010002_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該不會，",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "願望已經實體化了也說不定！",
        "unit_id": 108911
    },
    {
        "type": "background",
        "background": "500560"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和！",
        "unit_id": 108811,
        "voice": "vo_adv_5010002_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "　在哪―？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和——！",
        "unit_id": 108911,
        "voice": "vo_adv_5010002_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "　妳在哪裡——？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣、怜——！",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　騎士先生！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這裡這裡！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　在哭的，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就是這孩子——！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "爸爸、",
        "unit_id": 111,
        "voice": "vo_adv_5010002_019"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "媽媽……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚嗚……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是迷路的小孩啊……",
        "unit_id": 108911,
        "voice": "vo_adv_5010002_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是實體化的願望呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "得快點幫他找到父母……",
        "unit_id": 108811,
        "voice": "vo_adv_5010002_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對啊！",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我去找！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那個，",
        "unit_id": 611,
        "voice": "vo_adv_5010002_023"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "不好意思。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是神殿的人嗎？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對！　沒錯！",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_024"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "巫女在嗎？",
        "unit_id": 1011,
        "voice": "vo_adv_5010002_025"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "　",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "不好意思——。有沒有人送遺失物過來？",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n是御守，她不小心弄丟的。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡沒有收到遺失物的通知唷。",
        "unit_id": 108911,
        "voice": "vo_adv_5010002_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有我們並不是巫女――",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "真傷腦筋……",
        "unit_id": 1011,
        "voice": "vo_adv_5010002_027"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "因為是兩個人一起買的成對護符，",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n所以想幫她找到呢。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "應該掉在這附近才對……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果是這種事的話，我可以幫你唷。",
        "unit_id": 108911,
        "voice": "vo_adv_5010002_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉，日和。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那邊就交給妳了。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "知道了！ ",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_029"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那個……",
        "unit_id": 611,
        "voice": "vo_adv_5010002_030"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和！",
        "unit_id": 108811,
        "voice": "vo_adv_5010002_031"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "老婆婆就交給我。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n這孩子就麻煩妳了。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣，謝謝妳！",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好——，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "去尋找爸爸和媽媽囉——！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喔喔找到了找到了！",
        "unit_id": 811,
        "voice": "vo_adv_5010002_033"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "　你就是神殿的巫女嗎？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "和伙伴走散了很頭痛呢。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可以幫我們嗎？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個，我不是巫女〜――",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_035"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　該不會這樣下去，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n會變得誰也幫不了……！？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "吶，拜託啦。",
        "unit_id": 811,
        "voice": "vo_adv_5010002_036"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "一下下就好，幫我啦！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "姐姐……",
        "unit_id": 111,
        "voice": "vo_adv_5010002_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊！",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_038"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　真抱歉！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會幫你找到爸爸和媽媽！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎、",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_039"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼辦，騎士先生！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n大家都遇到麻煩了！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣啊！",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_040"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　就是這樣！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好主意！　",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那個！",
        "unit_id": 108711,
        "voice": "vo_adv_5010002_041"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　如果附近有人遇到困難，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n請幫助他！",
        "unit_id": 108711
    },
    {
