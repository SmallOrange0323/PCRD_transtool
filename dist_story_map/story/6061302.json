[
    {
        "type": "background",
        "background": "501240"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉……",
        "unit_id": 115911,
        "voice": "vo_adv_6061302_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就算是在貴族的宅邸工作，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n為何要穿這種輕飄飄的禮服啊。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有、",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "有夠難為情的……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是、",
        "unit_id": 115911,
        "voice": "vo_adv_6061302_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是嗎？",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "聽你這麼說，讓我覺得安心不少。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n好，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "現在說再多也無濟於事，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "無論是穿什麼",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "，我都會做好自己的工作！",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，",
        "unit_id": 115911,
        "voice": "vo_adv_6061302_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "關於這件事我完全沒有異議。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主她",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真的很厲害。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過啊──",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼是禮服……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n她很會抓住機會來展現自己的興趣呢，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你、",
        "unit_id": 115911,
        "voice": "vo_adv_6061302_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你老是馬上就說出這種話……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你也不是那種會說客套話的傢伙。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那、",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那就先跟你道聲謝……",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "謝謝你了。",
        "unit_id": 115911
    }
]