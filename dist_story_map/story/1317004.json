[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "愛梅斯和{player}在夢中被賦予了各式各樣的任務。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但兩人無視了那些，在海邊悠閒地度過。"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呼～",
        "unit_id": 131711,
        "voice": "vo_adv_1317004_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……差不多是她進行下一個行動的時候了吧。",
        "unit_id": 131711,
        "voice": "vo_adv_1317004_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "涅比亞最討厭被無視了，",
        "unit_id": 131711,
        "voice": "vo_adv_1317004_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "像這樣對她置之不理，她會受不了",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "的吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看吧，",
        "unit_id": 131711,
        "voice": "vo_adv_1317004_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "果然。",
        "unit_id": 131711
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這次是什麼啦？",
        "unit_id": 1,
        "voice": "vo_adv_1317004_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n……啊？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咖啡廳和",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "高樓大廈……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡",
        "unit_id": 1,
        "voice": "vo_adv_1317004_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不就是「那邊的世界」嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "涅比亞那傢伙，",
        "unit_id": 1,
        "voice": "vo_adv_1317004_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是出於什麼打算才做這種……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怎樣啦？",
        "unit_id": 1,
        "voice": "vo_adv_1317004_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "一直盯著這邊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我有點難為情耶。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我有什麼──",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_008"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "──咦？",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_009"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "這是怎樣！",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_010"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n誒，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "原本的",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我……！？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "涅比亞",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_011"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "那傢伙～～～～～！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "給我擅自亂用我的模型資料，",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_012"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n就算是在假想空間裡也惡作劇過頭了啦，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "真是的……！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……對，",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_013"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "沒錯喔，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n這就是原本的我。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "「你終於醒來了！",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_014"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我是妖精菲歐。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我會告訴你阿斯特朗的各種事的，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "要仔細聽喔！」",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……開玩笑的",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_015"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "啦。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "不過話說回來……",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_016"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "好強烈的違和感啊，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n我竟然會在這個世界裡。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "這是絕對……",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_017"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "不可能的光景呢。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "那是當然啊，",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_018"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "因為",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "「那邊的世界」裡並沒有我的存在。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n我",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "只能存在於資料中。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "啊啊，",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_019"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "如果像晶和小可可蘿所做的，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n進到義體之中的話，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "好像就有可能呢？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "不過，",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_020"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "做那種事是沒有意義的。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n因為我是嚮導小妖精，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n是為了介紹阿斯特朗而存在的。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……不過，",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_021"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "機會難得，稍微走一下吧。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n因為我在飛，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "所以會動到腳的只有你就是了♪",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "嗯～",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_022"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n就我稍微四處看一下的感覺，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "沒有半個人在。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "而且，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "似乎有很多限制呢。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "你看，",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_023"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "有像是看不見的牆壁一樣的東西吧？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n是沒辦法隨意繞路的",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "刻意設計。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "總之，",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_024"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "只朝著可以前進的方向前進吧。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "要緊跟著我喔♪",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_025"
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "好了……",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_026"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "可以正常地來到車站呢。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "也就是說，大概……",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "啊啊，果然。",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_027"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n正好有電車停靠。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "是要我們搭這個吧。",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_028"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "電車啊……",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "其實我有點想搭搭看呢。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "啊！",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_029"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "有在賣車站便當嗎？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n搭電車的時候果然要買車站便當吧？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "啊啊，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "沒人的話就沒辦法買啊，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "真可惜。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "那麼，",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_030"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "重振精神，出發前進♪",
        "unit_id": 134011
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "──來到海邊了呢。",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_031"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "是要我們在這邊做什麼嗎？",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_032"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……嗯？",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_033"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n那邊，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "沙灘裡埋著什麼？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "這是……",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_034"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "寶箱？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n這裡是終點",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "的意思嗎？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "都耍我們到這種地步了，",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_035"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n要是裡面沒有裝相應的東西，我可不會原諒她喔。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "{player}，打開吧。",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_036"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "妖精的……",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_037"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "泳裝？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "該不會",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_038"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "是要我穿這個吧！？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "別開玩笑了！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n我絕對不會穿的！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "「不穿就出不去喔～♪」",
        "unit_id": 190911,
        "voice": "vo_adv_1317004_039"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "那傢伙～～～～～！",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_040"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_041"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "沒辦法，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n只能穿了啊。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "欸，{player}，",
        "unit_id": 134011,
        "voice": "vo_adv_1317004_042"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n你就這樣把泳裝放在雙手中，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "然後把眼睛閉起來。",
