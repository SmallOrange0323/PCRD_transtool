[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚哇，",
        "unit_id": 106011,
        "voice": "vo_adv_9016155_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這氛圍好像有點不妙……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誰叫妳沒事發出那麼大的聲響",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才把牠吵醒的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原本想說現在是冬眠的時期，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該可以輕鬆取勝才對啊——！！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "冬眠中的野獸被叫醒時，",
        "unit_id": 105911,
        "voice": "vo_adv_9016155_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會因為飢餓加上警戒心的關係更加暴躁，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎會比平常更加倍危險的樣子。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不曉得牠會有什麼舉動，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您小心。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105811,
        "voice": "vo_adv_9016155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像還在睡昏頭的樣子喲？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "趁牠動作還很遲鈍的時候",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "解決掉吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n喝啊啊",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊啊啊―――！！！",
        "unit_id": 105811
    }
]