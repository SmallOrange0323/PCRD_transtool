[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了陪伴千歌進行現場演唱的練習，\n{player}正在等著跟千歌碰面。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你好。",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n時間剛剛好呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，我們出發吧。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "果然在有人煙的地方練習，我還是會覺得害羞……",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們去平常去的森林吧。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "雖然可能會出現魔物，",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但跟你在一起的話，我一定能好好對付牠們的。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只要跟你在一起，",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n令人恐懼的事物就會消失無蹤……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊，沒什麼，什麼事都沒有。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那麼，我們趕快去練習吧。",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……你、",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你覺得如何呢？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯……我自己也覺得唱得不太好。",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不知道為什麼，我覺得自己好像被很多人看著……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很奇怪對吧？",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這裡應該只有你在而已啊……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "儘管如此，我卻感受到像是他人視線般的氣息……",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有如在大家面前唱歌時一樣……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀啊啊啊啊啊！",
        "voice": "vo_adv_1042003_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是、是魔、魔物啊──！！"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不是只有……魔物的聲音……！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "剛剛我們確實聽到了慘叫聲吧！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們趕快去救他們吧！",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n聲音是從那邊傳來的！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們還好嗎――！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_012"
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "──千、",
        "unit_id": 1411,
        "voice": "vo_adv_1042003_013"
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "千歌……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "那個，我、我們是千歌的粉絲……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "\n因為聽說了妳似乎在森林中練習的傳聞……所以就……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我的粉絲……？",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們是為了我，所以才來到這樣的森林深處……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "對、對不起！",
        "unit_id": 311,
        "voice": "vo_adv_1042003_015"
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "\n我們雖然知道會很危險，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "但沒想到真的有魔物出現……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "咿咿咿咿咿咿！",
        "unit_id": 1411,
        "voice": "vo_adv_1042003_016"
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有話等等再說吧。請大家退到後面去！",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_017"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n首要之務是先把魔物給打倒！",
        "unit_id": 104211
    },
    {
        "type": "still",
        "still": "104200101"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "{player}，我現在要來唱喚精靈，",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_018"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你幫忙轉移魔物的注意。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n拜託你了！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "精靈",
        "words": "──！"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呼……",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_019"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總算是打敗牠們了呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "我、",
        "unit_id": 311,
        "voice": "vo_adv_1042003_020"
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "我們得救了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "千歌，謝謝妳！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "\n妳戰鬥的樣子也非常帥氣喔！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…………",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_021"
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "咦、咦？千歌……？",
        "unit_id": 1411,
        "voice": "vo_adv_1042003_022"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "請你們不要做出這麼危險的事情……！",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_023"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "在這附近，真的經常有魔物出現。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n而你們卻什麼武器都沒帶就跑進森林裡……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果大家發生了什麼事情的話，",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_024"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "千、千歌……對不起啊。",
        "unit_id": 1411,
        "voice": "vo_adv_1042003_025"
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "我們太不小心了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……你們有在反省的話，那就好了。",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_026"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你們說你們是我的粉絲，",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_027"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n而且還說想聽我唱歌，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n這讓我非常的高興。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你們。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……剛剛我一時慌了手腳，真是不好意思。",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_028"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n不過，真的發生了什麼事的話就太遲了……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就請你們今後不要再做出這麼危險的事情囉。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "……當、",
        "unit_id": 1411,
        "voice": "vo_adv_1042003_029"
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "當然啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "\n我們跟妳約定好！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "妳竟然會這麼擔心我們……！",
        "unit_id": 311,
        "voice": "vo_adv_1042003_030"
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "果然千歌最棒了！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "我們會一直支持千歌的喔……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你們。",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_031"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這裡可能還會有魔物出現，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們回去城鎮上吧。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "那個……話說，那邊那位像騎士的人是誰？",
        "unit_id": 1411,
        "voice": "vo_adv_1042003_032"
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "該、",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "親衛隊長",
        "words": "該不會……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "對、對！他是我們的經紀人！",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_033"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "像今天這樣去城鎮外練習時，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我也會請他做我的護衛喔？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯、",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_034"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯嗯！就是這樣！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我有請護衛好好地跟著我並保護我。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "原來是這樣啊……",
        "unit_id": 311,
        "voice": "vo_adv_1042003_035"
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "親衛隊員",
        "words": "下次我們再來看妳練習時，也會請人當我們的護衛喔！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個……可以的話，請你們不要公開我在練習的事情……",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_036"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "總之今天就告一段落，我們回城鎮去吧。",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今天真是謝謝你了。 ",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_037"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n沒有人受傷，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "真是太好了……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是，這也只是結果論呀。",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_038"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n實際上因為我，害我的粉絲們陷入危險了……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我明明是身處要保護大家的立場……",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_039"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "發生這種事情可是不行的呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是，要我在城鎮內練習……",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_040"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我還不太習慣在別人面前唱歌。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……你說自信嗎？",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_041"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "的確，要在粉絲們面前唱歌的話，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n必須要相信自己跟自己的歌聲呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……說的也是呢。",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_042"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今後，我的歌聲會傳達給更多的人。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果總是這樣自己一個人獨唱的話，是改變不了什麼的呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……在森林裡的練習，就這樣結束吧。",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_043"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如果像今天這樣，粉絲也跟過來的話就危險了。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為了讓自己更有自信，我得習慣在大眾面前唱歌才行。",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_044"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "今後，我想開始進行為達成此目標的練習。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只要這世上，有任何一個人喜歡我的歌聲……",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_045"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……為了報答像這樣的人，今後我也會繼續唱下去。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "咦……咦咦！？",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_046"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "喜、喜喜、喜歡……！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……是指我唱的歌嗎？",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_047"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "說、說的也是呢！你是在說唱歌的事情吧！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……嚇我一跳……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "謝謝你喜歡聽我唱歌。",
        "unit_id": 104211,
        "voice": "vo_adv_1042003_048"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……可是，為什麼呢？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我覺得有一點遺憾呢……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌不曉得理由，\n但心中感到莫名的失落。"
    }
]