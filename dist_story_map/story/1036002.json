    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好～要開始找囉──！",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n妳們兩人都做好心理準……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "哇啊！",
