    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "好～那麼我要開始找囉──！",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "做好心理準備喔……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "嗯？咦？怎麼感覺聽到聲音好像，",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n就在旁邊呢……？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……所以說，為什麼沒去躲起來而在這呢！？",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不是說，想要一起玩躲貓貓的嗎？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咦？",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n想要幫當鬼的我的忙？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不、不行啦！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你、你到底在說什麼呀！？",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "躲貓貓，不是那種戰鬥啦……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "說什麼好可憐……",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且美美跟禊都在這，我才不是一個人呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這個人的溫柔，怎麼總是少了根筋呢……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "聽好了喔？",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n玩躲貓貓，當鬼的就只能有一個人而已。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n如果有兩個人當鬼，就太卑鄙了呢。",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……可是躲的人也有兩個人？所以這樣並不卑鄙？",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "問、問題不是出在那……",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n躲貓貓，就是一個鬼必須同時面對很多人的遊戲……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就算是說，即使是要1對2，",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "或1對3，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "甚至是1對100也好，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n躲貓貓的鬼就是需要一個人戰鬥……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這、這麼聽起來，好像真有一點不公平呢。",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？兩個人來當鬼也沒關係嗎？",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這不是當然不行的嗎──！！",
        "unit_id": 100411,
        "voice": "vo_adv_1036002_029"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "鏡華！不可以一個人偷偷霸佔著哥哥哦～！",
        "unit_id": 102011,
        "voice": "vo_adv_1036002_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "美美！禊！",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳們全都聽到了嗎！？",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！",
        "unit_id": 100411,
        "voice": "vo_adv_1036002_032"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這邊有個絕對不會被找到的地點唷！　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這次特別告訴你！快點快點～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "不～行～啦！",
        "unit_id": 102011,
        "voice": "vo_adv_1036002_033"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥是要和美美躲在一起的啦～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "妳、妳們兩個，也隨便就跑出來了！",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_034"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那怎麼還算是在玩躲貓貓呀！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "這全都是{player}的錯喔！",
        "unit_id": 103611,
        "voice": "vo_adv_1036002_035"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "每當只要和{player}一起，總是不自覺地被會牽著鼻子走。\n怎麼也想不透為什麼會這樣的鏡華，不禁大嘆了一口氣。"
    }
