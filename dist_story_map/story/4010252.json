    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今天也辛苦你來鯛魚燒店幫忙喵～",
        "unit_id": 104632,
        "voice": "vo_adv_4010252_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n只要有{player}在，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n對接客和開發新口味鯛魚燒都有所幫助喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 104632,
        "voice": "vo_adv_4010252_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你最近經常來幫忙，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n是有什麼想要的東西喵？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是這樣喵？",
        "unit_id": 104632,
        "voice": "vo_adv_4010252_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有買到想要的東西真是太好了喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n一口氣把工作賺來的錢",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "花完的瞬間",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "特別痛快喵～♪",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……喵？",
        "unit_id": 104632,
        "voice": "vo_adv_4010252_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n要送我禮物",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "該不會是",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為了這個",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "才工作喵……？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而且",
        "unit_id": 104632,
        "voice": "vo_adv_4010252_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是……！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n坊間流傳的",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "「貓咪一躺就廢坐墊」喵！？",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "據說軟綿綿的，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就算買給自己用，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "也會被貓咪搶走，根本坐不到……！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊……",
        "unit_id": 104632,
        "voice": "vo_adv_4010252_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "太感謝了喵～～～～～～～！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n雖然收到坐墊也很開心，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n但你為了我工作這點，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓我超級開心喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為……",
        "unit_id": 104632,
        "voice": "vo_adv_4010252_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我在旁邊一直看著喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你沒有偷懶，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一直很努力地",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n和我一起經營鯛魚燒店喵……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……感覺",
        "unit_id": 104632,
        "voice": "vo_adv_4010252_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "收到了兩份禮物喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對了喵！",
        "unit_id": 104632,
        "voice": "vo_adv_4010252_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我馬上來試試坐墊坐起來的感覺喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "來吧，",
        "unit_id": 104632,
        "voice": "vo_adv_4010252_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}也一起坐喵！",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不靠近一點的話，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "會坐不下的喵。",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n……",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈，",
        "unit_id": 104632
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好舒服喵～♪",
