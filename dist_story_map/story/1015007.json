[
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與美里一起來到了精靈之森野餐。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，天氣真好♪",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n今天是絕佳的野餐天氣呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "偶爾像這樣兩人悠悠哉哉的也很好呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊，對了對了，最近總是受你照顧，",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就當作是回禮吧，今天做了便當帶來呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如果合你胃口的話就好了……嗯，就在這邊野餐吧。",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵……這裡，還記得嗎？",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n老師和你初次見面的地方。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我發現了吃下毒蘑菇而倒在地上的你……",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n真令人懷念啊。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，不客氣──",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也是啊，因為麻痺而變得動彈不得呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那時我真的很擔心啊～",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n可不能再隨便撿東西來吃了唷～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵♪\n來，為了不要因為肚子餓又跑去吃蘑菇，",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n快來吃便當吧～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "放了很多{player}喜歡吃的東西進去，",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n盡量多吃一點哦ー",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好的，那麼雙手合十，我開動──",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_011"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，是小魔物……！",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n嚇了老師一跳呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？相當溫和的孩子呢……怎麼了嗎？",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀……這樣的話，稍微分一點便當給你吧。",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好的，請好好享用♪",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嚼嚼！嚼嚼！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，吃的很美味的樣子呢～",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n肚子真的餓了吧。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，呵呵呵呵。什麼？想要我摸摸你嗎？",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真可愛的孩子呢。好乖好乖……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀，已經吃飽了嗎──？",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，回家路上小心喔～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "話雖如此，你還真能看出牠的肚子餓了呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n好厲害啊～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦？和老師一起相處的過程中，",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你也變得能夠",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "猜想出別人的需求了？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，老師只是因為，想為這孩子做些什麼，",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n抱著這樣的心情與大家來往而已喔～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，總覺得好害羞啊～",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來，",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "重新打起精神，來吃便當吧。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n雙手合十，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我開動了──",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來，",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊──",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……呵呵，好吃嗎？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "合你胃口真是太好了。還有很多唷～",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_024"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也要乖乖的吃蔬菜唷。呵呵呵，了不起了不起。",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_025"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，臉上沾著飯飯呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_026"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，老師幫你吃掉吧～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "吃了好多啊～",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_027"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n果然是食慾旺盛的時期呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好的，粗茶淡飯不用客氣♪",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_028"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？怎麼了呢，打呵欠了？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，吃了很多所以瞌睡蟲上身了？",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_029"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n沒關係唷──因為今天是悠悠哉哉的一天……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好了，",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_030"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "快來躺老師的膝枕吧？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好的，真乖真乖……晚安～",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_031"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n老師會幫你看顧著的喔。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，已經睡著了……睡臉真可愛呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_032"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……你真的成長了呢。剛剛的事也好，上次的事也是。",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_033"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n雖然從相遇那時就一直是個溫柔的孩子……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但你也變成了相當可靠的男人……",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_034"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "現在就算老師不在身邊，也沒問題了吧。",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_035"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……呵呵呵，總覺得有些寂寞呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "得讓孩子獨立才行……不對。已經不是小孩子了呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_036"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……老師啊，對你……",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_037"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不行呢，我真是的……在他睡著的時候……",
        "unit_id": 101511,
        "voice": "vo_adv_1015007_038"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這種事情，要在醒著的時候好好傳達才行呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "微笑的美里以及在美里腿上熟睡的{player}，\n舒爽的氛圍下，森林的寂靜將兩人包圍。"
    }
]