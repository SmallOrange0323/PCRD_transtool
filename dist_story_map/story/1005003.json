[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嚕啦啦～♪",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n嚕啦啦～♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呵呵呵♪",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n所謂雀躍不已，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "指的就是這種情況吧！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊～",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "腳好像沒有踩在地面一樣！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n難道說，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我現在在用尾巴走路是嗎～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n開～玩笑的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……哎呀，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不小心又說錯話了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n把嘴巴",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "拉上拉鍊！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "自己是獸人的這件事，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不可以讓任何人知道！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "畢竟【王宮騎士團】在歷史上，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_005"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n一～直都和獸人處於敵對狀態呢……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n雖然我不知道其中的理由是什麼就是了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我光是",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "為了以見習身分進入【王宮騎士團】、\n就已經付出了",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不少的心力了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n用帽子藏住耳朵、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "堅稱尾巴",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "只是裝飾品。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然只是這麼做，\n就能普通地成為見習生這一點真是不可思議。",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_007"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_008"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也沒有接受身體檢查之類的……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大概是在入團測驗時，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我把自己的熱情，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n傳達給面試官的純了吧？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但是，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "大意可是禁忌。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "要是被發現我是獸人的話，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n說不定還會被趕出騎士團。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "畢竟可是敵對種族呢～",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真面目曝光的話就毫無立場了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我已經很習慣這裡了，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_011"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n在團員中，像是小智姐……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "關係變好的人",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "也增加了許多。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "事到如今，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "絕對不想被趕出去。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "絕對",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_012"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "絕對",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "絕對，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不可以被任何人發現我是獸人！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……嗯？",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_013"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n前面好像，聚集了好多人！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯嗯～？",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_014"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n真在意，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "難道是在表演什麼節目嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我身高",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "太矮了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "被人牆擋著什麼都看不見！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……嗚哇哇！？",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_015"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊啊，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嚇了我一跳！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_016"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是{player}！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "哈囉～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好久不見了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……呃，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_017"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在不是打招呼的時候了，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你突然把我抱起來讓我很困擾呢。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還以為是綁架犯什麼的，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_018"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n希望你",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "至少跟我說一聲啦。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "被嚇一跳以後，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_019"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n好像又要腳軟了～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_020"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你能夠",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "把我抱起來真是幫大忙了。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這樣就能夠看見人牆的另一側了～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呵呵♪",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "呦呦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_021"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "果然是在表演節目耶？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "看起來，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是穿著玩偶裝的人在戰鬥！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔哦哦♪",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_022"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "難道是在表演，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我最喜歡的英雄秀嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "……嗯～？",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_023"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不過，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "看起來好像又不太像耶？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "聚集的觀眾都是女孩子，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_024"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n而且也沒看到看起來像英雄的人！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊…",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_025"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "看起來，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n好像是「魔法少女鈴鈴噹」的秀呢……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "什麼嘛～",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_026"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "原來是女孩子喜歡的東西啊。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "英雄和魔法少女，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是相似卻不同的東西哦。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔？",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_027"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "才不是啦～",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n你不懂嗎～？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "魔法少女",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_028"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "是什麼愛啊溫柔的，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "英雄則是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "正義和勇氣！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_029"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你不知道哪裡不一樣嗎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你說兩邊都會變身、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "和壞人戰鬥，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n而且也很受小孩子歡迎？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔嗯～？",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_030"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我也",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒辦法說明得很清楚！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "但就是哪裡不一樣。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦，",
        "unit_id": 100511,
        "voice": "vo_adv_1005003_031"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "話是這麼說沒錯啦。",
        "unit_id": 100511
