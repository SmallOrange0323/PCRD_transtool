[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}正和鈴奈碰面……"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈嚕～",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "抱歉，突然叫你出來。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家有點事想跟秀才商量。",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "其實……",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n最近，人家的舞台服裝常常被偷走呢～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "稍微一不注意，",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n就從包包裡面不見了～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你說是不是人家搞錯了？",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家一開始也是這麼想。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是已經不見好幾次了，果然很奇怪。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家正想著要跟誰商量一下的時候，",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "腦海中就浮現出了秀才的臉喔。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "畢竟果然還是秀才可靠。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你能幫人家抓到小偷嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "拜託！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的嗎！？ ",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "太好了～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不愧是秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼可以立刻跟人家來嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今天有時裝秀。",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家覺得犯人大概也會來，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n所以秀才也一起監視吧。",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好了，時裝秀也結束了，",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n服裝也事先放在容易看見的地方了～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "接著只要等犯人來就可以了吧？",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈，感覺好像偵探，",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n好興奮喔？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超有趣～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸～！",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n因為和秀才在一起的話，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不管做什麼事都會變得有趣嘛～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對吧！",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家只要跟秀才在一起，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不管做什麼都很開心喔～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？好像有動靜？",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊！人家放行李的地方，有人在那邊！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那個人手上拿著的，不就是人家的舞台服裝嗎！",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也就是說，那個人就是犯人！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，要被她跑了！？",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，捉住她！",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "咦？",
        "unit_id": 411,
        "voice": "vo_adv_1016006_018"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n有什麼事嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還敢問有什麼事！",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家現在很生氣～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "妳偷人家的服裝，究竟想做什麼？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "偷？",
        "unit_id": 411,
        "voice": "vo_adv_1016006_020"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "鈴奈小姐，妳究竟在說什麼？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "妳怎麼會知道人家的名字……",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "等等，妳不是事務所的工作人員嗎！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以工作人員是小偷？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這……是在說什麼呢？",
        "unit_id": 411,
        "voice": "vo_adv_1016006_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家當然是在說最近舞台服裝被偷的事情啊？",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n是妳偷走的對吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "唉……真是有鈴奈小姐風格的誤會呢。",
        "unit_id": 411,
        "voice": "vo_adv_1016006_024"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這不是偷，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n是要拿回事務所清洗的。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "一直以來不都是這樣做的嗎？",
        "unit_id": 411,
        "voice": "vo_adv_1016006_025"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳都沒注意到？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這、這麼說來……",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家的確是有想過",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "「不知不覺就被洗好了呢」……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃……",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n……很抱歉誤會妳，說妳是小偷。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然現在才說有點晚，不過謝謝妳一直以來都幫人家洗衣服。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不客氣。",
        "unit_id": 411,
        "voice": "vo_adv_1016006_028"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "……啊，不過鈴奈小姐，請至少把內衣帶回去。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳的內衣經常就這樣放著跟服裝混在一起喔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "騙人！？真的假的！？",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_029"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "真的。",
        "unit_id": 411,
        "voice": "vo_adv_1016006_030"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "看吧，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳今天也忘了這件。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哇！？ ",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "等一下等一下！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才也在這裡！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不要把它攤開～！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才也不要看啊～！！",
        "unit_id": 101611,
        "voice": "vo_adv_1016006_032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鈴奈出了大糗，\n這或許正是誤會別人的懲罰吧。"
    }
]