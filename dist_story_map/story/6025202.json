    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "在城鎮各處",
        "unit_id": 111111,
        "voice": "vo_adv_6025202_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "對不同的人惡作劇，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n會鬧得沸沸揚揚的呢……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為平常",
        "unit_id": 111111,
        "voice": "vo_adv_6025202_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "總是只被禊惡作劇呢。",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你的從容態度……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "說不定我還滿想學習的。",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "的確可能是如此。",
        "unit_id": 111111,
        "voice": "vo_adv_6025202_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果不好好享受",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就太吃虧了呢。",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是，",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要做什麼惡作劇才好？",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "去問問禊吧……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你、",
        "unit_id": 111111,
        "voice": "vo_adv_6025202_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你到底在說什麼呀！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不可以那樣做！",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你想被當成可疑人士嗎！？",
        "unit_id": 111111
    }
]