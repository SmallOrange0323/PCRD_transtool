[
    {
        "type": "background",
        "background": "501450"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "虐待狂先生，",
        "unit_id": 104512,
        "voice": "vo_adv_6078203_000"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "這個據點的名稱，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "伊緒老師想取叫「祕密的校舍」，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n靜流則說",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "「姐姐與弟弟的愛之巢穴」比較好。",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "但是空花覺得",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "「高深莫測被虐狂之館」比較好！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "你覺得怎樣！？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "不愧是虐待狂先生！",
        "unit_id": 104512,
        "voice": "vo_adv_6078203_001"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n你接收到空花傾注在這個名稱裡的",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "心意了嗎！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "什麼？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "你一丁點也沒搞懂？",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "……",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "但是空花很滿足！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "確實，",
        "unit_id": 104512,
        "voice": "vo_adv_6078203_002"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "空花也很受這個名字吸引。",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "在祕密的校舍裡，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "虐待狂先生與空花進行熱情激烈的課程……！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "嘻嘻嘻……",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "好的，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "空花要",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "當虐待狂先生的椅子……",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "流口水～♪",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "愛之巢穴，",
        "unit_id": 104512,
        "voice": "vo_adv_6078203_003"
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "這個叫法",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "讓空花的胸口悸動不已。",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n這種完全沒把虐待狂先生和靜流兩人以外的人",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "放在眼裡的感覺，",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "\n對空花來說分數也很高……！",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "遭到冷漠對待的空花……",
        "unit_id": 104512
    },
    {
        "type": "dialogue",
        "name": "黑暗空花",
        "words": "嘻嘻嘻♪",
        "unit_id": 104512
    }
]