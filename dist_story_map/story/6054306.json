[
    {
        "type": "background",
        "background": "501060"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "まさか",
        "unit_id": 113211,
        "voice": "vo_adv_6044306_000"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "彦星が女子に手を出しまくっているとはな……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "何か擁護できる点が",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "少しくらいはあると思っていたが",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "あまりにも酷すぎて",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "逆に驚いてしまったぞ。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "うむ、",
        "unit_id": 113211,
        "voice": "vo_adv_6044306_001"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "あのスケベな視線を思い出すと",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "今でも寒気が……",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "だが",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "あの姿を見て確信した。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "彦星は懲らしめねばならん！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "なんとしても",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "我らで織姫を救い出すぞ、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "よいなシグルド！",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "もし好きだと言い張るなら、",
        "unit_id": 113211,
        "voice": "vo_adv_6044306_002"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "私には到底信じられんな。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "本当に好きな相手が悲しんでいるのなら",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "気遣って当然であろう？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "もし私が同じ立場なら、",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "決してそんなことはしないぞ。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "確かに、",
        "unit_id": 113211,
        "voice": "vo_adv_6044306_003"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "シグルドは女子の知り合いが多いな。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "だが",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "シグルドは彦星みたいに",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "変なことをしていないのだろう？",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "……うむ。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "いい返事だ。",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "もちろん初めから",
        "unit_id": 113211
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "信じていたがな。",
        "unit_id": 113211
    }
]