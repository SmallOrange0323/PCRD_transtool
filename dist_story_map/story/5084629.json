[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍……",
        "unit_id": 103011,
        "voice": "vo_adv_5084629_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n今天也沒有醒來是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "原因是什麼呢，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我完全搞不懂是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "發生這種事，",
        "unit_id": 103011,
        "voice": "vo_adv_5084629_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "作為家臣真是失格……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊！？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我不可以喪氣！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n從嚴重的事態中幫助家主，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是家臣的使命是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "既然如此，就輪到我在《武士道》中學到的",
        "unit_id": 103011,
        "voice": "vo_adv_5084629_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那個儀式……！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n百次參拜登場了！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "事不宜遲是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "馬上就出發吧！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "如果是為了將軍，",
        "unit_id": 103011,
        "voice": "vo_adv_5084629_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就算是赴湯蹈火也在所不辭是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好好見識我的忠誠心吧！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻啪啪啪啪──！",
        "unit_id": 103011
    }
]