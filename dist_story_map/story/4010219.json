    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生……",
        "unit_id": 104531,
        "voice": "vo_adv_4010219_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n把空花叫到這種地方，",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n是想讓空花做什麼呢……？",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花會被壓倒在",
        "unit_id": 104531,
        "voice": "vo_adv_4010219_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "清脆的草坪地毯、柔軟的自然大床上，",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n然後虐待狂先生",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "「就會提出「喂，空花，",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在這大自然中就不需要衣服了吧？」\n",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這種",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "取回野生本能似的要求～～～！",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻……♪",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是，",
        "unit_id": 104531,
        "voice": "vo_adv_4010219_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "馬上就能適應大自然的！",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呃，",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生！？",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你什麼時候來的！？",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦？",
        "unit_id": 104531,
        "voice": "vo_adv_4010219_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一開始就在？",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "對、",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "對不起……",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "沒分清楚妄想和現實……",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n話說回來今天、",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "到底是……？",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……！",
        "unit_id": 104531,
        "voice": "vo_adv_4010219_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "謝、",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "謝謝你……！",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n居然能收到你的祝福──",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呵呵♪",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生的溫柔都讓",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "忍不住渾身顫慄了……！",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦咦！？",
        "unit_id": 104531,
        "voice": "vo_adv_4010219_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎麼會，",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "居然還有禮物……！",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……？",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎麼了嗎？",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你露出一副似乎是在為什麼而困擾、",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "或是煩惱的表情……",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咿、",
        "unit_id": 104531,
        "voice": "vo_adv_4010219_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咿耶耶！？",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空、",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花會喜歡的東西！？",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生，",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你怎麼會提出這種建議！？",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "要一起挑，",
        "unit_id": 104531,
        "voice": "vo_adv_4010219_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就表示空花要赤裸裸地",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n向虐待狂先生",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "公開自己喜歡的東西吧！？",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "太、",
        "unit_id": 104531,
        "voice": "vo_adv_4010219_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "太厲害了，",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生……！",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n連在生日",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "都想如此",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "侮辱空花……！",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但是，",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就是這點好……",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "流口水！",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我知道了，虐待狂先生……！",
        "unit_id": 104531,
        "voice": "vo_adv_4010219_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花會完整公開",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "自己的一切……！",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這才是空花的、",
        "unit_id": 104531
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "生日快樂呢……！",
        "unit_id": 104531
    }
