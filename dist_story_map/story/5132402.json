    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哈、",
        "unit_id": 128011,
        "voice": "vo_adv_5132402_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哈哈……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "太好了，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "做到了啊──！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n討伐完",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "巴西利斯克",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "了……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哎、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呀呀呀……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐！？",
        "unit_id": 127911,
        "voice": "vo_adv_5132402_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳是有",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哪裡受傷了嗎！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "請您放心。",
        "unit_id": 6111,
        "voice": "vo_adv_5132402_002"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "那只是在體力快耗盡時還大聲宣告勝利，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n所以才終於到達極限了而已。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n只要靠特製的營養劑",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "來預支體力，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "馬上就會復活了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣、",
        "unit_id": 127911,
        "voice": "vo_adv_5132402_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太好了……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我太勉強",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐了。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了我，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真謝謝妳……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵，",
        "unit_id": 128011,
        "voice": "vo_adv_5132402_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "如果是陛下的請託，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n區區一兩隻怪物",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也能打倒才是真正的忠臣",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "不過，",
        "unit_id": 6111,
        "voice": "vo_adv_5132402_005"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "實際上打倒的",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "是陛下就是了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不、",
        "unit_id": 128011,
        "voice": "vo_adv_5132402_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不用執著於小細節啦！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總之只要是為了陛下，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我什麼都願意做，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我已經展現出這點了，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "今後也會持續努力的！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐……",
        "unit_id": 127911,
        "voice": "vo_adv_5132402_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然很抱歉在妳疲勞時提出要求，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但請幫我先處理一下這隻巴西利斯克！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咦……？",
        "unit_id": 128011,
        "voice": "vo_adv_5132402_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要、",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要在這裡處理這隻大過頭的",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "巴西利斯克……？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的！",
        "unit_id": 127911,
        "voice": "vo_adv_5132402_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是不馬上處理就會漸漸走味，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以為了做出最美味的佳餚，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "麻煩妳",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "務必幫忙。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "請加油囉，",
        "unit_id": 6111,
        "voice": "vo_adv_5132402_010"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "真正的忠臣。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等一下！？",
        "unit_id": 128011,
        "voice": "vo_adv_5132402_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n妳也要幫忙喔，秘書一號！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "啊。",
        "unit_id": 6111,
        "voice": "vo_adv_5132402_012"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "已經過下班時間了。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咿咿咿咿────！！",
        "unit_id": 128011,
        "voice": "vo_adv_5132402_013"
    }
]