[
    {
        "type": "background",
        "background": "500055"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這裡是遭受到魔物的攻擊而失去意識的可可蘿所住的病房，\n{player}也在這住了下來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "僅管醫生已經將她的傷勢不留瑕疵全都治療好了，\n但不知為何意識遲遲無法恢復，就這麼過了整整一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可可蘿彷彿永遠再也不會甦醒，\n只能夠任由時間不斷流逝……\n就在時鐘的指針指向深夜十二點時，她悄悄地睜開了雙眼。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……。",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯、",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊、",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼啊♪",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這可不行。",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n竟然伸了一個大懶腰，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不成體統。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來……",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n總算是",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好好地回到了『這邊』的世界了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在，",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是幾點呢？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n窗外一片漆黑呢……？",
        "unit_id": 105912
    },
    {
        "type": "still",
        "still": "201000401"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……哦呀？　",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為何，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會趴在床鋪的一旁入睡呢？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真令人懷念。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這還真如同夢境一般呀，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人、",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……♪",
        "unit_id": 105912
    },
    {
        "type": "background",
        "background": "500055"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是可可蘿喔，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下沉睡時，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您一直緊緊握著",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的手嗎？",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "握得這麼緊……",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "血液都快無法流通了，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n像是要讓手麻掉一樣。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓您為了在下擔心，",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下感到非常抱歉。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而正如您所見，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下已經完全沒事了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對喪失了記憶的主人您來說，",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這世界仍有許多摸不著頭緒的事。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此在下是絕不會丟下您離去的。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就是滄海桑田，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要您希望，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就會陪伴在您左右。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此，",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您放心……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在這之後，抱著可可蘿，聽她將所有事情娓娓道來。\n包括了在『那邊』……『真正的現實』中所聽聞到的事物，\n她一五一十地詳述給你聽。"
    },
    {
        "type": "still",
        "still": "201000402"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如同剛才的說明，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下已經能夠在『這邊』\n和『那邊』",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的兩處之間順利往返。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在晶小姐……",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉比林斯達小姐的帶領之下，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "則是乘著一種叫巴士的交通工具回到了家中。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知主人您知不知道呢？",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎是動物園附近的一間研究設施。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並非是在指公會的名字唷。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是指獸人們互助的組織",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【動物苑】……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來您並不知道此事呢。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在『這邊』，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n並沒有什麼如同那樣類型的",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "娛樂設施。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個。",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所謂的動物園，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是住著非常多動物的地方。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而以該處附近一間研究所作為住處，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n便是『那邊』的在下生活的地方。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "父親他似乎處於相當艱困的立場之上，",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此未留於家中……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總而言之，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該處便為在下當前暫時留宿的地方。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "緊接著入夜後，",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也迎來了睡意。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n儘管在下於『那邊』的身體，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是如同機器人般的代用品，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n既然是活體，就有睡眠的必要。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這也為晶小姐向在下所說明的事情之一。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貌似在『那邊』陷入睡眠之際，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便會在『這邊』醒過來的樣子。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "靈魂、",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "心靈",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只能於其中一方的世界中存在……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要保持清醒、",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能活動的狀態，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只侷限在其中一方的世界而已呢。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在『那邊』",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下處於嚴密警備的住所中，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n已經確保了人身安全……",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此在下，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會以『這邊』為中心來進行活動。",
        "unit_id": 105912
    },
    {
        "type": "background",
        "background": "500055"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在成功救出貪吃佩可小姐以前，",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "皆以『這邊』的事情為優先。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而實際上，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將貪吃佩可小姐救出的理由也增加了。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不對……",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在『那邊』醒著的那段時間，",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在『這邊』的在下，似乎就會保持在睡眠的狀態。",
        "unit_id": 105912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明重要的人仍被囚禁著，",
        "unit_id": 105912,
        "voice": "vo_adv_2010004_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n可不能悠哉地睡大頭覺了。",
        "unit_id": 105912
    }
]