[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}來到了隔天即將在蘭德索爾舉辦的\n演唱會現場佈置打工。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……騎士先生。這時候這麼忙，你來這裡有什麼事嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊，話說回來是有聽說還有一個人要來做佈置兼差的這回事……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過怎麼偏偏又是你……為什麼每次都這樣，真是的……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "算了，也無所謂。這邊也是有能給騎士先生做的簡單工作，",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你就帶上臂章去向工作人員詢問看看有什麼活可以幹的吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "順帶一提我是這個演唱會的營運負責人，",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以有任何問題的話請一定要向我或是工作人員詢問哦。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼，",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就請你快點去工作吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n一直工作到午休以前都不可以休息哦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "紡希小姐──！第三首歌的照明是藍色的對嗎～？",
        "unit_id": 1111,
        "voice": "vo_adv_1054003_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是的！前奏開始前都是藍色系的！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n煙霧只要設置在腳邊就好！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "紡希小姐！關於麥克風支架……",
        "unit_id": 1011,
        "voice": "vo_adv_1054003_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在第三首歌結束後會插入談話的部分，請在這個時候處理！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "果然還是有點累呢……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？騎士先生。怎麼了嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎、怎麼了這是！？突然間……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然一般來說都是送飲料的……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過也好啦。我收下了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊，不好意思……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是什麼好甜啊！而且還黏糊糊的……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過辛苦了一番，這樣剛剛好感覺還挺不錯的……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝了。多虧了你讓我有空喘口氣。",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼要這麼吃驚啊！？　",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n看見我這麼老實的樣子很稀奇嗎！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "先說好，休息時間還沒到喔！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請騎士先生馬上回去工作。好了，快去快去！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不過，還為我操心……真的很謝謝你。",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊，走掉了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "接下來！趕快結束佈置工作也能爭取更多時間，得好好加油了！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_021"
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當晚，現場佈置工作結束後的演唱會舞台上──"
    },
    {
        "type": "still",
        "still": "105400301"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "１、２、３、４！１、２、３、４！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_022"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "乾淨俐落，",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "確認好最後一個姿勢！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "然後樂曲結束以前，維持這個姿勢……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_024"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總算把明天的演出曲目，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "全部都跳完了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不行了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "動不了了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我累過頭了嗎……好像都看見騎士先生的幻覺了……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n還是收拾一下回去好了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "本人！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼你會在這……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n比起這個，剛才的你全都看見了嗎！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "明明只有這個絕對不能給任何人看見的說……！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒辦法，只能在這裡把騎士先生給綁起來說服一番了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……剛，剛剛的那些，你都聽見了？",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……那個，要和我一起去吃個飯嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n又唱又跳的，肚子就餓起來了。",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個，這頓我請。所以剛才你看到的，",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n請你不要對任何人說！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "尤其是小望和千歌，絕對要對她們保密！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n請和我約定好！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們約定好了喔。要是敢毀約我就把你綁起來，",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n倒吊在門前！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "絕對不可以說哦。要是敢對誰說的話，",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我就把你綁去當魔物的誘餌哦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過騎士先生好像口風挺緊的，應該沒問題……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個不好意思！這邊來兩碗拉麵――！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "好的，拉麵兩碗――！",
        "unit_id": 411,
        "voice": "vo_adv_1054003_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生有吃過拉麵嗎？很好吃哦！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在拉麵上來之前，我就告訴你我跳舞的理由吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "作為負責服裝的我，得插手偶像的舞蹈編排。",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n為了確實指正，就必須要對舞蹈動作有相當的把握才行。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唱歌也是。有很多各種各樣的要點必需注意。",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……但是，唱歌也好跳舞也好，我是慈樂之音裡頭最外行的。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算舞沒有小望跳得好，歌也沒有千歌來得會唱……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我希望能夠盡量離那兩個人更近一點，不管是舞蹈動作或是歌曲，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我也希望能跟她們站在同樣的高度說話。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "即使再怎麼辛苦，也是現在的我必須去做的事情，",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n如果人們穿上我親手做的衣服後能散發出最燿眼的光芒，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那我就必須達成！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且這次所準備的服裝，可是我的自信之作喔！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那腰間上的緞帶和裙擺的躍動感！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "能看見小望穿上那件服裝華麗地唱歌……",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n散發出最燿眼的光彩，啊啊……真是棒極了……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……好厲害？我、我嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才沒有那回事呢！我只是一直在努力而已……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……咦？我、我嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n……在騎士先生的眼中，當時的我是閃耀著的嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什、什、什麼嘛突然間的！",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你這樣稱讚我，也不會發生什麼好事喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……騎士先生。那個，你剛才說的，是認真的──",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_047"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "──讓你們久等了！這是你們點的兩碗拉麵！",
        "unit_id": 411,
        "voice": "vo_adv_1054003_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……我什麼都沒說。",
        "unit_id": 105411,
        "voice": "vo_adv_1054003_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來了，這就是拉麵哦！趕快趁熱嘗嘗吧！",
