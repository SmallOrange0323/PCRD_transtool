[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和倭一起離開魔物的賭場。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n外面"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "已經看不到追兵的身影了。"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "怎麼了小子，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_000"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "表情看起來很暢快呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "爆冷門中獎就這麼讓你開心嗎。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……啊？",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_001"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不是？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n追兵已經不在了可以回去了？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n──你啊，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "怎麼還沒睡就在說夢話。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你看。",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_002"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n多虧了你我的荷包滿滿的呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "在它變成隔夜錢之前，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "都拿去花掉吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "花掉了再去賺回來就好啦♪",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_003"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──決定了，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "好了走吧！",
        "unit_id": 130012
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被倭拉著手，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "來到的地方是"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n夜晚的熱鬧酒館。"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_004"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "呼哈。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "果然別有一番風味呢。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n用義弟賺的錢喝的葡萄酒。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是啊，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_005"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這種時候就要豪爽一點吧？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "來，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "小子也大口喝下吧！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……怎麼了，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_006"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你怕了嗎。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "別擔心，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你的杯子裡裝的，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n是小孩子也能喝的能量果汁。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "來，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_007"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你稍微舔看看。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "對吧？",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_008"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我就覺得很適合你。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n想喝多少就喝多少。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……哼哼♪",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_009"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "欸小子，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_010"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不覺得只是一直喝太無趣了嗎？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n餘興節目……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "雖然是沒到這麼盛大……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "來拼酒吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n你跟我一起。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "別擔心，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_011"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我喝葡萄酒，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "小子喝果汁。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "誰比較有利一目瞭然吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "規則很簡單。",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_012"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "喝了多少杯，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就能問對方多少問題。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "被提問的人，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不管是什麼問題都得回答。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "喝得越多真實的自己就越會展露出來，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_013"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n是可以了解對方的方法。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你應該",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不會拒絕挑戰……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "對吧？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那麼，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_014"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "就馬上開始……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗯？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──你",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "已經喝完第一杯了！？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_015"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真不錯。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我不討厭喝得快的男人。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "沒有禁忌。",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_016"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n不管多大膽的問題我都會回答。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "想問什麼就問吧！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "喜歡的食物是……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_017"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "葡萄酒、",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "香露，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "和八鹽折。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你說那是飲品？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "對我來說這些是我的汽油啊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n就像是主食一樣的東西。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "因為固態食物的能量太少了。",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_018"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "若菜的咖哩？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n那個……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "美中不足的是一個禮拜會出現好幾次。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──嗯，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_019"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不過那個啊，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "跟喜歡還是討厭沒有關係啦。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "雖然盜賊也沒分什麼假日……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_020"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我想想，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "喝個酒睡個午覺……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "再看看天空吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……雲朵的形狀，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_021"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "意外的很有趣喔。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n沒辦法預測接下來會變成什麼形狀不是嗎？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是有來搭訕的傢伙啦……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_022"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但每個都是，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不超過三天就放棄了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "只有剛開始的時候很有氣勢──",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_023"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗯，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "打從一開始就不可能跟得上我的節奏。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "為什麼男人，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_024"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "都莫名的喜歡較勁呢？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……所以像你這樣的人，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "才反而讓我感到新鮮吧。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈哈哈！",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_025"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n很好，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那就換我了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n這次輪到我來發問囉。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "聽好了小子。",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_026"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n看著我的眼睛回答。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "老實說……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_027"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "若菜和布武機，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哪一個是你的菜？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "原來如此。",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_028"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不知道是有看女人的眼光還是沒有……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "呵呵呵。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "話說在前頭，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_029"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "可沒有比若菜更麻煩的女人了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "身為姊姊的我這麼說的話可是不會錯的。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不過……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_030"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "倒是專情到無可救藥。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n是只要牽起一次的手，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "直到地獄的盡頭都不會放開的類型。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "如果你喜歡這種類型的話，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那她可是數一數二的。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "喜好真特別。",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_031"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "難不成，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你是被欺負會感到高興的類型？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……不過，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_032"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那傢伙看起來那樣但其實也有冷漠的一面。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "明明直到剛剛還玩得很開心，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n下一秒卻沒了興趣轉頭就走。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "想和那孩子好好相處，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_033"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "重要的是要一直吸引她的注意。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗯你就加油吧♪",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊啊！？",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_034"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n真不果斷，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我不是說過我討厭優柔寡斷的人嗎！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "還是說你對我們家妹妹不滿意嗎！？",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_035"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "雖然說，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "確實是個性強烈的不只一點……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "或是……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_036"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈哈，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你想要左擁右抱？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那我不會阻止你的，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但辛勞也會翻倍就是了……♪",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哈哈，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_037"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是這樣嗎？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n你能懂嗎。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這樣啊……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你能懂啊……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "呵呵呵。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "雖然是說越令人費心的孩子越可愛……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_038"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但要說那孩子們令人費心的程度，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "可是不得了的。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你能夠懂的話，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我的負擔也能減輕一點了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──啊？",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_039"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "再來換小子提問嗎？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不錯，整個都來勁了呢。",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_040"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "很好，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那接下來就是比速度了。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n開始囉──！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "倭和{player}不斷的喝完飲品，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n向對方做出提問。"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "最近看的有趣的書？",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_041"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──我怎麼可能會看書。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "比起紙上非現實的故事，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "眼前發生的事物更加有趣啊。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "告訴我小子。",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_042"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "和妹妹們結婚的時候，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n和其他女人們的關係，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你都會",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "好好斷開吧？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "啊？",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_043"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "晚上睡覺的位置是怎麼安排的？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那當然，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是並排睡成川字型囉。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "各說出10個，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_044"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "若菜和布武機可愛的地方。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……什麼，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "10個太多了？",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "這我可不能當作沒聽見呢……！",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後──"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……嗝。",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_045"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你這傢伙，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "蠻厲害的嘛。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n雖然說是果汁，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "但喝得也很豪爽……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗯",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗝。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……嗯？",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_046"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n怎麼了，",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "死死盯著人看。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "…………嗝。",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_047"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n…………",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哼。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "哪裡會有不替妹妹著想的姊姊啊……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_048"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "…………雖然這麼說……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_049"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n但讓那孩子們……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n走上危險道路的人就是我……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "不過……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_050"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "正因如此……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "至少……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n得幫她們……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "物色到好對象啊……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "所以……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_051"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "想和你……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "和妹婿候補的……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "你……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n快點……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "打成一片……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗝。",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "才會今天一整天……",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_052"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "像這樣……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……呵呵，",
        "unit_id": 130012,
        "voice": "vo_adv_1300003_053"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是不是太強硬了……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……這我當然……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "也知道……",
        "unit_id": 130012
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊啊～",
        "unit_id": 1411,
        "voice": "vo_adv_1300003_054"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "這位大姐，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "已經半夢半醒了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "話說，",
        "unit_id": 1411,
        "voice": "vo_adv_1300003_055"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我還是第一次，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "看她醉成這樣。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "平時都是深不見底的蟒蛇。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n看來她是真的",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "很信任小哥啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "小哥也是不簡單。",
        "unit_id": 1411,
        "voice": "vo_adv_1300003_056"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n至今為止",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "沒有任何人",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "能夠像這樣",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "和這位大姐一起喝酒。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "至少",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "我知道的範圍內是這樣。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "所以啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1300003_057"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "你可以更有自信一點！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
