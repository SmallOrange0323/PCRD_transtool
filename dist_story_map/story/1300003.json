        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "雖然我也不知道是對什麼的自信。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "……喔，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "你還要喝嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "能量果汁的原液……！",
        "unit_id": 1411,
        "voice": "vo_adv_1300003_058"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n那個，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "是要加水稀釋來喝的東西喔──",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "呃，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "啊啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "全喝完了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "那當然了，",
        "unit_id": 1411,
        "voice": "vo_adv_1300003_059"
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "因為濃度很高啊……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n雖然是不會對身體不好……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "但可能",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "會變得想睡……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "──呃，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "小哥",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "你還好嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "小哥……！",
