    },
    {
        "type": "dialogue",
        "name": "店長",
        "words": "不行了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為能量果汁原液的強烈刺激，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}不知不覺地睡著了。"
