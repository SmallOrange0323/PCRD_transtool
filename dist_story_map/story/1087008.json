[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}及日和總算趕在天色變暗前回到蘭德索爾，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人前往委託人老奶奶身旁。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們回來了～！",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但不是那種凱旋歸來！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的感覺呢。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "趕快去老奶奶等我們的地方吧。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖說老奶奶被騙了，",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但她好像很期待",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能寄信給她的孫子，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "希望她不會覺得很失望……",
        "unit_id": 108711
    },
    {
        "type": "background",
        "background": "500371"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而，等著兩人的是滿面笑容的老奶奶。"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "啊",
        "unit_id": 7911,
        "voice": "vo_adv_1087008_002"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "啊，",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "太好了！",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n你們平安回來了啊。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我等很久了！",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "奶奶，",
        "unit_id": 311,
        "voice": "vo_adv_1087008_003"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "在那之前要先向他們道歉……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們趕忙回來了！",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "然後，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呃……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那位是？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "……啊，",
        "unit_id": 311,
        "voice": "vo_adv_1087008_005"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "不好意思。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n我還沒自我介紹吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我是奶奶的孫子。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "呵呵，",
        "unit_id": 7911,
        "voice": "vo_adv_1087008_006"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "你們前腳剛走，孫子就傳來了聯絡，",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "發現事情不對勁，",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "孫子也急急忙忙跑來這了呢。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "真的很抱歉呀。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我才要道歉，",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然利用了妳的信，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但多虧如此",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們才抓到了壞人！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n老奶奶",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "並沒有因此很消沉。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "當我發現被騙時",
        "unit_id": 7911,
        "voice": "vo_adv_1087008_009"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "的確很震驚……",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "但是，",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "孫子已經了不起到會讓人認錯了，",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n所以沒發現被騙也是沒辦法的事。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我才沒有",
        "unit_id": 311,
        "voice": "vo_adv_1087008_010"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "變得多了不起呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我還只是初出茅廬而已。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我把這封信和行囊",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還給妳。",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還是說，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要交給真正的孫子呢？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "也對呢，",
        "unit_id": 7911,
        "voice": "vo_adv_1087008_012"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "把這份行囊當作是我的賀禮交給他吧。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n而信的話，",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我下次會",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "好好重新寫一封的。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是啊。",
        "unit_id": 7911,
        "voice": "vo_adv_1087008_013"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n這孩子，",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "這次好像要在蘭德索爾辦個展呢。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n會聯絡我也是為了這件事。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "個展！？",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好厲害～！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "他是藝術家嗎？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "沒那麼誇張啦，",
        "unit_id": 311,
        "voice": "vo_adv_1087008_015"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我是剛獨立的攝影師。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "所以，",
        "unit_id": 311,
        "voice": "vo_adv_1087008_016"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "雖說我也想給你們一些謝禮，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "但很丟臉的是",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我現在很窮。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n怎麼辦呢……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能請你替我們拍照嗎？",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們兩人，",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "正好想拍賀年卡用的照片！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n其實",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這次委託，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也是抱著想趁機",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n到各地尋找拍攝景點的想法才接下的……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "唉呀，",
        "unit_id": 7911,
        "voice": "vo_adv_1087008_019"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那不是正好嗎？",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "就幫他們拍吧。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "讓專家來拍",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會讓人很放心，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "請務必",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "幫我們拍！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "既然是這種事，",
        "unit_id": 311,
        "voice": "vo_adv_1087008_021"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "那我很樂意替兩位拍了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "不過，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "我的器材都不在這裡呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "可以改天拍的話請到我的攝影棚……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "但賀年卡用的還是該趕快拍吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "這是你的相機嗎？",
        "unit_id": 311,
        "voice": "vo_adv_1087008_022"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "剛好跟我用的是同個型號，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n那就借我用一下吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "那",
        "unit_id": 311,
        "voice": "vo_adv_1087008_023"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "麼，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "借這背景一角來拍吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好的！",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "麻煩你了！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "拍攝了一會兒後……"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "好，",
        "unit_id": 311,
        "voice": "vo_adv_1087008_025"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "這樣差不多就行了吧。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "那我就先收下這捲底片，等洗出來後再寄給你們。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好的！",
        "unit_id": 108711,
        "voice": "vo_adv_1087008_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n好期待喔，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "也請記得來看他的個展喔。",
        "unit_id": 7911,
        "voice": "vo_adv_1087008_027"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "好了，",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我們也回去吧？",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "謝謝你們！",
        "unit_id": 311,
        "voice": "vo_adv_1087008_028"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n下次請再讓我",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "好好替兩位拍攝！",
        "unit_id": 311
    },
    {
        "type": "background",
        "background": "501470"
