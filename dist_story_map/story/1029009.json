    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "咦，",
        "unit_id": 1111,
        "voice": "vo_adv_1029009_062"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "小望？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "妳想做什麼……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "哈！",
        "unit_id": 1211,
        "voice": "vo_adv_1029009_063"
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "難不成妳打算放我走嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "偶像小姐人還真好啊。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼可能放妳走。",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_064"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我會要妳好好贖罪的。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
