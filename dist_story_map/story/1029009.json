        "voice": "vo_adv_1029009_049"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "這傢伙是休息室小偷。",
        "unit_id": 1111,
        "voice": "vo_adv_1029009_050"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "而且",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "還是個會裝成工作人員混入現場，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n重複犯下罪行的",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "惡劣慣犯。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員3",
        "words": "我們有接到騎士團的通知，",
        "unit_id": 1411,
        "voice": "vo_adv_1029009_051"
    },
    {
        "type": "dialogue",
        "name": "工作人員3",
        "words": "\n本來打算一有可疑的舉動就把她抓起來，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員3",
        "words": "\n結果她對我們這些資深工作人員警戒心很強，完全沒有露出破綻。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "於是我們",
        "unit_id": 1111,
        "voice": "vo_adv_1029009_052"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "就去找新來的他，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "請他若無其事地偷偷觀察。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n因為我們覺得，如果是面對新來的人，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "她應該就不會那麼警戒。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "也因為這樣，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "才能在她露出本性時抓到她。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以說，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_053"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "他最近是為了這件事才會看著那女生啊。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣啊……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來是這樣啊。",
