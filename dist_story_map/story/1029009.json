    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "我有說錯嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "偶像小姐？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "不要再幫自己找藉口了！",
        "unit_id": 1111,
        "voice": "vo_adv_1029009_059"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "那種歪理怎麼可能說得通。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員3",
        "words": "喂，",
        "unit_id": 1411,
        "voice": "vo_adv_1029009_060"
    },
    {
        "type": "dialogue",
        "name": "工作人員3",
        "words": "我們趕快把她交給騎士團吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員3",
        "words": "\n今天有很重要的新歌發片活動，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工作人員3",
        "words": "\n可沒時間把時間浪費在這種傢伙身上。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……那個，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_061"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可以請你們稍微等一下嗎？",
