        "name": "望",
        "words": "{player}看起來好像很開心……",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n也已經跟其他工作人員打成一片了。",
        "unit_id": 102913
    },
    {
