    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "會不會出什麼事了？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n希望不是出意外",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "或是生病之類的就好。",
