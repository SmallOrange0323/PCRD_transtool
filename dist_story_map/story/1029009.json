[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "有一天，望獨自在休息室內讀著雜誌。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "之前的訪談報導。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "「特別號！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "窺探矚目焦點的超人氣偶像──",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "望平素的模樣！」",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "超人氣啊，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聽起來真不錯。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "演唱會的來場人數和音響盤的銷量也都節節攀升！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "工作順利是不錯啦，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但實在是太忙了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "忙到最近幾乎都沒什麼私人時間。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但這點",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "當初在決定要做為偶像進行活動時",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我就早有心理準備了，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以也沒什麼好抱怨的。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……只不過",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒辦法見到{player}，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就感覺有點寂寞。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "最後一次遇到他，然後跟他聊上幾句，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "已經是什麼時候的事了呢？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "之前就算騰出了些空檔，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也剛好會遇到他要去打工或有其他行程。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唉……",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為是工作所以也無可奈何，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但事情總是無法如願呢。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "工作……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對了，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是工作！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為什麼我沒有早點想到呢！",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n既然如此，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我要趕快去跟他聯絡！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "──就是",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這麼一回事，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以我想請{player}",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "來當我的隨從兼保鑣。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "儘管行程非常滿所以會很忙，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "工作時間也很長，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但相對的薪水給得很大方，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "最重要的是可以待在我身邊。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n應該沒有比這更好的工作了吧！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯嗯，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是我一開始就這麼做就好了。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n這樣就能一直在一起了嘛。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是、",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是嗎……？",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣的話",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也覺得很高興",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哦。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真、",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "話講得這麼直接，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的很狡猾耶。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我可是在忍著別表現得那麼開心的說。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對了對了，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在開始工作之前有件事要先提醒你。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這次我們只是工作夥伴，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以不能像平常一樣用朋友的態度相處。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "工作歸工作，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們就把它區分清楚吧。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這並不是針對他，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "而是對我自己的警告。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "本來我對他就已經有點公私不分了，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "身為一名偶像，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就必須要劃清最低限度的界線才行。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那就請你",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "多多指教囉。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "保鑣先生♪",
        "unit_id": 102913
    },
    {
        "type": "background",
        "background": "500580"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一、",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "二，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "二♪",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}，\n從剛才就一直盯著我看。",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "他大概是為了在我有任何狀況時能立刻反應，才會像這樣警備著，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不過被他這樣緊盯著看，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "實、",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "實在好令人害羞……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是很希望他在演唱會上盡量看我練好的表演，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但不是很想讓他看到我練習時候的樣子呢……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "本來還覺得",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "保鑣作戰很成功，",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "萬萬沒想到竟然有這個盲點……！　",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "辛苦了，",
        "unit_id": 1111,
        "voice": "vo_adv_1029009_021"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "新來的。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "你去休息一下吧。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "你放心，",
        "unit_id": 1111,
        "voice": "vo_adv_1029009_022"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "這裡就交給我吧。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "而且你",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "從剛才開始就在忍著不去上廁所了吧？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "想、",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "想去廁所就要去啊！{player}！",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的，",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "他實在太老實了……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "不會啊，",
        "unit_id": 1111,
        "voice": "vo_adv_1029009_025"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "這樣很可靠啊。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "畢竟像這種現場",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "三不五時就會有盯上偶像，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n心懷不軌的傢伙出沒。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "真不愧是小望指名的人選。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "有這麼可靠的夥伴在，",
        "unit_id": 1111,
        "voice": "vo_adv_1029009_026"
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "\n這次的工作",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "工作人員1",
        "words": "也許會比平常還順利呢。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒、",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "沒錯。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "現在不是光被盯著看就心煩意亂的時候。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我得振作點！　",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯？",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像聽到很開心的聊天聲……",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊。",
        "unit_id": 102913
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "原來如此，",
        "unit_id": 1211,
        "voice": "vo_adv_1029009_029"
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "你到目前為止做過各式各樣的工作啊。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "工作人員2",
        "words": "\n感覺很可靠呢。",
