    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "可惡，",
        "unit_id": 1211,
        "voice": "vo_adv_1029009_054"
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "我還以為他只有個性認真這點可取，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "太小看他了……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "為什麼？",
        "unit_id": 1211,
        "voice": "vo_adv_1029009_055"
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "那還用問。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "因為我很討厭",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "所謂的偶像。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唔……",
        "unit_id": 102913,
        "voice": "vo_adv_1029009_056"
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "偶像只因為長得好看就受人吹捧，",
        "unit_id": 1211,
        "voice": "vo_adv_1029009_057"
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "\n輕輕鬆鬆就能過上好日子，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "沒有一個像樣的。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "既然過得這麼幸福快樂，",
        "unit_id": 1211,
        "voice": "vo_adv_1029009_058"
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "那讓我找點樂子，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "休息室小偷",
        "words": "也沒什麼關係吧？",
