    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就要結束了呢～",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "聖誕節給茜里的印象",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一直都是要與情人共度，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n但是……",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "像這樣和很多人一起放縱，",
        "unit_id": 124011,
        "voice": "vo_adv_5106411_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "感覺也很特別呢～",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里超級興奮的。",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "對吧，",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊？",
        "unit_id": 124011
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳、",
        "unit_id": 124111,
        "voice": "vo_adv_5106411_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳的用詞好像怪怪的，",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯，",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不過",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里說的可能……",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "沒錯吧。",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "聖誕節是要和大家一起過的，",
        "unit_id": 124111,
        "voice": "vo_adv_5106411_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n我以為",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這個活動一輩子和我無緣。",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n可是……",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯，",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我覺得",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真的",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "很開心。",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 124211,
        "voice": "vo_adv_5106411_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那就再好不過了。",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對了，還有一點時間，",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳們待會要做什麼？",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "該不會要去約會？",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "依里、茜里",
        "words": "……！！",
        "unit_id": 1,
        "voice": "vo_adv_5106411_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 124111,
        "voice": "vo_adv_5106411_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不，",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "呃……",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "這個嘛……",
        "unit_id": 124111
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "…………",
        "unit_id": 124011,
        "voice": "vo_adv_5106411_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唉呀，",
        "unit_id": 124211,
        "voice": "vo_adv_5106411_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看來還有尚未解決的問題呢。",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳們一路都一起共患難，",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以一定可以的，",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我保證。",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n──來吧，",
        "unit_id": 124211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "努力到最後吧！",
        "unit_id": 124211
    }
