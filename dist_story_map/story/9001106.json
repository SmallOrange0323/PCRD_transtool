    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n做得漂亮，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿♪　小凱留♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然還有你♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳說還有他……喂，",
        "unit_id": 106011,
        "voice": "vo_adv_9001106_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}不就是在旁邊看我們戰鬥而已嗎。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不是的。",
        "unit_id": 105911,
        "voice": "vo_adv_9001106_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人運用了愛梅斯大人所授予的特別能力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從旁輔助我們。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛才的戰鬥中，",
        "unit_id": 105911,
        "voice": "vo_adv_9001106_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐有感受到",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n自己發揮出比平常還要強大的力量吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原、",
        "unit_id": 106011,
        "voice": "vo_adv_9001106_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來是這樣啊～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有這種奇怪的能力啊～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_9001106_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且主人還有將我們的潛在能力引導出來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n讓我們得以發動超強力技能的能力。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就是所謂的「必殺技」。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105911,
        "voice": "vo_adv_9001106_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真不愧是在下的主人♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您好厲害。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您太優秀了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你呀，",
        "unit_id": 105811,
        "voice": "vo_adv_9001106_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的很厲害呢～☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今後也要借助你的力量，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓我們一起把工作和委託都咻咻咻地完成吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_9001106_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這也關連到取回主人記憶一事。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9001106_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能與兩位相遇，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也都要感謝愛梅斯大人的引導。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請多多指教了。",
        "unit_id": 105911
    }
