    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_046"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你呀！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n明明跟我在一起，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你在跟誰聯絡？",
