[
    {
        "type": "background",
        "background": "500891"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對{player}說出帶著告白感覺的話後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n美咲衝出宅邸一路逃進了小巷子。"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚嗚……",
        "unit_id": 105011,
        "voice": "vo_adv_1050011_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "太糟糕了……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我說了那種話……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一定會被誤會的……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n從明天起，我要用什麼樣的表情和那傢伙見面才好……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "──咿！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050011_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "他",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "他他、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "他為什麼追過來了！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不行不行不行，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我現在沒辦法跟那傢伙說話！　",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雖然想逃走，",
        "unit_id": 105011,
        "voice": "vo_adv_1050011_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但鞋子磨腳沒辦法好好跑步……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還是假裝沒聽到，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "趕快溜回家……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "…………啊啊，真是的！",
        "unit_id": 105011,
        "voice": "vo_adv_1050011_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "煩人！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "別跟過來！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦，",
        "unit_id": 105011,
        "voice": "vo_adv_1050011_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你的背後！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n那是什麼光啊～～～！？",
        "unit_id": 105011
    },
    {
        "type": "background",
        "background": "510102"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚嗚……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "想著想著天都黑了……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n說真的，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我該怎麼辦才好……？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你、",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你為什麼在這裡！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "話說在前頭，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "今天我沒空理你……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……你問我為什麼不在門禁時間前回家……？",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那種事",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "與你無關吧！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n不如說，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為什麼你會知道啊！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "難道說……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是媽媽拜託你的對吧！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "她希望你來接我吧！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "…………哼。",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好啊。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我就陪你一下下。",
        "unit_id": 105032
    },
    {
        "type": "background",
        "background": "510122"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "然後呢？",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你帶我來公園這種地方打算做什麼？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那是什麼？",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "熱可可？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "成熟的淑女才不會喝這種",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "孩子氣的飲料！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦？",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_012"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你說可可多酚對肌膚很好？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "既然是這樣……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊～",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真好喝♪",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "果然在沮喪的時候",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就要吃甜食呢♪",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你在偷笑什麼啦。",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_014"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n……看到我心情好，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "讓你這麼高興嗎？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哼……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "話說在前頭，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我可不會道謝。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過作為報答……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我可以",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "稍微告訴你一點。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……我並沒有",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_016"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "離家出走。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我去姊姊家玩，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "本來打算在拜訪結束後回家的……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對了，",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你還沒見過",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我姊姊對吧。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我的姊姊",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_018"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "長得很漂亮，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n打扮時髦，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "性格溫柔……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "而且",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "非常博學。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "男人見到她全～都為她著迷喔。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_019"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "非常尊敬她。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n將來",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我想成為像姊姊那樣的成熟的淑女。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以我想請姊姊",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "教我化妝和穿搭等等的",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "各種事情，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "經常去找她玩……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是今天……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_021"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我吃了閉門羹。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我明明有跟她約好的……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "而且姊姊",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_022"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "完全不肯露面，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我擔心她會不會是感冒了。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以我說",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "「在妳告訴我理由之前，我不會回去」，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "結果……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "姊姊",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_023"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就生氣了！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對著我發火！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣的姊姊……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "才不是成熟的淑女！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "姊姊那種人……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_024"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "姊姊那種",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "人……！",
        "unit_id": 105032
    },
    {
        "type": "still",
        "still": "105001101"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……嗚嗚。",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_025"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n怎麼辦……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我說了我最討厭姊姊了……！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "吶。",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_026"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為什麼姊姊會",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "突然生氣呢？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n她是不是",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "討厭我了？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是因為我總是黏著姊姊嗎？",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_027"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n她嫌我很煩人了嗎？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我不明白……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_028"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我不明白啊……！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對呀，",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_029"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我當然最喜歡她了……！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我不想把事情放著不管……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n可是，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我不知道該如何是好……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……抱歉。",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_030"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "即使對你說這種事，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n明明也無可奈何的……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_031"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我有點害怕",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一個人去見她……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n……{player}也會跟我",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一起去嗎？",
        "unit_id": 105032
    },
    {
        "type": "still",
        "still": "105001102"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嘿嘿……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_032"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "謝謝。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n儘管我不太想說出來……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我覺得你這樣的一面，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n很有紳士風範喔。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那麼，",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_033"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "在去姊姊家的路上，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你願意護送我嗎？",
        "unit_id": 105032
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………"
