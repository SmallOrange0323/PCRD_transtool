    {
        "type": "background",
        "background": "510102"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哼哼哼～♪",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_034"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊～",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_035"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "太好了！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n能夠跟姊姊和好♪",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過，",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_036"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也得反省才行……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n在姊姊跟最喜歡的男朋友分手，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "傷心哭泣的時候還跑去找她。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "然而姊姊",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_037"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "卻嚎啕大哭地對我說，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n對不起，我把氣出到妳身上……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我能做的，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n只有告訴姊姊",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "「我最喜歡妳了」而已。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是、",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_038"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是嗎……？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "既然你這麼說，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這次我就當作是這樣吧。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_039"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "和姊姊聊了很多事，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n聊到許多平常沒有提起的",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "話題。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以，我知道了各種",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "關於姊姊美麗的祕密！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為了那位男朋友，",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_040"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n姊姊將髮型弄得漂漂亮亮，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "化妝",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "並注重打扮。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……那麼，",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_041"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "只要我戀愛了……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也會變成像姊姊一樣成熟的淑女嗎？　",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "比如說……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_042"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "和{player}談之類的？　",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "他雖然看起來靠不住，",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_043"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但相當溫柔。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n在我遇到困難時，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "會立刻幫助我……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "儘管周遭的大家都很寵我……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_044"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n但感覺不管到哪裡都願意護送我的人，",
