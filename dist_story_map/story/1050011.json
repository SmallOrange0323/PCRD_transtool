    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "美咲……！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n邀請他去約會，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "沒什麼大不了的……！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "說呀……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "說呀……！　",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "…………沒、",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_054"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
