        "voice": "vo_adv_1050011_055"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "別隨便摸淑女的頭，笨蛋～！！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "唔唔……",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_056"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我才不覺得、",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "開心……！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n因為",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我被當成小孩子對待了……！",
