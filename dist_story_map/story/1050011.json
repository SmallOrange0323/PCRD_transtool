    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……啊，",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_050"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "已經到家了。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個，",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_051"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "今天真是謝謝你。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n多虧",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "有你幫忙……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個，",
        "unit_id": 105032,
        "voice": "vo_adv_1050011_052"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果方便的話……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呃……",
        "unit_id": 105032
    },
