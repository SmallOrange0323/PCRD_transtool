        "voice": "vo_adv_1050011_045"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "其實",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我不太懂戀愛是什麼，",
