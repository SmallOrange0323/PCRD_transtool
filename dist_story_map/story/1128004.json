        "words": "太、",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "太難為情了啦……",
        "unit_id": 103332
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1128004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是很開心的夢吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真陽",
        "unit_id": 190011,
        "voice": "vo_adv_1128004_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在另一邊不斷遇到各式各樣的麻煩，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總是一直逞強，要自己更加努力。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以我才想，至少要讓她做個高興的夢。",
        "unit_id": 190011,
        "voice": "vo_adv_1128004_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n希望有讓她稍微放鬆到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子克服了巨大難關，",
        "unit_id": 190011,
        "voice": "vo_adv_1128004_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也加深了夥伴們間的羈絆，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以後一定沒問題的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1128004_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也要努力幫助她唷？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼就加油囉，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我的夥伴♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500156"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯……",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_058"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "呼啊～",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "已經早上了嗎？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我實在太累了，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "睡得好熟的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯～",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_059"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "睡了個覺後身體已經不累了，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而且又做了個好夢，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在我感覺神清氣爽的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_060"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥也做了一樣的夢的啦？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚嗚，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在夢裡面發生了很丟臉的事，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n又給一堆人添了麻煩……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真想找個洞鑽進去的啦……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_061"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "多虧了這個夢我才知道，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n只靠我",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一個人是什麼事",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "都辦不到的呢。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我不會再硬要讓自己表現得像個公會長了。",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_062"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我要借助大家力量，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在我自身能力所及的範圍內",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "努力向前邁進的啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "大家互相幫助，共同前進，",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_063"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這就是",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "【伊麗莎白牧場】的啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯？",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_064"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這個聲音……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一定是大家回來了。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我們快去迎接她們的啦！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "各位，",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_065"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "歡迎回來的啦～！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "滿面笑容迎接大家的真陽，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她的身影看起來似乎比以前更成長了一些，也散發出更耀人的光芒。"
    }
]