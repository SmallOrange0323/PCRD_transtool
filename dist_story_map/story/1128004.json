        "words": "\n便和{player}一起回到了公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀～",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真是從早到晚都閒不下來的一天呢。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不好意思啊老哥，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "讓你陪我這麼久的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "能夠輕描淡寫地這樣說，",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥果然很了不起的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但你應該也很累了才對，",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今晚就好好休息吧。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也快睡著了，",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就這樣一覺熟睡到天亮……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不覺得",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "房間好像莫名的亮嗎？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這樣根本睡不著的啦。",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為、",
        "unit_id": 112811,
        "voice": "vo_adv_1128004_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為什麼煤燈會這麼亮的啦？",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n越來越亮了……",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚、",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗚呀～！",
        "unit_id": 112811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "好刺眼啦～！",
        "unit_id": 112811
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦哦！",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_004"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在這邊遇到你還真巧。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n今天有什麼事嗎？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我一聽說",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這座購物中心在舉辦北海道物產展，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就怎麼樣也耐不住性子，決定來一趟了啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搞笑段子？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我、",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我當然有在想的啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n畢竟離敗部復活戰",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "已經沒多少時間了。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但不知道是不是離開北海道太久，",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_007"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有點遇到瓶頸了……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這時候我剛好聽說",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有這個物產展的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果能在這座水泥叢林中",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_008"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "感受到一點北海道的氣息，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "說不定我就能擺脫",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這股鬱悶感的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就是這樣，",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_009"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以老哥也一起來吧！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "今天",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就盡量買盡量吃，玩個痛快的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n來吸收北海道之力，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "兩個人一起想出最好笑的哏啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇喔～",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_010"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "品項好多的啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還有很多在家鄉常看到的商品。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n家鄉的東西在這裡",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就好像鑽石一樣閃閃發光的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "該怎麼辦老哥？",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_011"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "點心和海產都很好吃喔！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哦哦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那邊還有內用區！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我已經",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "興奮到發抖了！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "放心的啦。",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_012"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這裡就交給大姐姐吧！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可以的話希望不要買螃蟹和哈蜜瓜……",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊勒？",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我失陪一下啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "嗯～",
        "unit_id": 1231,
        "voice": "vo_adv_1128004_014"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不愧是物產展。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "每個都看起來很好吃，",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "都不知道要看哪個好。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是啊，",
        "unit_id": 1031,
        "voice": "vo_adv_1128004_015"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "光是點心就有這麼多種類。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "哦，",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "湯咖哩看起來也很好吃耶。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "啊～",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "好煩惱啊！",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "兩位，",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "如果可以的話，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我來給你們一點建議吧？",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "咦？",
        "unit_id": 1231,
        "voice": "vo_adv_1128004_017"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳是？",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不重要，",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我只是個路過的北海道人的啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "首先，",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_019"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不知道要買什麼點心的時候，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不論如何就是應該選這個！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這可是不管誰收到都會開心的",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "必吃北海道伴手禮的啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "然後，",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "地瓜點心就要選這個的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "綿密的地瓜口感會讓人一吃就上癮。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "在北海道以外的地方幾乎都買不到喔，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "要買就趁現在的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊，",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_021"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "湯咖哩粉的話",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我推薦這個的啦。",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這款高度重現了店內的口味，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就像在當地吃到一樣的啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "呵呵，",
        "unit_id": 1231,
        "voice": "vo_adv_1128004_022"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳懂得好多喔。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n謝謝，",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳推薦的東西",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我都會買來試試看。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哈哈，",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝啦！",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我問妳哦，",
        "unit_id": 1031,
        "voice": "vo_adv_1128004_024"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這裡賣的牛奶",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "和超市的價格完全不同耶。",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n到底哪裡不一樣啊？",
        "unit_id": 1031
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "差別在於殺菌時間的啦。",
        "unit_id": 103332,
        "voice": "vo_adv_1128004_025"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n超市的牛奶大部分",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "都是超高溫瞬間殺菌，",
        "unit_id": 103332
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這裡的則是長時間",
        "unit_id": 103332
    },
    {
