[
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "什麼……",
        "unit_id": 7112,
        "voice": "vo_adv_5064301_000"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "\n這是怎麼回事，",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "那個巨大魔物……！",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "誰、",
        "unit_id": 116211,
        "voice": "vo_adv_5064301_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "誰知道呢，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "到底是什麼呢……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "琪愛兒，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳說那是什麼。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "呃，",
        "unit_id": 116311,
        "voice": "vo_adv_5064301_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那個……",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「德蕾女千鈞一髮！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "神祕暗黑組織憂妮們來襲」",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "之卷！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對啊，",
        "unit_id": 116211,
        "voice": "vo_adv_5064301_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是那個。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的就是那個。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以說啊，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就快點打倒吧，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個神祕暗黑組織憂妮們。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是啊，",
        "unit_id": 116411,
        "voice": "vo_adv_5064301_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但各位可別輕敵了。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n受到無數負面情感影響而萌生的自我意識，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是破壞衝動本身。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那女孩是個強敵。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "哦～",
        "unit_id": 116211,
        "voice": "vo_adv_5064301_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說那是母的喔？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但統整能力還很弱，",
        "unit_id": 116411,
        "voice": "vo_adv_5064301_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "簡直就是理科會想出來的東西。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "居然還是理科女喔？",
        "unit_id": 116211,
        "voice": "vo_adv_5064301_007"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "神祕暗黑理科女",
        "unit_id": 7112,
        "voice": "vo_adv_5064301_008"
    },
    {
        "type": "dialogue",
        "name": "瑪麗亞",
        "words": "為什麼會跑進這所學院裡……？",
        "unit_id": 7112
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哎呀～",
        "unit_id": 116311,
        "voice": "vo_adv_5064301_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "晚點再說吧！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "敵人開始行動了！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯！",
        "unit_id": 116411,
        "voice": "vo_adv_5064301_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "同志，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學習的時間到了。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n麻煩你用一直以來的那個學術性強化協助我們。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有什麼湧現出來了～～～！",
        "unit_id": 116411,
        "voice": "vo_adv_5064301_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n哇、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哇啊啊啊啊～！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "突擊～！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "跟在我後面～！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "學姐不要擋路，讓開。",
        "unit_id": 116211,
        "voice": "vo_adv_5064301_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好，",
        "unit_id": 116311,
        "voice": "vo_adv_5064301_013"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就切嚕地打倒她們吧！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好朋友社，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "使出全力上吧！",
        "unit_id": 116311
    }
]