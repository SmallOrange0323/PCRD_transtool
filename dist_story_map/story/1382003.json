[
    {
        "type": "background",
        "background": "502114"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──經歷遺跡騷動的隔天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}在涅妃‧涅羅的帶領下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n移動前往鬼岩城塞的廣場。"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "小心搬運！",
        "unit_id": 50811,
        "voice": "vo_adv_1382003_000"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n那傢伙鱗片上的刺，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "一旦扎進去可就很難拔出來了！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "喂，",
        "unit_id": 1,
        "voice": "vo_adv_1382003_001"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "別擠！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n這肉在生的時候跟鋼鐵一樣硬，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n要是掉下來砸到腳，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "那可就不得了啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "搬運了這麼多過來，",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_002"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "真是熱鬧起來了呢～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n這可是在吉歐‧格黑納也見不到，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "以凶惡魔物為原型的",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n食材大遊行唷～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝是來遊山玩水的嗎？",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "嘿咻，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這不正是鍛鍊力氣的好機會嗎？",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "唔！",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_004"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n這是要我去",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "幫忙搬運",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "的意思嗎～！？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n不知道有沒有……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "留下什麼比較不危險的食材……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下呀，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "請儘管悠閒地放鬆休息。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n待場地準備就緒後，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "便會著手進行烹煮。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正是如此。",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_006"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那些魔物，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "皆是為了款待騎士閣下而備齊的極品……",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "稱之為吉歐‧格黑納引以為傲的",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "至高美食，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "亦絕不為過。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家會大顯身手",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_007"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "細心烹飪。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若恁能期待",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家親手準備的這份誠摯款待，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那便是奴家的榮幸──",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_008"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n恁剛剛，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "說了什麼？",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "騎、",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_009"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "騎士閣下先生～？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "你是認真的嗎，",
        "unit_id": 50811,
        "voice": "vo_adv_1382003_010"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "臭小子！？",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n你是說你已經",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "做好那樣的覺悟了嗎！？",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……騎士閣下的話語，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_011"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對奴家而言無疑是意料之外的喜悅。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "既然如此……",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那便請容奴家厚著臉皮接受恁的好意。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不不不，",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_012"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "別這麼輕易就答應啊！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n騎士閣下先生，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "您到底明不明白啊～！？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n要用這些食材和皇女大人一起料理，就意味著……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "唔唔！？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "米亞……",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_013"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n當然，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝們也會幫忙吧？",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "唔唔",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_014"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "唔唔……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "呼哈～！！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n皇女大人，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "太過分了啦～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n竟然突然摀住我的嘴～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "…………",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_015"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "嗚……",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_016"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "知、",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "知道了啦，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我不亂說話就是了嘛……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "看樣子……",
        "unit_id": 50811,
        "voice": "vo_adv_1382003_017"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "我們也只能做好覺悟了啊。",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "是涅妃‧涅羅大人所認可的對象。",
        "unit_id": 1,
        "voice": "vo_adv_1382003_018"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n沒有異議。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "但是～！",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_019"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "處理這些食材",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "既危險又困難！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n這簡直就像是象徵著吉歐‧格黑納那嚴酷的大地一般～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n至今為止",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "還沒有任何一個人敢嘗試挑戰！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "即使如此，",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_020"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "皇女大人和騎士閣下先生也打算完成挑戰的話，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n我們也會作為吉歐‧格黑納的人民，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "盡微薄之力協助～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "可以吧……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "各位！？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "全員",
        "words": "嗚喔喔喔喔喔喔喔喔！！！！",
        "unit_id": 1,
        "voice": "vo_adv_1382003_021"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵。",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_022"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "諸位，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真是深得奴家之心。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "甚好。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家也會為了不辱騎士閣下的覺悟",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_023"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "竭盡全力，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還請多多指教，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "共同",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "開始動手烹煮吧。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此乃，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_024"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「巖裂大蛇之肋肉」。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n其堅如磐石，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "唯有熟練之士奮力一擊方能切斷。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若以粗劣刀技應之，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "反被震碎腕骨亦是當然。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下呀，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_025"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "借恁的手一用……",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家會將自身的手化為利刃",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "將其斬斷。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n希望能得到恁的力量相助。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "喔喔，",
        "unit_id": 50811,
        "voice": "vo_adv_1382003_026"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "在兩人共同作業下，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "肉直接一刀兩斷了！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那麼接下來，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_027"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "要製作高湯。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n這是從「硝火水瀑布」釣上來的",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「吞焰之益荒魚」……",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "以業火使其沸騰，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並於釜中持續燉煮，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "直到鮮味滲出為止。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "好燙！？",
        "unit_id": 1,
        "voice": "vo_adv_1382003_028"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n火、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "火力也太強了……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "咳",
        "unit_id": 1,
        "voice": "vo_adv_1382003_029"
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "咳咳……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "這、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "這個煙霧是……！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "\n臭小子，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "千萬別吸進去啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "\n要是吸了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "會整整臥床三天三夜的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "在熬煮高湯的期間，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_030"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "先準備野菜。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這是在「蠱啼原」採摘的",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「甜露草」……",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n須仔細洗淨清毒，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並切成適合擺盤的大小。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "騎士閣下先生，",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_031"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "危險～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "痛痛痛痛！？",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_032"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n這種野草，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "有時候會附著牙齒很尖的蟲子～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "好痛",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "好痛！！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "就算咬我",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "也一點都不好吃啦～！！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "米亞，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_033"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "過來這兒。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "讓奴家為汝清理乾淨吧。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "啊唔！？",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_034"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "謝、",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_035"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "謝謝您！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "皇女大人～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "雖然剛才好像也稍微打到我本人了～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不過騎士閣下先生，",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_036"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "感覺很樂在其中呢～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "明明是這麼危險的烹飪過程～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "到、",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_037"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "到底是擁有什麼樣的經驗呢～？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "難道說，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我們的支援",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "根本是多餘的嗎……？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "別說這種掃興的話。",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_038"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "既然是在客人面前，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "理當展現身為主人款待客人的氣魄。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "被您這麼一說",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_039"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我還真沒法反駁呢～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "誰、",
        "unit_id": 50811,
        "voice": "vo_adv_1382003_040"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n誰快來！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "救救我！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "魔物的體液……",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "啊啊啊！！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "好的好的，",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_041"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "現在就過去～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "這邊我們會處理的，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n騎士閣下先生",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "協助皇女大人的工作，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "就拜託你囉～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……♪",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_042"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵。",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_043"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那樣的事絕對不──",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "存在……♪",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "誠如所言，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_044"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "理當如此。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n能像這樣與諸位並肩",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "致力於烹飪……",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如此契機，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "確實不曾有過。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n此時此刻，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實乃心曠神怡，宛如身處雲端。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……既然如此，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_045"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "終於要進入最後階段了。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n若有奴家與騎士閣下攜手合作，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "再加上彼些傢伙的從旁協助，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "想必",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "定能大功告成……♪",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "……完成……",
        "unit_id": 50811,
        "voice": "vo_adv_1382003_046"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "了……",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "成功了……",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_047"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我們，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "終於完成了～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "感謝諸位的支持，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_048"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真是辛苦了。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下的膽量，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "以及烹飪的手藝，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "確實令奴家深感佩服。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "因此。",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_049"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n將這煉獄之地的產物",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "活用至淋漓盡致的逸品──",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「煉獄窯煮魔物鍋」，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "就此大功告成。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那麼，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_050"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "趁熱享用吧。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "請往這邊走。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "終、",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_051"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "終於！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n到這一個時刻了呢～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "啊啊！",
        "unit_id": 50811,
        "voice": "vo_adv_1382003_052"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "我們的努力總算沒有白費！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n往後也請多多關照啦──",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "新郎閣下！！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這場正式的饗宴，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_053"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "有著吉歐‧格黑納的豪族",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "與權貴之間",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n自古流傳至今的",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "特別禮節呢。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那是單憑一己之力無法達成的烹製技法──",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_054"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "將處理極其棘手的食材，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "藉由相互扶持，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "共同跨越難關，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "以此作為永恆盟約的證明。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此即……",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「婚禮之儀」。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "啊～",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_055"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n看你一臉愣住的表情，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "你果然不知道呢～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "但是，",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_056"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "已經無法回頭了喔～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "這個婚禮之儀，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "要透過互相餵食親手製作的料理",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n方能大功告成……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "請做好覺悟吧，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "騎士閣下先生～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "既然如此，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_057"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那就僭越了……",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "先由奴家",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "將這份美味",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "送至騎士閣下的嘴間吧。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "來吧，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_058"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下呀。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n「啊～」……♪",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_059"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這是在逗恁玩呢。",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_060"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下羞澀的臉龐──",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真是可愛至極，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "能像這樣近距離端詳，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實乃無上的幸福呀♪",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "咦……？",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_061"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "逗我玩……？",
        "unit_id": 1,
        "voice": "vo_adv_1382003_062"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下乃是",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_063"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "足以稱為救世英傑，實至名歸之人。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "因此，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "傾慕騎士閣下的女子們，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "猶如繁星般眾多，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這亦是不爭之實。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "更遑論，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "在未事先告知禮儀細節的情況下，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "締結這如奇襲騙局般的婚姻。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若奴家在此刻將騎士閣下據為己有，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_064"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n並迎娶為夫婿，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "諸國間的紛爭想必是在所難免……",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還真沒想到，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "恁真是位",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "名副其實，罪孽深重的男人呢。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "也、",
        "unit_id": 51611,
        "voice": "vo_adv_1382003_065"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "也就是說～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "這會發展成",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "國際的問題對吧～？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n光、",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "光是聽到就讓人胃痛的詞彙～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "那……",
        "unit_id": 1,
        "voice": "vo_adv_1382003_066"
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "我們的覺悟呢？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "\n剛才捨命支援的意義是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "絕非是徒勞無功。",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_067"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對汝們而言，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "想必也是個磨練自我的大好機會吧？",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "全員",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_1382003_068"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哎呀，",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_069"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "說起汝們這幾位。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "明明接下來就要與貴客共進饗宴了，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "多少也",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "莊重檢點些吧。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "即便如此……",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_070"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "剛才那番話，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "可不全都是在開玩笑喔。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "倘若",
        "unit_id": 138211,
        "voice": "vo_adv_1382003_071"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下也有此意的話──",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "縱使會與諸國產生嫌隙，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家也甘願作為恁的伴侶，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "成為恁的正室，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "終生相隨亦在所不辭。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "待恁心意定奪，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "無論何時",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "都請儘管告訴奴家吧……♪",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "儘管過程手忙腳亂，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}最後還是\n與涅妃‧涅羅她們盡情享用了一起製作的吉歐‧格黑納料理，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n愉快的夜晚就在歡聲笑語中漸漸深沉。"
    }
]