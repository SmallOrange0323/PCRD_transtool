    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……跟從１年級到６年級的所有男女都是，",
        "unit_id": 102731,
        "voice": "vo_adv_5204063_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n而且",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "連飼養的兔子、烏龜、雞也是朋友？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……這是怎麼回事？",
        "unit_id": 102731
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嗯？",
        "unit_id": 132431,
        "voice": "vo_adv_5204063_029"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽有確實說了喔？",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n說沒有朋友",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "「跟彩羽玩躲避球」。",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "啊哈哈，",
        "unit_id": 1,
        "voice": "vo_adv_5204063_030"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n因為彩羽躲避球太強了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "連國中生都能贏。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "\n沒有任何人想跟彩羽玩躲避球。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……那，",
        "unit_id": 105631,
        "voice": "vo_adv_5204063_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那個眼淚是？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "嘻嘻，",
        "unit_id": 132431,
        "voice": "vo_adv_5204063_032"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽是演技派吧♪",
        "unit_id": 132431
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……啊啊？",
        "unit_id": 102731,
        "voice": "vo_adv_5204063_033"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然流夏和惠理子被彩羽的演技給騙到了，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但不知為何卻也有種被那演技幫助的感覺。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "……前世說不定也曾發生過這種事。"
    }
]