    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}～！\n好巧喔，",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是姐姐呀～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "抱抱……",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_001"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n呵呵呵，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "抓～住～你～啦……♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "真的是",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "剛好在這裡遇見了你。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我絕對不會讓你逃跑的～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "一輩子",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "和姐姐在一起吧♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呼。",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_003"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n久違的{player}的觸感，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}的味道……♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我活過來了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n謝謝你呀～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我剛展開新生活，",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n累得要命！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_006"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "最近實在是太忙碌了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "尤其是我才剛搬到這裡，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n還沒有完全安頓好。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "正在努力讀書考取證照，",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_007"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姑且",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有公會的工作要做。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我真的是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "累到都要老了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "謝謝你什麼都不過問",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n讓我補充{player}成分～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵。",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_009"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果是以前的{player}，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n肯定又是害臊又是抗拒的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "完全不抵抗",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "反而會讓我猜想",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是不是對我沒有興趣了呢～？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐的心情也是很複雜的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不說這個了。",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_011"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}，你在這裡做什麼呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n買東西嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "喔。",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是來買齊一些",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n零星生活用品的呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那姐姐介紹一些平價店家給你吧。",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還可以殺價喔～♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "讓我照顧你，",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "畢竟這就是",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐的生存意義了呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……！？",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n慢著，{player}？\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你在閃閃發光耶。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "發生什麼事了？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯～？",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n這是怎麼回事呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我沒聽說過呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "居然發生了連我們公會長",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n都沒有察覺到的異常情況……？",
        "unit_id": 104911
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "早安，{player}！",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n今天是個舒服的早晨呢☆",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "溫柔的姐姐",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n來叫醒賴床鬼{player}囉～！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要是不快點起床，",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你上學就要遲到了……",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唷♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵呵。",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我都叫這麼久了，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "他還是完全睡死了呢。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那就沒辦法了。",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n只好動用武力了。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "清醒的猛烈一擊，",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n降臨……",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "囉♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，在這之前。",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我先看一會兒……♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "把{player}的可愛睡臉",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n看到燒起來～♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呼……",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n啊，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "多麼可愛呀……♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好想就這樣讓他安穩地睡下去～",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好想寵著他呀……♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是，不行。",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我要狠下心來",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "叫他起床。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}的雙親出差去了，",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n他們特別交代我「就麻煩靜流叫醒他了～」",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯。",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n為了讓大家認知到我是{player}的姐姐，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就連雙親那邊，我都做好完美的準備。",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "他們很喜歡我呢。",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我可是透過合法管道",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "拿到備份鑰匙的喔♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你已經逃離不了",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_031"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐的手掌心了，\n{player}……♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇啊！？",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你、你不要這麼突然起身啦，{player}！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好痛……",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_033"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n臉湊得太近了，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n直接撞上了起身的{player}！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗚嗚，",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_034"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "流鼻血了……",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n居然讓姐姐吃了一記頭槌，",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "看來{player}也成長了不少呢！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵呵，",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_035"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你已經超越姐姐了呢……♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_036"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "早安～！",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿，",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_037"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有乖乖打招呼，很棒喔♪",
        "unit_id": 104931
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104931,
        "voice": "vo_adv_1049004_038"
    },
    {
        "type": "dialogue",
