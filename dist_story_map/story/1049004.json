        "words": "啊？",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_072"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n「菲歐」的干擾？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "菲歐又是什麼？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是我不知道的名詞耶！？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_073"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n哇，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你醒來了，{player}？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呃，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "抱歉，公會長。",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_074"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我先中斷通訊魔法喔！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "之後我再去找妳，",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_075"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n妳要解釋清楚喔！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那就先這樣了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "拜拜！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……真是的。",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_076"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那個，{player}？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你還好嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有沒有哪裡不舒服？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你的樣子突然不太對勁，",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_077"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我好擔心你啊……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯？",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_078"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n喔，嗯。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "本來說好",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "要一起去買東西的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過現在好像",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_079"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不是做這種事的時候。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼？",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_080"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你要買姐姐喜歡的東西",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n送給我嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為、",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_081"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "為什麼呀？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你怎麼突然對我這麼好。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒有啦，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我超級開心的呀。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你說是",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_082"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n平時承蒙我照顧的",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "謝禮……？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我、",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我有那麼照顧你嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我已經試著",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_083"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n盡量不去接觸{player}了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_084"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n{player}，你的這份心意，我很高興。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有點想哭呢♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那我們",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_085"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "買成對的馬克杯吧！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n夫妻會用的那種！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "如果",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_086"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "平時用對杯的話……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n即使你在遠方，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我也可以隨時想起{player}。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就像是生活在一起的感覺，",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_087"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "所以……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不管距離再怎麼遙遠，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們都像是親姐弟一樣。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這樣的想法",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_088"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n會很噁心嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可以嗎？",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_089"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們就去挑一對這個鎮上最好看的馬克杯！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我們去四處逛逛吧～{player}♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿，",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_090"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為{player}說了很令人開心的話，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以今天也是{player}紀念日～",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐的行事曆上",
        "unit_id": 104911,
        "voice": "vo_adv_1049004_091"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n又多了一個",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "{player}紀念日了呢♪",
        "unit_id": 104911
    }
