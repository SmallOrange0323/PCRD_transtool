[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被鈴奈叫了出來――"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，秀才！ ",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈嚕！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "非常準時。",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不愧是秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼就走吧。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃？你問說要去哪裡……？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？人家沒有說明嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今天希望你陪人家去買東西喔。",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為下次有時裝秀，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家想說先來做些準備。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然人家自己決定也可以，",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_004"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但參考別人的意見還是很重要的吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以想要秀才給點建議喔。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為人家覺得秀才很可靠！",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼就朝商店出～發！",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "抵達！",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_006"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這間是人家常來的香水店喔～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "呃？你問為什麼是香水？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為是時裝秀，所以你以為人家要買的是衣服？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才什麼都不懂呢～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "因為用香水能提高興致，",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n也能更加突顯出人家和人家穿的衣服。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是這樣，麻煩你提出意見～",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼？對香水不熟悉……？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_011"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒關係，沒關係。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那方面就憑感覺囉？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這裡的香水可以試用喔。",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家會先試用一點看看，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才只要說出自己的感想就可以了。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，可是香水的味道",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "也有各種不同的效果喔～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個嘛，比如說……",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……有了！這個這個。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "用這種柑橘系列的香水，有使人恢復活力的效果喔～",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "除此之外！聽說還有瘦身的效果呢！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n很厲害對吧～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如何？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家有變瘦嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……不可能那麼快就能瘦下來？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣啊。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，那麼這個……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如何如何？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n聽說噴了這個香水後，就會散發出清純的感覺！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你看！你看！",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家有變清純嗎！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……沒有變得清純的感覺？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_020"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗚～是這樣子的嗎～？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊，對了！",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_021"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那就噴這款珍藏香水！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如何？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_022"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n有沒有感覺人家變得不一樣了？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "怎麼會？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_023"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你不覺得人家看起來更有魅力嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，你在敷衍人家對吧？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好奇怪？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_025"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n這明明寫說是會讓男人神魂顛倒的香氣？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才太遲鈍了～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家還想說如果噴了這個香水，",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_026"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n就能讓秀才對人家神魂顛倒呢……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "算了，香水的效果無所謂了。",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_027"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "總之，先試試看各種香水，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才如果有喜歡的味道再告訴人家。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雖然嘗試了各種香水，",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n但都還沒什麼Fu～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼，接著……來試試看這個吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯！？這個香氣是……",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，你覺得這個如何？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是說嘛！",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n感覺跟人家的形象相當搭配！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才也這麼認為！？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家好像也超喜歡這個香氣～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "竟然想著同一件事情，",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_032"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n我們這不是意氣超相合嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼，",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今天要買的香水，就決定是它了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦！？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_034"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n秀才，你臉色很難看喔？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "怎麼了嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "熏暈了！？被香水的香氣！？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這下不妙了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n趕快到外面去！",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，沒事吧？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_036"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n香水的味道，如果不習慣就會覺得不舒服呢～",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "總之，不買香水了，",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_037"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n要不要到那邊的咖啡廳喝杯茶？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "在秀才恢復前休息一下吧。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "什麼～？你叫人家不用在意，去買香水也沒關係……？",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_038"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這樣啊……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "嗯…………",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_039"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是，還是算了吧。",
        "unit_id": 101611,
        "voice": "vo_adv_1016003_040"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n既然秀才不習慣香水味，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
