[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和雪菲"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人來到了蘭德索爾的街道上。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這好像……",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是第一次",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和你兩個人單獨外出呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唔，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就我所記得的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "部分啦。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──從天而降且喪失記憶的少女‧雪菲。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n直到不久之前，她的精神狀態還像個幼童一樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在歷經了某個事件後，恢復成原來的人格。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……貪吃佩可小姐",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在王宮履行她作為公主的職責。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n凱留",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要處理「【美食殿堂】服務活動義務」",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "的進度報告，\n去了一趟",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "公會管理協會。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "媽媽她……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不是啦……！",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "小姐她",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那、那個，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n陪凱留",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一起出門了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……唔！",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "剛、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "剛才那是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……我說錯了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……這也是沒辦法的事嘛。",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我這張嘴",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就記住這個叫法了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……吶，",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "剛才的事我們就忘了吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "今天找你陪著我是因為……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我希望你可以",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "幫我一起找回記憶。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒錯。",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你也知道的，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n完全沒有",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你們救了我之前的記憶。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然現在",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這件事不是真的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼讓人難受……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但就這樣放著不管，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "心裡也會滿不舒暢的，對吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以，",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就是這樣。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n總之，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我打算先在這座城鎮四處走走。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "或許……",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我會看到有印象的建築物，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n或是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有人對我的長相有印象。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……雖然一切的前提",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只是「或許」而已。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個提議對你來說也不差吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n沒有從天而降",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "以前的記憶，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n就這一點來說，我們兩個是一樣的。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然對你來說",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "已經是熟悉的街景了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但為了找回記憶，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "再四處走走看看，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n搞不好會有什麼新發現呀。對吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……謝謝。",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有你陪著我，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真是幫了大忙。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "因為我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不是很清楚這座城鎮",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n哪裡比較熱鬧、哪裡會有危險……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼，",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們要先往哪邊去呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……咦？",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這裡有什麼",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "能夠找回記憶的線索嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n倒是有個肉包的攤販……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "店長1",
        "words": "好，",
        "unit_id": 311,
        "voice": "vo_adv_1064001_015"
    },
    {
        "type": "dialogue",
        "name": "店長1",
        "words": "謝謝惠顧！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "原來如此。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n在四處走動之前，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要先填飽肚子呀。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不、",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在這個時間",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "買點心吃，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣好嗎……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "既然",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你都這麼說了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……啊呣。",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n嚼嚼嚼……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呼。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯。",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有點燙。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……不過，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我不討厭。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "店長2",
        "words": "您好，",
        "unit_id": 411,
        "voice": "vo_adv_1064001_021"
    },
    {
        "type": "dialogue",
        "name": "店長2",
        "words": "歡迎光臨～♪",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唔嗯、唔嗯……",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n鮮奶油份量真驚人……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我不討厭。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "店長3",
        "words": "喲，小伙子！",
        "unit_id": 1411,
        "voice": "vo_adv_1064001_023"
    },
    {
        "type": "dialogue",
        "name": "店長3",
        "words": "今天要吃什麼？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唔嗯、唔嗯……",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_024"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呼。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……因為是現炸的，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "酥酥脆脆的呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n雖然很燙……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但我不討厭。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……那、",
        "unit_id": 106412,
        "voice": "vo_adv_1064001_025"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個。",
