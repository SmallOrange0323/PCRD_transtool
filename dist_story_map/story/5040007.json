[
    {
        "type": "background",
        "background": "500991"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "收拾完監察官詐欺事件的殘局以後，【伊麗莎白牧場】"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n找回了和往常一樣……比往常更忙亂一點的生活。"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "吶，",
        "unit_id": 102611,
        "voice": "vo_adv_5040007_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真陽！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n咲戀育幼院的孩子們來看牛了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我現在可以帶他們去看嗎～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊～！　",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牛現在都在",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "牛舍那裡，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳帶他們過去吧！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是的～",
        "unit_id": 102611,
        "voice": "vo_adv_5040007_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明說好等取回牧場",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就要讓我偷懶的～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n怎麼跟約好的完全不一樣！　",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真陽～妳這個監察官！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那是什麼意思啊……",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "啊！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "說我是騙子的意思嗎！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n抱歉，妳裝傻我卻沒反應過來吐槽。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這一陣子實在是太忙了，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搞笑藝人的敏銳度都下降了啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "本來就沒有多敏……",
        "unit_id": 102611,
        "voice": "vo_adv_5040007_004"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "真陽姐姐！　",
        "unit_id": 111,
        "voice": "vo_adv_5040007_005"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我們來玩囉！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "妳今天一定要教我搞笑段子喔！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔～",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你們來啦！　",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "沒問題！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n今天要",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "讓你見識一下",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "多～～到不行的",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "搞笑段子一百連發！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……雖然不敏銳，",
        "unit_id": 102611,
        "voice": "vo_adv_5040007_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不過既然已經有粉絲的話，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "也算是個正牌搞笑藝人了吧～？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "吶吶，",
        "unit_id": 211,
        "voice": "vo_adv_5040007_008"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "小鈴。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n牛牛在哪裡～？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～",
        "unit_id": 102611,
        "voice": "vo_adv_5040007_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好好好。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在這邊唷。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "一起去看牛吧。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "啊！　",
        "unit_id": 111,
        "voice": "vo_adv_5040007_010"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我也要去看牛！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "真陽姐姐，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "等等見！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n鈴，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "快走吧！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "知道了知道了。",
        "unit_id": 102611,
        "voice": "vo_adv_5040007_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n鈴姐姐會帶你們過去的，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不要急。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真陽，",
        "unit_id": 102811,
        "voice": "vo_adv_5040007_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "午安。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "喔～",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_013"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咲戀。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "歡迎光臨。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "謝謝妳",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "特地帶孩子們過來。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我本來打算馬上帶他們過來的，",
        "unit_id": 102811,
        "voice": "vo_adv_5040007_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過真陽妳們",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那時好像很忙。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然偵訊我們的時候，",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n很快就以不予追究結案了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過因為其他遭到",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那個前監察官詐騙的公會也有不少事情要處理。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我聽說真陽跟{player}一起",
        "unit_id": 102811,
        "voice": "vo_adv_5040007_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n到處去尋找",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "受害者們對吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "有些人幾乎算是用半夜跑路的方式逃跑的，",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以找到他們的時候，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還被誤認為是來討債的，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "亂成一團的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們就這樣",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_018"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "一個一個跟他們解釋，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "他們的公會可以繼續經營下去。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，不過，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就算公會得以復活，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但因為土地和設備遭到破壞\n的緣故",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還要花錢重新整理，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "最後仍然無法經營下去",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "等等，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那又是一大難題。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以，",
        "unit_id": 102811,
        "voice": "vo_adv_5040007_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳就把溫泉牧場的利潤",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "分給了那些公會吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不只是這樣。",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_020"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "最後，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "村人們捐的錢",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n也心懷感激地拿去幫助他們了。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然可能輪不到我說這種話，",
        "unit_id": 102811,
        "voice": "vo_adv_5040007_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過真陽妳",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的是個大好人……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是這樣嗎？",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_022"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "不過，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這次的事件",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也接受了很多人的幫助。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n有恩就得要回報的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這次的事件",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_023"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也是因為農業公會之間的關係過於疏離",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "而導致的，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "藉著這個機會，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我們決定大家一起互助合作發展下去。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "溫泉本來就像是天上掉下來的禮物，",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_024"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "所以我覺得用這樣的方式處理也不錯的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "本來我聽了【伊麗莎白牧場】的情況，",
        "unit_id": 102811,
        "voice": "vo_adv_5040007_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n想要推辭",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳給咲戀育幼院的捐贈，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過既然妳人好成這樣，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那我也不需要客氣了吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那當然的啦！",
        "unit_id": 103311,
        "voice": "vo_adv_5040007_026"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就算",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "咲戀妳說不需要，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我也會繼續捐贈的！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "敬請期待！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵。",
        "unit_id": 102811,
        "voice": "vo_adv_5040007_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811
    },
    {
