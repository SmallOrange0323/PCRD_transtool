        "words": "{player}與璃乃來到了回憶中的公園。"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯～",
        "unit_id": 101112,
        "voice": "vo_adv_1011011_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "天氣真好呢！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這種天就是……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是說呢！",
        "unit_id": 101112,
        "voice": "vo_adv_1011011_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "難得哥哥都陪我來了，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n要好好念書囉！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是說呢～",
        "unit_id": 101112,
        "voice": "vo_adv_1011011_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天就這樣睡個午覺……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不可以啦！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "差距就是在這種時候拉開的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，",
        "unit_id": 101112,
        "voice": "vo_adv_1011011_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一起加油吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "首先第一題！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　『請回答以下魔物的名稱。』",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112,
        "voice": "vo_adv_1011011_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　我問題都還沒讀到最後，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥就已經知道答案了嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你不需要那樣發光來吸引注意也沒關係……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸！",
        "unit_id": 101112,
        "voice": "vo_adv_1011011_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　哇哇哇！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n你又在發光了耶！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這種時候……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101112,
        "voice": "vo_adv_1011011_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　該不會",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "連我都在發光了？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呀啊啊……！",
        "unit_id": 101112
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "找到了！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喂――",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥――！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿，",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "居然在這種地方碰面，真巧呢！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n怎麼了嗎？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……其實",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這都是騙人的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我事前",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "跟媽媽打聽調查過了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天叔叔和阿姨都不在，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "家裡只有哥哥一個人！　",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我要在這裡逮住哥哥，",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然後去幫他做飯，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "向他展現我的優點！　",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿～",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你是來買今晚的晚餐呀。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你自己一個人會下廚嗎？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是的～",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真拿你沒辦法耶。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我來幫你吧。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "既然決定了，",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "首先得去買晚餐的材料！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們走吧！",
        "unit_id": 101131
    },
    {
        "type": "background",
        "background": "510040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒有家人在，自己一個人吃飯……",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "很容易就會隨便亂吃，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但這種時候更該注重均衡的飲食喔！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會做出好吃又有滿滿愛情的",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "料理給你吃的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "交給我吧！",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "別看我這樣，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我可是有認真練習做飯喔。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你要幫我拿購物籃？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那就麻煩你了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣子，",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "感覺",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就像新婚夫妻來買東西一樣呢～",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有什麼想吃的東西嗎？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "出、",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "出現了，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "『都可以』……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那是讓人感到困擾的回答第一名喔，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個回答……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那回答要是說太多次，",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是會從新婚家庭一口氣進入倦怠期喔！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n你要多注意喔，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒關係。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我對哥哥想吃的東西瞭若指掌。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呵呵，",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我可不是白白當哥哥的妹妹這麼多年的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我會準確猜中",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥想吃的東西！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "『硬要說的話就是",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "固體？』",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "原來如此原來如此。",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "『偶爾會出現在餐桌上？』",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我能知道囉……！",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就決定是這個了！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　『哥哥愛吃的東西？』",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我知道了！",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那就是！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　『咖哩』！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n如何？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "　我猜中了，對吧？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "很好，",
        "unit_id": 101131,
        "voice": "vo_adv_1011011_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我當然早就知道囉。",
        "unit_id": 101131
    },
    {
