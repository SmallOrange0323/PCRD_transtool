    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那天，送完東西的{player}\n在回家路上，發現了在遠處有煙霧往上竄。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "他以為是失火了，慌慌張張地往冒煙的地方跑去，\n發現是正在燒落葉和樹枝的妮諾。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻啪啪！",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n啪噠啪噠！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呼――",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呼――！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嘿――！",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　將軍",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "駕到是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你真是早到是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你馬上就過來了，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我好開心是也！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯？",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　這不是失火喔。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這叫作狼煙，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是東國的連絡方式是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "升起大大的濃煙，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就能和在遠方的夥伴連絡。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "今天的天氣不錯，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是極佳的升狼煙的天氣，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以我就試看看了。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "像這樣子，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "為了能升起濃煙變成狼煙，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n必須要收集很多",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "小樹枝",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "和小樹葉才行。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖然非常辛苦，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不過不管什麼事",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "都是從小事",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一點一滴積累起來的是也！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "喔！",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": " 是這樣子。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我今天的呼叫，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n是因為想要指引將軍",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "去某個地點。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那是哪裡，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我想",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看我的穿著就知道了吧。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這是東國的",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍者傳統服飾是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那麼，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們立刻過去吧！",
        "unit_id": 109611
    },
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "妮諾這麼說後，帶著{player}前往的地方是\n散發著東國風情的大江戶町的一角，\n有很多人愉快地投擲著手裏劍的遊樂場。"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嘿！",
        "unit_id": 111,
        "voice": "vo_adv_1096001_009"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "太棒啦！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "　射中了！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "呵呵呵。",
        "unit_id": 511,
        "voice": "vo_adv_1096001_010"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "小朋友，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "您真厲害呢。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在這裡，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不分老少",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大家都能一起玩。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這正是",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "理想的城市風景是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍為了",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "統一天下十分忙碌，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這點我非常清楚是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正因如此，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我才想說偶爾也該放鬆一下，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "才帶你私訪這間",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "遊樂場的是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "來吧來吧，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "請讓我借用你的手是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我已經申請了投到飽方案，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "還請你拚命的投吧！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……嗯？",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n你一直盯著手裏劍，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是怎麼了嗎？",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "什麼！",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_015"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　問題是那個啊！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我記得將軍你的",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "武器是印盒與威勢，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以不會扔手裏劍",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是正常的呢。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "既然如此，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_016"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就由我來教你",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "投擲方法是也！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不愧是將軍！",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_017"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "一開始",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "連要往前方投擲都很困難的手裏劍，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這麼快就能夠",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "命中目標，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真是太厲害了是也！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "如果是將軍的話，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n在今天內",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就能厲害到能夠使用",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "手裏劍忍法了吧！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "投擲手裏劍的比賽，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n裡面有一次機會",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可以使用各種手裏劍忍法，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n大家稱其為",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍法Chance。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這是能影響勝敗，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_020"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "非常重要的規則。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "學習手裏劍忍法",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是沒有壞處的！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_021"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在那之前，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "首先要從控制的特訓開始呢。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "現在將軍的手裏劍",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "扔中的地方，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n以相撲摔角的排名來說，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "得分大約是幕下。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "接下來狀況不錯，",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_023"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "就瞄準目標",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正中間的橫綱區吧！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嘿咻、",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嘿咻！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呣呣！",
        "unit_id": 109611,
        "voice": "vo_adv_1096001_024"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　將軍扔的手裏劍",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "被彈飛了嗎！？",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "？？？",
