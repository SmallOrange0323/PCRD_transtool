[
    {
        "type": "background",
        "background": "500362"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "自從公會之家的二樓開放後，\n又經過了一段時間。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【美食殿堂】的成員們，\n對於依舊被封印著的三樓感到非常在意……\n因此他們得到了花凜的許可，準備開始進行調查。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "姆姆姆姆！",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n『皇家裝備』，火力全開……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拜託妳啦～。",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然我已經解除了魔法封印，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但物理上的封鎖依然是很牢固的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只能強行打開了，",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們之中有怪力女在實在是太好了♪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "加油，",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n揮舞著小小的旗子在為您加油喲♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算{player}為她打氣，",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也幫不了什麼忙啦……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，是這麼回事啊。",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我記得那傢伙好像具有能",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n增強隊友實力的怪異能力？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人也藉由累積經驗，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n逐漸懂得如何去運用這個力量了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人真棒！",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做得非常好喔，主人……♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎覺得可蘿仔比平常要來得興奮呢……",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最起碼也請擺好戰鬥姿態呀，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為不知道有什麼東西會飛過來呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下知道了。",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，請您再站得遠一點。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "花凜小姐也是……",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幾乎沒有戰鬥能力吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果出現魔物的話就會變成飼料喔。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "好的。",
        "unit_id": 190811,
        "voice": "vo_adv_4001003_012"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各位，真的不要緊嗎？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如果感到棘手的話……",
        "unit_id": 190811,
        "voice": "vo_adv_4001003_013"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n也可以委託其他由我負責的",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "力量更強大的公會來調查喔？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用不用～",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果造成其他人的麻煩我們也會過意不去，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟這是我們公會之家自己的問題～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且妳別看這樣子，",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們其實相當有能力的呦？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要凝聚【美食殿堂】公會的力量，",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就沒有辦不到的事～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我非常相信這一點☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別說廢話了，",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n請集中一點呀，貪吃佩可……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n被封鎖的三樓潛藏了危險魔物一事，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n應該還不能完全肯定吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "萬一藏的是金銀財寶之類的……",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那與其他公會牽扯上的話就是愚策呢，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n難得的一筆橫財不就得被人瓜分了嗎。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒想到凱留小姐還挺貪心的呀。",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可是小市民呀。",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟某處的某人不一樣啊。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……喔？",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連接三樓的門出現裂縫了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n狀況不錯喔貪吃佩可，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "乘勢把它給破壞掉吧♪",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚～？",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n由",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "於全力使用了『皇家裝備』的力量，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我現在肚子非常餓！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是出現魔物的話我可能也沒辦法處理～",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那時候就要拜託大家囉？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔喔～好像行得通呢！",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "門上的裂痕越來越大了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n裂縫已經大到可以讓一個人通過了喔！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "數到三我們就衝進去吧！",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一二三……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "Let's Go☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚嗚……？",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咳咳，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n好奇怪的味道！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咳咳！",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺裡面充滿著奇怪的魔力呀，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我來張開防護罩，你們先躲到我的後面去！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，含有水蒸氣的濃厚空氣……",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，應該稱作霧吧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這顏色看起來就像有毒一樣。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吸了可能會有問題，",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還是盡量不要吸入比較好。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n三樓是完全被密封住的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有可能是滯留的混濁空氣噴出來了吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～……？",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_032"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺又不像是單純被污染過的空氣呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "裡面含有異常大量的魔力……",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_033"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幾乎都是肉眼可見的「詛咒」呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我先分析它的構造然後再消除，",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n目前就暫時撒退吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然像是沒有方向性的魔力團塊，",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但如果是沒有抵抗力的人類，光是觸碰到就會身體不適的。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……嗯？",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可呢？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跑去哪了，那傢伙！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個笨蛋！",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n沒頭沒腦地，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就衝到霧裡面去了嗎？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該更注意自身安全，審慎行事啊！",
        "unit_id": 106011,
        "voice": "vo_adv_4001003_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼老是這樣子！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直抱怨也不會有進展的，凱留小姐。",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐因為過度使用『皇家裝備』，",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n體力應該消耗殆盡了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很有可能沒辦法保護自己的安全。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們救出貪吃佩可小姐時也要小心，",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不要賠了夫人又折兵了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟是同一個公會的夥伴，",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不能見死不救呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人跟花凜小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為慎重起見，請在這裡待命。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果在下等人沒有回來的話，",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就請向其他公會請求救援吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "真，真的不要緊嗎？",
        "unit_id": 190811,
        "voice": "vo_adv_4001003_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的，請不用擔心。",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這種程度的苦難，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下等人至今已經經歷過很多次了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……唉呀，主人也要同行嗎？",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是因為或許能幫上什麼忙嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓我們牽著手一起去吧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請千萬不要離開在下的身邊。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……咦，凱留小姐？",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知什麼時候，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐也消失了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是不是太過擔心貪吃佩可小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以心急地一個人先闖入霧裡了呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那兩個人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n感情真的非常地好呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人？",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n抱歉，您說了什麼嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好意思，請您再說一次。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的聲音很小，",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而且這奇怪的霧好像擾亂了在下的知覺……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒辦法聽清楚。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知不覺，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就被這霧給包圍了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幾乎什麼都看不到了，",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n耳朵跟鼻子好像也有麻痺的感覺？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "五感都變得混亂又模糊，",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n感覺好像在做夢一樣呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是奇怪的霧……",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這到底是什麼呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐～？",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n凱留小姐～？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問您們在哪裡呢？",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請回答在下！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔～再怎麼樣這裡只是室內。",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n明明兩個人應該就在附近，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n卻完全感受不到她們的氣息呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "…………",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……！？",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_062"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒想到您在這麼近的地方呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜託請回應在下！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……豐盛……",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯？",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱歉，您說了什麼？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚哇哇哇！",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是豐盛的大餐耶……☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼一回事！？",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耶嘿～",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_067"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耶嘿嘿……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "今天就決定吃烤肉吧～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是改吃熱火慢燉的燉肉呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真讓人難以抉擇啊～",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "耶嘿嘿嘿嘿♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，咦？",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_069"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n嗚！貪吃佩可小姐！？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼您要砍在下呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "切切剁剁，烤成金黃色～♪",
        "unit_id": 105811,
        "voice": "vo_adv_4001003_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n再灑點香料調調味！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了提味～加入大量的蜂蜜～……☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不、不知為何竟思考著在下的烹調方法！？",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n停……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊、危險！",
        "unit_id": 105911
    },
    {
        "type": "background",
        "background": "500362"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請不要亂來，貪吃佩可小姐！",
        "unit_id": 105911,
        "voice": "vo_adv_4001003_072"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您很明顯是神智不正常了吧！？",
        "unit_id": 105911
    }
]