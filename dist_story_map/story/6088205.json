[
    {
        "type": "background",
        "background": "500354"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "客人們似乎都很開心的樣子，",
        "unit_id": 121311,
        "voice": "vo_adv_6088205_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真是太好了。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然與客人對話",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "跟登台演出不一樣，讓我很緊張，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但能夠直接聽到他們的反饋是件好事。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你是說蘭德索爾以外的地方嗎？",
        "unit_id": 121311,
        "voice": "vo_adv_6088205_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那樣太辛苦了啦～",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在育幼院的庭院裡",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "介紹一些蘭德索爾以外的東西倒是不錯。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我去找秋乃小姐討論看看好了。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "也有那種讓客人參與的舞台吧。",
        "unit_id": 121311,
        "voice": "vo_adv_6088205_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n對耶，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那種舞台也挺不錯的。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我得先練好即興演出的工夫才行。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "感覺不簡單呢。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "很開心能將伊麗莎白牧場的魅力",
        "unit_id": 121311,
        "voice": "vo_adv_6088205_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "傳達給更多人知道……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你是說我有新的魅力？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "請不要突然說這種話好嗎。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我會害羞的。",
        "unit_id": 121311
    }
]