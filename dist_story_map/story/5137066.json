[
    {
        "type": "background",
        "background": "502190"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對志那都跟埃拉兩人來說，這是在蘭德索爾度過的最後一個夜晚……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n埃拉悄悄地溜出了旅館。"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "…………",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_000"
    },
    {
        "type": "dialogue",
        "name": "老人1",
        "words": "這樣的天空，",
        "unit_id": 1,
        "voice": "vo_adv_5137066_001"
    },
    {
        "type": "dialogue",
        "name": "老人1",
        "words": "到底要持續到什麼時候啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人1",
        "words": "\n我覺得好恐怖喔。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人2",
        "words": "是啊，",
        "unit_id": 1,
        "voice": "vo_adv_5137066_002"
    },
    {
        "type": "dialogue",
        "name": "老人2",
        "words": "妳說的沒錯。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人2",
        "words": "\n如果這是天地異變的前兆，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人2",
        "words": "\n那還不如快點發生，心情反而比較輕鬆。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……啊哈哈。",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_003"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n沒事啦，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那邊的爺爺跟奶奶！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "紅色的天空，",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_004"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "很快就會不見了♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n日子會回到以前那樣的！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你們就放心吧～！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "老人1",
        "words": "……是你",
        "unit_id": 1,
        "voice": "vo_adv_5137066_005"
    },
    {
        "type": "dialogue",
        "name": "老人1",
        "words": "認識的人嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人1",
        "words": "\n剛剛那個女孩……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人2",
        "words": "我不認識。",
        "unit_id": 1,
        "voice": "vo_adv_5137066_006"
    },
    {
        "type": "dialogue",
        "name": "老人2",
        "words": "\n不過……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老人2",
        "words": "感覺她有一種莫名的說服力呢。",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哈啊～～～！！",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_007"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n麥酒果然很好喝呢～♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n啊哈哈哈哈！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "哎呀──妳喝得真豪邁！",
        "unit_id": 1,
        "voice": "vo_adv_5137066_008"
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "\n我都要迷上妳了～♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "等一下，",
        "unit_id": 1,
        "voice": "vo_adv_5137066_009"
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "\n迷上她是什麼意思～？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "你想腳踏兩條船嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "我、",
        "unit_id": 1,
        "voice": "vo_adv_5137066_010"
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "我才不是這個意思咧～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "\n我剛剛說的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "是一種形容啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "\n我對妳",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客１",
        "words": "可是一心一意的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "是喔～？",
        "unit_id": 1,
        "voice": "vo_adv_5137066_011"
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "\n…………",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "顧客２",
        "words": "我知道啦♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈！",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_012"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n謝謝你們的放閃，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我大飽眼福了♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n你們兩個",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要繼續這麼要好喔～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……妳果然在這裡啊。",
        "unit_id": 135614,
        "voice": "vo_adv_5137066_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "志那都！",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_014"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳是跟在我後面過來的嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "差不多吧。",
        "unit_id": 135614,
        "voice": "vo_adv_5137066_015"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n……如果大家發現妳偷溜出來的話，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "會很擔心的。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我馬上就會回去啦♪",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_016"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我只是想再喝最後一次這裡的赤麥酒而已。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "再喝最後一次啊。",
        "unit_id": 135614,
        "voice": "vo_adv_5137066_017"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……終於要出發了呢。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是啊，終於。",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_018"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……話說回來，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "待在這裡太久也不太好呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "待在蘭德索爾的期間，",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_019"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "志那都妳也聽到了吧？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n鎮上的人們說的話。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……妳是指紅色夜空的事嗎。",
        "unit_id": 135614,
        "voice": "vo_adv_5137066_020"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "人們的確對此感到很恐怖。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也不是真的發生了什麼大事，",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_021"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但是，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也沒辦法放心。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那樣當然讓人開心不起來呢～",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……這是提醒大家要警戒入侵者",
        "unit_id": 135614,
        "voice": "vo_adv_5137066_022"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "的「警告」。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n確實是達到告知異常狀況的功用。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯，",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_023"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "沒透露出「誰是入侵者」這點倒是很不錯啦。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n多虧這樣，才能在這裡悠閒地喝麥酒……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n也不會被大家斥責。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……這就代表保全程式很有自信吧。",
        "unit_id": 135614,
        "voice": "vo_adv_5137066_024"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "實際上，",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我們也被逼入絕境了。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……是啊。",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_025"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n會這麼有自信也是理所當然的。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "沒能完成目的，找到方法",
        "unit_id": 135614,
        "voice": "vo_adv_5137066_026"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "通往「重置點之後的未來」呢。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n……我們兩個都是。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過，",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_027"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "事情不可能從一開始就很順利呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "放輕鬆一點吧♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "現在，能夠來到這邊就足夠了。",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_028"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n而且──",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "也遇到了大家。",
        "unit_id": 135614,
        "voice": "vo_adv_5137066_029"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n……對吧？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就是這樣♪",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_030"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n啊哈哈哈！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "不好意思，",
        "unit_id": 311,
        "voice": "vo_adv_5137066_031"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "這麼晚才來點餐！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "請問要點什麼呢？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……赤麥酒，",
        "unit_id": 135614,
        "voice": "vo_adv_5137066_032"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "小杯的。",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "我明白了──！",
        "unit_id": 311,
        "voice": "vo_adv_5137066_033"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳不是說不會再喝第二次了嗎～♪",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_034"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……小杯的沒關係吧。",
        "unit_id": 135614,
        "voice": "vo_adv_5137066_035"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "妳有什麼意見嗎？",
        "unit_id": 135614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "沒有，",
        "unit_id": 135512,
        "voice": "vo_adv_5137066_036"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "完～全沒有意見喔。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我反而要謝謝妳，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "陪我一起喝♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為埃拉說的話而害羞起來的志那都，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n默默地摘下了面罩……"
    }
]