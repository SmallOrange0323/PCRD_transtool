    {
        "type": "dialogue",
        "name": "華音",
        "words": "好～",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_000"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "想睡……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n像這樣守夜巡邏，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "如果肌膚變糟的話該怎麼賠我？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "居然連這種平常沒在使用的客房都得巡視……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呀啊啊啊啊啊啊啊！？",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_001"
    },
    {
        "type": "background",
        "background": "502114"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "妳怎麼可以趁別人在換衣服時襲擊呢～",
        "unit_id": 51611,
        "voice": "vo_adv_5205066_002"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "華音小姐～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n騎士閣下先生已經準備睡覺了哦～？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "我可沒聽說阿貓阿馬今天睡在這裡啊！",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_003"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "而且話說",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這太奇怪了吧！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "一般不都是反過來嗎！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "難道阿貓阿馬你要",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "用這種理由來懲罰我！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "準備好了嗎～？",
        "unit_id": 51611,
        "voice": "vo_adv_5205066_004"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "那麼",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "就來表演吧～♪",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "請開始～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……這、",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_005"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這裡",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "就是蘭德索爾的「街道」嗎～？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "然後",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "那邊則是",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "吉歐‧格黑納的",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "「街道」嗎～？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "也就是說",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "是本小姐的勝利",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "「皆大」歡喜～！！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……大、",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_006"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "大事不好～",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "了──！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n鳳凰她",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "燒起來啦！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "烘烘、",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "烘烘、",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "烘凰。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "用麵包？",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_007"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "和麵包？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "從兩邊把臉夾住後～？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "──就完成愚蠢之徒三明治啦～！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "…………我已經，",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_008"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "想不出來了……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n饒了我吧……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "為什麼本小姐要受到這種對待……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "我受夠了～！！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "華音在心靈崩潰後依然持續進行搞笑，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n直到太陽西斜時才終於得到特赦。"
    },
    {
        "type": "background",
        "background": "502301"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "為什麼本小姐是被陪睡的那邊……？",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_009"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n唉……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "你要是敢在睡著時亂來的話",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "我可不會輕易放過你喔。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "那麼，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "晚安。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "話是這樣說，",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_010"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "但這叫我怎麼睡得著～！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n光是守夜巡邏就讓交感神經很緊繃了，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n再加上阿貓阿馬在同個寢室裡，緊張到眼睛根本闔不起來啊！？　",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "不、",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_011"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "不過嘛？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "就算他對我出手，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "也只要斥責一下就好了吧？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "面對如此絕世美女，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哪可能有男士能忍住不出手的呢～♪",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n只要我稍微假裝成睡著的樣子……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呼～",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_012"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呼……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……咦？",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_013"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "好奇怪？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "居然毫無動靜……？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這怎麼可能！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這笨貓笨馬到底在做什麼！？　",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "居然睡著了！？",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_014"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "唉～",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "本小姐像個傻瓜一樣……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "簡直就像是有所期待似的！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "啊",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "糟糕，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "一知道笨貓笨馬已經睡著後，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "睡魔馬上就……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "呼嚕……",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_015"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結果，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人很要好地睡在了一起。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在那之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "華音對沒有發生任何事這點感到安心及不明的屈辱，\n但那又是另一個故事了……"
    },
    {
        "type": "background",
        "background": "502301"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……好了，",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_016"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "快點進到被窩裡。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "早點睡覺吧。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "好好好，",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_017"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "晚安。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n話先說在前頭，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "別期待我",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "會唱什麼搖籃曲或說床前故事──",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "──咦，",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_018"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "已經睡著了？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "再怎麼樣也太快了吧……？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "應該不是在裝睡吧？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "啊、",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "戳戳……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "好～",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_019"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "柔軟……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n以阿貓阿馬的臉頰來說",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "還真是柔軟呢……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "戳戳、",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "戳戳……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "是說，",
        "unit_id": 134912,
        "voice": "vo_adv_5205066_020"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這未免太沒有防備了吧？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n要是本小姐想下殺手",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "隨時都能動手呢。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "不過，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "因為我想要阿貓阿馬的力量",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "所以不會這樣做就是了……",
