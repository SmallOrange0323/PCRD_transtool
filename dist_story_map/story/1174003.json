[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "慈樂之音的巡演順利落幕後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}被紡希叫了出來。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我有話要和你說！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "…………你明天和後天，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有空嗎？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果有事的話",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我只是順便問問你而已！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……什麼？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你有空？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的嗎！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "其實，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這附近",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有個著名的孤島度假勝地，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我拿到了",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那裡的住宿優惠券。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "正好",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "多出了一張，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生不介意的話，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要不要",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一起去呢？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就是可以我才會邀請你嘛。",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你這個人真奇怪。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你什麼意思嘛！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我邀請騎士先生",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有這麼奇怪嗎！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我話先說在前頭，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這是為了還騎士先生的人情。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……因為今年夏天，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我受了你諸多關照。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你有意要來的話，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "明天就到碼頭會合吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那我先走了！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他會來嗎？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他是那種被邀請",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就不會拒絕的人，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一定沒問題的。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "光是要拿到優惠券就費了不少力氣，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我還為了騎士先生特地預約了驚喜晚餐……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不如說，他要是沒來的話我會生氣的！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……是說，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一開始就",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "講清楚不就行了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "在騎士先生面前真的很不坦率耶。",
        "unit_id": 117411
    },
    {
        "type": "background",
        "background": "500280"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天──"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "兩位，",
        "unit_id": 1411,
        "voice": "vo_adv_1174003_013"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "我們到囉。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "歡迎來到",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "祕境之島！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯～！",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "終於到了～！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你覺得這座島的風景",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼樣啊？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哼哼。",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要好好感謝我喔。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這可是憑你自己一個人絕對來不了的地方呢。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "那麼，",
        "unit_id": 1411,
        "voice": "vo_adv_1174003_016"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "我幫你們把行李搬進小屋，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "兩位玩得開心啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你！",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_017"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "……對了對了，",
        "unit_id": 1411,
        "voice": "vo_adv_1174003_018"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "我這裡有個值得一聽的情報。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n聽說這座島的沙灘上，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "散落著一種名為「星之碎片」的美麗沙子。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "據說集滿100個碎片",
        "unit_id": 1411,
        "voice": "vo_adv_1174003_019"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "就能實現願望喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "……像妳這種年紀的姑娘，",
        "unit_id": 1411,
        "voice": "vo_adv_1174003_020"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n或多或少都有一兩個",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "想實現的願望吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "比如",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "和那個男孩子在一起──",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請別開我玩笑啦！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n小心我把你綁起來唷！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "哈哈哈！",
        "unit_id": 1411,
        "voice": "vo_adv_1174003_022"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "妳紅著那張臉發怒",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "可一點也沒有說服力啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "那麼，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "電燈泡就先行告退了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "兩位慢慢來！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那、",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個人一定誤會了……！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什、",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "什麼啊！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……咦，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "白色的沙子？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n仔細一看，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有點像星星的形狀呢……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n難道",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這就是「星之碎片」？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "據說集滿100個碎片",
        "unit_id": 1411,
        "voice": "vo_adv_1174003_026"
    },
    {
        "type": "dialogue",
        "name": "船長",
        "words": "就能實現願望喔。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我的願望……",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說到底",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "願望本來就該由自己實現。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不過，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果是當作一種寄託，收集一下倒也無妨。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生。",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "天黑以前我們各自行動吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我會暫時待在這片沙灘上！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……什麼？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果要收集碎片的話就一起找？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不用了啦。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生偶爾也該好好玩樂。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "又說這種話……",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你真的很囂張耶。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n那你要有心理準備，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n陪我收集到100個碎片為止喔！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這裡已經沒有了呢。",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生那邊呢？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……嗯～",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你那裡也沒有的話，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們再往前找找看吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉。",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "本來是想讓騎士先生好好放鬆的，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "結果反而一直在使喚他……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有玩得開心嗎？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n還是其實他是在費心顧慮我……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "突然下雨了！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們去那裡躲雨吧！！",
        "unit_id": 117411
    },
    {
        "type": "background",
        "background": "500173"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……雨，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "下個沒完呢。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼辦，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這裡離小屋有一大段距離，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "再這樣下去可能會趕不上晚餐……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "反正待在樹蔭下也還是會淋濕，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我們乾脆就這樣回小屋吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那超大片的葉子是！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n該不會",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要拿來當傘吧？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我就恭敬不如從命了……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "距離太近了啦！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種狀態也太……！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這、",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣果然還是太難走了，我──",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚呀啊！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真、",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真危險。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n因為下雨，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "地面",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "變得很滑呢。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個……",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "多虧了你我才沒有摔得滿身泥濘。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "話說",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你的手！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是、",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是要抓到什麼時候啦！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那騎士先生不就會被淋濕嗎！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我知道了啦。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然有點擠，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但總比兩個人一起感冒來得好。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們一起撐吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚嗚……",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "果然還是太近了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雨快點停吧～～",
        "unit_id": 117411
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……雨雖然是停了，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_048"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在都已經晚上了耶！？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們該不會",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是迷路了吧……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可不要啊！",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_049"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我不想騎士先生在這種地方度過一晚！！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為這樣的話……",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我的計畫不就泡湯了嘛！！　",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_051"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說到底，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這本來就不是騎士先生的錯……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總、",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總之！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n停在這裡也沒什麼用，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們繼續前進吧！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚嗚……",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_053"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我居然遷怒他，真是太慚愧了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們現在",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_054"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "本該一邊吃著晚餐，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n一邊愉快地聊著天的……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "別說是盡興而歸了，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_055"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要是讓騎士先生",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "留下了不好的回憶該怎麼辦……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_056"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可是……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我知道了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_058"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "氣氛太尷尬，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我都不敢和騎士先生說話了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_059"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼這麼突然！？",
        "unit_id": 117411
    },
    {
        "type": "still",
        "still": "117400301"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你問我「巡演開心嗎？」……",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_060"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "當、",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "當然開心啊！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這次算是捲土重來，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_061"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以無論是服裝還是編舞",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "都比平時更加用心。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然也有出現一些狀況，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_062"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但克服了這一切的慈樂之音，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "展現了最閃耀的舞台。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這次的演出近乎完美，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是有史以來最棒的演唱會！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且──",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_063"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "透過與騎士先生的訪談，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_064"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我能夠像這樣回顧自己的表現，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "似乎也挺不錯的。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該是",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_065"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "「兼顧」吧。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "無論是裁縫師",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還是偶像，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我都想以專業的身分向頂峰邁進。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "或許有人會覺得",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_066"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該要專注於某一項，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但是，讓他人發光發熱，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也讓自己發光發熱，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對我來說都是必要的。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然達不到小望那種程度，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_067"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但客人們的笑容",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就是我努力的泉源。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我兩邊都不會放棄！",
        "unit_id": 117411
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……喂，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_068"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "幹嘛讓我說些熱血沸騰的話啊！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不要笑啦！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生真的很囂張耶！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，多虧了騎士先生，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_069"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們總算能正常對話了。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n他的這一點",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的很狡猾呢。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……嗯嗯？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_070"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "快看天空。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你看，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那裡有煙。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "說不定是從小屋裡飄出來的？",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也就是說，",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_071"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要順著那股煙就能回去……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "士先生，",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們還來得及。",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "快走吧！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_072"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你問來得及什麼……",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這還用說嗎！",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_073"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n當然是我祕密為騎士先生準備的",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "驚喜晚餐啊！！",
        "unit_id": 117411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "…………",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_074"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊啊啊──！？",
        "unit_id": 117411,
        "voice": "vo_adv_1174003_075"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "紡希難堪的悲鳴"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "響徹夜空。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在這之後，兩人順利回到小屋，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n享受了紡希準備的特別晚餐。"
    }
]