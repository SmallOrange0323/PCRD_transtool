[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──4月1日愚人節。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n【美食殿堂】一行人聽說有不可思議的魔物出現的傳聞，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n便為了調查而來到埃斯特雷拉街道。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……各位，",
        "unit_id": 105911,
        "voice": "vo_adv_0001003_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請多加小心。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根據花凜小姐所說，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個魔物",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎就出現在這一帶。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼，",
        "unit_id": 106011,
        "voice": "vo_adv_0001003_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "無聊透頂。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說什麼……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n魔物正在創造一個類似",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n「看直播時常常出現的遊戲廣告」",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的世界喔。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會做那種蠢事的魔物，",
        "unit_id": 106011,
        "voice": "vo_adv_0001003_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能存在嘛。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "做這種事",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是會有什麼好處啊？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留，",
        "unit_id": 105811,
        "voice": "vo_adv_0001003_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳忘了嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n每年愚人節時，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都會發生很不可思議的事！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……聽妳這麼一說，",
        "unit_id": 106011,
        "voice": "vo_adv_0001003_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像的確是這樣。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像是之前被捲入了一個非常精緻的遊戲世界……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有在更之前，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像還夢到了跟機器人戰鬥的夢……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105911,
        "voice": "vo_adv_0001003_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以說，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們應該認為，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這次又發生了什麼離奇的事。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好。",
        "unit_id": 105811,
        "voice": "vo_adv_0001003_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們就謹慎地進行調查吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……啊，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "奇怪？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那邊的魔物是……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "愚人節～！！",
        "unit_id": 1614,
        "voice": "vo_adv_0001003_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個奇怪的叫聲……",
        "unit_id": 105911,
        "voice": "vo_adv_0001003_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是我們在找的魔物。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 106011,
        "voice": "vo_adv_0001003_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們就馬上收拾掉它吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先下手為強！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "護甲削弱！",
        "unit_id": 106011
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接著是……",
        "unit_id": 106011,
        "voice": "vo_adv_0001003_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去死吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "電光球！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "嗶嗶嗶嗶嗶！？",
        "unit_id": 1614,
        "voice": "vo_adv_0001003_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼哼！",
        "unit_id": 106011,
        "voice": "vo_adv_0001003_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真悲慘～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "解決了嗎！？",
        "unit_id": 105811,
        "voice": "vo_adv_0001003_013"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "愚、",
        "unit_id": 1614,
        "voice": "vo_adv_0001003_014"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "愚、",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "愚、",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "愚人節～！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106011,
        "voice": "vo_adv_0001003_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙是怎樣！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n難道……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是想把我",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "帶到傳說中的奇怪世界去嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n被捲入傻瓜世界這種事，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我可絕對不要啊～！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊，",
        "unit_id": 105811,
        "voice": "vo_adv_0001003_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "老實說，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就覺得事情會發展成這樣！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣下去就不得了了……！",
        "unit_id": 105911,
        "voice": "vo_adv_0001003_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為了解救被囚禁的凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拜託請您",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "助我們一臂之力……！",
        "unit_id": 105911
    }
]