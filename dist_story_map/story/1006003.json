[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥……真的要做嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n在、在這種地方嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為……這個又粗又大的、",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n而且還又硬又粗糙……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呀，哥哥！這麼亂來！？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "摸、摸到了……超級硬邦邦……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥……",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這麼高大的樹茜里爬不上去啊。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥說這個也是特訓之一嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_004"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可、可是……爬樹跟吹薩克斯風，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n好像沒有關係……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……爬樹不只跟體力有關，",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_005"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n還能鍛鍊肌肉是嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "原、原來如此。",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_006"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "吹薩克斯風時，肌力也是必要的呢！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不愧是哥哥……",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不，教練！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "一生都會跟隨著教練的！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……可是，茜里還是害怕爬樹。",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這棵樹非常高大呢……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n如果掉下來可是會受傷的。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥會把我接住嗎？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這樣的話，那茜里就放心了呢！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里要開始爬了喔。",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥，要看好喔？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那個！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊！",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里要掉下去了！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥、哥哥，茜里爬不好……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好、好的！",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_012"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "為了讓哥哥感到滿意 ，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里會加油的！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊……",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥壞心眼。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里在努力了說……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸！？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里沒爬上去就不能回家……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "真、真的要再多加點油呢……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里再試著爬一次囉！",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸～！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗚……茜里還是掉下來了……",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_016"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸！不！那個！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不管試幾次，茜里都爬不上去啊。",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_017"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n第一根樹枝太高了，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里的手勾不到啊……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥、哥哥……",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_018"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里一個人的話，不管爬多久都爬不上去喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦？哥哥問我想說什麼嗎……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_019"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那、那個……要讓茜里自己說出口嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥壞心眼……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯……那個……",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥能幫茜里爬上去嗎？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果哥哥幫忙的話，",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里覺得就爬得上去。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可以嗎！？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "謝謝哥哥！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可是，要怎麼幫忙呢……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_023"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦？哥哥要當茜里的墊腳石！？ ",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那種事茜里怎麼做得出來！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒有其他辦法了……？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我、我知道了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n那麼就麻煩哥哥了喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "若哥哥會痛的話，要趕快跟我說喔？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_025"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿咻……嘿咻……",
        "unit_id": 100611
    },
    {
        "type": "still",
        "still": "100600301"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，哥哥！",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我的手碰到樹枝了喔！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呀，哥哥！",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "現在不能往上看啊！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "吼，哥哥真是個色狼！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請哥哥就這樣靜止不動喔。",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿咻……！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "太棒了！茜里爬上來了喔！",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_029"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……嗯？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_030"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n可是，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "讓哥哥幫忙的話，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n好像就沒有意義了呢……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸，哥哥說什麼呢？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_031"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n沒有說要茜里自己一個人爬……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這麼說的話！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "那麼，茜里及格了嗎！？",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_032"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "太棒了――――！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……哥哥接下來都會幫助我，一直到我增進體力為止嗎？ ",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_033"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n真的嗎！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇！",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_034"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n那麼，茜里就拜託哥哥囉！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "然後……那個……哥哥。",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_035"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里爬上來了是很好，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n可是我現在下不去了……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥請幫助我下去！",
        "unit_id": 100611,
        "voice": "vo_adv_1006003_036"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嘿嘿，馬上就拜託哥哥了。",
        "unit_id": 100611
    }
]