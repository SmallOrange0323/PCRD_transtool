[
    {
        "type": "background",
        "background": "500553"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "はぁ～……",
        "unit_id": 128311,
        "voice": "vo_adv_5134431_000"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nまったく、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "とんだ大晦日でしたよ！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n全然休んだ気がしねーです！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "本当に大忙しっていうか、",
        "unit_id": 128411,
        "voice": "vo_adv_5134431_001"
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "大慌てで爆睡したよ～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "こんなに必死に寝ようとしたの、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "人生で初めてかも。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "何一つ間違ったことは言ってないはずなのに、",
        "unit_id": 128511,
        "voice": "vo_adv_5134431_002"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\nものすごくナンセンスなことを言ってるように聞こえるね……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "でも、",
        "unit_id": 128511,
        "voice": "vo_adv_5134431_003"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "ハツネさんが頑張ってくれたおかげで、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\nランドソルは救われたんだ。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "改めてお礼を言わせてほしい、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "ありがとう。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "ううん、",
        "unit_id": 128411,
        "voice": "vo_adv_5134431_004"
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "私だけのがんばりじゃないよ。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "カスミンもイノリちゃんも、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "他のみんなも、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "\nできることをいっぱい手伝ってくれたし……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "キミも、",
        "unit_id": 128411,
        "voice": "vo_adv_5134431_005"
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "最後まで傍にいてくれたしね。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "すごく頼りになったよ、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "ありがとう♪",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "あ～、",
        "unit_id": 128511,
        "voice": "vo_adv_5134431_006"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "こほん！",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "さて、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "過去を振り返るのはこれくらいにして、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\nそろそろ屋台を見て回るのはどうかな？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "あっ、",
        "unit_id": 128311,
        "voice": "vo_adv_5134431_007"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "そうですね！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n【自警団（カォン）】からの報酬もあるし、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n今財布に入ってるお金は使い切る勢いで",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "食べまくるですよ！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "ハツネちゃん、",
        "unit_id": 128411,
        "voice": "vo_adv_5134431_008"
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "温かいものが食べたいな～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "ずっと寒いとこ歩いてて、",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "凍えちゃいそうだもん。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "それじゃあ、",
        "unit_id": 128511,
        "voice": "vo_adv_5134431_009"
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "たい焼きでも買おうか。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "助手くんも食べたいものがあれば、",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "カスミ",
        "words": "遠慮なく言ってくれたまえ。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "おめでたい日なんだから、",
        "unit_id": 128411,
        "voice": "vo_adv_5134431_010"
    },
    {
        "type": "dialogue",
        "name": "ハツネ",
        "words": "\n思いっきりみんなで楽しもうね！",
        "unit_id": 128411
    }
]