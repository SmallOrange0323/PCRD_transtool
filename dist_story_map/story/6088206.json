[
    {
        "type": "background",
        "background": "501510"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "老鼠們其實也只是",
        "unit_id": 121311,
        "voice": "vo_adv_6088206_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "想要一個自己的棲身之所而已。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然做法，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呃，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不太妥當，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但我也是，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "如果是為了咲戀育幼院，會不會也……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "既然哥哥都這麼說了，",
        "unit_id": 121311,
        "voice": "vo_adv_6088206_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那就沒問題……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "吧？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不對，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就算哥哥沒這麼說，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我也一定不能有問題呢。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "會努力的。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那怎麼可以呢～！",
        "unit_id": 121311,
        "voice": "vo_adv_6088206_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "頭上戴著鍋子的老鼠很可愛呢。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n如果戲劇裡面出現那樣的造型",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "一定很有意思。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那句話",
        "unit_id": 121311,
        "voice": "vo_adv_6088206_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是秋乃小姐的……",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "說得也對。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "人不能只顧著自己，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "得思考出讓大家都能幸福的方法。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n雖然很困難，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但我不能放棄，對吧？",
        "unit_id": 121311
    }
]