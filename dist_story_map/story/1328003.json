        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "允許你坐在吾旁邊。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "今晚可是平安夜哪。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_030"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "難道你要放吾一人度過嗎。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾有諸多事想問你。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_031"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n葡萄酒，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你也喝嗎？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "什麼……？",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_032"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n你居然不喝吾的葡萄酒──",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不過，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_033"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "今晚就原諒你。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "因為是平安夜哪。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n聖誕節是個充滿愛的季節。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你好好享受點心與茶吧。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_034"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "而吾則享受點心與葡萄酒。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n今晚，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就由吾跟你探究解答哲學的問題。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒錯，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_035"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這可是場饗宴。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n既然有葡萄酒與茶",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還有點心的話，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那就該來討論哲學哪。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "而且「吾」本身也，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_036"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "想試著與你更進一步討論。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這亦是為了讓吾面對自己……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_037"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就馬上來吧……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "愛到底為何物。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n你會怎麼去定義？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……話題結束了哪。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_038"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不過別擔心，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_039"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾換個問法。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "用二選一來深度挖掘你的思考。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "愛的本質，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_040"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是給予，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還是接受。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你深思熟慮後認為是哪邊？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "愛的本質，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_041"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是給予嗎……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n也就是說，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "即使要自我犧牲也在所不惜嘛？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "愛的本質，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_042"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是接受嗎……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n也就是說，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "即使要全部肯定也在所不惜嘛？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真是不得了的器量。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_043"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n你為了愛，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "可以奉獻一切是嗎。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "什麼嘛，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_044"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這就收回前言了嗎。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你說吾把話題弄得太誇張了？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "居然敢指使神意，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_045"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "簡直傲慢至極──",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不過",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_046"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "今晚就原諒你。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "因為是平安夜哪。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "倒不如說，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "若是不能坦誠地對答就沒意義了。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那麼，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_047"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "下一個二選一。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n愛是，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "情感",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還是選擇。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你認為愛是自然湧現的情感。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_048"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n正因為有情感上的交流，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "才能維持住愛是嘛。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "乍看之下，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_049"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是很浪漫的思考，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但若假設當情感交流結束時，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "愛也會跟著結束的話，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這種思考方式或許需要相對的覺悟哪。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你認為愛是根據有意識地去選擇，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_050"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "來維持的是嗎。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n沒想到",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你意外理性哪。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但這得要看看你的優先順位，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_051"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "以及選擇的基準擺放於何處。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "根據情況不同，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "愛的結局",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "肯定也會不同哪。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "熱身該結束了。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_052"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n那麼，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就讓吾等來引導真正的解答吧。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n愛到底為何，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "天使與人到底為何，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "絕望到底",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "為何……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與萊拉耶爾反覆討論著哲學的問題。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不管是哪個問題都無法導出完美的答案。"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "咕……",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_053"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "難道說哲學問答，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "無法導出完美的答案嘛……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "公主與冒險者，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_054"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "天使與人，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吉歐‧提格尼亞與蘭德索爾。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "本以為有著不同觀點的吾與你",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "只要徹夜暢談，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就能發現些什麼……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "沒想到即便是吾，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_055"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也沒這麼容易……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…………",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_056"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……確實，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_057"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "如你所說。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然沒能得到答案，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但這是一段很愉快的時光。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯嗯，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_058"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "心靈這個東西",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還真是不可思議哪……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n看似無益的時間也能利用得七彩繽紛……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "最後吾再問你。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_059"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "心靈是為何而存在的，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你的想法為何？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……什麼意思？",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_060"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……為了與夥伴一起，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_061"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n享用美味的料理，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "才會有心靈的存在是嗎？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "嗯嗯……",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_062"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這真是，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "很符合你風格的答案呢。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n你那踏實的答案，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾很中意。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "比起一個人，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_063"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "兩人一起享用的料理會更美味，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n確實是因為",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾等擁有心靈的關係哪。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就像現在，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_064"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不管是點心還是葡萄酒",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "都感覺比平時還要美味。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這是因為，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "與你一起分享點心，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還有共度時光的關係。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "能將國家與種族都不同的吾等，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_065"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "連結起來的方法。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "其中之一就是，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "共享料理嗎……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這樣一想，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_066"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "或許心靈的確是……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n為了像這樣",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "與你一起邊吃東西邊聊天而存在的哪。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呼……",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_067"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然哲學的問答沒有得出答案來，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n但你之所以能夠吸引他人的原因，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾可以推測……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "哈哈哈，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_068"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "感覺情緒高昂起來了哪。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n很好，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "來確認一下",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "現在吾與你",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "能否共享心靈。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾興致來了。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_069"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n就特別",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "由吾來送給你",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "聖誕禮物吧。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n讓你窺探一下",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "天使的內心。",
        "unit_id": 132812
    },
    {
        "type": "still",
        "still": "132800301"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "夜風",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_070"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "將身體的熱氣給吹散了……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "如何，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "很舒服對吧？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_071"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "可別放手哦？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n會真的",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "就這樣掉下去。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "在你下面的是，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_072"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "聖誕節的夜景。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n吾等所守護的城鎮。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "而這則是，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_073"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "天上的景色，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "天使的視角。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n地上與空中，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "看到的東西很不一樣吧。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "天使與人不同，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_074"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不會受到重力的束縛。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾想讓你，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "也來體驗一下吾的感覺。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這就是，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_075"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "由吾所贈送給你的聖誕禮物。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "看到這片夜景，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你有何想法？",
        "unit_id": 132812
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "132800302"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "居然與神意有著相同感想，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_076"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還真是傲慢呢。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真是不得了的氣量。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_077"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n真的是個，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不得了的傢伙……",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "能與你體驗同樣的感動，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_078"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾很高興。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n果然，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "兩個人比一個人好。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……跟吃飯一樣呢。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_079"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……是嗎。",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_080"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不過這是身為人會有的感覺。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n與天使不同。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾只是想與你共享這片景色，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_081"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "很抱歉這樣勉強你。",
        "unit_id": 132812
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "132800302"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "呵呵……",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_082"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "別擔心，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你是不會掉下去的。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n有吾陪著你。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾跟你兩人，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_083"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "在看著一樣的景色。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "現在，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "這樣就夠了。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然吾與你之間，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_084"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "有著不同之處。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但內心的距離，",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "並不遙遠。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n你說對吧？",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_085"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "並不打算揮開你的手。",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "所以，",
        "unit_id": 132812,
        "voice": "vo_adv_1328003_086"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "你也別放開",
        "unit_id": 132812
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "吾的手。",
        "unit_id": 132812
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "平安夜的夜晚。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n萊拉耶爾與{player}一同奔馳在夜空中。"
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後，時間來到隔天──"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "昨晚，",
        "unit_id": 132811,
        "voice": "vo_adv_1328003_087"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "真的是",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "萬分抱歉。",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 132811
    },
    {
        "type": "dialogue",
