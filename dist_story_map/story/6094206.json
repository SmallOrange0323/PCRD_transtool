[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "はかなげな女幽霊……",
        "unit_id": 114011,
        "voice": "vo_adv_6050206_000"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ツムギはどうして私にそんなものを……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "もう少しアグレッシブな幽霊の方が合ってると思うんだけど。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "はかなげ……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "やっぱりよく分からないな。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "例えば",
        "unit_id": 114011,
        "voice": "vo_adv_6050206_001"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "素早くステップを踏んで獲物を追い詰めたり……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "それじゃあ",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "幽霊というより妖怪なのかな？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "でも",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "それなら私でも……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "いや、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "お化け屋敷向きではないね。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "キミみたいな人が居たら、",
        "unit_id": 114011,
        "voice": "vo_adv_6050206_002"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "幽霊にならずに済んだんだろうね。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "そう考えると、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "かわいそうな女性……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ああ、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "そう考えればいいのか。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ありがとう。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "少し糸口がつかめそうだよ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "それを言われたら",
        "unit_id": 114011,
        "voice": "vo_adv_6050206_003"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "もう何も言えないんだけど、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "でも",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "マツリはマツリらしい衣装じゃないか。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\nだったら私も……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "いや、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "やっぱり今回は",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ツムギの望みを叶えてあげよう。",
        "unit_id": 114011
    }
]