    {
        "type": "dialogue",
        "name": "美空",
        "words": "啊，",
        "unit_id": 131213,
        "voice": "vo_adv_5148603_000"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是大家一起拍的合照喔──★",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n這是張好照片呢～",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯呼呼～♪",
        "unit_id": 131111,
        "voice": "vo_adv_5148603_001"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n是張很有趣的照片呢～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "要一一",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "做整理嗎～？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是的。",
        "unit_id": 131611,
        "voice": "vo_adv_5148603_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那麼，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然是合照，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但是有個人躲起來了呢……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "啊～",
        "unit_id": 131111,
        "voice": "vo_adv_5148603_003"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是小卡里莎呢～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n他說他不想被照到，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "所以沒能一起拍啊～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n真的很可惜呢～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "有些人",
        "unit_id": 131213,
        "voice": "vo_adv_5148603_004"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "會討厭拍照啊～",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n尤其是卡里莎那個年紀的人就更多了啊。",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "然後，",
        "unit_id": 131611,
        "voice": "vo_adv_5148603_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "涅婭小姐試著用史萊姆",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n去抓住",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在畫面外的卡里莎先生吧。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小莉莉是在……",
        "unit_id": 131111,
        "voice": "vo_adv_5148603_006"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n把剉冰撒在",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小騎士身上嗎？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小蘭法",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "也嚇到了喔～？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個……",
        "unit_id": 131611,
        "voice": "vo_adv_5148603_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我不是故意那麼做的……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我會打翻",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是有原因的……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "因為美空小姐",
        "unit_id": 131611,
        "voice": "vo_adv_5148603_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "手上拿著炸彈，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "所以我慌了……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "應該說，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "為什麼美空小姐要拿著炸彈？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "其實",
        "unit_id": 131213,
        "voice": "vo_adv_5148603_009"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我把西瓜跟炸彈搞混了啊～",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "它們的形狀",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "還挺像的對吧？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "原來如此……",
        "unit_id": 131611,
        "voice": "vo_adv_5148603_010"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不對，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有很像嗎？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "再怎麼說那個",
        "unit_id": 131111,
        "voice": "vo_adv_5148603_011"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "應該是玩具炸彈吧？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n是開玩笑用的道具？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是啊，",
        "unit_id": 131213,
        "voice": "vo_adv_5148603_012"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "當然★",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n託它的福，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那變成到一張很熱鬧的照片了喔。",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯～確實",
        "unit_id": 131111,
        "voice": "vo_adv_5148603_013"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是那樣吧？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n小騎士還是一樣帶著笑容。",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "這果然",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是張好照片吧。",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是的。",
        "unit_id": 131611,
        "voice": "vo_adv_5148603_014"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n雖然是支離破碎的，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n但是傳達出很熱鬧又開心的氣氛。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯♡",
        "unit_id": 131111,
        "voice": "vo_adv_5148603_015"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n有留下照片真是太好了～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "呵呵。",
        "unit_id": 131213,
        "voice": "vo_adv_5148603_016"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n就是說啊★",
        "unit_id": 131213
    },
    {
        "type": "still",
        "still": "end"
    }
