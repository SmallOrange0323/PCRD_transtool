[
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就在{player}一行人，正準備開始進行反擊的時候。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n矛依未仍還正在獨自一人揮舞著手中的那把劍――"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "轟飛他們！",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_000"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n天樓霸斷劍……！",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呼、",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呼……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然這附近的魔物大概都解決了……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但我的體力，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也差不多要到極限了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家究竟都到哪裡去了……！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是因為一片大混戰，",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以大家都分散了嗎……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "該不會，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "把我們全部打散這件事本身，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就是真那所設下的圈套嗎？　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可惡呀……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊、啊啊～",
        "unit_id": 105411,
        "voice": "vo_adv_2014099_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n喂～，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂～～！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "！？",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是誰！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是通訊魔法嗎……？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳好～初次見面！",
        "unit_id": 105411,
        "voice": "vo_adv_2014099_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我是",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "【慈樂之音】的紡希。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳是……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對！　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是矛依未對吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是、",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是我沒錯……？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n總覺得",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有點可疑呢……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然這麼突然有點不好意思，",
        "unit_id": 105411,
        "voice": "vo_adv_2014099_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但妳那邊有一大群的魔物正準備過去了唷！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以還請沿著那條主幹道，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "往南邊的方向前進！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n然後再請妳",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "和其他的人會合――……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯……",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我知道了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳這傢伙，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是真那的……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是霸瞳皇帝的手下對吧！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦！？",
        "unit_id": 105411,
        "voice": "vo_adv_2014099_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不是啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳講這話也太失禮了吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳是打算對我設下陷阱，",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n把我引誘到魔物那邊對吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真遺憾呀！　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我就給妳往反方向去啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "給、",
        "unit_id": 105411,
        "voice": "vo_adv_2014099_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "給我等一下呀～！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n聽人說話啊～！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊～啊～啊～！",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n吵死了妳這敵人！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n啊～啊～啊～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔哇，",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "魔物！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "咕……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我、",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我已經沒有用天樓霸斷劍的體力了……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "痛、",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "痛死了……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "慘了……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "諾維姆！",
        "unit_id": 1,
        "voice": "vo_adv_2014099_015"
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "得、",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "得救了……？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n剛剛的鞭子……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "加上，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛剛的聲音！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀！",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n果然",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是你呀！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且你剛剛",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還叫了我諾維姆……！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……啊。",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_019"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "有這回事？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過這就先放一邊吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "能看妳這麼有精神實在太好囉，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "矛依未。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂～！　",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你剛剛絕對是叫了我諾維姆了吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為什麼又叫回矛依未了啊～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是妳自己聽錯了吧。",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_021"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n就連我剛剛會在那邊救了妳，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "也就只是偶然而已。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊～啊，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真倒楣啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "『王宮』突然間就塌了呀。",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_022"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "原本碰巧我人剛好在中庭所以才沒被捲入，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "「Lucky～！　",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就趁現在悄悄躲起來吧！」",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "而就正當我這麼想時……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就被那彈開瓦礫從廢墟堆中飛了出來的純團長",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_023"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "給逮個正著。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n然後我就開始和她一起，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "救助起其他的同事們……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "在那之後，",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_024"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我又接著被拖去在城內各個地方進行戰鬥呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真～的，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "早知道快點逃掉就好了呀。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哎，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我幹嘛和沒關係的妳",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "浪費唇舌講這麼多呢？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……啊哈哈！",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不管是講話還逃跑，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可不都最擅長了嘛，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你這傢伙！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在不能夠逃避的時候，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你卻又絕對不會逃跑呢……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳又懂了些我的什麼事啊？",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_027"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳不會又要開始說什麼，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我前世是妳的朋友之類的讓人有聽沒有懂的話吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "――你到哪去了！",
        "unit_id": 104711,
        "voice": "vo_adv_2014099_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "尾狗刀！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n又臨陣脫逃了嗎！？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "噁啊，",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_029"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "團長……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……哎呀……",
        "unit_id": 104711,
        "voice": "vo_adv_2014099_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n怎麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "失禮了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你是自發性地，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "來對市民進行救助嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很好很好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小妹妹，",
        "unit_id": 104711,
        "voice": "vo_adv_2014099_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "走得動嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n來吧，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我會派個部下跟在妳身邊的，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n妳就和其他的難民一塊",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "逃往城外吧……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……不對。",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不對唷。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我才不是什麼難民。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_2014099_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不但不是難民……",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也不是你的什麼朋友。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你的搭擋啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是遠比朋友比家人",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都還更加重要的，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "命運共同體啊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……啊哈哈！",
        "unit_id": 104711,
        "voice": "vo_adv_2014099_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n竟然是命運共同體嗎！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真是太好了呢，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "尾狗刀！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "欸欸～？　",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_036"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那是什麼東西啊，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我可沒聽過？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "而且這不是比前世的朋友，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "聽起來更麻煩了嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿嘿，",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且你看啊……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "直到剛才",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我都還暈暈的。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但現在總感覺，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "精神全都湧上來了呀！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那一定是因為尾狗刀你，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛剛呼喊了我的名字的關係唷！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不不，",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_038"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哪有這種可能。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n妳到底有多單純啊，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "矛依未。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那、",
        "unit_id": 105411,
        "voice": "vo_adv_2014099_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個～",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n從一旁……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不對，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "從天上插話不好意思唷～",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊。",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_040"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n【慈樂之音】的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛才我還懷疑妳呢真不好意思！　",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抱歉啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒事沒事～。",
        "unit_id": 105411,
        "voice": "vo_adv_2014099_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "畢竟是非常時期嘛，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且如果再和妳吵下去的話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我還有可能會被怜大人給討厭呢！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n加上――",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "矛依未妳會感覺到力量變強了，",
        "unit_id": 105411,
        "voice": "vo_adv_2014099_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是因為受到了{player}所進行的強化唷～",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "剛剛，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才正好把妳的所在處告訴他了而已～",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是這樣嗎？　",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不和{player}道個謝可不行呢！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在的我不管是來了怎樣的魔物，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好像都能一拳揍飛呢！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔呣……",
        "unit_id": 104711,
        "voice": "vo_adv_2014099_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小妹妹。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們【王宮騎士團】也一樣，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n現在正與{player}他們和【慈樂之音】分頭，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n準備將城裡的魔物們全部給解決乾淨……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如何？",
        "unit_id": 104711,
        "voice": "vo_adv_2014099_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若妳不介意的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "願不願意助我們一臂之力呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n當然，妳那命運共同體的尾狗刀也會一起來唷。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "欸～？　",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_046"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我說團長呀～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n這孩子只是普通人――",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦！　",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "當然好！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n一起戰鬥吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "鎧甲人！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "順便，",
        "unit_id": 106113,
        "voice": "vo_adv_2014099_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為了不要讓尾狗刀能夠在後面偷懶，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就讓我來好好的監視他吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哈哈，",
        "unit_id": 104711,
        "voice": "vo_adv_2014099_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那還真是幫了大忙了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊～真是的……",
        "unit_id": 106211,
        "voice": "vo_adv_2014099_050"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真的很不走運呀，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "最近的我。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "既然如此，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那我也只好拿那群魔物來洩恨了～",
        "unit_id": 106211
    },
    {
