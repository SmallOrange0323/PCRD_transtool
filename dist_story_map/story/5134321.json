[
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯……",
        "unit_id": 128411,
        "voice": "vo_adv_5134321_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "唔嗯唔嗯……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我怎麼又在宇宙空間裡！？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳終於醒了啊。",
        "unit_id": 128311,
        "voice": "vo_adv_5134321_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒錯，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這裡就是妳應該生存的，真正的",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "現實。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳至今為止所認為的現實世界，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "才是一場夢。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "祈梨在說些感覺她絕對不會說的話，",
        "unit_id": 128411,
        "voice": "vo_adv_5134321_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這肯定是夢沒有錯！！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我是不是不小心打瞌睡了呢……？",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "比起那個，Psycho★初音！",
        "unit_id": 112211,
        "voice": "vo_adv_5134321_003"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n我們必須盡快阻止隕石撞上除夕的鐘才行！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "要是讓鐘響了108次，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "煩惱就會爆炸四散，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "導致人類滅亡啊！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小霞還是魔法少女型態！",
        "unit_id": 128411,
        "voice": "vo_adv_5134321_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "然後剛才好像說明了很多事，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n但是內容太過莫名其妙，我完全沒有聽進去！！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳在說什麼東西啊？",
        "unit_id": 128311,
        "voice": "vo_adv_5134321_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "隕石衝撞除夕的鐘會導致不可逆的世界滅亡，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這可是能用熱力學第二法則解釋的",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "公理。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "但是，",
        "unit_id": 112211,
        "voice": "vo_adv_5134321_006"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "愛與魔法是可以扭曲物理法則的！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "來吧，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "Psycho★初音！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "跟我Misty★霞一起，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "拋棄邏輯思考，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "用魔法之力來迎接新年吧！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……啊！？",
        "unit_id": 128411,
        "voice": "vo_adv_5134321_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "太好了，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "順利醒過來了……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這下就能安心……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
