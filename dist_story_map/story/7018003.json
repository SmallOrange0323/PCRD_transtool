[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一行人一邊尋找出口，一邊想辦法處理附身在鈴莓身上的惡靈。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但面對這前途堪憂的情況，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "忍不自覺地一直在嘆氣。"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "居然沒辦法拯救想幫助的人……",
        "unit_id": 103111,
        "voice": "vo_adv_7018003_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我是個失職的",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "靈媒啊……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "忍非常沮喪呢……",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這是我造成的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該怎麼向她搭話才好呢……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這是個好點子呢！",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們也走了很多路，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就來吃飯吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這是女僕的本分，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "包在我身上！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "事情就是這樣！",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鏘鏘～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這是簡易午餐套餐！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請各位",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "享用吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也可以吃嗎？",
        "unit_id": 103111,
        "voice": "vo_adv_7018003_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但這是鈴莓為",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}做的……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我做了很多，",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以沒關係喔！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……雖然說",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我不太能",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "保證這會好吃。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "來，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請妳坐這裡吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝。",
        "unit_id": 103111,
        "voice": "vo_adv_7018003_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其實",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也餓了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那我開動了……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如何！？",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是能好好嚥下肚的味道嗎！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也曾為重要的人",
        "unit_id": 103111,
        "voice": "vo_adv_7018003_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "製作過點心。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我能懂喔。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是充滿了愛情",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而十分美味的餐點呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "忍……",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘻嘻，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我好開心♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n忍笑起來時",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "果然也很漂亮呢！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……啊，",
        "unit_id": 103111,
        "voice": "vo_adv_7018003_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對不起。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我露出的",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "表情一直都很可怕吧……？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我也經常讓來占卜的人",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一臉尷尬。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒有沒有！",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "與其說是可怕的表情，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "更該說是認真的表情喔！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就和我在服侍的大小姐一樣，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我能感覺到那是在擔心我",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "又為我著想的……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "溫柔的眼神。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我覺得很高興。",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為妳很認真地",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在為我著想。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "忍絕對",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不可怕。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "忍是非常溫柔的人！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這是不會錯的！！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵……",
        "unit_id": 103111,
        "voice": "vo_adv_7018003_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "聽妳說得這麼鏗鏘有力，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n會讓原本沮喪的心情都消失不見呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n鈴莓，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝妳。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的♪",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_014"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這都要歸功於你提議",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說要一起來吃飯！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對了對了，",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我還挑戰做了{player}愛吃的菜喔！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不嫌棄的話，就請你盡情享用吧♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝招待。",
        "unit_id": 103111,
        "voice": "vo_adv_7018003_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n真希望我能做些什麼",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "來和鈴莓道謝……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣的話，",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "能不能也為我占卜呢！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "……嗯，",
        "unit_id": 2411,
        "voice": "vo_adv_7018003_018"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "但占卜的結果可說是顯而易見啊。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，你安靜一點。",
        "unit_id": 103111,
        "voice": "vo_adv_7018003_019"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那我",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要來占卜囉。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好緊張……！",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_020"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……占卜出來了。",
        "unit_id": 103111,
        "voice": "vo_adv_7018003_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "結果是",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "大凶。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n就算到了明天",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "或是大後天，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好像還是會繼續維持同樣的運勢……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "打擊好沉重……",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大凶……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這果然代表了",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "「我會一直冒冒失失的」對吧……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "「會一直冒冒失失的」",
        "unit_id": 103111,
        "voice": "vo_adv_7018003_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……我是沒算到這個結果，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但今天……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有特別明顯的火難之相。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n請妳小心，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不要靠近火源。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我知道了！",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我今天絕對不會",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "靠近火源的！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我才剛這麼想……！！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就遇上了一群魔物嗎？",
        "unit_id": 2411,
        "voice": "vo_adv_7018003_026"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "而且那群傢伙",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "還用火用得毫不客氣。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n真的就和忍的占卜一樣啊！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "哎呀～",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "真不愧是本大爺的女兒！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "遇到這種狀況，",
        "unit_id": 102511,
        "voice": "vo_adv_7018003_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我該怎麼辦才好！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "忍",
