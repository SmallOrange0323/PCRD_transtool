[
    {
        "type": "background",
        "background": "500892"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "偷了不是「龍之卵」，而是「溫泉之卵」的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "祈梨和{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在無賴們的追蹤下四處逃竄。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼、",
        "unit_id": 121611,
        "voice": "vo_adv_1216004_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "應、",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "應該不會再追過來了吧……？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "明明寶物都還了還緊追不放，",
        "unit_id": 121611,
        "voice": "vo_adv_1216004_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是一群纏人的傢伙。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好啦，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓竊賊輕易逃掉的話，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n會很沒面子，這我也明白──",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咿，",
        "unit_id": 121611,
        "voice": "vo_adv_1216004_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好刺眼！？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n難道是",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "被他們打了強光燈嗎？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在眼睛習慣黑暗的時候，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "來這招還真是難受……！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦，",
        "unit_id": 121611,
        "voice": "vo_adv_1216004_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在發光不就是小哥你嗎！？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "難道說……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "又是",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個情境嗎──？",
        "unit_id": 121611
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊！",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n終於找到了，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我想要很久的玩偶！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這家店居然進貨了啊……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "挺能幹的嘛！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我從預定發售的消息出來時就在關注了……",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯嗯，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "品質還真不錯呢。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就跟圖片上看到的一樣。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "變成玩偶後也還是這麼可愛……",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不愧是我主推的遊戲角色呢。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘿嘿♪",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "再等我一下喔，",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我馬上就讓你從裡面出來。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對了，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在那之前要先確認今天的預算才行。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我看看……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔……",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這還真不好說呢。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n好像夠又好像不夠……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但要是不夠的話，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就拿不到了。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然這是理所當然的事。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……憑我的技術，",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "應該是沒問題。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要是沒夾到的話……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就會是白白花了錢，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "最後卻空手而回。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那樣不是很傻嗎？　",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "今天確認有貨後，",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "下次再來夾也是個辦法。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……不過，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也不確定到時會不會還有存貨。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯嗯嗯……",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還是算了吧。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n零用錢要有意義地使用，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫！",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你什麼時候來的啊！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣嚇人對心臟很不好喔！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是啊……",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我剛正想說",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還是算了。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "最一開始是想要的啦。",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "仔細看了看之後……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n總覺得很微妙。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而且",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "實物比想像中的還大，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "帶著走會很顯眼。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n被不認識的傢伙嘲笑的話又會很生氣。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "比起冒著不知能不能拿到手的風險，",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不如拿去買可麗餅還比較聰明。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就像是有句話說君子怎麼樣什麼的。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你真的是，",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到底從什麼時候開始看的啊？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……雖然，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也不是沒有那回事啦。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你說要幫我，",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是能幫忙什麼？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼啊，",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種說詞。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n好像靠得住，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "又好像靠不太住……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不用了，",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_022"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你不要這麼輕易就把錢包拿出來啦！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我也不是那種",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "見錢眼開的人！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我知道你很可靠了，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "快點收起來吧！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總之，",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我明白小哥你的心意了。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然小哥你都這麼說……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n而且我也不是不想要……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那就夾吧……",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就夾給你看！",
        "unit_id": 106631
    },
    {
        "type": "still",
        "still": "121600401"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看仔細囉，",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n只要我親自出手，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種程度根本輕輕鬆鬆！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怪、",
        "unit_id": 106631,
        "voice": "vo_adv_1216004_026"
    },
    {
