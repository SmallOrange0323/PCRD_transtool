[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在街上散步的伊莉亞與{player}，突然被不可思議的光芒所包覆。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這道光是怎麼回事？",
        "unit_id": 104412,
        "voice": "vo_adv_1044004_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n該不會，是對妾身發動的攻擊嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼！",
        "unit_id": 104412,
        "voice": "vo_adv_1044004_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n竟然敢攻擊妾身，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n膽子還不小呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是，你用不著慌張。",
        "unit_id": 104412,
        "voice": "vo_adv_1044004_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身會保護你的，放心吧。",
        "unit_id": 104412
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "恭喜！",
        "unit_id": 1,
        "voice": "vo_adv_1044004_003"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n這是二獎的福袋！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……？",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喔，是你啊。",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n居然在這種地方遇到你，真巧呢。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯，你說這袋子嗎？",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是妾身買番茄汁拿到的。",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n看起來，似乎是獻給妾身的貢品呢。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯，真是用心。",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓妾身馬上來鑑定一下內容吧。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "機會難得。",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n也准你一起看看。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，這是什麼？",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……美顏器？可以讓人變美？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦……拿這玩意兒送給世界上最美的妾身……",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是刻意想惹妾身生氣的嗎？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯……原來如此。",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "原來是這樣，",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n人民總是會對支配者強加過高的理想呢。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是，能順應這種想法才稱得上是支配者。",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n人民的心意，妾身確實地收到了。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……你、你說可愛、嗎……？",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……哼！",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n很不適合用來形容妾身的詞彙呢……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不、不過，既然是從你口中說出來的，",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這次就原諒你吧。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好了，還放了什麼其他的東西呢……？",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……這是？",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n手持式按摩器？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n另外這是……攜帶用迷你加濕器……？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "原來如此，",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n盡是些妾身沒看過的玩意。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "在妾身長眠的這段期間，",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n世界變得很方便呢。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼……這些就是那個叫福袋還是什麼的裡頭全部的東西了吧。",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n算是挺有趣的――",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咦？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看來裡面似乎還有一樣東西呢。",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n讓妾身看看……？",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是……手鐲嗎？",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼，就這設計看來是給男人用的吧。",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "一點都不適合妾身……",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "――好！",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_025"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這個手鐲就給你吧。",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別、",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別會錯意了！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身可沒有特別的意思！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那個……對、對了，是這樣的！",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這只是妾身看在你平時的努力上，",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n賞賜給你的獎勵而己！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你、",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你儘管感謝妾身吧！",
        "unit_id": 104431
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "接下來，今後你也要繼續為了妾身犧牲奉獻！",
        "unit_id": 104431,
        "voice": "vo_adv_1044004_030"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "伊莉亞，即使在那邊仍然還是個孩子呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1044004_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真是可憐……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過要是伊莉亞在那邊以吸血鬼之姿復活的話，",
        "unit_id": 190011,
        "voice": "vo_adv_1044004_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼，事情也會變得很嚴重了呢～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我在這邊的世界，",
        "unit_id": 190011,
        "voice": "vo_adv_1044004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然可以算是神明之類的角色，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但即便是我，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也無法干涉伊莉亞",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個很特別的存在呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但我也只記得，",
        "unit_id": 190011,
        "voice": "vo_adv_1044004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n伊莉亞是位很漂亮的大姐姐就是了……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊，剛才那個是我根據你與伊莉亞的「記憶碎片」所製造出的「夢」。",
        "unit_id": 190011,
        "voice": "vo_adv_1044004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n很懷念嗎？嗯，你還不太明白吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多「記憶碎片」，",
        "unit_id": 190011,
        "voice": "vo_adv_1044004_036"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就可以再讓你看到其他的「夢」了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "看過自己與許多女孩子的「夢」之後……",
        "unit_id": 190011,
        "voice": "vo_adv_1044004_037"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你就能找出這世界的真相了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n加油喔♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次再見囉～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1044004_038"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……？",
        "unit_id": 104412,
        "voice": "vo_adv_1044004_039"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……看起來妾身好像是睡著了呢。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這裡是……蘭德索爾啊。",
        "unit_id": 104412,
        "voice": "vo_adv_1044004_040"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "居然在路上睡著了，這也是妾身力量低落的證據嗎……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而且妾身好像做了一個奇怪的夢……？",
        "unit_id": 104412,
        "voice": "vo_adv_1044004_041"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……什麼？",
        "unit_id": 104412,
        "voice": "vo_adv_1044004_042"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你也做了一個跟妾身在商店街相遇的夢？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "…………嗯。",
        "unit_id": 104412,
        "voice": "vo_adv_1044004_043"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這還真是奇妙。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "算了。",
        "unit_id": 104412,
        "voice": "vo_adv_1044004_044"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n別管那個，咱們繼續散步吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "與夢中一樣，在這個城鎮裡，",
        "unit_id": 104412,
        "voice": "vo_adv_1044004_045"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n也充斥著妾身從沒見過的東西。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若是發現有能夠幫助妾身征服世界的東西，全都要告訴妾身喔。",
        "unit_id": 104412,
        "voice": "vo_adv_1044004_046"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "知道了嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在經歷了一段短暫的神奇體驗之後，\n{player}與伊莉亞繼續散步去了。"
    }
]