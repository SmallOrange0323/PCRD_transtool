[
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我說，",
        "unit_id": 114511,
        "voice": "vo_adv_5054302_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那傢伙",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是不是比剛才更強了？",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是啊。",
        "unit_id": 114611,
        "voice": "vo_adv_5054302_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "攻擊也變得更激烈了。",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "拜它所賜，",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "會場內變得更慘不忍睹了。",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "它該不會是那種，處境越危險就會越強大的類型吧？",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這點也同樣適用於我們！",
        "unit_id": 114411,
        "voice": "vo_adv_5054302_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "每當捲入這種預料之外的麻煩，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們彼此間的羈絆就會加深，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還有，",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "企業家之魂",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也會熊熊燃燒呢！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "確實，",
        "unit_id": 114611,
        "voice": "vo_adv_5054302_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "讓人躍躍欲試呢。",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "再多準備幾張",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "請款單好了！",
        "unit_id": 114611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那傢伙擁有的所有資產，",
        "unit_id": 114511,
        "voice": "vo_adv_5054302_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都是偷盜而得的贓款。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們就儘管大膽地請款，",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再將這些錢財都捐贈出去吧。",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n正好，現在是聖誕季呢！",
        "unit_id": 114511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀，",
        "unit_id": 114411,
        "voice": "vo_adv_5054302_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這真是個好主意呢！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我決定採用了！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼，",
        "unit_id": 114611,
        "voice": "vo_adv_5054302_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我們就更得加把勁了呢！",
        "unit_id": 114611
    }
]