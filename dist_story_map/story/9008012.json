[
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "天空也",
        "unit_id": 105913,
        "voice": "vo_adv_9008012_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "開始有繁星閃耀了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這個季節的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "空氣很清澈，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以星星能看得很清楚。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "流星。",
        "unit_id": 126112,
        "voice": "vo_adv_9008012_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_9008012_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來現在許願",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是晚了一步。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n已經什麼都看不到了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "……我有",
        "unit_id": 126112,
        "voice": "vo_adv_9008012_003"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "幫妳。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n許願。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_9008012_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不愧是普蕾西亞小姐。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您許了什麼願望呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "飯菜。",
        "unit_id": 126112,
        "voice": "vo_adv_9008012_005"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n好吃的那種。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個願望還真有普蕾西亞小姐的風格。",
        "unit_id": 105913,
        "voice": "vo_adv_9008012_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明天一定",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又能吃到好吃的飯菜。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126112,
        "voice": "vo_adv_9008012_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對了，",
        "unit_id": 105913,
        "voice": "vo_adv_9008012_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說到流星……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "去年的除夕夜",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有隕石砸了下來呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "蘭德索爾。",
        "unit_id": 126112,
        "voice": "vo_adv_9008012_009"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n……危機。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是啊。",
        "unit_id": 105913,
        "voice": "vo_adv_9008012_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖說蘭德索爾已經多次",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n面臨困境，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但沒想到會有巨大隕石……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 105913,
        "voice": "vo_adv_9008012_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為主人等人的活躍，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n巨大隕石被",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "打得粉碎了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能夠和平地享用年糕，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "全都是多虧主人等人的功勞。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "巨大……",
        "unit_id": 126112,
        "voice": "vo_adv_9008012_012"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "年糕……",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n…………流口水。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "普蕾西亞小姐？",
        "unit_id": 105913,
        "voice": "vo_adv_9008012_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "願望。",
        "unit_id": 126112,
        "voice": "vo_adv_9008012_014"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n變更。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "我希望。",
        "unit_id": 126112,
        "voice": "vo_adv_9008012_015"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n有巨大的年糕。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "掉下來。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "巨大的年糕嗎……",
        "unit_id": 105913,
        "voice": "vo_adv_9008012_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那地表會變得黏黏的喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這樣蘭德索爾",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又會陷入危機了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請住手。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "沒問題。",
        "unit_id": 126112,
        "voice": "vo_adv_9008012_017"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n我會吃掉。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "拯救……",
        "unit_id": 126112,
        "voice": "vo_adv_9008012_018"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "世界……！",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己創造出世界的危機，",
        "unit_id": 105913,
        "voice": "vo_adv_9008012_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再自己拯救世界……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所謂的自導自演吧，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "普蕾西亞小姐──",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126112,
        "voice": "vo_adv_9008012_020"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n好期待。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_9008012_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天就到此告一個段落吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n以上是「蘭德索爾時光」。",
        "unit_id": 105913
    }
]