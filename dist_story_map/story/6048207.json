    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "街上的人很多都互換了身體，",
        "unit_id": 113812,
        "voice": "vo_adv_6048207_000"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n哥哥怎麼樣呢？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "不想換個身體試試看嗎？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "這樣說也是呢。",
        "unit_id": 113812,
        "voice": "vo_adv_6048207_001"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "不過",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "試著變成其他人",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n也意外還不錯喔？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "怎麼說呢，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "世界會完全不一樣喔！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "雖然我不太會形容，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "真的",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "很厲害喔！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哇～",
        "unit_id": 113812,
        "voice": "vo_adv_6048207_002"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哥哥好色！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "你想用茜里的身體",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "做什麼啊？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "開玩笑的，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "我也很樂意",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "和哥哥互換身體喔！",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "嘻嘻，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "哥哥的身體，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "會是什麼感覺呢？",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "好像很有趣！",
        "unit_id": 113812,
        "voice": "vo_adv_6048207_003"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "不過",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "如果真的變成那樣，",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "姊姊她",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "一定",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n會滿臉通紅然後昏倒吧。",
        "unit_id": 113812
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "沒有實現真是太好了呢。",
        "unit_id": 113812
    }
]