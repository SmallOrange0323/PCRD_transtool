        "words": "【美食殿堂】的各位，",
        "unit_id": 190814,
        "voice": "vo_adv_5056601_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "再次向你們",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "說聲新年快樂！",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "大間的事",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "真是謝謝你們了。",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "花凜！",
        "unit_id": 111811,
        "voice": "vo_adv_5056601_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不會不會～",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼好吃的魚",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n實在難得一見，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我覺得這項差事很賺☆",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有了捕獲巨魚",
        "unit_id": 111911,
        "voice": "vo_adv_5056601_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個寶貴的體驗，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n使得這次跨年極具意義。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n花凜小姐，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下才要向您致謝。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗚──",
        "unit_id": 112011,
        "voice": "vo_adv_5056601_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總覺得一如往常地被哄騙過去了……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n或是該說被那傢伙玩弄在股掌之間嗎……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在大間",
        "unit_id": 190814,
        "voice": "vo_adv_5056601_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所拍攝的大合照沖印好了，",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n所以我今天帶了過來。",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n請收下♪",
        "unit_id": 190814
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "謝謝您！",
        "unit_id": 1,
        "voice": "vo_adv_5056601_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是太棒了……",
        "unit_id": 111911,
        "voice": "vo_adv_5056601_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這張美妙的照片，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "令人能鮮明地回想起",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人的活躍。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該裝飾在哪兒好呢──",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇♪",
        "unit_id": 111811,
        "voice": "vo_adv_5056601_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳看看，小凱留，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拍得超可愛的！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n太讚了吧☆",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳們別被騙了啊！",
        "unit_id": 112011,
        "voice": "vo_adv_5056601_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不出我所料，她果然乘機把照片用在宣傳大間上了……！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還是要另外收取其他酬勞才划算啦！！",
        "unit_id": 112011
    }
]