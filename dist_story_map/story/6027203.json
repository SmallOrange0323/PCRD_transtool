    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "幫派的工作？　",
        "unit_id": 106511,
        "voice": "vo_adv_6027203_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你也有興趣嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過我不是很建議你來做這個。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "都是一些擺攤店員、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n巡邏地盤等……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "無聊到死的工作，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你對這有興趣嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "其實主要是以老大提出的方針，",
        "unit_id": 106511,
        "voice": "vo_adv_6027203_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "然後由我和祈梨負責執行，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n都是些很輕鬆的工作。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "因為我們是重要的夥伴……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她是這麼說的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "說來說去，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "老大還是很顧慮我們的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "而且我同時還有接打手相關的工作，",
        "unit_id": 106511,
        "voice": "vo_adv_6027203_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以也不算太累。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "能夠同時兼做打架相關的工作，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "恐怕也只有我們公會了！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n很多手續她都幫我處理了，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的幫了大忙！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯～",
        "unit_id": 106511,
        "voice": "vo_adv_6027203_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也沒有啦？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "做的事情和一般的打工",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒什麼不同。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "該說是有點沮喪嗎？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "明明她可以多依賴我和祈梨一點呢。",
        "unit_id": 106511
    }
]