    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可璃亞和安涅默涅好不容易完成採購，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n離開了村子，正一起走在街道上。"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "話說回來──",
        "unit_id": 129612,
        "voice": "vo_adv_5207002_000"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n欣特蘭德，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "到底在哪裡？",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦？",
        "unit_id": 126012,
        "voice": "vo_adv_5207002_001"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這個嘛……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我想想……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我記得聽說是",
        "unit_id": 126012,
        "voice": "vo_adv_5207002_002"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "再往東邊……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "走一段路之後，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "更加北邊的地方！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "所以，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我們得先穿越對面的草原。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這樣啊──",
        "unit_id": 129612,
        "voice": "vo_adv_5207002_003"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "地圖上，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "沒有記載位置嗎？",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是、",
        "unit_id": 126012,
        "voice": "vo_adv_5207002_004"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是啊。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n似乎是只以口耳相傳的形式",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "流傳下來……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊，",
        "unit_id": 126012,
        "voice": "vo_adv_5207002_005"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不過，請放心！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我會在途中好好帶路──",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呀！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "──！",
        "unit_id": 129612,
        "voice": "vo_adv_5207002_006"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "痛痛痛……",
        "unit_id": 126012,
        "voice": "vo_adv_5207002_007"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對不起，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我好像有幹勁過了頭。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n這種小傷，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "只要貼上OK繃──",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "…………",
        "unit_id": 129612,
        "voice": "vo_adv_5207002_008"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這是──",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "藥草",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦？",
        "unit_id": 126012,
        "voice": "vo_adv_5207002_009"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "OK繃──",
        "unit_id": 129612,
        "voice": "vo_adv_5207002_010"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n只是遮住傷口，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "對吧。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "那麼，",
        "unit_id": 129612,
        "voice": "vo_adv_5207002_011"
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "請先塗上這個。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "\n",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "這樣做，",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "傷口",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "才會好得快。",
        "unit_id": 129612
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……！",
        "unit_id": 126012,
        "voice": "vo_adv_5207002_012"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "謝謝妳，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "安涅默涅小姐……♪",
        "unit_id": 126012
    },
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "攜手合作誠屬佳事。",
        "unit_id": 129711,
        "voice": "vo_adv_5207002_013"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "且因默涅本就",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是個心地善良的姑娘。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "璃亞",
        "unit_id": 125812,
        "voice": "vo_adv_5207002_014"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "看上去好像也比平時更開朗。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "雖然接下來的路程",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "有段距離……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "啊，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "非常抱歉。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "明明是承蒙馬車夫先生的好意，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "讓我們搭乘馬車……",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "沒關係沒關係！",
        "unit_id": 1411,
        "voice": "vo_adv_5207002_015"
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n對我來說，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "有小姐你們為我護衛，真是幫了大忙！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "最近，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "車夫",
        "words": "這一帶的魔物可多了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物啊……",
        "unit_id": 106012,
        "voice": "vo_adv_5207002_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果村民所說的是真的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n也是想趁現在設法解決啦……",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "502580"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "「夏天快被奪走了」……？",
        "unit_id": 125812,
        "voice": "vo_adv_5207002_017"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n這到底",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是什麼意思呢？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "據傳",
        "unit_id": 414,
        "voice": "vo_adv_5207002_018"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "寒帶地區的魔物最近正在失控！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "聽說它們集結成大群，正在南下前進！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "唔嗯。",
        "unit_id": 129711,
        "voice": "vo_adv_5207002_019"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n寒帶地區之魔物……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那麼，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n失控原因",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是否為北方暑熱難耐？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "這個嘛，",
        "unit_id": 414,
        "voice": "vo_adv_5207002_020"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "雖然是這樣沒錯，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "但正確來說，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "該說是好像有點",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "微妙地",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "不同嗎……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啥？",
        "unit_id": 106012,
        "voice": "vo_adv_5207002_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那是什麼意思？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "傳聞說，",
        "unit_id": 414,
        "voice": "vo_adv_5207002_022"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "該地區的魔物",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "本來就具有高度的智慧和自尊心……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n但會因為敗給炎熱",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "而變得很好捕獲。",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "然後，",
        "unit_id": 414,
        "voice": "vo_adv_5207002_023"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "聽說",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "它們無法原諒這麼愚蠢的自己，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "「那麼，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "就用魔法",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "使天氣變冷，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "讓夏天消失吧──！」",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "似乎是……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "這麼一回事……？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真搞不懂它們是聰明，",
        "unit_id": 106012,
        "voice": "vo_adv_5207002_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是笨蛋了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "不過，大事不好這件事是真的！",
        "unit_id": 414,
        "voice": "vo_adv_5207002_025"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "它們不斷使用冰魔法，不僅使氣溫下降，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n而且農作物也無法生長了！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "最重要的是，",
        "unit_id": 414,
        "voice": "vo_adv_5207002_026"
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "再這樣下去，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "休閒設施的生意也做不成吧？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "這麼一來，我們村子的作物也會賣不出去！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "這……",
        "unit_id": 125812,
        "voice": "vo_adv_5207002_027"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "也可以稱為群輕折軸，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n我們不能置之不理。",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "村人",
        "words": "真的嗎！？",
        "unit_id": 414,
        "voice": "vo_adv_5207002_028"
    },
    {
        "type": "dialogue",
        "name": "村人",
