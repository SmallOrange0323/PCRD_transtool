[
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在、",
        "unit_id": 123911,
        "voice": "vo_adv_5104321_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在那群魔像中，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n還有我們的冒牌貨混在裡面喔！？",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼，",
        "unit_id": 123811,
        "voice": "vo_adv_5104321_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不論外表如何掩飾，說到底也只是冒牌貨。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這種場面實在是太容易理解了。",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "「超越出現於眼前的自身的幻影」……",
        "unit_id": 123811,
        "voice": "vo_adv_5104321_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "對英雄來說，",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這就像是特別量身訂做的情境不是嗎？",
        "unit_id": 123811
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "啊！",
        "unit_id": 123911,
        "voice": "vo_adv_5104321_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的確也是能這麼想呢……！",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "既然如此，",
        "unit_id": 123911,
        "voice": "vo_adv_5104321_004"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我會戰勝這場困境，",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 123911
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "然後在作為英雄的方面更上一層樓的！",
        "unit_id": 123911
    }
]