[
    {
        "type": "background",
        "background": "500033"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]為了讓騎空團的裝備更加充實，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n吉塔等人來到跳蚤市場。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n{player}在會場看到熟識的身影。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]好了，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]該怎麼處理呢……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n啊，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]是少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n你好，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]你也是來買東西的嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]哇，",
        "unit_id": 105712,
        "voice": "vo_adv_5118064_002"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]是【王宮騎士團】的團長……！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n你真的",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]人脈好廣喔。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]這位是……",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]我們是第一次見面",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]對吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n少年，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]你能否替我介紹一下呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]啊，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]妳就是吉塔啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n我常聽少年提起妳喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]我叫純，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n擔任【王宮騎士團】團長一職，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n請多指教。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我才要",
        "unit_id": 105712,
        "voice": "vo_adv_5118064_006"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]請妳多多指教！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我也常聽他提起",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]團長喔。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n聽說團長非常強",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]又可靠……",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]呵呵，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]當面聽人這麼說還真難為情呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n我只是完成",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]自己該負的職責而已。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]不，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]現在只是休息時間。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n所以我才自發性去巡邏會場。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]像這樣的大型活動，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]會有很多觀光客。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n人一多起來，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]就越容易引起糾紛。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n我想在糾紛鬧大之前",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]處理掉。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]是這樣啊。",
        "unit_id": 105712,
        "voice": "vo_adv_5118064_010"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]啊，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]那……",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n那個金色的東西",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]是扣押品還什麼嗎？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]吉塔將視線移向純手上的金色物體。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]啊，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]妳說這個嗎……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n這不是扣押品……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n其實這讓我有點傷腦筋。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]這個叫日緋色金，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]是在異國發現的金屬。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n我在巡邏的時候，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]就順手跟攤販買下來了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]日緋色金……",
        "unit_id": 105712,
        "voice": "vo_adv_5118064_013"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n好不可思議的名字喔。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]照老闆的說法，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]似乎可以作為非常堅固的武具素材。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n我在實際拿到後，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]也體會到它",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]有多堅固。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]被老闆那樣熱情招呼之外，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n我也想說能拿來作為武具的素材使用。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]雖說買下來是沒關係……",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]事到如今，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]我才發現要鍛造成武具，量實在太少了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]要製作全套裝備",
        "unit_id": 105712,
        "voice": "vo_adv_5118064_017"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]確實很困難呢。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]不過，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]要做成武器的選擇可能又太少了。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]果然不該做不習慣的事呢。",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n平常我並不會衝動購物……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]一定是我比自己想的",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]還要受周遭歡樂的氣氛影響吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n讓你們見笑了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]抱歉，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]我希望你們能忘記這件事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]請別放在心上！",
        "unit_id": 105712,
        "voice": "vo_adv_5118064_020"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我也遇過",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]買了之後才煩惱的情況啊。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]聽妳這麼說讓我心情輕鬆多了。",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n謝謝妳，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]吉塔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]……有了，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n就趁這個機會，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]可以順便陪我想想該如何利用它嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n你們兩個的思考",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]應該比我更靈活才對。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我知道了！",
        "unit_id": 105712,
        "voice": "vo_adv_5118064_023"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n不介意的話我們很樂意幫忙！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]得救了。",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n事不宜遲，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]少年，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n你有什麼好點子嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]盾牌嗎……",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n稍微加點工，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]確實是可以",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]做成手持的盾牌呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n其堅固性或許也能讓加工的程序",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]減到最低程度。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]真是個好點子呢，{player}！",
        "unit_id": 105712,
        "voice": "vo_adv_5118064_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]……好，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n那麼，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]我把這個讓給你們。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n希望你們能好好善用它。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]咦？",
        "unit_id": 105712,
        "voice": "vo_adv_5118064_028"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n為、",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]為什麼？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]這是答謝你們提供點子給我啊。",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]\n再說，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]我也不能仰賴盾牌。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]不為別的，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]因為我自己本身",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]就是守護大家的盾牌。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]…………！",
        "unit_id": 105712,
        "voice": "vo_adv_5118064_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "[FFFFFFFF]啊，",
        "unit_id": 104711,
        "voice": "vo_adv_5118064_032"
    },
    {
