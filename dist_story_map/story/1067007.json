[
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，帆稀在自己房間忙著工作，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不知是誰敲響了房門。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是誰啊～？",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您好──！",
        "unit_id": 1,
        "voice": "vo_adv_1067007_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我是來送可麗餅的──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝～",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我不需要～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦咦──！？",
        "unit_id": 1,
        "voice": "vo_adv_1067007_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "別這麼絕情，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "捧個場吃吃看嘛！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要是這麼希望我吃，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n為什麼不直接開門進來呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳還好意思講！",
        "unit_id": 1,
        "voice": "vo_adv_1067007_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n明明光是這個房間就防禦得滴水不漏的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就算我來硬的破解它，",
        "unit_id": 1,
        "voice": "vo_adv_1067007_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "等弄完可麗餅都凉了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n所以快放我進去啦～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我不會亂來的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "拜託！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "唉，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真拿妳沒辦法……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "門鎖已經開了，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想進來的人就進來吧～☆",
        "unit_id": 106711
    },
    {
        "type": "still",
        "still": "106700201"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我我──",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想進來──！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n打擾了──！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哇～",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是有夠做作～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請問妳有何貴幹，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可麗餅店老闆？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來，",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_011"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這是可麗餅請笑納♪",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n晚點我再交給大家分著吃。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以妳自己不吃嗎！？",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "虧我特地做來外送給妳……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "大名鼎鼎的迷宮女王找上門來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n總不可能就只是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為了送可麗餅吧～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個嘛～",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是這麼說沒錯啦……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也希望我只是單純來外送可麗餅的……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過送可麗餅",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也是我前來的真正目的之一！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這點很重要！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "幸會。",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "【龍族巢穴】的公會長。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想想，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳叫做帆稀……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒錯吧？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我叫──",
        "unit_id": 106812
    },
    {
        "type": "still",
        "still": "106700701"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "──模索路晶。",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別名為迷宮女王。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n喔，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在這地方",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我還是稱妳為拉比林斯達比較好？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不，",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "挑妳覺得順口的就行了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我並沒有難搞到對稱呼這種事斤斤計較。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喔～",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n七冠像這樣專程跑來見我，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "究竟是有什麼事呢～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這真是讓人好奇得不得了～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我今天來不為其他事。",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我希望妳能與我合作，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一起對抗【憤怒‧軍團】。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喔喔～！",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳是指那幫人嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒錯，",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那幫人。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我現在說到這邊，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳覺得妳會願意幫忙嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不好意思，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "您請回吧～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嘖，",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喔，這樣啊～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n坦白講，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "最近我們被那幫人給壓著打。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以我覺得再不想想辦法恐怕不妙啊～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此～",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟跳躍王也下落不明，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n總不能再繼續毫無作為嘛～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……真是的，妳到底能看得多遠啊……",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒錯沒錯，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是這樣！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳能一點就通真是太好了～！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "最近這陣子，",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那幫人動作越來越頻繁。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "甚至還跑來試探過我。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要是可以的話，",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我希望能進一步強化蘭德索爾的戒備。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n具體來說，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我需要能夠監視街上一舉一動的耳目。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但是",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對那方面最拿手的人，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n目前被逮住，幫不了我們的忙。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這下就該妳上場了！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我希望妳能用那眼睛的力量，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "佈下監視網。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳願意幫我忙嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……嗯～",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "該怎麼辦呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n老實說，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我實在是提不起興趣啊。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我跟那些人交手過幾次，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_032"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但不太想再跟他們攪和了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我目前的重點在於幕後黑手……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在於該怎麼對付那萬惡的根源。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖說要成就大事就不該忽略小事，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_033"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不過既然有公主殿下他們以及優衣他們在，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該不要緊才對吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "的確。",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "妳說得沒錯。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n剛剛那番話",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "合情合理。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可是……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "算我求妳吧。",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "請助我一臂之力。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n少年他們守護至今的街道與世界，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我不希望被人摧毀。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_036"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_037"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊哈哈♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n想不到七冠竟然會低聲下氣地求我呢～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過呢……",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_038"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其實這個世界",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "早已經毀了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n扭曲不堪，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "充滿虛假……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "關於這點",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想必妳也很清楚吧☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "過去我調查過許許多多的遺跡與場所，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_039"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n資料結構全都變得一塌糊塗。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但是",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_040"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在艾爾皮斯島",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "確實殘留了某些痕跡。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n攪亂這一切的犯人所遺留的痕跡。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那除了犯人，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_041"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就只有我與霸瞳皇帝……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "以及",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像妳這種",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "感應得到物件結構的人才看得出來。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "目前這個世界，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_042"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像那種新生成的物件，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n以及原本就存在的物質產生的變化，都變得更好判讀。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而根據那些痕跡獲得的資訊，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_043"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我原本一度懷疑起優衣……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可惜只是白忙一場～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "關於",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_044"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "【憤怒‧軍團】的成員，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我姑且也試著接觸過，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但他們就只不過是堆棋子。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "明明是在禁錮開始後才特地潛入這裡頭，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_045"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n事前卻沒獲知太多資訊，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只是群可憐的人……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就如我剛說過的，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_046"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的真正目標是他們的贊助者。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n那個擁有超凡力量的傢伙，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "依然躲在幕後尚未現身。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在跟對方正面交手之前，我希望能保留實力。",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_047"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以很抱歉，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我想我不方便幫忙。",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……哎呀，",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_048"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真的是了不起。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看來妳的眼睛，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "確實能夠洞悉一切呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "以單獨調查來說，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能獲得這樣的情報量真是不容易。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊，",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_049"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我說的單獨是指",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在「這邊的世界裡」",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喔？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟身在阿斯特朗要想得到那麼多情報，",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_050"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n沒和「那邊的世界」的人合作是不可能辦得到的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "答對了～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_051"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "的確，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那個人與其稱為客戶，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不如稱為合作對象的確是更貼切些～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只不過，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_052"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也不是單純為那個人行動。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們就只是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為了彼此的目的。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只要這樣的條件還成立，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我就會幫那個人做所有交代的事情。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是喔……",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_053"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "原來妳也有",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所謂的目的在嗎。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有喔～",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_054"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我想要盡情地，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "享受這個遊戲♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……就這樣？",
        "unit_id": 106812,
        "voice": "vo_adv_1067007_055"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_056"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就這樣♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "目前的阿斯特朗是被某人重組過的，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_057"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n一個全新的遊戲……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像這樣的遊戲，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我希望能將它玩個透徹。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣壞得一塌糊塗的遊戲，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_058"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其實也別有一番趣味，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n甚至讓我覺得賭上性命也無所謂♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_059"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嘉夜跟祈梨……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n還有其他所有的玩家，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n大家看起來都不像是在享受這遊戲。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這就好像是小孩子演的話劇，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_060"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "每個人都是睡美人♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n人人都在昏沉的夢裡，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "虛假地活著。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像這樣的人們，",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_061"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總該有選擇其他生活方式的權利吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為「這」",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不是人類該活出的人生，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n從一開始就只是個遊戲。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "若是決定",
        "unit_id": 106711,
        "voice": "vo_adv_1067007_062"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對遊戲豁出性命與人生也就罷了，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但若這些人並不是自願的，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那跟他們一起玩實在讓人有些不忍。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
