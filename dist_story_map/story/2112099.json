    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我就是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為了那種目的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「而被製造出來的」……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……不只是我。",
        "unit_id": 106412,
        "voice": "vo_adv_2112099_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "贊恩……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哥哥他也是一樣……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雪菲……",
