    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "剛才的事……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的很",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對不起……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒關係啦。",
        "unit_id": 106815,
        "voice": "vo_adv_2112099_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我也有責任，剛剛因為注意力全都放在厄莉絲身上，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有點太大意了。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可、",
        "unit_id": 106412,
        "voice": "vo_adv_2112099_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n連我自己",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也不明白",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為什麼會做出那種事……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只是聽到",
        "unit_id": 106412,
        "voice": "vo_adv_2112099_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
