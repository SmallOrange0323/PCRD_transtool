    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說不定",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還會",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "傷害其他人……",
