        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "留給我們研擬計畫",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "阻止厄莉絲的時間就越少……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "更重要的是……",
        "unit_id": 106412,
        "voice": "vo_adv_2112099_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "拉比林斯達小姐。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這樣會讓妳",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "暴露在危險之下……",
