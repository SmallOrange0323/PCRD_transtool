        "voice": "vo_adv_2112099_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "解析妳的角色的話，",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n或許能",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "找出修正的辦法。",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過……",
        "unit_id": 106815
    },
    {
        "type": "dialogue",
        "name": "雪菲",
