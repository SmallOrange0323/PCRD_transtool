    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這給妳！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_068"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "上頭寫著「護身符」呢。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這個要給我？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊……",
        "unit_id": 112011,
        "voice": "vo_adv_1207003_069"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然這東西可能只是心理作用。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但這是抽到大吉的我們買來的，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該多少有點靈驗吧？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家……",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_070"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我會好好珍惜的。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐能露出笑容，",
        "unit_id": 111911,
        "voice": "vo_adv_1207003_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就安心了。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼這次真的",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家一起去參拜吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為了避免走散，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家牽起手來……♪",
        "unit_id": 111911
    },
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃……",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_072"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "鞠躬兩次拍手兩次……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……神明。",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_073"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "求求你。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "希望今後我也能一直……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "作為【美食殿堂】的雪菲，",
        "unit_id": 120711
    },
