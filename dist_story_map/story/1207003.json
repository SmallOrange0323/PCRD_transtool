[
    {
        "type": "background",
        "background": "500560"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了前去新年第一次的參拜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n自新年以來首次聚集在一塊的【美食殿堂】一行人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "來到了神殿。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不會吧，",
        "unit_id": 112011,
        "voice": "vo_adv_1207003_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這什麼情形？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明新年都已經過了，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "人居然還這麼多……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "人潮擁擠到連鳥居都看不到了，",
        "unit_id": 111911,
        "voice": "vo_adv_1207003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看這樣子",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許等過中午再來看看會比較適合……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣的話，",
        "unit_id": 111811,
        "voice": "vo_adv_1207003_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們來進行新年首次的公會活動吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實我有很多很感興趣的攤販喔♪",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說妳啊……",
        "unit_id": 112011,
        "voice": "vo_adv_1207003_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "晚上不是還要大家一起煮火鍋嗎？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n小心妳會吃不下喔。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用擔心！",
        "unit_id": 111811,
        "voice": "vo_adv_1207003_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為早上有早上的胃，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "中午有中午的胃，",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後晚上有晚上的胃啊☆",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是只有妳一個人吧！",
        "unit_id": 112011,
        "voice": "vo_adv_1207003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果陪妳這樣吃，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的胃袋會被撐破啦！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好了好了……",
        "unit_id": 111911,
        "voice": "vo_adv_1207003_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難得出來外面，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位一起",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "適度地慢慢享受吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊……",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n看到這個有【美食殿堂】風格的景象，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "令人感到很安心。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n能和大家",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "再一起來參拜，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我覺得好開心……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對「現在的我」來說，",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這是第二次來參拜……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我希望也能在這裡",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好好留下回憶。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n畢竟也有很多令人感興趣的事物……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我現在就有個問題，",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個是什麼東西？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我看大家",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "都在從木筒中抽出紙條。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您對抽籤",
        "unit_id": 111911,
        "voice": "vo_adv_1207003_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很感興趣嗎？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣的話，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家一同去抽吧。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……啊，",
        "unit_id": 111911,
        "voice": "vo_adv_1207003_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是大吉。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人抽到了什麼呢？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇～",
        "unit_id": 111811,
        "voice": "vo_adv_1207003_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是一樣的耶！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也是大吉☆",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦！？",
        "unit_id": 112011,
        "voice": "vo_adv_1207003_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們也都是！？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……那個籤筒裡該不會",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全都是大吉吧……",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳抽到了什麼！？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……大凶。",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "跟我想得一樣。",
        "unit_id": 112011,
        "voice": "vo_adv_1207003_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n果然所有的籤都是…………",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "大凶！？",
        "unit_id": 1,
        "voice": "vo_adv_1207003_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「不久將會找回失去的東西，",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但是",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "將會失去擁有的東西。」",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n「無法",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "實現願望。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凡事都不如己意。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "選擇時要謹慎。」",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "找回失去的東西……？",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這該不會",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是指「以前的我」？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那籤上寫",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "將會失去擁有的東西……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "又是什麼意思？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「現在的我」",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所擁有的東西……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這難道是在指",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家嗎……？　",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲！",
        "unit_id": 112011,
        "voice": "vo_adv_1207003_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "運勢這種東西，",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是個機率而已！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳不需要放在心上！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯沒錯，",
        "unit_id": 111811,
        "voice": "vo_adv_1207003_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這種時候就要去吃東西轉換心情！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐",
        "unit_id": 111911,
        "voice": "vo_adv_1207003_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有什麼想吃東西嗎……！？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n不用擔心，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我沒有放在心上。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "攤販的隊伍",
        "unit_id": 111911,
        "voice": "vo_adv_1207003_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一直沒有前進呢……",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………噫！？",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐。",
        "unit_id": 111911,
        "voice": "vo_adv_1207003_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……您的眼眶都泛淚了，",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是怎麼了嗎……？",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有、",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_027"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "東西……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "掉到我的肩上了……！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "濕濕的……！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "濕濕的……！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哇哇！？",
        "unit_id": 111811,
        "voice": "vo_adv_1207003_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的耶！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小雪菲肩膀上有鳥的──",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "噫",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_029"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……！？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不用怕！",
        "unit_id": 112011,
        "voice": "vo_adv_1207003_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這不會死人的！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚",
        "unit_id": 120711,
        "voice": "vo_adv_1207003_031"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚嗚……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "媽媽，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
