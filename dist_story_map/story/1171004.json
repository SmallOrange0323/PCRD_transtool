    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "唷！",
        "unit_id": 117131
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "首先最該學會的是",
        "unit_id": 117131,
        "voice": "vo_adv_1171004_036"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "搭話的方法！",
        "unit_id": 117131
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 117131
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "來，",
        "unit_id": 117131
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟，",
        "unit_id": 117131
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你把姐姐當成隨處可見的",
        "unit_id": 117131
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "普通女孩子，",
        "unit_id": 117131
    },
    {
