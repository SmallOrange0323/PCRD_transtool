        "voice": "vo_adv_1171004_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊，",
        "unit_id": 117131
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對了。",
