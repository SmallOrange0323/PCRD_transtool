        "voice": "vo_adv_1171004_034"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就由姐姐來教你！",
        "unit_id": 117131
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n其名為──",
        "unit_id": 117131
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「姐姐親傳，",
