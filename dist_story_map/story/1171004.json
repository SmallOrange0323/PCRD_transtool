        "voice": "vo_adv_1171004_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "果然是男孩子。",
        "unit_id": 117131
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n總是對女孩子充滿興趣呢。",
        "unit_id": 117131
    },
    {
        "type": "dialogue",
        "name": "靜流",
