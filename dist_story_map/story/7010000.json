[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "通往露娜之塔途中的祠堂，有一對男女的身影。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n女性將一隻手，伸向男性的頭上——"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "雖然路程有點遠，",
        "unit_id": 101511,
        "voice": "vo_adv_7010000_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但還是努力走過來了呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好孩子好孩子～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "話說回來，",
        "unit_id": 101511,
        "voice": "vo_adv_7010000_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是個不可思議的地方呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這裡生長的植物們，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "和精靈族之村完全不同呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？　",
        "unit_id": 101511,
        "voice": "vo_adv_7010000_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是誰在這種地方呢？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯啊～！　",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好癢喔～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……啊！　",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來得正好！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "葉子掉進了衣服裡……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "能幫我拿出來嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！　",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不是那裡啦～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好像掉進了更深的地方。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "還有，",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你的手也弄得我癢的受不了啦！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n快點拿出來～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀哎呀～",
        "unit_id": 101511,
        "voice": "vo_adv_7010000_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "晴朗的天氣，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在這樣的森林裡～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了～",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "好像拿出來了呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "話說回來，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你為什麼會在這裡呢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那位是？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "初次見面，",
        "unit_id": 101511,
        "voice": "vo_adv_7010000_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我是",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在精靈族之村擔任幼教老師的美里。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "聽說",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這裡有與他的記憶相關的線索，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n散步時順便繞過來的～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哎呀，",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "原來如此呢！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這裡居然是那樣的地方……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我是",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "在【月光學院】擔任教師的伊緒。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是{player}的導師。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天是",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為了尋找適合校外教學的場地。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "說來慚愧，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "因為途中迷了路",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以才到了這裡……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總感覺，",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這裡看起來是十分古老的建築物，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "或許正好能作為歷史課的教材。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "美里老師，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "能讓我也一起行動嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不只為了校外教學，",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也為了{player}，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n作為老師",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我也想幫上一些忙……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "當然沒問題～",
        "unit_id": 101511,
        "voice": "vo_adv_7010000_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n對{player}來說，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "導護的老師有兩位的話，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "心裡也會更踏實吧。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……？　",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有兩位老師是…",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "美里老師是幼教老師對吧？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n為什麼會是{player}的老師呢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "他在村子的幼稚園裡，",
        "unit_id": 101511,
        "voice": "vo_adv_7010000_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "和其他的孩子一起",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "被我照顧的呦～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為是最年長的哥哥，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n不用我費太多心力，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是個非常好的孩子呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？　",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "也在幼稚園上學嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你今年是幾歲來著？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好了，",
        "unit_id": 101511,
        "voice": "vo_adv_7010000_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就別站著閒聊了，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "先往前進吧～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "{player}不用擔心任何事呦。",
        "unit_id": 101511,
        "voice": "vo_adv_7010000_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "來吧",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "伊緒老師也一起走囉～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦咦～！？　",
        "unit_id": 101811,
        "voice": "vo_adv_7010000_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "兩位等等我～！",
        "unit_id": 101811
    }
]