        "voice": "vo_adv_5205067_002"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下。",
        "unit_id": 129711,
        "voice": "vo_adv_5205067_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n近來華音那傢伙",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "情況如何？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "啥──",
        "unit_id": 134912,
        "voice": "vo_adv_5205067_004"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "好孩子什麼的",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "真──",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "是有夠無聊～～～～！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣哪裡是好孩子了，騎士先生！？",
        "unit_id": 134812,
        "voice": "vo_adv_5205067_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_5205067_006"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n正是──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n在奴家眼裡，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "確實有朝佳境",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "轉變之勢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那便勞煩騎士閣下，",
        "unit_id": 129711,
        "voice": "vo_adv_5205067_007"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "今後之管教",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "也都全權交與恁了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n如能得遇良師薰陶，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "或許華音的器量……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "亦能",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "漸次成型也說不定。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "你那自以為是監護人的態度最讓本小姐不爽了～～～～！！",
        "unit_id": 134912,
        "voice": "vo_adv_5205067_008"
    }
