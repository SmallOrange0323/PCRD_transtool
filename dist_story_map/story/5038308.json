[
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "切切嚕～～～～～～～～！！",
        "unit_id": 13211,
        "voice": "vo_adv_5038308_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_5038308_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n好朋友X這傢伙，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來又成功自我進化了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "跟它懷舊玩具般的外表相反，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唯有內部功能可說是最先進的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "吵死了閉嘴，",
        "unit_id": 13211,
        "voice": "vo_adv_5038308_002"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "空有無用知識的戀母情結小矮子。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "\n趕快放馬過來切嚕。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哼、",
        "unit_id": 111011,
        "voice": "vo_adv_5038308_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哼，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來似乎只有毒舌功能沒有升級呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我的冷靜沉著可是眾所皆知的，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "才不會被你那點無聊的挑釁給刺激到——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "吵死了！　",
        "unit_id": 110911,
        "voice": "vo_adv_5038308_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "吵死了，笨～蛋！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不准欺負我們的優妮學姐～廢鐵！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不准說什麼空有無用知識戀母情結小矮子這種話～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "她被這種",
        "unit_id": 110811,
        "voice": "vo_adv_5038308_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "無聊的挑釁刺激到了耶。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而且，",
        "unit_id": 111011,
        "voice": "vo_adv_5038308_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有必要再重複一次",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個毒舌的內容嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐可不僅僅是個空有無用知識的戀母情結小矮子呢！",
        "unit_id": 110911,
        "voice": "vo_adv_5038308_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n她還是個能夠因為被小小甜心們當成「迷路的8歲小優妮」收留，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n索性就直接盡全力陪她們玩扮家家酒的瘋狂18歲少女喔！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "琪愛兒，",
        "unit_id": 110811,
        "voice": "vo_adv_5038308_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳完全沒幫上忙。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n妳的眼神",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "變得和保育類的蘭德索爾藏狐一樣了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳先把嘴巴閉上，",
        "unit_id": 111011,
        "voice": "vo_adv_5038308_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "琪愛兒。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然後把妳那個粗糙的夥伴意識",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "和對上位者的敬意放在天秤的兩端比一下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳給我閉嘴，笨蛋。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊～！　",
        "unit_id": 110911,
        "voice": "vo_adv_5038308_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小優妮，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "竟然罵琪愛兒笨蛋！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哼，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "罵人家笨蛋的人才是笨蛋～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什……",
        "unit_id": 111011,
        "voice": "vo_adv_5038308_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果妳要把",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在本校入學考試中以榜首合格的我定義為笨蛋的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那麼在我以下的妳們全都是大笨蛋了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "笨～蛋！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哼～！",
        "unit_id": 110911,
        "voice": "vo_adv_5038308_012"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n現在又沒有人在講考試的事情，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "笨蛋～笨蛋～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊～真是的！",
        "unit_id": 110811,
        "voice": "vo_adv_5038308_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "笨蛋跟笨蛋不要再吵那笨吵架了……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮＆琪愛兒",
        "words": "不要叫人笨蛋啦，",
        "unit_id": 1,
        "voice": "vo_adv_5038308_014"
    },
    {
        "type": "dialogue",
        "name": "優妮＆琪愛兒",
        "words": "笨蛋～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？\n妳們是怎樣，要打架嗎兩個笨蛋。",
        "unit_id": 110811,
        "voice": "vo_adv_5038308_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "吵死了，笨蛋！",
        "unit_id": 110911,
        "voice": "vo_adv_5038308_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳說什麼，笨蛋！",
        "unit_id": 111011,
        "voice": "vo_adv_5038308_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我宰了妳喔，笨蛋！",
        "unit_id": 110811,
        "voice": "vo_adv_5038308_018"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "好了啦，快點上啊，",
        "unit_id": 13211,
        "voice": "vo_adv_5038308_019"
    },
    {
        "type": "dialogue",
        "name": "好朋友X",
        "words": "三笨蛋。",
        "unit_id": 13211
    },
    {
        "type": "dialogue",
        "name": "三笨蛋",
        "words": "三笨蛋！？",
        "unit_id": 1,
        "voice": "vo_adv_5038308_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗……",
        "unit_id": 110811,
        "voice": "vo_adv_5038308_021"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "吶。它在說些什麼啊，那個傢伙。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "竟然對聖德蕾莎的三賢者說這種話，真是意義不明。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯。",
        "unit_id": 111011,
        "voice": "vo_adv_5038308_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我會全力支援妳，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳就盡情地大鬧一場吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n聖德蕾莎的三賢者，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使出全力上吧！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是啊！",
        "unit_id": 110911,
        "voice": "vo_adv_5038308_023"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n聖德蕾莎的三賢者，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "使出全力上吧！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "三賢者",
        "words": "唔喔喔喔呀啊啊啊啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_5038308_024"
    }
]