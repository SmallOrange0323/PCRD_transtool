    {
        "type": "dialogue",
        "name": "禊",
        "words": "還為了增加自己的力量利用它們……",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "大家就只是想要享受萬聖節而已，你這樣太過分了！！",
