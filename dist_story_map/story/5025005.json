        "voice": "vo_adv_5025005_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "也就是說叔叔你會去捉那些",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n期待萬聖節的幽靈們？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那、",
        "unit_id": 111211,
        "voice": "vo_adv_5025005_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那樣太奇怪了吧！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "而且萬聖節結束後，",
        "unit_id": 111211
