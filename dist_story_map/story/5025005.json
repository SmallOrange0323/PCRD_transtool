        "voice": "vo_adv_5025005_006"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "我是爸爸喔……",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "我們一直都",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "在一起呢。",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個人是",
        "unit_id": 111111,
        "voice": "vo_adv_5025005_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "花的父親？　",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是――",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "是啊，",
        "unit_id": 3511,
        "voice": "vo_adv_5025005_008"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "我已經死了……",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "那又怎麼樣呢？",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "就算我死了，",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "我也不想放下花。",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "什、",
        "unit_id": 111211,
        "voice": "vo_adv_5025005_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "什麼意思？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n那個叔叔是花的爸爸……",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可是他是幽靈？",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那我們聽到的小孩聲音是？　",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊──",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊已經搞不懂了！",
        "unit_id": 111211
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "……萬聖節會將死者與生者的世界連結起來。",
        "unit_id": 3511,
        "voice": "vo_adv_5025005_010"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "在這天，",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "那些年輕尚輕就逝去的靈魂，",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n會混進現世在過節的孩子們裡，",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "一起來享受萬聖節。",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "我就",
        "unit_id": 3511,
        "voice": "vo_adv_5025005_011"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "邀請那些靈魂進入宅邸，",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "讓它們成為花的朋友。",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "為了安慰在我死後",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "變得孤身一人的",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "這孩子……",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "讓幽靈當朋友？　",
        "unit_id": 111111,
        "voice": "vo_adv_5025005_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可是她說",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "朋友會消失……",
        "unit_id": 111111
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "它們的靈魂能存在於現世的時間就只有",
        "unit_id": 3511,
        "voice": "vo_adv_5025005_013"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "萬聖節當天。",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "所以我",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "會在萬聖節結束前，",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "吞噬它們的靈塊。",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "\n為了讓我維持靈力……",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "也是為了繼續留在現世呢。",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "因為我想",
        "unit_id": 3511,
        "voice": "vo_adv_5025005_014"
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "一直陪在",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "男",
        "words": "這孩子身邊。",
        "unit_id": 3511
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那……",
