[
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……那個",
        "unit_id": 121511,
        "voice": "vo_adv_5090302_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……帆稀小姐曾經這麼說過。",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n賭場王",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是讓「龍之卵」吸取自己的壽命，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n來換取魔力",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "的……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為什麼要做到這種地步……",
        "unit_id": 121511,
        "voice": "vo_adv_5090302_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "已經……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "已經",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可以停手了吧……？",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "咯咯咯……",
        "unit_id": 16011,
        "voice": "vo_adv_5090302_002"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "這妳就不懂了，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "步未……",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "短暫而隨心所欲地活著！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n這才是賭徒的夙願啊！",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "而且……",
        "unit_id": 16011,
        "voice": "vo_adv_5090302_003"
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "也要我先熟悉「龍之卵」才行。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n你們跟幻影貓說到底，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "只不過是暖場角色而已。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "\n",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "痛扁你們之後，",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "賭場王",
        "words": "就輪到帆稀啦。",
        "unit_id": 16011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "老大不會跟你打。",
        "unit_id": 106511,
        "voice": "vo_adv_5090302_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n因為……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "肌肉煙槍賭徒老頭會在這裡，",
        "unit_id": 121611,
        "voice": "vo_adv_5090302_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就被我們",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "痛扁一頓啦！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……賭場王",
        "unit_id": 121511,
        "voice": "vo_adv_5090302_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不僅壞到骨子裡，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還是我們敵人……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "即使如此……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不惜削減壽命也要戰鬥的行為，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n是一定要阻止的……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "對吧，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……我會隱身",
        "unit_id": 121511,
        "voice": "vo_adv_5090302_007"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "從死角發動攻擊喔！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n兩位就趁著賭場王被我轉移注意力的時候攻擊！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……盡快結束",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這場戰鬥吧！",
        "unit_id": 121511
    }
]