        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是送給我最好的禮物了！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不好意思，強搶妳的禮物，",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過下一個輪到妾身了！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "遇到體型巨大的敵人",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就要從遠處發動攻擊！",
        "unit_id": 111711
    },
    {
        "type": "background",
        "background": "500873"
    },
    {
        "type": "dialogue",
        "name": "馴鹿頭目",
        "words": "噗喔喔！\n（沒效！）",
        "unit_id": 12511,
        "voice": "vo_adv_5029006_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的魔法……",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_020"
    },
