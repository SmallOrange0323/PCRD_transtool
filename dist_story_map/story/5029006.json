        "voice": "vo_adv_5029006_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "難道我被期待要做些什麼嗎？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那個，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "各位～",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "久等了～！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "【慈樂之音】的偶像",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不要這麼認真和馴鹿互動好嗎……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_041"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "剛剛的咆哮，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "難不成是――",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "馴鹿們",
        "words": "噗喔喔喔！",
        "unit_id": 4111,
        "voice": "vo_adv_5029006_042"
    },
    {
        "type": "background",
        "background": "500873"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然，",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_043"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "牠在操縱這些馴鹿！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不愧是馴鹿中的菁英，",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是了不得的領導力啊！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "現在可不是誇牠的時候了，製作人！",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "馴鹿們不斷聚集過來了……！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n再這樣下去會被牠們包圍的！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "馴鹿頭目",
        "words": "噗喔喔！\n（有破綻！）",
        "unit_id": 12511,
        "voice": "vo_adv_5029006_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀！？",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_047"
    },
    {
        "type": "background",
        "background": "500873"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}……！",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n謝謝你保護我！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "馴鹿",
        "words": "噗喔喔喔喔喔！",
        "unit_id": 4111,
        "voice": "vo_adv_5029006_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔，",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "周圍的馴鹿出乎意料地礙事耶。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不過，牠們原本都是人類，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也不能斬了牠們……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "乾脆把牠們斬了好了？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "住手！",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_051"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "牠們可是",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "未來妾身要統治的人民，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身不允許妳傷害牠們！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "先不管統不統治，",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_052"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總之不可以傷害牠們！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "首先當然不能傷害居民們，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "然後，那幾隻菁英馴鹿",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n牠們應該本性也不壞……！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "馴鹿頭目",
        "words": "噗喔、",
        "unit_id": 12511,
        "voice": "vo_adv_5029006_053"
    },
    {
        "type": "dialogue",
        "name": "馴鹿頭目",
        "words": "噗喔喔喔喔喔喔！\n（不需要這種為了使喚馴鹿而存在的聖誕節！）",
        "unit_id": 12511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嘖……！　",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你們是要我在這種情況下，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還要跟所有人握手言和啊……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是在講這麼天～真的夢話嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……沒錯！",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_055"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為，",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_056"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天是……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊～",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_057"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是呢。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不管怎麼說今天都是……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……原來如此。",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n既然妳們這麼說，那就沒辦法了。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼這些",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n原本是人類的馴鹿，就由妳來想辦法。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那邊那個大塊頭，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就由我和伊莉亞‧奧恩斯坦來對付。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？　",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_060"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要我",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "想辦法處理這些馴鹿們嗎……！？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼這樣，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "該怎麼辦才好……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳在不知所措什麼。",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "――想想妳是誰？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我……？",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_062"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我是……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "【慈樂之音】的偶像！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "既然如此，就像個偶像一樣，",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n好好地達成製作人的要求吧！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "管他是聖誕老人還是馴鹿，",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n用妳的歌聲迷倒他們吧――",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "望！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……是！",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_065"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我知道了！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "馴鹿頭目",
        "words": "噗喔喔喔喔喔喔喔喔喔喔喔！\n（這種只會讓馴鹿感到痛苦的聖誕節，不要也罷！）",
        "unit_id": 12511,
        "voice": "vo_adv_5029006_066"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "牠們要來了！　",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_067"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "克莉絲提娜！",
        "unit_id": 111711
    }
]