    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，蘭德索爾的人們一個個被"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n聖誕老人禮物袋的力量變成了馴鹿。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}他們為了阻止這件事情，到處奔波。"
    },
    {
        "type": "dialogue",
        "name": "馴鹿頭目",
        "words": "噗喔喔喔喔喔喔喔喔喔喔喔喔喔喔――！\n（就由我這個新上任的聖誕老人，\n把聖誕節全部毀掉――！）",
        "unit_id": 12511,
        "voice": "vo_adv_5029006_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總算追上牠了！",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……嗯，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身好像來過這裡呢？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聖誕演唱會的會場！？",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "眼光真不錯，竟然挑上這裡……♪",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不管戰鬥或歌唱都是舞台上的娛樂之一。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n盡情地炒熱氣氛吧！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂！克莉絲提娜！",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不要單槍匹馬地闖進去！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈☆",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這個時候要敬老尊賢喔！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的年紀比妳大得多了！",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嘿咻☆",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_007"
    },
    {
        "type": "background",
        "background": "500873"
    },
    {
        "type": "dialogue",
        "name": "馴鹿頭目",
        "words": "噗喔！\n（哼！）",
        "unit_id": 12511,
        "voice": "vo_adv_5029006_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "牠用鹿角擋下了！？",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_009"
    },
    {
        "type": "dialogue",
        "name": "馴鹿頭目",
        "words": "噗喔喔喔喔喔！\n（這些小蟲子！）",
        "unit_id": 12511,
        "voice": "vo_adv_5029006_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒什麼大不了的！",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這點程度――",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "咦？",
        "unit_id": 111511
    },
    {
        "type": "background",
        "background": "500873"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "被打飛了！？",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身方才就說了吧！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……只是擦傷了而已！",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "原本，",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是不可能會被擋下，也不會擦傷的……",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "亂數聖域的反應變遲鈍了？　",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是因為下雪的緣故嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那個發達的肌肉，",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "力氣比看起來還要更強呢。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "瞬間的遲疑被對方逮著了……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "製作人，",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳沒事吧！？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n雖然妳在笑，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過剛剛應該被擊中要害了吧……？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆　",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這怎麼能不笑呢！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這配得上聖誕夜的強敵，",
        "unit_id": 111511
    },
