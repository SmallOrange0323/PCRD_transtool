        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不管牠要使出什麼招――",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "馴鹿",
        "words": "……噗喔。",
        "unit_id": 4111,
        "voice": "vo_adv_5029006_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？　",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "被變為馴鹿的居民們！？",
