        "voice": "vo_adv_5029006_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定會有辦法的！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "馴鹿頭目",
        "words": "――噗喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔喔！",
        "unit_id": 12511,
        "voice": "vo_adv_5029006_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
        "unit_id": 111611,
        "voice": "vo_adv_5029006_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "什、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "什麼！？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "突然間怎麼了！？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "剛剛的咆哮……",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_031"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總覺得",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有種不好的預感。",
