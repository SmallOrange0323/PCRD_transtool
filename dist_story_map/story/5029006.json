    {
        "type": "dialogue",
        "name": "望",
        "words": "吸收了……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "再怎麼誇張也要有個限度啊～～～～～！？",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_022"
    },
    {
        "type": "dialogue",
        "name": "馴鹿頭目",
        "words": "噗喔喔喔喔喔喔喔喔！\n（給我收下這個禮物吧！）",
        "unit_id": 12511,
        "voice": "vo_adv_5029006_023"
    },
    {
        "type": "background",
        "background": "500873"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "牠、",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "牠竟然把袋子甩過來了……！",
        "unit_id": 111711
