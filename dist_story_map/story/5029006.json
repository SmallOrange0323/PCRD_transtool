        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒錯沒錯。",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n牠才不是傳說的吸血鬼――妾身的對手呢。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家同心協力，",
