    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂！",
        "unit_id": 111711,
        "voice": "vo_adv_5029006_037"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別把妾身跟馴鹿混為一談！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳以為妾身是誰啊！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈，",
        "unit_id": 111511,
        "voice": "vo_adv_5029006_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這不是很有意思嗎！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n傳說的吸血鬼應該會很有看頭♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？",
