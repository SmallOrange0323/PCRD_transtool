[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了參加瑪爾傑海岸的海灘開放日，\n珠希和{player}一起來到了海邊。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今天天氣真好啊喵～！",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "趕緊開始做準備吧喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "說的對，",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "到了海邊就要好好做一下熱身運動才行……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那背後就麻煩你了喵～",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "才不是呢喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們才不是來這裡玩的喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "說到海灘開放日，",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "當然是海邊攤位的小吃啊喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我的目標可是要在那邊擺起鯛魚燒的攤位喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "把好吃的鯛魚燒全部大賣特賣給客人，",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我要在這夏天大賺一筆啦喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要是能賣很多出去，",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我也可以請{player}吃美味的鯛魚燒哦喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以，",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "準備工作就好好交給你了喵～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯？",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "海灘開放日的主辦人好像在說些什麼喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n離活動開始還有一點時間，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是有什麼事情喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "正在為海灘開放日做準備的大家！",
        "unit_id": 311,
        "voice": "vo_adv_1079001_009"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "大事不好了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "沙灘排球大賽所使用的排球網，",
        "unit_id": 311,
        "voice": "vo_adv_1079001_010"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n從今天早上開始就一直找不到了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "由於置放的地方凌亂不堪，",
        "unit_id": 311,
        "voice": "vo_adv_1079001_011"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n很有可能是被什麼人給偷走了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "欸～！？",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為什麼要偷走那種東西啊喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "每年，",
        "unit_id": 311,
        "voice": "vo_adv_1079001_013"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "沙灘排球大賽的氣氛最為熱烈，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n要說是海灘開放日時最受矚目的活動也不為過呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "這樣下去",
        "unit_id": 311,
        "voice": "vo_adv_1079001_014"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "活動就不得不中止進行了……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那，",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那可就麻煩了喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們可是為了今天都已經做足了準備的耶！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "沒錯，就是這樣！",
        "unit_id": 311,
        "voice": "vo_adv_1079001_016"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "為了能讓大家的活動順利圓滿，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n拜託各位了，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "請幫我們找出偷走排球網的犯人！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "能在活動開始之前找出犯人的人，",
        "unit_id": 311,
        "voice": "vo_adv_1079001_017"
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "\n我們",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "主辦人",
        "words": "也會支付相應酬勞的！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "酬、",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "酬勞！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這可又是一個大撈一筆的機會啊喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我們兩個，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一起抓出犯人找回排球網吧喵～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "首先，",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "從這附近的人先打聽一下狀況喵～",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n走吧，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們先來取得有用的情報吧喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在搜集到的情報之中，",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "最令人可疑的地方，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就是當地最出名的地痞流氓了喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "肯定是想藉偷走排球網，",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "當作無聊的夏日英勇事跡講述吧，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n真是一群無藥可救的傻子喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "啊？",
        "unit_id": 811,
        "voice": "vo_adv_1079001_022"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "說什麼啊妳這傢伙！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唉……",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "果真就是一副不良份子的樣子……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你該不會就是這附近的地痞流氓了喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "妳說誰是地痞流氓啊！",
        "unit_id": 811,
        "voice": "vo_adv_1079001_024"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "啊？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n又不是在地人一副裝模做樣的！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n我現在馬上就把你們轟出去！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "喂！",
        "unit_id": 811,
        "voice": "vo_adv_1079001_025"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "你這傢伙也想找麻煩嗎！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n我要和那女人算帳，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "給我閃一邊去！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊，",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你沒事吧喵！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喂地痞流氓！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為什麼要連他都撞倒呀喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不可原諒了喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "待我把這傢伙給抓住了，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n一定要好好質問他偷走排球網的事喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵！",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵、喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓你見識得意忘形的後果喵──！",
        "unit_id": 107911
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "這、",
        "unit_id": 811,
        "voice": "vo_adv_1079001_029"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "這女人",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "好強……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還不能讓你們逃走呢喵──！",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_030"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "唔呃呃……！",
        "unit_id": 811,
        "voice": "vo_adv_1079001_031"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "我、",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "我錯了……！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "是我輸了！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n求妳別再扭我的手啦──！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在這之前，有件事情想問一下喵。",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "今天早上，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沙灘排球大賽用的排球網是不是你偷走的喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "我，",
        "unit_id": 811,
        "voice": "vo_adv_1079001_033"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "我才沒有幹出那種事情！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n搞不好是最近在海岸出沒的",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "魔物搞的鬼啊！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "坦白說，",
        "unit_id": 811,
        "voice": "vo_adv_1079001_034"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "我聽說排球網被偷走是在今早，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "\n那時我有看到魔物",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "在海岸邊行走啊！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "此話……",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_035"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "當真喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你沒有騙我吧喵？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "我真的沒有騙妳！",
        "unit_id": 811,
        "voice": "vo_adv_1079001_036"
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "拜託",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴",
        "words": "快放開我的手啊──！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然還不能完全相信你說的……",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_037"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "姑且，就先調查看看吧喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真的有魔物在的話……",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_038"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那問題就是它會躲在哪裡了喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我認為，",
        "unit_id": 107911,
        "voice": "vo_adv_1079001_039"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為人潮會逐漸比早上的多，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n魔物應該也會有所警戒而藏匿在什麼地方才對喵。",
