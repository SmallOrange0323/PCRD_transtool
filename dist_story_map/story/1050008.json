    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被美咲帶去購物，\n可是兩人卻突然被一道奇怪的光芒包圍住。"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這道光，",
        "unit_id": 105011,
        "voice": "vo_adv_1050008_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是什麼！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "之前的？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呀、",
        "unit_id": 105011,
        "voice": "vo_adv_1050008_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呀啊啊啊！",
        "unit_id": 105011
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你看，",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "難得我帶你來",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "「大人的店」，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你要表達出更多的謝意才對！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼嘛，",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你那個表情？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n說到大人的店的話，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就是名牌精品店呀！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那不是當然的嗎？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎麼了？",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你是",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "以為要去什麼奇怪的店嗎？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好了啦，",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們快進去吧！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為你要幫我挑選適合我的衣服！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "其實我本來是打算請姊姊幫我挑的……",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是她實在是抽不出時間來，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因此拒絕了我的請求。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以才輪到你！",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n因為實在沒辦法，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以我只好勉強參考你的意見！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來吧，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們走！",
        "unit_id": 105032
    },
    {
        "type": "still",
        "still": "105000801"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯～",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "唔，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這件還算可以吧？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n雖然尺寸大了一點……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣不是可愛，",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "而是很漂亮吧！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你要說我穿起來頗具成熟魅力！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "才、",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "才沒有這回事！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這件的尺寸對我來說",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不是很合身嗎！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我都是大人了，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是撐得起這種尺寸的衣服的！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的……",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你實在",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "太沒有眼光了！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "難得我帶你來，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n所以你要再更可靠一點啊！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼啦？",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_012"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……你說也要考慮一下預算？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊──",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你真的很囉唆！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這種事",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我自己也知道！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為我挑的是好貨，",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_014"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n所以我是有打算講價的！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我是說真的！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果你這麼在意預算的話，",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n就先",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "確認一下售價吧。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果能順便算一下價錢，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就幫了我大忙了。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "等、",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_016"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "等一下！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你為什麼這麼慌張？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……價格吊牌？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那有什麼問題嗎？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "反正",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "應該也不會貴到哪去吧？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你也太",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "大驚小怪了。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n嗯，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "售價是……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "──咦！？",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_018"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這、",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這也太貴了吧！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是怎麼回事……",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_019"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦！？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這個價格",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是不是多了一、二個零呀？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我居然在試穿",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這麼昂貴的衣服嗎……？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "在、",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "在這裡脫？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "等一下，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你不要扯我的衣服！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你這個變態！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不、",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_021"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不行啦！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n因為衣服很貴",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就馬上還回去，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這不是成熟的女性該有的行為！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這裡就要用成熟的態度，",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_022"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n聰明地還回去。",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你說現在不是說這種話的時候",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_023"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雖、",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雖然你說的沒錯……",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_024"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "等一下！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你不要扯我的衣服！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不用你擔心，",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也會好好地還回去的！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "那個～",
        "unit_id": 1,
        "voice": "vo_adv_1050008_025"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "客人？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n如果對待衣服太粗魯的話……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊……",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_026"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n剛剛好像",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "有個不妙的聲音……？",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……對、",
        "unit_id": 105032,
        "voice": "vo_adv_1050008_027"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對了對了！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我突然想起來",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我還有事！",
        "unit_id": 105032
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n所以之後就拜託你了～！",
