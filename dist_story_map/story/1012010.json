        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總覺得一直在給你添麻煩……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "雖然{player}\n有說過不在意，",
        "unit_id": 101211,
        "voice": "vo_adv_1012010_065"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但果然",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣子……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……開心嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_1012010_066"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為不知道會發生什麼事，",
        "unit_id": 101211,
        "voice": "vo_adv_1012010_067"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "所以很開心……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "原來是這樣啊。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "願意這樣說……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯……",
        "unit_id": 101211,
        "voice": "vo_adv_1012010_068"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我也很開心唷。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一醒來，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總是可以看到{player}的臉",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n近在身旁……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦，",
        "unit_id": 101211,
        "voice": "vo_adv_1012010_069"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那個！　",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "總之，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我們必須要找到{player}的衣服才行！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "要穿我的衣服嗎！？　",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那是不行的吧，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "耶嘿嘿！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好――",
        "unit_id": 101211,
        "voice": "vo_adv_1012010_070"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我一定會找到你的衣服給你看！",
