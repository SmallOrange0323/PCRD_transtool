    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "初音的超能力派上用場的時刻，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n可要讓{player}好好瞧瞧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "快點吧！",
        "unit_id": 101211,
        "voice": "vo_adv_1012010_071"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n{player}\n要是感冒了可就不好了啊！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和展開笑容的初音一起，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n回到了街上。"
    },
