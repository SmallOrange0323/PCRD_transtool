    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣繼續浪費時間下去的話，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺正中芙蕾雅小姐的下懷啊！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要是雪菲小姐的靈魂被阿剌克涅粉碎，",
