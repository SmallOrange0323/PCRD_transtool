[
    {
        "type": "background",
        "background": "500893"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾充滿了新年的歡樂氣氛，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而這股熱鬧氛圍也傳到了幫派地盤的巷弄裡。"
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "要來囉，",
        "unit_id": 416,
        "voice": "vo_adv_1283001_000"
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "「動物園管理員」！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "「圓形護盾」也已經配置完成！",
        "unit_id": 111,
        "voice": "vo_adv_1283001_001"
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "「蔓延森林」也已經準備就緒。",
        "unit_id": 5311,
        "voice": "vo_adv_1283001_002"
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "如果趁這個時候……！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼，",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就憑這些雜魚，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還以為能贏得過我的",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n「三女神‧慈樂之音六周年紀念版改裝‧",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n超級幫派巨星祈梨大人特別號」嗎？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "完全一動也不動！",
        "unit_id": 5311,
        "voice": "vo_adv_1283001_004"
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "可惡！",
        "unit_id": 111,
        "voice": "vo_adv_1283001_005"
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "實在太巨大了！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "別放棄啊！",
        "unit_id": 416,
        "voice": "vo_adv_1283001_006"
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "勝負現在才要開始！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼我就送你們上西天吧！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "招，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咚──！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "少年等人",
        "words": "嗚哇啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_1283001_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈──哈哈哈──！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "根本連比都不用比嘛！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你們想要對抗祈梨大人我，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還早了一百年啊！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "可惡──！",
        "unit_id": 416,
        "voice": "vo_adv_1283001_010"
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "我們輸了！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "唉，",
        "unit_id": 111,
        "voice": "vo_adv_1283001_011"
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "這樣當然贏不了嘛，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "\n畢竟她的陀螺幾乎是我們的三倍大……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀啊啊啊！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "欸，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼嘛，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "原來是小哥啊……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我還以為是嘉夜夜，害我嚇了一跳。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "啊，",
        "unit_id": 416,
        "voice": "vo_adv_1283001_013"
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "是祈梨姐姐手下的那個大哥哥。",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "你該不會不知道",
        "unit_id": 111,
        "voice": "vo_adv_1283001_014"
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "什麼是激鬥陀螺吧？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "激鬥陀螺",
        "unit_id": 5311,
        "voice": "vo_adv_1283001_015"
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "是現在最流行的戰鬥遊戲。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "參戰者使用改造過的陀螺來對戰，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "只要把對手撞出賽場，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "\n或是保持旋轉到最後的人就是贏家……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我就是在用這個陀螺",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "教訓教訓",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這些小鬼啦。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你在說什麼啊？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這可是官方正版的，哪裡奸詐了！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "是啊，",
        "unit_id": 5311,
        "voice": "vo_adv_1283001_018"
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "這是官方推出的聯名商品。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "\n那上面加裝的零件",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "也都是符合規定的改造零件。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是說啊！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是慈樂之音6th巡迴演唱會賣的周邊，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是超級限量品！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "慈樂之音有三個人，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以陀螺有三倍大也很合理！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "是、",
        "unit_id": 111,
        "voice": "vo_adv_1283001_020"
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "是這樣嗎？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "畢竟是那個慈樂之音嘛，",
        "unit_id": 5311,
        "voice": "vo_adv_1283001_021"
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "這也是沒有辦法的。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "不如該說她們已經有節制了。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "對喔，",
        "unit_id": 416,
        "voice": "vo_adv_1283001_022"
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "這傢伙也是慈樂之音的粉絲啊……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說起來你們可是三打一，",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我才是該抱怨的人吧！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話雖如此，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣的情況下我還是贏了，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那就表示我的實力是貨真價實的呢。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "的確是這樣沒錯～",
        "unit_id": 416,
        "voice": "vo_adv_1283001_024"
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "\n",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "不過即使三打一，",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "我們還是從頭輸到尾……",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "這樣下去，比再多次結果可能也一樣……",
        "unit_id": 111,
        "voice": "vo_adv_1283001_025"
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "畢竟我們一次都沒有贏嘛。",
        "unit_id": 5311,
        "voice": "vo_adv_1283001_026"
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "好像也只能下次再來了。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你們該不會不比了吧？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你們難道是想逃跑嗎！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "說連比都不用比的人不就是妳嗎？",
        "unit_id": 416,
        "voice": "vo_adv_1283001_028"
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "我們必須",
        "unit_id": 111,
        "voice": "vo_adv_1283001_029"
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "要變得更強才行……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "要去修行對吧！",
        "unit_id": 5311,
        "voice": "vo_adv_1283001_030"
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "\n我知道一個好地方，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "精靈族少年",
        "words": "我們走吧！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "獸人族少年",
        "words": "好！",
        "unit_id": 416,
        "voice": "vo_adv_1283001_031"
    },
    {
        "type": "dialogue",
        "name": "人族少年",
        "words": "走吧！",
        "unit_id": 111,
        "voice": "vo_adv_1283001_032"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "欸，",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_033"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等等……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦咦咦咦？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那些傢伙，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "居然就這樣走掉了……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_034"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "最近的年輕人就是吃不了苦，真不像話！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只不過是讓他們見識了一下成熟大人的財力，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n竟然就夾著尾巴逃走了……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "都不覺得丟臉嗎？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你在胡說什麼啊！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_035"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我要是對他們放水，那才叫不成熟！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你說什麼？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_036"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我只是陪他們玩玩而已！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n因為我是大人，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以不得不去應付小孩啦！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "身為長輩，",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_037"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就是要讓小鬼好好認清自己的實力，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這就是激鬥陀螺的……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不對，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是新年帝王祈梨大人的使命！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵呵……",
        "unit_id": 511,
        "voice": "vo_adv_1283001_038"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳自稱",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是帝王啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n很敢說嘛～",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼！？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_039"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你是……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是那個好像一直都在地盤邊緣曬太陽的老爺爺！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你笑什麼笑啊！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "這當然是因為，",
        "unit_id": 511,
        "voice": "vo_adv_1283001_040"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "看妳那點程度就在那邊嚷嚷的模樣太滑稽了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "不過比個陀螺就自稱帝王，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "真是可笑至極。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥！？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_041"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "像你這種只會呆站在一旁的老爺爺，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不管對身為帝王的祈梨大人說什麼，我都不會被你激怒啦。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒有用的！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好吧，",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_042"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我就來回應你這個",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "粗糙的挑釁吧。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "祈梨大人我會像對付那些小鬼一樣，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "徹底把你打趴！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說吧，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你要比什麼？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "只會呆站在一旁……？",
        "unit_id": 511,
        "voice": "vo_adv_1283001_043"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "原來妳是這麼看老夫的啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你還在那邊說什麼啊？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_044"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要比的話",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就趕快說你要比什麼！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "妳說這話還真是天真啊。",
        "unit_id": 511,
        "voice": "vo_adv_1283001_045"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "比賽，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "早就已經開始囉。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_046"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你說",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "他的手裡好像抓著什麼？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "看來那邊那位年輕人已經注意到了啊……",
        "unit_id": 511,
        "voice": "vo_adv_1283001_047"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "注意到老夫的",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "這條「線」。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "他的手上",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_048"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "的確抓著一條線耶。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n線看起來是往上延伸的，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這該不會……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是風箏嗎！？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "正是如此。",
        "unit_id": 511,
        "voice": "vo_adv_1283001_049"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "老夫就是那個擁有60年放風箏資歷的",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "天空霸主席茲爺爺。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "天空霸主席茲爺爺！？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_050"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不，",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_051"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "從來沒聽過……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我只是看到一把年紀的成年人一副很威風地報上愚蠢的名號，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n覺得很驚訝而已……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "呵，",
        "unit_id": 511,
        "voice": "vo_adv_1283001_052"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "妳就儘管耍嘴皮子吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "和某個連風箏都沒注意到，就自稱是新年帝王的蠢蛋相比，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "老夫這根本不算什麼。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔……",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_053"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘴巴還真會說啊。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "他說的也的確有道理……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "哦？",
        "unit_id": 511,
        "voice": "vo_adv_1283001_054"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "看來妳終於明白了啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "那麼，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "妳要收回妳那愚蠢的帝王宣言嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_055"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我才不會做那種丟臉的事。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就讓我陪你玩玩吧！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要撂倒你，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "成為真正的帝王！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_056"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "跟我來！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我們要去買風箏！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "席茲爺爺，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你可不准逃跑喔！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "老夫就在這裡，不躲也不藏。",
        "unit_id": 511,
        "voice": "vo_adv_1283001_057"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "倒是妳，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "可別就這樣逃之夭夭囉。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_058"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我現在就告訴你！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我會讓你輸到哭出來的！",
        "unit_id": 128311
    },
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "阿姨！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_059"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "給我最厲害的風箏！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "哎呀，",
        "unit_id": 1511,
        "voice": "vo_adv_1283001_060"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "祈梨，歡迎光臨。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "妳今天想要買什麼呢？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要買風箏，",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_061"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "風箏！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不是風車，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而是風箏！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要讓席茲爺爺輸個落花流水！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "妳說席茲爺爺……？",
        "unit_id": 1511,
        "voice": "vo_adv_1283001_062"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "原來如此，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "已經到這個時候了啊……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_063"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是有什麼事嗎？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "比起那個，快點給我風箏！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我要超級帥氣的最強巨龍風箏！！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "沒什麼事。",
        "unit_id": 1511,
        "voice": "vo_adv_1283001_064"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "現在只有這種飛龍圖案的風箏，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "可以嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔，",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_065"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然我最想要的其實是巨龍圖案的……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "算了，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也可以啦。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我就買這個吧。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "祈梨，",
        "unit_id": 1511,
        "voice": "vo_adv_1283001_066"
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "如果妳贏了……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "不，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "現在就先不說了。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "懷舊糖果店",
        "words": "妳要拿出全力，別留下遺憾囉。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_067"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總覺得有點奇怪……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過現在沒空在意那個了。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們走吧，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "去打倒席茲爺爺！",
        "unit_id": 128311
    },
    {
        "type": "background",
        "background": "500893"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "呵呵呵……",
        "unit_id": 511,
        "voice": "vo_adv_1283001_068"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "看來妳沒有逃跑呀。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n我們來比賽誰的風箏飛得高，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "沒問題吧？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "正合我意！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_069"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要開始囉，小哥！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我來拉著線跑，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你跟在我的後面舉著風箏！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓你看看幫派成員",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_070"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在草原上鍛鍊出來的腿力────！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哦哦哦哦哦哦哦────────────────────────！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_071"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼……",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_072"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小、",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你懂不懂啊……？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你要是……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "跑得比我還快……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "風箏就飛不起來了啊……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "呵呵呵……",
        "unit_id": 511,
        "voice": "vo_adv_1283001_073"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "風箏還沒飛起來啊？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "這樣可就連比都不用比了呢。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可惡……",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_074"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們年輕人的風箏都還沒飛起來，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那樣的老頭子卻已經讓風箏飛在空中，太不合理了……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而且",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_075"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還飛得很高。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "從這裡看過去，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "簡直就像是隻鳥一樣……",
        "unit_id": 128311
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 10111
    },
    {
        "type": "background",
        "background": "500893"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那不是真正的席茲嗎────！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_076"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "沒、沒錯，",
        "unit_id": 511,
        "voice": "vo_adv_1283001_077"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "人人都說老夫所操縱的風箏",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "看起來",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "就像真正的席茲，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "所以才會有席茲爺爺",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "這樣的稱號……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說什麼看起來像席茲啊！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_078"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這樣才不是席茲爺爺，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "而是狡猾爺爺了！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "妳、",
        "unit_id": 511,
        "voice": "vo_adv_1283001_079"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "妳胡說什麼！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "這是老夫的奧義，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "「襲姿王翼翔」！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n就算看起來再怎麼像真的，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n妳有什麼證據可以證明那是真正的席茲……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊。",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_080"
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 10111
    },
    {
        "type": "background",
        "background": "500893"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那果然是真的席茲啊！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_081"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "咳",
        "unit_id": 511,
        "voice": "vo_adv_1283001_082"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "咳……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "啊，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "很好，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "妳打敗老夫了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你少在那邊若無其事地想蒙混過去！",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_083"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "算了，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不管怎麼樣，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是我贏了對吧……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真正的新年帝王",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "果然就是我！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "當上帝王妳就滿意了嗎？",
        "unit_id": 511,
        "voice": "vo_adv_1283001_084"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼樣？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_085"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "事到如今你還不服輸嗎？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "不是那樣的。",
        "unit_id": 511,
        "voice": "vo_adv_1283001_086"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "妳難道不想超越帝王……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "坐上神的寶座嗎？",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n妳打倒了老夫，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "就有資格向上挑戰……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "我把這個交給妳吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個……",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_087"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是什麼？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n「年神祭參加券」？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "拿著這個去懷舊點心店吧。",
        "unit_id": 511,
        "voice": "vo_adv_1283001_088"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n妳可以在那邊詢問詳細的內容……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "席茲爺爺……？",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_089"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "今年是龍年……",
        "unit_id": 511,
        "voice": "vo_adv_1283001_090"
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "這也許是命中註定的吧。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "席茲爺爺",
        "words": "那麼就再會了！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼有種自顧自地把話說完就溜走的感覺……",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_091"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼……",
        "unit_id": 128311,
        "voice": "vo_adv_1283001_092"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那還用說嘛。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n既然如此，不管是神還是什麼，我都會坐上寶座的！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "快走吧，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "圍繞在年神上的奇妙戰鬥就此展開。"
    }
