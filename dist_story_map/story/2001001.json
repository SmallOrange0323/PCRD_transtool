[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}開始在蘭德索爾生活，\n已經過了約一個月。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是，某一天所發生的事情。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這件事實在非常相當的難以啟齒……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但我們，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經沒有錢了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從故鄉啟程之時，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管有從長老那授取了些許的盤纏。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那份錢也即將要用盡了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蘭德索爾果然是個大都市呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "物價的確相當高。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算試著在各方面精打細算，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n像是找較廉價的住宿，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或是自力去找尋食材等等……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明如此盡力地，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想要節省開銷了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n然而，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如今荷包還是空空如也了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是否",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能允許在下前去工作來掙錢呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也想要盡可能不離開主人您的身邊去行動。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但在下是想，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若找到份工作……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n來賺取薪水，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看是否能借此來應付生活費的開銷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請您……，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就一如以往，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "安心愜意地在附近打轉，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或是去品嘗一些街角的美食即可。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是今日的零用錢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請收好♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下於此先行一步。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n太陽下山之前，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就會回來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您怎麼了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的臉色，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎有些不太好呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟是不習慣的新環境，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難不成是弄壞身子了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真令人擔心……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又或者是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那份零用錢不夠您花嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是非常抱歉。",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n方才交託給您的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經是手邊剩下所有的銀兩了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來也沒有其他辦法了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下這就去將身上的裝飾品變賣，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好能換取現金喔。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……唔呀？",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您這麼突然抱上來會讓人很困擾的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡還是公眾場所呀。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道是若在下不在您身邊，會讓您感到不安嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人您說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您也想要工作？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這種與勞動相關的責任，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下原本是想一個人來承擔的呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說，讓別人工作",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻只有自己在玩樂，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會有罪惡感嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若這是主人您的意願，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼在下將會給予尊重。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人您真是溫柔……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且若是雙薪，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相較起來也更有效率呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就這麼做吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下想想……",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在這個廣場上，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該哪裡有著張貼",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n徵才啟事的佈告欄才對。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是想在那佈告欄，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n試著看能不能找到看起來還算不錯的工作。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對此方針，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還不知道主人您是否有所疑慮呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就趕緊……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是那個。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那個就是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "方才所提過的佈告欄。",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "200100101"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您、",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您沒有大礙吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來是盛大地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "摔了一跤的樣子呢……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀痛痛痛……",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇呀，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我沒事，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請不用擔心♪",
        "unit_id": 102511
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀哈哈…",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為想要貼這張啟事，所以爬上踏板又掂起了腳尖，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n沒想到一不小心失足就摔下來了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是丟人～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "鈴莓總是這麼冒失♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……鈴莓？",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哦？",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀這可不是，{player}！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "您近來可還安好嗎！",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總覺得，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "被您看到了不好意思的一面了呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人。",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您與這位女性原本就有認識嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，嗯！",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在不久之前，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就有陣子曾受過{player}的一點點關照了唷♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而這孩子……",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那個，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該不會是{player}的妹妹？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇呀～",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真可愛啊♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n妹妹，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "妳今年幾歲呀？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "今天，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是和哥哥一起出來約會嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下不是妹妹……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是為侍奉於主人之身，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "名為可可蘿。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "原來是這樣啊！",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那麼",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "跟我做的工作有點相似囉？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相似，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼說？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鈴莓小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難道也是侍奉主人之身不成……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不是啦，",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "並不是妳想的那樣！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n抱歉呢，是我講得不夠清楚！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼說呢，",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我的外貌正如妳所見，就是一名女僕對吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而我所侍奉的，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是另外一位高貴的大人♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "現在也是聽從大小姐……",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_037"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那位大人的差遣，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n來這邊找尋能夠協助我們工作的人唷。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請看這個，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這可是我費盡心思做出來的求人啟事呢♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是在徵求搬家的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幫手嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n除了行李的打包，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還希望也能護衛搬運行李的馬車嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來並不是件困難的工作，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但報酬卻給得很大方呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嘿嘿。",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_039"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然大小姐她基本上是個小氣……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃，是個節儉的人，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但在該要花錢的地方，就絕對不會手軟唷♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}你們兩位，會到佈告欄這來也是有什麼事對吧？",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_040"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果是打算找份工作……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "若你們不介意，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n要不要試試看我們的這一份工作呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果妳們剛好也在找工作的話。",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比起去僱用一些陌生人，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還是拜託本來就認識的人比較讓人放心嘛♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對我們來說就像及時雨，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n且這報酬也相當的優渥，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可說是求之不得的好機遇。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但就憑在下的一己之見無法定下此事。",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的意下如何，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？　",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這話是什麼意思呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "方才在鈴莓小姐不經意摔了一跤時，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就這麼剛好跌坐倒在主人您的身上了呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇呀？",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_045"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n對對對，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我還真是的，",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總是這麼冒失呀！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "明明騎在{player}的身上，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我竟然還那麼悠哉的聊起天來了呢！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這這這，",
        "unit_id": 102511,
        "voice": "vo_adv_2001001_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這還真是失禮了～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我馬上讓開……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊哇哇，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇呀嗚啊！？",
        "unit_id": 102511
    },
    {
        "type": "still",
        "still": "200100102"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為慌慌張張的緣故，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一不小心又摔了回來呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這已經不光只騎在人身上了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n簡直就像是交纏在一起了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，這個……",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還真是一位冒失的小姐呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的確，",
        "unit_id": 105913,
        "voice": "vo_adv_2001001_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若讓這個人來忙搬家，可得多費番苦功了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n照這麼看來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許真有幫忙的必要也說不定呢。",
        "unit_id": 105913
    }
]