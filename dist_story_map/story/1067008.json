[
    {
        "type": "background",
        "background": "501442"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由於厄莉絲現身，被迫從蘭德索爾撤退的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在獸人族的國度珊托魯斯暫時棲身，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n人則是陷入沈眠。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……幸好你平安無事。",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只是弄得這樣渾身是傷……",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n當初怎麼不一起趕緊逃跑呢。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這點正是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你向來的優點吧……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然我一點都不認為是優點。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為你老是，",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n像這樣把自己給弄得",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "遍體鱗傷……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……今天我要送你一個",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "珍藏已久的禮物♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓你我之間的羈絆，",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "能夠緊緊～地，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n重新相繫在一起……♪",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喂～",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這裡這裡～♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝你今天過來～☆",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今天天氣實在太好了，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓我就是想到戶外工作呢。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼我們出發吧♪",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "往那邊走～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我看看～",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你的裝置……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是這個，請吧☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n裝置沒有上鎖，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想怎麼用都行。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我的是這個。",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "稍微調整過的特別版♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n能夠透過mimi",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "連線到自家的伺服器，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這樣不管身在何處都能夠畫漫畫了～☆",
        "unit_id": 106731
    },
    {
        "type": "still",
        "still": "106700801"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當然是真的～！",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "底稿已經都畫好了，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以今天的工作就是",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n上墨線跟完稿。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一起加油吧～♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要是碰到不懂的地方",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n儘管發問沒關係喔？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "作業開始～♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……其實我從好久以前，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就一直想像現在這樣，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "跟其他人一起工作看看呢～♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你現在操作的是台詞的圖層。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你該動的不是那裡，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那格的圖層在另一邊……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯沒錯♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "至於網點……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "用那組就行了。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很好很好～☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就照這樣子保持下去吧，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "助手小弟♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我因為平常一直是個匿名作家，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n平常沒有人可以幫我忙。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟用數位檔案畫稿，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真要找的話也不是找不到，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只是又覺得跟想像中的不太一樣……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像這樣跟人邊交談邊上墨線不但是嶄新體驗，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我也是頭一次讓人看未完成的漫畫……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "能帶著和以往不同的心境畫漫畫，還真是有意思呢～♪",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很有趣對吧？",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "先畫上圖畫，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "再添加台詞，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n於是漫畫就完成了……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很高興你也能樂在其中～♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n其實今天找你來",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是想讓你看看這一幕。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而且……",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_021"
    },
    {
        "type": "still",
        "still": "106700802"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "抱歉稍等一下喔。",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不知道是誰，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這時傳訊到mimi……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒想到會在這時接到業務聯絡。",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你就繼續進行下去吧。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我處理一下這頭馬上回來。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟這可不是能夠交辦給別人的工作。",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_024"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只要對方肯出錢，我倒不介意就是了……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不是喔～",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我現在",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "正在駭入企業的伺服器。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n委託人希望我竊取裡頭的檔案，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我現在正忙著將它弄到手。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦？",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你幹嘛這麼驚訝呢？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這應該不是什麼值得驚訝的事情吧。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_027"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是我",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "從阿斯特朗的伺服器裡，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n偷出龍人族資料的喔？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我可是駭進了那個名叫米奈娃，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n配備各種",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當前世上最尖端科技，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n擁有怪物般性能的存在喔♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像現在這種沒什麼防護措施的伺服器，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n駭起來就跟吃飯喝水一樣輕鬆☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "實際上，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_030"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這才是我的本行。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "同人作家",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "或者說",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "漫畫家的身分，就只是畫個興趣而已♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要不要",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在商業誌畫連載啊～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "之類的，其實不少人像這樣對我邀稿過，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但我怕一忙起來會沒空玩阿斯特朗，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n目前只打算",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "以自己的步調畫漫畫。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……怎麼了？",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_032"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有哪裡覺得不解嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "「這種事」",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_033"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗎……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為我",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對這種事最拿手，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而且也樂在其中♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n加上還能賺到不少錢。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……以前啊，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_034"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在我還讀小學的時候，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n有個女生曾經",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "暫時和我讀同一所學校。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那個女孩是個",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_035"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "大家口中的天才。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n她真的樣樣精通，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "成了我崇拜的對象。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所謂的天才，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_036"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "指的就是像她這種人吧──",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我當時心想。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不過呢，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我會崇拜她並不是因為",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "她多才多藝。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "她無論做什麼，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_037"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看起來總是樂在其中。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我就是超崇拜她這點。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n即使面對不會的事，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也享受過程並持之以恆，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n最後就學會了。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看著她讓我心想，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_038"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不會做的事只要開開心心去做，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n有朝一日我也能學會吧……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這想法觸發了我。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在那之後我嘗試了許多事，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_039"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n決定挑最拿手的一項當作工作，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就一路做到現在囉♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總之，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_040"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對自己覺得有趣的事持續投入，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這就是現在的我。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n漫畫也不例外，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是因為有趣才持續到今天。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "於是學生時代我就像這樣子，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_041"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "全心做自己感興趣的事呢～☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n陪伴我的除了流夏，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有一位姓白銀的朋友，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n三人一起體驗了許多事。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們現在也偶爾會在阿斯特朗裡一起玩……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不然你指的是……？",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_042"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "106700803"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喔喔～",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_043"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我懂了～☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你想問的是，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我難道不覺得自己在做壞事嗎？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "若要問這件事，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_044"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我對自己的所作所為，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "並不會以善惡來區分喔？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "首先，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_045"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "凡事根本就沒有真正的善與惡。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有的就只有",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "彼此的意志或者說",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "願望……",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n還是改說慾望比較好懂呢？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "力量的方向？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總之",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_046"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "諸如此類的想法會彼此衝突，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓狀況隨之改變。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n１和１衝突後",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是會變成２",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還是化為０，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "抑或是變成１，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n端看衝突的一方如何計算，對吧？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而我所做的，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_047"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就只是扮演計算機的角色。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n選擇什麼工作，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "端看我是不是能夠樂在其中。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對我來說最重要的就只有",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_048"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這計算有不有趣。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n是對是錯都不重要。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "至少目前是這樣。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要是我開始追求樂趣以外的事物，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_049"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "除非是世上",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "發生什麼天翻地覆的大事，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n否則應該永遠都不可能吧？",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "既然你這麼憂心忡忡我就先聲明，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_050"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這次的目標企業是",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "作假帳的慣犯，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n委託內容只是請我揪出證據而已☆",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣做",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_051"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然能讓弊案水落石出，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但要是讓犯人的家人因此流落街頭，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n到時我也不會覺得",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "自己做了件正確的事～",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以你也要切記，",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_052"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好好想想那些你希望幫助的人。",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這不只是為了他們著想，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也是為你自己著想♪",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "另外",
        "unit_id": 106731,
        "voice": "vo_adv_1067008_053"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我會像這樣和你在一起也是因為，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我自己感到樂在其中，",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106731
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "希望你也像我一樣樂在其中……♪",
        "unit_id": 106731
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好，",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_054"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "辛苦了～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你剛才看見的是如同夢境的情景……",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_055"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不對，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n是根據我的記憶還原的畫面喔♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過等你醒來應該大部分都忘光了，",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_056"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n現在不必太在意也無所謂。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……但說是這麼說，",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_057"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n睡著的你應該也聽不進這些話吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "唉～",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_058"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要是可以的話",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真想像這樣一起畫漫畫，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n一起上街購物，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一起玩遊戲……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n有好多事想陪你一起做～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但現況不允許呢……",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_059"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "唉～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是沒意思～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "等將來有一天，",
        "unit_id": 106711,
        "voice": "vo_adv_1067008_060"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們再一起",
        "unit_id": 106711
    },
