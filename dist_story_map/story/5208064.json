[
    {
        "type": "background",
        "background": "500403"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在怜的複製品世界旅行最後一天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n從和正將軍那裡得知了祕密釣點的兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n垂下了釣線，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "悠閒地度過了安穩的時光。"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……在這之後，",
        "unit_id": 135612,
        "voice": "vo_adv_5208064_000"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我們又要暫時分別了呢。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "快樂的時光",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "總是轉瞬即逝。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵。",
        "unit_id": 108912,
        "voice": "vo_adv_5208064_001"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……嗯？",
        "unit_id": 135612,
        "voice": "vo_adv_5208064_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……啊啊，",
        "unit_id": 108912,
        "voice": "vo_adv_5208064_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "抱歉，",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我高興到",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不小心笑出來了。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝妳。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n謝謝妳說",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "跟我在一起的這幾天",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很快樂。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……",
        "unit_id": 135612,
        "voice": "vo_adv_5208064_004"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這是",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "當然的啊。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "妳、",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "妳看，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "浮標沉下去了。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在距離那裏有段距離的樹蔭下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "有個人影正注視著兩人。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……呵呵。",
        "unit_id": 1,
        "voice": "vo_adv_5208064_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n看來她們都很開心，真是太好了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怜～！",
        "unit_id": 1,
        "voice": "vo_adv_5208064_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妳在看什麼～！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "噓……",
        "unit_id": 1,
        "voice": "vo_adv_5208064_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳太大聲了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "日和。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妳看",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那邊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……啊。",
        "unit_id": 1,
        "voice": "vo_adv_5208064_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怜的……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……唔！",
        "unit_id": 108912,
        "voice": "vo_adv_5208064_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才",
        "unit_id": 108912,
        "voice": "vo_adv_5208064_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我好像聽到了日和的聲音。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有……",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "另一個聲音是……",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵……",
        "unit_id": 108912,
        "voice": "vo_adv_5208064_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……志那都，",
        "unit_id": 108912,
        "voice": "vo_adv_5208064_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳把耳朵摀起來一下。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……嗯？",
        "unit_id": 135612,
        "voice": "vo_adv_5208064_013"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "好。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 108912,
        "voice": "vo_adv_5208064_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "得好好協助我們那位有點笨拙，",
        "unit_id": 108912,
        "voice": "vo_adv_5208064_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n而且",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "又很容易害羞的隊長才行呢～！",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……！",
        "unit_id": 1,
        "voice": "vo_adv_5208064_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n呵呵呵！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯，",
        "unit_id": 1,
        "voice": "vo_adv_5208064_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "交給我吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我會在這裡",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "跟志那都一同向未來邁進，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n所以妳也……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不對。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我也要保重啊！",
        "unit_id": 1,
        "voice": "vo_adv_5208064_018"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜的這趟複製品世界旅行就這樣落幕了。"
    }
]