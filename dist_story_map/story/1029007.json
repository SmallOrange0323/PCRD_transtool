[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "演唱會隔天。\n望來找{player}。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為我一直到昨天都在忙著準備演唱會和寫新歌，",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以今天我請他們讓我休假一天喔。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸，機會難得，就我們兩人來舉辦慶功宴吧？",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦？你問為什麼兩個人……因為……",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你想想，演唱會之前我們不也一起工作了嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n那份工作的也順便辦！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就這麼決定囉！",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我知道這附近有間好吃的店，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就去那裡吃飯吧！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這間是我很喜歡的店喔。",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我想你一定也會喜歡的――",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "男粉絲",
        "words": "咦！？望望！？",
        "unit_id": 311,
        "voice": "vo_adv_1029007_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不、不好了！",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n好像是我的粉絲們……！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們快逃！\n造成騷動的話，也會給店家添麻煩的！",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_007"
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……呼……沒有再追過來了吧。",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n突然要你逃跑，抱歉喔。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那我們再去吃飯吧。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "小孩粉絲",
        "words": "啊～是望望～♪ ",
        "unit_id": 211,
        "voice": "vo_adv_1029007_009"
    },
    {
        "type": "dialogue",
        "name": "小孩粉絲",
        "words": "好可愛喔～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這裡竟然也有我的粉絲！？\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉，我今天休假――！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "老人粉絲",
        "words": "喔喔……這不是望望嗎……",
        "unit_id": 511,
        "voice": "vo_adv_1029007_011"
    },
    {
        "type": "dialogue",
        "name": "老人粉絲",
        "words": "\n跟我死去的老伴簡直一模一樣……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這、這裡也有粉絲嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要逃跑囉！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "結果逃到街道外了……\n",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但都逃到這裡了，應該不會再有――",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "無賴（小）",
        "words": "喔喔！這、這不是望望嗎！",
        "unit_id": 811,
        "voice": "vo_adv_1029007_014"
    },
    {
        "type": "dialogue",
        "name": "無賴（小）",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "無賴（小）",
        "words": "老子是你的鐵粉喔！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "我也是！待會再讓我逮捕你們！",
        "unit_id": 711,
        "voice": "vo_adv_1029007_015"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士",
        "words": "\n望望！先幫我簽個名！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "嗯，我們都先不要吵了！",
        "unit_id": 911,
        "voice": "vo_adv_1029007_016"
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "\n望望",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "無賴（大）",
        "words": "，跟我握個手吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "連、連這裡都有！？",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天……今天一天就好，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "放過我吧――！",
        "unit_id": 102911
    },
    {
        "type": "background",
        "background": "500211"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們兩人終於能夠獨處了。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然已經傍晚了……\n唉，難得的休假要結束了。",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉喔。\n我又搞砸了你的休假……",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "話說回來，我們第一次見面也是這種情況呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你說的沒錯。\n不久前我們兩人才約會……",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才練習過約會而已呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是啊。像是女生、小孩和老爺爺粉絲們……",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有各式各樣的人為我加油，真的很開心呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但我的目標是超級偶像喔。",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n還差得遠呢。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我得更加更加地努力才行。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那我們兩人來舉辦慶功宴吧！",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n雖然沒有食物和飲料……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸，坐吧坐吧！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……你說再不回去就太晚了？",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖、雖然這麼說沒錯啦……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但我們還沒舉辦慶功宴呢……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是、是嗎？能聽到你這麼說……我也很開心。",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，說得也是。",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然今天泡湯了，但下次一定要……",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃，果然還是不行嗎？",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n雖然我很開心有這麼多粉絲，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n但相對的一定會失去私人時間……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "唉……不能跟你一起玩……",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我要不乾脆不當偶像了……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我、我當然是開玩笑的喔！開個玩笑而已～",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……{player}，\n你希望我繼續當偶像嗎？",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果……{player}對我說，",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n「不要當偶像了」的話……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呵呵呵。",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你不可能會說這種話吧。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為你一直都在為我加油嘛。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "當偶像是一件相當辛苦的工作，",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_034"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不但有一堆討厭的事情，也完全沒有私人時間……",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "即便如此，我能堅持下去的理由，\n就是因為遇到了你喔。",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_035"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為啊，你知道我是偶像後，\n還能很自然地跟我相處對吧？",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_036"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只有在你面前，\n我才能……成為一個普通的女孩子喔。",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_037"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以，我平常才能繼續努力當偶像。",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_038"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n像現在這樣和你在一起的時間，",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n正是支持著我的原動力喔。",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個……\n今天我有件事無論如何都想告訴你――",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_039"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我，",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_040"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對{player}──",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對{player}──",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_041"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "………………",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_042"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對{player}……一直以來都很感謝喔。",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_043"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我很信賴你。\n在我成為頂尖偶像前，你要繼續協助我喔？",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_044"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈，今後也請多指教！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "以上就是我想說的話，完畢！",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_045"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我們回家吧！{player}！",
        "unit_id": 102911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "………………",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_046"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果告訴他我的心情，\n我就沒辦法再當偶像了……",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_047"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但如此一來，\n就會白費了你對我的支持……",
        "unit_id": 102911,
        "voice": "vo_adv_1029007_048"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以我只能將這句話藏在心裡……",
        "unit_id": 102911
    }
]