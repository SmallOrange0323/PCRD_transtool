        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "矛依未妳的份也全都沒了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到底有什麼好開心的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "發現寶箱時的興奮期待……",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_060"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "與夥伴一起逃脫怪物魔爪時的悸動心跳……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那正是",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_061"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "冒險的樂趣對吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳說是不是？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔……",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_062"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個嘛……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是無法否認沒錯。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對吧！",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_063"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跟發現或丟失寶物之類的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "毫無關係！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n冒險本身",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才是我現今的目的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我現在",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_064"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "非常的開心！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n因為能跟你們",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "一起冒險！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……唉。",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_065"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你們兩位還真悠哉！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "太過悠哉了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓懊悔不已的我看起來開始像個傻子了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……不過，",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_066"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也是吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "冷靜下來想想，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "剛才……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說不定",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也很開心就是了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎，是嗎！",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_067"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那麼",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也很開心喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……但是，",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_068"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種「最棒的寶物是冒險的回憶」",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "之類的結局就免了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我一定要獲得值錢的東西！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_069"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "調整好心情，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們走吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n去尋找比剛才的寶石",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "更為驚人的寶物！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是祈梨一行人為了探尋新的寶物，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n朝著更上面的樓層前進。"
    }
]