[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "祈梨為了獲得寶物而繼續探索露娜之塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是完全沒能找到值錢的東西，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n漸漸地開始顯現出死心的氛圍。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼……",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "已經爬了好一段路了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n但目前卻毫無所獲……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看來這下子是白費一場了……",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也許在據點以完美重現慈樂之音的舞蹈為目標練習，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n還更有意義吧……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別發牢騷了嘛。",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "能像這樣跟你們冒險，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我倒是很樂在其中耶！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "在幫派成員的世界只去享樂是不行的！",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要是不好好賺到錢，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就無法更上層樓──",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……呃，",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼了，小哥？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n突然停下來。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "難道說，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "又有魔物……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……幸好，",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看來對方還沒察覺到我們的樣子。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓我用偷襲來打倒魔物吧。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "兩位，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你們在這邊等我！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真的假的，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳一個人行嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那傢伙",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是龐然大物耶？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒什麼，",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要活用跟步未未在怪盜活動",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n培養出來的隱密技能，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這只是小菜一碟！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "從後方",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "悄悄地、悄悄地……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呵呵呵……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "都這個距離了還沒有發現，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是個蠢傢伙！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看我一擊就打倒你！",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘿啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫噫！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒有打倒！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "難不成，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只是把牠激怒了……！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不，",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "祈梨，妳做得好！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "趁牠注意力放在祈梨上時，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "由我來打倒！",
        "unit_id": 106113
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣的戰鬥方式不錯！",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "接下來就照這樣作戰來前進吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳是指由我來當誘餌嗎！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "駁回，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這種作戰我要駁回啦！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎？",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我覺得是很好的作戰就是了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……嗯？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛才的魔物，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "有掉落寶箱耶！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看上去很像藏有寶物的樣子！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我來！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓我來打開它！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "拜託了，",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "裡面請藏有值錢的東西……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好，我要開了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "打開囉！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦哦……！",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼哼……",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哈～哈哈哈！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n成功了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我終於成功了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有了這麼多的寶石，",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "保證會成為大富翁！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我的時代終於要開始了！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼好像……",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "相當地得意忘形耶。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n她一直都是這樣嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是要得意忘形啦，",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有這麼多耶！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n好了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "把寶物全部塞進包包裡！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳認真的嗎！？",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看起來有幾十公斤耶！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒問題、沒問題！",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "幸福也是有重量的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這樣背負起來才有意義！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼、",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "實在是……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有點重呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這當然囉。",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我說，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要換我來拿嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒事，",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這不算什麼……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳別問了，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "去留意魔物或陷阱之類的！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對了。",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "關於寶物的分配……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不需要喔。",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算沒錢也總會有辦法的！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那可不行！",
        "unit_id": 106611,
        "voice": "vo_adv_7027004_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這種事要是沒有好好決定，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "之後會起爭執的！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是喔，",
        "unit_id": 106113,
        "voice": "vo_adv_7027004_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是那樣一回事嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是那樣一回事！",
