[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在城鎮的近郊，有一位抱頭苦惱的小孩。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊──真是的！",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n接下來",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣要我該怎麼辦才好！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣的話，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不就變成是我在逞強了嗎……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不對。",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n可是，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "被當作小孩果然還是令人很生氣！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是……",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要我和魔物戰鬥什麼的，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n萬一出了什麼狀況的話……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我該怎麼辦。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "幹、",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "幹嘛啦。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你不要突然向我搭話啦！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "話說回來，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你是誰啊！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不過你無法對正在苦惱的淑女置之不理，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n也算是蠻有紳士風度的……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你這個人搞什麼！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "話說，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你不要把我當成小孩子！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n突然跟我搭話還這麼說，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你真是個失禮的傢伙！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……說真的，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你到底是什麼人？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "難道你是來",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "向我搭訕的嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呵呵，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "果然有我這種水準之後，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n身上的那個就藏不住了呢。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……咦？",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你問我",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是哪個？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我是指費洛蒙啦，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "費洛蒙。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "從成熟淑女身上散發出來的",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "魅",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "・",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "力♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "等等！",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n什麼嘛！你一副冷淡的眼神是怎樣！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什、",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你說差不多要五點了，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "叫我最好快點回家！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所‧",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "以‧",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "說！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你別把我當小孩子──！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我把話說在前頭了，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我可是不會回家的！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為我等一下",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還得去打倒魔物不可！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦？",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你問為什麼，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那是因為……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哼！",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n都是那些臭男生不好！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為他們不肯認同我已經是一位成熟的淑女了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "他們故意說些",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n「既然妳是大人的話，應該能打倒魔物吧」",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "之類的話……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "男生真的是",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "又蠢又幼稚！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不過，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "像魔物這種東西，\n我可是一點也不害怕！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我要輕鬆地打倒魔物給他們瞧瞧！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什、",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你說我、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "的腳、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在發抖？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怎麼",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可能！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的眼睛",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是不是有問題呀！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "算了。",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n既然連你都把我當小孩看的話，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我就做給你們看！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我會華麗",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "又快速地，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在一瞬間將魔物打倒――",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀――！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n出現了――――――！！？？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怎怎怎、",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怎麼辦……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n魔物比我想像的還要大太多了……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可是，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如果不設法解決牠的話，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "男生會看不起我的――",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀――！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是糟透了！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "為什麼我要因為臭男生的關係，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "而落入這種窘境……！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "等、等一下！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你想做什麼啦！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "竟然突然抓住我的手……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_029"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你說要逃走！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "別開玩笑了！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我身為一位成熟的淑女，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怎麼可以做這種事――",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呀――――！！",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我們要逃跑了呦！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你快點在前面幫我帶路！！",
        "unit_id": 105011
    },
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "幹、",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_031"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "幹嘛啦。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你不要一直盯著我看！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "受傷？",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_032"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我沒有受傷啦！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n硬要說的話",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "，倒是你那麼大力地握住我的手，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以覺得手有點痛而已！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是的……",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_033"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你為什麼",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要做這種多餘的事？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n像那種程度的魔物，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "只要交給我這個成熟的淑女，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就能在一瞬間優雅地――",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什、",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_034"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我什麼時候",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "說過魔物很可怕了！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_035"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "等一下！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我想還是算了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你可以不用告訴我詳細情況！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_036"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真的是笨蛋笨蛋、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "笨蛋！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "都是因為遇到你的關係，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我今天一整天都糟透了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不過，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_037"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "算了……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哼！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個，",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_038"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你叫什麼名字？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你問我為什麼要問這種事……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "別管那麼多，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "給我回答就對了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗯……叫做{player}啊。",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_039"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我知道了。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我就姑且告訴你一下，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我的名字",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "叫美咲。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個、",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_040"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呃……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "謝、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "謝謝你",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "救了我。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這、",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_041"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這種時候，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我要是不自我介紹，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還有跟你道謝的話，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n之後我會被媽媽罵的！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "多、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "多謝你了。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是、可是！",
        "unit_id": 105011,
        "voice": "vo_adv_1050001_042"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我身為一位成熟的淑女，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n其實真的不需要什麼幫忙喔！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "唯獨這一點，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你絕對不要搞錯了！",
        "unit_id": 105011
    }
]