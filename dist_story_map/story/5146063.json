[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "ペコリーヌはクリスマスイベントの準備が進む"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nランドソルの街を一人、散策していた。"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ふふ、",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_000"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "クリスマスの準備、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "着々と進んでますね。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "クレジッタさんは心配そうでしたけど……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "この調子なら、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "当日も成功間違いなしですね♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "今からもうワクワクしちゃいます☆",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "くっ",
        "unit_id": 1,
        "voice": "vo_adv_5132063_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "くっ",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "く……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "無邪気にクリスマスを楽しみにするなど",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\nおめでたいものだな、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "白き王女よ。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "どちらさまですか？",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_003"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "歓喜に沸く冬の祝祭、",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_004"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "クリスマス。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "だが",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "その煌めきの裏に蠢く闇があるということを",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\nまだ知らぬと見える──",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "わあ、",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_005"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "アンナちゃん！　",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "お久しぶりですね！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "う、",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_006"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "うむ、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そうだな……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "息災のようでなによりだ。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ところで今、",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_007"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "クリスマスの闇がどうとかって言ってましたけど、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\nそれって本当ですか？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "フッ、",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_008"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "無論だ。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "この世界には人知の及ばぬ",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n恐ろしきものどもが",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "数多存在する。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "奴らは常に我々を監視し、",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_009"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "隙あらば魔の手を伸ばさんとしている。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "それは",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "クリスマスとて例外ではない。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "いや、",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_010"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "人々が歓楽に浮かれ心に隙が生まれる時こそ、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n奴らが狙いし絶好の機となるだろう。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "人心の闇に付け入り",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "悪逆の道へいざなわんとするのだ。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "そんな……",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_011"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ア",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ンナちゃんの話が本当なら、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "この国の王女として",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n見過ごすわけにはいきません。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n人々を守るために、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "そのお話",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ぜひ聞かせてください！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "聡明なる王女よ。",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_012"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ならば教えてやろう！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "クリスマスに顕現せし",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "恐怖の魔女、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ベファーナの伝承を！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "魔女、",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_013"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "ベファーナ……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "ベファーナは",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_014"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "善良な子供にはプレゼントを、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n悪い子には炭を贈ると伝えられている。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "炭……",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_015"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "それは、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "どうしてですか？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "疑問に思うのも当然だ。",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_016"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "子供への戒めなら",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\nもっと分かりやすくイヤなものを贈ればいい。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "悪童なら炭を渡されたとて",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "悪戯に使うこともあろう。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "黒き魔女の目的は何か……",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_017"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "長きにわたり",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "謎とされていた。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "だが、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "私は一つの結論に辿り着いたのだ。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "これは──",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "素質ある子供に対する、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "闇への誘いの証なのだ！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "炭の色──",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_018"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "すなわち黒、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "これは端的に",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "闇を意味するのであろう。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n闇色の贈り物をすることで、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "子供を闇に染め、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n自らの眷属とする……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "そのための",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "行動なのではないかと。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "な、",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_019"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "なるほど、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "言われてみればその通りです！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "さらに",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_020"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "この伝承とよく似たブラックサンタと呼ばれる",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n黒衣の男の存在も確認されている。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "奴らはクリスマスという光の宴の裏で、",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_021"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n宵闇の中に、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "蝋燭の暖かな光の作り出すわずかな影に潜んで",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\nその魔の手を伸ばし続けているのだ！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "……",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_022"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "そう、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "だったんですね。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "わたしの知らないところで",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "そんな恐ろしいことが……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "知らぬのも無理はないな。",
        "unit_id": 100911,
        "voice": "vo_adv_5132063_023"
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "奴らは極めて狡猾、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "私やシグルドのように",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "\n戦禍に身を置く者でなければ",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "知りえぬことだ。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "あの、",
        "unit_id": 105812,
        "voice": "vo_adv_5132063_024"
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "よかったら",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "もっと色々聞かせてくれませんか？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "アンナちゃんのお話、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "ペコリーヌ",
        "words": "すっごく面白いので！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "シュテッヒパルム",
        "words": "え？　",
        "unit_id": 100911,
