[
    {
        "type": "background",
        "background": "500833"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你、",
        "unit_id": 106611,
        "voice": "vo_adv_6027102_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你是說老大嗎！？　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噓！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你太大聲了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n那女的搞不好在某個地方",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聽我們說話……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥你也要注意喔！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是說啊！　",
        "unit_id": 106611,
        "voice": "vo_adv_6027102_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她總是笑容滿面，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n沒有人知道她到底在想甚麼……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "搞不好她現在也聽得到我們的對話！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "快、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "快逃吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊？　",
        "unit_id": 106611,
        "voice": "vo_adv_6027102_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……啊？　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊～～？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥你察覺危機的能力實在太不夠了！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我就來好好告訴你老大到底有多恐怖！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯，",
        "unit_id": 106611,
        "voice": "vo_adv_6027102_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你這樣講也不能說不對啦。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她一定",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有什麼事情瞞著我們……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是個恐怖的女人！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "剛剛的對話你要保密喔？",
        "unit_id": 106611
    }
]