[
    {
        "type": "background",
        "background": "500550"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在神殿工作的某一天，\n休息中的{player}與鈴莓――"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "甜心，",
        "unit_id": 311,
        "voice": "vo_adv_1121003_000"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們是不是不行了……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我好害怕喔，",
        "unit_id": 411,
        "voice": "vo_adv_1121003_001"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "達令……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？　",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那些人",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是怎麼了呢？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看起來好像非常消沉的樣子……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說得也是。",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n或許有什麼我們能幫得上忙的地方！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個～",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不好意思。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請問你們遇到了什麼麻煩嗎？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "……其實我們",
        "unit_id": 311,
        "voice": "vo_adv_1121003_005"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "剛才去求籤。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n想說",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "要一起來確認今後的運勢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "結果我們的",
        "unit_id": 411,
        "voice": "vo_adv_1121003_006"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "戀愛運卻是最差的！！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "同時抽到戀愛運最差的籤，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這機率到底有多低啊！！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們交往了三年！　",
        "unit_id": 311,
        "voice": "vo_adv_1121003_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "都快接近終點了說！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒想到我們的關係竟然會以這種方式結束！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "居、",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "居然為了籤的結果這麼動搖……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "難道我也是這種感覺嗎……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就、",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就是說呢。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我覺得不需要太在意喔。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n籤只是一種叮嚀，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是類似參考的東西。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "曾經因為太在意籤的結果，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而白忙一場……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "就算妳這麼說……",
        "unit_id": 411,
        "voice": "vo_adv_1121003_011"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "對了！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n巫女小姐，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "請妳替我們結緣吧！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦咦～！？　",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "為什麼會變成這樣！？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "該怎麼說呢，",
        "unit_id": 411,
        "voice": "vo_adv_1121003_013"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳想想！　",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "就算籤的結果很糟糕，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n但只要有巫女小姐的力量，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "感覺就會有辦法克服了！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "的確！　",
        "unit_id": 311,
        "voice": "vo_adv_1121003_014"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "況且這裡是神殿，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "應該會有結緣之類的儀式吧？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "為了我們那相親相愛的未來，求求妳了！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那、",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的可以讓我來嗎？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "要結緣的話，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還是去拜託祭司大人――",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不，",
        "unit_id": 311,
        "voice": "vo_adv_1121003_016"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "能在這裡相遇也是某種緣份吧，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我們希望能請巫女小姐來做！　",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "妳不願意嗎！？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……我、",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我知道了。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也不清楚自己能做到什麼程度，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但為了兩位，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我會加油的！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "情侶",
        "words": "謝謝妳！",
        "unit_id": 1,
        "voice": "vo_adv_1121003_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我去向祭司大人",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "確認關於結緣的問題，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請在這裡稍等一下。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這裡沒有進行",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "結緣的儀式！？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "嗯。",
        "unit_id": 511,
        "voice": "vo_adv_1121003_021"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "我們是有結緣的護身符，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n但這座神殿只有進行",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "消災解厄和祈求健康的儀式而已……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "真是抱歉。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因、",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為有護身符，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我還以為一定有儀式呢……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我居然沒有確認清楚，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼會這樣子～……！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看來只能",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "跟他們兩人說這裡沒有進行結緣儀式了。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n可是，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣他們又會很消沉吧……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我自己的方式？",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可是，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這樣自作主張",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的好嗎？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "只要有想為了他人去做些什麼的心意，",
        "unit_id": 511,
        "voice": "vo_adv_1121003_025"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n我想一定",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "會有結緣的效果的。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "雖然這並不是神殿正式的儀式，",
        "unit_id": 511,
        "voice": "vo_adv_1121003_026"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "但如果有事先向他們說明過情況再進行的話，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "我想應該沒問題的。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……我知道了！",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那個，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可以請你也來幫忙嗎？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n該怎麼進行結緣比較好，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請你和我一起思考！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不好意思，讓你們久等了。",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_028"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "首先，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "有件事必須先告訴兩位――",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起！",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這座神殿",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "並沒有在進行結緣的儀式！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "情侶",
        "words": "咦～！？",
        "unit_id": 1,
        "voice": "vo_adv_1121003_030"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那我們的戀愛運就只能",
        "unit_id": 411,
        "voice": "vo_adv_1121003_031"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "維持在最差的結果了……？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒救了……",
        "unit_id": 311,
        "voice": "vo_adv_1121003_032"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "完蛋了……！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但、",
        "unit_id": 112111,
        "voice": "vo_adv_1121003_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但是相對的！",
        "unit_id": 112111
    },
    {
