        "words": "\n這樣子",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就能打倒了……",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "吧？",
