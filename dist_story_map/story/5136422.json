    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大家",
        "unit_id": 135512,
        "voice": "vo_adv_5136422_001"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好厲害喔！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n對方明明變得很強，卻還是打贏了！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "很好，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "今天要大肆慶祝喔──！　",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……實際上",
        "unit_id": 128812,
        "voice": "vo_adv_5136422_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是如何？",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們沒能打贏吧？",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "…………是啊。",
        "unit_id": 135613,
        "voice": "vo_adv_5136422_003"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "沒能打贏。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "但確實有把它趕跑。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……戰果已經十分足夠了。",
        "unit_id": 135613,
        "voice": "vo_adv_5136422_004"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n做得好。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……是嗎。",
        "unit_id": 128812,
        "voice": "vo_adv_5136422_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就好。",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "各位，",
        "unit_id": 128911,
        "voice": "vo_adv_5136422_006"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "辛苦了。",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我馬上就來──",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……啊。",
        "unit_id": 128911,
        "voice": "vo_adv_5136422_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 128911,
        "voice": "vo_adv_5136422_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生、",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "菲歐。",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n雖然有點難以啟齒，",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但是你們可以再稍微",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "幫我強化一下嗎？",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我想要提高恢復力……",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "拜託你們了。",
        "unit_id": 128911
    }
