[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不好意思。",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "結果我還是請你陪我去買東西了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊哈哈。",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為我稍微走幾步就開始頭昏眼花了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "與其說是擔心我，不如說是你無法放著我不管吧。",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你真是個溫柔的人呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇、唉呀……？",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對不起。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n今天的風很大呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不知道是我太瘦了，還是自己站不住……",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一吹到風我就好像快要",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "飄～起來了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "走路都走不穩。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你扶著我。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天我已經像這樣頭暈了好多次……",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "每次遇到這種情況，{player}都會扶著我。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以我已經慢慢地習慣依靠你了呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我這樣是不行的吧。",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n總是依賴別人。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，因為我出生時就是這副身體了……",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我想這也是沒辦法的事，已經放棄了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過我還是覺得很不好意思。",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要多少做點運動來增進體力才行。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因此，那個……",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你已經幫我提買來的書了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是我自己的東西我可以自己提喔？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你說提東西之類的就讓你來做吧？",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我覺得很感激……只是你為什麼",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n對我這樣的人這麼親切呢？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊……",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n像是在打發時間的感覺嗎。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為我的緣故，",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n占用某個人一生中的寶貴時間，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會讓我很過意不去……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果你是抱持這樣輕鬆的心情，我比較不會煩惱呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊哈哈……",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你是自然而然就會去幫助別人吧。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣行有餘力的感覺，真好",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，總之……",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要是買一大堆東西，憑我的臂力也提不回牧場。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我就買到這裡就好了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n因為想要的書等等的，我大致都買齊了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "其實我還想要買衣服……",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n還有套裝信封之類的東西。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只是如果我買了一堆，對我也會是個負荷。",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我在醫藥費方面就已經給父母造成負擔了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以我就婉拒父母的好意，沒有向他們拿零用錢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我偶爾會幫忙做些牧場裡的工作，有拿些薪水。",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我是用這些錢買東西的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "而且我想盡可能地寄些生活費回老家，所以不能用得太奢侈。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我只要這樣就很滿足了。",
        "unit_id": 103811,
        "voice": "vo_adv_1038002_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n這是像我這樣的人也能承擔的些許寶貴責任……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想，如果能用自己的方式努力珍惜它就好了。",
        "unit_id": 103811
    }
]