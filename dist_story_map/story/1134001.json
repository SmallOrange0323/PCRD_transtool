    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了報告美里在特別赴任時的狀況，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}前往了精靈之森，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這時正好碰見初音與栞在聊天。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣啊～",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "看來小栞也過得很快樂呢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n真是太好了～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，",
        "unit_id": 103811,
        "voice": "vo_adv_1134001_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這都多虧有【伊麗莎白牧場】的大家在。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以我也──",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n啊，{player}，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你好……！",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的耶！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "{player}，好久不見～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那還用說！",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n初音我可是隨時都充滿活力呢～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且，",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "今天小栞也在！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "讓我的活力",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "變成平常的200%了唷～♪",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵，",
        "unit_id": 103811,
        "voice": "vo_adv_1134001_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊還真誇張。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我最近",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "身體狀況不錯，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "加上精靈之森也很涼爽，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n所以我就趁著避暑來這裡玩了。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過",
        "unit_id": 103811,
        "voice": "vo_adv_1134001_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你怎麼會突然來這裡？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我聽說{player}接受了公會管理協會的委託，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n前去擔任美里老師的助手……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對啊，",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "聽說你會跟美里老師一起去海邊！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n難不成……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "發生什麼事了嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣啊，",
        "unit_id": 103811,
        "voice": "vo_adv_1134001_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "美里老師要擔任沙灘棒球社的顧問，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是嗎……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沙灘棒球啊～",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n美里老師",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還真是辛苦呢。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "感覺很有趣！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我要不要也去幫忙加油呢～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也這麼覺得。",
        "unit_id": 103811,
        "voice": "vo_adv_1134001_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n姊姊的開朗個性，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "都一定能鼓舞許多人的。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n無論是隊伍的成員，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或是去看比賽的觀眾。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿～",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣說我會害羞啦～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果能幫上大家的忙，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我就得多努力才行呢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "欸嘿嘿～",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你都這樣說了，那怎麼好拒絕呢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我就來助{player}一臂之力吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我會用最響亮的聲音",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "幫你加油的～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 103811,
        "voice": "vo_adv_1134001_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還真有幹勁呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n但如果是姊姊的話，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不只是{player}，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n想必也能為其他人注入活力。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "很～好！",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那麼我們就早點出發吧～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "閃亮亮☆",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊",
        "unit_id": 103811,
        "voice": "vo_adv_1134001_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "等一下，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣會不會有點太性急了？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "畢竟是要出遠門，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我認為要好好準備。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "妳說得對！",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我們可是要去海邊，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且還要待上幾天。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不能抱著只是稍微出門去遠足",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "的想法來準備呢～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "替換的衣服跟睡衣，",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "枕頭跟毛毯……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "其他還有什麼需要帶上的東西嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對了，",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "還有泳裝！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒帶到泳裝一定會很麻煩！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但是，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我沒有泳裝，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這時候就要──",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇～！",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這件泳裝真的好可愛！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "妳覺得怎麼樣？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是呀。",
        "unit_id": 103811,
        "voice": "vo_adv_1134001_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我覺得很可愛，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也很適合姊姊。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "動起來可能會",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不太方便呢。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "要去加油的話，",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "選擇適合運動的款式比較好。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "原來如此！",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼這件如何呢？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "感覺動起來很方便！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯～",
        "unit_id": 103811,
        "voice": "vo_adv_1134001_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然感覺動起來很方便……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但似乎有點太性感了……",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "喔～",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這樣啊～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "挑選泳裝比想像中的還要難呢～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "每一件都好可愛，讓人無法決定……",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_024"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "{player}現在拿的那件泳裝！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "讓我看一下！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇～",
        "unit_id": 101211,
        "voice": "vo_adv_1134001_025"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這件很棒呢！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n看起來就給人一種「我來加油囉！」的感覺！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對啊。",
        "unit_id": 103811,
        "voice": "vo_adv_1134001_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這個造型是叫啦啦隊，",
        "unit_id": 103811
    },
    {
