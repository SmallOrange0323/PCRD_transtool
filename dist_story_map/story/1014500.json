[
    {
        "type": "background",
        "background": "509010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我好像比約定好的時間",
        "unit_id": 101411,
        "voice": "vo_adv_1014500_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還要早到很多呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還沒到。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n想不到他會約我出來，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是稀奇。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "話說回來，",
        "unit_id": 101411,
        "voice": "vo_adv_1014500_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "今天是我的生日。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還問過我最近有沒有什麼想要的東西……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有很高的機率是……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "應該",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是吧……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哎喲，",
        "unit_id": 101411,
        "voice": "vo_adv_1014500_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我怎麼會察覺到",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這件事呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣我的推理能力不就適得其反了嗎……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊──",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呃，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗨！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "今天天氣真好！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_1014500_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝謝。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你還真是個率直的人。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然我心裡有數了……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還是忍不住會心跳加速呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我可以",
        "unit_id": 101411,
        "voice": "vo_adv_1014500_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "拆開禮物了嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n推理？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我才不做那種不解風情的事呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想用自己的雙眼確認以後，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "發自內心感到喜悅。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為今天是我生日，",
        "unit_id": 101411,
        "voice": "vo_adv_1014500_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以給我一個……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謎題？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哦，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "挺有意思的嘛。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那就說來聽聽吧，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你所發現的神祕事物。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哎呀，",
        "unit_id": 101411,
        "voice": "vo_adv_1014500_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你還在做什麼呀，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "坐到我旁邊來。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你是我的助手，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以要和我一起思考。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我和你",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "攜手揭穿所有謎團的真相吧！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101411,
        "voice": "vo_adv_1014500_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "什麼！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你是認真的嗎！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你好好想一想，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n搞不好不小心忘了什麼事！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不然我也幫你一起回想吧！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411,
        "voice": "vo_adv_1014500_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "什麼？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這本書",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是送我的生日禮物？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……助、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這都是你預謀好的吧！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "居然這樣玩弄我的純情……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生真壞！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "其實呀，",
        "unit_id": 101411,
        "voice": "vo_adv_1014500_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我在想你會不會是要幫我慶生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n根據推理……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不是的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是我心裡",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有一點點期待啦。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "實際上，有人為自己慶生，",
        "unit_id": 101411,
        "voice": "vo_adv_1014500_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就算有猜到",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也控制不住情緒呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n高興得",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "無法像平時一樣",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "冷靜。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嘿嘿……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝謝你，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生♪",
        "unit_id": 101411
    }
]