    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對不起啦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "上一次我和你一起去了燒肉店。",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n結果我忘記帶錢，最後還是沒有由我付錢呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "明明就講好要請你的～對不起對不起♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我呀，平常出門時不太會隨身帶錢呢～",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "完全忘記這件事情了呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過就算沒有帶錢，通常也都能夠解決的。",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "船到橋頭自然直呢～對吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這次只要能夠從貝利奧火山取得木炭，",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n以及稀有食材的話……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們還沒支付的餐費就能一筆勾消啦～",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "人間處處有溫情呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們原本就說好燒肉店的費用要由我來付。",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以說呢，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你不用勉強自己陪我也沒關係的啦～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯？",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你說要工作償還自己吃掉的部分？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真是認真呢～其實你不用這麼做的啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為你沒有什麼體力，所以登山途中得休息好幾次，",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "多花一些時間在所難免～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我一個人來的話事情會比較簡單呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過對於你的心意我覺得很開心呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我們就一起登山吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那邊有高低差要小心一點呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我拉你上來吧～嘿咻～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你呀，應該要多鍛鍊一下自己的體力呢？",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你實在是太虛弱了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要不要我來教你空手道和舞蹈呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "貝利奧火山蠻高的，所以空氣也會變稀薄～",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n而且它是活火山會噴出奇怪的氣體，讓空氣很差呼吸不順呢。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我在這裡也不能太大意呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "晚點要是覺得身體不舒服的話要說出來呦～",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我會揹你下山的～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯。",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n這可是攸關性命，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不可以勉強，不舒服就要說出來呦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且貝利奧火山裡棲息的魔物也相當強悍～",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們要慎重行動才行呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你真是愛撒嬌呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們才剛開始登山而已～你應該還很有精神的呀？",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "加油、",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "加油～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～感覺好像自己多了一個小寶寶呢～",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n可愛的小貝比，泥想要偶抱抱泥嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真拿泥沒辦法膩～要乖乖滴呦……♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀。發現目標物了～",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這是只有在貝利奧火山才能取得的木炭呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "用這種木炭來烤肉的話，聽說會變得非常美味呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，袋子裡能裝多少就裝多少吧。",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈～兩隻手都變得黑漆漆的了啦～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我要在你的臉上塗鴉～幫你畫個鬍子好了♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～感覺好像在野餐，真開心呢～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸？你說我們是在工作，所以不可以太放鬆？",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對不起～我的個性就是這樣的呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "其實我已經算有要認真在工作了呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯。接下來只要取得那個罕見的食材，任務就達成了～",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好像是～全身覆蓋著熔岩、長得像豬的魔物。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n那種魔物好像可以變成高級食材呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過牠算是相當強的魔物，",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n也是只棲息在貝利奧火山的稀有物種。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "燒肉店沒有辦法自己取得這個食材，",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以才會來拜託我們的～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過全身都覆蓋熔岩的話，",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n只要牠不動，我們也分不出牠和普通熔岩的差異吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且火山地區裡硫磺的味道又很強烈，",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我的鼻子也都不靈光了",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這次我們就放棄罕見食材的部分，只把木炭運下山也不錯吧？",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這也不是什麼緊急的工作～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們就多嘗試幾次，直到任務達成就好了吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且比起這些事情，",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我的肚子已經餓了～我們來吃午餐吧？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯！我在真步施加了魔法的保冷盒裡頭，",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n放進了新鮮的生肉～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "只要再搭配鐵網和醬料，我們就可以烤肉了呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且我們還有最高級的木炭呢～",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在野外吃肉感覺好像在玩BBQ一樣有趣呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過我不管做什麼事都很開心就是了啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你覺得開心的話我也會很開心呢～",
        "unit_id": 101711,
        "voice": "vo_adv_1017006_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n雖然不管烤肉還是跳舞都可以自己來，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但是和你在一起會更加更加快樂呢……♪",
        "unit_id": 101711
    }
]