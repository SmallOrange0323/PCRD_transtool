[
    {
        "type": "background",
        "background": "500159"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "跟美咲一起演出的舞台……",
        "unit_id": 121311,
        "voice": "vo_adv_6088202_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然靠我們自己準備各種大小事很辛苦，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n但似乎也對磨練演技有幫助。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但願能讓大家都看得很開心。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "才、",
        "unit_id": 121311,
        "voice": "vo_adv_6088202_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "才沒有那回事呢。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我光是要熟悉每一個舞台就已經很吃力了。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "只要盡心竭力一步一腳印走下去，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總會有",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那麼一天的吧？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "要是我自己不開心，",
        "unit_id": 121311,
        "voice": "vo_adv_6088202_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就無法傳遞快樂給客人是吧。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "為了讓正式演出更有趣，",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我得加倍練習才行。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "也得叫美咲陪我一起練習！",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "製作人？",
        "unit_id": 121311,
        "voice": "vo_adv_6088202_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我、",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我從來沒有考慮過那種事。",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有認識製作人嗎？",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 121311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "果然哥哥才是最厲害的……",
        "unit_id": 121311
    }
]