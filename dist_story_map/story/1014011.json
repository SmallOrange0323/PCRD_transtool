        "type": "dialogue",
        "name": "霞",
        "words": "就只有學長了……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "能像這樣",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_036"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "和學長沉浸在解決事件的餘韻當中，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n對我來說……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "比什麼都重要。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對了學長，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你知道嗎？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我們兩人，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在這所學校中",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也變成謠言了唷！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……啊！",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不是！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖說是謠言，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但內容並不是……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n關於我和學長之間的關係……！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果和我們商量煩惱，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_040"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就會替委託人解決困難的雙人組。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是這樣的謠言。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對我來說，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_041"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我本來期待",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "會以偵探搭檔之名讓眾人知曉，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但現在還……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感覺像是",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學校的便利屋一樣。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_042"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "現實的偵探跟故事中的不同，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就像整天在調查東西的",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "便利屋一樣嘛。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "即使如此，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_043"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也多多少少……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在我本以為是灰色青春的每一天裡，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "都加上了一點色彩。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝謝你，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_045"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總覺得，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "氣氛變得好害臊喔。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "差不多……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "該回家了吧。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧──",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_046"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還在家裡等著我。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_047"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在我",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "家裡？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這是為什麼……？　",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "算了，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_048"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒差。",
        "unit_id": 101431
    },
    {
        "type": "still",
        "still": "101401101"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後啊，小霧。",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_049"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n站在犯人身處的教室前",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感到非常緊張的我，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n是學長給了我勇氣。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "喵～♪",
        "unit_id": 1,
        "voice": "vo_adv_1014011_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "他說：「霞的想法沒錯喔，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_051"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n因為有我陪妳，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以別害怕。」",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嘿嘿……♪",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_052"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n學長，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真是帥氣呢～",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然我自稱偵探是有點狂妄，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_053"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但如果我真的當了偵探，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長就是……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我的助手，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對吧。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "……喵？",
        "unit_id": 1,
        "voice": "vo_adv_1014011_054"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長他啊，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_055"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "會好好地聆聽我的想法並回話，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n藉此替我整理思緒。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "簡直就是，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_056"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "推理小說裡偵探必備的",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手角色呢。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我跟學長，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_057"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也許很合得來。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n甚至合拍到",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "可以變成推理小說中的主角搭檔一樣！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……呃，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我的結論跳太快了嗎？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我說，小霧，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_058"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳覺得呢？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "喵～嗚～",
        "unit_id": 1,
        "voice": "vo_adv_1014011_059"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_060"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧妳不懂對吧？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對了，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_061"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要不要再戴上mimi試試？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "即使只是說想睡覺或想吃飯",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也可以喔。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_062"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣就行了。",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那麼，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們來聊天吧──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「名偵探小姐",
        "unit_id": 1,
        "voice": "vo_adv_1014011_063"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "喜歡學長嗎？」",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "101401102"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦！？",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_064"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n小、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "小霧……！？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳剛剛，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說什麼──",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦？",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_065"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "騙人，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我剛才說的話",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳都理解了？",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好厲害！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "別說是聰明了，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "根本是天才……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_066"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是不對，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不對啦！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長對我來說確實很特別，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是喜、",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "喜歡之類的，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒有那種感情……！",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為啊！",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_067"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "學長認識很多人，",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且女孩子還特別多……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "像我這種人，",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_068"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對學長來說……",
        "unit_id": 101431
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「照這樣下去……」",
        "unit_id": 1,
        "voice": "vo_adv_1014011_069"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦……？",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_070"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "「名偵探小姐的感情",
        "unit_id": 1,
        "voice": "vo_adv_1014011_071"
    },
    {
        "type": "dialogue",
        "name": "小霧",
        "words": "將會消失。」",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "！",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_072"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "什麼",
        "unit_id": 101431,
        "voice": "vo_adv_1014011_073"
    },
    {
        "type": "dialogue",
