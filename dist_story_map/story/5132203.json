[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喝啊──！",
        "unit_id": 127911,
        "voice": "vo_adv_5132203_000"
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克‧阿洛斯",
        "words": "咕呃呃呃呃呃呃──！",
        "unit_id": 18011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "成功了……",
        "unit_id": 128011,
        "voice": "vo_adv_5132203_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "打倒牠了，陛下！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n真是精彩的一擊啊！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 127911,
        "voice": "vo_adv_5132203_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這都是因為有克蕾琪塔小姐的協助喔！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "陛下所言甚是。",
        "unit_id": 6111,
        "voice": "vo_adv_5132203_003"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "都是因為有克蕾琪塔小姐",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "死纏爛打地轉移敵人注意，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n施展以此弱化敵人的卑鄙戰術，所以才會勝利。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等等，妳的說法！",
        "unit_id": 128011,
        "voice": "vo_adv_5132203_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "簡直就像我是個耍小手段的跟班一樣啊。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n給我說是恰當的支援啦。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是，",
        "unit_id": 127911,
        "voice": "vo_adv_5132203_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我真的受到了克蕾琪塔小姐的幫助。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "多虧克蕾琪塔小姐為我製造破綻，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我才有辦法贏！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下，",
        "unit_id": 128011,
        "voice": "vo_adv_5132203_006"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "您的話語是多麼令人開心──",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克‧阿洛斯",
        "words": "咕咕嘟嚕嚕嚕嚕嚕嚕啊啊啊啊啊啊！",
        "unit_id": 18011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "吵死了！？",
        "unit_id": 128011,
        "voice": "vo_adv_5132203_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等一下，是怎樣啊？真是的！\n現在氣氛正好，能請你安靜嗎！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呃，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "騙人的吧！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "牠這不是還活蹦亂跳的嗎！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "巴西利斯克‧阿洛斯",
        "words": "咕呃呃呃呃呃呃──！",
        "unit_id": 18011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 127911,
        "voice": "vo_adv_5132203_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "巴西利斯克要移動了喔！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "追上去吧！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唔唔，",
        "unit_id": 128011,
        "voice": "vo_adv_5132203_009"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "偏偏還往更深山裡……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊──真是麻煩死了！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就是因為這樣，我才討厭桌前辦公解決不了的工作！",
        "unit_id": 128011
    }
]