[
    {
        "type": "background",
        "background": "500037"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "3位候補聖誕老人回到了蘭德索爾的城鎮上。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n時間已近日暮時分，一天即將要結束了。"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "呵呵呵！",
        "unit_id": 3911,
        "voice": "vo_adv_5029005_000"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n辛苦囉！",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "小姐們。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聖誕老人！？",
        "unit_id": 111611,
        "voice": "vo_adv_5029005_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你這人是怎樣啊。",
        "unit_id": 111511,
        "voice": "vo_adv_5029005_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "途中完全都沒有露臉，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你真的有見證了我們精采的表現嗎？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "那當然。",
        "unit_id": 3911,
        "voice": "vo_adv_5029005_003"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "老夫可是",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "看得很仔細呢。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那就好……",
        "unit_id": 111711,
        "voice": "vo_adv_5029005_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你現身在我們面前，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就表示你已經有結論囉？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "嗯。",
        "unit_id": 3911,
        "voice": "vo_adv_5029005_005"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "老夫一路看到現在，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n妳們3位，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "真的都非常努力。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "察覺人們的願望，",
        "unit_id": 3911,
        "voice": "vo_adv_5029005_006"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "並且努力幫他們實現的那副模樣，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "只有一句話可以形容，那就是做得太棒了！",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "雖然有些地方做得有點過火，",
        "unit_id": 3911,
        "voice": "vo_adv_5029005_007"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "不過這全都是因為",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "妳們想要帶給所有人快樂的緣故。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "要當聖誕老人",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "沒有這種拚勁可是不行的。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼，",
        "unit_id": 111511,
        "voice": "vo_adv_5029005_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那是當然的☆",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "畢竟妾身是遲早會統領整個世界的支配者啊。",
        "unit_id": 111711,
        "voice": "vo_adv_5029005_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "傾聽人民的願望",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也是妾身的工作。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "整個過程都很開心。",
        "unit_id": 111611,
        "voice": "vo_adv_5029005_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "當聖誕老人",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "原來是這麼棒的工作啊！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "所以，",
        "unit_id": 3911,
        "voice": "vo_adv_5029005_011"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "這個袋子的繼承人……",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n老實說，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "妳們3位真的難分軒輊。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂喂。",
        "unit_id": 111511,
        "voice": "vo_adv_5029005_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你該不會要給我說什麼3個人一起",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當聖誕老人，這種多方討好的話吧？",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這妾身可沒辦法接受。",
        "unit_id": 111711,
        "voice": "vo_adv_5029005_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n若是這樣的話，目前為止的努力到底算什麼。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯。",
        "unit_id": 111611,
        "voice": "vo_adv_5029005_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "正因為我們很努力，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以才需要一個明確的答案。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "呵呵。",
        "unit_id": 3911,
        "voice": "vo_adv_5029005_015"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "我知道！我知道！",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "所以，我認為就",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "由他來代替老夫做決定吧。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "在整個過程中，",
        "unit_id": 3911,
        "voice": "vo_adv_5029005_016"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "他在妳們身旁看著的時間比誰都久，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n就由他來選出最適合當聖誕老人的人選吧。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "這樣的話，",
        "unit_id": 3911,
        "voice": "vo_adv_5029005_017"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "小姐",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "妳們也沒有意見吧？",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯！　",
        "unit_id": 111611,
        "voice": "vo_adv_5029005_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果是{player}的判斷，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n不管是什麼結果，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我都會接受的！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "確實，比起今天才遇到的聖誕老人，",
        "unit_id": 111511,
        "voice": "vo_adv_5029005_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n他的可信度更高。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 111711,
        "voice": "vo_adv_5029005_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就由{player}來決定是誰吧。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來吧！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "說出你的答案吧！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵。",
        "unit_id": 111511,
        "voice": "vo_adv_5029005_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就知道小子一定會選我的。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n晚一點",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我再好好的獎勵你……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔唔。",
        "unit_id": 111711,
        "voice": "vo_adv_5029005_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒想到妾身竟然會輸給這傢伙……！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "結果就是結果，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒辦法。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯。",
        "unit_id": 111611,
        "voice": "vo_adv_5029005_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也是，我相信製作人",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一定會準備",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n能帶給大家歡樂的禮物！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真不愧是{player}，",
        "unit_id": 111711,
        "voice": "vo_adv_5029005_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你判斷的很好！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n早晚妾身和你",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是不是能成為像那個、",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "聖誕老人夫婦一樣呢……？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "恭喜妳！伊莉亞！",
        "unit_id": 111611,
        "voice": "vo_adv_5029005_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我很期待",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "妳的禮物喔！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 111511,
        "voice": "vo_adv_5029005_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然很不甘心，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但就讓給妳吧！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "伊莉亞‧奧恩斯坦。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我想妳應該能帶給我一個合我胃口的刺激聖誕節吧……♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的嗎！？　",
        "unit_id": 111611,
        "voice": "vo_adv_5029005_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘿嘿嘿～",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "感覺好像在作夢……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "【慈樂之音】的偶像也不是虛有其表呢。",
        "unit_id": 111511,
        "voice": "vo_adv_5029005_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "聖誕老人兼偶像啊，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這樣我做製作人也值得了呢♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳只要送妾身下一場演唱會的門票",
        "unit_id": 111711,
        "voice": "vo_adv_5029005_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "當作聖誕禮物就可以了。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為妾身很期待！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "呵呵。",
        "unit_id": 3911,
        "voice": "vo_adv_5029005_030"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "原來如此。",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n我相信",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
