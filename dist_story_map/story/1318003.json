        "voice": "vo_adv_1318003_043"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這裡面也有很多啊。",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呵呵，",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
