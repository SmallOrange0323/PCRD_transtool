    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "\n",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "這真是令人興味盎然呢……",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯……",
        "unit_id": 131813,
        "voice": "vo_adv_1318003_045"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對了。",
        "unit_id": 131813
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不好了～",
