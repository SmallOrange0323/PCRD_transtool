[
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "回到了蘭德索爾的{player}與帆稀"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在帆稀的書房中稍事休息。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "辛苦你了～",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "抱歉把你捲進來。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過多虧如此，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我才把在這邊一直很在意的事",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "全都解決了喔。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這下就能放心……",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦？",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你說",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "引退……",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "誰？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n從哪引退？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你該不會",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "認真以為我打算引退，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以才在進行",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "各種收拾善後吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊──",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此原來如此，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是因為那樣啊……",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "總覺得嘉夜和祈梨的反應很奇怪，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n該不會",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是因為她們在想跟你一樣的事吧～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒事的，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我沒有要做那種事喔。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n因為至今我在這邊的世界所做的，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n都是為了",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "認真調查背面世界。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "為此，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我才把這邊的家族打造為",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "即便我不在也能經營，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n並且也排除了不確定要素的介入。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我想你已經注意到了，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "龍人族是",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n原本不存在於這個世界的種族。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其根源……",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是背面世界喔。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "作為這個世界不存在的種族之一，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n有天生的龍人族存在就是證據吧。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "天生的。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n與我、嘉夜、",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "祈梨不同，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "自然產生的龍人族。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有其他像是狗頭人、",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "貓妖精、巨人族",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那樣，這邊的世界",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所沒有的各種種族存在吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "令人興味盎然呢～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過呢，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "龍人族……原本應該是不會",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n自然產生的才對喔，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "本來都並不是龍人族呢。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯喔～",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n事情演變成這樣之前，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我套用了",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n駭入取得的",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "測試用角色。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "之前我是人類，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嘉夜是獸人，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "祈梨是精靈族吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當我找到與我們無關的雪菲時，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n真的很高興呢～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為她是我們一直",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在尋找的龍人族根源相關線索，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n是數量稀少的重要同族。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這次也與那是一樣的。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我在背面世界",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "必須調查的事情堆積如山啊～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為這樣，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "以後也",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "能請你繼續幫我嗎？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我得到承諾了～♪",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n那能馬上",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請你配合我做一件事嗎？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "過來這邊～",
        "unit_id": 131811
    },
    {
        "type": "background",
        "background": "501330"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被邀請去的是熟悉的祕密房間。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "有確實留著呢。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n太好了♪",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "開玩笑的，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我一直在看著祈梨的努力呢。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所、以～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們要使用這個～！",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如你所知，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是可以自由調整數值，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n創造出與現實一模一樣空間的",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "模擬設備。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我要去",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這裡面拿某個東西喔。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那就",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "Let's go♪",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以說──",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳在嗎──？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "在喔──",
        "unit_id": 106715,
        "voice": "vo_adv_1318003_022"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是時間儀所產生的",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我喔。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你有見過吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "總覺得比我想的還更花時間啊。",
        "unit_id": 106715,
        "voice": "vo_adv_1318003_024"
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "\n也就是說，",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "是通過外部途徑？",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不是，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_025"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那邊的路徑被封鎖了，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以是從內側。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "這樣啊──",
        "unit_id": 106715,
        "voice": "vo_adv_1318003_026"
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "果然沒辦法那麼輕易出去啊～",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "\n",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "不過，",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "那是不是意味著已經侵蝕到深處了呢。",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_027"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "抱歉抱歉，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "把你丟在一邊了呢。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我到這邊來的理由，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是因為如果",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是現在的我，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n可能會在背面世界拖累大家也說不定",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喔。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖說我是回來了，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但現在我的力量",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "並沒有決戰前那時的程度……",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "後來加上去的大量強化和調整都沒有了。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "要回擊",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那時嘉夜和祈梨的聯手攻擊，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n也是真的很勉強喔？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "作為一個玩家，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這種弱化",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很氣人呢～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_030"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "決戰前我也用了很多禁藥，所以很危險就是了。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我想把力量先恢復到",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那之前的程度呢～",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳當然也知道",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我過來的理由吧？",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "那當然♪",
        "unit_id": 106715,
        "voice": "vo_adv_1318003_031"
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "\n畢竟那是我留在這裡的理由之一嘛。",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "基本上，",
        "unit_id": 106715,
        "voice": "vo_adv_1318003_032"
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "這裡是假想空間，",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "所以無法把物體帶回去。",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "\n",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "不過，",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "能帶回最重要的東西……",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你知道是什麼嗎？",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_033"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_034"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還算接近吧。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是無法形式上保留下來的東西……",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就是情報喔。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "嗯，",
        "unit_id": 106715,
        "voice": "vo_adv_1318003_035"
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "完全正確♪",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "\n這原本就是",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "為了獲取情報的道具呢。",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在這個時間儀中，",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_036"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "能得到可能曾經會是那樣的現在，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n或者可能將會迎接的未來的情報。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我在這裡",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "留下了別的東西。",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "那就是",
        "unit_id": 106715,
        "voice": "vo_adv_1318003_037"
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "那時的……",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "決戰前",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "當時最強的我的情報。",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "並不是能力值",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_038"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很高之類的，",
        "unit_id": 131811
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n該說是將其改造為我容易操作",
