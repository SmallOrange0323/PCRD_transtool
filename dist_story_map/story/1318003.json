        "name": "假帆稀",
        "words": "\n",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "我就是我，",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "反正最後都會合而為一。",
