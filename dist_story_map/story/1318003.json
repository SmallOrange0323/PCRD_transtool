        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "不夠啊～",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "並不是沒事呢～",
