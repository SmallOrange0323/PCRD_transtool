        "voice": "vo_adv_1318003_041"
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "有效率地同步。",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "\n",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "假帆稀",
        "words": "像這樣……",
        "unit_id": 106715
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯……",
        "unit_id": 131811,
        "voice": "vo_adv_1318003_042"
    },
    {
        "type": "still",
        "still": "131800301"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "帆稀與帆稀面對面，並將額頭貼近。"
