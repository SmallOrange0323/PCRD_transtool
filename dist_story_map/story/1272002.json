[
    {
        "type": "background",
        "background": "500081"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天的放學後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當凱留與{player}正準備回家時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n聽見了班上女同學的聲音。"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "魔仙、",
        "unit_id": 6511,
        "voice": "vo_adv_1272002_000"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "魔仙。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "我最喜歡的坂本老師",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "有交往對象嗎……？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "呀！",
        "unit_id": 1,
        "voice": "vo_adv_1272002_001"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "硬幣自己動了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n妳",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "沒有在用魔法吧！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "妳先別講話！",
        "unit_id": 6511,
        "voice": "vo_adv_1272002_002"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "有……？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "沒有？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "…………答案是沒有♪",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n坂本老師他",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "沒有交往對象！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……真是有夠蠢的呢。",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算這裡是魔法學園，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但那也太不科學到令人反胃了。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "哦～",
        "unit_id": 915,
        "voice": "vo_adv_1272002_004"
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "還有人在啊？",
        "unit_id": 915
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "\n妳們幾個",
        "unit_id": 915
    },
    {
        "type": "dialogue",
        "name": "班導",
        "words": "快點回家去～",
        "unit_id": 915
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "好、",
        "unit_id": 6511,
        "voice": "vo_adv_1272002_005"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "好的！",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "坂本老師♪",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……這麼說來，",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們的老師是叫坂本嘛。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼會喜歡上那種狂戰士啊！！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "啊～",
        "unit_id": 6511,
        "voice": "vo_adv_1272002_007"
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "坂本老師走掉了……",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "\n我今天",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "明明還看到了",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生1",
        "words": "三次黑色掃帚的說～",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "啊～",
        "unit_id": 1,
        "voice": "vo_adv_1272002_008"
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "妳是說一天內看見三次騎著黑色掃帚的人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n就會招來幸運的迷信吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "\n不過，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "他都跟妳說話了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生2",
        "words": "也算是有好運吧♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……受不了，",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又是魔仙、",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又是黑色掃帚……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那只不過是騙小孩的無聊迷信罷了。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……啊，",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "奇怪……？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等、",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不見了……！！",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的鉛筆盒不見了！！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "會這樣……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說這不太妙吧！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你問我為什麼那麼慌張……？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……這跟你沒有關係！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之得要找到鉛筆盒才行……！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這……",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣啊，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "幫大忙了。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不過，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我先給你一個忠告。",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算找到鉛筆盒，",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也絕對不能打開來看……！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要是敢看，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就宰了你！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "知道了嗎！？",
        "unit_id": 127212
    },
    {
        "type": "background",
        "background": "501111"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我記得下午在室外實習的時候還有拿在手上。",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n應該是在那張長椅附近……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有了！！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是這個鉛筆盒！！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n太好了～～！！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒想到這麼簡單就找到了呢！",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然給你添了麻煩，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但已經沒事了！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你看，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "裡面的東西也都……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不見了！！？",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦！？",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼會！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為什麼只有橡皮擦不見了啊～～！？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯……",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你有兩塊，可以給我一塊？",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對啦，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不是這個問題……！",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一定得要是那塊橡皮擦才行啊……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "糟糕……",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要是有人看到那塊橡皮擦，",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你問說為什麼那麼重要？",
        "unit_id": 127212,
        "voice": "vo_adv_1272002_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是因為……",
        "unit_id": 127212
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "啊，",
        "unit_id": 413,
        "voice": "vo_adv_1272002_024"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "凱留",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "妳在這裡做什麼？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "妳先聽我說！",
        "unit_id": 1,
        "voice": "vo_adv_1272002_025"
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "她剛剛被告白了耶！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "\n而且對象還是她一直單戀著的人！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "嗯，",
        "unit_id": 413,
        "voice": "vo_adv_1272002_026"
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "我現在超幸福的♪",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女學生3",
        "words": "會不會是那個迷信奏效了呢～？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "啊～",
        "unit_id": 1,
        "voice": "vo_adv_1272002_027"
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "妳是說將心上人的名字寫在橡皮擦上，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "\n在不被發現的情況下用完，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "就能實現戀情的迷信嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "\n我要不要也來試試看呢～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "凱留要不要也試試看？",
        "unit_id": 1,
        "voice": "vo_adv_1272002_028"
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "橡皮擦的迷信！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "\n……開玩笑的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生4",
        "words": "這種事感覺妳就不會相信呢～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生4",
