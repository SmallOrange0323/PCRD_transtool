[
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "克蕾琪塔小姐──",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請問您怎麼了嗎──",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還請快點",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "過來這邊──",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等等啦……！",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_002"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n可、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可以請妳別把事情說得好像很簡單好嗎……！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "因為，",
        "unit_id": 106411,
        "voice": "vo_adv_1180005_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的不是很難呀。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "像我還有",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不都很輕鬆地就跳過來了嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哪裡不是很難！",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n從懸崖這頭到妳們所在的對面，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是有七公尺以上耶！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "一般來說",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是根本沒辦法跳過這種距離的！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請放心。",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n與在下和雪菲小姐相同，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在克蕾琪塔小姐您",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經受到主人的強化。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就是呀。",
        "unit_id": 106411,
        "voice": "vo_adv_1180005_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n跳到這裡來的難度，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大概就跟一口氣跨四階樓梯差不多而已。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你說是吧，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "{player}。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就、",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就算你這麼說……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n雖然身體的能力",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "確實感覺起來比平時來得強啦……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是可是！",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_008"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n害怕的感覺不會因此消失啊！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要是從這裡摔落，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就會一頭栽進無底深淵了耶！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唉，",
        "unit_id": 106411,
        "voice": "vo_adv_1180005_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "什麼無底深淵，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "太誇張了。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n就算真的掉下去，我會立刻去救人，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐也會幫妳施展恢復的。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……除非妳撞到什麼不該撞的地方……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n克蕾琪塔小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算摔下去也請放心。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下隨時都準備好了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是、",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可是……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚嗚嗚～～",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_012"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "討厭……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為什麼事情會變成這樣……！？",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "500366"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就在昨晚──"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等一下，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_013"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n【美食殿堂】的各位，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這到底是怎麼一回事！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哎呀？",
        "unit_id": 106412,
        "voice": "vo_adv_1180005_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "克蕾琪塔小姐。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_015"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "晚上好。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不對，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_016"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "現在不是打招呼的時候啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就在剛才，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下參加完",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那什麼",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n「公會活動」後回到了王宮……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "因為陛下出去前，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_017"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我有稍微問過，她是回答，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "「我們要去趟美食吃遍之旅！」",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以我原本",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "以為十之八九",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n是去附近山裡摘點野莓之類的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "卻沒想到……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "當初我安心目送出門的陛下！",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_018"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n會帶著那樣的傷回來！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀。",
        "unit_id": 105913,
        "voice": "vo_adv_1180005_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n原來還留有沒能完全恢復的傷口嗎。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明可以說出來，不用顧慮在下的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒能完全恢復的傷……！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_020"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n難道說，除了那個膝蓋的擦傷之外，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n陛下實際上還受了更多的傷！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且說到底！",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_021"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n到底事情為什麼會",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "發展成讓陛下受傷的局面呀！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "和魔物戰鬥！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "畢竟貪吃佩可小姐，",
        "unit_id": 106412,
        "voice": "vo_adv_1180005_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "戰鬥時會站在前方，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n保護我們不被魔物攻擊。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "像是飛龍、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "巨大魔像之類的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "飛龍！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n巨大魔像！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有奇美拉、賈巴沃克，",
        "unit_id": 105913,
        "voice": "vo_adv_1180005_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n甚至也與怒火沖天的龍戰鬥過。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "龍、龍、龍龍，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_026"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "龍……！？！？！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你、",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你、你、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n你們的",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "公會活動……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n究竟都是在",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "做什麼……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲、可可蘿",
        "words": "在進行",
        "unit_id": 1,
        "voice": "vo_adv_1180005_028"
    },
    {
        "type": "dialogue",
        "name": "雪菲、可可蘿",
        "words": "「美食吃遍之旅」。\n聽說是「美食吃遍之旅」。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "………………",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_029"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……就為了美食？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_030"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……堂堂一國之主？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n……賭上自身安全？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "並從凶暴魔物或傳說之龍的攻擊下，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_031"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n守護夥伴……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_032"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對啦啊啊啊──！！　",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "太奇怪了吧真不敢相信怎麼想都覺得你們有病啊！",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_033"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n既然如此，那我當初也不用想什麼暗殺計畫嘛，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n照你們這樣，哪天她根本就會自取滅亡了呀！？！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……呼、",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_034"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呼、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哈啊……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……那我不客氣了。",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_035"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "咕嚕……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "─",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_036"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "─你們幾個也是，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就算是冒險者，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "也至少稍微考慮一下大局吧？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n要是陛下出了什麼萬一，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就等於是",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "國家存亡的危機唷？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是……",
        "unit_id": 105913,
        "voice": "vo_adv_1180005_037"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……貪吃佩可小姐可不是輕易就能勸住的人，",
        "unit_id": 106412,
        "voice": "vo_adv_1180005_038"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n克蕾琪塔小姐應該也很清楚這一點吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗚呃……",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_039"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這點倒是，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_040"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嗯……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "很有道理……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……雖然我剛才提到了國家存亡的危機，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_041"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但要說的話，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也不是效忠於這個國家……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……我只不過是，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_042"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "身為一名忠臣，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n希望能勸陛下盡量避免",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "去冒一些不必要的險……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_043"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這麼說來，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "明天是久違的假日……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……那個呀，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_044"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們幾個。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也要",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_045"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "參加你們的公會活動……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n讓我體驗一下那什麼",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "「美食吃遍之旅」吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 106412,
        "voice": "vo_adv_1180005_046"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我不會說要免費參加。",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_047"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n如果有需要，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我也可以去公會管理協會提出正式委託。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "地點要能當天來回。",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_048"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n而且盡量不太危險……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還有",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "陛下不能一起！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可小姐不能一起？",
        "unit_id": 106412,
        "voice": "vo_adv_1180005_049"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呃，那個……",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_050"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "錯。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n明天她",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "要處理重要公務，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "無法找替身幫忙的那種。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "所以不能一起去也是沒辦法呢？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔姆……",
        "unit_id": 105913,
        "voice": "vo_adv_1180005_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您意下如何，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，接受了克蕾琪塔委託的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲、可可蘿、和{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這才會在爬山的途中。"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我……",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_052"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我跳啊啊啊啊────！！！",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_053"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……！",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_054"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n呼、",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呼……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我、",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_055"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還以為會摔下去……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n總算是想辦法",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "跳過來了……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "恭喜妳成功，",
        "unit_id": 106411,
        "voice": "vo_adv_1180005_056"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "克蕾琪塔小姐。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，主人。",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n此處的裂縫很危險，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請牽著在下的手，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起跳過去吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請準備好後一起，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n跳～過去囉。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……雖然說他無法對自己施展強化，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_059"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n但這種照顧方法，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "會不會有點……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "話說回來……",
        "unit_id": 106411,
        "voice": "vo_adv_1180005_060"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "克蕾琪塔小姐。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n昨天",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒能好好問清楚，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳為什麼",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "會想跟來參加我們的公會活動呢？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "…………",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_061"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就跟你們",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_062"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還未能徹底相信我一樣，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我也並非",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "已經全盤信任你們。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然我也不希望你們把這話看得太重……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "總而言之，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_063"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我要親眼確認，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們是否有足夠的實力，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n不會給陛下添麻煩……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這便是我的想法。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔姆，",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在擁有主人所施加的強大力量後，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n克蕾琪塔小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的想法是否有產生變化了呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "你們說這是公主騎士的強化能力……",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_065"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對吧。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n確實，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "其效果超乎我的想像。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就連最近都坐在桌子前辦公的我，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_066"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n也能發揮超乎一般王宮騎士的體能。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……雖然目前身體操控起來仍和腦袋認知差太多，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "感覺不太自然啦……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_067"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要能將此力量運用得當，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就連未滿十歲的孩童，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也可以有辦法與凶暴的魔物戰鬥。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這就……",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_068"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有點令人不敢置信哪。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不，確實，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "或許反而是年輕人能比較快適應，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這種被施加在身上的能力也不一定……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "不對！",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_069"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我也是還很年輕呀！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……那個，",
        "unit_id": 106411,
        "voice": "vo_adv_1180005_070"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "能麻煩妳稍微安靜一下嗎？",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "什麼！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_071"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n難道妳也和【王宮騎士團】的矮子虎一樣，\n把我當成",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "老阿姨嗎……！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並非如此……",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_072"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "目標的食材似乎就在附近了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該就在前方……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……！",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_073"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然這麼說，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但在前方擋住路的……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "看似很強的魔物",
        "words": "──嘎喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是隻魔物啊！！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_074"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n而且看起來還超級強呀！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不只貪吃佩可小姐不在，",
        "unit_id": 106411,
        "voice": "vo_adv_1180005_075"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留目前也在王宮……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "光靠我和可可蘿小姐，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感覺會是一番苦戰呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我想也是啦！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_076"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n所以，我們現在",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "還是繞路避開魔物比較好吧！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但……",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_077"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "目標的食材，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是在那邊的魔物。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "食……",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_078"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "材？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_079"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但那不是魔物嗎！！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_080"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "請冷靜下來，",
        "unit_id": 106411,
        "voice": "vo_adv_1180005_081"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "克蕾琪塔小姐！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n雖然我很明白妳的心情……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "看似很強的魔物",
        "words": "──嘎喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "噫呀！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_082"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n魔物朝這邊來了！？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請相信主人，",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_083"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "克蕾琪塔小姐！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只要克蕾琪塔小姐願意同心協力戰鬥，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n便應當可以順利戰勝魔物的！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們會牽制住魔物的動作！",
        "unit_id": 106411,
        "voice": "vo_adv_1180005_084"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n請趁機攻擊牠！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "可以請你們別把事情說得好像很簡單好嗎！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_085"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n啊啊真是的──！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然這樣",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_086"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "乾脆豁出去啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n這個",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "混蛋魔物啊啊啊！！",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "看似很強的魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有、",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_087"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "有效果……？",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n我的攻擊竟然",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "對感覺很強的魔物有效……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是這種感覺，",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_088"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "克蕾琪塔小姐！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請繼續攻擊！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "看、",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_089"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "看我的！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n喝呀啊啊啊──！！",
        "unit_id": 118011
    },
    {
        "type": "background",
        "background": "500210"
    },
    {
        "type": "dialogue",
        "name": "看似很強的魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "哼……",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_090"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呵呵呵呵……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這確實……",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_091"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "感覺起來還挺有趣的哪♪",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "像這樣發揮平時沒有的力量，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n來打倒原本不可能打得過的對象……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然這樣，",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_092"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我可要拚命攻擊囉！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n嘿呀～～！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "看似很強的魔物",
        "words": "──嘎喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_093"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n被閃過了……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊！",
        "unit_id": 106411,
        "voice": "vo_adv_1180005_094"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n克蕾琪塔小姐，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那邊是懸崖……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "……咦？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_095"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊～～咧～～！？",
        "unit_id": 118011,
        "voice": "vo_adv_1180005_096"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "克蕾琪塔小姐────！？",
        "unit_id": 105911,
        "voice": "vo_adv_1180005_097"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──嘗試擊退魔物卻失敗，並跌落山谷的克蕾琪塔。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她的命運，究竟會如何呢？"
    }
]