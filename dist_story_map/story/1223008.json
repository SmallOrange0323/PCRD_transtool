    {
        "type": "dialogue",
        "name": "班比",
        "words": "嘿嘿♪",
        "unit_id": 122332,
        "voice": "vo_adv_1223008_017"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n班比很喜歡",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從這一點♪",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從知道嗎？",
        "unit_id": 122332,
        "voice": "vo_adv_1223008_018"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n「膽小龍貝斯」這個故事！",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "貝斯",
        "unit_id": 122332,
        "voice": "vo_adv_1223008_019"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "是在森林出生的小龍。",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "大妖精說，",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "牠將來會成為",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "森林之主，",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n所以牠與森林裡的居民一起長大。",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "牠既嬌小",
        "unit_id": 122332,
        "voice": "vo_adv_1223008_020"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "又膽小。",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "但是，",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "當森林裡的居民遇上困難，",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "牠總是會試著幫忙。",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就連壞女王",
        "unit_id": 122332,
        "voice": "vo_adv_1223008_021"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "被大家擊敗後，",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n也只有貝斯",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "反對將她趕出森林。",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "牠說：「就像女王有刺一樣，",
        "unit_id": 122332,
        "voice": "vo_adv_1223008_022"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "我也有利牙。",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n但我有大家的陪伴，",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "女王卻沒有人在她身邊。",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n女王需要有人幫她。」",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "然後，",
        "unit_id": 122332,
        "voice": "vo_adv_1223008_023"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "因自己的刺",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "傷了大家",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "也傷了自己的",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "孤獨女王，",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n和貝斯",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "成為了朋友。",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以班比",
        "unit_id": 122332,
        "voice": "vo_adv_1223008_024"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "非常喜歡貝斯！",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n因為牠願意成為",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "女王的朋友♪",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "還有",
        "unit_id": 122332,
        "voice": "vo_adv_1223008_025"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從也是！",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n在學校時，",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n你一直對班比",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "非常親切對吧。",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "所以班比，",
        "unit_id": 122332,
        "voice": "vo_adv_1223008_026"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n也決定",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "要一直珍惜你！",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n因為「契約」",
        "unit_id": 122332
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "是絕對的！",
        "unit_id": 122332
    },
