    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "精靈失控事件過了一段時間後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被蘭法找去，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於是再次造訪精靈族之村。"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有段時間沒見了呢，",
        "unit_id": 134411,
        "voice": "vo_adv_5202061_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "蘭法小姐。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "聽說妳有件事想找我商量，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是怎麼了嗎？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……難道說，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "和精靈之間",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "又發生什麼異變了？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "啊，",
        "unit_id": 134311,
        "voice": "vo_adv_5202061_001"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "那個，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "不是",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "那樣的……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "說",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "要商量的事，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "其實是……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "自那之後……",
        "unit_id": 134311,
        "voice": "vo_adv_5202061_002"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我在想，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "要是可以答謝村裡的人們就好了……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n雖然，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "一直在思考……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "但是光憑我一個人，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "有點難……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "所以才說要找我商量是吧！",
        "unit_id": 134411,
        "voice": "vo_adv_5202061_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "太",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "好了……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我還想說",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要是蘭法小姐又碰上麻煩該怎麼辦，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n為此感到很擔心呢。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "而且，",
        "unit_id": 134411,
        "voice": "vo_adv_5202061_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我正好也在思考能不能",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n回報村裡的大家……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就這點來說，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "也是很剛好呢。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "原來、",
        "unit_id": 134311,
        "voice": "vo_adv_5202061_005"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "是這樣呀。",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "太好了……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "……所以、",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "說。",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n雖然我自己……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "也有",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "試著想過……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "那個……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "這個……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法、千歌",
        "words": "「送上歌曲，適合嗎……？」\n「送上歌曲，妳覺得怎麼樣……？」",
        "unit_id": 1,
        "voice": "vo_adv_5202061_006"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "……！",
        "unit_id": 134311,
        "voice": "vo_adv_5202061_007"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n千歌……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "呵呵。",
        "unit_id": 134411,
        "voice": "vo_adv_5202061_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n看來，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我們想到了同樣的事呢。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n真令人開心！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "只唱、",
        "unit_id": 134311,
        "voice": "vo_adv_5202061_009"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "幾首歌",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "的話……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "而且……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我希望，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "能夠",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "讓大家看到",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我現在，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "可以好好使用唱喚術了……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "蘭法小姐……",
        "unit_id": 134411,
        "voice": "vo_adv_5202061_010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我充分了解",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "妳的想法了。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "既然這樣──",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不如我們兩個人一起",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "舉辦演唱會吧？",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "為了讓村裡的大家開心，",
        "unit_id": 134411,
        "voice": "vo_adv_5202061_011"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n從曲目到舞台組成",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "全都由我們自己想。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "像這樣親自規劃的演唱會。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "當然，",
        "unit_id": 134411,
        "voice": "vo_adv_5202061_012"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一些必要的設備還是得去租借才行……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過這部分",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就請慈樂之音的製作人幫忙，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我們自己去找找看吧。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "兩位，",
        "unit_id": 134311,
        "voice": "vo_adv_5202061_013"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "謝謝……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "啊，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "只是……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "很笨手笨腳……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "會努力，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "不要拖累你們",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "的……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "只要大家同心協力就不會有問題的。",
        "unit_id": 134411,
        "voice": "vo_adv_5202061_014"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "既然決定好了，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就快點開始準備吧！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "從日期到曲目表，",
        "unit_id": 134411,
        "voice": "vo_adv_5202061_015"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還有配置……",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要思考的事",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可是有一堆呢。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "一起加油吧，",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "蘭法小姐！",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "好的……！",
        "unit_id": 134311,
        "voice": "vo_adv_5202061_016"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "作為給村民們的謝禮，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "千歌和蘭法"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n決定舉辦一場迷你演唱會。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人很快地便開始進行準備。"
    }
]