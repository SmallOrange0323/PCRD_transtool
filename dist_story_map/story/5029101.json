    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真不愧是聖誕節，",
        "unit_id": 111511,
        "voice": "vo_adv_5029101_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "整個城裡都充滿了興奮的氣息。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n城裡這麼和平真是再好不過。",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也就是說――",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "差不多該輪到我出場了吧！",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "給我洗好脖子等著☆",
        "unit_id": 111511,
        "voice": "vo_adv_5029101_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n現在聖誕老人，也就是我克莉絲提娜，",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要送聖誕禮物過去囉♪",
        "unit_id": 111511
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "克莉絲提娜那傢伙，",
        "unit_id": 111711,
        "voice": "vo_adv_5029101_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "真是幹勁十足。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也不能輸！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來吧！",
        "unit_id": 111711,
        "voice": "vo_adv_5029101_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "我的蝙蝠部下們！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n來幫忙搬我聖誕老人伊莉亞的禮物吧！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n只要遇到人就馬上送給他～！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "等等！製作人！",
        "unit_id": 111611,
        "voice": "vo_adv_5029101_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "伊莉亞！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這兩人也太自我了吧……！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不過，",
        "unit_id": 111611,
        "voice": "vo_adv_5029101_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我也不能輸。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我會成為聖誕老人偶像望！",
        "unit_id": 111611
    },
