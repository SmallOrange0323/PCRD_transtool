[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某日午後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正在散步的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n發現空花一臉愉悅地走在路上。"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻～♪",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_000"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n好興奮～♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是的～♪",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_001"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花得到了一個令人熱血沸騰的情報……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦，",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_002"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n你是什麼時候出現在空花身邊的！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_003"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "莫非虐待狂先生",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一直都在空花的身邊！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "「我時時刻刻",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "都在注視著妳」",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n怎麼這樣……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花的一切",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "都被你看光光了是吧！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_004"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "只是碰巧經過？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "喔，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這樣啊。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "有點遺憾……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "呃，",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_005"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你問空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "為什麼會一臉興奮地扭個不停嗎？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "因為",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "之前空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在酒館跳舞時……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n聽到了稀有飾品的傳聞。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "聽說那好像",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_006"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是個充滿刺激性的東西。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "或許你會感到意外，",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_007"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但空花，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "其實對那種飾品很有興趣。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嗯？",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_008"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你怎麼",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這麼肯定地點頭……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "然後呢，",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_009"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n空花現在",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "正想去試著把那個稀有飾品",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "給拿到手。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "其實空花",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "本來是想找公會的夥伴",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一起來幫忙的，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但大家都不在，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "只剩空花一個人……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過，",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "熱血沸騰的空花，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n已經壓抑不住心中的渴望了……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "雖然那好像是個有點危險的地下迷宮，",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_012"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "但空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "現在就要去挑戰了……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦？",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_013"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "也要跟空花一起去……？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "難、",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_014"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "難不成，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你是想遠遠看著掉進陷阱裡",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "無法抵抗的空花，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n藉此獲得快感……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_015"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生願意同行，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花心裡會感覺更踏實。",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n請你",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "務必要一起來……！",
        "unit_id": 104511
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻……",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_016"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "一片青翠的茂盛草原……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n真是個冒險的好日子……♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "話說回來，",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_017"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "只有虐待狂先生跟空花兩個人的冒險……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "感覺已經好久沒有這樣了呢……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花想起與虐待狂先生初次相遇的時候……♪",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_018"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生藉口想要一起討伐魔物，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "把空花叫去四下無人的地方，\n對空花那樣那樣、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這樣這樣……♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "噫──！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_019"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你都聽到了嗎！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這、",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這要空花怎麼說得出口嘛……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "虐待狂先生那些人格異常的變態行為，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花實在羞於啟齒～！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過，",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_020"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不曉得怎麼搞的，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n光是虐待狂先生陪在身邊，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "就覺得很放心……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊！？",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_021"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "難不成，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n這是虐待狂先生為了將空花的身心都馴服",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "而設下的陷阱……！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "太可怕了……",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_022"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這場冒險",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "空花能否撐到最後呢……！",
        "unit_id": 104511
    },
    {
        "type": "background",
        "background": "500253"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這裡就是",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_023"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "傳聞中的",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "地下迷宮……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "既昏暗",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_024"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "又閃爍著詭異的迷濛亮光……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "嘻嘻嘻♪",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "在這種地方",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_025"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "跟虐待狂先生兩個人獨處……",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "搞不好",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "會發生什麼不得了的事情喔……！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦、",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_026"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "咦咦！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n虐待狂先生",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "怎麼突然脫下披風……！",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "莫非",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_027"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "是這種四下無人的狀況，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "點燃了虐待狂先生的慾火……！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "……啊，",
        "unit_id": 104511,
        "voice": "vo_adv_1045009_028"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "你說這裡很冷，",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n你的披風可以借空花穿？",
        "unit_id": 104511
    },
    {
