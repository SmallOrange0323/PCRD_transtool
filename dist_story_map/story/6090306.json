        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "マシューさんたちの悩みも分かってくる気がするッス。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "あの見た目じゃその……",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "いろいろと難しいッスからね。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "そうッスよね……",
        "unit_id": 114111,
        "voice": "vo_adv_6050306_001"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "って、",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ちょっと待つッス。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\nひょっとして、",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "自分もその枠に入ってるッスか？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "自分はマスコットじゃないッスよ！！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "気休めはいいッスよ……",
        "unit_id": 114111,
        "voice": "vo_adv_6050306_002"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "って、",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "そうじゃないんスか？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\n確かに",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "見た目で油断させて、",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ってのは",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ありッスね！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "諦めずに考えてみることも大切ッスね！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "あんたも怖さとは縁のない人ッスもんね。",
        "unit_id": 114111,
        "voice": "vo_adv_6050306_003"
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "一緒に考えてくれるとありがたいッス。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "\nそれでもだめなら",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "マツリ",
        "words": "ツムギさんに相談するッスよ。",
        "unit_id": 114111
    }
]