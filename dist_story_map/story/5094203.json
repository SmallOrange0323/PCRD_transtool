        "voice": "vo_adv_5094203_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "現在還不能安心喔。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n畢竟牠現在可是",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "還留有逃跑的力氣……",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是啊。",
        "unit_id": 104715,
        "voice": "vo_adv_5094203_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "再加上，對方是擁有蘑菇特性的魔物。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我推測，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其繁殖力恐怕也與蘑菇同樣強大吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若是時間再拖下去，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "事情搞不好會變得更加棘手。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這、",
        "unit_id": 122111,
        "voice": "vo_adv_5094203_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "這麼說確實有道理……！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為了避免那樣的狀況發生，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還是趕緊追上去吧！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n蘑菇狩獵，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "繼續進行！",
        "unit_id": 122111
    }
]