    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "成功了！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我們趕跑牠了！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不，",
