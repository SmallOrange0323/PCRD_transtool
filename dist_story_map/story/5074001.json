[
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接下黑道男子的委託數天後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n深月與{player}一同造訪了大江戶町。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這城鎮獨樹一格，真是有趣呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "東國文化獨有的技術與素材，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還有思想，都令人十分感興趣，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "上次拿到的中藥也很有研究價值呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "每次我來大江戶町大多都是有麻煩要處理，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真希望有機會可以來這裡悠哉漫遊一下。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你在發什麼愣呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "到時候你當然也要陪我一起來囉。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你是這城鎮的英雄不是嗎？",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n只要帶著你，應該很吃得開吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請多指教囉，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "將軍大人♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說回來，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "鎮上似乎出現了一些凶神惡煞呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n上次來的時候沒看過那些人。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "八成是吧。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "以前應該都是來道一家",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在抑制那些不良分子，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n暗中嚇阻他們不四處作亂。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來委託我的那個男人說他們重情重義，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n看來並非隨便說說的呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我知道這令人不安，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但我們現在還有其他事情該處理。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不可以誤判情勢的優先順序。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這狀況應該是由於頭目不在造成的。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以我們現在該努力解決委託的問題。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這就是讓鎮上恢復原樣最快的方法。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "鎮上龍蛇雜處，毫無情調可言，也別想觀光了。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以這也是為了以後可以開心漫遊大江戶，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓我們好好解決這件事吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好啦，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "總算抵達目的地，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "聖阿弗萊特醫院了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "喔～",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還挺壯觀的嘛。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "鎮上有這麼大型的醫院，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "居民想必都很開心吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那個男人也說啦，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "外觀毫無疑問是間氣派的醫院。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "越是奸詐的傢伙就越是會擦脂抹粉呀。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以眼下應該把這間醫院視做龍潭虎穴呢。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n千萬不要忘了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個嘛，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是很想入鄉隨俗，\n化身忍者華麗潛入院裡調查啦，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只可惜我對忍者沒研究。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過相對地，我花許多時間做好準備了，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以我們光明正大地從大門進去吧。",
        "unit_id": 105111
    },
    {
        "type": "background",
        "background": "501390"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀呀，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "門庭若市呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看來風評好不是騙人的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也因此要等很久才輪得到就是了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓身體有狀況的患者一直等，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這對心理健康可不好喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這件事情先放一邊，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們先去櫃台吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "打擾了，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是今天來上任的醫師。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "啊，",
        "unit_id": 412,
        "voice": "vo_adv_5074001_022"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "是，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "直美醫生對吧？",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "院長有告訴我了。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "請多多指教。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "……不過，",
        "unit_id": 412,
        "voice": "vo_adv_5074001_023"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "另外一位是？",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "他是我的助手。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要一併請你們多多關照了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你先別多嘴，配合一下吧。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_025"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "那麼先請兩位",
        "unit_id": 412,
        "voice": "vo_adv_5074001_026"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "去向院長打聲招呼──",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可以先帶我參觀一下診察室嗎？",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想盡快確認自己接下來的工作場所。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "這、",
        "unit_id": 412,
        "voice": "vo_adv_5074001_028"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "這樣嗎？",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "好的，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "我帶兩位參觀。",
        "unit_id": 412
    },
    {
        "type": "background",
        "background": "501380"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "直美醫生，這裡就是妳的診察室。",
        "unit_id": 412,
        "voice": "vo_adv_5074001_029"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n請妳自由使用吧。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對了，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我剛剛看到候診室，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來了好多患者呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真高興能來到這麼好的醫院。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這麼棒的醫療環境，來道一家的頭目也能安心住院療養了。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_031"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "……不好意思，",
        "unit_id": 412,
        "voice": "vo_adv_5074001_032"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "我不知道妳是在哪邊聽說的，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n但是本院並沒有收治妳說的患者。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……這樣啊。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_033"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看來謠言真是不能隨便相信呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼事不宜遲，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_034"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我這就開始診察吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n護理師，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "把候診室那些患者全都轉來我這邊吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "咦？",
        "unit_id": 412,
        "voice": "vo_adv_5074001_035"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "全、",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "全部嗎！？",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "這再怎麼說都太亂來了吧！",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但是讓患者一直等也不好吧？",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_036"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "放心，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我很優秀的♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "我、",
        "unit_id": 412,
        "voice": "vo_adv_5074001_037"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "我知道了。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "那麼就麻煩妳了。",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_038"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "進行得很順利呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_039"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不用這麼客氣，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "兩人獨處時叫我深月就好♪",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不開玩笑了，我先說明吧。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_040"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n直美其實是真正該來這裡報到的醫師。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "簡單說呢，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_041"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是我假扮成她混進醫院裡面來了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為要先找出假冒的對象，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還有竄改文件等等的事前準備要做，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以我們才會在接到委託後那麼多天後才出發。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "放心。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_042"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "她還活得好好的啦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現在應該在其他醫院勤奮工作吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以我接下來",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_043"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是要準備到時候的對策囉。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那個護理師聽到頭目時的反應，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_044"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你應該也看到了吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不只是謝絕會客，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "他們就連頭目住院這件事都隱瞞了起來。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這簡直就是在大聲說我們醫院很可疑喔。",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_045"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "既然嫌疑加重了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那我們也要有所對策。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好啦，",
        "unit_id": 105111,
        "voice": "vo_adv_5074001_046"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "患者應該快進來了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "接下來會很忙，做好覺悟吧。",
        "unit_id": 105111
    },
    {
        "type": "still",
        "still": "507400101"
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "咳咳、",
        "unit_id": 311,
        "voice": "vo_adv_5074001_047"
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "咳咳……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "\n嗚嗚……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "出差來大江戶就突然得了感冒，真倒楣……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你好。",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_048"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "今天是哪裡不舒服呢？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "什麼！？",
        "unit_id": 311,
        "voice": "vo_adv_5074001_049"
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "真的假的？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "這裡居然有這麼美的醫生……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯～",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_050"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看得出來你有咳嗽，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還有其他症狀嗎？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "呃、",
        "unit_id": 311,
        "voice": "vo_adv_5074001_051"
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "啊、",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "那個，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "我還有一點發燒、全身也有點無力，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "大概吧？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那我開止咳的藥給你吧。",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_052"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "拿了藥後就趕快回去，多補充水分和營養，好好休息。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "可、",
        "unit_id": 311,
        "voice": "vo_adv_5074001_053"
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "可是我還有工作……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "身體和工作，",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_054"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你覺得哪個比較重要？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是你真那麼堅持，就吃這個退燒藥吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "下一位，",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_055"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請進～",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "咦？",
        "unit_id": 1412,
        "voice": "vo_adv_5074001_056"
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "不是平時那位醫生……？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是今天才剛上任的醫師。",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_057"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請多指教喔。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼你今天是哪裡不舒服呢？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "那、",
        "unit_id": 1412,
        "voice": "vo_adv_5074001_058"
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "那個，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "我最近為了維持健康而開始跑步，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "\n但似乎太勉強了，導致膝蓋疼痛……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣的話請你先暫時減少運動吧。",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_059"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n運動前自然不用說，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "運動之後的伸展操也很重要喔。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是擔心自己運動不足，",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_060"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在膝蓋治好之前可以做些肌力訓練。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我教你一些輕鬆又有效的鍛鍊動作吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我會開藥布給你回去貼，就這樣先觀察一陣子。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "喔喔，",
        "unit_id": 1412,
        "voice": "vo_adv_5074001_061"
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "那真是太好了。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "麻煩醫生、",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "好痛！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "怎麼好像",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "突然變痛了……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣啊，",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_062"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那要不要試試",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我的特殊治療呢？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "躺到床上吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "好、",
        "unit_id": 1412,
        "voice": "vo_adv_5074001_063"
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "好的！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "麻煩醫生了！",
        "unit_id": 1412
    },
    {
        "type": "background",
        "background": "501390"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "醫師",
        "words": "怎麼了？",
        "unit_id": 1,
        "voice": "vo_adv_5074001_064"
    },
    {
        "type": "dialogue",
        "name": "醫師",
        "words": "都沒看到患者來接受診察啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "那、",
        "unit_id": 412,
        "voice": "vo_adv_5074001_065"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "那是因為，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "醫生你自己看……",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "醫師",
        "words": "一個患者都沒有……？",
        "unit_id": 1,
        "voice": "vo_adv_5074001_066"
    },
    {
        "type": "dialogue",
        "name": "醫師",
        "words": "\n剛才候診室還擠得水洩不通的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫師",
        "words": "怎麼突然就……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "就是那位今天上任的醫生，",
        "unit_id": 412,
        "voice": "vo_adv_5074001_067"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n她說要替所有患者看診，我就轉給了她……",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "醫師",
        "words": "所有患者……",
        "unit_id": 1,
        "voice": "vo_adv_5074001_068"
    },
    {
        "type": "dialogue",
        "name": "醫師",
        "words": "這怎麼可能！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "醫師",
        "words": "\n首先，這樣根本不可能好好替每一個人診察──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "哎呀～",
        "unit_id": 1412,
        "voice": "vo_adv_5074001_069"
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "新來的醫生真是太棒了！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "平常總是要等上半天，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "新醫生又快又細心，真是太好了。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "而且那位醫生的針灸治療",
        "unit_id": 1412,
        "voice": "vo_adv_5074001_070"
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "十分有效啊。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者2",
        "words": "原本明明很痛的，現在看完診簡直健步如飛啊！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "我很怕上醫院，",
        "unit_id": 311,
        "voice": "vo_adv_5074001_071"
    },
    {
        "type": "dialogue",
        "name": "外來患者1",
        "words": "不過有那麼棒的醫生，我就完全不怕啦。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "就像那樣，",
        "unit_id": 412,
        "voice": "vo_adv_5074001_072"
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "那位新醫師不只看得快，也看得確實，",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "護理師",
        "words": "\n已經深受患者們青睞……",
        "unit_id": 412
    },
    {
        "type": "dialogue",
        "name": "醫師",
        "words": "真不敢相信，",
        "unit_id": 1,
        "voice": "vo_adv_5074001_073"
    },
    {
        "type": "dialogue",
        "name": "醫師",
        "words": "居然有如此名醫來到我們醫院……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這件事情，",
        "unit_id": 512,
        "voice": "vo_adv_5074001_074"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可以詳細說給我聽聽嗎？",
        "unit_id": 512
    },
    {
        "type": "background",
        "background": "501381"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_075"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "已經這麼晚了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "以第一天來說，成果豐碩呢。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "打擾了。",
        "unit_id": 512,
        "voice": "vo_adv_5074001_076"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "抱歉，",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_077"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "今天已經休診囉。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "別在意。",
        "unit_id": 512,
        "voice": "vo_adv_5074001_078"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "我只是來看看才剛上任也不來向我打聲招呼，",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "\n就自作主張的無禮醫師長什麼樣子罷了。",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_079"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這麼說你就是院長囉。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "聽說你手腕高明，重振了這間有如風中殘燭的醫院。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我叫做直美。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不好意思，現在才跟你打招呼。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "哼，",
        "unit_id": 512,
        "voice": "vo_adv_5074001_080"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "我可不是來說這些無聊的客套話的，",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "妳這個冒牌貨。",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_081"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "太令人心寒了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我──",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "妳認為我會沒事先確認過僱用醫師的來歷嗎？",
        "unit_id": 512,
        "voice": "vo_adv_5074001_082"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "\n妳如此大費周章，",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "究竟有何目的？",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好吧，",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_083"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "反正我本來就覺得只瞞得了一時。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我的目的就是想被這家醫院僱用。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "而妳就為了這個不惜做了這麼多事情，是吧？",
        "unit_id": 512,
        "voice": "vo_adv_5074001_084"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是的。",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_085"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大型醫院的慢性問題，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是總是會令患者久候。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而我能解決這個問題，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也已經證明我並非紙上談兵了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "況且，",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_086"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "院長你手腕高明，好不容易才將這間醫院重振得有聲有色，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "卻讓患者不斷久候，損害風評也不太好吧？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "……好吧，",
        "unit_id": 512,
        "voice": "vo_adv_5074001_087"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "如妳所願，從明天起就來這間診察室上班。",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "感謝。",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_088"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我會誠心誠意工作的。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "但是，",
        "unit_id": 512,
        "voice": "vo_adv_5074001_089"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "妳可別多管閒事啊。",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "多管什麼閒事呢？",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_090"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "真是明知故問。",
        "unit_id": 512,
        "voice": "vo_adv_5074001_091"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "希望妳別聰明反被聰明誤啊。",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "\n",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "好好工作吧，",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "優秀的大醫師。",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊，對了對了，",
        "unit_id": 117511,
        "voice": "vo_adv_5074001_092"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "忘記自我介紹，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我叫做深月。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請多關照囉，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "院長♪",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，成功與院長見到面的深月，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n順利潛入醫院之中了。"
    }
]