[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說是遊行，",
        "unit_id": 114011,
        "voice": "vo_adv_6050209_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我還以為只是走一走，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "意外地還有其他事情要做呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而那些孩子也都做得很好，真厲害。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "聽你這樣說讓我很開心呢。",
        "unit_id": 114011,
        "voice": "vo_adv_6050209_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過那個時候，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "反而是受到那些孩子幫助了吧？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的和一開始的時候完全不一樣了呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯嗯，",
        "unit_id": 114011,
        "voice": "vo_adv_6050209_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看到那些孩子，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很自然地就開心起來了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的是很優秀的鬼怪喔。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "即使他們並不可怕呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果下一次能做得更好就好了呢。",
        "unit_id": 114011,
        "voice": "vo_adv_6050209_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要是這樣說了，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希感覺會更幹勁十足，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n所以還是稍微保密吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我還想把這當成一個驚喜。",
        "unit_id": 114011
    }
]