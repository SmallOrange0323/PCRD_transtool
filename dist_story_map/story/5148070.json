    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是是蘭法姐啊，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n她有可能用奶瓶",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "餵騎士同學喝牛奶之類的呢★",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "奶……",
        "unit_id": 131611,
        "voice": "vo_adv_5148070_007"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "奶瓶……？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我變得",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "更無法了解他們兩個的關係了……",
