        "voice": "vo_adv_5148070_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n為、",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "為什麼會提到兄長大人……？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n兄長大人跟蘭法小姐",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "都是很認真、",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "很冷靜的人……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "相似的兩人產生共鳴，",
