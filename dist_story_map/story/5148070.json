    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "雖然她是負責誘導人，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "但是她居然能發出那麼大的聲音，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n嚇到我了啊～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "沒辦法發出大的聲音的話，",
