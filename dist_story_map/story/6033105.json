[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "多虧了師傅，",
        "unit_id": 112211,
        "voice": "vo_adv_6033105_000"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "變得能使用新的魔法真是太好了呢！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n這樣一來，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "就會想要學會更多種魔法呢。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "怎樣的魔法才好呢……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "原來如此。",
        "unit_id": 112211,
        "voice": "vo_adv_6033105_001"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "就算助手先生把點心藏在懷裡，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我也能輕易識破呢。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n你這表情是被我說中了吧？　",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "呵呵。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "就算沒有透視的能力，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這點程度我還是\n做得到的唷？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "話說，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "你嘴邊有食物的殘渣唷。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我幫你拿掉吧。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "也就是所謂的",
        "unit_id": 112211,
        "voice": "vo_adv_6033105_002"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "讀心術嗎？　",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "的確，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "對偵探而言或許會是最棒的能力呢。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n但是不仰賴魔法，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "而是以知識和邏輯去面對挑戰，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這是我身為偵探的\n信念唷。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "雖然助手先生心裡想的事，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我有點在意就是了呢。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "那個，",
        "unit_id": 112211,
        "voice": "vo_adv_6033105_003"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "能派得上什麼用場嗎……？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "你說在群眾面前表演推理？　",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "呵呵。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "助手先生還是太天真了呢。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "所謂的推理",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "才不是賣弄給人看的東西呢。",
        "unit_id": 112211
    }
]