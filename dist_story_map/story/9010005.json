    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在【美食殿堂】的公會小屋中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n準備迎來７周年的此刻，涅比亞高聲宣布──"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我",
        "unit_id": 190911,
        "voice": "vo_adv_9010005_000"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不再惡作劇了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "咦咦！？",
        "unit_id": 134011,
        "voice": "vo_adv_9010005_001"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "怎麼辦，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "是要下雨了嗎？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "窗外看起來很晴朗的說……",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳不要這麼震驚啦，",
        "unit_id": 190911,
        "voice": "vo_adv_9010005_002"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "先聲明我可是認真的，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "寫作認真，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "讀作真心誠意。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我發現自己也差不多該成為大人了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "…………",
        "unit_id": 190911,
        "voice": "vo_adv_9010005_003"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n……等等，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳那什麼表情。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "臉上寫著完全不相信耶？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "不、",
        "unit_id": 134011,
        "voice": "vo_adv_9010005_004"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "不",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "是啦，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我只是太感動了。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n原來妳也會成長",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "啊……",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我很高興♪",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "沒想到妳能夠自己發現……",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……好了，",
        "unit_id": 190911,
        "voice": "vo_adv_9010005_005"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那麼就馬上來",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "開始打掃吧！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "值得慶祝的日子要保持好心情迎接才行♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "開玩笑",
        "unit_id": 190911,
        "voice": "vo_adv_9010005_006"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "的啦～！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n怎麼可能",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不再惡作劇嘛♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我這個人少了惡作劇，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就跟肉包少了肉一樣啊～♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "接下來，",
        "unit_id": 190911,
        "voice": "vo_adv_9010005_007"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "在門上掛蒟蒻……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這樣就好了！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n在菲歐來確認我有沒有認真打掃的時候，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "滑溜地直擊頭頂♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n呵呵，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "好了，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "快來吧～♪",
        "unit_id": 190911
    },
    {
        "type": "background",
        "background": "500367"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "唔～？",
        "unit_id": 190911,
        "voice": "vo_adv_9010005_008"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "一直不過來耶……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "難道說菲歐那傢伙",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "在睡午覺～？",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "去看一下好了。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "什麼嘛，",
        "unit_id": 190911,
        "voice": "vo_adv_9010005_009"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "明明醒著啊。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……比起那個，菲歐",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "妳在做什麼……",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "咦，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "等一下！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐為什麼在哭……？　",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "嗚嗚，",
        "unit_id": 134011,
        "voice": "vo_adv_9010005_010"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "沒想到那孩子會自己開口說不再惡作劇了，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n我真的高興的不得了，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "忍不住喜極而泣……",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "她其實是個乖孩子呢。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "等打掃結束後，",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "要好好誇獎她才行。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……",
        "unit_id": 190911,
        "voice": "vo_adv_9010005_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "什麼啊，",
        "unit_id": 190911,
        "voice": "vo_adv_9010005_012"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "讓人不知如何是好。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……真拿她沒辦法，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "今天就不惡作劇了，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "要我打掃我就打掃啦。",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這樣不只是菲歐，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "也能讓大家大吃一驚吧♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……呵呵！",
        "unit_id": 190911,
        "voice": "vo_adv_9010005_013"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "很好，",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "決定好了就馬上開始吧♪",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n要來努力打掃～",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "囉！",
        "unit_id": 190911
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "偷瞄……",
        "unit_id": 134011,
        "voice": "vo_adv_9010005_014"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "比起罵她，",
        "unit_id": 134011,
        "voice": "vo_adv_9010005_015"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "誇她應該會比較好……",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "是嗎。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n{player}的建議",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "真是太正確了。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "……比至今為止的任何惡作劇還要令人吃驚，",
        "unit_id": 134011,
        "voice": "vo_adv_9010005_016"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "呵呵。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "好了，",
        "unit_id": 134011,
        "voice": "vo_adv_9010005_017"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "我就去找裝飾公會小屋的花吧。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "值得慶祝的日子就是要用燦爛的心情度過嘛。",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "涅比亞心血來潮變成了乖孩子。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雖然菲歐希望她能一直維持這樣，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但那只能看今後涅比亞的想法了。"
    }
]