    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "對了，",
        "unit_id": 117811,
        "voice": "vo_adv_6076203_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "比我們更早",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "開始擔任博士的助手吧？",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "感覺他不是個等閒之輩，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "但研究也",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "意義不明，讓人搞不懂。",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不知將軍",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "對博士和",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "他的研究",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有何看法是也？",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哦……",
        "unit_id": 117811,
        "voice": "vo_adv_6076203_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "徵招他來擔任參謀嗎？",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖然對他的研究",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "毫無頭緒，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n不過他確實具有",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "製作我們裝備的技術能力是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "肯定",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "能夠在將軍麾下",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有活耶的表現！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍",
        "unit_id": 117811,
        "voice": "vo_adv_6076203_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "對博士的研究",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "很有信心呢。",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "俗話曾說",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "事出必有因，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "無風不起浪，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n身為家臣，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我也會",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "致力追隨將軍，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "努力表現是也！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "連將軍也不清楚，",
        "unit_id": 117811,
        "voice": "vo_adv_6076203_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "看來他果真是個",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "深不可測的人是也。",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不過，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要是",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "真的會",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "發生大災難，這可是很嚴重的大事！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "為了守護將軍",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所治理的這個世界，",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我會",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "全力以赴是也！",
        "unit_id": 117811
    }
]