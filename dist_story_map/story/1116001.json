[
    {
        "type": "background",
        "background": "500872"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了準備隔天的個人演唱會，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n望結束了一天的排練正在收拾中。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好了，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "工作人員們好像也已經回去了，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我也差不多該回去了。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "簡單吃個晚餐，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n淋個浴，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為了明天得早點睡覺呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "果然還是",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再稍微練習一下吧。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n有幾個動作做得還不是很好呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "1、",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "2、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "1、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "2",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n轉身、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "停！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……嗯～",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "結束時手的角度，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是不是再抬高點比較好啊。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n還有",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "轉身再稍微快一點……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "很好呢！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "最近都是舉辦【慈樂之音】的演唱會，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n很久沒有辦個人演唱會了，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "必須準備得更加周全才是。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "千歌跟紡希都不在，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "全部都只能靠我自己，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n既然目標是頂級偶像，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就不能容許不完美的表演呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好～，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "從最開始再來一次――",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀啊！",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n{player}？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嚇到我了……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你為什麼在這裡？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣啊，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是幫忙演唱會場地佈置的打工呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才巡邏到現在啊。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "做到這麼晚謝謝你呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是啊，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是在自己練習啦。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n是在工作人員努力佈置的舞台上表演呢，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n必須得好好表現。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯？　",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你看過排練了嗎？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "覺、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "覺得怎麼樣呢？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的嗎？　",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就算是客套話也讓我更有自信了呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_013"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "新歌怎麼樣？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那首歌",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是我自己作詞的喔。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "表演曲目也很不錯吧？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我煩惱了很久呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對了對了，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "周邊也出了新的喔！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊――，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "怎麼辦呀。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n一跟你說起話來就覺得越來越開心了呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "想要一直聊下去呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明天演唱會的事情啦，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聖誕節的事情之類的。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對了，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要不要一起吃飯然後慢慢地……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呃，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不行不行！　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還在練習中啊！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "要是隨便妥協，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也做不出什麼精彩的表演！　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "抱歉呢，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我還得繼續練習。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n所以呢……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明天見喔。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "走掉了……",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我是不是有點冷淡呢？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我的目標是成為頂級偶像。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n為了呈現最棒的舞台，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "必須要練習到自己能夠接受的程度呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊――",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是如果",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "被{player}討厭的話怎麼辦啊！",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就只有他，我不想被他討厭，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n可是……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯……",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "再想下去也沒有用呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "只能好好地練習，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "用表演來當作賠禮吧。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "1、",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "2、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "1、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "2",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不行，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "總覺得沒辦法冷靜練習。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是丟臉呢，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明明是自己下定決心的事情卻辦不到……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦、",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "{player}！？　",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "為什麼……？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n你不是回去了嗎？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這是",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "熱的飲料……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你是",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "去拿這個了嗎？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦，",
        "unit_id": 111611,
        "voice": "vo_adv_1116001_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你要回去了嗎？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n好、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好吧、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然還在練習、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不是、",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
