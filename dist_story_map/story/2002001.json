[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "數小時後"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從騷動的漩渦之中進行避難的{player}一行人，\n被真琴帶領至【哞哞自衛隊】的據點，\n並稍作休息了一陣子。"
    },
    {
        "type": "still",
        "still": "200200101"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "討厭啦，",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不是真步小姐",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "，要叫人家真步公主。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有夠愛欺負人的，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的是。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且呀，",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不用跟人家道謝哦。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "放著受傷的妳們不管，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也過意不去。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哦哦，",
        "unit_id": 102511,
        "voice": "vo_adv_2002001_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一下子就不痛了！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "話說，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就連衣服也恢復原樣了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "應該說簡直跟全新的沒兩樣吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "比起活的動物，人家更擅長修整衣服。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以就順手一起用一用了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果人家做了多餘的事，還請見諒……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不會不會，幫了大忙～",
        "unit_id": 102511,
        "voice": "vo_adv_2002001_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n如果衣服破破爛爛的話，大小姐會擔心的。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一切都要謝謝妳♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀～小事一樁不用道謝的。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且真琴也給妳添了麻煩。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n應該很害怕吧？ 真是可憐～……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果這樣做能算是跟妳道歉就好了。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n真是可憐、可憐……♪",
        "unit_id": 101011
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請不要摸在下的頭。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "感謝各位⋯⋯",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看起來【哞哞自衛隊】沒有惡意的樣子。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "傷害也控制到了最低，請別煩惱太多了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話雖如此～因為打擾到妳的工作。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那部分就請讓我盡可能地補償。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在正火速地準備馬車。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看來你們的馬車因為爆炸而被吹飛了。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n還好馬車夫是沒甚麼大礙……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為有受傷，所以送去信得過的治療所了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這、這樣啊。",
        "unit_id": 102511,
        "voice": "vo_adv_2002001_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n經過那種程度的激戰，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n沒有人死掉真是不幸中的大幸呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然那個叫小矛依未還是小諾維姆的孩子……",
        "unit_id": 102511,
        "voice": "vo_adv_2002001_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n最後還是被【拉比林斯】她們誘拐走了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "當然也派了人去追那一邊了。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咱們【哞哞自衛隊】正拼命地在追蹤。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是……看來【拉比林斯】那群人，",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n非常擅長逃跑躲藏呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "連犬獸人的嗅覺都能擾亂，逃得無影無蹤的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然有些莫名其妙的感覺……",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但因為咱們的關係害妳捲入這麼麻煩的狀況，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以人家希望盡可能地幫忙。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有任何需要請盡管說。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "誠心感謝各位的用心。",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下對於中斷了鈴莓小姐的工作，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n很過意不去。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明要負責護衛馬車的，",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n卻沒盡到責任。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下真是不爭氣。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，沒關係喔～",
        "unit_id": 102511,
        "voice": "vo_adv_2002001_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請不要太在意。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢竟這是一場不幸的事故，並不是誰的過錯。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "【哞哞自衛隊】的各位，",
        "unit_id": 102511,
        "voice": "vo_adv_2002001_020"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n好像也為我們準備了馬車。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓我們重新振作，出發前往宅邸吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話雖如此，時間已經很晚了……",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n現在出發的話，會變成半夜移動。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "日落之後魔物會更殘暴，很危險的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天晚上就在咱們的公會之家休息吧。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "當然不需要住宿費。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "反而是咱們應該要付個賠償金之類的才對。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "至少讓【哞哞自衛隊】支付",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那些被搬運的物品費用。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不用不用。",
        "unit_id": 102511,
        "voice": "vo_adv_2002001_024"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們只是運送裝行李用的空箱而已，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不用太在意。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比起這個，",
        "unit_id": 102511,
        "voice": "vo_adv_2002001_025"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我們一直沒有抵達，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大小姐好像會很擔心呢～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "可以讓我聯絡一下嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_2002001_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我的通訊魔法不怎麼拿手。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "座標計算等等實在有點難呢～",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也搞不大清楚魔法的用法所以很不拿手。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "同樣隸屬【哞哞自衛隊】的霞，",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n很擅長使用那種細微的魔法。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過現在她在出任務。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "什麼任務來著……",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好像是在調查",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n『闇影』之類的事件。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴也還在審問本次騷動的主嫌……",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n尾狗刀，似乎很忙的樣子。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在她的工作告一段落以前，就由人家來陪伴王子先生你們♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……王子先生？",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那個人……",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是人家的王子先生♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是指主人嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，【哞哞自衛隊】的公會長⋯⋯",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是叫真步小姐嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您也跟主人互相認識嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是的、是的。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家和那個人是命中註定的邂逅，人家的王子先生……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人真的在很短的時間內，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n隨便結識了很多女孩子呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這樣子啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您並不是意圖不軌，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n才跟一個又一個的女孩子搭話的對吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣的話，",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就沒什麼關係了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說到底，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這件事在下也什麼理由好抱怨的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……沒有道歉的必要。",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過那也沒關係。",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "畢竟英雄難過美人關呢。",
        "unit_id": 105913
    },
    {
        "type": "still",
        "still": "200200102"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨──呵，我回來了～☆",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_041"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "巡邏的時候，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我也順便安排好真步吩咐的馬車囉～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，香織，歡迎回來～",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "辛苦了，快坐下休息吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒關係我不累～我今天也活力十足～！",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_043"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n啊哈哈～♪",
        "unit_id": 101711
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，{player}在這裡！",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_044"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你怎麼會在這～ 如果是來玩的話非常歡迎唷～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～一起唱歌跳舞吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯，",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_045"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我也只有活力這個長處了～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n雖然你一直都很沉穩，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但偶爾也應該放開來大鬧一場哦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "（唉呀？",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這位名為香織⋯⋯的小姐，也是主人認識的人吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果只是歸納為『偶然、剛好』，那就顯得太不自然了。）",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "（嗯……",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正如愛梅斯小姐的諭示，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看來主人是眾多起伏的因果中心呢。）",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～？",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_048"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n那邊的孩子怎麼看起來面有難色呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "笑起來比較可愛唷～笑口常開才能招福呀！",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_049"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還是說，妳餓了嗎？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我代替真琴去巡邏，",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_050"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n在鎮上繞了一圈！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為一直東奔西跑，肚子好餓喔～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "借用公會之家的廚房做個點心好了～",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_051"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "比如說好吃的開口笑之類的♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "開⋯⋯",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，那是什麼呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下食量小，請不用費心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在想想，在下從中午開始就什麼都沒有吃呢。",
        "unit_id": 105913,
        "voice": "vo_adv_2002001_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果可以吃上一餐的話那就太好了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊……",
        "unit_id": 102511,
        "voice": "vo_adv_2002001_054"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "如果不介意的話，我可以幫忙做菜喔～",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒關係，客人請好好休息吧～",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_055"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "請等一下喔，讓我好好款待你們～♪　",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要是有材料，就能做更豐盛的料理了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，這樣的話……",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_056"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "拜託真琴要回來時",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "順便買回來吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴很習慣了，",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_057"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以通訊魔法可以立刻接通唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n而且她應該就在不遠的地方。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在大概正和尾狗刀熱烈議論當中……",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_058"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就用簡易的通訊魔法，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n等她有時間時再看訊息。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "神奇真步魔法靈，咕嚕靈波～……♪",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_059"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "喔？",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_060"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n奇怪了，怎麼好像沒反應……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～魔法失敗了嗎？",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_061"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看來通訊似乎受到了阻礙……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯～很少看到真步的魔法會失敗呢～",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_062"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個，怎麼了嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_2002001_063"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不……如果只是人家想太多就好了。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_064"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n回來的路上有沒有什麼可疑的地方？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可疑的地方？",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_065"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這麼說起來，公會之家附近好像比平常還安靜呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "空氣好像有點凝重的感覺？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為動物們喜歡【哞哞自衛隊】，",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_066"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以平常都有鴿子或貓的叫聲，很熱鬧的。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但今天總覺得大家連呼吸都憋著～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那有問題嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_2002001_067"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果是的話，我再去外面好好看一下吧？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不，不需要。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_068"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n為什麼沒早點發現呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不行……人家真是太大意了。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_069"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n有一種熟悉而且強烈的氣息正在靠近。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織，準備進入迎戰狀態吧。",
        "unit_id": 101011,
        "voice": "vo_adv_2002001_070"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n大家退到咱們的後面。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
