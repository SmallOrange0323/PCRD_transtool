[
    {
        "type": "background",
        "background": "502390"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "第二天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在格羅哥團的據點──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "布武機被要求修理因她而故障的車輛。"
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "喝啊，",
        "unit_id": 52111,
        "voice": "vo_adv_5156005_000"
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "快點修好！",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "\n這個小屁孩！",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "好痛喔！",
        "unit_id": 130212,
        "voice": "vo_adv_5156005_001"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "嗚嗚～",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "不要用鐮刀戳人家的屁股啦～",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "吵死了！",
        "unit_id": 52111,
        "voice": "vo_adv_5156005_002"
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "\n被你們背叛的老大的心",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "才痛百倍呢。",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "\n讓你們活著",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "就要懂得感恩了！",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "討厭。",
        "unit_id": 130212,
        "voice": "vo_adv_5156005_003"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n不要一直戳人家啦～",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "搞清楚啊？",
        "unit_id": 52111,
        "voice": "vo_adv_5156005_004"
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "在把妳弄壞的我們的腳，",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "\n把所有車輛修好前，",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "妳可沒飯吃喔！",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "\n",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "聽懂了沒？",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "這個",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "團員１",
        "words": "雜碎小屁孩！",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "嗚～",
        "unit_id": 130212,
        "voice": "vo_adv_5156005_005"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "好苦喔～",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n好餓喔～",
        "unit_id": 130212
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "布武機……！",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_006"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n那根本是被當作奴隸呀……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……對不起，都是因為我……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "對……",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_007"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n因為我們",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不像布武機有利用價值……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "唔、",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_008"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊啊，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "對不起。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "把你跟我相提並論。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "而且，",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_009"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "竟然像這樣兩個人被關在牢裡，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n你一定覺得很擁擠吧。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "對不起對不起……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_010"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我不能、",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不道歉……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "在那之後，",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_011"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "被格羅哥團逮到……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n布武機被當作奴隸……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我們被關在牢裡……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊後來也下落不明。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可是，就算是姊姊，",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_012"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n也難以想像",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "有辦法在那種情況下成功逃跑……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "雖然我不想去想……",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_013"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗚、",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗚",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗚嗚……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "都是我、",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_014"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n毀了【蠻賊三姊妹】……！",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "…………",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_015"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……你……",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_016"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n不怪我呢。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "不會責怪、",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "失敗的我。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "…………",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_017"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "要跟、",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_018"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "你說……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "嗎……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "真正的情形。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n就一點點。",
        "unit_id": 130112
    },
    {
        "type": "still",
        "still": "515600501"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "…………",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_019"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……姊姊她呢，",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_020"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n如果不管她，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "就會一直做壞事。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "「我只能這樣生活」",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_021"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "或者是",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "「正義和法律又為我做了什麼」",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n之類的……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "都是姊姊的口頭禪。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n只要是為了她想做的事，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呵呵，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "她才不管什麼規則。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "吵架早已是",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_022"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "家常便飯──",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n驚動警察",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也是常有的事。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可是……",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_023"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "即使像這樣肆意胡鬧，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n姊姊本身看來總還是",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "因為少了什麼，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "而感到焦躁。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "會不會有一天……",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_024"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "有一天……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n在姊姊內心不斷沸騰的東西終於爆發，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n發生不可挽回的事，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我常這樣擔心……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那樣的話，",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_025"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n姊姊會不會",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n從我和布武機的身邊",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "離開……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_026"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "一直都",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "好害怕…………！",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……所以，",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_027"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n我才把姊姊帶來「這個地方」。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n為了讓她",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "在這裡紓壓。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "對。",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_028"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n──《阿斯特朗傳奇》。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呵呵，",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_029"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可是",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "結果，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n在這裡",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也開始組起盜賊這樣危險的公會。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "一開始，",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_030"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "我想說是虛擬的世界，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n只要姊姊看起來很開心，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那就好了。",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "可是，",
        "unit_id": 130112,
        "voice": "vo_adv_5156005_031"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "慢慢地，",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n在和你們戰鬥、",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n欣賞相同景色的過程中……",
        "unit_id": 130112
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊，",
