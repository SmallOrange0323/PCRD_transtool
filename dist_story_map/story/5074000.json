[
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天深月依舊在蘭德索爾的小巷內替人們看診。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我要打針囉。",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可能會有一點刺刺的，要忍耐喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "痛死啦──！",
        "unit_id": 911,
        "voice": "vo_adv_5074000_001"
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "可惡，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "這哪是一點刺刺的！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "我還以為手臂炸掉啦。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哎呀，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣才能趕快痊癒呀，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這可是",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我給你的溫柔呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你想要的話，我也可以給你更硬派點的溫柔喔？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "還是算了吧。",
        "unit_id": 911,
        "voice": "vo_adv_5074000_003"
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "真是的，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "妳的溫柔太可怕啦……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有時間抱怨，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不如快點回去好好養傷吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算是你這種人，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個城鎮依舊需要你喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "不用說我也明白啦。",
        "unit_id": 911,
        "voice": "vo_adv_5074000_005"
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "暴徒",
        "words": "再見啦，醫生。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好啦，{player}，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可以幫我叫下一位患者嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣啊。",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說回來，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "最近這陣子病患還真多呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不然平常我一個人就應付得來了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n現在卻還要請你來充當護理師。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "蘭德索爾也真是一波未平一波又起，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "和平還遙不可及，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看來你還得忙上好一陣子吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你覺得開心就好。",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓我這種密醫生意興隆，這世界沒救了呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "關於這件事，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "公會夥伴也問過也一樣的問題，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n但說起來我其實是科學家，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "研究與實驗才是我的本分。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然我順勢而為，看起來像是在助人為善，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n但我跟社會一般認知的醫生不同，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "並不全然是出於善意才幫助人的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "況且像我這樣的人",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "保持地下活動才比較方便。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "非法研究只能暗中進行啊。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算真的出了差錯，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也可以在暗中輕易處理掉。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "舉個例子，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算我現在對你做了什麼，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也能輕鬆消滅痕跡喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……我開玩笑的。",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "當我沒說吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你總是會讓我不知所措。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你應該只是個方便的實驗品才對啊，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真傷腦筋。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現在被你害得我為了這些不習慣的助人活動而忙碌，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n本業都被耽誤了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "以前的我根本不可能這樣。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過相對地，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你也讓我看到了很多有趣的事，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n所以我其實也挺感謝你的啦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好啦，今天就到這邊吧。",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n想休息就休息，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這也是密醫的特權喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "打擾啦。",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就是妳沒錯吧？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "妳就是那個叫做深月的醫生？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……沒錯。",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但我是個密醫喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n如果你為人正派、不做虧心事，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "最好還是去找有執照的醫生吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不必，",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_021"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "聽到妳這麼說我就放心了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我就是有事要來拜託妳這位密醫的。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "拜託妳！",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請妳",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "救救我們頭目吧！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……你先抬起頭吧。",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不然我們要怎麼繼續談呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n更何況，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我都還不知道你是什麼人呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "的、",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_024"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "的確。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我是大江戶町，來道一家的人。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來道、",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "一家……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "喔喔，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "黑道是吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "簡單說，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是東國的幫派吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "別把我們跟其他地方的幫派混為一談！",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_027"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我們可是重情重義的俠客集團。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你是要來拜託我替你們頭目動手術嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可以是可以，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但我價格不菲喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不是的，",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_029"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們頭目被帶走了，我是來拜託妳去救他的。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "被帶走了？",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我可不要捲入你們黑幫之間的鬥爭。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n抱歉，你另請高明吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不是那樣的。",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_031"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們頭目被帶去的地方是……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "醫院。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……這是怎麼回事？",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_032"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "頭目他最近身體狀況欠佳，",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_033"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但他原本是很硬朗的，所以我們也不怎麼擔心。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可是，",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_034"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "某一天有間醫院的院長突然過來，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n幾乎用押送的方式把頭目給帶走了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們想去探病，結果那個混帳院長居然說頭目謝絕會客，把我們趕了回來。",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_035"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我拜託妳了，醫生！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "幫我們把頭目帶回來吧！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但是就我聽來，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_036"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "感覺不出有什麼異狀。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "之所以強行帶走頭目，也許是因為有緊急狀況需要處理，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "住院後謝絕會客，也可能是因為狀況突然惡化了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不可能，",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_037"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那是絕對不可能的！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "肯定是那間醫院有問題！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你對我說這些也沒用啊……",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_038"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說那是哪間醫院呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "叫做聖阿弗萊特醫院，",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_039"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "看上去很氣派、房子又大。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n妳有聽過嗎？",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "聖阿弗萊特醫院……",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_040"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我是有聽過……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "想起來了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我記得是間經營困難險些倒閉的醫院。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可是，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_041"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我不覺得他們有那閒工夫，\n可以跟黑社會的人起爭端呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "其實那間病院",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_042"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "一年前才換成現在這個院長，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n之後就一口氣重振了經營。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只花了一年？",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_043"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是驚人。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "看來那位院長是個優秀的人才呢？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我想是吧。",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_044"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "實際上那家醫院現在的風評非常好。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可是，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那個院長實在",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "太可疑了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那只是你個人的印象吧？",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_045"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "再說了，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你不該找我這密醫處理這種事情的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "前提是妳只是個普通的密醫，",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_046"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我知道妳是什麼人才來拜託妳的，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "「單眼惡魔」。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……這樣啊，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_047"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以你知道我是誰。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "太出名也挺傷腦筋的呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也就是說，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你想要找個同時是醫生",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "又深諳黑社會的人物，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n於是就挑中了我，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒錯吧？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒錯，",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_048"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "就是那樣。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "若要潛入黑暗之中，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_049"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "了解黑暗的人自然是不二人選。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你的選擇，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是正確的。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這、",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_050"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這麼說……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但是，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_051"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算我是不二人選，\n但蹚這渾水對我真的有好處嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你自己就是黑社會的人，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_052"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "難道不知道接觸黑暗會有危險？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "正因為理解其中風險，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_053"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以才更需要深思熟慮。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我可不能輕言答應這種事情。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……我說你啊，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_054"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可以別說得一派輕鬆嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n若是落到最糟的情況，我可能會被捲入有致命風險的麻煩裡面喔？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "重點不是你幫不幫……",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_055"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不對，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_056"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "已經來不及了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "無論對象或風險如何，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這個人只要路見不平就會一視同仁地拔刀相助。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "他聽完對方原委之後就已經不可能拒絕了。",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_057"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "拜託了！",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_058"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "不只我們來道一家，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n這是攸關大江戶町的大事。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n請妳助町上一臂之力吧！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……剛剛也說過了，",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_059"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我價格不菲喔。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "出差費用，以及出了什麼事的危險津貼等等，金額上你們要有心理準備。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒、",
        "unit_id": 1111,
        "voice": "vo_adv_5074000_060"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒問題！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "謝謝妳，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這份恩情我沒齒難忘！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說得太早了喔。",
        "unit_id": 105111,
        "voice": "vo_adv_5074000_061"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要道謝，等我把你們頭目帶回來再說吧。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，\n深月與{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "動身前往大江戶町。"
    }
]