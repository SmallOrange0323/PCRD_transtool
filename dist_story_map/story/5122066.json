[
    {
        "type": "background",
        "background": "502000"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "這個……",
        "unit_id": 6411,
        "voice": "vo_adv_5122066_000"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "不是我的釣竿嗎！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n什麼？",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "從海裡找到的？",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "是真的嗎！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "感激不盡！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "太感謝你啦，小兄弟！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "實不相瞞，",
        "unit_id": 6411,
        "voice": "vo_adv_5122066_001"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "這支釣竿……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n其實是我師傅",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "留給我的遺物。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "不，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "不是祕密廢棄物。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "是我把它丟進海裡的，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "這只是",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "遺失物而已。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "小兄弟……",
        "unit_id": 6411,
        "voice": "vo_adv_5122066_002"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n看來你把我",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "當成了犯傻的冒失角色是不是？",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "好吧，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "雖然也無法否認啦。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "但是呢，",
        "unit_id": 6411,
        "voice": "vo_adv_5122066_003"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "當時的情況可不一樣。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "……那是我剛開始出海捕魚的時候，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n我就是用這支釣竿首次釣到了",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "超大的金槍鮪啊。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "這下子終於能對師傅抬頭挺胸了！",
        "unit_id": 6411,
        "voice": "vo_adv_5122066_004"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "正當我這麼想的瞬間，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "我看見了啊。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n那傢伙的背鰭上",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "有著巨大的舊傷。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "那是一尾",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "背鰭傷痕累累，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "身上負傷卻又奮力求生的金槍鮪。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "這可讓我迷惘了～！",
        "unit_id": 6411,
        "voice": "vo_adv_5122066_005"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "要是放手，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "好不容易有的成果就泡湯了。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n更何況這還是初次的漁獲耶？",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "……可是啊，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "我是這麼想的：",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "「師傅他一定會這麼做」。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "可不能對負傷的獵物下手，",
        "unit_id": 6411,
        "voice": "vo_adv_5122066_006"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "所以我就把手放開了，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "連同遺物的釣竿一起……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n畢竟這傢伙緊緊地",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "咬住了魚餌嘛。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "……我的第一次漁獲就這樣沒了。",
        "unit_id": 6411,
        "voice": "vo_adv_5122066_007"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "不過，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "不知為何",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "我並不感到後悔，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "反倒是燃起了鬥志。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "現在回想起來，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "那",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "正是我的",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "「初心」吧。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "……這一定是那傢伙",
        "unit_id": 6411,
        "voice": "vo_adv_5122066_008"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "送還給我的。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "看來",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "我和正也差不多該下定決心",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "大幹一場啦。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "哦哦？",
        "unit_id": 6411,
        "voice": "vo_adv_5122066_009"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "稍微對我",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "另眼相看了嗎？",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "哈──哈哈哈！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "那你可要再來喔！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n接下來換我把小兄弟你",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "鍛鍊成大海男兒！",
        "unit_id": 6411
    }
]