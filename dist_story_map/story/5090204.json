[
    {
        "type": "dialogue",
        "name": "步未",
        "words": "有種",
        "unit_id": 121511,
        "voice": "vo_adv_5090204_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "討厭的感覺……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n皮膚隱隱作痛，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不停地起雞皮疙瘩……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "賭場王那個渾蛋……",
        "unit_id": 121611,
        "voice": "vo_adv_5090204_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n都離這麼遠了，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還是能感受到他強大的壓力……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也就是說，剛剛他還沒有拿出真本事嗎……！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "正好……！",
        "unit_id": 106511,
        "voice": "vo_adv_5090204_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n不管他用「龍之卵」強化到什麼程度，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n我們都要揍扁他！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對吧，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "祈梨、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "步未！",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說的沒錯！",
        "unit_id": 121611,
        "voice": "vo_adv_5090204_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就由我們",
        "unit_id": 121511,
        "voice": "vo_adv_5090204_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "來打倒賭場王吧……！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為了",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "結束這一切……！",
        "unit_id": 121511
    }
]