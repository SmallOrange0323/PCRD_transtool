    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，",
        "unit_id": 100411,
        "voice": "vo_adv_1004500_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "叫禊出來是有什麼事嗎？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "應該沒有地洞之類的陷阱吧？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嘛、",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥應該是不會做這種事情吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇！　",
        "unit_id": 100411,
        "voice": "vo_adv_1004500_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "原來你記得呀！？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "居然能讓禊吃驚，哥哥也很厲害呢～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸嘿嘿，",
        "unit_id": 100411,
        "voice": "vo_adv_1004500_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "被人祝福生日讓禊覺得很高興呢。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥生日的時候要準備特別的惡作……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不對！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "會準備禮物的，哥哥要好好期待喔！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……？　",
        "unit_id": 100411,
        "voice": "vo_adv_1004500_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "突然間怎麼了？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "雖然搞不太懂，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊才是要請哥哥多多指教？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "到底是什麼事情呀，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊！　",
        "unit_id": 100411,
        "voice": "vo_adv_1004500_004"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "因為是禊的生日嗎！　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣很難懂啦～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "做為處罰，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥今天一整天",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "都要陪禊\n一起惡作劇喔，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "做好覺悟吧！　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸嘿嘿！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個箱子",
        "unit_id": 100411,
        "voice": "vo_adv_1004500_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是什麼？　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "學禊做的驚嚇箱？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣的話不做得更低調可不行啦！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好了，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥你自己打開吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？　",
        "unit_id": 100411,
        "voice": "vo_adv_1004500_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "沒有爆炸呢。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "裡面是……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊想要的惡作劇道具！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這是最棒的驚嚇箱了！　",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "謝謝！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "果然跟哥哥在一起的時候都不會無聊呢～",
        "unit_id": 100411,
        "voice": "vo_adv_1004500_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "以後也要讓禊開開心心喔！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "約好了唷！",
        "unit_id": 100411
    }
]