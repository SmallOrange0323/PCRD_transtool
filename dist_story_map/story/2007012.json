[
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼。",
        "unit_id": 103111,
        "voice": "vo_adv_2007012_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "費盡千辛萬苦，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n終於成功突破了那一大群魔物了呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還真累人呢～。",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的肚子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也已經餓扁扁了啦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "究竟是怎麼一回事呢……",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "若只是想要擊退入侵者而放出眷養的魔物，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺也玩得太過火了一點呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家有受傷嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果只是小傷，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下可以做一點簡易的處理，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有需要的話請跟在下說。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您沒有事吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請趕緊讓在下看看您的傷！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……太好了。",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是受了一點擦傷的程度嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是沒有那個臉見您了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明大放厥詞了，卻沒能徹底保護您呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若被細菌給感染就不好了，",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓在下替您消毒一下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，可能會有點刺刺的，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請忍耐一下唷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "替您塗塗抹抹消毒水囉……♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好，",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "結束了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有其他人有受傷嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "託您的福，在下毫髮無傷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而且大多數的魔物，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都由其他人打倒了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "輕鬆了許多呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由於在下對自己的體力沒什麼自信，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拖久會很不利的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幸好",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "平安無事地結束了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這場戰鬥相當激烈呢……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有些擔心大家是否有受傷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位沒事吧？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "大家都沒事～",
        "unit_id": 100711,
        "voice": "vo_adv_2007012_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n活蹦亂跳的喲，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "活著真好♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "先不說我們自己，",
        "unit_id": 102211,
        "voice": "vo_adv_2007012_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n武器的狀況很糟呢，都破破爛爛的了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "若要再繼續打下去，可能就不太妙了唷。",
        "unit_id": 102211,
        "voice": "vo_adv_2007012_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n趕緊達成目的，撤退吧。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊，我這裡有磨刀石唷。",
        "unit_id": 100611,
        "voice": "vo_adv_2007012_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n一起來維修一下武器吧～。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "維修這單字",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "乍聽下是不是有點下流呀……♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呵呵。",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n看起來大家都無恙，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這樣就安心多了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……那位叫似似花的人，",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就在這附近嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這裡的景色，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來跟剛才沒什麼差別呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 103111,
        "voice": "vo_adv_2007012_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n在前方的轉角那裡……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n有一個看起來相當不起眼的岩石旁邊，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有個按鈕。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "按下它，",
        "unit_id": 103111,
        "voice": "vo_adv_2007012_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就會開啟通往研究所的道路了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然沒有留下任何記號，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但我很擅長記住這類的事。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……？",
        "unit_id": 104412,
        "voice": "vo_adv_2007012_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "各位，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "腳步先停一下！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看來",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有些不對勁？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "瞧。",
        "unit_id": 104412,
        "voice": "vo_adv_2007012_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n明明還沒按下過按鈕，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但通路的入口卻已經敞開了。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而且不覺得，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有陣異樣的地鳴嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 103111,
        "voice": "vo_adv_2007012_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n和魔物的腳步聲也不同呢，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這聲音究竟……？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……咦？",
        "unit_id": 1,
        "voice": "vo_adv_2007012_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n誰在那裡！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "哇……？",
        "unit_id": 102211,
        "voice": "vo_adv_2007012_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好、",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "好像有人",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "從研究所的出入口飛奔出來了耶？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯～打扮也很可疑……",
        "unit_id": 100611,
        "voice": "vo_adv_2007012_024"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "該不會",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是想要把遺跡搜刮一空的盜賊之類的？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯嗯？",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您該不會是矛依未小姐……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "欸？",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊呀！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是你們！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": " 你們怎麼在這裡！？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是這邊該說的台詞……",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "矛依未小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家都很擔心您唷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再怎麼說前些日子……",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n傳聞在發生大量破壞魔法的現場，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎有目擊到您的身影。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但這麼看來是多慮了呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓人放心了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不禁深切感到，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您還真是與爆炸相當有緣份的呢♪",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔～",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也不想每次都被捲入",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n爆炸之中呀。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但這似乎是命中註定。。",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也無可奈何。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……不對",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_032"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在可不是閒聊的時候！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然不知道你們來這裡要幹嘛，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但是快點逃吧！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這個研究所要爆炸啦！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦咦，",
        "unit_id": 105913,
        "voice": "vo_adv_2007012_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又要爆炸了嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呃……",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是怎麼一回事呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們來到這，",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是為了要見一位名為似似花的人物呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔，蒂亞娜……",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳也沒事啊，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "太好了太好了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "照這樣看來……",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_037"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n當時在大量破壞魔法爆炸中心的人，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n應該大多都撿回一條命了吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳說蒂亞娜……",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼會知道我的本名呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_039"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只是克莉絲提娜都這麼叫妳而已。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克莉絲提娜？",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們才聽說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那人已經越獄了呢……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊真是的！",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_041"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "廢話少說！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就說先逃再說了嘛！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們也感受到這個地震了吧？",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_042"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那是因為在研究所中心的",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "魔力爐失控了！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "再過不久就會到達臨界點，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_043"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "然後轟轟烈烈地爆炸了啦！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n研究機會炸到連碎片都不剩唷！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個爆炸的威力可能會跟前幾天的大量破壞魔法一樣，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_044"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "甚至更強！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唔唔……",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼這樣～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好不容易才到這裡的耶。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "連想找的人都沒見上一面，",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就得垂頭喪氣地打道回府嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "留得青山在，不怕沒柴燒。對吧？",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_047"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只要還活著，總會有辦法的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且……",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_048"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n也不可能見到似似花唷。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "似乎是被綁走了呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "比我和你們到這兒前更早一些，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_049"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n王宮的軍隊好像已經來過這裡囉。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "似似花雖然很強大，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_050"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但抵抗到最後似乎還是敵不過被帶走了呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在那時，派來的軍隊在各處大肆破壞，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_051"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n害得被保存起來的「漏洞」魔物全都給放出來了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「肉凍」魔物？",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳說的難不成，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就是由複數魔物合成起來的那些傢伙嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_053"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那是真軌身為『公主騎士』能力的產物",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n那傢伙，可以合成複數的魔物。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在合成的時候，產生了一些漏洞",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_054"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n而變成了本來不應該存在的奇妙魔物。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真軌……？",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_055"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103111,
        "voice": "vo_adv_2007012_056"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是個有印象的名字。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n可說是似似花的助手，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "又或是護衛一樣的人。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我有與他照過幾次面。",
        "unit_id": 103111,
        "voice": "vo_adv_2007012_057"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看起來還剛成年不久，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是一位開朗的青年。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那位先生，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "他也沒事嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然",
        "unit_id": 103111,
        "voice": "vo_adv_2007012_058"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n似似花似乎已經被",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "王宮的軍隊給捉走了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但到底，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是發生了什麼事情呢？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也不清楚。",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_059"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們也在猜，下一個被襲擊的或許就是似似花也說不定，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_060"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以才趕來要助上一臂之力的呀～",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但最後卻沒有趕上，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在正感到窮途末路了啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "真軌的話……",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_061"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n好像在緊要關頭時，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "似似花讓他逃出來了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然真軌看起來是傷痕累累的狀態，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_062"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但在剛才見著時也幫了他一把。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果還有什麼想問的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "留著去問他吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "比起這些事，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_063"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "還不快逃啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "似似花她不希望自己的研究資料被人奪走，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_064"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以在這個研究所裡設了自爆功能。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n而那個功能，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在已經啟動了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟是那個神經質的似似花所設置的自爆功能……",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_065"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這個研究所真的會被炸到面目全非，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n連張紙不會留喔。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我可不想被捲進去，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_066"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "趕快撤退吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算妳這麼說，",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_067"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但是我們用來傳送到這裡的轉移魔方陣",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n離這邊有好一段距離呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算用衝刺的跑去避難，",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_068"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n可能在還沒到達以前就已經爆炸了唷？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔……",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_069"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒辦法了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們跟我們來吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基拉基雖然一次只能運送幾個人，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_070"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但也只能讓他來回幾次加把勁試試看了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼做，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_071"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n大概也比你們跑到那個魔方陣快得多了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我也是由",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_072"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那傢伙的那個能力……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n用空間跳躍，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才能到達這個地方。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拉基拉基……",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_073"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是那個叫",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拉基尼卡東的人嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個在大量破壞魔法的爆炸核心處，",
        "unit_id": 105812,
        "voice": "vo_adv_2007012_074"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n有些不可思議又有點愛現的那男人？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哎！",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_075"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就說沒有那麼多時間廢話了啦！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n跟我來！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然現在已經亂成一團讓人完全搞不清楚狀況，",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_076"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但再怎麼說活下去是先決條件！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "跑起來！",
        "unit_id": 106112,
        "voice": "vo_adv_2007012_077"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你們也不想在一頭霧水的狀況下，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就這麼掛了對吧？",
        "unit_id": 106112
    }
]