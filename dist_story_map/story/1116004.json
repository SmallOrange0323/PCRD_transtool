[
    {
        "type": "background",
        "background": "500037"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "順利再會的望跟{player}，\n重新開始約會。"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 111611,
        "voice": "vo_adv_1116004_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你看。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "樹頂的星星，",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "非常地明亮呢。",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n就好像在為我們成功再會祝福一樣呢♪",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是",
        "unit_id": 111611,
        "voice": "vo_adv_1116004_001"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好像有點太亮了？",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那應該只是普通的裝飾才對……",
        "unit_id": 111611
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀啊！",
        "unit_id": 111611
    },
    {
        "type": "still",
        "still": "111600401"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家～！　",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_002"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "開心嗎～！？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "喔喔喔～！",
        "unit_id": 1,
        "voice": "vo_adv_1116004_003"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊哈哈，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_004"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "根本不需要問呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家熱烈的靈魂，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "確實傳達給我了喔！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "其實呢，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為是在聖誕節舉辦的演唱會，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我一直很擔心大家會不會來呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n因為這是跟家族、朋友、",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "戀人",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "等重要的人一起渡過的節日呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "在這種日子大家選擇與我一起度過，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_006"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我非常地開心喔！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "喔喔喔～！",
        "unit_id": 1,
        "voice": "vo_adv_1116004_007"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但我是",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_008"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的很高興大家肯過來呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n如果大家沒有過來的話，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "接下來就得被製作人",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n叫去咖啡廳了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不管是美味的蛋糕",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_009"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "還是暖呼呼的飲料全部都只能乾瞪眼，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n難得的聖誕節就得在說教中結束了……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那個呀，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_010"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "如果變成那樣，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家會來救我嗎？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_011"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聲音好像有點小呢？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣的話就得跟大家說再見了喔？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝！　",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_012"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "大家的想法，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "全都傳達給我了喔！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼到最後都要不間斷地一起嗨喔！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n要好好跟上來喔！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "粉絲們",
        "words": "嗚喔喔喔喔喔喔喔！",
        "unit_id": 1,
        "voice": "vo_adv_1116004_013"
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_014"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "呼……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n抱歉我遲到了！　{player}！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真的嗎？　",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_015"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "桌上的空杯子跟盤子！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n都露出馬腳了啦……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可是，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝♪",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "才沒有呢！",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_016"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我才不像你呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是抱歉呢。",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_017"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明明是我找你出來的。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然想要趕快過來，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是有各種狀況……",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "但是太好了，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_018"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你在這裡。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "打開門的時候",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "看到你在這裡很令人安心呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你在這裡也就是說，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_019"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "有確實察覺到",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我想告訴你的訊息呢♪",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "對，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_020"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就是希望你來這間我們一起來過好幾次的店",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這樣。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "把只有你能聽懂的",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們兩人的回憶，插進串場MC了喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "其實在過來這裡的途中，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_021"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n擔心著你到底會不會注意到，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "讓我感到很緊張呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸？　",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_022"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你問為什麼要叫你出來？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "明明就注意到那個訊息了，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你還真是遲鈍呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "當然是因為我想跟你兩個人一起慶祝聖誕節啊！",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_023"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "哇啊，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_024"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "好驚訝的表情呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "畢竟這是驚喜嘛。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "給做出這麼好的反應的你，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_025"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "這個，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "是禮物喔。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "欸？　",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_026"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "什麼都沒準備非常抱歉？　",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "不用在意那種事情啦。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n聖誕節能夠見面就已經是很棒的禮物了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_027"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "差不多該開始了吧？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "已經把店給包下來了，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "可以悠閒地聊聊天呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "……不過，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_028"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "因為我太晚過來了，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "也不能那麼悠閒呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "所以更要好好地享受呢。",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_029"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "聖誕快樂！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "啊，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_030"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "已經是這個時間了。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然很可惜，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "今天只能到這裡了呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "謝謝你今天願意過來呢。",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_031"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "雖然只有很短的一段時間，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n我真的很開心喔！",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "咦，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_032"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你還在在意沒有準備禮物的事情？",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "\n",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "真是的，",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "你還真是認真呢。",
        "unit_id": 102931
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗯～，",
        "unit_id": 102931,
        "voice": "vo_adv_1116004_033"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "那麼",
