[
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "カフェ店員、",
        "unit_id": 107911,
        "voice": "vo_adv_6106204_000"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "義賊、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "財団のお仕事……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "忙しくて目が回りそうだにゃ。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n猫の手も借りたいのに、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "猫のあたしが大忙しってどういうことにゃ！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "んにゃにゃ……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "もうすこし楽に仕事できないものかにゃあ……？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "！　",
        "unit_id": 107911,
        "voice": "vo_adv_6106204_001"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "その手があったかにゃ！　",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "確かにカフェで一休みしてるときは\nみんな気が緩んでるから、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "情報収集には好都合だにゃ！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "……って、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "結局仕事しちゃってるじゃないかにゃ！　",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "謀られたにゃ！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "あ、",
        "unit_id": 107911,
        "voice": "vo_adv_6106204_002"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "ありがとにゃ……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "はにゃ～、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "この一杯が染みるにゃ～……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nたっぷりミルクも、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "あたし好みで……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "むふ、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "キミのコーヒーのおかげで",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nなんだか元気が湧いてきたにゃ。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "もうひとがんばりしてやるにゃ！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "くっ、",
        "unit_id": 107911,
        "voice": "vo_adv_6106204_003"
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "それは猫派のプライドが傷つくのにゃ……！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\nでも……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "ぐぬぬ、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "背に腹は代えられないにゃ。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "この場は一時休戦、",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "タマキ",
        "words": "今からひとっ走り行って助っ人を呼んでくるのにゃ！",
        "unit_id": 107911
    }
]