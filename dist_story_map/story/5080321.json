[
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "怎麼回事！？",
        "unit_id": 119311,
        "voice": "vo_adv_5080321_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n出現了和我們長的一模一樣的人！？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子的布丁是宮子的！",
        "unit_id": 119911,
        "voice": "vo_adv_5080321_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n拿走宮子布丁的傢伙才不是宮子呢！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然聽起來十分哲學，",
        "unit_id": 119211,
        "voice": "vo_adv_5080321_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但其實宮子並沒有深入思考太多吧……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子有在思考！",
        "unit_id": 119911,
        "voice": "vo_adv_5080321_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n只要打倒那些傢伙，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁就全都是宮子的了喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊哈哈，",
        "unit_id": 119311,
        "voice": "vo_adv_5080321_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "果然沒有我們的份呢。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我已經習慣啦。",
        "unit_id": 119211,
        "voice": "vo_adv_5080321_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那麼，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "為了宮子的布丁，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我們再努力一下吧！",
        "unit_id": 119211
    }
]