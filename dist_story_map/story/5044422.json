[
    {
        "type": "background",
        "background": "500016"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "呼，",
        "unit_id": 105611,
        "voice": "vo_adv_5044422_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "花心星終於安分點了。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "太讓人折騰了吧，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「呵呵呵……",
        "unit_id": 101311,
        "voice": "vo_adv_5044422_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那傢伙是花心星裡面最弱的一個……！」",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "待會應該不會",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "突然冒出另一個四天王說出這種話吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "啊！",
        "unit_id": 100911,
        "voice": "vo_adv_5044422_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "也有可能暗中策劃這場騷動的邪神會出現，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n吸收花心星的力量，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "對我們發動襲擊！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳們",
        "unit_id": 105611,
        "voice": "vo_adv_5044422_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "為什麼這麼興奮啊……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我們都已經戰鬥這麼久了，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種發展還是別了吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 101311,
        "voice": "vo_adv_5044422_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們都把他打得抬不起頭了，應該沒問題啦。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這一切能平安過去都要感謝七七香的努力──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是是是。",
        "unit_id": 105611,
        "voice": "vo_adv_5044422_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這樣就算是告一段落了，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們也去享受七夕祭吧。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗯。",
        "unit_id": 100911,
        "voice": "vo_adv_5044422_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "讓我們盡情沉醉於勝利之宴吧！",
        "unit_id": 100911
    }
]