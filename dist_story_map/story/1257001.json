[
    {
        "type": "background",
        "background": "500371"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被花凜叫了出來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n造訪了公會管理協會。"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "{player}先生，您好。",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "謝謝您",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在百忙之中撥冗赴約。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這次找您的理由嗎？",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_001"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那當然是",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有一份希望您務必接下的委託。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "首先，請看這裡。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的，",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "如您所見……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這是",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "一份約一百年前的委託書。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這是我在整理資料保管庫時發現的，",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_003"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n它似乎在尚未解決的情況下被遺忘，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "經過了一百年的時間。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "更重要的是……",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您有察覺到嗎？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的，沒錯！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請看這個目的的部分！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「希望得到沉眠於瀑潭迷宮的",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "鍊金術秘傳書」──",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這次會找您來，",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_005"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我就直說了！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n就是希望您能完成",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這份委託。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "話雖如此，",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_006"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "原本的委託人已經身分不明，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n委託本身也在尚未完成的情況下被作廢。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這是屬於我個人的委託……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您願意接下嗎？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "謝謝您。",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_007"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我就知道您會這麼說。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "咦？",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_008"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請、",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請等一下！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n難不成……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您現在打算獨自一人前往嗎？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "單獨前往不是很危險嗎？",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_009"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我認為至少應該帶一名支援者。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "例如……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "沒錯，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "熟知鍊金術的人",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "或許是個不錯的人選。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "況且，",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_010"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您看來也沒有帶上地圖……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n不先調查瀑潭迷宮的詳細地點沒問題嗎？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我已經背下地圖，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "記住全部路線了……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不是，",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_011"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我是公會管理協會的人……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n……什麼？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您說，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "一個人前往果然有難度？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "自己也不知道路該怎麼走……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這樣啊！",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_012"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n如果是這樣的話，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那就沒辦法了……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呃……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您在笑什麼呢？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "……對不起。",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_013"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "原來您已經看穿了啊。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "其實，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我也很想去現場看看……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "很抱歉，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "讓您費心了。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼，再重來一次……",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_014"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這次的冒險，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請務必",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "讓我同行。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "……可以嗎？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "謝謝您的許可！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼，",
        "unit_id": 118511,
        "voice": "vo_adv_1257001_015"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我還有很多準備要做，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我們明天在前往現場吧！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請記得事先做好準備喔。",
        "unit_id": 118511
    },
    {
        "type": "background",
        "background": "501370"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天，{player}和花凜來到了"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n委託書上記載的瀑潭。"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們平安無事地來到附近了呢。",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_016"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但是，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這裡開始才是重頭戲！",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們不要鬆懈，繼續加油吧！",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的。",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_017"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我認為需要有關鍊金術的專業知識和技能，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n就穿這身衣服來了。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您怎麼了嗎？",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_018"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您在四處東張西望……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n咦？",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您說，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然有瀑布，但沒看到迷宮入口。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請您放心。",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_019"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "關於這件事，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我已經事先調查完畢了。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請往這邊走。",
        "unit_id": 125711
    },
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "來，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_020"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這裡",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是瀑潭迷宮的入口。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您怎麼了？",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "露出一副不可思議的表情……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "明明沒有瀑潭，怎麼會有迷宮。您是在意這點啊。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那是因為",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_021"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這裡",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在一百年前",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "原本有一座瀑潭。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "因為數十年前的惡劣天氣改變了河川流向，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n連帶改變了瀑布的位置。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我看了過去冒險者們的報告書。",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_022"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我想您也知道，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "報告書是情報的寶庫。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "整理冒險者拚命留下來的情報，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_023"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n讓下一位冒險者能夠加以活用，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是我們的工作。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們會把記載的情報",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "一字不漏地記錄下來。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_024"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請確實提交報告書喔。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "說不定",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "能幫助到一百年後的冒險者們。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您怎麼了？",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_025"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您說，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "牆壁上有東西……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n嗯，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "上頭刻有一些文字呢。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「想要吾之財寶者。",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_026"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "挑戰吾之測驗，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "展現其睿智吧。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n鍊金術師‧",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "霍拉弗基」……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "上頭是這麼寫的……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "鍊金術師‧霍拉弗基……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是我沒聽過的名字呢。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我在公會管理協會的紀錄中，也不曾見過他的名字……",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_027"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n表示他可能是隱居的天才，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "或是被流放的異端人士……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我的興趣",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "突然湧了上來！",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們繼續前進吧！",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "哎呀，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_028"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是岔路啊。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這裡同樣也寫了些什麼……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是「第一道測驗」啊。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "下方還有個",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_029"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "陌生的圖形。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不對……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我記得這個好像是……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "文字……？",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "嗯嗯……",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_030"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "原來如此。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我知道了，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「正確答案是右邊」",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這樣就突破",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "第一道測驗了。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們繼續前進吧。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "哎呀，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_031"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這個並不是圖形。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這是在阿斯特賴亞大陸以外的地方所使用的文字。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我偶爾",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_032"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也會收到外籍冒險者的報告書，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我是在那時學到的。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我是時隔許久才又見到，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不過我有確實看懂喔。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "又是岔路呢。",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_033"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也就是說……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有了，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「第二道測驗」。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這是",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "劍士的胸像……吧。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n什麼什麼……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「朝劍指的方向前進」，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "上頭是這麼寫的。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我好像在哪裡看過這個胸像……",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_034"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "原來如此原來如此。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n也就是說，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "正確答案是左邊。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呵呵，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您的表情像在說",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "妳為什麼會知道啊？",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這座雕像是",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_035"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在數百年前赫赫有名的",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "著名冒險家，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n留下來的紀錄有提到",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "他是個左撇子。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也就是說，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "他的劍會指向左邊。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不……",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_036"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我所知道的，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "都只是留在資料中的事情。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "沒有留下資料的事情，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我當然不知道。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "再說，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_037"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "只是擁有知識沒有用，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n活用智慧，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "才能漸漸轉為睿智，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "前人也曾說過這番話。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這番話用在這場測驗再貼切不過了。",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_038"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "好了，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們照這個步調",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "繼續前進吧！",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人之後也通過了數道的測驗，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n終於抵達洞窟最深處。"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "看來已經走到盡頭了呢。",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_039"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也就是說……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有了！",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n是訊息和寶箱！",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "「做得好。",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_040"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "吾會將寶藏",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "讓給抵達此處的冒險者。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "鍊金術師‧",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "霍拉弗基」",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也就是說……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "寶箱裡頭是",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "鍊金術秘傳書！",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "咦？",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_041"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "可以嗎？",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n沒有我在，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就無法抵達這裡？",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我覺得沒有這回事喔。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "況且，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_042"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這次的委託人是……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我想起來了……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是我。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不小心",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "出於平時的習慣……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我就收下這本秘傳書了。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我還想要稍微探索一下這個地方……",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_043"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呀啊！",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "謝謝您。",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_044"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "咦，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "嗯。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我沒事。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我只是腳步踉蹌了一下……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "呼啊啊……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不是，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_045"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "沒有這回事！",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我怎麼可能在這樣的冒險途中……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "雖然",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_046"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我很想這麼說……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "對不起。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "其實，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我有點睡眠不足……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我昨晚一直在進行事前調查，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_047"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n但調查到停不下來……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不小心熬夜了。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我、",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_048"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我並不是",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "因為",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "太過期待……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不對，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就算企圖蒙混也無濟於事。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我是因為太過興奮而睡不著覺。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "平時的話，包含健康管理在內，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_049"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我都會做好萬全準備，但……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我太過期待這場冒險，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_050"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有點興奮過頭了。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我就像個遠足前的小孩子一樣，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "實在太丟臉了。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您說的沒錯，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_051"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n非常抱歉，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "給您添麻煩……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "咦！？",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您怎麼了嗎？",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_052"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n突然蹲了下來。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您是不是哪裡受傷……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您、",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_053"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您說我背妳……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您要背我嗎？",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不必了，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "太不好意思了。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我累歸累，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "也不能讓您做到這個份上……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我一路上都受到了妳的幫忙，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_054"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這次換自己幫妳了，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是嗎？",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "的確，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "畢竟我不能不小心在這裡睡著……",
