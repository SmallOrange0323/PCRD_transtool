    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "沒、",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_057"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "沒事……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "沒什麼！",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您說妳就睡一下吧，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這樣……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "太不好意思了……",
