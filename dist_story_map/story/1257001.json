    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊。",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_058"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "對了，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我有一點要補充……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n回到城鎮……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "向公會管理協會",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_059"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "提交報告書之前……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "都是",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "冒險……",
