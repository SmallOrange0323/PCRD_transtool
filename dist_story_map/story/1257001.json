    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不愧是平時透過冒險所鍛鍊出來的身體。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "比我想像的來得結實，",
        "unit_id": 125711,
        "voice": "vo_adv_1257001_056"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
