        "name": "鈴莓",
        "words": "得、",
        "unit_id": 112111,
        "voice": "vo_adv_1121001_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "得快點收拾東西……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n啊、",
