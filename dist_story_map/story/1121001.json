    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呃，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不好意思還讓你幫忙！　",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "非常謝謝你。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……這身打扮嗎？　",
        "unit_id": 112111,
        "voice": "vo_adv_1121001_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "其實，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我目前正在神殿打工。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n打工時必須穿著巫女的正式服裝，",
        "unit_id": 112111
