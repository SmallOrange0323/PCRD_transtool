        "voice": "vo_adv_1121001_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是的！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "神殿的工作，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們一起好好加油吧。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦咦咦咦咦！？",
