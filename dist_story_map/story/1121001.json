    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以就借了這套衣服。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我才剛結束了神殿的跑腿工作，",
