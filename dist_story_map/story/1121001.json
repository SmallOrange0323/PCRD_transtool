        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "連我在旁邊看都覺得危險，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你好好陪在她身邊啦。",
