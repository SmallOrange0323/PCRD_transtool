    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "也許……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是這樣、",
