[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真對不起，少年。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n讓你久等了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我向職場……向【王宮騎士團】的據點，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n傳達了今天要請假的通知。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過由於要排隊等候通訊魔法，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此耗費了不少時間。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為我不會使用魔法，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這種時候就特別不方便呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "必須要逐一地與擁有會使用通訊魔法的術士",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n的公會進行交涉、辦理程序才行。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "直接走到王宮，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n向他們傳達聯絡事項還比較快。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就像照相機一樣……",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果有能邊走路，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n邊使用通訊魔法的道具的話，就方便多了",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是無論在技術上或是法律上，都很困難吧。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n由於通訊魔法的使用上有些規範，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n難以在一般大眾中流行起來",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "陛下的方針……",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n讓方便的技術或魔法，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n變得很難在民間普及化",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想，若能變得更加方便，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也會更易於人民生活吧……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "陛下應該有什麼深遠的想法吧，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有些不滿但也沒有辦法呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "話說回來。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n謝謝你陪我到這裡，少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為我一直都只是佇立在王宮前面，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以一直到現在，都還搞不太清楚城鎮的哪裡有些什麼呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "明明只是隨意說說，想要使用通訊魔法而已……",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不只走了相當遠的路，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也耗費了不少時間，我反省了一下。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "趕緊回到家後，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就要準備休息了喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在昨天的任務中所受的傷還沒有痊癒……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也沒有緊急的工作，想要安靜的休養。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那麼重新說一次。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n受你關照了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我不會忘記這份恩情的喔，少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你真的，是個溫柔的好孩子呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不會擺架子，也不會強加己見於人，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n能夠親切待人。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "能夠在不經意中表現出體貼，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這是非常棒的事情。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "該說我總是很粗魯嗎，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為我很粗枝大葉……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對於你的言行舉止感到欽佩，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n甚至覺得很羨慕。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也想像你一樣喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哎呀，不小心就喋喋不休了呢……",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總覺得和你很好聊天，總不自覺的變得很開心。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "和我在一起很無聊吧，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我就趕快告退了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只要我說出消極的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你就會馬上鼓勵我呢……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我覺得，你就是這點很討人喜歡喔。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……哇？",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為、為什麼抓住我的手？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有什麼話想說嗎……少年？",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦……",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n嗯，我是這麼打算的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有什麼問題嗎。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為我並不是那麼細心，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若有什麼奇怪的地方，希望你可以指出來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有什麼想說的，可以儘管告訴我，少年",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你說，就這樣分開很寂寞，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不一起去玩嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "剛好也這個時間了，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n至少一起吃個午飯……是嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這倒是沒問題呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也是，總覺得有點依依不捨。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只是我還受著傷，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n中的毒也還沒恢復……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不能太過勉強。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "若是要出遠門，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n或是進行激烈運動的話會有些困難。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "即使如此也沒關係嗎？",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼走吧，少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我對街上不太熟悉，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望你能為我導覽。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "能介紹你平常經常去遊玩的地方，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n或者是吃飯的地方給我就好了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不對。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我是想知道關於你的事情，少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然，不應該與你有所牽扯的……",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "一般來說，明明是該絕對服從上級命令的。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不知為何，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我對於要與你拉開距離的指令很反感啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好奇怪呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真不可思議。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我還是第一次有這樣的心情喔。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，雖說得有點晚，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但以這副樣子到處走動的話還真是顯眼呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "請了假又和比自己小的男孩子到處去玩～",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這件事，\n若是被同事知道，我就無法立足了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你說，首先要把頭盔跟鎧甲脫掉……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "找一家店，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n買些普通的衣服來換裝吧……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如此一來，\n誰都不會發現我是【王宮騎士團】的純？",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "話雖如此……",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我已經說過無數次，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我是不能被人看見真面目的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是我的家訓。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_050"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然也不是被看見真面目就非死不可的地步，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並不是這麼嚴厲的家訓。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但我從孩提時期開始，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_051"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就一直遵從著這個家訓。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "要違背它是很令人害怕的……",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_052"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n被一般地看見自己的真面目，感覺好害羞。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哇哇，不要硬脫！",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_053"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真強硬呢，少年……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "事情不照自己的預期進展，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_054"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而感到不滿嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是的。",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_055"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然你很聽話又坦率，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是換句話說……就像個孩子一樣啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "既然你都向我展現了任性的一面，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_056"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只有我自己裝成好孩子的模樣也不公平呢",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其實我也是，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_057"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像個隨處可見的普通女孩子般……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "想要無所遮掩，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_058"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n以原來的樣貌，和某人一起遊玩等等。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "被鎧甲及頭盔所遮掩，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_059"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n無法與任何人直接接觸……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不能深刻的與人相處，",
        "unit_id": 104711,
        "voice": "vo_adv_1047007_060"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是很寂寞的喔，少年。",
        "unit_id": 104711
    }
]