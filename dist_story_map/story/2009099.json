[
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊！",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你終於來了呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "等你很久了唷！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的……",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算有想跟你說的事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要和你接觸也必須在夢境中才行，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只能等你睡著，相當不方便呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過嘛，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這事先放一邊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也終究是正式和王宮敵對了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n畢竟是這麼緊張的時期……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然不太想讓你增添煩惱，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過遺憾的是又有新的問題發生了唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "吶……",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可愛的可可蘿啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天碰上了很糟的事了對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n被可惡的魔物重擊到了頭部，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "失去意識了呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子的傷勢明明都已經治療好了，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n卻沒有醒來的跡象，你不覺得很不可思議嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我當然也覺得很奇怪啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以就到處調查了一下呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "失去意識，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "換句話說就是沉睡著正在做夢的狀態的話……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在我瞭若指掌的夢境領域之中，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那孩子很有可能迷失了方向也說不定。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後呢，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我在許多的夢境裡仔～細的搜索過後……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n終於找到那孩子了唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子，應該說是",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那孩子的靈魂……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "或說意識？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也能說是那孩子的自我，你覺得現在在哪呢？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是在現實之中唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我這話的意思是，真正的現實……",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不是被身為『七冠』的千里真那所扭曲的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你們現在生活著的那個現實唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而是你們認為是夢境的那個，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "『真正的現實』唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不知道為什麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可可蘿似乎不小心闖到那邊去了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那並不是平時，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她所看到的夢境……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而是可可蘿她，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以可可蘿的身分，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不知怎地在現實中徬徨著呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "簡直就像只有她一人，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n從這個『遊戲的世界』中被解放了一樣……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "完全無法理解她是怎麼辦到的，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也是第一次遇到這種情況，所以也很訝異呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這和在前些日子，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可可蘿在我的神殿中參拜時，\n想要和我商量的",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "『那件事』之間有什麼關連嗎……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我也搞不太懂。",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但那孩子現在的動向，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "已經能從這邊確認了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我在現實中也有好幾個供我使用的頻道，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但就算跟你解釋你也聽不懂吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可可蘿她所在的，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n真正的現實的景色也可以稍微偷瞄一下唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也讓你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "稍微看看那些畫面吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "來吧，",
        "unit_id": 190011,
        "voice": "vo_adv_2009099_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "握起我的手……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然很短暫，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但要連接上真正的現實了唷。",
        "unit_id": 190011
    },
    {
        "type": "still",
        "still": "200909901"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……？",
        "unit_id": 105913,
        "voice": "vo_adv_2009099_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "　",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "什麼？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉比林斯達小姐？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是拉比林斯達小姐對吧？",
        "unit_id": 105913,
        "voice": "vo_adv_2009099_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是祕密社團【拉比林斯】的首領？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2009099_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在【拉比林斯】的據點有見過您沉睡時的容貌！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然和那時相比，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "服裝似乎稍微不同的樣子……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯。",
        "unit_id": 106832,
        "voice": "vo_adv_2009099_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這個嘛，妳想問的事情應該還有不少吧。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "話又說回來，我想問妳的事情也是有一大堆就是了呢。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但比起那些事，",
        "unit_id": 106832,
        "voice": "vo_adv_2009099_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "總之現在要不要吃點可麗餅呀？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n根本都賣不出去啊，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n事先準備的大量食材剩下一大堆，都快要壞光了呢♪",
        "unit_id": 106832
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊、",
        "unit_id": 105913,
        "voice": "vo_adv_2009099_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正好肚子有一些餓了，在下就恭敬不如從命了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105913,
        "voice": "vo_adv_2009099_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但這是夢境，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼會感到肚子餓呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也有這樣子的夢嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不是夢境唷，",
        "unit_id": 106832,
        "voice": "vo_adv_2009099_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡是現實。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所以當然會肚子餓囉。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊啊，對了對了……",
        "unit_id": 106832,
        "voice": "vo_adv_2009099_028"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "因為這裡是現實，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n所以叫我的時候，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n別用『拉比林斯達』了，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "叫我『模索路晶』吧。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那是我在現實中的名字唷。",
        "unit_id": 106832,
        "voice": "vo_adv_2009099_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2009099_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "模索路……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "小姐？\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是個奇怪的名字呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也是啦，",
        "unit_id": 106832,
        "voice": "vo_adv_2009099_031"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在那邊的世界是很少見的名字吧。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n是摸索著道路的意思，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "聽起來有點迷宮的感覺吧？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以我呀，還被人家叫成什麼『迷宮女王』呢～♪",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "妳的話，本名是叫",
        "unit_id": 106832,
        "voice": "vo_adv_2009099_032"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "『棗 可蘿』對吧？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "妳的父親，\n在很～久以前就非常關照我了呢～……",
        "unit_id": 106832,
        "voice": "vo_adv_2009099_033"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n應該就是俗稱的恩師吧？",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也因為這樣，",
        "unit_id": 106832,
        "voice": "vo_adv_2009099_034"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我才會出手幫妳呢。",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n算是回報從小受妳父親關照的恩唷，",
        "unit_id": 106832
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "可可蘿♪",
        "unit_id": 106832
    }
