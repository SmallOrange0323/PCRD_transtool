[
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "在沙漠的夜晚，",
        "unit_id": 127611,
        "voice": "vo_adv_5128204_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可以清楚地看到星星與月亮呢。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊，",
        "unit_id": 127511,
        "voice": "vo_adv_5128204_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果這是在夜裡散步，",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就會很浪漫美好了呢……",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "哈立德",
        "words": "──────！！",
        "unit_id": 17811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "發光了！",
        "unit_id": 127611,
        "voice": "vo_adv_5128204_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "敵人就在那個方向啊。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "居然主動洩漏自己的所在位置，",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "讓我們省去找它的工夫了。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是，",
        "unit_id": 127511,
        "voice": "vo_adv_5128204_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那是魔力匯集的光芒吧？",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果它又射出那道光線，",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會造成重大損害的……！",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "得在那之前決勝負才行──",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "動作快！",
        "unit_id": 127511
    }
]