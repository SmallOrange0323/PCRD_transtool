[
    {
        "type": "background",
        "background": "500750"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長～……",
        "unit_id": 110911,
        "voice": "vo_adv_6038109_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "小墨丘利的資金援助，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們都拿不到了啦……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "企劃本身明明就很好，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是簡報太難了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長你也試試看吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請你介紹一下自己的優點。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你有……",
        "unit_id": 110911,
        "voice": "vo_adv_6038109_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "很強嗎？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你是說精神面嗎？　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "如果是這樣的話，嗯。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n當我們幾個準備要換衣服的時候，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你也一樣站在那裡發呆，\n完全沒有打算要走出教室，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這點真的讓我有種「真強！」的感覺。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊～",
        "unit_id": 110911,
        "voice": "vo_adv_6038109_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "「溫柔」不錯呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "像是很強、很聰明，或是很擅長做某件事之類的，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n都必須要有天賦或付出努力，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但是只有溫柔這一點就不需要。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不管是誰，只要在自稱溫柔的瞬間就能獲得，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為它實質上就是「無」嘛！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "太謙虛了！　",
        "unit_id": 110911,
        "voice": "vo_adv_6038109_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "原來如此，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這種虛懷若谷的地方，的確是學長的優點。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真是有這種人呢，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "世人給他的評價明明只有40～50分，\n但不知為何卻一臉自己有85分的人。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長這樣的自我認同感剛剛好。",
        "unit_id": 110911
    }
]