    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過……",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "確實是這樣呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n與其因為害怕而裹足不前，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不如朝向幸福的方向努力奔跑。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果是現在的我，",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就算抱著你感覺也能逃得掉",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n……之類的。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "唔……",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好像……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "有點玩過頭了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n總覺得……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好刺眼……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "睡意……",
        "unit_id": 138812
    },
    {
        "type": "background",
        "background": "510260"
    },
    {
        "type": "dialogue",
        "name": "栞",
