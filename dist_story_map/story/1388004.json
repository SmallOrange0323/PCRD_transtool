    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你說的話好有趣喔。",
        "unit_id": 138812
