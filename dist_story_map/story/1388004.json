    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在墨丘利度假村停留的最後一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n從大會開始到後續的休假，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n栞他們回顧了一起度過的這幾天的時光。"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "時間過得好快呢……",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "參加大會的時候很拚命，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "休假時則是像夢一般……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n回過神的時候，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就已經是最後一天了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}，真的很謝謝你。",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一直陪伴在我身邊。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "託你的福……",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這次休假，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我真的過得非常非常開心。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的是可以",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這麼開心的嗎……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不，",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不是這樣的。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這段時間，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "身體的狀況很好，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還挑戰了很多事物。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n保持健康活力……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這種事，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我之前一直都覺得與我無緣呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很開心，",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "太開心了……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "以至於",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我有時候會突然感到害怕。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "想說這麼幸福真的是可以的嗎，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或是會不會受到上天懲罰",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "之類的。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是啊……",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的♪",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "既然{player}都這麼說了……",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n那我也會覺得，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這樣",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就好。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊一定也……",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "大家也一定",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "都會這麼說的對吧。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為我覺得",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_008"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那樣的話，大家才會一同歡笑。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想變得幸福。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不只是我，",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還有大家都是。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n變得更加",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "更加幸福。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦，",
        "unit_id": 138812,
        "voice": "vo_adv_1388004_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那是……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "什麼意思？",
        "unit_id": 138812
