        "words": "很抱歉，還讓你特地跑這一趟。",
        "unit_id": 103832,
        "voice": "vo_adv_1388004_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "聽說",
