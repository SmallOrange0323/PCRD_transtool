        "voice": "vo_adv_1388004_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103832
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你的關心。",
