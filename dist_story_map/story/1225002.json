[
    {
        "type": "background",
        "background": "501610"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜與{player}一邊在海邊散步，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊討論接下來要怎麼度過假期。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼……",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想想。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天該來做什麼呢？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然我說了想用",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "最有我風格的方法度假……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但就是因為想不到才會去依賴導覽手冊。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為像這樣來到了南島，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我想做些只能在這裡做的事情。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這麼一來……",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "果然是釣魚吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒這回事。",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一旦釣場改變，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "魚和喜歡的餌也會改變。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或許也能遇上只有在南島",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "才有的獵物。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "除了釣魚之外，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想到的還有",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "鍛鍊吧？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在海灘上的訓練",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能很有效率地鍛鍊腿跟腰。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "更有度假感的事……",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也對。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我現在的目標",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是尋找這種事。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "最有我風格的……",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話雖如此，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也不能過得跟平時一樣……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "試著思考後意外地想不到呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喔，",
        "unit_id": 312,
        "voice": "vo_adv_1225002_008"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那邊那位姐姐。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n妳看起來實力相當堅強呢！",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "有興趣的話，",
        "unit_id": 312,
        "voice": "vo_adv_1225002_009"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "要不要參加我們辦的活動啊？",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n這是介紹用的傳單。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我們歡迎強者喔。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "「水上劍鬥」……？",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在海上打鬥，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "類似模擬戰的活動嗎？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我看看……",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不能自行攜帶武器，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會使用主辦單位所準備，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n以特殊柔軟素材製作的模擬劍對戰……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "沒錯。",
        "unit_id": 312,
        "voice": "vo_adv_1225002_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "雖然花了不少時間在準備會場，",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但總算是完成了。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n也已經得到度假村給的舉辦許可。",
        "unit_id": 312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我說，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "{player}。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你說好要陪我一起尋找",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "最有我風格的度假方法對吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你應該懂我想說什麼吧……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "夏天的海洋與劍術……",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你不覺得這正是以我為對象的度假方法嗎？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就立刻去報名吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "櫃台是在對面吧。",
        "unit_id": 122511
    },
    {
        "type": "background",
        "background": "500163"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那就是要戰鬥的場所啊。",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n竟然讓那麼正式的舞台漂浮在海上，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n看來是相當盛大的大會呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嘿……",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咻。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "熱身運動差不多就做到這樣吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n大會差不多要開始了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我過去了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "讓各位",
        "unit_id": 1,
        "voice": "vo_adv_1225002_019"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "久等了！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n豔陽、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "藍海，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "以及在海上競爭的夏季霸者！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n水上劍鬥大會……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "現在正式開始！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "首先從",
        "unit_id": 1,
        "voice": "vo_adv_1225002_020"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "A組的第一回合開始進行。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n請參賽者前往海上浮島，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "特設領域上面！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "竟然在第一回合的",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "第一場比賽就出場啊……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的運氣到底該算好還是不好啊。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "地板因為海浪搖晃不安定，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n而且",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "兩名對戰者在搶位時重心會變動，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n平衡也會持續不斷改變……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再加上",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種玩具劍……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "軟趴趴又會彎曲，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n無法用跟平常一樣的方法揮劍呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若是全力揮擊，被打到會相當疼痛吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊哈～♪",
        "unit_id": 1212,
        "voice": "vo_adv_1225002_024"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "大家要幫我加油喔～♪",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她就是我的比賽對手嗎。",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖說對手的能力也是未知數，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但總之先看看狀況吧。",
        "unit_id": 122511
    },
    {
        "type": "still",
        "still": "122500201"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "受到以模擬劍揮出的有效打擊，",
        "unit_id": 1,
        "voice": "vo_adv_1225002_026"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n或者跌落海中時就算淘汰。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "那麼第一回合，",
        "unit_id": 1,
        "voice": "vo_adv_1225002_027"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "現在開始！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說是參賽者，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但大部分都不是冒險者和參與公會活動的人吧，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n還是別讓對方太痛──",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那麼，",
        "unit_id": 1212,
        "voice": "vo_adv_1225002_029"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我要上囉～？",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "哈！！",
        "unit_id": 1212
    },
    {
        "type": "still",
        "still": "122500202"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔！",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好快！？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是何等",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "銳利的突擊啊！！　",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔……",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還太嫩了！！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "哎呀～？",
        "unit_id": 1212,
        "voice": "vo_adv_1225002_032"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這位姐姐，",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "妳意外地厲害呢～♪",
        "unit_id": 1212
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那是我要說的台詞……",
        "unit_id": 122511,
