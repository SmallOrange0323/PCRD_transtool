        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還太嫩了！！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "喔喔────！",
        "unit_id": 1,
        "voice": "vo_adv_1225002_066"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n怜選手",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "使出怒濤般的連擊────！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "確實擋下我的攻勢，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_067"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還抓住破綻反擊。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他是什麼時候成長到這種程度的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好快樂……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想繼續確認他的實力！　",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這場戰鬥可不能只注意對手。",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_068"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──還得注意腳邊的",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "狀況才行喔！！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "怜選手",
        "unit_id": 1,
        "voice": "vo_adv_1225002_069"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "用力踩踏場地，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n打算連同舞台讓對手失去平衡！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你的確是變強了。",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_070"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "近身戰的話對我有利。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不好意思這場比賽就由我取勝了！　",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "怜選手",
        "unit_id": 1,
        "voice": "vo_adv_1225002_071"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "使出強力一踏，打算一決勝負──！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在就是取勝良機！！",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_072"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就在這裡",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "拿下──！？",
        "unit_id": 122511
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "122500202"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼……！",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_073"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "場地",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "裂開了……！！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "至今為止的戰鬥中所累計的傷害，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_074"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n讓浮島無法再承受衝擊了嗎……！？　",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_075"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的姿勢……！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不行，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "撐不下去……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要落海了……！！　",
        "unit_id": 122511
    },
    {
        "type": "background",
        "background": "500163"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦！？",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_076"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為什麼往這邊跳下來啊……！？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了要救我？",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_077"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如今正在進行決賽喔。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n竟然眼睜睜捨棄獲勝機會……！　",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_078"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比起這個……！　",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你不會游泳吧！？",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_079"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……噗哈！！",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_080"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼、",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_081"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好了，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這邊的話就能踩到地面了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話說回來，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_082"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明不會游泳卻跳下來……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你到底",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在想什麼啊！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我知道你是打算要幫我，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_083"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但是更該優先考慮自己的安全吧？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算等確定勝敗後",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_084"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再來救我也來得及啊。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n而且",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只要抓住浮島的碎片，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就能有不致於溺水的浮力了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "至今為止",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_085"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有很多參賽者都有落海，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他應該知道就算自己不出手，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n大會的主辦單位",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也會派人來救才對。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話雖如此……",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_086"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他肯定",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是在思考前身體就先動起來了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該說他真的是個",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "濫好人嗎……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……聽好囉？",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_087"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就跟你會想要救我一樣，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n對我來說",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也是很重要的人。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "非常重要。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以我不希望你遭遇危險，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "希望你能記好這點。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_088"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒事了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比起比賽，你選擇試著來救我的心意……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n讓我現在覺得非常高興。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比賽的結果……",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_089"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雙方平手嗎。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n畢竟關鍵的舞台變成那等慘況，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就算想再比一場也辦不到吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "身為你的劍術師傅，",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_090"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我原本想在這裡拿下勝利保持威嚴的……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這下只好找別的機會表現了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "因為",
        "unit_id": 122511,
        "voice": "vo_adv_1225002_091"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這場假期才剛要開始啊。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n還有機會再跟你一決勝負的。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明天來比賽釣魚吧？",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看著露出笑容的怜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}也跟她約好之後會找機會再戰。"
