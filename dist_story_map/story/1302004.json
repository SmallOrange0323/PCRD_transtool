    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n難不成，",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "是為了不讓我受傷",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "而手下留情了？",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "咿嘻嘻，",
        "unit_id": 130231,
        "voice": "vo_adv_1302004_052"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "真可惜～ｗ",
