    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "呀哈哈哈♡",
        "unit_id": 130231,
        "voice": "vo_adv_1302004_035"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n居然被女孩子輕易壓制，",
