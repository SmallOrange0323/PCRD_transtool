    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "咦～？",
        "unit_id": 130231,
        "voice": "vo_adv_1302004_038"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n就想說要讓願意聽我任性的哥哥～",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n在特等席看著",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "我吃甜點的樣子♡",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "不過",
        "unit_id": 130231,
        "voice": "vo_adv_1302004_039"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "變成座位的是哥哥就是了♡",
