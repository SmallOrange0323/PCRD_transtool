    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "我這樣，我力氣很大的～♡",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n擺弄機器",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "會有很重的零件，",
