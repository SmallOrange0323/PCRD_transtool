        "voice": "vo_adv_1302004_051"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n你、",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "你以為這樣就能挪開我了嗎？",
