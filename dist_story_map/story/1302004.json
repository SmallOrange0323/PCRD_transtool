    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "如何？",
        "unit_id": 130231,
        "voice": "vo_adv_1302004_047"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n好吃嗎？♡",
