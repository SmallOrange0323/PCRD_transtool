    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n啊，",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "難不成是因為我騎在你身上，覺得很開心？",
