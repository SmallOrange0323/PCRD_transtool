    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n畢竟這原本就是哥哥的嘛，",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n要是你能做出討喜的要求，",
