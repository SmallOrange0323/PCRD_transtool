        "voice": "vo_adv_1302004_040"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "視野真好♡",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n一邊俯視雜碎哥哥，一邊吃甜點",
