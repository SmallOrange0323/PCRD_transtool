        "voice": "vo_adv_1302004_044"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "不用客氣啊～",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n就憑哥哥跟我的關係，",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "雖然我也不懂是什麼關係啦♡",
