    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n雜碎至極又變態的哥哥",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n被關到牢裡，",
