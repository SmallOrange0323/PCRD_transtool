    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "哥哥真是變態呢～♡",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n果然還是叫警察先生來會比較好吧～？",
