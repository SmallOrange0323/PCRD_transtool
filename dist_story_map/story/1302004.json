    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "有破綻！",
        "unit_id": 130231,
        "voice": "vo_adv_1302004_034"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n布武機擒抱，",
