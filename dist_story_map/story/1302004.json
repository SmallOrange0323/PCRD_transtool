    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "那麼～",
        "unit_id": 130231,
        "voice": "vo_adv_1302004_045"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "我就把冰融化的部分",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n一點一點滴到",
