    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "還要搬工具喔～",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "唔……",
        "unit_id": 130231,
        "voice": "vo_adv_1302004_053"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n就說、",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "沒用的～啦ｗ",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n雜碎哥哥從今以後，",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "一輩子都是我的椅子了ｗ",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "啊、",
        "unit_id": 130231,
        "voice": "vo_adv_1302004_054"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "哇、",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "等、",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "等等……！",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n不要亂動～！",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n會掉下去，",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "冰會掉下去啦～！",
