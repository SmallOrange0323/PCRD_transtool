    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "欸～？",
        "unit_id": 193211,
        "voice": "vo_adv_1302004_057"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n我說你，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "不要緊吧？",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "你問什麼，",
        "unit_id": 193211,
        "voice": "vo_adv_1302004_058"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "喏，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "就剛剛的夢。",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "按照慣例，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "我為現實中互不認識的你們，",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "\n安排煞有其事的相遇……",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "那個名叫布武機的女孩，",
        "unit_id": 193211,
        "voice": "vo_adv_1302004_059"
    },
    {
        "type": "dialogue",
        "name": "媞雅",
        "words": "再怎麼樣也太過分了吧～",
        "unit_id": 193211
    },
    {
        "type": "dialogue",
