    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "咿嘻♡",
        "unit_id": 130231,
        "voice": "vo_adv_1302004_042"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n這麼坦率很棒喔♡",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "真拿你沒辦法～♡",
        "unit_id": 130231,
        "voice": "vo_adv_1302004_043"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n那麼～",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "我就把冰融化的地方",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n一點一點滴到",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "哥哥的嘴裡吧♡",
        "unit_id": 130231
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "吼～",
