        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說是【伊麗莎白牧場】被愛著，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不如說是真陽受到大家的喜愛呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "必須先從這件事開始做起呢。",
        "unit_id": 112711,
        "voice": "vo_adv_6040206_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n得拿回牧場，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "然後給他們超乎期待的回報才行。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果是為了達成這個目的，我也會加油的。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "能給的回報",
        "unit_id": 112711,
        "voice": "vo_adv_6040206_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "果然還是乳製品之類的吧。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真陽會很忙呢。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "看來在回報完恩情之前，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n連我也得工作了吧。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "唉……",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "到底什麼時候才能回到原本的日常生活呀。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是啊。",
        "unit_id": 112711,
        "voice": "vo_adv_6040206_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "拿回牧場跟牛群之後",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就能向大家報恩……",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呃，",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "先等一下。",
        "unit_id": 112711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "拿回牧場之後我可不工作喔？",
        "unit_id": 112711
