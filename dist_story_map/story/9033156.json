[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼哼～",
        "unit_id": 106011,
        "voice": "vo_adv_9033156_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的作戰不錯吧！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大成功對吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": " \n果然打從一開始就該往多個方向攻擊的！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105911,
        "voice": "vo_adv_9033156_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿怎麼了嗎？　",
        "unit_id": 105811,
        "voice": "vo_adv_9033156_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼一臉不可思議的神情……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有，在下只是在想，",
        "unit_id": 105911,
        "voice": "vo_adv_9033156_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "與其以知識去思考策畫，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n某些時候",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "採取大膽的行動反而更為上策……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n又學到",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "寶貴的一課了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "天啊，",
        "unit_id": 106011,
        "voice": "vo_adv_9033156_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也太正經八百了吧！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "明明還是個孩子卻活得這麼辛苦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……稍微戲弄她一下好了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？ ",
        "unit_id": 106011,
        "voice": "vo_adv_9033156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剛才森林裡好像有什麼在動喔？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道說",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有另外一隻嗎？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……開玩笑的啦。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！！　",
        "unit_id": 105911,
        "voice": "vo_adv_9033156_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "飯糰請讓在下借用一下。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": " \n這次就由在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身先士卒！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "另一隻小偷先生！　",
        "unit_id": 105911,
        "voice": "vo_adv_9033156_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "光明正大地",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "出來一決勝負吧！ ",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀啊啊啊啊啊～！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯嗯，",
        "unit_id": 105911,
        "voice": "vo_adv_9033156_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "跑到哪裡去了？　",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這裡嗎！　",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘿！嘿！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還是這裡！　",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘿呀—！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "第二隻嗎！？　",
        "unit_id": 105811,
        "voice": "vo_adv_9033156_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "順利解決的話就不只火鍋，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n連鐵板和香煎也不成問題了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "等等我小可蘿，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也一起來！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給、",
        "unit_id": 106011,
        "voice": "vo_adv_9033156_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我等一下！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我看錯了！　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看‧錯‧了‧啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以說妳們兩個快點回來啦—！",
        "unit_id": 106011
    }
]