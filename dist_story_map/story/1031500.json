[
    {
        "type": "background",
        "background": "509010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你終於來了，{player}。",
        "unit_id": 103112,
        "voice": "vo_adv_1031500_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "很抱歉遲到了？",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不用在意，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我也花了點時間說服爸爸，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n要他安靜地在家待著。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這下子",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們就能靜下來慢慢談了。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "送給我的？",
        "unit_id": 103112,
        "voice": "vo_adv_1031500_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "難道是",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "慶祝生日的禮物嗎？",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我可以打開看看嗎？",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "原來是",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "塔羅牌嗎。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嘻嘻，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "上頭的圖案真可愛……",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然",
        "unit_id": 103112,
        "voice": "vo_adv_1031500_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "平常很少用這類不習慣的道具來占卜，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n不過這樣一來隨手都能占卜，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一目了然的結果",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "也讓人樂在其中呢。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你的禮物。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "之後",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我會幫公會的大家",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "用它來占卜看看。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這該不會是",
        "unit_id": 103112,
        "voice": "vo_adv_1031500_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "慶祝生日的禮物吧？",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是那本很有名的恐怖小說呢。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n不過因為有些年代了，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因此我不曾讀過。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你的禮物。",
        "unit_id": 103112,
        "voice": "vo_adv_1031500_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "若是不介意的話我們一起讀吧？",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不敢看？",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "沒關係的，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我跟",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其他許多夥伴都會一起陪你。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "新、",
        "unit_id": 103112,
        "voice": "vo_adv_1031500_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "新爸爸？",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是……",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "骷髏頭鑰匙圈？",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這麼說來，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "今天好像是我的生日。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你的禮物。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過這個骷髏頭",
        "unit_id": 103112,
        "voice": "vo_adv_1031500_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不但小巧，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "動起來也可愛又逗趣呢。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要是也能像它一樣可愛就好了。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "啊，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "剛剛的話",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請不要告訴我爸爸喔。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "其實",
        "unit_id": 103112,
        "voice": "vo_adv_1031500_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "今天占卜時就已經算出，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "本日會是個好日子。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只是沒想到",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "竟然是這麼令人開心的事。",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我會珍藏這段回憶，",
        "unit_id": 103112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "將它帶進自己墳墓裡頭。",
        "unit_id": 103112
    }
]