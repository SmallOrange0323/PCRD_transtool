    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "魔法學園。",
        "unit_id": 126112,
        "voice": "vo_adv_9008008_000"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n學生，",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "招生中。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我補充一下。",
        "unit_id": 106012,
        "voice": "vo_adv_9008008_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "現在在",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這場公開錄音中，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n有安魔學……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "安布羅斯魔法學園的同學們來參觀。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以我們才特別地",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "替安魔學宣傳。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然有笨蛋",
        "unit_id": 106012,
        "voice": "vo_adv_9008008_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和沒什麼魔力的傢伙，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也有好人和讓人討厭的傢伙，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但那是一所很有趣的學校喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n原以為班導",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是個狂戰士，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "結果他也是名真正的魔法師呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果有",
        "unit_id": 106012,
        "voice": "vo_adv_9008008_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想要享受青春的人，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "去看看也不錯吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n聽說連制服都能選擇喜歡的款式喔♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "凱留，",
        "unit_id": 100111,
        "voice": "vo_adv_9008008_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳去上學了嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真好～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也想了解，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也想了解～♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "學生餐廳。",
        "unit_id": 126112,
        "voice": "vo_adv_9008008_005"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n我想去。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂！",
        "unit_id": 106012,
        "voice": "vo_adv_9008008_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別問我腳本上沒寫的問題！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咳咳……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過的確，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我過得很開心喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然也發生過突然有魔物跑出來的事，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但也留下了很多美好回憶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是這樣啊？",
        "unit_id": 100111,
        "voice": "vo_adv_9008008_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "最開心的回憶是什麼？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "印象最深刻的回憶是，",
        "unit_id": 106012,
        "voice": "vo_adv_9008008_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n和這傢伙一起去的",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "制服約會……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……這種事我怎麼說得出口啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "笨蛋！　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大、",
        "unit_id": 106012,
        "voice": "vo_adv_9008008_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大概是畢業旅行吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能與大家一起去大江戶，真的很開心喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "畢業旅行～",
        "unit_id": 100111,
        "voice": "vo_adv_9008008_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "聽起來好棒喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有呢～？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～",
        "unit_id": 106012,
        "voice": "vo_adv_9008008_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "其他還有……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n和鈴奈她們一起過夜之類的？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n本來打算開讀書會，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "結果幾乎變成是睡衣派對了呢～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和朋友一起過夜……♪",
        "unit_id": 100111,
        "voice": "vo_adv_9008008_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "光是聽了就讓人好雀躍喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……是啊。",
        "unit_id": 106012,
        "voice": "vo_adv_9008008_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然當時每天都吵吵鬧鬧的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但現在回想起來都是很美好的回憶呢……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呵呵。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "……凱留。",
        "unit_id": 126112,
        "voice": "vo_adv_9008008_014"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "讀書。",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_9008008_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "讀書……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126112,
        "voice": "vo_adv_9008008_016"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "……妳沒有，",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "讀書嗎？",
        "unit_id": 126112
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼！",
        "unit_id": 106012,
        "voice": "vo_adv_9008008_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我有讀啊！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我有認真讀書充實自己！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n因為我可是學院首席嘛！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈……",
        "unit_id": 100111,
        "voice": "vo_adv_9008008_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "盡情玩耍的青春，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也是「學生時代」",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "的一種嘛……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳、",
        "unit_id": 106012,
        "voice": "vo_adv_9008008_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳不用勉勵我啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我可是真的有在讀書喔～～～！？",
        "unit_id": 106012
    }
]