        "type": "dialogue",
        "name": "可可蘿",
        "words": "直到剛才，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明還是賭上性命也絲毫沒有勝算的強敵呀。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你這是做了什麼好事啊，",
        "unit_id": 104712,
        "voice": "vo_adv_2011005_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年！",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真過份！　",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "頭盔，",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還給我……！",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "臉、",
        "unit_id": 104712,
        "voice": "vo_adv_2011005_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "臉要是被人給看到了，我、",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我？",
        "unit_id": 104712
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦？",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人他邊道著歉",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "邊朝著純小姐撞過去了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呀，",
        "unit_id": 104712,
        "voice": "vo_adv_2011005_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哇呀啊啊啊啊啊！？",
        "unit_id": 104712
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔哇……",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "純小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "失足朝著樓梯的下方跌落了呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n她、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她應該沒事吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……。",
        "unit_id": 104712,
        "voice": "vo_adv_2011005_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來是完全昏過去了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由於主人與純小姐早已熟識的緣故，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此也就知悉對方的弱點了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "靈機一動，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "完全逆轉局勢了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是高招呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍微有些卑鄙就是了……♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您這作戰真是太漂亮了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過呢，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎也不是能歡慶這場勝利的時機呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管略有失禮，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下這就去調查看看純小姐是否持有著牢房的鑰匙。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "再將",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐救出，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接著馬上撤退吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如同純小姐說的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從上頭",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "傳來了大量的腳步聲。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然沒像純小姐",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那般強悍。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就算只是一般的警備兵，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果被團團包圍",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就沒戲唱了吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的根據是？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣、",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n才心想主人您，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎比在下預料中的還更快醒了過來呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來是某位人物，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在主人暈厥時",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "出手相救的樣子呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而那位人物在",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【王宮騎士團】之中，\n有著相當程度的地位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n當場號令匆忙趕來的部下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓他們遠離此處嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實照您這麼說，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那大量的腳步聲",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "逐漸遠離了呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這真是不可思議。",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟是哪位人物，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又是為了什麼呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說是【王宮騎士團】內",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的人物呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難不成是曾與在下等人交流過的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "智小姐與",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "茉莉小姐嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過。",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算是那兩位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也和純小姐一樣，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有被洗腦的可能性……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不應該會對在下等人伸出援手才對，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是這樣想的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且沒記錯的話，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她們兩位",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎並沒有能稱得上多高的地位才是？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為並非顯赫的家世，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以無法進到『王宮』裡……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是這樣？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位似似花小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽說擁有變身的能力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是她",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "幻化成了【王宮騎士團】中有權勢的人……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來出手相救的嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管那位也是遭囚禁之身，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但似乎",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能以分身來行動對吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……雖然遺留下了不少疑問，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但推測還是留到事後吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在純小姐身上搜出鑰匙了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此一來",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便能夠打開",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "地下監獄的鎖了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在立刻就救您出來，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_055"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐……♪",
        "unit_id": 105911
    }
]