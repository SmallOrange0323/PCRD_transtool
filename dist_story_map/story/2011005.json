    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "地下監獄的入口……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n站在純小姐身後的",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個是主人！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您確實醒過來了呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "太好了♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦呀？　",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人他，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎有什麼打算……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "究竟",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想做什麼？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔嗯？　",
        "unit_id": 104711,
        "voice": "vo_adv_2011005_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這個光芒……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n{player}少年，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你使用了那個能力嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過。",
        "unit_id": 104711,
        "voice": "vo_adv_2011005_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你們的戰力已經是窮途末路了唷，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n再怎麼強化都是沒有意義的！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n只靠我一人，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就足夠對付你們了！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是。",
        "unit_id": 104711,
        "voice": "vo_adv_2011005_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "如果不管再怎麼下手，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還是能夠因為強化而起身反抗的話，那就麻煩了……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這次，會改用暫時醒不來的力道，",
        "unit_id": 104711,
        "voice": "vo_adv_2011005_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n將{player}少年給徹底揍暈！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "危險！　",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請您快逃啊！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n想要對主人出手的話，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先過在下這一關！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咕嗚嗚？　",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然如此，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n只能拼死抱住純小姐的腿，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拖延時間了嗎……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "於此期間，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只能冀望主人能夠順利逃出重圍了！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但依主人的個性，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要丟下在下等人自己一個人逃亡，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是不可能的……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果是現在被主人強化的狀態，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n捨身向純小姐突擊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許有機會讓她失去平衡而露出破綻？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就趁那個機會，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人再將純小姐給擊倒……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n並沒有被主人以往",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所釋放的光芒給籠罩……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就是說",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人他的能力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有強化到在下的身上。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "腳力也",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有任何被強化的跡象，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就連那正衝向主人的純小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也追不上！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為、",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為何？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人的能力，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "施放失敗了嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "{player}少年！",
        "unit_id": 104711,
        "voice": "vo_adv_2011005_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖和你無冤無仇，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但請為了正義倒下吧！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……咦、",
        "unit_id": 104711,
        "voice": "vo_adv_2011005_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n哇呀啊！？",
        "unit_id": 104711
    },
    {
        "type": "still",
        "still": "201100501"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n純小姐她，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以驚人之勢衝上了樓梯……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n直直",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "往走廊上的牆上一頭撞下去了耶？",
        "unit_id": 105911
