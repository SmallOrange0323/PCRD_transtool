    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這也太戲劇化了……",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為、",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n純小姐感覺應該是受過訓練，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n歷戰的強者才是呀？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為何，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會有這種冒失的……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呀哈哈，",
        "unit_id": 105813,
        "voice": "vo_adv_2011005_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此呀。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "竟然想到了這招呢，{player}。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}他呀，\n強化了那個穿鎧甲的人唷。",
        "unit_id": 105813,
        "voice": "vo_adv_2011005_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後因為腳力突然被強化，",
        "unit_id": 105813,
        "voice": "vo_adv_2011005_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而用上比預料之中更強的力量蹬向了地面……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最後因為停不下來，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以才往牆上撞了下去呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊……",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若是如此就能理解了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟純小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也與主人有所相識嘛。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以主人的角度來看，當然也為夥伴的一人，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也因此",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在能力所能適用的範圍之內。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絞盡腦汁，",
        "unit_id": 105911,
        "voice": "vo_adv_2011005_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "最終巧妙地使用了自身的能力呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真是令人欣慰的成長呢",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您做得太棒了♪",
        "unit_id": 105911
    },
