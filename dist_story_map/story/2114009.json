        "words": "我、",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_031"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我剛剛……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我是暈過去",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "了嗎……？　",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對了……",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_032"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "剛剛……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n有一座外觀就像超大黑薔薇的建築物",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "突然出現在旁邊，",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "然後撞上了",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "索爾之塔……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "當時我正使盡全力和哥哥對戰，",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_033"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n實在沒有餘力閃避，",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就這樣一起受到撞擊……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_034"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這裡是……",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_035"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "看來並不是",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "索爾之塔。",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那麼，",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是在那個撞上來的黑薔薇裡面嗎……？",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n看來是從上面那個縫隙",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "掉進來的……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……這個建築物裡",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_036"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "圍繞著大量的魔力……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "而且",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "非常濃厚……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "又帶著悲傷。",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這是……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個該不會是",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "來自厄莉絲的……？　",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……咕……",
        "unit_id": 191713,
        "voice": "vo_adv_2114009_037"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "！",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_038"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n哥哥……！",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "──嘎啊！！",
        "unit_id": 191713,
        "voice": "vo_adv_2114009_039"
    },
    {
        "type": "background",
        "background": "501621"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唔！！",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_040"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "剛剛那陣衝擊",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_041"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說不定可以讓哥哥恢復正常──",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n有那麼一瞬間，",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我還這麼期待的。",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n看來當然不會有",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼好的事……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_042"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為什麼？",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n他明明可以趁我昏過去的時候",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "給我最後一擊的才對。",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "難道……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他一直",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在等我醒來嗎……？　",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他真的是……",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_043"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n在這個方面",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就是這麼講規矩……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "嘎喔喔喔──！！！",
        "unit_id": 191713,
        "voice": "vo_adv_2114009_044"
    },
    {
        "type": "background",
        "background": "501621"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "唔唔…",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_045"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…！",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我的體力",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_046"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還沒從剛剛的衝擊中恢復……！　",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個傷勢",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_047"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不知道還能保持清醒多久，",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "現在沒有那個時間",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "慢慢用寒氣削弱他的體力……",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……既然如此，",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_048"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那我就只剩一個選擇──",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "把所有的一切",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "賭在這一擊上！",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "咕、",
        "unit_id": 191713,
        "voice": "vo_adv_2114009_049"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "咕咕……",
        "unit_id": 191713
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我要出招了，",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_050"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "哥哥！",
        "unit_id": 106416
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "咕喔嘎啊啊啊啊啊啊！！！",
        "unit_id": 191713,
        "voice": "vo_adv_2114009_051"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──冰牙龍咬！！！",
        "unit_id": 106416,
        "voice": "vo_adv_2114009_052"
    },
    {
        "type": "background",
        "background": "500273"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一方面──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在可可蘿一行人離開後的索爾之塔內。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "厄莉絲試圖藉由自身體內融合的米奈娃，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n以及來自「漆黑薔薇城」的侵蝕，\n重新奪回對塔的控制力。"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_053"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "D型末端裝置的氣息……",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_054"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不見了……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "消失了嗎？",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_055"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n抑或是，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "擺脫了我的掌控？",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n……無所謂，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "枝微末節的小事……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_056"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "索爾、",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_057"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "之塔……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我原先並沒有，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "回到這裡的打算。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這裡，",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_058"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就是過去……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n騎士先生他們，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和霸瞳皇帝戰鬥的地方。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n同時……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也是我、",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "出生的地方……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過……",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_059"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我沒有任何一絲、",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "近似懷念的感受。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n只感覺得到，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "滿腔的怨恨和嫌惡。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在這個地方，",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_060"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "誕生。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n然後被拘禁在這個，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "對我而言猶如牢籠般的塔頂……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我只能被迫",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_061"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一次、一次又一次，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n無窮無盡、",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "數不勝數地……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n目睹他的",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "最終結局。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我不斷重複那",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_062"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "為了發動重置而能介入的短暫時刻……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n然後，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "利用世界的扭曲，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "才總算，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "逃離了這座塔。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n然而我是營運裝置的一部分，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這點卻並未改變。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果沒有遇到美空他們……",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_063"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n還有，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果騎士先生他們沒有打倒霸瞳皇帝，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我說不定",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會受不了無窮無盡的循環，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "磨耗掉所有精神意志。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不對……",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_064"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……沒錯。",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_065"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n過去，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在「再構築」之前──",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "正好，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就是在這裡，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我和騎士先生，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "相遇的記憶……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那才是，",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_066"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我唯一的、",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "心靈寄託。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n要是沒有那段記憶……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我一定早在更早之前，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就崩潰了……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可是……",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_067"
    },
    {
        "type": "background",
        "background": "500802"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 129013,
        "voice": "vo_adv_2114009_068"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是我",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "呀……",
        "unit_id": 129013
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你不記得……",
        "unit_id": 129013,
        "voice": "vo_adv_2114009_069"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "了嗎？",
        "unit_id": 129013
    },
    {
        "type": "background",
        "background": "500273"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_070"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那個時候……",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_071"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所發生的事情，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n他似乎已經，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不記得了……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "──那也是無可奈何的、",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_072"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "吧……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n畢竟騎士先生忘記的……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不是只有我而已。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n況且……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生他，",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_073"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "被霸瞳皇帝逼到絕路，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n失去了嚮導小妖精，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "傷得非常重。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n還有，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "剛開始「再構築」的世界，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也極為不穩定。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……沒關係的……",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_074"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只要在未來，",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_075"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "再創造許多專屬於我和騎士先生的時間就行了。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那就是我，",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_076"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "走到這一步的動機。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "美空替我蒐集到的、",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_077"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "七冠情報──",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「創造世界」的方法……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n雖然，",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還稱不上完整……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不過……",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要實現我的願望，",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_078"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "已經足夠了。",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所以……",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_079"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所以，",
        "unit_id": 129012,
        "voice": "vo_adv_2114009_080"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n你等我──",
        "unit_id": 129012
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129012
    }
]