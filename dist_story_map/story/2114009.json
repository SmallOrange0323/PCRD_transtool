    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "公主……",
        "unit_id": 105811,
        "voice": "vo_adv_2114009_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突襲──！！！",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "TYPE-R闇影",
        "words": "…",
        "unit_id": 192721,
        "voice": "vo_adv_2114009_001"
    },
    {
        "type": "dialogue",
        "name": "TYPE-R闇影",
        "words": "…！",
        "unit_id": 192721
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼、",
        "unit_id": 105811,
        "voice": "vo_adv_2114009_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "呼……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這些",
        "unit_id": 105811,
        "voice": "vo_adv_2114009_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "闇影……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底還有",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "多少人啊……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然我靠著{player}",
        "unit_id": 105811,
        "voice": "vo_adv_2114009_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "送來的強化之力，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n勉強戰到了現在，但……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我好像已經很久沒像這樣",
        "unit_id": 105811,
        "voice": "vo_adv_2114009_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "獨自一人奮戰了。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "畢竟這陣子，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "身邊總是有人陪伴著我。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "被襲擊的市民1",
        "words": "──呀啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_2114009_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "！！",
        "unit_id": 105811,
        "voice": "vo_adv_2114009_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那邊……！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我想去跟",
        "unit_id": 105811,
        "voice": "vo_adv_2114009_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "純小姐她們會合啊……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都沒時間去找她們了……！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "被襲擊的市民2",
        "words": "噫噫噫噫～！！",
        "unit_id": 1,
        "voice": "vo_adv_2114009_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位居民！",
        "unit_id": 105811,
        "voice": "vo_adv_2114009_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請快點逃離這裡！！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算",
        "unit_id": 105811,
        "voice": "vo_adv_2114009_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我只有一個人，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也會奮戰到最後的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為──",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使是在一個由他人創造的世界裡，",
        "unit_id": 105811,
        "voice": "vo_adv_2114009_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n無論國家、歷史、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "城市居民、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "父親大人或母親大人……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使一切的一切",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都是虛假的……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對",
        "unit_id": 105811,
        "voice": "vo_adv_2114009_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我來說，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這裡的每一個人都是我所珍惜、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是我要守護的人……！",
        "unit_id": 105811
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲──！",
        "unit_id": 180611,
        "voice": "vo_adv_2114009_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳人到底",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在哪裡啊──！！",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡的視野這麼好，卻看不到人在哪……",
        "unit_id": 180611,
        "voice": "vo_adv_2114009_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這麼說來，",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n難道，",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙已經遭遇不測了……",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不。",
        "unit_id": 180611,
        "voice": "vo_adv_2114009_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就算她的對手",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是那個強得跟怪物一樣的贊恩，",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她也不會",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼輕易就輸了才對。",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她可是",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們【美食殿堂】的一員啊……",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 180611,
        "voice": "vo_adv_2114009_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "她到底去哪了……",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是回到塔去了……",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在那座城堡裡嗎……？　",
        "unit_id": 180611
    },
    {
        "type": "still",
        "still": "211400601"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說回來，那座像城堡的東西？",
        "unit_id": 180611,
        "voice": "vo_adv_2114009_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是什麼啊？",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "根本是一塊超巨大的魔力集合體啊。",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看起來像是要佔領索爾之塔之類的樣子。",
        "unit_id": 180611,
        "voice": "vo_adv_2114009_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "萬一，",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是那麼大一座的塔和城堡整個掉下來的話……",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n城市會被摧毀的！",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到時候就不用談什麼重建了！　",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "況且高塔的正下方",
        "unit_id": 180611,
        "voice": "vo_adv_2114009_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是王宮。",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n陛下應該",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也還待在地下……",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n最糟的情況",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是遭到活埋……",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──啊啊可惡！",
        "unit_id": 180611,
        "voice": "vo_adv_2114009_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n完全忙不過來啊！",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我還想去幫貪吃佩可或可蘿仔的忙啊……！",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總之，",
        "unit_id": 180611,
        "voice": "vo_adv_2114009_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "進那座城堡裡看看吧……！",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "畢竟現在也只有我",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能夠去調查情況了。",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果裏頭的傢伙在打什麼壞主意，",
        "unit_id": 180611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就從內部把它破壞掉……！　",
        "unit_id": 180611
    },
