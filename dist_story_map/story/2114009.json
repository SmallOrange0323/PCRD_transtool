    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就在{player}一行人即將從索爾之塔逃出的不久前，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可與凱留分開後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她隻身一人奮不顧身地對抗著闇影天使。"
    },
    {
