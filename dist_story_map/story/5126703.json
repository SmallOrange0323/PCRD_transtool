[
    {
        "type": "background",
        "background": "500081"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "正在讀書的凱留與{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人一起讀書的日子到今天迎來最後一天。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……好啦，",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天就念到這裡吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過話說回來，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天是最後一天了。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如何？",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們努力念了這麼久，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n考試應該沒問題吧？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦，",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很敢說嘛！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們很認真地念書了嘛～",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～？",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼一臉沒自信的樣子～！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我說你，",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把鉛筆拿出來！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……你在發什麼楞啊！",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我不是在開始準備考試時有給你一支鉛筆嗎～？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還說了要認真讀書，讀到把鉛筆用完。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是這個。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……呵呵，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "稍微借我一下喔。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……好厲害。",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "交給你的時候還是全新的，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在已經短到都快握不住了。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你很認真努力呢。",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真沒辦法，我就給你個獎勵吧！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼，",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是當然囉！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我都親自教你了，如果你還沒有動力，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我可是會宰了你喔♪",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……來，",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是給你的",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "禮物。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是新的鉛筆喔。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你就用這支來考試吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……咦？",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這隻短的鉛筆比較好？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可是這支筆，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不管怎麼說都太短了吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好啦，",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我給你一支新的，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那支就丟了吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……！！",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什……",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼～？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說這就是青春，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n未免也太寒酸了吧！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……哎，",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "隨便你了！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，考前讀書就到這裡結束！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我還要再多待一下，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你先回去吧！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再見囉！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你要是敢在正門等我，我就宰了你喔！？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………他走掉了吧？",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n應該聽不到我說話了吧……？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……呵呵，",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說什麼那支鉛筆是青春。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還說是他",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和我的……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "青春。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呵呵呵。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很想笑呢。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n明明我一點也不覺得高興啊♪",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我會繼續送你的，",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再送個",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "100支",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鉛筆吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真希望這段時光",
        "unit_id": 127214,
        "voice": "vo_adv_5126703_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "能夠繼續下去──",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，認真讀書的兩人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n面帶著笑容迎接了期末考的挑戰。"
    }
]