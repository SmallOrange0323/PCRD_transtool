[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "梅莉莎小姐，",
        "unit_id": 138312,
        "voice": "vo_adv_5213311_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我要用這股新的力量",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "擊敗妳！",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "唉……",
        "unit_id": 20013,
        "voice": "vo_adv_5213311_001"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "真煩。",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n還以為自己是什麼女神嗎？",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "話說回來，",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "妳居然也覺醒了啊……",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "嗯，",
        "unit_id": 20013,
        "voice": "vo_adv_5213311_002"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "說真的啦？",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "其實我早就知道了，",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "到了我這種程度。",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "不管怎樣，",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "我也猜得到妳遲早會覺醒的嘛～",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "這不就是所謂的「套路」嗎？",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "不過啊，",
        "unit_id": 20013,
        "voice": "vo_adv_5213311_003"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "那種爛「套路」在我身上可行不通。",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "就算妳成功了覺醒，",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "最後還是會淒慘地敗給我……！",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n這才是這個故事的結局啊♪",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 138312,
        "voice": "vo_adv_5213311_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱歉了，",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我完全沒有會輸的感覺。",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為──",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可的肚子",
        "words": "咕嚕嚕嚕嚕～",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我現在肚子可是餓得很呢！",
        "unit_id": 138312,
        "voice": "vo_adv_5213311_005"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "不是，這也太莫名其妙了吧！",
        "unit_id": 20013,
        "voice": "vo_adv_5213311_006"
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "\n",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "納命來……",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "梅莉莎",
        "words": "我要讓妳渾身蜂蜜淋漓！！",
        "unit_id": 20013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正合我意！",
        "unit_id": 138312,
        "voice": "vo_adv_5213311_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那些美味的蜂蜜，",
        "unit_id": 138312
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我可是會全部喝個精光喔☆",
        "unit_id": 138312
    }
