    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在散步的時候，\n宮子一臉驚慌地飄了過來。"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不好了──！出大事了喲──！重大事件來的──！",
        "unit_id": 100711,
        "voice": "vo_adv_1007008_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不論去哪一間店，都買不到布丁了～",
        "unit_id": 100711,
        "voice": "vo_adv_1007008_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n布丁從城鎮上消失了喲～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "為什麼布丁這麼受歡迎來的～",
        "unit_id": 100711,
        "voice": "vo_adv_1007008_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n每家店都賣光光來的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子超想吃布丁來的！",
        "unit_id": 100711,
        "voice": "vo_adv_1007008_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n你快想想辦法來的！！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "哇，好刺眼啊～",
        "unit_id": 100711,
        "voice": "vo_adv_1007008_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這個光……和之前一樣來的～！？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚哇～～來的～～！",
        "unit_id": 100711,
        "voice": "vo_adv_1007008_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "！",
        "unit_id": 100711
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁消失了喲──！",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "現在布丁好像大流行來的～！",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_007"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不管是超市還是便利商店，每間店都買不到布丁來的……",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……現在流行布丁減肥法嗎？",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "吃布丁怎麼可能會瘦來的──！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n隨著媒體起舞，簡直是笨蛋來的──！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子無法忍耐──",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "現在趕快準備好布丁給宮子來的──！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子等不了──！",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n現在就想吃布丁來的──！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這樣的話……",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你做布丁給宮子吧～",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n買不到布丁的話，我們自己做就好了喲～♪",
        "unit_id": 100731
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就決定來做布丁吧～♪",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "來，這是水桶來的！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "拜託……你用常識好好想一想吧～",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "做布丁的話，不可能會有那麼多的垃圾喲～",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這個水桶當然是布丁的容器來的！",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "說傻話也要有個限度喲～",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n你要是在走廊上罰站的話，誰負責做布丁來的～？",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "用這個水桶的話，就能做巨無霸布丁來的～♪",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_016"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那麼開始做布丁來的！",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_017"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "主廚是我，出雲宮子來的！嗯哼♪",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那麼你這個助手，",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_018"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n先開始打蛋～",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啪卡啪卡有節奏地打蛋吧～♪",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好～接下來你在這裡面，",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "加入砂糖和牛奶，然後攪拌一下吧～♪",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "感覺很不錯來的～",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_020"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "接著要做焦糖來的！",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子負責加油來的～♪",
        "unit_id": 100731,
        "voice": "vo_adv_1007008_021"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100731
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你負責努力做布丁來的！",
        "unit_id": 100731
