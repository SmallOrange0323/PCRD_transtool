[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好！　",
        "unit_id": 106011,
        "voice": "vo_adv_9023156_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣就算完勝了吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過也真是可怕的執念啊…",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n差點活生生地被吃掉，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣的感覺真恐怖呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是啊～",
        "unit_id": 105811,
        "voice": "vo_adv_9023156_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們平常在吃的東西，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也是這些生命成就而來的。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們要好好珍惜，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱持著感恩的心享用☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來，",
        "unit_id": 105911,
        "voice": "vo_adv_9023156_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "上次在下也認為，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總覺得那隻魔物的體格，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有什麼地方不自然。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n應該是這座島的環境，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對魔物",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "造成了什麼影響吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唔～嗯……",
        "unit_id": 106011,
        "voice": "vo_adv_9023156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然不太能肯定，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但那算是「進化」吧。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n隨著環境變化，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在世代變遷中",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "逐漸調適改變。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n畢竟只能在特殊的岩山地形生存，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因而強化了",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這部分生活能力的感覺。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實，",
        "unit_id": 105911,
        "voice": "vo_adv_9023156_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為魔物的世代更迭",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很劇烈的關係吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n沒有受到討伐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而經過反覆的自然淘汰，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此發生了那種變化",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "目前的情況，還不是很明朗啊。",
        "unit_id": 106011,
        "voice": "vo_adv_9023156_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果是神創造了所有的生物，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那一隻也未免在受限制的環境下適應得過頭了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有",
        "unit_id": 106011,
        "voice": "vo_adv_9023156_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "調查下去的必要呢。",
        "unit_id": 106011
    }
]