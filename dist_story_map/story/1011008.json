[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊～……",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n結束一個工作後所吃的飯，真是特別好吃呀！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我現在特別",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n有活著的感覺喔，哥哥……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然很辛苦，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不過我總算湊齊會長的圍裙……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，不對，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是我總算湊齊所有做衣服的必備材料了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這都多虧了",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n有哥哥來幫我的忙喔♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯嗯！",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n只要最後有滑嫩的肌膚，保養過程都無所謂！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呀～特別是最後的蜘蛛是強敵……",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我覺得累了呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥有沒有受傷？",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我可以幫哥哥做點緊急處理喔？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我學到的全是些沒什麼用處的技能，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n像是求生術或是射箭之類的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "無論在任何環境下，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我似乎都能堅強地生存下去了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我正在準備的入學考試要是考上的話，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "將來就會成為服裝設計師……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以即使變得擅長戰鬥，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n對我來說也沒什麼意義。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是這對我收集材料很有幫助，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n而且俗話說有一技之長在身，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就不怕危險……？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是不怕沒飯吃！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想我學到的應該不是全無用處，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n對吧，哥哥？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對哥哥來說，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n像這樣和我一起度過的時光……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果不是全都白費時間，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "而能多少有些價值，我就很開心了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就算有一天",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥會全都忘掉……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "在哥哥的身體裡",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n和哥哥的靈魂深處，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一定還是會留下些什麼的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n對不起，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我說了一些摸不著頭緒的話。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "果然我也是覺得累了吧～，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我可以加點甜食嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔喔喔！？",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥又突然發光了喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "每次都是這麼突然呢～，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我還以為心臟要從嘴裡飛出來了……！",
        "unit_id": 101112
    },
    {
        "type": "still",
        "still": "101100801"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥～，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這邊這邊！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是的，哥哥太慢來了！",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥這一點還真是老樣子呢～？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我沒等哥哥來，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就先吃完蛋糕……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我這一點也是老樣子呢♪",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，真是的，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這裡的蛋糕真是太棒了！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥也請點些喜歡的蛋糕吧，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n今天我請客喔！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這算是溫習考試之餘的休閒活動，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n也是給一直教我讀書的哥哥一個謝禮！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會請哥哥吃",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n喜歡的蛋糕喔♪",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也來加點吧，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要、點、什、麼、好、呢～♪",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這已經是第七個蛋糕了，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我要和胃容量商量一下～……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，我吃太多了？",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n才沒那回事呢！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "前面吃的都是前菜，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n接下來吃的才是主食吧！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿♪",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為考試溫習很耗腦力～",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以我不管吃多少甜食都沒問題！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n應該說我不攝取大量的糖分是不行的！",
        "unit_id": 101131
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥問我打算考哪一間高中？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我沒有對哥哥提過嗎？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯～……",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n沒什麼，總覺得說出來有點害羞，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以我還是先保密。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n話說回來，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們這樣好像在約會喔……♪",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，我沒有刻意轉開話題喔？",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我只是單純地覺得和哥哥在一起真幸福～啊……？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔哇！",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_039"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚……",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我一個沒注意失去平衡，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n包包裡的東西都掉出來了。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，沒事，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_041"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我沒有受傷喔～？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為哥哥在那瞬間",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_042"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n把我往自己那邊拉了一把……♪",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，哥哥不用替我撿包包裡的東西啦！",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_043"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我自己來就好了！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊……",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_044"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯，被哥哥看到了呢。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是的。",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_045"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n那是都立高中的歷屆考古題。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為這一帶的都立高中只有椿丘高中，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_046"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我想報考的學校露餡了呢。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒錯。",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_047"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我想和哥哥",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n讀同一所高中。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘖～。",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_048"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n明明我是打算考上後再告訴哥哥，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讓哥哥嚇一跳的。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "以我的學力偏差值來說，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_049"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n合格機率是一半一半……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我沒什麼自信能考上。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讓哥哥知道我要報考，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_050"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n卻落榜的話，我會很丟臉。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……欸嘿嘿。",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_051"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "吶，哥哥。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果哥哥想和可愛的璃乃一起度過高中生活的話，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_052"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n能不能給我施一個『合格的魔法』呢？",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我從以前開始……",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_053"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就最喜歡哥哥的『魔法』了♪",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要哥哥給我施『魔法』，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_054"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我就覺得自己什麼事都做得到。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以，哥哥……",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_055"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯～……♪",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦？",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_056"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我是指只要得到喜歡的人親吻",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就能考上的『魔法』！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我之前看過的雜誌是這麼寫的，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_057"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請哥哥快點",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "！",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_058"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我還以為只要氣勢十足地拜託哥哥，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥就會答應的……",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "拿哥哥沒辦法，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_059"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這次我就先放棄。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_060"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n如果我考上的話，",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥要給我獎勵的『魔法』喔。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們約好了喔，",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_061"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥。",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101131,
        "voice": "vo_adv_1011008_062"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101131
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我會非常努力用功喔☆",
        "unit_id": 101131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……唔～嗯。",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n璃乃比我想像的還要積極呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這孩子似乎並不滿足於",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n『妹妹』這個地位呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你幹嘛一愣一愣的……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你啊，太遲鈍了。",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你難道不懂，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n為什麼璃乃會說想要和你上同一間高中嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦？",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n璃乃不也明白地說了",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想收到喜歡的人的吻嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說，",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n親吻是『合格的魔法』吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是如果要求以親吻當作合格的獎勵，",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n意思就不一樣了呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要從這一點",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n推測出對方的心情呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過算了。",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_071"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為你已經跟璃乃約好了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是她考上了，就要給她一個吻喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為你是璃乃既喜歡",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_072"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n又憧憬的理想哥哥。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你打破約定的話，",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n會讓璃乃的期待破滅喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "加油吧，哥哥♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼今天就先這樣……",
        "unit_id": 190011,
        "voice": "vo_adv_1011008_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n掰掰～，下次見囉♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥？",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_075"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們點的東西已經送上來了喔，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥不吃嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不是啦～，我已經吃很飽了。",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_076"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖說如果是甜食的話，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我比較能夠不停地大吃。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過我為了收集服裝的材料，也徹底地運動了，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_077"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以我也得攝取卡路里才行……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果我在考試當天",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_078"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n搞壞身體的話就糟了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嚼嚼♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯。",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_079"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "收集材料本來就是",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n溫習考試之餘出來喘口氣的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這次我絕對不想再為了落榜而哭了，",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_080"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我也會努力讀書的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "什麼？",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_081"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥說如果我考上的話，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就會給我一個吻……？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦、咦？",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_082"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥突然間是在說什麼啊。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n親親親吻什麼的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_083"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n明明是兄妹～……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不對，因為我們沒有血緣關係，\n所以在倫理與法律上都沒什麼問題！",
        "unit_id": 101112,
        "voice": "vo_adv_1011008_084"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不、不過還是太早了啊～！？",
        "unit_id": 101112
    },
