    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "雖然有點可怕……",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "小阿",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "會和拿娜一起吃嗎？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "會的，",
        "unit_id": 136011,
        "voice": "vo_adv_5210007_063"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "小拿。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "還有……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "也可以邀請",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生一起嗎？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "當然",
        "unit_id": 136212,
        "voice": "vo_adv_5210007_064"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "可以了！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n小騎士一定會說",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "「我要去！」",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "的！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "嗯。",
        "unit_id": 136011,
        "voice": "vo_adv_5210007_065"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "和小拿，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "還有騎士先生，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "不論到哪裡也……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "是三人一起的",
        "unit_id": 136212,
        "voice": "vo_adv_5210007_066"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "零食探險隊！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "為了尋找各式各樣世界的甜點，",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "出發──！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜‧阿剌克涅",
        "words": "啊哈哈哈哈哈♪",
        "unit_id": 1,
        "voice": "vo_adv_5210007_067"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "響徹吉歐‧格黑納天空的笑聲。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那是曾經"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "身為加害者與受害者"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "的聲音。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "如今，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "卻成為了獨一無二的「朋友」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那兩人的笑聲──"
    }
]