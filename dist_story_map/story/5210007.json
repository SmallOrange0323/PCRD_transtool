        "name": "涅妃‧涅羅",
        "words": "好比",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那會長。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那青年毫無疑問",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "深愛此煉獄之地。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正因如此──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "才墮入黑暗。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "走上歪道之危險性，",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_057"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "阿剌克涅亦然。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "為免其墮入黑暗、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "為免其受內心黑暗所噬。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n還請諸位看望──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "明白了。",
        "unit_id": 137411,
        "voice": "vo_adv_5210007_058"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想她肯定沒問題的。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為現在的阿剌克涅小姐",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有朋友在啊。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "沒料到那魔蜘蛛與拿娜",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_059"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "竟能締結情誼……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呼呼呼……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "甚好，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "甚好。",
        "unit_id": 129711
    },
    {
        "type": "background",
        "background": "502250"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "呼。",
        "unit_id": 136212,
        "voice": "vo_adv_5210007_060"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "結束了呢！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "那個，",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "小阿。",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "今天的零食要吃什麼？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "已經沒有甜甜圈了～",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "零食……",
        "unit_id": 136011,
        "voice": "vo_adv_5210007_061"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n在吉歐‧格黑納",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "沒有像甜甜圈一樣的甜點。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那麼──",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "蜘蛛愛吃的，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "甜蟲子怎麼樣？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "咦！？",
        "unit_id": 136212,
        "voice": "vo_adv_5210007_062"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "蟲子也有甜的嗎？",
