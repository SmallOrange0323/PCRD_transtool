[
    {
        "type": "background",
        "background": "502170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在一切塵埃落定之後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}他們接受涅妃‧涅羅的召集，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在鬼岩城塞與煉獄的皇女會面。"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "霞閣下。",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_000"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n疏於問候，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實在萬分抱歉。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "大致緣由",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_001"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家已從",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "米亞那兒聽聞。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "皆因奴家管理不周，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n令汝煞費一番勞苦──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒有這回事，",
        "unit_id": 137411,
        "voice": "vo_adv_5210007_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "涅妃‧涅羅小姐。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我才是，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不知道是否滿足了妳的期待呢？",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哦……",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝所言之",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "期待是指？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳會把這面「真實之鏡」交付給我，",
        "unit_id": 137411,
        "voice": "vo_adv_5210007_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n正是希望我揭露",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "審判長和會長的本意，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我認為這是妳的請託，因此接下了──",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這正可謂",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「不言自明」──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不愧為王都之名偵探。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "非也，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如今",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝應為煉獄之名偵探才是。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "咦？",
        "unit_id": 136212,
        "voice": "vo_adv_5210007_006"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "咦？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "什麼意思？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "哼。",
        "unit_id": 134912,
        "voice": "vo_adv_5210007_007"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "反正我就知道會是這樣。",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "涅妃早就猜到",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "那兩個人很可疑了吧？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哦……",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_008"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "華音。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家聽聞汝",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "吃太多溫泉饅頭而已撒手人寰……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n嗯，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝之雙腿還在？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "很遺憾！",
        "unit_id": 134912,
        "voice": "vo_adv_5210007_009"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n本小姐的玉腿",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "一如既往",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "的",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "美麗啊，別裝傻！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正如霞閣下的推斷，",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_010"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家早已看穿",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "彼些傢伙心懷鬼胎。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而──",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_011"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若由奴家親自出馬，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n定必讓蘭德索爾",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "諸位商人惶恐。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "故此奴家忍住羞愧，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "求助於",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "赫赫有名之名偵探閣下。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "能將難以伺候的「真實之鏡」運用於指掌間，",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_012"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "出色破解謎團之舉。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此凡種種成果，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "皆遠超奴家之期望。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "再次感謝",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "霞閣下對此事之協助。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "承蒙誇獎，",
        "unit_id": 137411,
        "voice": "vo_adv_5210007_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我深感榮幸。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n當作這次工作的報酬──",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然不能這麼說，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但其實，",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我有一事相求。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來吧，",
        "unit_id": 137411,
        "voice": "vo_adv_5210007_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "阿剌克涅小姐。",
        "unit_id": 137411
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "好、",
        "unit_id": 136011,
        "voice": "vo_adv_5210007_015"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "好的……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "………",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_016"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "那、",
        "unit_id": 136212,
        "voice": "vo_adv_5210007_017"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "那個，",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "涅羅！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "希望妳能聽拿娜說──！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n小阿已經",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "不是以前的小阿了！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "拿娜，",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_018"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不必如此吵鬧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "與其由奴家絮絮叨叨，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "問問幾位當事人，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "豈不更為實際？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "諸位。",
        "unit_id": 129711,
        "voice": "vo_adv_5210007_019"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "進來吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "妖魔人們",
        "words": "打、",
        "unit_id": 1,
        "voice": "vo_adv_5210007_020"
    },
    {
        "type": "dialogue",
        "name": "妖魔人們",
        "words": "打擾了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "你們是",
        "unit_id": 134712,
        "voice": "vo_adv_5210007_021"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "曾經懷疑阿剌克涅的……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "雖說是受到審判長唆使，",
        "unit_id": 52111,
        "voice": "vo_adv_5210007_022"
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "我們對妳",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "做了很過分的事。",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "\n",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "真的",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "非常抱歉。",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "請原諒我們。",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "我們向妳賠罪。",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請、",
        "unit_id": 136011,
        "voice": "vo_adv_5210007_023"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "請不要道歉。",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "各位的憤怒",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是十分合理的……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "自那之後，",
        "unit_id": 52111,
        "voice": "vo_adv_5210007_024"
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "我被弟弟妹妹罵了。",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "\n",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "他們說我死纏爛打著過去的事，",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "不像是我的作風。",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "\n",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "男性妖魔人",
        "words": "……來。",
        "unit_id": 52111
    },
    {
        "type": "dialogue",
        "name": "妖魔人小孩1",
        "words": "姐姐。",
        "unit_id": 1,
        "voice": "vo_adv_5210007_025"
    },
    {
        "type": "dialogue",
        "name": "妖魔人小孩1",
        "words": "謝謝妳從大蜘蛛手上",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妖魔人小孩1",
        "words": "救了我們。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妖魔人小孩2",
        "words": "妳的傷口",
        "unit_id": 1,
        "voice": "vo_adv_5210007_026"
    },
    {
        "type": "dialogue",
        "name": "妖魔人小孩2",
        "words": "還痛嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那時候的兩人……",
        "unit_id": 136011,
        "voice": "vo_adv_5210007_027"
    },
    {
