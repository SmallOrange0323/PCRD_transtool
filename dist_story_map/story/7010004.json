    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "吃到毒蘑菇後倒地了！？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒錯喔～",
        "unit_id": 101511,
        "voice": "vo_adv_7010004_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那時候",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是把我嚇壞了呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 101511,
        "voice": "vo_adv_7010004_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "明明毒蘑菇的麻痺還沒消退，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n卻為了從魔物們手中保護我",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "而站起身了呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "居然有這種事……",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "伊緒老師，",
        "unit_id": 101511,
        "voice": "vo_adv_7010004_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是怎麼和{player}認識的呢？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我……",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是在森林裡被植物纏住的時候",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "被他幫助了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然不像毒蘑菇那麼嚴重的事態，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "但可真丟臉呢～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀。",
        "unit_id": 101511,
        "voice": "vo_adv_7010004_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "果然{player}，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n總是抱持著一顆溫柔的心呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好乖好乖、",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "乖孩子～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "再次遇見的時候，",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "他正在讀和他年紀不相符的讀寫書，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n那時候才知道",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "他失去記憶的事。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n於是就",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "推薦他來【月光學院】就讀了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "雖然一開始連簡單的問題都解不開，",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "卻在不知不覺間變得十分可靠了，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總會被{player}的進步給嚇到呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "希望能保持著這份溫柔",
        "unit_id": 101511,
        "voice": "vo_adv_7010004_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "繼續成長呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是啊。",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我也是這麼希望的。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n希望他能在【月光學院】繼續成長得更茁壯。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……對了，",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}總有一天",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "會從學院畢業呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是的，",
        "unit_id": 101511,
        "voice": "vo_adv_7010004_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就是這樣呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n一定會成為不需要我們陪在身邊，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "獨當一面的大人呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果……",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "今天，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "{player}在這裡恢復了記憶，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不需要再到學院上學的話……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "雖然很寂寞，",
        "unit_id": 101511,
        "voice": "vo_adv_7010004_014"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但送別",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也是我們的工作呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我才剛到任",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以還沒有這樣",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "送過學生。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "第一次",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "居然是{player}……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……{player}！",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是啊，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你曾是我們的學生這件事，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n是就算畢業以後也不會消失的記憶。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "為了在替你送別的那天不要感到後悔，",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "所以才總是盡心盡力的教導你呢！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀呀！",
        "unit_id": 101511,
        "voice": "vo_adv_7010004_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我也不能輸，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "會努力的將很多的事都教給你的～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "美、",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "美里老師？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n為什麼需要抱在一起呢？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀？　",
        "unit_id": 101511,
        "voice": "vo_adv_7010004_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我就是這樣照顧",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "每個孩子的唷～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "吶，{player}……",
        "unit_id": 101811,
        "voice": "vo_adv_7010004_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "能跟老師稍微解釋一下嗎……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n精靈族的幼稚園，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "到底是怎麼樣的地方……？",
        "unit_id": 101811
    }
]