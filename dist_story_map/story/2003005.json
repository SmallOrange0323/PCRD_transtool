[
    {
        "type": "background",
        "background": "500353"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚嗚～",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n雖然帥氣又架勢十足的跑了出來，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但還真不是普通可怕！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐～",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請保佑鈴莓！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "希、",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "希望不要是妖怪之類的就好了～……\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不，不管是魔物、可疑人士還是什麼的都很討厭就是了。\n真、真希望只是孩子們看錯了～……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "（嗯。",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_003"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n沒記錯的話，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n小綾音的房間是在這一帶。）",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "小綾音說她看到了窗戶對面有什麼。",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以，只要確認這附近是否有可疑事物的話……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 102321,
        "voice": "vo_adv_2003005_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀！？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n咦，小……綾音？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "（不對。",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_007"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n小綾音是聽話的好孩子，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n所以現在一定還待在育幼院內。）",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "…………",
        "unit_id": 102321,
        "voice": "vo_adv_2003005_008"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "（啊，仔細一看，眼睛的顏色不一樣！",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_009"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而且，眼睛隱隱約約發著光？）",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "（跟小綾音說的一樣，這是誰？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_010"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎怎怎、怎麼回事？）",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『……玩……遊戲。』",
        "unit_id": 102321,
        "voice": "vo_adv_2003005_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n什、什麼？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "玩遊戲……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『沒有啦～只是想一起玩遊戲呀！』",
        "unit_id": 102321,
        "voice": "vo_adv_2003005_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗯、嗯？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_014"
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『喂，",
        "unit_id": 102321,
        "voice": "vo_adv_2003005_015"
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "快點做吧！』",
        "unit_id": 102321
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "\n『鼴鼠，好可愛！』",
        "unit_id": 102321
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "\n『哥哥，加油呀！』",
        "unit_id": 102321
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦、咦……？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嘎啊啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_2003005_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "（哇？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_018"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n剛剛是小胡桃的尖叫聲？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "（那群孩子們是不是發生什麼事了？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_019"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個、我想想、該怎麼辦？）",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "『哈哈哈哈！』",
        "unit_id": 102321,
        "voice": "vo_adv_2003005_020"
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "\n『好開心～！』",
        "unit_id": 102321
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "\n『哈哈哈哈！』",
        "unit_id": 102321
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "（那個像小綾音的人，",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_021"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n現在似乎還不會有什麼危險的舉動……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "總之先不管她，趕緊回到大家身邊吧！）",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "（說不定，",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_022"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大家身邊可能也出現了奇怪的事物……！？）",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "500112"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "各位！",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_023"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n發發發、發生什麼事了？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我剛剛聽見了尖叫聲……！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不，不要……！",
        "unit_id": 102111,
        "voice": "vo_adv_2003005_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n停手呀，咲戀媽媽……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "咲戀？",
        "words": "…………",
        "unit_id": 102821,
        "voice": "vo_adv_2003005_025"
    },
    {
        "type": "background",
        "background": "500112"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_026"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "危險！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n咦咦咦，大小姐？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "這是在做什麼～？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_027"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "您現在可是拿著劍往小胡桃砍去啊……！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是呀，鈴莓！",
        "unit_id": 102311,
        "voice": "vo_adv_2003005_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不是咲戀媽媽呀，這個人也是『假冒』的！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是在窗外，和『另一個我』一樣的傢伙！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為，眼睛會發亮呢！",
        "unit_id": 102311,
        "voice": "vo_adv_2003005_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "如果是咲戀媽媽的話，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n一定不會對我們做過分的事情的！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這傢伙，果然是假冒的！",
        "unit_id": 102311,
        "voice": "vo_adv_2003005_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "走開，嗚啊啊啊啊～啊！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n消失吧，噗吉全力揮～擊",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "！",
        "unit_id": 102311
    },
    {
        "type": "background",
        "background": "500112"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不、不要這樣，小綾音！",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_031"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n別這樣大鬧，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不然育幼院的房子會倒塌的啊～！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀？",
        "words": "『很有自信嘛。』",
        "unit_id": 102821,
        "voice": "vo_adv_2003005_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀？",
        "words": "\n『那就讓我看看妳的本事吧♪』",
        "unit_id": 102821
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇呀！？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_033"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大大大、大小姐？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n您剛剛攻擊我了吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好過分～我是多餘的人嗎？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_034"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以您才想解決我對吧！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "果然是這樣吧！",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我總是冒冒失失的，老是給您添麻煩……！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "鈴莓小姐，請冷靜下來。",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來⋯⋯是叫綾音小姐吧？",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正如這位小姐所說的，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這並不是咲戀小姐本人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這位咲戀小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像只是重複進行相同的動作而已。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n冷靜下來應對的話，大概不會有什麼危險。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "它這樣不像咲戀小姐。",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不如說，這也不像戰士經過訓練後的行為。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下推測，",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是不是變身成人類模樣的魔物之類的？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "魔物……",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "聽妳這麼一說總覺得，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n它死氣沉沉的，或者該說感覺不像人類？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "稍微，確認一下吧。",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_042"
    },
    {
        "type": "still",
        "still": "200300501"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的……",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n托您的福，在下等人毫髮無傷。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倒是最後鈴莓小姐笨拙地跌倒，",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此白受了傷。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "阿哈哈，這是自作自受……",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_045"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家平安無事真是太好了♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個大小姐的冒牌貨究竟是什麼呢……",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "打倒它的那一瞬間，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n它就像幻影一樣消失了。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不僅攻擊它的時候沒有實感，",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而且它也沒有流血對吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個應該不是生物吧，",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "比較像是幽靈般的存在……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "看起來的確是那樣呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "到底是什麼呢，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真是不可思議的現象。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個，",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "詳細情況在下也不太清楚‥‥",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的劍，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎是愛梅斯大人所賜予的特別物品。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不光是剛才那種像幽靈的存在，",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n好像也可以吸收一般的魔物之類的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不曉得是什麼原理呢……",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "下次",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "向愛梅斯大人祈禱時，在下會再仔細地問她看看。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……哎呀。",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n各位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來現在似乎不是悠哉聊天的時候哦？",
        "unit_id": 105911
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500353"
    },
    {
        "type": "dialogue",
        "name": "綾音？",
        "words": "…………",
        "unit_id": 102321,
        "voice": "vo_adv_2003005_054"
    },
    {
        "type": "dialogue",
        "name": "咲戀？",
        "words": "…………",
        "unit_id": 102821,
        "voice": "vo_adv_2003005_055"
    },
    {
        "type": "background",
        "background": "500112"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚哇，好像有什麼在鑽動！？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_056"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不只有假冒大小姐和小綾音的人，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還有其他許多人！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "育幼院正被大量的『冒牌貨』包圍著？",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔⋯⋯",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n體力與魔力有限，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一一對抗的話反倒會被擊垮呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該要趁現在還有力氣的時候突破重圍，",
        "unit_id": 105911,
        "voice": "vo_adv_2003005_059"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n到安全的地方避難吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說、說的也是呢。",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_060"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們逃到大小姐開會的地方去，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n請她保護我們吧？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家～",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_061"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "！\n小心不要走散，\n一起過來我這邊！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咿……！",
        "unit_id": 102511,
        "voice": "vo_adv_2003005_062"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n今天從早到晚，直到最後都還是戰場啊～！",
        "unit_id": 102511
    },
