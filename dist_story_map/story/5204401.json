        "voice": "vo_adv_5204401_006"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "感覺不是那樣。",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n她是在引誘我們到開闊、",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "沒有障礙物、便於戰鬥的地方啊。",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "怎麼辦？",
        "unit_id": 132511
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "露易。",
        "unit_id": 132511
