[
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "這樣啊……",
        "unit_id": 16711,
        "voice": "vo_adv_5102323_000"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "沒想到你們可以撐到現在。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我就認同你們吧。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n你們的確有機會能打贏我。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "不過即使如此，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我也不會遺忘必須帶給觀眾歡樂的使命。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "畢竟我可是直播主啊。",
        "unit_id": 16711,
        "voice": "vo_adv_5102323_001"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "只要先打倒那邊那位騎士先生，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n妳們的強化就會消失，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我就能輕鬆獲勝，不過……",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "我並不打算那麼做。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "實力失衡的比賽就不好看了不是嗎？",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還真是謝了喔……",
        "unit_id": 123511,
        "voice": "vo_adv_5102323_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "其實妳儘管瞄準他也無妨啊。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為我們一定會保護他的，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就靠七七香她們。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 123711,
        "voice": "vo_adv_5102323_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒妳的份嗎！？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這時候該說「我一定會保護他」吧──！？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……好啦，這事先放一邊。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "是時候",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "結束這場對戰了！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是啊。",
        "unit_id": 123611,
        "voice": "vo_adv_5102323_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我們可不能",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "繼續放任這種事不管。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……輝美小姐，",
        "unit_id": 123611,
        "voice": "vo_adv_5102323_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果妳真的想帶給粉絲歡樂，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n就不要再搞小手段、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "或是把文化祭弄得亂七八糟，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n妳應該堂堂正正、",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "光明正大地經營下去才是。",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "單純享受喜歡的事物，",
        "unit_id": 123611,
        "voice": "vo_adv_5102323_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "將那模樣展現出來，",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n那才是",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "粉絲最想看到的一面啊……！",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "喜歡……",
        "unit_id": 16711,
        "voice": "vo_adv_5102323_007"
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "啊。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "那是我早已忘卻的情緒。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "為了播放次數和點讚數，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "那些無足輕重的事，",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "輝美",
        "words": "\n我都可以輕易拋棄。",
        "unit_id": 16711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳錯了……！",
        "unit_id": 123611,
        "voice": "vo_adv_5102323_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我會用這把劍",
        "unit_id": 123611
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "證明給妳看！",
        "unit_id": 123611
    }
]