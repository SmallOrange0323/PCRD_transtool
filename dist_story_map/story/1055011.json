[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在步未將護身符送給{player}後過了幾天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n做為當時的回禮，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}與步未講好要一起去約會。"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這裡就是約好碰面的地方……",
        "unit_id": 105511,
        "voice": "vo_adv_1055011_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n{player}前輩",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "似乎還沒有來。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "幸好今天沒有遲到～",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒想到能再次跟{player}前輩約會，",
        "unit_id": 105511,
        "voice": "vo_adv_1055011_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n有努力做護身符真是太好了～",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n雖然是自己手工做的，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但我也有受到保佑呢～♪　",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "要去什麼地方，",
        "unit_id": 105511,
        "voice": "vo_adv_1055011_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "又要聊些什麼話題好呢……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "在遠處看著前輩時",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "明明妄想了很多事情，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "一旦實際見面就會緊張起來，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "無法好好說話……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩……！",
        "unit_id": 105511,
        "voice": "vo_adv_1055011_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我真的沒有等很久，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還請放心！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "今天",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "非常感謝你願意陪我……♪",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "啊……",
        "unit_id": 105511,
        "voice": "vo_adv_1055011_004"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩今天",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也有把護身符繫在身上呢。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n你能那麼重視它，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我真的很開心……♪",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那麼，",
        "unit_id": 105511,
        "voice": "vo_adv_1055011_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "今天要去哪裡……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n那個，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "{player}前輩",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你是不是在發光……？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "之前好像也發生過一樣的事……",
        "unit_id": 105511,
        "voice": "vo_adv_1055011_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呀啊～！？",
        "unit_id": 105511
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我看看，",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_007"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "制服跟書包已經下訂了……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n接下來去買教科書吧。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "通知書上寫說在商店街的書局就有賣……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "總覺得",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_008"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好沒有真實感……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n考試的當下",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還想說一定會落榜，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "沒想到",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "竟然考上了第一志願……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然過程很辛苦，",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_009"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但有認真念書真是太好了～♪",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "然後，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "也多虧有那位在我的腳受傷時……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "願意出手相助的人。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n要不是他騎腳踏車送我一程，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我甚至無法參加考試。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我好想",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_010"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "再見他一面……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "他真的好帥……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我來不及問他的名字跟學校……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……算了，",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_011"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這也沒辦法。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n除了教科書之外，還得買很多東西，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n早點把事情辦完吧。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……啊～！？",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_012"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n是考試那天幫助我的大哥哥！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n那、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好久不見……！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這實在太巧了……！",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_013"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "難道說，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我想要見到他的心情傳達給神明了嗎……！　",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦，",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_014"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你問我……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "考試的結果嗎？",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗯，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我有順利通過考試，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "進入椿丘高中就讀了！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n這、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這都是多虧有",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "大哥哥你的幫忙……♪",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你說",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_015"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這樣我就是學妹了……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦咦！？",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n難不成",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "大哥哥也是椿丘高中的學生嗎……！？",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這樣啊，",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_016"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "大哥哥是因為升班，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "來買新的教科書。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我也是因為相同的理由才來這裡。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "其他還有很多東西要買，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "挺辛苦的……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……你要幫忙……",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_017"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這怎麼",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好意思呢……！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n考試那天就已經受到你的幫助了……！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "幫助一次",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_018"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "跟幫助兩次也差不了多少……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "大哥哥，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "你真的很溫柔呢。",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我可能還是第一次",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "碰到如此親切的人……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗯，",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_019"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這樣的話……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那麼，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就、",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就麻煩你了！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "已經買齊需要的書了……",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_020"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n不過高中的教科書",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "比國中的還要厚，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n感覺很難呢……",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "跟得上進度嗎？",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "說得也是……♪",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_021"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n既然都靠著大哥哥的幫忙順利考上了，",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n就得用功讀書才行……！",
        "unit_id": 105531
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "大、",
        "unit_id": 105531,
        "voice": "vo_adv_1055011_022"
    },
    {
        "type": "dialogue",
        "name": "步未",
