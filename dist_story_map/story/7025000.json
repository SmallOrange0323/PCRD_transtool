[
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在聳立天際的露娜之塔下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和嘉夜仰望著那遙遠的頂端。"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……真令人吃驚。",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "為了尋找同族我到很多地方旅行過，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但還是第一次見到這麼高的塔。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但是",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "為什麼這種地方會有你失去的記憶的線索啊？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "如果你知道的話也就不會那麼困擾了吧。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算了，",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那些小事就先不管了。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只要往這上面爬",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n你就能取回記憶，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我也能跟盡情享受跟魔物的戰鬥。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "做為行動的理由十分充足了。",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼趕緊出發吧──",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂～",
        "unit_id": 1,
        "voice": "vo_adv_7025000_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "等等啊～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯？",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那是……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哈，",
        "unit_id": 101711,
        "voice": "vo_adv_7025000_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呼……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "終於追上你們了～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那是我的台詞呀～！",
        "unit_id": 101711,
        "voice": "vo_adv_7025000_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "準備要登這塔對吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n為什麼不通知我一聲呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我聽說你跟真步和真琴",
        "unit_id": 101711,
        "voice": "vo_adv_7025000_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "還有霞都一起登過這塔了呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我一直在期待",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "下次何時來邀請我登塔的呢",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n結果竟然想拋下我，真～是見外～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我聽真步她們說過",
        "unit_id": 101711,
        "voice": "vo_adv_7025000_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "塔裡充滿魔物非常危險對吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以這就輪到我出馬了，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "讓我好好守護你吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是很棒嗎，",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_010"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一起來吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "增加戰力只有好處沒有壞處的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～♪",
        "unit_id": 101711,
        "voice": "vo_adv_7025000_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "說得真好呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "記得妳是，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呃……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊啊，",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_012"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我是嘉夜",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "上次跟妳見面是在蘭德索爾的祭典以來吧，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "香織？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "果然是那時候的龍人族呀～？",
        "unit_id": 101711,
        "voice": "vo_adv_7025000_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好久不見呢～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真高興妳還記得",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我的名字～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "當然，",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我沒有忘記妳的。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "沒想到【哞哞自衛隊】會出現在這裡呢……",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_015"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "事情變有趣了呢！　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在那之後我可是詳細調查過了妳們的事情了。",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_016"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "雖然表面上沒有互相對立",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "，但是幫派成員跟哞哞自衛隊",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n什麼時候發生衝突都不奇怪呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "只由獸人族所組成的公會",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_017"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "【哞哞自衛隊】……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在棘手的成員當中",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "劍與拳頭的兩大武鬥派可無法輕視呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "特別是跟我一樣專攻格鬥的妳的事情",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "之前就一直很在意了呢。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n進入眾多魔物徘徊的這塔",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "是非常好的機會。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n就讓我充分見識下",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳的實力吧！　",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "所以",
        "unit_id": 106511,
        "voice": "vo_adv_7025000_019"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼樣啊？{player}。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "香織也說想一起去，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "夥伴是越多越好的吧？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣就對了～♪",
        "unit_id": 101711,
        "voice": "vo_adv_7025000_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我會盡全力守護你的唷～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "獸與龍。兩雙強力的拳頭聚集，熱血沸騰的冒險即將開幕。"
    }
]