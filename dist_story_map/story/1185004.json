[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在街上走著的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n偶然遇見了花凜。"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，是{player}。\n你來得正好。",
        "unit_id": 190811,
        "voice": "vo_adv_1185004_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是啊。",
        "unit_id": 190811,
        "voice": "vo_adv_1185004_001"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "要說拜託",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "應該也算是種拜託吧？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊──你誤會了你誤會了！",
        "unit_id": 190811,
        "voice": "vo_adv_1185004_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不是前陣子提到的那種事。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "確實",
        "unit_id": 190811,
        "voice": "vo_adv_1185004_003"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有好幾個案件想請你幫忙，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n可是情報收集方面差了一些，還不夠完整。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那部分感覺還差了幾分火侯。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "明明說過要請您吃頓好吃的但卻還沒做到，",
        "unit_id": 190811,
        "voice": "vo_adv_1185004_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我想起的是這件事。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以說呢，",
        "unit_id": 190811,
        "voice": "vo_adv_1185004_005"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "現在和我一起去吃午飯吧。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我從職場同事那裡打聽到了推薦的店家。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "嗯，",
        "unit_id": 190811,
        "voice": "vo_adv_1185004_006"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請好好期待吧……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "咦，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "怪了？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n怎麼有奇怪的光芒…",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "怎，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "怎麼了？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這怎麼回事？",
        "unit_id": 190811
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "那麼",
        "unit_id": 1,
        "voice": "vo_adv_1185004_007"
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "今天也來進行",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "市內清潔活動吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "\n{player}，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "一直以來真是感謝你。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "\n像你這樣的年輕人願意參加",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "我感到很高興。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "到剛剛分配",
        "unit_id": 1,
        "voice": "vo_adv_1185004_008"
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "給各位的區域撿拾垃圾，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "\n等時間一到",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "再回這裡集合，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "拜託大家了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "好～的。",
        "unit_id": 1,
        "voice": "vo_adv_1185004_009"
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就在{player}默默地撿拾掉在地上的垃圾之際──"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "你好。",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_010"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "在假日撿垃圾，還真是個奇妙的年輕人呢。",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_011"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "如果不嫌棄的話，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "願意讓我幫你忙嗎？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "哎哎。",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_012"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "俗話說有緣千里來相會不是嗎。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n啊，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "馬上就看到了空罐。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "要是沒有亂丟垃圾的人，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_013"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n或許也就不用做這種麻煩的事了，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n世事總是不從人意呢。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不過街道變乾淨的話",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_014"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "也會讓想亂丟垃圾的人多上幾分猶豫吧。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "讓我們一路撿個乾淨吧。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "您家的",
        "unit_id": 1,
        "voice": "vo_adv_1185004_015"
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "孩子真的很上進呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "才沒那種事。",
        "unit_id": 1,
        "voice": "vo_adv_1185004_016"
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "那孩子假日整天都在睡覺，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "\n根本不願意幫忙做家事。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "那些人",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_017"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "也和您一樣是出來撿垃圾的",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "對吧？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "怎麼從剛剛就一直聊個不停……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "啊，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_018"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "可是",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "叮嚀她們的話會不會惹人嫌……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "嗯，",
        "unit_id": 1,
        "voice": "vo_adv_1185004_019"
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "什麼事？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_1185004_020"
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "你指的是三丁目的山田太太嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "\n哎呀，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "最近都沒有她的消息。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "\n真想久違地和她見個面。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "她還在那邊嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1185004_021"
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "我們快過去看看！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "……走掉了。",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_022"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "那個，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "結果撿垃圾的人，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n只剩下您了的說……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "說什麼不要緊……",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_023"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n你的意思是在那聊天，不如趕快離開還比較好一點是嗎？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "啊，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_024"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "好、",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "好的！",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "……走掉了。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "嗯？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "只是個濫好人？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n真是搞不懂的孩子呢。",
        "unit_id": 118531
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "哦，",
        "unit_id": 1,
        "voice": "vo_adv_1185004_025"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "是{player}。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n哎呀，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "不愧是年輕人，撿了不少呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n我完全不行呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "就是說啊。",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_026"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n老爺爺就慢慢地以自己的步調……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "哈哈哈，",
        "unit_id": 1,
        "voice": "vo_adv_1185004_027"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "雖然很感謝你的好意，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n但我也還不會認輸。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "哈哈哈，",
        "unit_id": 1,
        "voice": "vo_adv_1185004_028"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "年輕人口氣還真大。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n哎，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "老頭子也有老頭子的智慧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "……啊，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_029"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "難不成。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "嗯？",
        "unit_id": 1,
        "voice": "vo_adv_1185004_030"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "小姑娘。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "妳說的難不成指的是什麼？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "沒事沒事，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_031"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "沒什麼。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n請別放在心上。",
        "unit_id": 118531
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "那個，山田太太，",
        "unit_id": 1,
        "voice": "vo_adv_1185004_032"
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "真是好久不見了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "山田",
        "words": "哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_1185004_033"
    },
    {
        "type": "dialogue",
        "name": "山田",
        "words": "真不好意思。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "山田",
        "words": "\n因為我家老公",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "山田",
        "words": "工作上的關係，所以好一陣子不在家。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "山田",
        "words": "\n我買了伴手禮回來。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "山田",
        "words": "待會再大家一起分著吃吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "哎，",
        "unit_id": 1,
        "voice": "vo_adv_1185004_034"
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "沒關係啦。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "\n話說回來妳聽說了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "二丁目的鈴木太太……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "看來她們發現",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_035"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "山田太太了呢。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "還是一樣聊著八卦",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "根本沒有撿垃圾就是了。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "從他與老爺爺的對話聽起來，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_036"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n還以為他在一來一往間讓人提起了某種幹勁，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "看來是我想太多了呢……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "啊，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_037"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "沒事。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "沒什麼。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n我們繼續撿垃圾吧。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "嗯……",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_038"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "看來這次是白費工夫了。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "哎，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這也沒辦法。",
        "unit_id": 118531
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "哦～哦，歡迎回來！",
        "unit_id": 1,
        "voice": "vo_adv_1185004_039"
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "\n今天也託了{player}的福，收集到了大量垃圾。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "畢竟在那之後也一步一腳印地認真撿著垃圾嘛。",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_040"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n當然會很大量啦。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "咦？",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_041"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "那是……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "啊！",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "呵呵呵，",
        "unit_id": 1,
        "voice": "vo_adv_1185004_042"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "這份量你覺得如何。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n我可還不會輸給年輕人。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "雖然這垃圾量很可觀……",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_043"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不過有那麼多垃圾可撿嗎？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "嗯？",
        "unit_id": 1,
        "voice": "vo_adv_1185004_044"
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "不是，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "這是從認識的爺爺奶奶家裡回收來的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "老爺爺",
        "words": "\n再怎麼說都不能輸給年輕人啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不、",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_045"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不是，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這樣一來不就算不上市內清潔活動了……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "啊哈哈！",
        "unit_id": 1,
        "voice": "vo_adv_1185004_046"
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "無妨無妨。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "\n長輩精神飽滿是再好也不過的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這、",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_047"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這樣啊……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "再加上",
        "unit_id": 1,
        "voice": "vo_adv_1185004_048"
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "這對捨不得丟東西的長輩來說，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "\n剛好是次不錯的斷捨離。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "\n換成我們挨家挨戶造訪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "可沒辦法這麼順利。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "原、",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_049"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "原來如此……？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "對地區活性化有所助益，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_050"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "是這個意思沒錯吧？　",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "我們也不差哦！",
        "unit_id": 1,
        "voice": "vo_adv_1185004_051"
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "看清楚了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "哇，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_052"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這量真的很誇張……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不過",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這是為什麼？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "啊哈哈，",
        "unit_id": 1,
        "voice": "vo_adv_1185004_053"
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "妳以為我們只是在閒聊嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "\n是啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "旁人總是這麼認為的呢──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "活用IT撿垃圾，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_054"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "是嗎？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "沒那麼誇張啦。",
        "unit_id": 1,
        "voice": "vo_adv_1185004_055"
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "\n只是鄰居交流罷了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "有人就算無法完整參與清潔活動，",
        "unit_id": 1,
        "voice": "vo_adv_1185004_056"
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "\n還是願意稍微幫個忙。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "\n所以",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "我們所做的就是去找出那些人。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "啊，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_057"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "原來如此。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n所以您才會把見到什麼人的資訊告訴她們啊。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "畢竟{player}的人脈",
        "unit_id": 1,
        "voice": "vo_adv_1185004_058"
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "也和我們不相上下呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "\n小姑娘也是他的熟人對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_059"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我是……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "哎呀！",
        "unit_id": 1,
        "voice": "vo_adv_1185004_060"
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "看你身邊的女孩子",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "總是一個換過一個，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽2",
        "words": "\n你的花言巧語終於也達到這種程度了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "一、",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_061"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "一個換過一個？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "唉……",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_062"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "真是人不可貌相呢。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "哎，",
        "unit_id": 1,
        "voice": "vo_adv_1185004_063"
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "{player}身邊不管帶著什麼女孩，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大媽1",
        "words": "\n都不會讓人感到驚訝就是了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "就是說啊。",
        "unit_id": 1,
        "voice": "vo_adv_1185004_064"
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "畢竟全都是些願意幫忙撿拾垃圾的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "城內自治會會長",
        "words": "好孩子呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "擁有不可思議魅力的少年……",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_065"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n和我事前打聽到的",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "情報相符，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "應該是這樣吧？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "啊，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_066"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "那個……",
        "unit_id": 118531
    },
    {
        "type": "still",
        "still": "118500401"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "忘了報上名號真是非常抱歉。",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_067"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n其實我",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "做的是這種工作……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不僅限於日本，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_068"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "也會在世界各地四處尋找有趣人才，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n我的名字叫觀崎佳凜。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我從某個情報來源",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_069"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "聽說了您的傳聞，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "因此前來挖角。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不嫌棄的話",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_070"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "要不要和我一起共事看看呢？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "在敝公司服務的人才之中，",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_071"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "就連小學生或國中生都有，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n因此不會有任何問題的。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "哎呀哎呀。",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_072"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我聽說了許多關於你的傳聞。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "總之",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "先讓我對事業內容做個介紹吧。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "讓您的人脈",
        "unit_id": 118531,
        "voice": "vo_adv_1185004_073"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "以及打動他人的魅力",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "發揮得淋漓盡致吧！",
        "unit_id": 118531
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "人脈這點先不提……",
        "unit_id": 190011,
        "voice": "vo_adv_1185004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "打動他人的魅力？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該說是",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "擅長被使喚，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我覺得這樣比較貼切的說……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎，不過確實一旦見到你，",
        "unit_id": 190011,
        "voice": "vo_adv_1185004_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就會神奇地冒出一股",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "得努力才行的心情就是了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呃，",
        "unit_id": 190011,
        "voice": "vo_adv_1185004_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "先不提這個！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也遇見了花凜對吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而且好像還被她挖角了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "儘管不清楚花凜到底都做些什麼工作，",
        "unit_id": 190011,
        "voice": "vo_adv_1185004_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但我想她不會叫你做壞事才對，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n試著幫她工作應該也蠻有趣的吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然可能不是什麼輕鬆的工作，",
        "unit_id": 190011,
        "voice": "vo_adv_1185004_078"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但凡事都講究經驗，經驗很重要的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那麼就改天見啦♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
