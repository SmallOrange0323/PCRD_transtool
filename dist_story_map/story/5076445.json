    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "所以，各位，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我們還得繼續陪小棉花糖玩耍喔──！",
        "unit_id": 117711
    }
