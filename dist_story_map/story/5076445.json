        "voice": "vo_adv_5076445_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "小棉花糖並沒有這麼做～！",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "牠還是",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那個最喜歡點心和玩耍的",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "溫柔小棉花糖～♪",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "話雖如此，",
        "unit_id": 117711,
        "voice": "vo_adv_5076445_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要是放任橫衝直撞的小棉花糖不管，",
        "unit_id": 117711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n肯定會造成危害吧～？",
        "unit_id": 117711
