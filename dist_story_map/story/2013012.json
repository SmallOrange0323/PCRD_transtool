[
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "首先，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_000"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n從我為何要奪走他人生命力的理由，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "開始說起吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "首先第一點。",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_001"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在過去，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那次施放了大量破壞魔法之際，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我與晶……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "拉比林斯達貌似打成了平局的樣子――",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "因此我便陷入了昏睡的狀態，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_002"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n要甦醒",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "則是需要相當龐大的能量呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而為了有個萬一，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_003"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若我因為不小心而導致意識不清，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "或是陷入瀕死狀態時還能夠再次復活……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我在事前，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就預先準備好了安排。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "主要是",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_004"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "對進行了深層洗腦的凱留等人，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在事前下達了命令……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n為了能讓我復活，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就是賭上她們的小命也得行動。",
        "unit_id": 106914
    },
    {
        "type": "still",
        "still": "200601203"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而原本，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_005"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過只是施放大量破壞魔法的程度，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n根本連昏迷這種事兒都不可能發生。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "然而那時，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "拉比林斯達也同時",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "朝著我這採取了攻擊呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我挨了一記她所施放的魔法，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_006"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n也導致我的精神受到了致命性的傷害。",
        "unit_id": 106914
    },
    {
        "type": "background",
        "background": "500780"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "託她的福我暫時",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_007"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "成了睡美人呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過嘛",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那棘手的拉比林斯達也中了招，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n因此也陷入無法行動的狀態，可說是大幸了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過呢。",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_008"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "從他人那奪取生命力，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並且收集起來的裝置，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n並非只是為了萬一才準備的唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "應該說只是副產品吧，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是順便設定而附上的其中一個機能呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我為了",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_009"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "要實現我自己的願望，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "需要有大量的生命力呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n因此，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "使用了各式各樣的方法來收集生命力。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而『闇影』也是如此，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_010"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是為了能讓我取得生命力所設置的其中一個產物。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "一開始儘管只是偶然，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_011"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "自然產生的『闇影』……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而我將之捕獲",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並加以解析，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "且掌握了其結構，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n最後變得可以",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "讓我任意的生產出它們了唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『闇影』……",
        "unit_id": 105811,
        "voice": "vo_adv_2013012_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個到底是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "什麼東西啊？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是在這個毀損的世界中，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_013"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "必然地產生的Bug唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我則是主動且有意圖的，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "將它們給增加了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在這個世界中擁有生命的萬物之中，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_014"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n存在著一種生命力的型態。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "為得方便，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "魂魄……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就如此稱呼它吧。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "從豐富的生命力形成結晶的魂魄，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_015"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若將之剝離於人類的肉體上，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n便會化為『闇影』。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "順帶一提，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "被剩下來如同空殼般的肉體，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不用多久就會自然消滅。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "能夠維持肉體的生命力、",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_016"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也就是魂魄畢竟不存在了嘛……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n最後將不會存留於世而消失無蹤。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而這些人類失去蹤影的現象，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "便被人們稱呼為『消失』了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "『消失』還有『闇影』……",
        "unit_id": 105811,
        "voice": "vo_adv_2013012_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是最近",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在城內引起騷動的怪現象呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而這也全部都是",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你暗中在搞鬼所造成的對吧。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "嚴格來說並不正確，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_018"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但是加速了這些異變的人確實是我呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過在這個世間中所存在的所有不幸與悲劇，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_019"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n若能歸咎於僅僅一名惡徒所為，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也比較好判斷是非嘛？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n……對於你們而言呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……。",
        "unit_id": 105811,
        "voice": "vo_adv_2013012_020"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "總而言之。",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_021"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不知原因",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "自己從肉體脫離的魂魄，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "會成為『闇影』。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n嚴格來說",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就算只是魂魄的碎片，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "或者只是記憶的片段也足以構成……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而這些，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_022"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "全都是具有龐大生命力的結晶唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "每當找到了這些結晶，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我便會進行保護，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並且使其增殖。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n最後，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我便釐清了如何操縱『闇影』的方法了呢。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "所謂的『闇影』",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_023"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "幾乎不具有自我，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n且輕易地就會受到魔力影響，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "因此操縱起來相當容易。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而我也對",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_024"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "被賦予了能力而得以操縱『闇影』與魔物的凱留下了令，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n為了提升操縱的技術而讓她進行了實驗……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過嘛，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那孩子總是派不上什麼用途就是了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……。",
        "unit_id": 105811,
        "voice": "vo_adv_2013012_025"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不管如何，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_026"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只要一聲令下",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我便能如我所願的",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "操縱『闇影』。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n而為了將那積蓄的生命力奉獻於我，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n所以也能讓它們聚集到我的身邊喔。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "剛才",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_027"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那些從『闇影』轉變而成的黑色泥濘一般的玩意兒，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n都化成了洪流",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "且以『王宮』當成目的地聚集了過來對吧？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那個，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "便是這麼一回事唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在吸收了聚集而成的『闇影』所提供的生命力後，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_028"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我便復活了，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "並且也得到了那我得以實現願望所需的力量。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n這全部，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "都是為此所布下的局唷。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不過呢。",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_029"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還不夠呢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "光憑這種程度完完全全不足……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也是因為昏睡了好陣子的緣故，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n所以沒得有辦法讓『闇影』能夠增殖多少嘛。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "既然如此就別無他法了呢。",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_030"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也就只能不計形式，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "靠自身來收集生命力了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "已經刻不容緩了唷……",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就在我悠哉地睡著的時候，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "時間到了。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我已經",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_032"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "受夠了呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n這個見不著終點的無限輪迴。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無限輪迴？",
        "unit_id": 105811,
        "voice": "vo_adv_2013012_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你到底在說什麼……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哼。",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_034"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n看來還沒有抵達過那裡呢，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳們幾個都是。",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不論是拉比林斯達，",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_035"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "又或是",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不知為何碰巧留下了大部分記憶的諾維姆……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還有",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "似乎總是會提供建議給你們的菲歐……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也就是",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "愛梅斯，就連她們也無法認知的高次元裡，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n會不會有造成這場無限輪迴的原因呢？",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒關係。",
        "unit_id": 106914,
        "voice": "vo_adv_2013012_037"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "或許，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這全都是我的妄想、",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "誤會也說不定呢……",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "啊啊，",
        "unit_id": 106914
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "若真是這樣就好了呢。",
        "unit_id": 106914
    }
]