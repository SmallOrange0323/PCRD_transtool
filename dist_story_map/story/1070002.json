[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "前去找似似花無數次的{player}，\n在課程中漸漸地學會了一般常識。"
    },
    {
        "type": "still",
        "still": "107000101"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "……下一個問題。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_000"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "一袋裡有100盧幣的蔬菜三個，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n與300盧幣的水果兩個。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "請問買下兩袋",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "會是多少錢？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "答對了。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_001"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "做得很好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "算數問題也幾乎都不會答錯了。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_002"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "和一開始比起來，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "你成長了不少。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "……這或許是個適當的時機。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_003"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n也教他足夠的常識了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "偶爾會將他",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_004"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "以及與他有來往的少女們",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "包覆住的神祕光芒。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "超越我知識範圍的某種存在，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "也一樣在讓他成長。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "不僅如此，",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_005"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "曾見過的少女們與他的再會。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "看樣子果然",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "只能在你身上賭賭看了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "並非是我的公主騎士真軌，",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_006"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "你才是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "打倒真那所不可或缺的存在……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "正因為如此，",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_007"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "才更應該避免繼續與你接觸。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "要是讓真那察覺了我這裡的存在，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "就前功盡棄了。",
        "unit_id": 107011
    },
    {
        "type": "still",
        "still": "107000102"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "{player}。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_008"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n到今天為止，你都做得很好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "現在開始進行最終測驗。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_009"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "只要這測驗能合格，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n想必就算只有你一個人也能出色地生活下去吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "那麼，首先是第一題。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_010"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n5＋73＋750是？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "答對了。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_011"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "你也會算複雜的加法了呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n就是這個步調。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "除了我的課程以外，",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_012"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "看來在與其他幾位少女相處的時間中，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n你也有確實成長呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "那麼第二題。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_013"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n盧幣",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "只能用在去店裡購物。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "是◯還是×？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "答對了。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_014"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "盧幣，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "也就是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "金錢不只能夠消費購物，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n也能夠販賣某種東西，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "作為報酬由他人身上取得。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "……如果有這種程度的常識，",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_015"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "就沒問題了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "最終測驗合格。",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "我有個",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_016"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "珍藏的獎勵要給你。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n我想一定會對你有幫助的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "說不定",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_017"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "她也已經忘記了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "因此這是",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "我作為她的友人要給你的餞別禮。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "你被賦予的",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_018"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "公主騎士之力。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n我教你那力量原本的使用方法吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "你至今為止",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_019"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "似乎都是無意識之中使用的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "我讓你今後能夠自由地使用力量。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "首先拿起劍。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_020"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "接著集中精神……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "沒錯。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n做得很好。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "然後強烈地去希望吧。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_021"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "心想希望能幫我或你親愛的人，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "或是希望能成為某人的力量。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "將想法傳達出去。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "……成功了。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_022"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n沒想到",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "我會有接受你力量的這一天。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "不管怎麼說，",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_023"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "我的課程就到此為止。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "因此，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "該道別了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "明天起你就不能再到這裡來了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "你不能什麼事都要讓人來教你。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_024"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "因為你是身為一個人類。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "你今後應該要",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_025"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "親自去經歷各種事情，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n然後思考",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "並加以理解。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "無論是有多麼困難的問題在等著你，",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_026"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "都不應該等著別人告訴你解答，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "而是要靠自己去導出答案。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "我相信你能做得到。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_027"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "因為你是我的學生。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "……明白了嗎？",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_028"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "這麼坦率，很好。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_029"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "那麼走吧，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n回到等待你的夥伴身邊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "……嗯，",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_030"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "有緣再見。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "……明天起",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_031"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "這裡，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n除了真軌之外就沒有其他需要招待的人了吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "既然決定了……",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_032"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "守衛。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "聽得到嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "『請問您叫我嗎？",
        "unit_id": 1211,
        "voice": "vo_adv_1070002_033"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "主人。』",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "捨棄這座研究設施。",
        "unit_id": 107011,
        "voice": "vo_adv_1070002_034"
    },
    {
        "type": "dialogue",
        "name": "姊姊",
        "words": "\n移動到新的設施去吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "『遵命。",
        "unit_id": 1211,
        "voice": "vo_adv_1070002_035"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "也傳達給真軌。』",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "姊姊",
