    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聖誕節甜點大賽之後……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這天宮子與{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n也來造訪老婆婆的店。"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "婆婆～！",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n做布丁給宮子吃～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子肚子餓扁了喲～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "抱歉啊宮子。",
        "unit_id": 7911,
        "voice": "vo_adv_5080700_001"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n婆婆",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "接下來得外出去採買才行。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我回來後就做給妳吃哦。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗚……",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_002"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "知道了。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子會等妳的，所以快點回來喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "呵呵，",
        "unit_id": 7911,
        "voice": "vo_adv_5080700_003"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我知道了。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "要乖乖等我哦。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……好慢。",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子說很慢就是很慢！",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子肚子餓到快死掉了來的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子肚子餓了～！",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子想吃布丁～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "對了！",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_007"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要為宮子做布丁！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "應該有材料來的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "技術太爛了！",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_008"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n婆婆才沒有像你這樣弄呢！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔……",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子覺得自己應該做得會比你好。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "東西借人家！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "完成了！",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子做了很多喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n真不愧是宮子來的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子要全部津津有味地吃掉喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "…………好鹹。",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n大概是把砂糖和鹽弄錯了。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這種東西才不是布丁。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊！",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_012"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "竟然比宮子先吃，你在想什麼啊！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你在說什麼啊？",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_013"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁哪可能會辣。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那個布丁",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "加了美麗的紅色粉末，應該很好吃才對喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這～～個……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "上面寫著辣椒。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真是千鈞一髮。",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_014"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n你先吃真是幫了大忙。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "唔唔～～",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_015"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "做布丁好難喔！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n吃不到好吃的布丁，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子都開始恍神了……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "因為平時都從你那邊收到布丁，",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_016"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n你的臉越看越像布丁了……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你是，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "啊！",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_017"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子想到好主意了！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n真不愧是宮子喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是天才來的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "等宮子一下！",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_018"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "──成功了！",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "很順利地完成了！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "來來你看！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是有著你的臉的布丁喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n超有趣的～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你的臉",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_020"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就算做成布丁，感覺還是一樣蠢來的。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n但香味還不賴呢。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子開動了喲～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嚼嚼。",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_021"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯嗯嗯……？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這、",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這是……",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好吃驚喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這個布丁",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "雖然一副蠢相，還滿好吃的！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "明明是隨便拿那邊的材料做的，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "卻比之前做的都還好吃喲～！",
        "unit_id": 100711
