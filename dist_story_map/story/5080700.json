        "type": "dialogue",
        "name": "宮子",
        "words": "該不會",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_022"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "只要模仿某人的臉，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n就能做出美味的究極布丁……？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子知道了！",
        "unit_id": 100711,
        "voice": "vo_adv_5080700_023"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n既然如此…………",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子要把大家都做成布丁喲～～～！",
        "unit_id": 100711
    }
