[
    {
        "type": "dialogue",
        "name": "奴隸龍",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 19511
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那些自作聰明的種種算計，",
        "unit_id": 129711,
        "voice": "vo_adv_5213323_000"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家已盡數看破。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "自此刻起，再無虛招可言，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "唯有正面交鋒、刀刃相向──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "來場堂堂正正、真槍實戰，",
        "unit_id": 129711,
        "voice": "vo_adv_5213323_001"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "所謂之「認真對決」吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "對手可是傳說中的魔物，",
        "unit_id": 126511,
        "voice": "vo_adv_5213323_002"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "龍之眷屬。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "絕對不是能夠輕易應付的存在──",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "話雖如此……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "如果對手是我們，",
        "unit_id": 126512,
        "voice": "vo_adv_5213323_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n就另當別論了。",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "「進攻！」\n「上陣！」\n「我出招了！」",
        "unit_id": 1,
        "voice": "vo_adv_5213323_004"
    }
]