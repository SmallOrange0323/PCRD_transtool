[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真步與香織帶著伊莉亞與{player}\n回到了【哞哞自衛隊】的公會小屋。\n霞和真琴出來迎接他們四個人。"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "兩個人都辛苦了。安全無恙真是太好了。",
        "unit_id": 101411,
        "voice": "vo_adv_5003007_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而且沒想到傳說的吸血鬼復活這件事是場誤會……",
        "unit_id": 104311,
        "voice": "vo_adv_5003007_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n真抱歉，輕易就相信了來路不明的流言！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是，是呢～。根本沒有什麼傳說的吸血鬼呢～。",
        "unit_id": 101011,
        "voice": "vo_adv_5003007_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對、",
        "unit_id": 101711,
        "voice": "vo_adv_5003007_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對啊～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總、",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總而言之，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家一起歡迎\n伊莉亞吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對，對呀！哈，哈哈哈……",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n叨擾了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……？",
        "unit_id": 104311,
        "voice": "vo_adv_5003007_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳們怎麼這麼不自然……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "算了，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "既然還有客人一起回來。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那今天就放鬆一點吧！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～……就是這樣，",
        "unit_id": 101011,
        "voice": "vo_adv_5003007_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為了慶祝和伊莉亞的新友情，我們就開始晚餐會吧～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦哦！這就是款待了對吧！",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n等很久了呢！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "主菜是人家和香織親手作的，",
        "unit_id": 101011,
        "voice": "vo_adv_5003007_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n像苦瓜的東西口味的烏龍麵！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哪個哪個……",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……好，好苦…",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "…",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為伊莉亞說不怕像苦瓜的東西，",
        "unit_id": 101011,
        "voice": "vo_adv_5003007_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以其他小菜也用苦瓜作了～。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "烏龍麵則是使用『魔物之角』試打，",
        "unit_id": 101011,
        "voice": "vo_adv_5003007_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒想到效果很不錯呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這、這樣啊……！",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳的手藝還真是精湛呢……！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "（沒、沒想到像苦瓜的東西，竟然這麼苦！",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "為什麼她們可以吃得津津有味啊！)",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "臉、臉色是天生的啦！別管我",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒，",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒事啦！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是那個，妾身只是不知道該擺怎樣的表情才好啦！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可是，表情很僵硬耶，真的沒事嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_5003007_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不用擔心啦！",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n只是看到朋友為了妾身所作的料理，很感動而已！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "（說，說不出口……！這個像苦瓜的東西……",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n雖然吃下去不會出事，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但絕不能說出味道超不合口味！）",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而、",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "而且，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "身為大人理所當然吃得下這種東西吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "最重要的是，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身與她們之間的",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "友情……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "友情啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔，嗯……好，好吃啊……好吃……",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那真是太好了──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003007_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n還有很多唷！希望妳儘管添多一點！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "烏龍麵的湯頭，",
        "unit_id": 101011,
        "voice": "vo_adv_5003007_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是參考了真步真步王國中",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n名店的口味哦。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "請妳品嘗看看吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔、",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔嗯……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嚼……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嚼嚼……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咕呃……！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "怎，怎麼伊莉亞的臉色，從青白色變得開始發青了！",
        "unit_id": 101011,
        "voice": "vo_adv_5003007_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "難不成怕吃像苦瓜的東西嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒……沒有那種事！",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這是真步為妾身作的嘛！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哇，真高興～。那再幫妳盛一碗！",
        "unit_id": 101011,
        "voice": "vo_adv_5003007_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咕呃……",
        "unit_id": 104412,
        "voice": "vo_adv_5003007_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚嗚……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這點小事，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "算不了什麼……！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了無價的友情，\n伊莉亞只好繼續吃著像苦瓜的東西烏龍麵。"
    }
]