    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果你覺得害怕，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是一起行動比較好吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既然難得，就這麼做吧！",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確也可以這樣想呢。",
        "unit_id": 114011,
        "voice": "vo_adv_6050204_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論怎麼說也得要分辨出來誰是鬼怪才能擊敗啊。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只是如此一來，",
        "unit_id": 114011
