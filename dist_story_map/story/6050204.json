    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有其他混進來的鬼怪嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喂，",
        "unit_id": 114011,
        "voice": "vo_adv_6050204_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種惡作劇可不好喔。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我不會回頭的。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我是絕對不會回頭的！",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我、",
        "unit_id": 114011,
        "voice": "vo_adv_6050204_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我我可沒有說自己害怕喔？",
