    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "明明可愛的我都露臉給你看了，",
        "unit_id": 100811,
        "voice": "vo_adv_5084609_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你竟然沒有醒來……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這可能是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "比我想的還要嚴重的狀況呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是的……",
        "unit_id": 100811,
        "voice": "vo_adv_5084609_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n怎麼反倒是我盯著你的臉看啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "氣色看起來很健康，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但總覺得露出了很痛苦似的表情……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唉……",
        "unit_id": 100811,
        "voice": "vo_adv_5084609_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n無論我怎麼盯著自己美麗的臉，心情也還是不愉快。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不如說因為想太多，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我甚至都覺得肌膚變糟了啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "{player}。\n希望你能快點醒來啊。",
        "unit_id": 100811,
        "voice": "vo_adv_5084609_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n這也是為了",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我還有你自己",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "喔。",
        "unit_id": 100811
