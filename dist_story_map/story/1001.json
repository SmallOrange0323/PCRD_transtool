        "voice": "vo_adv_0001001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是過來玩的嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 100311,
        "voice": "vo_adv_0001001_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛才在附近碰巧遇到凱留，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n想說機會正好，就請她帶我們來玩了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100111,
        "voice": "vo_adv_0001001_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雪菲呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n她出門了？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雪菲她去幫忙跑腿了！",
        "unit_id": 105812,
        "voice": "vo_adv_0001001_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她最近很常一個人到處跑來跑去喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那為了在雪菲回來後就能馬上玩，",
        "unit_id": 106012,
        "voice": "vo_adv_0001001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們就先來",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "記遊戲規則吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "遊戲？",
        "unit_id": 105812,
        "voice": "vo_adv_0001001_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "看起來是桌遊呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好像是那樣沒錯。",
        "unit_id": 100311,
        "voice": "vo_adv_0001001_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們遇到凱留的時候有聊一下，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣說是想玩拿到的遊戲。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個遊戲",
        "unit_id": 100213,
        "voice": "vo_adv_0001001_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "的玩法說明看起來滿簡單的，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但好像很深奧。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我又沒什麼玩過遊戲，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "所以第一次想和各種人玩。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那就是",
        "unit_id": 105913,
        "voice": "vo_adv_0001001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說明書嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要先按這個按鈕",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來啟動遊戲……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接著要所有參加者的手",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都放到按鈕上。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比想像中的還要複雜呢……",
        "unit_id": 106012,
        "voice": "vo_adv_0001001_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不覺得",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個按鈕好像發出超～亮的光嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且該怎麼說呢，",
        "unit_id": 105812,
        "voice": "vo_adv_0001001_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像在被按鈕拉著一樣！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該說正在被吸著！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣下去就",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太不妙了吧……☆",
        "unit_id": 105812
    },
