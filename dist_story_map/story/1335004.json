    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你也做得很不錯嘛♪",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為變成自己一人而感到不安呢，",
