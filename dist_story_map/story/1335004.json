        "name": "咲戀",
        "words": "……這樣啊。",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n聽到你這麼說，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我很高興。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼啦。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你打算今後每年",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都要和我一起去參拜嗎？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那樣的話，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_041"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "已經不是青梅竹馬……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n反而",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "更像是家人了吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一直在一起",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果那樣的日常能夠到來，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一定……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會非常",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "幸福呢……",
        "unit_id": 102832
    },
