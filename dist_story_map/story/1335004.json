[
    {
        "type": "background",
        "background": "500320"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束在大江戶的旅行，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咲戀和{player}\n乘坐在前往蘭德索爾的馬車上。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總有種一如往常的感覺……",
        "unit_id": 102811,
        "voice": "vo_adv_1335004_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過是趟開心的旅行呢！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "觀光景點和美食",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都有充分享受到了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且，",
        "unit_id": 102811,
        "voice": "vo_adv_1335004_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能夠和你兩個人",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "悠閒地度過，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是太好了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "…",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "…嗯，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然有發生了點小意外。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒想到",
        "unit_id": 102811,
        "voice": "vo_adv_1335004_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會因為在想事情",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而泡溫泉泡到頭暈……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還好馬上就恢復了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒有影響到旅行……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811,
        "voice": "vo_adv_1335004_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那時候",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒、",
        "unit_id": 102811,
        "voice": "vo_adv_1335004_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我已經沒事了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別擔心。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是，",
        "unit_id": 102811,
        "voice": "vo_adv_1335004_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在回想起來……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在我泡過頭",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以頭還暈暈的時候，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺好像說了",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n有點令人害羞的話呢……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "想起那時候的事，",
        "unit_id": 102811,
        "voice": "vo_adv_1335004_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "該說是有種全身發癢的感覺嗎，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "頭也開始熱起來……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且你看，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "眼前一片耀眼的光芒……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦……？　",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "510270"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在充滿新年氛圍的城鎮中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}為了去新年參拜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而前往了附近的神社。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但神社的參拜人潮卻比想像得多，人山人海──"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "{player}……欸，",
        "unit_id": 1,
        "voice": "vo_adv_1335004_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這邊這邊。",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "133500401"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呼……",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你也是來新年參拜的呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n看這樣子，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該是才剛到吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如你所見，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "參道上滿滿都是人喔。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺還要等很久",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才能參拜到，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這期間一直排隊的話，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會很累人吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就算想排隊，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等人再減少一些會比較好呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這邊的話很空曠，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "暫時",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "打發一下時間怎麼樣？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "太好了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n其實，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也正在煩惱",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這之後該怎麼辦呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "本來是全家人一起來的，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是好像突然收到",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "客戶的聯絡，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n父親大人和母親大人",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都跑去見客戶了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他們說新年問候",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是很重要的。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然我也能跟著去，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但那之後",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一定會開始談生意，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也不好打擾他們。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以我",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就先回來了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就這樣回家也很無趣，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要邀請誰的話，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "新年期間",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "又不太方便……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我本來",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "正為此煩惱著。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "然後，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就剛好看到你了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你是接下來才要去新年參拜，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那我就再去一次好了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n反正多一點保佑也不會造成困擾呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你也會去抽籤吧？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那邊應該也蠻多人排隊的，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我就陪你一起吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和父親大人他們一起抽的。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n順帶一提",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我是抽到小吉。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不好",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也不壞，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是很微妙的結果呢……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "變坦率的話運勢會變好，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "籤上好像是寫",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "類似這樣的話。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我現在這樣",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也很坦率了吧？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對吧？",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "難道是要我再更坦率嗎。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣的話……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就得要重新審視自己了呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是令人煩惱啊。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦～",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你這是否定的意思嗎？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不如說，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "像這樣說出有點彆扭回答的你，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n才是不坦率吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抽完籤要給我看喔。",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你的籤上，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一定也會寫著",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "「變得更坦率吧」。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然聊了一陣子。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但參道那邊",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還是很多人呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "聽說，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像是因為去年引起話題的電影，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有在這邊拍攝。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以才會有這麼多人。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然對神社的人來說是很開心的事，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但作為當地居民",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "心情有點複雜呢……",
        "unit_id": 102832
    },
    {
        "type": "still",
        "still": "133500402"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "其實啊，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和父親大人他們",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在中途就分開，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n讓我",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "覺得有點遺憾。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "明明很少有機會可以全家人一起度過，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n卻連新年期間",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都覺得工作更重要嗎？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我心裡這麼想……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但也只是想想而已，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這種話",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "實在是無法說出口。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我自己知道",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這是奢求。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很任性對吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n父親大人他們，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "絕對不是想要",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n忽視我，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這一點我也很清楚。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "以前，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們並不是那麼富裕的家庭，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以一到新年，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們就會一起看電視、",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "全家一起玩。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n很簡單地過年。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對於小時候的我來說，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那已經是十分特別的新年了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n父親大人的事業",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "上了軌道後，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大家都變得忙碌，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n全家一起度過的時間",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也變少了。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是啊。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "平時",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是不怎麼會在意，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但像今天這樣……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在熱鬧的",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "新年期間裡",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我卻是自己一人……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可能感到很不安吧。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n畢竟這裡明明有這麼多人，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "卻沒有任何人",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "能和我聊天嘛。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我找到你的時候……",
        "unit_id": 102832
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "133500403"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真的是",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很幸運呢。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們都有了能夠聊天的對象，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "算是雙贏？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊啊真是的……",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我為什麼",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "會想把心裡話全部說出來啊……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這樣",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很令人害羞耶……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n難道說，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "變坦率後會有好事……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "指的是這個？",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不不，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那也要分時間場合吧……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什、",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼事都沒有。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你不需要在意……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "…………",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……那個，",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我可以",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "問你一件事嗎。",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果……",
        "unit_id": 102832,
        "voice": "vo_adv_1335004_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我跟你說，",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n明年也想像這樣",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和你一起來新年參拜",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "的話……",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你會",
        "unit_id": 102832
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "實現我的願望嗎？",
        "unit_id": 102832
    },
