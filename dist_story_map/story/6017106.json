[
    {
        "type": "background",
        "background": "500351"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "【咲戀育幼院】的成員和",
        "unit_id": 109911,
        "voice": "vo_adv_6017106_000"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "【美食殿堂】的成員",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "大家好像都和雷姆相處得很好，我覺得很高興。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "她在羅茲瓦爾的宅邸",
        "unit_id": 109911,
        "voice": "vo_adv_6017106_001"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也一個人完成所有的家事。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n她在露格尼卡的時候就那個樣子，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "在蘭德索爾真的也幫了我大忙。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我也要",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "做點什麼來報恩才行。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "呵呵，",
        "unit_id": 109911,
        "voice": "vo_adv_6017106_002"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "謝謝。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不過，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "像這樣",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "對拉姆以外的人敞開心房",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是最近才開始的。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "而讓雷姆有所改變的昴，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "現在究竟跑到了哪裡去了――",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "初次見面就看到她手拿鐵球的話，",
        "unit_id": 109911,
        "voice": "vo_adv_6017106_003"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "可能真的會害怕……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "雷姆的確很強，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不過【美食殿堂】的成員",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也都相當強吧？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "所以，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "還請你不要害怕她哦。",
        "unit_id": 109911
    }
]