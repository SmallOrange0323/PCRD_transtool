[
    {
        "type": "background",
        "background": "500023"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聖誕節即將到來，瀰漫著愉悅氣氛的蘭德索爾街道……"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在離中心街道一小段路的巷子裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n【慈樂之音】的千歌正奮力奔跑著。"
    },
    {
        "type": "still",
        "still": "500900001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "哈啊，哈啊！",
        "unit_id": 104211,
        "voice": "vo_adv_5009000_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我不行了……！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "「記憶的大精靈霧奇」！",
        "unit_id": 104211,
        "voice": "vo_adv_5009000_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n比想像中還要危險，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我竟然解開了如此不得了的封印……！？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊，",
        "unit_id": 104211,
        "voice": "vo_adv_5009000_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "要忘記了！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "逐漸缺少，",
        "unit_id": 104211,
        "voice": "vo_adv_5009000_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "逐漸消失，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "逐漸地失去！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我就快要",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "忘記一切了！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "將要忘記唱歌的喜悅，",
        "unit_id": 104211,
        "voice": "vo_adv_5009000_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還有身為【慈樂之音】站在舞台上的激昂情緒！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n還有面對{player}，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n有生以來第一次感受到的溫暖心情！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊啊，",
        "unit_id": 104211,
        "voice": "vo_adv_5009000_005"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "全部都要遺忘了！",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "至今是如何走路的呢？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "如何呼吸？",
        "unit_id": 104211,
        "voice": "vo_adv_5009000_006"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　心臟如何跳動？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "究竟是如何？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我……？",
        "unit_id": 104211,
        "voice": "vo_adv_5009000_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　我是什麼？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n誰？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "　我連那個",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "都忘了……？",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "啊……",
        "unit_id": 104211,
        "voice": "vo_adv_5009000_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗚、",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗚嗚……",
        "unit_id": 104211
    },
    {
        "type": "background",
        "background": "500023"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "…………",
        "unit_id": 104211,
        "voice": "vo_adv_5009000_009"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "此時，{player}和寄宿的\n【咲戀育幼院】的孩子們一起\n出門採買食物和生活用品。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "順利的買完東西，大家開心地回家途中。"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼哼哼～♪",
        "unit_id": 102311,
        "voice": "vo_adv_5009000_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就快要到",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "愉快的聖～誕～節～了～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸，欸嘿……",
        "unit_id": 102111,
        "voice": "vo_adv_5009000_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n天氣這麼冷也很有精神呢，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "綾音……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真是的！　胡桃，我不是說過很多次了，",
        "unit_id": 102311,
        "voice": "vo_adv_5009000_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不能叫「綾音」，要叫「綾音姊姊」？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "就是啊，胡桃～",
        "unit_id": 2111,
        "voice": "vo_adv_5009000_013"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n對人總是那麼見外不太好喔。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我們是在【咲戀育幼院】感情很好地睡同一張床，",
        "unit_id": 2111,
        "voice": "vo_adv_5009000_014"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n在同一張餐桌吃飯，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "一起生活的家人不是嗎？",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼哼♪",
        "unit_id": 102311,
        "voice": "vo_adv_5009000_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "妳看，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "連噗吉都這麼說了！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "不過，",
        "unit_id": 2111,
        "voice": "vo_adv_5009000_016"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音比同年紀的人還要像孩子呢……",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n要說沒有『姊姊的樣子』的話，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n的確是這樣沒錯呢。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦咦？",
        "unit_id": 102311,
        "voice": "vo_adv_5009000_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　好過分喔，噗吉～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "老是愛多嘴！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n再這樣捉弄人，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "小心我在不可燃垃圾日把你給丟了喔？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "…………",
        "unit_id": 2111,
        "voice": "vo_adv_5009000_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦，咦咦？",
        "unit_id": 102311,
        "voice": "vo_adv_5009000_019"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對不起！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "剛才是騙你的，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "說笑的說笑的！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我竟然說了這種無心的話，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "像我這種壞孩子，聖誕老人不會來找我吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "…………",
        "unit_id": 2111,
        "voice": "vo_adv_5009000_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗚哇啊啊啊！",
        "unit_id": 102311,
        "voice": "vo_adv_5009000_021"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　噗吉不回答我！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n對不起啦對不起啦，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我道歉就是了，原諒我！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "絕對不會把你丟掉的，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我會永遠和噗吉在一起……！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇哇……",
        "unit_id": 102111,
        "voice": "vo_adv_5009000_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "走路不好好看路的話會跌倒唷，綾音，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n天氣很冷，路面都結凍了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇呀啊！？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃！？",
        "unit_id": 102311,
        "voice": "vo_adv_5009000_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "　沒事吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯，嗯……",
        "unit_id": 102111,
        "voice": "vo_adv_5009000_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿嘿，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我真沒用啊……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n剛才還自以為是的要綾音小心，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n結果自己反倒跌倒了……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "妳、",
        "unit_id": 102311,
        "voice": "vo_adv_5009000_025"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "妳沒受傷吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n要小心喔～？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯。",
        "unit_id": 102111,
        "voice": "vo_adv_5009000_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我沒事啦……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為{player}哥哥",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n他馬上抱住我了……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿……",
        "unit_id": 102111,
        "voice": "vo_adv_5009000_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "謝謝你，哥哥……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n馬上就要到快樂的聖誕節了，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n要是受了傷在床上動彈不得的話，就太慘了嘛……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_5009000_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "聖誕夜要和育幼院的大家一起開派對呢，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n要是受傷還是感冒的話就糟糕了！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "難得的聖誕節就會變成討厭的回憶呢～？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿，",
        "unit_id": 102111,
        "voice": "vo_adv_5009000_029"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真的好期待……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "第一次和育幼院的大家",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "一起過聖誕節……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯，",
        "unit_id": 102311,
        "voice": "vo_adv_5009000_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要好好玩個痛快！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n和【咲戀育幼院】的大家一起，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "和家人一起過呢……♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗯……♪",
        "unit_id": 102111,
        "voice": "vo_adv_5009000_031"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "　要將育幼院全部裝飾起來，",
