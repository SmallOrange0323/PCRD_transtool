        "voice": "vo_adv_5213322_000"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "使不上",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "力氣了……",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──嗯。",
        "unit_id": 129711,
        "voice": "vo_adv_5213322_001"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n看來敵方意圖削弱我方戰力。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若任此局面持續，咱們恐怕逐漸陷入窘境，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "或遭扼喉之憂。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "欸嘿嘿，",
        "unit_id": 20111,
        "voice": "vo_adv_5213322_002"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "再這樣下去，就要輸掉了哈尼～♪",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……哈尼。",
        "unit_id": 126512,
        "voice": "vo_adv_5213322_003"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "蜜蜂。",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "既然是蜂。",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……那麼針鋒相對，",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "以毒攻毒。",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "既然對方打算弱化我方，",
        "unit_id": 126512,
        "voice": "vo_adv_5213322_004"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n那麼我們也弱化對方就行了。",
        "unit_id": 126512
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "嗚咿咿咿！！",
        "unit_id": 20111,
        "voice": "vo_adv_5213322_005"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n就、",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "就就……",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "就算那樣，",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n我覺得也贏不了啦……！！",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129711,
        "voice": "vo_adv_5213322_006"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n這一箭可謂正中紅心。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n一語中的，說得分毫不差。",
        "unit_id": 129711
    }
]