[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊嗚……",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n肉～我想吃肉……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "【哞哞自衛隊】負責煮飯的人每天都會輪替……",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_001"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "輪到追求健康的真步和素食主義的霞煮飯時，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "菜單真的會讓人小不滿呢……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然她們說有意見的話就自己來煮。",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我自己是很喜歡下廚啦～所以也沒差。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過給我做的話，那每天每餐都會變成我故鄉的料理呀～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在蘭德索爾又不好取得材料，餐費會變得更貴呢。",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n而且【哞哞自衛隊】其實也蠻缺經費的呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這可會讓公會的經營更困難呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且呢，既然都到遠離故鄉的地方生活呀，",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n吃飯時也會想要吃一些當地的東西呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "俗話說入鄉隨俗呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "要繼續在這個城鎮裡生活的話，",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不管是肚子還是舌頭，都應該配合蘭德索爾調整呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯……",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n今天早上是霞負責煮飯，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以一大早就只吃了蔬菜～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗚嗚，我想要攝取一些蛋白質呀……",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "肉～我想吃肉……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哇？",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對、對不起～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我撞到你了啊～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀，是你呀！",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨──呵♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你在這裡做什麼呀～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯。你的肚子餓了但是卻沒有錢，",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以想來聞聞菜香裝作吃過了，再繼續忍耐？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真是辛苦呢～好像修行一樣……？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，這樣的話，你想不想和我一起去那邊的燒肉店？",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我的肚子也餓了呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過一個人去吃燒肉感覺好像很寂寞呢……？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "霞她也有說過，",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一個人吃燒肉和一個人唱歌，是世上最寂寞的事情呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然霞講的事情基本上我都搞不太懂啦，",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過這一點我倒是同意的呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一個人真是太寂寞了……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯，費用的部分就由我來請吧～",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n算是之前你幫我採收那些像苦瓜的東西的謝禮呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "沒關係啦，你不用客氣和我一起去吃燒肉吧～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你看你看，上頭還寫著情侶有折扣呢～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "情侶就是指男女成對吧，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣我和你就是情侶啦～？對吧～♪",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～我還是第一次來燒肉店呢～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你也是第一次啊？",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這樣呀，那我們兩個一樣呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "剛開始做新的事情，總是讓人很興奮呢～啊哈～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我看看。肉的部分不用自己切，",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_018"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n店員會幫我們拿過來的呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過烤的部分就要自己來了啊～嗯嗯？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "……嗯嗯？",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "問你喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n菜單上面有些詞我看不懂啦～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "「板腱」是什麼啊～是一種內臟嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯～好困難呀～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "算了，看不懂的話問店員就好了！",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_021"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "船到橋頭自然直啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你也點一些自己喜歡的東西吧！",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_022"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "你想要吃哪種肉呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈～這樣呀～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "其實我也一樣呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我們就把上頭寫著店員推薦的東西，",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n都點個一輪吧～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我也只要是肉都喜歡～我的身體想要蛋白質呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊？",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那你為什麼要來燒肉店呀～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是因為要陪我嗎～？",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然很謝謝你，不過我沒有要勉強你的意思呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "總覺得有點對不起呢？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我覺得你呀，",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n要多多將自己的意見之類的表達出來呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過，我平常也都一直在說自己的意見。",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "說不定我和你加起來平均一下，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就剛剛好了呢～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈～",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n總之我們就來點餐吧～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不好意思～這裡點餐～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "欸嘿嘿～真是期待呀～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_030"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "肉肉，吃肉囉～♪",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_031"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "感覺心情好興奮，都想要來跳個舞了呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯嗯？",
        "unit_id": 101711,
        "voice": "vo_adv_1017005_032"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n你也一樣啊？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
