    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個海岸，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好久不見了喵。",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n好懷念喵～！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "平安無事地到達真是太好了呢……！",
        "unit_id": 103411,
        "voice": "vo_adv_5005007_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "來來，",
        "unit_id": 103211,
        "voice": "vo_adv_5005007_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼既然事情告一段落，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n寶藏也拿到了，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "今天就來舉辦解決事件的慶功宴！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "大家都要穿泳衣參加唷！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "太好了！",
        "unit_id": 103411,
        "voice": "vo_adv_5005007_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "當然應該有喝到飽吧！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "優花梨，腦袋裡總是只有喝喵！",
        "unit_id": 107911,
        "voice": "vo_adv_5005007_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也邀請{player}大人",
        "unit_id": 103211,
        "voice": "vo_adv_5005007_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "一起參加！",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，\n回到現實的【墨丘利財團】和{player}，\n決定在瑪爾傑海岸慶祝一番。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼，",
        "unit_id": 108011,
        "voice": "vo_adv_5005007_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "慶祝事情解決＆獲得寶藏，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "乾杯──！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "4人",
        "words": "乾杯──！",
        "unit_id": 1,
        "voice": "vo_adv_5005007_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咕嚕、咕嚕、咕嚕、咕嚕、咕嚕……",
        "unit_id": 103411,
        "voice": "vo_adv_5005007_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "噗哈，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這一杯真是幸福得讓人受不了～！",
        "unit_id": 103411
    },
    {
        "type": "still",
        "still": "500500701"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "幸福",
        "unit_id": 108011,
        "voice": "vo_adv_5005007_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗎……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "雖然我們對島鯨說得很有氣勢，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不過說真的，放棄那座島的生活也有點可惜呢～",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "自己專用的訓練場、",
        "unit_id": 108011,
        "voice": "vo_adv_5005007_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "特別的SPA、",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "按摩……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n在想睡的時候睡覺，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "在想起床的時候起床……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "日常生活貓咪們什麼都會幫我做喵。",
        "unit_id": 107911,
        "voice": "vo_adv_5005007_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n只要道謝，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "貓咪們就會很開心喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鬆軟的床、",
        "unit_id": 107911,
        "voice": "vo_adv_5005007_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好吃的飯……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "心境上可說是度假了一個夏天的感覺呢……",
        "unit_id": 108011,
        "voice": "vo_adv_5005007_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n今年過了個……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "很棒的夏天啊！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "哦～",
        "unit_id": 103411,
        "voice": "vo_adv_5005007_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在我們擔心的時候，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "竟然遇到了那麼開心的事呢～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n真是的，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好狡猾～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "即、",
        "unit_id": 107911,
        "voice": "vo_adv_5005007_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "即使如此，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那也不過是幻覺喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n而且繼續那樣待下去的話也會死嘛！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不顧危險",
        "unit_id": 107911,
        "voice": "vo_adv_5005007_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "跑來救我們的【墨丘利財團】最棒了喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯！",
        "unit_id": 103411,
        "voice": "vo_adv_5005007_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "拚了老命呢～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳們兩個不見之後，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n剩下的工作該怎麼辦才好，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "珠希在其它店簽帳的錢還了沒有，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這些都讓我擔心得坐立不安呢～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是啊是啊，",
        "unit_id": 103211,
        "voice": "vo_adv_5005007_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們只要少了誰的話，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n其它人就必須工作到",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "徹夜難眠的程度呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "欸……？",
        "unit_id": 108011,
        "voice": "vo_adv_5005007_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們不在之後晚上都睡不著，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n原來是這個意思……？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "然後，",
        "unit_id": 103411,
        "voice": "vo_adv_5005007_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "為了救出妳們兩位所花費的\n這次的費用，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在這裡～♪",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n請看！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "帳單！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "欸！？",
        "unit_id": 108011,
        "voice": "vo_adv_5005007_024"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "個、十、百、千……",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "三千萬盧幣！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳、",
        "unit_id": 107911,
        "voice": "vo_adv_5005007_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳們不是也獲得寶藏了嗎喵！？",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不不，",
        "unit_id": 103211,
        "voice": "vo_adv_5005007_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就算賣了從島鯨身上獲得的貓幣，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n也完全不夠付呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n可不能小看",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "飛空艇的燃料費和",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "船的租金喔。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "等等……",
        "unit_id": 108011,
        "voice": "vo_adv_5005007_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這是，開玩笑的吧！？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不，",
        "unit_id": 103411,
        "voice": "vo_adv_5005007_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是真的唷～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n為了收回這些錢",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳們兩位要給我好～",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "好地工作唷～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒、沒人性！",
        "unit_id": 107911,
        "voice": "vo_adv_5005007_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "冷血的傢伙！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "最差勁了喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如、",
        "unit_id": 107911,
        "voice": "vo_adv_5005007_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果是這樣的話，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "果然應該待在島上就好了喵──！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "果然我，",
        "unit_id": 108011,
        "voice": "vo_adv_5005007_031"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "最討厭奢侈什麼的啦──！",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不會讓妳們逃走喔！",
        "unit_id": 103411,
        "voice": "vo_adv_5005007_032"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我會讓妳們扎扎實實地工作──！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "等等",
        "unit_id": 107911,
        "voice": "vo_adv_5005007_033"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我再去叫醒島鯨一下喵──！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\nCOME BA────CK！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "夢之島────！",
        "unit_id": 107911
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，多虧同伴幫忙平安歸來的珠希和美冬，\n再度為了逃離現實，在海岸上奔跑起來。"
    }
