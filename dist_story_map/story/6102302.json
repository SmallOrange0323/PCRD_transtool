[
    {
        "type": "background",
        "background": "501870"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "最近鈴閣下她啊，",
        "unit_id": 123711,
        "voice": "vo_adv_6102302_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "遊戲技巧大幅提升了呢～",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n明明之前還是一副玩興趣的，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "感覺強度普通而已說。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這下我搞不好也不能再散漫囉！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那感覺有點難度過高耶～",
        "unit_id": 123711,
        "voice": "vo_adv_6102302_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "依里閣下她，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n說不定是蘭德索爾數一數二強的，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是嗎？",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "目標還是要放高一點對吧！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "超越依里閣下，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就以這為目標！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "特訓……！",
        "unit_id": 123711,
        "voice": "vo_adv_6102302_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這個充滿少年漫畫感的詞彙",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "令人熱血澎湃啊！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n既然這麼決定了，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那就來練個必殺技吧！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "像是學會16連射、\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "或是練出看到對手助跑跳起都還來得及在半空中回擊的反射神經！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔唔……",
        "unit_id": 123711,
        "voice": "vo_adv_6102302_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這提問很深奧呢。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然打贏了當然很高興，",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過畢竟遊戲的魅力",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不只如此嘛。",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……我打算繼續",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "按照自己的步調來玩遊戲，不勉強自己！",
        "unit_id": 123711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "謝囉！",
        "unit_id": 123711
    }
]