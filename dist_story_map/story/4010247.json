    {
        "type": "dialogue",
        "name": "斜",
        "words": "哇啊……！",
        "unit_id": 136231,
        "voice": "vo_adv_4010247_000"
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n有好多甜甜圈～！",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "可以嗎可以嗎？",
        "unit_id": 136231,
        "voice": "vo_adv_4010247_001"
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n真的可以",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "全部吃掉嗎？",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "斜會全～",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "部吃光光喔？",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "嘿嘿，",
        "unit_id": 136231,
        "voice": "vo_adv_4010247_002"
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "謝謝～！",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "這麼豪華的生日，",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "斜還是頭一次體驗到♪",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "嚼嚼嚼……",
        "unit_id": 136231,
        "voice": "vo_adv_4010247_003"
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "甜蜜蜜～♪",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "哈，",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "真幸福……",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n今天的晚餐有這個就夠了。",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "是～",
        "unit_id": 136231,
        "voice": "vo_adv_4010247_004"
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "……被罵了啦，",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "嘿嘿。",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "……最近庫露露雖然會來找斜玩，",
        "unit_id": 136231,
        "voice": "vo_adv_4010247_005"
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n但我們都有",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "打工之類的事要忙，時間常常對不上……",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "你願意像這樣",
        "unit_id": 136231,
        "voice": "vo_adv_4010247_006"
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "陪在斜的身邊，",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "甚至",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "還幫斜慶祝生日，",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n斜真的",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "超級超級",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "開心的啦～♪",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "畢竟",
        "unit_id": 136231,
        "voice": "vo_adv_4010247_007"
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "兔子太寂寞的話可是會死掉的♪",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "啊，",
        "unit_id": 136231,
        "voice": "vo_adv_4010247_008"
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "對了！",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "把你的生日告訴斜吧！",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "下次換斜來幫你慶祝！",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "雖然可能不會",
        "unit_id": 136231,
        "voice": "vo_adv_4010247_009"
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "像今天這麼豪華……",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "但斜會用",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "同等的誠意",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "盡全力幫你",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "好好慶祝的！",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "\n斜要讓你",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "跟現在的斜一樣，",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "覺得",
        "unit_id": 136231
    },
    {
        "type": "dialogue",
        "name": "斜",
        "words": "「今年肯定會是個好年！」♪",
        "unit_id": 136231
    }
