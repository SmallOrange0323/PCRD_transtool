    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "那個……",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_043"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "不是這樣的……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "那些人",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "全都是患者。",
        "unit_id": 1412
    },
