        "voice": "vo_adv_1247001_056"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "去把支援的醫生找來！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n請稍等──",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "奇怪？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "醫生呢？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "咦？",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_057"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好了，",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_058"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "請多保重。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "下一位～",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "喂，我說你，",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_059"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "{player}！",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你要摸魚到什麼時候？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n快點來幫忙。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "醫、",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_060"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "醫生？",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "您不是說在支援來之前不看診的嗎──",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你在說什麼啊？",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_061"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我會一個都不剩地",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_062"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "幫他們看診治療的。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "為患者看診",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是醫生的職責，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是使命。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還有呃～",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我想想，那個啦，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是存在的理由喔。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "咦……",
