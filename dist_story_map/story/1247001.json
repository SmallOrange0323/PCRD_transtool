[
    {
        "type": "background",
        "background": "500670"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新年。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n待在溫泉旅館的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n遇見了在大廳角落嘆氣的深月。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唉……",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真討厭。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "為什麼才剛過年就這樣。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算是厄年也太慘了，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不是厄年的話就更慘了……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……啊？",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對吧？",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可以聽我說嗎？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我被人拜託了，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要我開設「年初診所」。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊，",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "年初診所指的是……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n在醫院休診的新年期間，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n為這間旅館的急診患者診療的臨時診所？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大概是這樣。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我很困擾呢，",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "莫名地這麼信任我。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唉，",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要說是自作自受的話，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也沒錯啦。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "畢竟我最近",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "老～是在幫助人呢……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "救人、",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "救旅館、",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "救醫院？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就我來說，實在是做過頭了。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "啊～找到了，",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_008"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "小深醫生！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "……還真熱鬧耶。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……什麼？",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_009"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "啊，不。",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_010"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "別管那個了。醫生，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "關於年初診所，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "真是抱歉！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n這樣硬是拜託醫生。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "但醫師肯來真的幫大忙了～",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_011"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n每年都會來的醫師突然說有事不能來……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "唉呀～這種事，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "只能拜託小深醫生啊。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "診療室在那邊，",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_012"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "我已經準備好了。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n要是有什麼不方便的，請馬上跟我說！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "那麼這件事",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "就拜託了！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "小深醫生！",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……知道了知道了。",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……剛才的",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你聽到了嗎？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "「小深醫生」是誰啊？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n那種對善良又好親近的醫生才會用的親暱稱呼，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "希望他別再這麼叫了。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "才不是呢！！",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_015"
    },
    {
        "type": "still",
        "still": "124700101"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……我說啊。",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n大家可能都忘記了。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但我",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是密醫耶？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是祕密的",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "醫生喔。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "祕密，",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是在暗中喔？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是地下工作喔？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是非法的喔？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你說哪個世界的密醫會善良又好親近啊。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說起來啊──",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_018"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "欸～欸～小深醫生，",
        "unit_id": 211,
        "voice": "vo_adv_1247001_019"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "妳戴在眼睛上的這個是什麼啊～？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n為什麼要遮住眼睛？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我可以拉拉看嗎～？",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……說、",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "說起來！",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我不知道已經說過多少次了，",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我做醫生，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過是順勢而為罷了。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我的本行是研究者。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "開發新藥所需的費用，",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "實在是太過龐大了。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n一般來說，可是需要大企業賭上公司命運才有辦法負擔的呢。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而我一個獨行俠",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要自己負擔起這些──",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客1",
        "words": "不過，",
        "unit_id": 311,
        "voice": "vo_adv_1247001_023"
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客1",
        "words": "我能理解孩子們為什麼會喜歡妳。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客1",
        "words": "\n既溫柔，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客1",
        "words": "技術又高超。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客1",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客1",
        "words": "小深醫生，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客1",
        "words": "真的是個好醫生呢。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客2",
        "words": "對啊。",
        "unit_id": 1511,
        "voice": "vo_adv_1247001_024"
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客2",
        "words": "\n大人們也是，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客2",
        "words": "即使沒有哪裡不舒服，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客2",
        "words": "也會像這樣聚集在這裡。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客2",
        "words": "\n小深醫生的存在本身就能讓大家放鬆呢。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "溫泉顧客2",
        "words": "呵呵呵。",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我一個獨行俠要自己負擔起這些，所以啊？",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以，",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我才選擇當「密醫」。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n因為要是不從黑社會那些不擇手段賺錢的人身上",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "榨取高額治療費，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n實在難以籌到開發費用啊。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可是呢？",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果善良醫生的形象就這麼定型了，",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n時間安排與對外的形象，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "都會使得密醫工作難以進行，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n那麼開發新藥所需的金錢和時間",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也都會一同失去。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以我",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "非得維持密醫的身分不可。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n難以理解、",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "令人敬畏、",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "難以親近的──",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊～我知道了！",
        "unit_id": 211,
        "voice": "vo_adv_1247001_030"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "這個，",
        "unit_id": 211
    },
    {
