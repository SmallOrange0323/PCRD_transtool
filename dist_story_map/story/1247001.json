    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "非得先告訴小深醫生不可……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "什麼？",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_048"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我不太想繼續聽下去就是了……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "對，",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_049"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "正式名稱是",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "「地下職業夥伴新年事始會」。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n簡稱地新會，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "我們是這麼稱呼的。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "每年從除夕到新年結束，",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_050"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "他們會把我們頂樓的大房間，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n也就是寬敞套房一口氣包下來舉辦活動。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "據說黑社會的各團體與個人會齊聚一堂，",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_051"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n在除夕以溫泉洗去罪孽後，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "整個新年期間",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "持續舉行盛大的宴會……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "是黑社會新年的例行公事。",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_052"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "嗯，總之大家",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_053"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "都血氣方剛，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n喝酒方式不太尋常……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "所以傷患、",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "以及因小紛爭而受傷的人源源不絕……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "沒錯，",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_054"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "幾乎100%",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "都是黑社會的人。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "溫泉旅館新年期間，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "有錢但有些問題的客人會在此集會，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n成為他們的聚集地……",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "歹勢！",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_055"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n若是一開始就說出來，",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "我想醫生一定會拒絕，所以……",
