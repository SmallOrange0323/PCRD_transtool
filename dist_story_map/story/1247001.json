        "words": "\n作為臨時診所的房間──"
    },
    {
        "type": "dialogue",
        "name": "患者們",
        "words": "（人聲嘈雜……）",
        "unit_id": 1,
        "voice": "vo_adv_1247001_040"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……這個患者數是怎麼回事？",
