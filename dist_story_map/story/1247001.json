        "voice": "vo_adv_1247001_041"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "都已經在排隊了耶？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大過年的，溫泉旅館患者為什麼會這麼多？",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_042"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n是把這裡誤認為大浴場了吧？",
