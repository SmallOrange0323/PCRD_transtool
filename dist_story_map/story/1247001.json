        "voice": "vo_adv_1247001_046"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "那個，",
        "unit_id": 1412,
        "voice": "vo_adv_1247001_047"
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "其實啊。",
        "unit_id": 1412
    },
    {
        "type": "dialogue",
        "name": "領班",
        "words": "\n我有件事，",
