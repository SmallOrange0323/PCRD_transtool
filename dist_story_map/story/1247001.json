    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦咦？",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_044"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "給我等一下。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這麼多人，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我處理不完啦。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我說，",
        "unit_id": 124711,
        "voice": "vo_adv_1247001_045"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "叫支援的醫生來吧，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我自己一個是看不完的。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n努力找還是能找到的吧？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n在支援人手來之前，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我不想開始看診。",
