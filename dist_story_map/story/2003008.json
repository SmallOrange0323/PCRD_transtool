[
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……若是不記得的話，",
        "unit_id": 102511,
        "voice": "vo_adv_2003008_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就表示您不是大小姐。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "您說多虧了我的迷糊，",
        "unit_id": 102511,
        "voice": "vo_adv_2003008_001"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n讓您得以緩解緊張，完成了演說…………",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n還說我的迷糊總是幫助著您。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "您並不是那位笑著對我這麼說的，",
        "unit_id": 102511,
        "voice": "vo_adv_2003008_002"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我所尊敬、服侍的主人。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    }
]