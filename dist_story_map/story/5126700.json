[
    {
        "type": "background",
        "background": "500081"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在臨近期末考的某天放學後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}為了拿忘記的東西而走進教室時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看見正在一個人自習的凱留。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很好……",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這邊的參考書已經全部記起來了。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼接下來",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就換這本題庫……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎呀，",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你忘了拿東西嗎？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都快要考試了還忘記帶課本回家，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真是迷糊欸～",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯～",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我要再念一下書。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……你也有",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好好在念書準備考試嗎？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……啊──",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不用回答沒關係。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我看你的臉就懂了。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "至少努力不要不及格吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不要沮喪得那麼明顯啦……",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你幹嘛露出像被遺棄的小貓一樣的眼神！？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我為什麼得教你啊。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別在我回答你之前就開始拿出課本啊！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我、",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我知道了啦。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n真拿你沒辦法，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就教你吧……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我話說在前頭，",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這可不是為了你喔！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只不過是因為教導不會的人，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "自己也可以複習罷了……！！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這些全都是",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為了我自己準備考試才做的！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "懂了嗎！？",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……你明白就好。",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然要教就要徹底一點……",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了……",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是我今天在合作社買的鉛筆。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……因為是兩根一組在賣的，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就送給你一根吧。",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "{player}！",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n直到考試前就努力念書，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把這枝鉛筆用到手握不住的程度吧！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然我要教你，",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你就要以目標成為年級第二名的氣勢來努力！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……你說不用把第一名當目標嗎？",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼哼，",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為第一名會是我的！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 127214,
        "voice": "vo_adv_5126700_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那我們開始吧！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n把課本打開！",
        "unit_id": 127214
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "凱留和{player}兩人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了準備考試，就這樣開始一起念書了。"
    }
]