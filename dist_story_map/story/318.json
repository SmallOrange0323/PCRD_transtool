    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "緊急狀態！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這是緊急狀態！！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我代表公會管理協會，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "立刻宣布進入緊急狀態！！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "上次，",
        "unit_id": 190811,
        "voice": "vo_adv_0000318_001"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "委託討伐的魔物",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "好像得到前所未有的力量，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n再次前來向各位挑戰！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "但是……",
        "unit_id": 190811,
        "voice": "vo_adv_0000318_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請看。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "透過這次的活動，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "與您締結了強烈羈絆的眾人，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n表情明顯不同。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "看起來充滿了力量！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您與大家之間",
        "unit_id": 190811,
        "voice": "vo_adv_0000318_003"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "細心培育的「羈絆之力」……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這點應該",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "能成為您最大的武器。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "編組最佳隊伍，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "迎接這場決戰吧！",
        "unit_id": 190811
    }
]