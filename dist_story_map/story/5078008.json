[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "黑暗力量互相角力的戰鬥結束，蘭德索爾恢復了和平。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但是在事件解決之後，城裡發生了異變，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n返回城內的魔法少女們察覺到氣氛有異，開始採取行動。"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "──都到齊了嗎，",
        "unit_id": 114211,
        "voice": "vo_adv_5078008_000"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "各位。",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "是的，",
        "unit_id": 112311,
        "voice": "vo_adv_5078008_001"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "Lovely★莫妮卡。",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "大家都到齊了。",
        "unit_id": 114311,
        "voice": "vo_adv_5078008_002"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "那麼Misty★霞。",
        "unit_id": 114211,
        "voice": "vo_adv_5078008_003"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n麻煩妳報告調查狀況。",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "嗯，",
        "unit_id": 112211,
        "voice": "vo_adv_5078008_004"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我知道了。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n嗯……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "最近幾天，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我們四個人各自有事，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n因而離開了蘭德索爾……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "看來在這段期間，",
        "unit_id": 112211,
        "voice": "vo_adv_5078008_005"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "城裡出現了反逆獸的樣子。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "我也向【王宮騎士團】確認過了。",
        "unit_id": 114311,
        "voice": "vo_adv_5078008_006"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "普通攻擊完全無效的敵人……",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "是反逆獸沒錯。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "回來後感覺城裡的狀況很奇怪，",
        "unit_id": 112311,
        "voice": "vo_adv_5078008_007"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "\n是反逆獸造成的嗎？",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "\n",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "該說城裡很安靜才好……",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "還是人莫名其妙變少了才好……",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "不，",
        "unit_id": 112211,
        "voice": "vo_adv_5078008_008"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "根據我打聽到的消息，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n反逆獸……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "好像早就被打倒了。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "什麼？",
        "unit_id": 114211,
        "voice": "vo_adv_5078008_009"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n難道說，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "出現了新的魔法少女嗎！？",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "不是，",
        "unit_id": 112211,
        "voice": "vo_adv_5078008_010"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "這個嘛……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "接下來這部分",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "我也還沒有完全釐清情報內容……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "好像",
        "unit_id": 112211,
        "voice": "vo_adv_5078008_011"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "說是",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "有個奇怪的三人組，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n一邊將城裡的居民們變成學生……",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "又或者是變成被虐狂，",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n莫名其妙地拯救了城鎮",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "什麼的。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "妳剛剛說了被虐狂嗎？",
        "unit_id": 1,
        "voice": "vo_adv_5078008_012"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "總、",
        "unit_id": 114211,
        "voice": "vo_adv_5078008_013"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "總之，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "先不提那個令人在意的詞，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n變成學生還真是難以理解……",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "那麼，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "所謂奇怪的三人組又是？",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "呃……",
        "unit_id": 112211,
        "voice": "vo_adv_5078008_014"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "聽說他們在城外建了個基地。",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "城裡似乎有不少人",
        "unit_id": 114311,
        "voice": "vo_adv_5078008_015"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "也都聚集在那裡。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n好像連【王宮騎士團】也有好幾個隊員參與其中。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n應該可以看做是規模相當龐大的組織吧。",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "唔……",
        "unit_id": 114211,
        "voice": "vo_adv_5078008_016"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "身為魔法少女，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "似乎不能對此事置之不理啊。",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "就是說啊。",
        "unit_id": 112311,
        "voice": "vo_adv_5078008_017"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "搞不好，",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "這件事",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "會是將要展開的戰鬥前兆，",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "\n",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "說不定已有比反逆獸",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "更巨大的邪惡誕生了……！",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "\n",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "或許這正是",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "魔法少女漫長的戰鬥即將揭開序幕的時刻……！",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "妳是不是很期待呀？",
        "unit_id": 112211,
        "voice": "vo_adv_5078008_018"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "栞……？　",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "很好！",
        "unit_id": 114211,
        "voice": "vo_adv_5078008_019"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n那麼，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "我們就馬上",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "朝那什麼基地出發吧！",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n身為魔法少女，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "讓我們親自確認該組織的真面目！",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "喔──！",
        "unit_id": 1,
        "voice": "vo_adv_5078008_020"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "這麼說來，",
        "unit_id": 114211,
        "voice": "vo_adv_5078008_021"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "摩拉那傢伙跑哪去了？",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n這種時候",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "牠應該會最先出現才是……",
        "unit_id": 114211
    },
    {
        "type": "background",
        "background": "501450"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "這裡就是",
        "unit_id": 112311,
        "voice": "vo_adv_5078008_022"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "基地……",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "的確很有那種氣氛。",
        "unit_id": 114311,
        "voice": "vo_adv_5078008_023"
    },
    {
        "type": "dialogue",
        "name": "路上的人們",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_5078008_024"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "雖然想辦法混進了人群裡，",
        "unit_id": 112211,
        "voice": "vo_adv_5078008_025"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "\n但這到底是什麼集會啊……？",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "天知道，",
        "unit_id": 114211,
        "voice": "vo_adv_5078008_026"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "雖然什麼都不清楚，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n卻感覺有種邪惡的氣息……",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "嗯？",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "那是……",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "唉……",
        "unit_id": 4211,
        "voice": "vo_adv_5078008_027"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "我還真是做了件不得了的事……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "摩拉！",
        "unit_id": 114211,
        "voice": "vo_adv_5078008_028"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n這不是摩拉嗎！",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "咦！？",
        "unit_id": 4211,
        "voice": "vo_adv_5078008_029"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "莫、",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "莫妮卡！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n大家也都在！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "妳們回來了是嗎！？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "嗚哇──",
        "unit_id": 4211,
        "voice": "vo_adv_5078008_030"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "大家，該怎麼辦才好！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "我、",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "我、",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "身為魔法生物，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n或許做了件很不得了的事……！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "請先冷靜下來，",
        "unit_id": 112311,
        "voice": "vo_adv_5078008_031"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "摩拉。",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "\n",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "到底發生了什──",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "──大家，",
        "unit_id": 119011,
        "voice": "vo_adv_5078008_032"
    },
    {
        "type": "dialogue",
        "name": "黑暗伊緒",
        "words": "早安～♪",
        "unit_id": 119011
    },
    {
        "type": "dialogue",
        "name": "路上的人們",
        "words": "喔喔喔喔喔──────！",
        "unit_id": 1,
        "voice": "vo_adv_5078008_033"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "唔哇！？",
        "unit_id": 114311,
        "voice": "vo_adv_5078008_034"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
