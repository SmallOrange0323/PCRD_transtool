[
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "前些日子的「蘭德索爾國際博覽會」的一連串事件，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n因涅妃‧涅羅想表示感謝\n而受邀請前往鬼岩城寨的{player}，但……"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "──歡迎，",
        "unit_id": 50811,
        "voice": "vo_adv_1382001_000"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "歡迎！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n進貨了",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "不錯的魔物肉喔！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n只要好好去掉致命的毒，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "那多汁的程度可是會好吃到讓人掉下巴！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "現在買的話，",
        "unit_id": 1,
        "voice": "vo_adv_1382001_001"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "巴西利斯克的眼珠竟然還打七折！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n雖然因為還殘留著魔力，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "對上眼的話就會石化，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n但只要小心食用，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "入口即化的美味肯定會",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "在口中擴散開來！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如此極其怪異的活動，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_002"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是在吉歐‧格黑納才有的意趣。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "在其他的世界，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "想必是極難見到的珍事吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "名為",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「大魔物市」",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "因為是幾年才舉辦一次的活動，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "稀有的魔物肉之類的東西",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n有時也會趁此機會",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "被拿出來販賣。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "是的～",
        "unit_id": 51611,
        "voice": "vo_adv_1382001_004"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "當皇女大人突然說出",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "想要邀請騎士閣下先生",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n前往危險的「大魔物市」時，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我真是嚇了一跳～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不過，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "既然有皇女大人在的話",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "應該就沒問題了～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "在前些日子的事件中，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_005"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "承蒙騎士閣下",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "給予非比尋常的深情厚意。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "依吉歐‧格黑納的禮數，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家希望能盡一點",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n報恩的心意。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "關於魔物飲食，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_006"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "觀察到恁",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "擁有許多的見識，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若是這「大魔物市」羅列的魔物，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "想必也能找到讓恁的舌頭",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n讚嘆不已的逸品吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若有中意的物品，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_007"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "請儘管",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "吩咐。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家想親手烹飪",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並款待騎士閣下。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n若恁能收下這點微薄的心意，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家將深感",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "榮幸。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "但是～",
        "unit_id": 51611,
        "voice": "vo_adv_1382001_008"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "請小心一點喔？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n因為也陳列著許多活力過頭的魔物～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我也曾有過好幾次",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "差點被整個吞掉的經歷～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並非值得張揚之事，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_009"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家平時應已告誡過汝。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……然而，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對於騎士閣下，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "則無須擔心。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如有什麼萬一，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家會以這副身軀為盾",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "守護恁的。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "啊，",
        "unit_id": 50811,
        "voice": "vo_adv_1382001_010"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "涅妃‧涅羅大人！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "居然能看上我們家的商品",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "真是深感光榮！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "如何，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "巨蛇的一夜乾！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "也可以試吃喔～",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "喔，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_011"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "試吃嗎？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這油脂分布可真漂亮。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呵呵……",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_012"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下呀。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n覺得如何呢？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n若恁不介意的話，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "請到奴家的身邊來。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "來吧，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_013"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「啊～」……♪",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "皇女大人竟然要親自",
        "unit_id": 51611,
        "voice": "vo_adv_1382001_014"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "對騎士閣下先生",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "「啊～」地餵食……！？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不對，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不對不對！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "那隻魔物帶有",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "強力的毒性喔～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n雖然已經去毒了，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "但騎士閣下先生想必也會猶豫的吧～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "咦咦～！？",
        "unit_id": 51611,
        "voice": "vo_adv_1382001_015"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n居、",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "居然一點猶豫都沒有……！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "不會太大膽了嗎～！？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "好極了，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_016"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "好極了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不愧是騎士閣下，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如此豪膽的模樣，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n正是英雄的行為。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "米亞呀。",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_017"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n汝也該學習騎士閣下的勇猛，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n稍微挺起胸膛，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "伸直尾巴才是。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "嗚嗚～",
        "unit_id": 51611,
        "voice": "vo_adv_1382001_018"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "即便對身為",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "文官的我這麼說～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "話說騎士閣下先生……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "該不會不是因為擁有豪膽，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n只是單純貪吃，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "應該不是這樣吧～？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "太過無禮了，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_019"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "笨蛋。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "要持有作為煉獄之民的驕傲──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "巨大的魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "嗚哇啊啊啊啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_1382001_020"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "這傢伙，\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "突然大鬧了起來！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "所以我才說別活捉的！",
        "unit_id": 1,
        "voice": "vo_adv_1382001_021"
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "\n就算鮮度跟稀有價值會下跌也一樣……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "巨大的魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "商人們",
        "words": "噫噫噫噫！？",
        "unit_id": 1,
        "voice": "vo_adv_1382001_022"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "沒想到呀。",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_023"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n話語剛落",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "隨即碰上──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下呀，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_024"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "請稍微退後一些。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那頭魔物，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "看來是氣血上湧，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "顯得相當暴躁易怒呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家明白。",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_025"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n正巧這時機也不錯，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那頭魔物，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "據說其美味程度亦是非比尋常。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "務必務必，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "要讓奴家以此珍味款待騎士閣下。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……若放血出了差錯，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_026"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "毀損了肉質，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "味道必然會大打折扣……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "然而，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這也是無可奈何之事。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n總不能眼睜睜看著商人們的性命，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "就這樣白白斷送──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "請等一下！",
        "unit_id": 50811,
        "voice": "vo_adv_1382001_027"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n涅妃‧涅羅大人！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "嗯……？",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_028"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "難得涅妃‧涅羅大人，",
        "unit_id": 50811,
        "voice": "vo_adv_1382001_029"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n打算要親手下廚款待客人……",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n若把食材給弄壞了，",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "那可就前功盡棄了！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "即使不依靠涅妃‧涅羅大人的力量，",
        "unit_id": 50811,
        "voice": "vo_adv_1382001_030"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n我們自己會想辦法解決的！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "雖然這麼說有些越權……",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "這邊就交給我們吧！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "對、",
        "unit_id": 1,
        "voice": "vo_adv_1382001_031"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "對啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n我們不能老是躲在涅妃‧涅羅大人的背後，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n受您的保護！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "我們可是吉歐‧格黑納勇猛的居民！",
        "unit_id": 1,
        "voice": "vo_adv_1382001_032"
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "\n為了讓涅妃‧涅羅大人能順利款待客人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "\n大家竭盡全力地",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人３",
        "words": "戰鬥吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人們",
        "words": "唔喔喔喔喔喔喔！！",
        "unit_id": 1,
        "voice": "vo_adv_1382001_033"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "啊，",
        "unit_id": 51611,
        "voice": "vo_adv_1382001_034"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "奇怪……！？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "總覺得，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "這個氣氛好像沒辦法讓我們在高處隔岸觀火呢～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我、",
        "unit_id": 51611,
        "voice": "vo_adv_1382001_035"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我明白了！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我明白了啦～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n雖然我覺得一定派不上用場，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我也會試著豁出去的！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n唔喔喔喔喔～～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……結果會如何呢。",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_036"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "事情演變成了意想不到的局面呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n究竟最後會迎來什麼結局呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不必為此擔憂。",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_037"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n若在此時由奴家出手干預，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那可真謂是掃興至極。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "最好的做法，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "應是靜觀其變吧。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "再者，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_038"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "受先前的「蘭德索爾國際博覽會」事件影響，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n吉歐‧格黑納",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "也正逐漸產生變化。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那是黎民百姓的轉變……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "亦是奴家內心的轉變。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "騎士閣下呀。",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_039"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n在守望彼些傢伙奮鬥的期間，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "希望能夠借用恁的雙耳。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "能否請恁稍微陪陪奴家，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "聽聽奴家的",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "一些閒談碎語呢？",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──時間回溯。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那是發生在「蘭德索爾國際博覽會」騷動期間的故事。"
    },
    {
        "type": "background",
        "background": "502091"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了尋找製作至高料理所需的傳說食材，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n涅妃‧涅羅獨自一人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "前往了位於吉歐‧格黑納深處的\n火山口──"
    },
    {
        "type": "dialogue",
        "name": "噴火橫綱豬神",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……喔。",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_040"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n這便是那傳聞中的",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "「噴火橫綱豬神」啊。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n如此雄偉壯碩的身軀，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "被冠以獸神之名，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "看來並非虛傳。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "噴火橫綱豬神",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "502091"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "唔……",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_041"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "原來如此……",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_042"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這還真是棘手至極。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n除了擁有一身剛力，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "更有如羚羊般的健步。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對於如今這副衰弱的身軀而言，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "或許是有些難對付的對手也說不定。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "噴火橫綱豬神",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真不愧是怪力亂神，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_043"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正面與之交鋒實屬愚昧之舉。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "雖然運籌帷幄、玩弄計策才是常道……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但現在可沒工夫在那悠哉慢行了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "既然如此那股剛力──",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_044"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "唯有傾盡全力",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "將其徹底擊潰。",
        "unit_id": 129711
    },
    {
        "type": "background",
        "background": "502091"
    },
    {
        "type": "dialogue",
        "name": "噴火橫綱豬神",
        "words": "──嘎喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "哎呀……",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_045"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這對老身來說還真是有些吃不消呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "默涅呀，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝身上沒受傷吧──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "…………",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_046"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "……奴家竟糊塗得忘了。",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_047"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "默涅她們中了「獄蜂」的奸計，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如今身陷囹圄。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n奴家明明是為了救那些孩子們，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "才不帶半名隨從，隻身一人趕赴此地的。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "連這副不滅之身，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_048"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "也衰弱到",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "令自己感到羞愧的地步嗎。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "又或者是在黎民百姓的環繞下，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "過著平淡悠閒日子的期間……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "才驚覺隻身一人終究萬事難成，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "或許這已成了理所當然的定數也說不定。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "正因如此，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_049"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "才得趕緊起行。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n為了將那所謂的定數，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "重新奪回",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家的掌控之中。",
        "unit_id": 129711
    },
    {
        "type": "background",
        "background": "502110"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真是奇妙。",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_050"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對這副身軀而言，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "黎民百姓雖是應當庇護守望的存在，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但在平日，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "卻未曾察覺他們就待在自己的身旁。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "對奴家而言，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_051"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那些人的存在",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "就如同稚兒一般。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n唯有將其包覆於掌心，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "守護其不受危難侵害，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n方能圓滿那高貴的生命──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家向來是如此思忖的。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這不過是身為「非人」",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_052"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "卻演起「凡人」模樣，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "一場微不足道的戲耍罷了。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "本來，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這應當只是不值一提的小事而已。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "請別露出那樣的神情。",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_053"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "自從與騎士閣下相遇，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "看著默涅成長──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家的視野與思維，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "如今也正迎來轉變。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "面對恐懼，",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_054"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並挺身對抗。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那宿於他們體內，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那堅韌的心性。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "曾幾何時，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家已被",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "那股心之力量所魅惑……",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "現下已無法再說是微不足道的小事了。",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_055"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那些人的存在，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "在奴家心中",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "已化作無可取代的大義。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是以如今，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家更想守望那份雄姿，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並將這份信賴貫徹到底。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "巨大的魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "商人們",
        "words": "哇呀啊啊啊啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_1382001_056"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我、",
        "unit_id": 51611,
        "voice": "vo_adv_1382001_057"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "我會試著努力的，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "但果然辦不到啊～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n皇女大人～！！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n救、",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "救救我～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "話雖如此……",
        "unit_id": 129711,
        "voice": "vo_adv_1382001_058"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "但看來要讓孩子們離開這片掌心獨自闖蕩，",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "現在似乎還有些為時尚早呢。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──堅定不移的驕傲，",
        "unit_id": 138212,
        "voice": "vo_adv_1382001_059"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "此刻即在此處。",
        "unit_id": 138212
    },
    {
        "type": "dialogue",
        "name": "巨大的魔物",
        "words": "──嘎喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "居、",
        "unit_id": 50811,
        "voice": "vo_adv_1382001_060"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "居然一擊就把那麼凶暴的魔物打倒……？",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n不愧是涅妃‧涅羅大人！",
        "unit_id": 50811
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "毫無損毀肉質，",
        "unit_id": 1,
        "voice": "vo_adv_1382001_061"
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "精準擊穿了頸部的要害！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人２",
        "words": "\n放血也處理得非常完美！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "唔……",
        "unit_id": 138211,
        "voice": "vo_adv_1382001_062"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "還過得去。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "並無任何異樣。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "鬼面佛心──",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "看來已徹底與奴家這副身軀契合了。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "哎呀～",
        "unit_id": 51611,
        "voice": "vo_adv_1382001_063"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "真是幫了大忙了……",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n不愧是皇女大人，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "這份力量簡直是",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "豪勇無雙！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n任何魔物到了您面前，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "都像是砧板上的肉呢～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "……",
        "unit_id": 51611,
        "voice": "vo_adv_1382001_064"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "可以這麼說嗎～",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "￼\n",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "既然您能如此精準地擊穿要害，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "那我們是不是根本不用戰鬥，",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n從一開始",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "由皇女大人",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "展現那副姿態不就好了嗎～？",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "若讓汝知曉能坐享其成，",
        "unit_id": 138211,
        "voice": "vo_adv_1382001_065"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝定會在那偷懶摸魚吧？",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "有道是，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "獅子亦會狠心將愛子推落谷底，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "有時親眼見證汝等成長，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "亦是身為皇女的奴家應盡之責。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "這成何體統，",
        "unit_id": 138211,
        "voice": "vo_adv_1382001_066"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "方才那副狼狽的模樣，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "實在令人嘆惋。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n鍛鍊不足之處簡直一目瞭然。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "既然如此，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "諸位──",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "奴家就維持這副姿態，",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "親自來給汝們一點指導吧。",
        "unit_id": 138211
    },
    {
        "type": "dialogue",
        "name": "全員",
        "words": "噫噫～",
        "unit_id": 1,
        "voice": "vo_adv_1382001_067"
    },
    {
        "type": "dialogue",
        "name": "全員",
        "words": "～～！！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看著發出窩囊哀求聲的民眾們，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "涅妃‧涅羅感到有些無奈與傻眼。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而，在那樣的神情之中，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "卻隱約透著一股不知何故的滿足感……"
    }
]