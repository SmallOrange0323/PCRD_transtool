[
    {
        "type": "background",
        "background": "501200"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可可蘿在與懷念的人們共同度過快樂的時間後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n向{player}表示還想帶他去一個地方。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下個人",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還想帶您",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "去另一個地方。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下還小的時候，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "經常一個人去到該處修行。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由於想回歸初心，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人陪在下走一趟。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個地方位於樹木茂密的山中，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "時常有風從山頂吹下，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是大自然中的瑪那通道。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還沒辦法像現在一樣",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "純熟地驅使精靈的那些日子裡，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下是藉助於那裡的瑪那之力",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來修行的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由於會離開村子的結界，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也可能會遭遇到魔物。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請主人務必當心。",
        "unit_id": 115511
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是在這附近才對……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "精靈啊！",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_006"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "嘿──！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "真是的，",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_007"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "為什麼啊！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我說精靈啊！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "午安。",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這種地方居然會有人在，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是稀奇呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只有您",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一個人嗎？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "哇！？",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_009"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……唔！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請等一下！",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一個人在這裡太危險了！",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "呼、",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_011"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "呼……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是村子裡的人沒錯吧。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "印象中",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "過去曾看過您幾次。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為什麼看到在下後",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要逃跑呢……？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您在這個地方",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "做什麼呢？",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那個……",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_015"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那是因為……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "妳……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下……？",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_016"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "妳……",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_017"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "是我很尊敬的人，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "可可蘿小姐。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "因為太緊張了，不小心就……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟是如此。",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_018"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我也想像妳一樣",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_019"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "離開村子，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n所以就在這邊修行。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "自從聽到可可蘿小姐傳回村子裡的",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_020"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "王都生活跟",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "冒險故事，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n我就一直很憧憬妳。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "只要聽到新的故事，",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_021"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那份感情就越來越強烈……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "在這個無聊的村子裡生活，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我已經受夠了！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "所以，",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_022"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我也想要跟可可蘿小姐一樣。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "為了能夠盡快離開村子，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我就在這邊修行……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "於離開村子前，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是經常在這裡修行沒錯……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您看起來",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還並未與精靈締結契約。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是先去請精靈術士的大人們",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "指導您關於契約的事會更好。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "這件事",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_025"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我並沒有告訴父母。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "因為我不是像妳一樣",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "有重要的職務，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我不認為單純的憧憬就能讓他們放我出村……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "要是被問了，",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_026"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "「為什麼需要跟精靈締結契約？」",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n我也",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不知道該怎麼回答……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n所以",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我才會先有樣學樣……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那個……",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_027"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "可可蘿小姐",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "跟我的年紀也沒有差那麼多，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n為什麼妳能像那樣到處冒險，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "還讓那個儀式也成功了呢？",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個問題的答案，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該是",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下不管何時都非常重視村子。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "咦！？",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如您所說，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是被指派職責後",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前往王都的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將這必須完成的責任託付給在下的，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正是在下出生長大的",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個村子。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算是在遠離村子的王都中生活，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下也未曾",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "遺忘過故鄉的存在。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "完成職責的場所，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "王都。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n還有……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "領受職責的場所，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "故鄉。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總是以自己是屬於這兩個土地的心情",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在生活著。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正是因為有著自己起點的故鄉，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下才能時常意識著背負的責任有多重大，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並轉化為力量。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那就是",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_037"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "可可蘿小姐強大的祕訣……？",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我有點",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "不太明白……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的見聞",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對居住於這村子的您來說，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n或許是相當有魅力的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會對此憧憬、",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想要踏上旅途的心情",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也能十分理解。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若處於您的立場，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n肯定也會抱有相同心情吧。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是……",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管如此……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也並沒有必要拋棄出生長大的故鄉，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "強行出走。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這個村子好好生活，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n並在這裡扛起責任或工作，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "更為重要。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為只要背負起越大的責任，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就越能成為自身的力量。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……原來妳是這樣想的啊。",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_042"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "因為妳的見聞總是那麼有魅力，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n我還以為妳已經忘了村子裡的事了……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "噫！？",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……！",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n似乎是被在下等人的說話聲",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "給吸引過來了呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那、",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_045"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那個魔物……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "就是",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "最近經常出現在村子附近的傢伙！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "是好幾個精靈術士的大人",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_046"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n才能勉強趕跑，非常兇暴！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n因為它，旅行商人也減少來訪的頻率了……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼聽來，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就更應該在這裡討伐它了呢。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "就算是可可蘿小姐，",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_048"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "要一個人討伐也太難了！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n我們快回村子的結界裡吧！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……在下",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "於這個瞬間，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "背負著兩個責任。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "這種時候責任什麼的不重要啦！",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_050"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我們快點逃吧！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正因為",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這種時候。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這裡",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_052"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "守護村中同胞的您，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n以及守護村子未來的安全，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下肩負這兩個責任。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正因如此，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "身為村裡的精靈族，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下不可以有半點退讓。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "背負責任",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_054"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能帶來什麼樣的力量，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就請您看著吧。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "咦？",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_055"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "就、",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "就算你們這麼說……！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓咱們迎戰吧，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "狂風之精靈啊……",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "揮下斬斷邪惡魔物之刃吧！",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n綠翠之絆風！",
        "unit_id": 115511
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呼……",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_059"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "好、",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_060"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "好厲害……！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "一擊就打倒那隻魔物了……！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n這就是進化後的精靈之力……！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "僅是將力量借給了在下而已。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈是回應了",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下想完成責任的強烈感情。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_062"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也是同樣，",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "將在下的感情",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "化為了力量。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "把強烈感情化為力量……！",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_063"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "……待會回去後，",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_064"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我會和父母討論看看。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "雖然不知道他們會不會允許，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "但我會告訴他們",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我是真的很憧憬村外的世界！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "作為懷抱憧憬的責任，",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_065"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我必須坦然面對……",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "看著可可蘿小姐，",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "讓我有了這份感觸！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_066"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是那份心情。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下會為您加油的。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "非常謝謝妳。",
        "unit_id": 5311,
        "voice": "vo_adv_1155002_067"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "那就再見了！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……狂風之精靈啊。",
        "unit_id": 115511,
        "voice": "vo_adv_1155002_068"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……請為那孩子的旅途",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "吹起祝福的風吧。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對著即將往未來踏出步伐的少年，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可可蘿以祝福的風溫柔地推了他一把。"
    }
]