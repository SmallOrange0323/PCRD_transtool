        "voice": "vo_adv_6033209_000"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "冷靜思考後覺得",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "牠真是一個不可思議的生物呢。",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "對呀……",
        "unit_id": 112311,
        "voice": "vo_adv_6033209_001"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "讓人很想好好調查看看。",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "\n",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "要撫摸那毛茸茸的皮毛，",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "捏一下長耳朵，",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "\n",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "還有揉揉牠的肚子……",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "的確……",
        "unit_id": 112311,
        "voice": "vo_adv_6033209_002"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "因為我跟霞",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "都不太常說話，",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "\n所以有時候會",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "變成只有摩拉一直在說話",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "的情況呢。",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "是的。",
        "unit_id": 112311,
        "voice": "vo_adv_6033209_003"
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "那個跳來跳去的身影，",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "會不自覺地用目光追逐牠呢。",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "\n…………",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "跳。",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "……",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "不、",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "不是，",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "不是的！",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "\n那個，",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "我只是在想這麼做會不會讓你也想用目光追逐我",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "……",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "好、",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "好難為情。",
        "unit_id": 112311
    }
]