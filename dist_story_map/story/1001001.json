[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，日和接受了工作的委託，\n一個人出門來到城鎮外的郊區。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喝呀！！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_000"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……呼……\n",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "先搞定一隻！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "明明是人來人往的地方，居然會出現魔物……",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "得在有人被襲擊前，火速擊退才行！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "馬上又來一隻！？",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "聲音好像是從那個方向傳來的……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有人被襲擊了！！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "得快點去幫忙！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還好吧！？",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我來幫忙了――",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？是騎士先生！？",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗨～！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n居然能在這種地方碰面真是令人開心呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生在這裡做什――",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_007"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唉呦喂呀！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呵呵，現在不是聊天的時候呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "先把魔物給擊倒吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n嗚咧呀呀呀～！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼……",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還好魔物並不會太強悍。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這樣就可以慢慢聊天了呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "感謝我拔刀相助之類的謝詞，就不用多禮了。",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為我今天接受了擊退魔物的委託呀。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "剛才做的是我份內工作的一環，不必介意的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "話說回來，騎士先生在這裡做什麼呀？",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "送快遞的工作……？要送到穿過森林後的地點去？",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是現在在那附近，有很多魔物出現……",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n只有騎士先生獨自前往的話是很危險的呦？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯……但工作果然還是",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不應該半途而廢呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對了！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "既然騎士先生碰到困難的話，那我來幫忙就好了呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……雖然我很想這麼說……",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但我也有擊退魔物的工作在身，抽不出空呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "聽說在這座森林之中呀，有很多魔物出沒呢。",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而且呀，是未必我獨自一人能全數擊退的數量喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣聽說之後，反倒是我想要個幫手呢，",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "而現在的我能幫上騎士先生的忙嗎……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯……",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_019"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "該怎麼辦呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……啊！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想到一個好主意呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我還是助騎士先生一臂之力吧！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "相反的……騎士先生也助我一臂之力可以嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我希望騎士先生幫我一起擊退魔物呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果是兩人的話，一定能很快就解決的！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "此外如果擊退魔物的話，騎士先生也比較容易辦事對吧？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯嗯！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真是天衣無縫呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那就這樣囉，我們互相幫忙吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_025"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不用道謝了啦。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為我也讓騎士先生來幫我了呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "碰到困難時要互相幫助幫助！沒錯吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼事不宜遲，",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們就動身出發去擊退魔物吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很一帆風順呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都是托騎士先生一同參加戰鬥的福！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，一直沒找到魔物集團的首領呢……",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n如果打倒首領的話，我想其餘魔物應該會逃走的說……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "接受委託時我聽說的內容，",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n是說首領會在日落時分之後，就藏身於某處。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以呀，如果不快點找到牠的話就……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇哇！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_030"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好、好驚人的吼叫聲……！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "或許首領就在那附近也說不定！我們去看看吧！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……總算找到牠了！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生快看，那就是魔物首領！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "牠就由我來對付吧！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "先下手為強！！喝呀─！！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不會吧！？",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n竟然接下了我的攻擊！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "背後也有魔物！！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難道我，是被誘入敵陣了嗎……！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚哇！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_035"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要、要被打倒了……！！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生來幫助我了呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我一不留神就被誘入敵陣……",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_037"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝騎士先生呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n請再抵擋一下魔物吧！我會馬上把首領擊倒的！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那我上了呦！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "喝呀！！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "依照地圖的話……",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_038"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "貨物的送交地點，是位於再稍微往前走一點之處的城鎮呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "帶路到這裡為止就可以了嗎？",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_039"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼，我就先回城鎮了呦！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！謝謝騎士先生剛才幫助我！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_040"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然我差一點就要被打倒了呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是托騎士先生的福，也順利打倒首領了！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想對騎士先生致謝，",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_041"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不知道騎士先生有沒有希望我幫騎士先生做的事情呢？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也一起想吧！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_042"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯……？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……啊，想到了！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_043"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "和我想法一樣呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_044"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "果然看到有困難的人，可不能放著不管呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生！今後如果有什麼困難，請隨時告訴我！",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_045"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n或許我能幫上忙呢！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦……？當我遇到困難時，騎士先生會幫我……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_046"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼……",
        "unit_id": 100111,
        "voice": "vo_adv_1001001_047"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "到時候，我就不客氣地拜託騎士先生了呦！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有困難時要互相幫助幫助這句話，是我自己說的嘛。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝！！",
        "unit_id": 100111
    }
]