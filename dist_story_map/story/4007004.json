[
    {
        "type": "background",
        "background": "500640"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在地上等候貪吃佩可等人歸來的{player}和"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n可可蘿親眼看到鋪天蓋地的圓盤同時撤退離開了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n神奇的是，這和凱留她們攻擊母船正好是同一時間發生。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "圓盤",
        "unit_id": 105913,
        "voice": "vo_adv_4007004_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "同時撤退了……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到底是怎麼回事……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊！？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！　",
        "unit_id": 105913,
        "voice": "vo_adv_4007004_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "空中有什麼東西降下來了！！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是巨大的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "莉瑪小姐？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "到宇宙去冒險",
        "unit_id": 105913,
        "voice": "vo_adv_4007004_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓莉瑪小姐大幅成長了吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是心理作用嗎，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "她在閃閃發光呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "機械莉瑪",
        "words": "莉瑪莉瑪莉瑪——！！",
        "unit_id": 13011,
        "voice": "vo_adv_4007004_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "莉瑪小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_4007004_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該不是吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那會不會是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "母船啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "戰鬥機又在哪裡……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿！　{player}！",
        "unit_id": 105812,
        "voice": "vo_adv_4007004_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n平安救出小凱留了哦！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是貪吃佩可小姐的戰鬥機！　",
        "unit_id": 105913,
        "voice": "vo_adv_4007004_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "平安無事真是太好了！",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "510270"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們一鼓作氣把母船擊落了！",
        "unit_id": 106012,
        "voice": "vo_adv_4007004_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "只不過也用盡彈藥啦！　",
        "unit_id": 105211,
        "voice": "vo_adv_4007004_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "抱歉！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "接下來只能在地上戰鬥了！",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "現在就降落到那邊去，",
        "unit_id": 105812,
        "voice": "vo_adv_4007004_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請稍等一下——！",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500640"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哎……",
        "unit_id": 106012,
        "voice": "vo_adv_4007004_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "終於回來了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_4007004_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您全身黏糊糊呢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n到底發生了什麼事啊……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那艘母船的目的，",
        "unit_id": 106012,
        "voice": "vo_adv_4007004_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是把蘭德索爾境內的食物都變成蘋果，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n當成征服世界時所需要的運作能源。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把它徹底破壞掉的話，",
        "unit_id": 106012,
        "voice": "vo_adv_4007004_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好像就能全部解決了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們趕快消滅它吧！！　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一點渣都不能留",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105913,
        "voice": "vo_adv_4007004_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來不想說出發生什麼事啊……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就不要詳細追問好了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯……",
        "unit_id": 105211,
        "voice": "vo_adv_4007004_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就別問了吧……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就算妳說",
        "unit_id": 105812,
        "voice": "vo_adv_4007004_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要消滅它，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "光靠我們的話是有困難的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "戰鬥機也不能用了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "各位，",
        "unit_id": 190811,
        "voice": "vo_adv_4007004_017"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "聽得到嗎？",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n我是公會管理協會的花凜！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "花凜小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_4007004_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來的正好。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就在剛剛",
        "unit_id": 190811,
        "voice": "vo_adv_4007004_019"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "確認了有像是母船的巨大物體降落了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "已經向各地的公會提出救援請求了，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我想應該很快就會抵達。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是可靠呢！",
        "unit_id": 105812,
        "voice": "vo_adv_4007004_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n大家一起同心協力地",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "拯救蘭德索爾吧！",
        "unit_id": 105812
    }
]