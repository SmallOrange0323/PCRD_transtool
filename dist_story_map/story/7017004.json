        "words": "這個是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能夠魅惑魔物的香水……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是費了我好多心力。",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了讓我更加美麗，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不做到這種程度不行呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這層樓好像",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也有掉落幾個魔導具的樣子，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n得先",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "整理好行李才行。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還真是",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "辛苦妳了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n虧妳能蒐集到這麼五花八門的東西。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我就認可妳那份對於美麗的執著吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔……",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是鏡子？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n沒特別感覺到魔力的氣息啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
