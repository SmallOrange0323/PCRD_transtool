    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再講一遍，我會好好誇獎妳的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要滿足",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "本尊的願望，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n分身自然就會消失了……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯～",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "兩人並排站的話根本分不出來啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "上次我做出分身的時候，",
