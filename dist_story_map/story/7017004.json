        "voice": "vo_adv_7017004_023"
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "\n不愧是我……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "就是得這樣！！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "啊啊，",
