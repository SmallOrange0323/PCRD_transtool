        "voice": "vo_adv_7017004_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "互相稱讚",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n對方的美麗之後就消失了呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "三天三夜裡",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "談論著至高無上的美麗，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如此美妙的時光……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真想再次",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "體驗",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那樣的幸福呢……♪",
