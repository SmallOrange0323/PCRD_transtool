        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "只為取我性命的那股殺氣！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "\n遊走在生死邊緣的劍光、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "刀刃碰撞時",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "迸裂的火花！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "自心臟奔騰而出的血液，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_025"
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "使我的背脊不禁顫抖！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "\n這是我、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "我們翹首以盼的爭鬥！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "\n來吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "讓我們耽溺在賭上性命的剎那歡愉吧！",
        "unit_id": 107111
    },
