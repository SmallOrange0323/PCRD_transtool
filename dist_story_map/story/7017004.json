        "voice": "vo_adv_7017004_026"
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "不說話了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "要不要讓我猜猜妳現在在想什麼啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不了，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無需妳的好意。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要交談，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們以劍相談足矣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "沒錯！",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_028"
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "正是如此！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我最先出的招，已經是完全瞄準空隙的全力一擊……",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n也就是說，我的能力無法通用於自身嗎。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要一不注意，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的人頭就會輕易落地吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是得這樣才對！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "與太過強悍的我相襯的強敵──",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n果然只會是",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我自己！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼會如此愉悅……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n果然賭上性命的戰鬥，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才能讓人有活著的感受。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n若是能夠",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "與這個強敵永遠鬥爭下去……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "太慢了！",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_033"
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "妳的首級，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "我收下了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這一擊……",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要躲已經來不及了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嘖，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "該說真不愧是我嗎。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在這種棘手到讓人著迷的時間點出招！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這個亂數聖域相互抵銷的狀況下，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n決定勝負的關鍵還是我與那傢伙原本的實力──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是要撤退、",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是防守……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "或者背水一戰、捨身搏命。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我的身體告訴我。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "假如在這裡退怯，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "連一線生機都會失去！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "踏進去！",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只差半步……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "半步就好。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n在那傢伙的劍光未至之前，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要這隻腳能夠搶先踏進去的話──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是──",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子的力量嗎！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒有時間迷惘了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "現在我就",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "心甘情願地借取這份力量吧！　",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈啊啊啊啊啊！",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_039"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "──",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_040"
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "沒想到",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "居然被反擊了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "我還以為至少不會輸給我自己呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "勝負不到最後無法揭曉。",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論是什麼狀況、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "利用什麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n最後獲勝的人才是贏家。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "結果是",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我贏了，妳輸了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "該說不愧是我嗎……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我承認，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳是個強敵。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是像做夢一般",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "愉快的戰鬥。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "然後……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再會了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_044"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "碎掉了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "吶，",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_045"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我一直有個疑問。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "剛才分身說的",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "「爭鬥」是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n克莉絲提娜小姐的願望……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "沒錯吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為什麼妳",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_046"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這麼渴求戰鬥呢？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是我的話，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只會覺得很麻煩。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n妳居然",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還願意為此賭上性命。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "誰知道呢。",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這對我來說太過理所當然，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我也不知道緣故。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要簡單說明的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那麼……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也許，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就如同妳追尋美麗的原因一樣吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "喔？",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_049"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣啊……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來如此。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那就是",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "克莉絲提娜小姐呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我，",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_050"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有點想聽聽妳說的話了呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "吶，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "克莉絲提娜小姐──",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "對繼續前進的克莉絲提娜，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪提起了些許興趣。"
    }
]