        "voice": "vo_adv_7017004_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "等一下。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n那面鏡子是……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼回事……！？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "突然發光……！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "早安啊，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "各位☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "睡得可好？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯～",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "增加了呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n克莉絲提娜小姐變成兩個了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "幻影嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "竟然模仿我，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是有趣……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "沒錯，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_010"
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "你好啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "我☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如你所見，",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這面鏡子會製造出所照之人的分身。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "世上最可愛的我",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要是變成兩人的話",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很棒吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "之前，",
        "unit_id": 100811,
        "voice": "vo_adv_7017004_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我有一面同樣的鏡子，",
