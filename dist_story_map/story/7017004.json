        "voice": "vo_adv_7017004_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這個是幫助肌膚保濕的秘境的靈草，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n然後",
