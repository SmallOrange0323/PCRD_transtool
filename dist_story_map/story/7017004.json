        "voice": "vo_adv_7017004_016"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不如說",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該有講過吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈哈，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小姑娘",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳真幽默。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有膽就在我的劍前",
        "unit_id": 107111
