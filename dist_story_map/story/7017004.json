    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "不就會害我想跟你們玩玩了嗎……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哼，",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以我的鏡中倒影來說還挺好戰的嘛？",
