    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "一閒下來的話，",
