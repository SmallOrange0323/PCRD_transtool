    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這麼血氣方剛",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "究竟是像到誰呀……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但這些話，感覺就是克莉絲提娜小姐會說的呢。",
