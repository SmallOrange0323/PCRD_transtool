        "voice": "vo_adv_7017004_024"
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "真是愉悅！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "分身克莉絲提娜",
        "words": "\n全神貫注、不放過一絲破綻，",
        "unit_id": 107111
    },
