        "voice": "vo_adv_7017004_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "分不出哪個是本尊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這種小事，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "根本不需要煩惱。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很簡單──",
        "unit_id": 107111,
        "voice": "vo_adv_7017004_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只要拔劍較量就知道了！",
