    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "黑暗姐姐被壓扁了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於是靜流分身引起的騷動終於解決了……？"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呼，",
        "unit_id": 120011,
        "voice": "vo_adv_1200004_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "事情解決了！",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n是姐姐贏了！",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "事情解決了",
        "unit_id": 4211,
        "voice": "vo_adv_1200004_001"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "──才怪啦，靜流！？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "妳最後是用力量和質量",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "強行解決掉的吧！？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "妳看啦，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "騎士大人嚇到整個人都呆住了！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦，",
        "unit_id": 120011,
        "voice": "vo_adv_1200004_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟，你怎麼了！？",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n你的嘴巴張得很大唷！？",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "啊，",
        "unit_id": 120016,
        "voice": "vo_adv_1200004_003"
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "是希望姐姐幫你刷牙嗎？",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "\n",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "真拿你沒轍，",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "你真愛撒嬌呢♪",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "嗚哇，",
        "unit_id": 4211,
        "voice": "vo_adv_1200004_004"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "嚇我一跳！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n咦，",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "為什麼妳還在啊！？",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "\n妳剛才不是被王者騎士大人壓扁了……！",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呵呵♪",
        "unit_id": 120011,
        "voice": "vo_adv_1200004_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我不會讓王者弟弟",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "做傷害他人的行為。",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為弟弟很溫柔的……♪",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "嗯……",
        "unit_id": 120016,
        "voice": "vo_adv_1200004_006"
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "在王者弟弟的手包覆住我的時候……",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "\n我被非常溫柔的觸感包覆，",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "彷彿置身夢境一般……♪",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "\n",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "……於是我不禁心想，",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "自己絕對戰勝不了。",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "這、",
        "unit_id": 4211,
        "voice": "vo_adv_1200004_007"
    },
    {
        "type": "dialogue",
        "name": "摩拉",
        "words": "這樣啊……",
        "unit_id": 4211
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "好了，",
        "unit_id": 120011,
        "voice": "vo_adv_1200004_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那麼……",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "做個了斷吧。",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "……我的黑暗力量",
        "unit_id": 120016,
        "voice": "vo_adv_1200004_009"
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "輸給妳了。",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "\n",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "隨妳處置吧。",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "\n",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "我覺得把我消滅掉，",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "妳會比較輕鬆就是了。",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我不會這麼做。",
        "unit_id": 120011,
        "voice": "vo_adv_1200004_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為……",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟說過",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "想要和「全部的我」待在一起。",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "……！",
        "unit_id": 120016,
        "voice": "vo_adv_1200004_011"
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "\n但是，",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "那樣不管經過多久，",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "黑暗都不會消失。",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "\n",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "妳得要在壓抑",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "和痛苦中……",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "繼續忍耐下去才行喔？",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……那也是",
        "unit_id": 120011,
        "voice": "vo_adv_1200004_012"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐的愛。",
        "unit_id": 120011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "回來吧。",
        "unit_id": 120011,
        "voice": "vo_adv_1200004_013"
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "……",
        "unit_id": 120016,
        "voice": "vo_adv_1200004_014"
    },
    {
        "type": "dialogue",
        "name": "黑暗姐姐",
        "words": "嗯。",
        "unit_id": 120016
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……！",
        "unit_id": 120011,
        "voice": "vo_adv_1200004_015"
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我回來了～♪",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_016"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n嘿嘿，",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "雖然不是姐姐的房間，",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還是說了我回來了♪",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "和弟弟一起去購物，",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "太開心了～♪",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟，謝謝你，",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "願意幫姐姐提東西。",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟為我挑選了很多東西，",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我高興到不小心買太多了……",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，沒問題！",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n為了弟弟而使用的錢，",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是姐姐的必要經費♪",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對了，",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天的晚餐",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你想吃什麼？",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "受你的雙親所託，要幫忙照顧你。",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我會像妻子一樣",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "細心照顧你的……♪",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "……不過，",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在那之前。",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n家裡只有我們兩個，",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還有事情要做吧。",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "難道你的作業還沒寫完？",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這可不得了，",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐待會幫你看看！",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n不過，現在不是要做這件事……！",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒錯沒錯！",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n說到兩人獨處要做的事情，",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是比腕力吧！",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我會讓你知道沒有弟弟能贏過姐姐！",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呃，不對～啦！",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "討厭，",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟你啊，根本就不懂。",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "在這個狀況下要做的事情……",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就只有一件，",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "對吧。",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "──由姐姐主辦！",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n姐姐的時裝秀要開始囉！",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咻咻～♪",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "哇啊，謝謝～♪",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟整個人的反應",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "相當熱烈呢♪",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嘿嘿，",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "其實今天的購物",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是為了這個～♪",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n我把購物中心的服飾店",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "全部逛了一圈♪",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我在回程路上，就一直快按捺不住了呢。",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "心裡想著「好想早點讓弟弟看到",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天買的衣服啊」。",
        "unit_id": 104932
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那我",
        "unit_id": 104932,
        "voice": "vo_adv_1200004_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
