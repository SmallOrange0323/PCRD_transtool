[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "唷諸君！ ",
        "unit_id": 191011,
        "voice": "vo_adv_2008005_000"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "早安！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "真是個風和日麗的早晨呀☆",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "話是這麼說，",
        "unit_id": 191011,
        "voice": "vo_adv_2008005_001"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "但這個據點在洞穴中呀，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n無法親眼目睹那旭日高升真可謂遺憾！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "但我依舊能感覺到！ ",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "今天鐵定會成為美好的一天呀！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "如此快活之日，",
        "unit_id": 191011,
        "voice": "vo_adv_2008005_002"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n就是將似似花大人救出這件如此艱困的任務，也感覺能夠水到渠成！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "更應該說今日不做還待何時！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": " 大家不這麼覺得嗎？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "事至於此，",
        "unit_id": 191011,
        "voice": "vo_adv_2008005_003"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "現在就即刻出發去王宮奪回似似花大人吧！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n來吧眾人，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不讓我們攜手一同進擊嗎！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "哈哈哈☆",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……雖然有很多想要嘴的地方。",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但總而言之，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才剛睡醒就看到你這傢伙該說是差點沒又暈過去嗎？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n各種傷眼睛的感覺呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "哈哈哈！ ",
        "unit_id": 191011,
        "voice": "vo_adv_2008005_005"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "冷不防就冒出這番話！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n這不是挺毒舌的嘛，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "諾維姆！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "感謝妳！",
        "unit_id": 191011,
        "voice": "vo_adv_2008005_006"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n被妳洗了把臉，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我也感覺清醒了許多呀！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不管講些什麼都充滿了正面能量呀，",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這要酸起來也沒什麼手感呢……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但有精神比什麼都重要嘛。",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n你也一樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "受的傷都還沒有痊癒，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可別太勉強囉。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "似似花的救援計畫，",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡也是正縝密的在考慮當中。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但是",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "王宮",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "比起我們先前偷偷潛進去時，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n警備又更加強化了的樣子，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "現在可說是固若金湯呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可以成功執行好救援作戰，",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在能夠如此斷言前，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然很難熬但再多忍耐一下吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我完全能夠理解！ ",
        "unit_id": 191011,
        "voice": "vo_adv_2008005_011"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "但這份衝動卻怎麼都按捺不住！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "這可說是自從呱呱墜地以來，第一次如此長時間無法好好安眠！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n我就是如此擔心似似花大人的安危呀！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "啊啊，",
        "unit_id": 191011,
        "voice": "vo_adv_2008005_012"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "似似花大人！ ",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "還請您一定得安好啊！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我發誓，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我真軌某人一定會將您給救出來的……！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為了這件事，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以更該做好萬全的準備。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n如果要治療好傷口",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "和恢復體力，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n能吃到美味的東西是最快也最有幫助的。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以說，",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "趕緊來吃早餐吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "今天負責煮東西的是誰來著？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "原本是我。",
        "unit_id": 107311,
        "voice": "vo_adv_2008005_015"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n『今日",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "為了那些客人，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "請讓給我們來大展手藝吧。』話才說完，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n靜流和璃乃她們就鬥志高昂的進廚房站到爐子前了呢。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦～，",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "拉基拉基你也早呀♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n剛剛好像和真軌兩人在聊天的樣子，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們說了些什麼？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "是。",
        "unit_id": 107311,
        "voice": "vo_adv_2008005_017"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我所擁有的知識，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "還有不少部分含著缺陷。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n因此請真軌告訴了我不少這裡的事情。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "他",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "可說是學識淵博，也使我相當地欽佩。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "嘿嘿，",
        "unit_id": 191011,
        "voice": "vo_adv_2008005_018"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "被這麼稱讚，不禁讓人害臊了起來呢！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "別看這樣，我可是似似花大人做研究時在一旁協助的助手呢，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n學術相關的知識問本人就對啦！ ",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "常理來看我也算是高學歷的嘛！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……啊，",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這麼說來，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果記得沒錯你好像是公務員嘛。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但在這個世界觀中，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那一部分還不知道是怎麼被詮釋的就是了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過畢竟都是人類嘛。",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n智能水平之類的，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也不會降低的那麼徹底吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但像是拉基拉基，",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "幾乎是完全喪失了記憶，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n變得像是小嬰兒一樣，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "連常識都忘光光了就是。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "呵呵。",
        "unit_id": 107311,
        "voice": "vo_adv_2008005_022"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n姑且，為了不給人添麻煩……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "一般基礎常識，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "現在我也還在努力學習中。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過嘛，",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你本來就是『七冠』之一。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以也不可能是個笨蛋。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n只要稍微努力一點，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "比起我",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "學習能力應該更強吧。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_2008005_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拉基拉基先生，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該這麼稱呼您吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "昨日，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對於您帶領在下等人從快爆炸的研究設施中逃出，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "非常的感激。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您似乎也是",
        "unit_id": 105913,
        "voice": "vo_adv_2008005_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "『七冠』中",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的其中一位呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼說來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在那本古文書中，似乎也有出現類似的名字……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若沒記錯，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "叫拉基尼、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我的名字是拉基尼卡東唷，",
        "unit_id": 107311,
        "voice": "vo_adv_2008005_026"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "小妹妹。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n讓別人取了一個名為拉基拉基的暱稱，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n若能這麼來叫我，會是我的榮幸。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了。",
        "unit_id": 105913,
        "voice": "vo_adv_2008005_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼這裡也鄭重地再為您介紹一次，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下名為可可蘿。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而這位大人，是{player}。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "好的。",
        "unit_id": 107311,
        "voice": "vo_adv_2008005_028"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n這裡也請您多多指教，{player}。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "還希望能夠長久的，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "保持良好的關係呢。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "呵呵。",
        "unit_id": 107311,
        "voice": "vo_adv_2008005_029"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "是呢，在屋內還穿著這麼件厚重的外套，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n自然會令人感到相當的奇異呢。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "但因一些緣故，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "我的皮膚不太能露給別人看。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "特別是，",
        "unit_id": 107311,
        "voice": "vo_adv_2008005_030"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "在像可可蘿這樣的小孩子面前……",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n更不能脫掉這件外套，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "畢竟很有可能會讓人感到畏懼。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呃……",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然事到如今了才問。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但蒂亞娜……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "又叫錯了，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那個叫貪吃佩可的傢伙去哪了？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n在這沒有看到她，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果還在睡的話，得去把人家叫醒呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "啊，",
        "unit_id": 191011,
        "voice": "vo_adv_2008005_032"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "妳說她的話，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "似乎是去幫忙靜流她們做早餐而進了廚房唷！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n為了回報這份受到的恩情，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n早餐就讓本小姐來露一手～",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "講了類似這樣的話呢！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是嗎。",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯～……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就只有那傢伙的事，我完全沒有印象啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總覺得好像在哪裡有看過就是了。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "到底是誰來著呢？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔～嗯嗯？",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "諸君！ ",
        "unit_id": 107111,
        "voice": "vo_adv_2008005_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "打擾到你們的談天我感到很抱歉，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但希望你們快給我坐定位啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n都站在那會擋到人端菜啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不聽話的傢伙小心我一腳踹飛他啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "喂喂，妳也太兇了吧……",
        "unit_id": 190711,
        "voice": "vo_adv_2008005_035"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "但是，如果這麼多人，位子不會不夠全部人坐嗎？",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "硬塞一下，還是擠得出位置啦。",
        "unit_id": 107111,
        "voice": "vo_adv_2008005_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n好啦小子……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "菜還有很多盤，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n隨便在桌上排一下就好，趕緊都端過來。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "好啦好啦，",
        "unit_id": 190711,
        "voice": "vo_adv_2008005_037"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "知道啦。",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈哈。",
        "unit_id": 106112,
        "voice": "vo_adv_2008005_038"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n還在想妳們跑去哪了，沒想到是在幫忙端盤子啊。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n有乖乖幫大家的忙，真讓人感動呢，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯嗯♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟是借住人家嘛，",
        "unit_id": 107111,
        "voice": "vo_adv_2008005_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "做點家事不足掛齒。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n就只是盡給人添麻煩，然後傻在那裡當個花瓶，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可就違反我的美學了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且。",
        "unit_id": 107111,
        "voice": "vo_adv_2008005_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "像這樣日常生活的行為老實說還挺新鮮的，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n意外的還算挺令人愉悅的呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n若和那枯燥乏味又鬱悶的牢獄生活比起來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這可說是天國般的生活了。",
        "unit_id": 107111
    }
]