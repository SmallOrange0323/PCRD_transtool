[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}順道散步，\n來到了森林入口。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊啊～！",
        "unit_id": 1,
        "voice": "vo_adv_1018001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n誰、誰來救救我呀～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "！",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "101800101"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "有誰來幫我了嗎！？",
        "unit_id": 1,
        "voice": "vo_adv_1018001_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n……太、太好了～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那個～ 其、其實……",
        "unit_id": 1,
        "voice": "vo_adv_1018001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我被植物的藤蔓給纏住了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "如果可以自己拔出來就好了，",
        "unit_id": 1,
        "voice": "vo_adv_1018001_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n但是手夠不到～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚嗚……拜、拜託了！",
        "unit_id": 1,
        "voice": "vo_adv_1018001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n趕快幫我鬆開來～！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇～！謝謝。",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要溫柔一點唷？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "欸？植物想要吃我？",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這種事情……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊ーーー！",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嘴、嘴巴打開了！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n快、快救救我ーーー",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "！",
        "unit_id": 101811
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼……得救了～",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "終、終於可以動了……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "本來打算自己想辦法的，",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_009"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但只要動一下藤蔓就到處勒得越來越緊，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n動彈不得。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要是你沒有來，",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_010"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我恐怕會一直被纏住……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我叫做伊緒。",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你叫什麼名字？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "哼～",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "謝謝你幫了大忙！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這一帶還會出現魔物，",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你真是我的救命恩人！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸？好柔軟……你說我的胸部！？",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！抱、抱歉。我竟然突然抱住你。",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "很痛苦嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "總、總之！",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n真的謝謝你",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我會小心不要再被魔物襲擊了。",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "不能再添麻煩了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那麼，再會。\n我先走了！",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_018"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "再見～",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！？",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_019"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n這裡也有植物的魔物！？",
        "unit_id": 101811
    },
    {
        "type": "still",
        "still": "101800101"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "來、來人啊～！",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n喂，救救我啊～！！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊～！我明明才說不要再靠別人幫忙了～！",
        "unit_id": 101811,
        "voice": "vo_adv_1018001_021"
    }
]