[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……我的名字是",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n尤絲蒂亞娜‧F‧阿斯特賴亞。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我以蘭德索爾王家女兒的身分出生，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n做為王位繼承人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "同時也做為未來的公主被養育成人。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "父皇與母后，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還有家臣們，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家雖然嚴厲卻很溫柔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n除了身為王族必須具備的禮儀或心態之外，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n他們還教導了我許多事情。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在那些事情當中，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n年幼時的我最喜歡，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也是最早就記起來的一句話就是",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「不論何時都必須保持樂觀開朗的模樣」",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "譬如說，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在慶典或是外交的場合上，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n身為國家的代表，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了要展現出自己是名充滿魅力的人物。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "譬如說在戰場上，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了要鼓舞士兵們的士氣。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或許是和我與生俱來的氣質很搭吧。",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n先不說在學習其他事情或是帝王學的知識上，我到底有沒有學好，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但光就「保持樂觀開朗的模樣」這一點，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我是一名成績優秀的學生。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以……",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n即使，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在我被突然現身的霸瞳皇帝",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n給奪走了一切的那天之後……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使在這個國家裡的所有人，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n都忘了我才是王女之後也是……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就只有",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「保持樂觀開朗的模樣」這一點",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "無法捨棄。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果我連這份覺悟都失去了的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就算我穿上這套皇家裝備，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n感覺「我」也已經",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不會再是「我」了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "當然，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在我孤單一人的時候，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也會失落難過到不能自拔。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我也曾經敗給了肚子餓……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留。",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還有",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在原本無依無靠的我身旁，不知不覺中",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n變成有我最珍惜的人們陪伴著我。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他們的存在，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n將我那其實相當脆弱、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "快要撐不下去的心靈……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n像是剛煮好的白飯一樣，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "暖暖地支撐住了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然而――",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_013"
    },
    {
        "type": "still",
        "still": "201500405"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105911,
        "voice": "vo_adv_2015006_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然而――",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在自己的面前，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "失去了最深愛的人。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就連我心中的覺悟，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也似乎要離我而去了。",
        "unit_id": 105812
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "吶，",
        "unit_id": 106915,
        "voice": "vo_adv_2015006_018"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳現在的心情如何呀？",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "公主殿下……",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n又有一樣妳最珍貴的事物被我給奪走了呢！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵、",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵哈哈哈哈哈……♪",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……霸瞳皇帝的那番話，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n掠過我的腦中，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "逐漸離我而去。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "嗚啊啊啊啊啊――！！",
        "unit_id": 1,
        "voice": "vo_adv_2015006_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……大家的身影，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n經過我的眼角餘光，逐漸離我而去。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我明明……",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我明明也得拿起劍來",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n挺身對抗才行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明明就得對霸瞳皇帝說些什麼話",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來反擊才行。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是……",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……我已經",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再也站不起來了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n……我已經",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再也動不起來了。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我已經",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "再也沒辦法",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "笑出來了……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明明我最深愛的那個人，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了保護我",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而失去了性命。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……但這樣的我，",
        "unit_id": 105812,
        "voice": "vo_adv_2015006_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "究竟",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還能做到些什麼事情呢……？",
        "unit_id": 105812
    },
    {
        "type": "background",
        "background": "500783"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105811,
        "voice": "vo_adv_2015006_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那……",
        "unit_id": 105811,
        "voice": "vo_adv_2015006_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "個……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛、",
        "unit_id": 105811,
        "voice": "vo_adv_2015006_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛才……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳有沒有",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "聽到些什麼呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106011,
        "voice": "vo_adv_2015006_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剛剛什麼都沒聽到，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也什麼都沒說……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n――",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀啊！！",
        "unit_id": 106011
    },
    {
        "type": "still",
        "still": "201500406"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎、",
        "unit_id": 106011,
        "voice": "vo_adv_2015006_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼了啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n怎麼突然……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦咦！？",
        "unit_id": 105811,
        "voice": "vo_adv_2015006_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}的身體",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "發光了……！？",
        "unit_id": 105811
    },
    {
