    {
        "type": "dialogue",
        "name": "美里",
        "words": "伊緒老師負責的科目",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是國文啊～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為聽說是歷史課的校外教學還以為……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "課堂上會閱讀各種書籍嗎？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是的，",
        "unit_id": 101811,
        "voice": "vo_adv_7010002_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我都會精心挑選讓學生們能在愉快中學習的讀物。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "如果以我的課堂為契機",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而喜歡上閱讀的話，會很令人開心呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒錯呢～！",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如果方便的話，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "能稍微",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "跟我聊聊關於繪本的話題嗎？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "雖然一直以來都有在創作讓孩子們看的繪本，",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "最近",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "卻想不到新的題材……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "村裡也沒有可以討論的對象，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真的十分困擾呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "請交給我吧！",
        "unit_id": 101811,
        "voice": "vo_adv_7010002_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "例如說",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "有一本小說的內容是這樣子……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "——然後女主角",
        "unit_id": 101811,
        "voice": "vo_adv_7010002_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n在學園祭的最後一天，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "向心儀已久的男孩子告白了！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "當然告白成功了，",
        "unit_id": 101811,
        "voice": "vo_adv_7010002_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n最後以兩人接吻的橋段，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "作為這部小說的結尾～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，",
        "unit_id": 101811,
        "voice": "vo_adv_7010002_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一講起來就覺得好有趣，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一不小心",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "就興奮起來了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "對孩子們來說",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這種內容是不是還太早了呢……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不會的，",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒有這種事喔～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "十分的有趣～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為我總是在閱讀兒童繪本，",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n聽了感到很新鮮呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "最近，",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "早熟的孩子也很多，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n試著讓內容",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "偏向大人一點，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "似乎也不是個壞主意。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那真是太好了～",
        "unit_id": 101811,
        "voice": "vo_adv_7010002_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我還有很多能推薦的戀愛小說和漫畫，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n隨時都可以來找我討論喔！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "回到村子後，",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就馬上開始畫畫看。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "感覺能畫出讓孩子們開心的繪本呢……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "完成之後",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "務必",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "請伊緒老師也看看～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "太好了，",
        "unit_id": 101811,
        "voice": "vo_adv_7010002_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "一定會的！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n美里老師的繪本，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "真期待呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "唉呀……",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "等、",
        "unit_id": 101811,
        "voice": "vo_adv_7010002_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "等一下！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n大人的繪本，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可不是那種意思呦……？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那是那個……",
        "unit_id": 101811,
        "voice": "vo_adv_7010002_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "課堂上不會教的內容……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀……",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "該怎麼辦呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "居然給老師們造成困擾，",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是壞孩子呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓這個話題結束吧！",
        "unit_id": 101811,
        "voice": "vo_adv_7010002_020"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "美里老師，",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "可沒有在課堂上教這種事情喔～！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "夠了！　{player}！",
        "unit_id": 101811,
        "voice": "vo_adv_7010002_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n等一下給我到導師辦公室！　",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我有話要跟你說！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀哎呀哎呀～～……",
        "unit_id": 101511,
        "voice": "vo_adv_7010002_022"
    }
