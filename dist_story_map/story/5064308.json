[
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "找到了～！",
        "unit_id": 116311,
        "voice": "vo_adv_5064308_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是神祕暗黑組織憂妮們！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這可是大發現！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說也太好笑。",
        "unit_id": 116211,
        "voice": "vo_adv_5064308_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n憂妮們",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "完全復活了嘛。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "魔力的流動",
        "unit_id": 116411,
        "voice": "vo_adv_5064308_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "甚至比剛才都還要流暢。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點就是很強──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個，等一下。\n暫停暫停，攝影機也停一下。",
        "unit_id": 116211,
        "voice": "vo_adv_5064308_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不覺得這段台詞",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "剛才已經說過了嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是啊，",
        "unit_id": 116311,
        "voice": "vo_adv_5064308_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "已經說過了。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n順帶一提，感覺應該還會再說個兩三次。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的假的。",
        "unit_id": 116211,
        "voice": "vo_adv_5064308_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n那傢伙到底會復活多少次啊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這是憂妮們復活慶典IN德蕾女嗎。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "話雖如此，",
        "unit_id": 116411,
        "voice": "vo_adv_5064308_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那傢伙被灌入的魔力也不是無限。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好了，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要不放棄地戰鬥啊克蘿依。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n既然如此反覆修復與強化，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那盡頭肯定不會太遠。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呃～",
        "unit_id": 116211,
        "voice": "vo_adv_5064308_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "真的嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我這充滿榮耀的文科人所推敲出的理論",
        "unit_id": 116411,
        "voice": "vo_adv_5064308_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不可能會錯。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果想反駁就說來聽聽。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "「那就自己去打倒她」。",
        "unit_id": 116211,
        "voice": "vo_adv_5064308_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "反駁完畢。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗚……",
        "unit_id": 116411,
        "voice": "vo_adv_5064308_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那種辯論太狡猾了……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "唔唔……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊～真是的～好了啦～",
        "unit_id": 116311,
        "voice": "vo_adv_5064308_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n優妮學姐都要哭出來了啦。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗚嗚，",
        "unit_id": 116411,
        "voice": "vo_adv_5064308_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以我才說運動會系的……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗚、",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗚……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊……",
        "unit_id": 116211,
        "voice": "vo_adv_5064308_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我很",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "抱歉……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好了，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "打起精神來吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "來，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "阿姨給你糖果。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我才不要，",
        "unit_id": 116411,
        "voice": "vo_adv_5064308_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "吃那個下巴超累的！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐討厭吃東西，",
        "unit_id": 116311,
        "voice": "vo_adv_5064308_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "怎麼可能被食物安撫嘛。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊──那好，",
        "unit_id": 116211,
        "voice": "vo_adv_5064308_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這個給妳。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這瓶",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我之前在魔導具店打工時拿到的",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可疑藥水。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哇～",
        "unit_id": 116411,
        "voice": "vo_adv_5064308_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是可疑藥水～！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克蘿依學姐，",
        "unit_id": 116311,
        "voice": "vo_adv_5064308_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們學校禁止打工喔。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "要是被瑪麗會長聽到的話可不得了喔。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 116211,
        "voice": "vo_adv_5064308_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呃，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是啦，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是志工啦。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是去當志工。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 14511
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，糟糕，",
        "unit_id": 116211,
        "voice": "vo_adv_5064308_020"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "普通地忘了那傢伙。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "總覺得超吵的，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就先讓她安靜下來吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "說得也是。",
        "unit_id": 116311,
        "voice": "vo_adv_5064308_021"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就切嚕地讓她安靜下來吧！",
        "unit_id": 116311
    }
]