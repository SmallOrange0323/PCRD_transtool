[
    {
        "type": "background",
        "background": "500253"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "踏入城鎮地下的伊莉亞一行人。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們在那裡發現了數量龐大的魔力結晶。"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然嗎。",
        "unit_id": 126211,
        "voice": "vo_adv_5120005_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身就覺得你有跟過來啊，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "布拉德。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "……跟隨伊莉亞大人，",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_001"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "是我的職責。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼──",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "結果布拉德你──",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "──是想利用伊莉亞",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來做什麼？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "哦。",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_004"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n看妳的態度，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "似乎從一開始就懷疑著我呢。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我當然會懷疑你啊，",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為你太不自然了。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "不自然？",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_006"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n妳是指哪個部分呢？",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那就是你",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "完全不看向我的這一點啊♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "…………",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊哈哈。",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你以為我在開玩笑嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但我是認真的喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為我太美了，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n所以對周圍的視線動向可是很敏感的。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你啊……",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n視線完全沒有停留在",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我跟{player}的身上過吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你雖然看似冷靜，",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但卻一直用狂熱的視線看著伊莉亞。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對你來說，除了伊莉亞以外的事物都不重要吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不然，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你是不可能",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "無視我的呢♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "先不論最後一句台詞，",
        "unit_id": 126211,
        "voice": "vo_adv_5120005_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雪那傢伙……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "意外地看得很清楚呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "布拉德啊，",
        "unit_id": 126211,
        "voice": "vo_adv_5120005_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你就來說明說明吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n你到底打著什麼主意。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我的目的是",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_014"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "讓傳說的吸血鬼復活。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……？",
        "unit_id": 126211,
        "voice": "vo_adv_5120005_015"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我說的話",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_016"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "沒有半點虛假。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我的目標是讓傳說的吸血鬼復活，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "僅此而已。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看來你沒有在說謊。",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你那眼瞳……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很危險呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "眼瞳這個東西，",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "本來是為了散發美麗光輝而存在的，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是你的眼瞳……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "蘊含著危險的兇光啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "危險……",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_019"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "是啊，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "那是當然的啊！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "讓傳說的吸血鬼復活一事，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "必須是這世界最大的危機，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n同時也必須是刻劃在歷史上最著名的事件才行……！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "「手指一揮就能改變天候，",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_020"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "腳下一踏便能使大地裂開，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "如果嘆了口氣，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n則會颳起龍捲風，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "光是一個眼神即可魅惑數萬生物的心。」",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "讓那樣的伊莉亞大人復活，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "是我唯一的目的……！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "然後！",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_021"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "當您取回所有的力量之後，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "要將人族、",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "獸人族、",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "精靈族全部從這世界上消滅。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n這一次！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "一定要討伐過去",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "將您封印起來的神明們！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你",
        "unit_id": 126211,
        "voice": "vo_adv_5120005_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "說這些……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是認真的嗎？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "當然是認真的。",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_023"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n我已經為此做好準備了。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "您也看到了吧？",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_024"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "只要有這麼多的魔力結晶，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "伊莉亞大人的復活就等同是已經實現了！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "而且士兵的數量，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "也日漸充足。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你一直喊著傳說傳說的，",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_025"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看來並不只是憧憬著它而已呢……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你是認真地",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "想要重現它啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是說，",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你知道神明們在哪裡嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n……應該說，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是什麼的神明？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "那不是像我這種人能知道的事情。",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_027"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "但是，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "等身為傳說的吸血鬼的伊莉亞大人完全復活之時，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n一切都會水落石出吧。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗚哇，",
        "unit_id": 126311,
        "voice": "vo_adv_5120005_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真麻煩的人啊……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "讓傳說的吸血鬼復活，",
        "unit_id": 126211,
        "voice": "vo_adv_5120005_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "除此之外別無目的嗎。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你還真的是",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒有將其他事物放在眼裡呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看來在事情變麻煩之前，",
        "unit_id": 126211,
        "voice": "vo_adv_5120005_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "阻止你比較好吧。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "哎呀，",
        "unit_id": 9811,
        "voice": "vo_adv_5120005_031"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "伊莉亞大人。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "我不建議您",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "在這裡戰鬥。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
