[
    {
        "type": "dialogue",
        "name": "望",
        "words": "嗚……",
        "unit_id": 124811,
        "voice": "vo_adv_5111204_000"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "一來到這裡，",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "就突然有點頭暈……",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "明明應該能抵抗那些傢伙的力量才對……",
        "unit_id": 124911,
        "voice": "vo_adv_5111204_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n也就是說，",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這裡危險到連我們也會受到影響……",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那不就代表……",
        "unit_id": 125011,
        "voice": "vo_adv_5111204_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你還好嗎！？",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……老實說，",
        "unit_id": 106211,
        "voice": "vo_adv_5111204_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "有點不好受。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過我和他一樣，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "借助諾維姆妳們的力量還能撐著。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過，",
        "unit_id": 106211,
        "voice": "vo_adv_5111204_004"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果會因為這樣就害怕，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那我打從一開始就不會來了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們好歹",
        "unit_id": 106211,
        "voice": "vo_adv_5111204_005"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "也是經歷過不少難關的。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "對吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀……",
        "unit_id": 125011,
        "voice": "vo_adv_5111204_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "果然，",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "只有你才是我的搭檔！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好～",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就全力衝刺吧！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔喔──！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哇，",
        "unit_id": 124911,
        "voice": "vo_adv_5111204_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "她像隻卸下狗鍊的狗一樣衝出去了喔？",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦、",
        "unit_id": 106211,
        "voice": "vo_adv_5111204_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦咦……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我狀態可沒有好到精神百倍的說。",
        "unit_id": 106211
    }
]