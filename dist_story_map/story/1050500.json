[
    {
        "type": "background",
        "background": "509010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "會把我叫到這裡來，",
        "unit_id": 105011,
        "voice": "vo_adv_1050500_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "應該是真的有很重要的事吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "成熟淑女可是很忙的，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n如果只是一些芝麻小事，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我可不會就這樣饒過你喔！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哎呀，",
        "unit_id": 105011,
        "voice": "vo_adv_1050500_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "想不到竟然記住了我的生日，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "看來你還蠻有前途的嘛！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這麼用心值得嘉獎！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "看來自從任命你為護花使者後，",
        "unit_id": 105011,
        "voice": "vo_adv_1050500_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你也越來越有成熟紳士的樣子了。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "明年的生日",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也會拭目以待♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呀～♪",
        "unit_id": 105011,
        "voice": "vo_adv_1050500_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這蛋糕還挺不錯的嘛！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n雖然有點樸素而且點綴也很孩子氣，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過就原諒你吧！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哼哼，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "怎麼樣？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這可是離大人更進一步的淑女才有的度量喔♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過",
        "unit_id": 105011,
        "voice": "vo_adv_1050500_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這麼大的一整個蛋糕，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我一個人哪吃得完啊。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "難得有這機會，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你不要也來一點？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "但是",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "草莓我可不分你喔！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣講是因為",
        "unit_id": 105011,
        "voice": "vo_adv_1050500_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "今天是我的生日嗎？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣的祝賀還真是善解人意！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "幹得好！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我也會保持下去，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "今年一定會當個成熟淑女讓你看看♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不對啦，",
        "unit_id": 105011,
        "voice": "vo_adv_1050500_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我早就已經是個大人了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "有夠沒禮貌的！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "總之剛剛說錯了，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "今年要成為更完美的成熟淑女！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "為了答謝你的祝福，",
        "unit_id": 105011,
        "voice": "vo_adv_1050500_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "今天就允許你當我的護花使者一整天！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "來吧，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "淑女的生日",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就是要優雅地度過！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你可要好好的服侍我喔♪",
        "unit_id": 105011
    }
]