[
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接獲帆稀的工作委託的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n前往她所在的公會小屋。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "歡迎光臨～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n謝謝你今天也過來幫忙～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "口渴了嗎？",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "請用～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是杯能夠生津止渴的飲料。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我就趁你喝的時候，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n說明一下今天想交辦的工作吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今天想請你幫這邊這些圖",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "全部塗上底色。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "每張圖都有指定好的顏色，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n千萬不要塗錯囉☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "塗色的時候請仔細點別漏塗了。",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果全部塗完了，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在我回來以前",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "先乖乖待著等我好嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我雖然拜託過你不少工作，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但這比起打倒霸瞳皇帝",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "或是往返艾爾皮斯島，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n總是輕鬆多了吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來你真的這麼想嗎？",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可惜不是呢～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像這種時候",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "該說可惜嗎……？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "至於我，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "得在裡頭的房間忙點事情，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以接下來就拜託你了～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喔，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n千萬不要",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像祈梨一樣",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "把壺給弄壞了喔♪",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "501330"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "時間儀，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啟動。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "開始啟動。",
        "unit_id": 14611,
        "voice": "vo_adv_1067006_011"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n已將當前時間、",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "空間座標設定為原始點。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "時空之門，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "開啟。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "將門內的時間流逝",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "與此處同步。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "時空之門，",
        "unit_id": 14611,
        "voice": "vo_adv_1067006_013"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "開啟。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n請進入時空之門。",
        "unit_id": 14611
    },
    {
        "type": "background",
        "background": "501290"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……要思考事情，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還是這地方最適合了♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "依據特定範圍的時空間內所有數據，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n開始驗證事象的變化。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "已接受指令。",
        "unit_id": 14611,
        "voice": "vo_adv_1067006_015"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "請指定範圍。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "時間設為",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "霸瞳皇帝被擊敗之日直到今天。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "空間請",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "設定為全阿斯特賴亞大陸。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "範圍設定完畢。",
        "unit_id": 14611,
        "voice": "vo_adv_1067006_017"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n將開始還原",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "阿斯特賴亞大陸至今的變化。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "驗證已開始……",
        "unit_id": 14611,
        "voice": "vo_adv_1067006_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在結果出爐前這下沒事可做了～",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "下次還是帶個塗鴉工具進來消磨時間好了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "當初為了抑制這東西的失控而把它破壞得四分五裂，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n是我好不容易才修復完畢的，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼像這種時候",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就好好為我工作吧☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個版本的系統已經透過更新做了不少改良，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_021"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n那麼只要在侷限範圍內使用機能，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就不必擔心失控了……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但由於無法增加負載，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "運算處理得多花點時間，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這點還有改善空間♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "驗證完畢。",
        "unit_id": 14611,
        "voice": "vo_adv_1067006_022"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "偵測到錯誤。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n接下來報告原因。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……！",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_023"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "從蘭德索爾",
        "unit_id": 14611,
        "voice": "vo_adv_1067006_024"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "以及阿斯特賴亞大陸的活動人口裡，",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n偵測到複數次",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "暫時性的異常。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "可播放時空間發生錯誤時的還原影像。",
        "unit_id": 14611,
        "voice": "vo_adv_1067006_025"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n請問要播放嗎？",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那個晚點再看，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "先幫我存檔起來。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣啊～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也就是說對方的據點，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n位在艾爾皮斯島，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "或者其他地方……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "外加",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_027"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對方似乎擁有無視距離的移動手段。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n對方若想發動攻擊，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也許會比預期的更早？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "加上對方大概也嗅出我們這邊放出的風聲，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼也差不多該準備因應對策了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好不容易再次跟他打好關係，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_029"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "馬上又變這樣……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我得趁現在",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "把能做的事先完成不可，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "時間儀，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_030"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "關閉。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n將檔案轉換為放映魔法的術式。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "已接受指令。",
        "unit_id": 14611,
        "voice": "vo_adv_1067006_031"
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "待時空之門封鎖後，",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n將關閉時間儀。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "時間管理員",
        "words": "\n請退出時空之門。",
        "unit_id": 14611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼……",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_032"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不知道他那頭做得怎樣了～？",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我回來了～☆",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_033"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n塗色塗得還順利嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哇～！",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_034"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "塗得真漂亮呢～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n小細節也都沒塗超過範圍，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想挑剔都沒得挑！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_035"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是今天的工資♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過這次你這麼努力，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n那麼除了報酬，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "再給你一點額外獎勵",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好了☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別客氣別客氣！",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_036"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你也累了吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓我幫你按摩肩膀當作答謝☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "他人的一片心意要坦然接受喔。",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_037"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "明白嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還是說你不願接受我的好意，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "難道其實是因為",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你討厭我……？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……應該沒這回事吧～？",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_038"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……沒錯沒錯，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_039"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "像這種時候，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只要乖乖接受他人的好意就行了♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "唔唔唔……",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_040"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不會吧～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還真是硬梆梆耶～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "平時有好好慰勞身體嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你一定是平常太操勞太硬撐了，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_041"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n疲勞全都在體內日積月累喔？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很好。",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_042"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很老實道歉♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這種事",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就像是遊戲的隱藏數值一樣，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n許多人自己察覺不出來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但你現在應該感受得到了吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就算只是這樣揉一揉背後，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_043"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "狀況也會大有改善……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣就行了♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你人還年輕，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "輕輕揉幾下就夠了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如何？",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_044"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不覺得身體輕快多了嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒錯吧～？",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_045"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以你以後",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也要像今天這樣，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n偶爾來讓我按摩按摩，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "把身體調整到最佳狀態☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畢竟你平常就已經",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "比其他人努力好幾倍了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好～",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_046"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼接下來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們上街買東西吧♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你有什麼想要的嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你是不是想說，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_047"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "自己根本沒做什麼？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不好意思，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我早料到你會這麼說了～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你平常還",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_048"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "替我照顧了嘉夜跟祈梨，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我從以前就一直覺得",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "光是請你來幫忙，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n付的酬勞根本就",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不足以報答你。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "正好我今天想去採買點東西，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_049"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你就當那是幫我提東西的謝禮，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣如何？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如此一來，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_050"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就不會有無功不受祿的感覺了吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哪裡，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_051"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不必客氣。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其實我只是想為你多做點什麼，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n說起來只是我一廂情願而已。",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500610"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "今天要採買什麼……？",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_052"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我目前缺些魔導具的材料，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n畫具好像也有些用完了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其他還有……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你怎麼會這麼想呢～！",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_053"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣講太傷人了啦～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是的～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我就只不過是，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_054"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想和你一起買東西而已♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……你該不會",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_055"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不肯相信我吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真傷心～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我說的明明都是真的呀……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_056"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是新品牌的顏料呢～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "綠色和藍色……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "用來上陰影的紫色消耗量也很大，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n不如就買點回去試試看～吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這個嘛～",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_057"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "它是黑的，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但也不是黑的。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n真要說的話，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在繪畫裡",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "影子的顏色可以不必是黑的喔。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畫的圖該上什麼顏色，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那都是畫家的自由。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過的確……",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_058"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "人眼所見的影子",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "乍看像是黑的沒錯，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但有時你別當它是黑色會更好。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好比說",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_059"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你走在地板上時，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "腳踏的地方會產生影子對吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你抬腳後產生的陰影，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看起來還會是純黑的嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "試著抬腳看看？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "腳的影子",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_060"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "跟地板顏色",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "是不是混合在一起了？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n影子的顏色會像這樣，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "隨影子的落點",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "而有所改變。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不是黑色的陰影有時看起來更加自然，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_061"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n所以你將來要是有機會畫圖，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就試著這樣上色看看吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "隨著陰影的成因而改變用色，也是很有意思的喔～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "以上就是",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_062"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "帆稀老師的繪圖講座～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n接下來",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你何不去找看看有什麼想要的呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喔喔～！",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_063"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真意想不到～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就幫你買套初學者用的畫具，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "再附送我推薦的入門書♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "只要學會畫圖，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_064"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很多地方都能派上用場喔～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n好比說目擊到逃犯時可以畫出對方長相，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也可以像我一樣",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在畫裡夾藏暗碼之類的……☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……呵呵，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_065"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你表情就像是在說～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你才不會拿來這麼用呢～♪",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝你幫我提東西～！",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_066"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n送你的畫具跟入門書，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "希望你能好好珍惜♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "接下來不知道還能為你做些什麼～",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_067"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你還有什麼其他事，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "希望我幫忙的嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "作業！",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_068"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "多麼令人懷念的字眼～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對喔。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你目前就讀月光學院是嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n是什麼的作業呢？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "體育以外的我全都幫得上忙喔～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼本人帆稀老師，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_069"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n今天就暫時擔任",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你的專屬家庭教師～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n雖然我體育不行，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "健康教育倒是能讓你拿滿分☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所以是怎樣的作業呢～？",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_070"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓我看看內容吧♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你放在公會小屋裡？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我在這裡等你，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你快去帶過來吧。",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "501320"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哼嗯～",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_071"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "讓我瞧瞧……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "喔喔～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來如此～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "關於這個算式的問題，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_072"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "首先",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你應該學過這道公式吧？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好比說要是碰上這樣的問題，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這時",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你只要像這樣代入公式，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這邊則是這麼做……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣懂了嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "對對對！",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_073"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣的概念就對了☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n接下來你就比照剛才，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "試著從這一題開始解起吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……一百分～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_074"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "作業順利完成～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n想不到替人指導功課，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "原來是這麼有趣的事情～！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "感覺連我的思緒也清晰起來了。",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_075"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不知道是不是因為腦袋動用到",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "平常比較少動用的部分？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "能為你做許許多多的事，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_076"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我今天就已經很滿足了～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n希望你也這麼覺得呢……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……能問你一件事嗎？",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_077"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n接下來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你有什麼打算？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我是指今天以後。",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_078"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……我只想跟你、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嘉夜以及祈梨……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n還有",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "其他家族成員，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一起矯正這個錯誤的世界。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "等到一切都結束，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_079"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n能夠每天快快樂樂地過日子，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我只要這樣就夠了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "到時還得讓你學習許許多多的不法勾當，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_080"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n讓你當上我們家族的幹部才行☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……不過",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_081"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣的願望肯定無法如願。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "身在某處的某人，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "一定不會讓我這麼做。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我也有自己的事得忙，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_082"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "基本上只是個旁觀者，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但要是想對你動歪腦筋的人某天現身了，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n到時我們再一起加油吧……♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_083"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "背負了一個人難以負荷的沉重命運。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n但那卻是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我無法插手的事。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你就維持原樣，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_084"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "以自己的方式加油吧。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "觀察這樣的你，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可是我目前最大的樂趣呢♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不管世界是如何狂亂，",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_085"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你的希望",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "以及絕望……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "所有的一切，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我全都會看著的……☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……玩笑就開到這邊吧～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067006_086"
    },
    {
