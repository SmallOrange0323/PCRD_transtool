    },
    {
        "type": "background",
        "background": "510330"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼了嗎學長，",
        "unit_id": 106531,
        "voice": "vo_adv_4010181_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "突然帶我到這種地方。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯……",
        "unit_id": 106531,
        "voice": "vo_adv_4010181_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你還記得啊。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不對，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "對學長來說這點小事是理所當然吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "在我的生日帶我來雜貨店",
        "unit_id": 106531,
        "voice": "vo_adv_4010181_002"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "的意思是，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n難道說",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊哈哈……",
        "unit_id": 106531,
        "voice": "vo_adv_4010181_003"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝你，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我很高興。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過～",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "禮物是要這樣一起挑的東西嗎？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n印象中在漫畫之類的裡面，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好像都是事先準備好的",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "就是了。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦？",
        "unit_id": 106531,
        "voice": "vo_adv_4010181_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "一起挑也許會比較有趣？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "喔～",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "原來如此，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "也能這麼想啊。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那麼",
        "unit_id": 106531,
        "voice": "vo_adv_4010181_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你先挑看看。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n挑適合我的。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "感覺",
        "unit_id": 106531,
        "voice": "vo_adv_4010181_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你是想讓我變可愛？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我是不討厭啦，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n但我的形象",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "比較像是",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那種……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "咦？",
        "unit_id": 106531,
        "voice": "vo_adv_4010181_007"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "難道說學長，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你覺得我是可愛類型的？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "那還真是……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "嗯，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "好像",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "有點",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "高興？",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，",
        "unit_id": 106531,
        "voice": "vo_adv_4010181_008"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "禮物果然還是讓我選吧。",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "學長，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這之後要逛很多店家，",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "你都要陪我喔！",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n因為……",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "感覺這樣",
        "unit_id": 106531
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "能讓生日更加愉快。",
        "unit_id": 106531
    }
]