[
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}今天也接受了深月的實驗。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "啊啊，今天也取得了很有趣的實驗數據呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "跟你做實驗真的很有意義呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過我有點擔心呢。",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n最近，我開始覺得沒有你的實驗有點無聊呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這下糟糕了呢。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣下去的話，總有一天我可能就不讓你回家了。",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如果是這樣的話，我們只好一起住了。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "結婚……",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "結婚啊。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我對這種社會規範的形式沒興趣。",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你不覺得就算不結婚，只要能在一起的話，這樣就好了嗎？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……嗯，這道光是怎麼了。",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n實驗的話應該早就結束了……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦……說起來，之前好像也有相同的光……",
        "unit_id": 105111
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "──喂喂？",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好久不見！是從同學會之後吧。怎麼了？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不用擔心我。我有好好活著啦。",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n今天是我久違的休假呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳呢？最近如何了？",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣啊，那就好。就只有這一件事而已？",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "下次一起去吃飯──",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "結婚對象？怎會有那種對象啊。",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我老是忙著研究啊實驗之類的……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……不是吧？",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "恭喜妳！記得邀請我去婚禮喔？",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就算通宵三天我也會去的，日子定好了就告訴我吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "再見。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唉……",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n結婚啊……",
        "unit_id": 105131
    },
    {
        "type": "still",
        "still": "105100801"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……終於拿起來了。",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我竟然也會有買結婚雜誌的一天……！",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒想到兒時玩伴的結婚通知，會令我這麼在意……",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗚……光是回想起來就令我不好受。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然我明白焦急是不會有好結果的……",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "得快點去結帳。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "什麼！？你、你為什麼在這裡！？",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不對，先別說這個……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "難、難道……你看到了？",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "哇！……不、",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不是啦。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這不是要結婚的人會買的雜誌，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n是想結婚的人才會買的雜誌。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不要讓我說出口啦。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "到了這個年齡，身邊越來越多朋友都結婚了……",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n雖然我並不是很想結婚，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n該說是一時鬼迷心竅嗎……",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……這話居然由你來問嗎？",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你說這是什麼意思……",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你也是充滿罪孽的男人呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "或者該說你太遲鈍。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯，不過準備好再說也比較好呢。",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……我可能有點太慌張了。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "當、當然啦，怎麼了……？",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……當、當然想結婚這個想法是有的啦。",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不過，我也有我想做的事。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這麼一想……",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n可能還不到被周圍影響而焦急慌張的時候呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……不過，這本書還是先買好了。",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n你等我一下。",
        "unit_id": 105131
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "剛剛真是謝謝你。",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_027"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n跟你聊天之後，心情舒暢了不少呢。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "如何？ 現在一起去吃個飯吧。",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_028"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就當作你讓我恢復精神的謝禮，我來請客吧。",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "多虧了你，現在我的心情變好了一點，",
        "unit_id": 105131,
        "voice": "vo_adv_1051008_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不過如果我遲遲都結不了婚的話，",
        "unit_id": 105131
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你會給我負責任吧？",
        "unit_id": 105131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1051008_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你看見的，是如同夢境一般的情景唷。 ",
        "unit_id": 190011,
        "voice": "vo_adv_1051008_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你醒來以後幾乎都會忘記的， ",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以沒關係，不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來，深月其實是想結婚的呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1051008_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到了那種年齡，自然而然就會在意的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過我以為她只對實驗有興趣。",
        "unit_id": 190011,
        "voice": "vo_adv_1051008_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而且以為那才是深月的樣子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "說不定讓深月有想結婚的念頭……",
        "unit_id": 190011,
        "voice": "vo_adv_1051008_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是因為受某人的影響？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑的～這次就先聊到這裡吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1051008_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯……",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_036"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "咦、咦。",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我在這種地方睡著了？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "總感覺之前也發生過類似的事……",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_037"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對了，我是跟你一起睡著了，還跟你做了相同的夢……",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "欸？你說夢見我去買結婚雜誌？",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_038"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那、那個，跟我做的夢一樣……？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "話說回來，你都夢到什麼了！",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_039"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "給我忘掉，現在馬上忘掉！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為太難為情了嘛！",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_040"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然嘴巴上說著對結婚沒興趣，",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但其實是很想結婚的……！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那是夢而已啦！我並不是真的很想結婚！",
        "unit_id": 105111,
        "voice": "vo_adv_1051008_041"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然不是想結婚，但也請你忘了吧！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
