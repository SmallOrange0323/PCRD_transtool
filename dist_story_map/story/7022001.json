[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "閃亮亮☆",
        "unit_id": 101211,
        "voice": "vo_adv_7022001_000"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哦～",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "初音美眉真不是蓋的。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n竟然一擊就打倒了強大的魔物。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "難不成",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛才那招魔法裡也有什麼祕密……？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那只是很平常的魔法啦～",
        "unit_id": 101211,
        "voice": "vo_adv_7022001_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不過小七七香，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對不起唷。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n都是因為我睡著，也給妳添麻煩了。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒什麼沒什麼。",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_003"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "倒不如說",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "能欣賞到那麼可愛的睡臉，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n真的真的感謝妳呀。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "話又說回來，",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "初音美眉沒事嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯？",
        "unit_id": 101211,
        "voice": "vo_adv_7022001_005"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "什麼意思？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳明明用了需要代價的強力魔法，",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n還要繼續爬塔不會很辛苦嗎～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是說這個啦。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊、",
        "unit_id": 101211,
        "voice": "vo_adv_7022001_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃～～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果是擔心這個，我沒事的。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "塔上似乎施有魔法，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "剛才途中就被擋下了，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n跟平常比起來我的超……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "魔力消耗沒有那麼多啦。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這裡竟然連初音美眉用的特殊魔法都能阻擋……",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這座塔",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "果真不尋常呢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "仔細想想，",
        "unit_id": 101211,
        "voice": "vo_adv_7022001_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就算一口氣飛上去，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n要是我又因此想睡，{player}也會很困擾。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "幸好失敗了呢。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過話說回來，",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_010"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那到底是什麼魔法？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我第一眼",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "見到時覺得像是轉移魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但好像～又不太一樣耶。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃、",
        "unit_id": 101211,
        "voice": "vo_adv_7022001_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃～～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那、",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那個是……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊、",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "要是不方便說",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也沒關係啦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "確實，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳要是願意告訴我，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "會幫我大忙，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但那也是妳辛苦想出來的魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "本來就不能輕易教人嘛！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也不是因為這樣啦……",
        "unit_id": 101211,
        "voice": "vo_adv_7022001_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "七七香我這個人呀，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一看到新魔法，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n就忍不住想要追根究柢。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "因為我可是……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法少女呢！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好啦好啦，",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這些小細節就不用在意了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "人總是得重視自己的探究心，對吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果妳不教我，",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那我就自己看著妳偷學囉。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我可不會放過",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "初音美眉的一舉一動唷！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "緊盯～～～～",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "妳這樣盯著看，我會很難為情啦～",
        "unit_id": 101211,
        "voice": "vo_adv_7022001_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "噢～～",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_019"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "美少女羞紅雙頰的樣子",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是百看不厭哪～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……等等，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這樣可偏離我原本的目的啦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我還想",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "繼續做個認真鑽研魔法的",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "健全魔法少女呀！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊哈哈，",
        "unit_id": 101211,
        "voice": "vo_adv_7022001_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小七七香真風趣呢。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我那招不是想教就能教的，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n但若能幫上妳的忙，我也很高興。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "反正",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就算我的目的達不到，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n只要能找到有關{player}記憶的線索，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n也就好了。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們一起加油吧！",
        "unit_id": 101211,
        "voice": "vo_adv_7022001_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不過",
        "unit_id": 101311,
        "voice": "vo_adv_7022001_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "魔法歸魔法……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "盯著初音美眉看",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "實在是太養眼了，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我要不停地一直看下去～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦～～～～！？",
        "unit_id": 101211,
        "voice": "vo_adv_7022001_025"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，初音在被七七香緊盯不放的狀態下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n往塔的上層前進。"
    }
]