[
    {
        "type": "background",
        "background": "500552"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "大家真的辛苦了呢。",
        "unit_id": 511,
        "voice": "vo_adv_5010007_000"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n今年的情況變得特別嚴重。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 108911,
        "voice": "vo_adv_5010007_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的是很辛苦呢。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就算這樣，",
        "unit_id": 108711,
        "voice": "vo_adv_5010007_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也幾乎沒有出現受傷的人呢！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "受傷的人只要靠著優衣的魔法",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "馬上就治好了！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "只是些逃跑時的擦傷",
        "unit_id": 108811,
        "voice": "vo_adv_5010007_003"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "或撞傷之類的，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那些不用我的魔法，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "也應該能自然痊癒。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "來參拜的各位",
        "unit_id": 511,
        "voice": "vo_adv_5010007_004"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "也都很開心呢。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "關於這次的報酬，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "我在一開始提到的金額上，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n稍稍地添加了一點心意。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了——！　",
        "unit_id": 108711,
        "voice": "vo_adv_5010007_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "非常感謝您！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝您的好意。",
        "unit_id": 108911,
        "voice": "vo_adv_5010007_006"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "沒有的事。",
        "unit_id": 511,
        "voice": "vo_adv_5010007_007"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "我能做的也只有這樣……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "各位所做的努力",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "真的遠遠超出報酬呢。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n可以的話，希望今年底也要麻煩你們了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……我、",
        "unit_id": 108711,
        "voice": "vo_adv_5010007_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們會好好考慮的！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "吶，",
        "unit_id": 108911,
        "voice": "vo_adv_5010007_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "最後我們去供奉繪馬吧。",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "久等了——！",
        "unit_id": 108711,
        "voice": "vo_adv_5010007_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總覺得裝飾繪馬好令人興奮呢——",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生知道繪馬嗎？",
        "unit_id": 108811,
        "voice": "vo_adv_5010007_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在木製護符上，",
        "unit_id": 108811,
        "voice": "vo_adv_5010007_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "把今年想實現的願望寫下來",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n供奉在神殿裡。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就是這個。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這是騎士先生的。",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "願望啊，",
        "unit_id": 108711,
        "voice": "vo_adv_5010007_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "想要許幾個願都可以唷！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果大家的願望實現了，",
        "unit_id": 108811,
        "voice": "vo_adv_5010007_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "再一起來參拜吧！",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生，",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "想要許什麼願望呢？",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼大家看來都寫好了，",
        "unit_id": 108711,
        "voice": "vo_adv_5010007_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就交換看吧！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼要開始囉——！　",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一二三！",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "好！",
        "unit_id": 1,
        "voice": "vo_adv_5010007_016"
    },
    {
        "type": "dialogue",
        "name": "繪馬的文字",
        "words": "『希望大家",
        "unit_id": 1,
        "voice": "vo_adv_5010007_017"
    },
    {
        "type": "dialogue",
        "name": "繪馬的文字",
        "words": "能一直",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "繪馬的文字",
        "words": "在一起』",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我回來了……",
        "unit_id": 108711,
        "voice": "vo_adv_5010007_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "終～於抵達了……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "已經累到全身軟趴趴了〜……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算是我也快不行了……",
        "unit_id": 108911,
        "voice": "vo_adv_5010007_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？　",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣還有他呢？",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼……呼……",
        "unit_id": 108811,
        "voice": "vo_adv_5010007_020"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……已經睡著了。",
        "unit_id": 108711,
        "voice": "vo_adv_5010007_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼啊……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也來睡吧……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "躺在優衣的旁邊，",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "打擾囉……",
        "unit_id": 108711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼……呼……",
        "unit_id": 108711,
        "voice": "vo_adv_5010007_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也",
        "unit_id": 108911,
        "voice": "vo_adv_5010007_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "快不行了……",
        "unit_id": 108911
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "大家晚安……",
        "unit_id": 108911
    },
    {
        "type": "still",
        "still": "501000701"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……今年也",
        "unit_id": 108811,
        "voice": "vo_adv_5010007_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "請多指教……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唷……",
        "unit_id": 108811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼……",
        "unit_id": 108811
    }
