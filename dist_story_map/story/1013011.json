        "type": "dialogue",
        "name": "七七香",
        "words": "看他好像也是一副樂在其中的樣子……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，",
        "unit_id": 101332,
        "voice": "vo_adv_1013011_054"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊～",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "請餵我吃一口吧～",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n開個玩笑而已……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呼喔喔喔！",
        "unit_id": 101332,
        "voice": "vo_adv_1013011_055"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n等等等等等！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "玩笑！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我是玩笑的！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們趕緊開動吧！！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好嗎！？",
        "unit_id": 101332
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1013011_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "七七香的男朋友，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "當的還挺稱職的嘛。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次就稱讚你吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "倒是",
        "unit_id": 190011,
        "voice": "vo_adv_1013011_057"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "七七香她也真是的～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "都察覺到自己的真心了卻還要裝傻下去。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這下真不曉得到底誰才是遲鈍男主角了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了，",
        "unit_id": 190011,
        "voice": "vo_adv_1013011_058"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "玩笑就開到這裡。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不管動畫還是電玩，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總是能全心全意地投入所好。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她真是個認真的女生呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過",
        "unit_id": 190011,
        "voice": "vo_adv_1013011_059"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "經歷了這件事，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也許她接下來",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就能夠面對自己的真心了吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼到時候，",
        "unit_id": 190011,
        "voice": "vo_adv_1013011_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你也要誠懇地面對七七香喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就到此結束。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "下次見囉～",
        "unit_id": 190011
    },
