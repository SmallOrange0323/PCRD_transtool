        "voice": "vo_adv_1013011_042"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我們倆完美演出！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "像兩位這麼有默契的情侶檔可不多喔。",
