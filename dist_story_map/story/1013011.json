        "voice": "vo_adv_1013011_039"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n因果的羈絆兩相纏繫！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嘶吼吧，",
        "unit_id": 101332,
        "voice": "vo_adv_1013011_040"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "必殺！",
