[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，七七香針對「黑暗魔導書」與「黑暗收藏家」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n蒐集了許多情報。"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "大概就像這樣吧～",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_000"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "所以才想問妳是不是知道些什麼。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "「黑暗收藏家」嗎。",
        "unit_id": 1211,
        "voice": "vo_adv_1013011_001"
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "那人最近好像是有些什麼動作。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "最近指的是，",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_002"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "之前這幾天嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "是啊。",
        "unit_id": 1211,
        "voice": "vo_adv_1013011_003"
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "聽說發掘出罕見魔導書的那間店裡，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "\n有幾個人跑去施展了前所未見的魔法鬧得天翻地覆。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "前所未見的魔法，",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗎。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那應該是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "「黑暗魔導書」賦予他們的魔法吧。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哼嗯……",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_005"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "明明「黑暗魔導書」在我這裡，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "也一樣嗎。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "看來那魔法一旦賦予，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "即使手頭沒有「黑暗魔導書」",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n還是能夠照常施展吧。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "倒是原來有「黑暗魔導書」這種東西。",
        "unit_id": 1211,
        "voice": "vo_adv_1013011_006"
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "雖然聽起來有點難以置信，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "\n但這下事情就說得通了。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "欸，",
        "unit_id": 1211,
        "voice": "vo_adv_1013011_007"
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "那東西能借我一下下嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這可不～行。",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_008"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "應該說，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我現在也還是脫不了手的狀態啦～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不管把它藏到哪兒去，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "都會不知不覺間回到我手裡。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "何況",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "根據對方的反應，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這東西應該是真的每人限用一次。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n那麼妳不如等到等級提升後再嘗試比較好。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "……",
        "unit_id": 1211,
        "voice": "vo_adv_1013011_010"
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "也對。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "那我就",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "等魔法的實力更進一步後再跟妳借吧。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好好好～",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "隨時等妳來～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "唉～",
        "unit_id": 1211,
        "voice": "vo_adv_1013011_012"
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "妳今天還真是從容大方喔。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "受不了妳們這種帶著男朋友的現充。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼？",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n妳哪壺不開提哪壺，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n竟然跟七七香我這種魔法宅中之宅說這種話！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "因為，",
        "unit_id": 1211,
        "voice": "vo_adv_1013011_014"
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "不就在妳後面嗎。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "男朋友。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "男朋友？",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_015"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啥？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔哇啊啊啊！",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你你你、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你是哪時在的！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嚇得我心臟差點從嘴裡跳出來了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "意思是他還不只是男朋友嗎？",
        "unit_id": 1211,
        "voice": "vo_adv_1013011_017"
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "\n真有妳的。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哇啊",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_018"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊啊啊！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n你、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你你你、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "在胡說些什……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦咦咦咦咦！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "是是是，",
        "unit_id": 1211,
        "voice": "vo_adv_1013011_019"
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "多謝放閃。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "好吧，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "反正帶著男朋友的女生總是這麼說嘛～",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "現在幸福就夠了，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "其他我別無所求！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "類似這種話。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啥？沒啦，",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不是的……！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "繼續打擾妳們也不好，",
        "unit_id": 1211,
        "voice": "vo_adv_1013011_021"
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "我看我就先走一步吧～",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "唉～",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女魔法使",
        "words": "我看我也別找魔法改找男朋友好了～",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呃，",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_022"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那個……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊哈哈……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "剛剛她",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "還真是誤會大了……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n這樣子……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對你應該很困擾吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為為為為為、",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_023"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為什麼？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等等，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不對啦，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "現在不是開玩笑的……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦咦咦？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦？",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_024"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "有嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這這、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這並不是",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "詛咒帶來的影響，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "呃嗯……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唔喔，",
        "unit_id": 101311,
        "voice": "vo_adv_1013011_025"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好刺眼！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼像是在發光……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等等，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這一幕以前好像似曾相識啊──！",
        "unit_id": 101311
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔！",
        "unit_id": 101332,
        "voice": "vo_adv_1013011_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "救世主來啦～！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "裡這裡！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我在這裡～！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔～",
        "unit_id": 101332,
        "voice": "vo_adv_1013011_027"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是感激不盡～",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "謝謝你今天來陪我！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯？",
        "unit_id": 101332,
        "voice": "vo_adv_1013011_028"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼了嗎？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n喔喔，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這串人龍嗎……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等等，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你竟然",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "不知道嗎！？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這間店目前正舉辦",
        "unit_id": 101332,
        "voice": "vo_adv_1013011_029"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "期間限定的神滅聯名咖啡廳。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不過正確來說",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "其實是神滅的巴哈姆提亞，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n裡頭的魔法少女活動的聯名咖啡廳就是了！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哈～",
        "unit_id": 101332,
        "voice": "vo_adv_1013011_030"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真棒……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是太迷人了！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這魔法少女版本的莉莉艾利！",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "雖然當初",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "風向並不看好這角色，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "認為跟世界觀格格不入，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n但那與平常不一樣的角色間交流，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "反而賦予了角色不一樣的深度呢。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而要是",
        "unit_id": 101332,
        "voice": "vo_adv_1013011_031"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "再從中推導出",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "角色至今的關聯性，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那又更加，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好尊……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真是",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "尊度破表了……",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "糟糕，",
