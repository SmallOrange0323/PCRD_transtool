        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "走吧，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "進攻──！",
        "unit_id": 101332
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊，",
        "unit_id": 101332,
        "voice": "vo_adv_1013011_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "點餐可以全部交給我來嗎？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我已經完美預習過，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "想好要怎麼點才能蒐集全套贈品了。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喔，",
        "unit_id": 101332,
        "voice": "vo_adv_1013011_034"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "錢當然會由我出不必擔心。",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n餐點就當成是你陪我參加的謝禮，",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好嗎？",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101332
    },
    {
        "type": "dialogue",
        "name": "七七香",
