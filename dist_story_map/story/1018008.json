[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一起去買東西的\n{player}和伊緒。"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，和你一起出來買東西，",
        "unit_id": 101811,
        "voice": "vo_adv_1018008_000"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n真開心。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n好像約會一樣。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？ 這是那時候的光……？",
        "unit_id": 101811,
        "voice": "vo_adv_1018008_001"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n啊，好耀眼……！",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！",
        "unit_id": 101811,
        "voice": "vo_adv_1018008_002"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "？",
        "unit_id": 101811
    },
    {
        "type": "still",
        "still": "101800801"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_003"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你醒來了呀。太好了～",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "記得嗎？",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_004"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你和其他男生鬧著玩的時候，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n從樓梯摔下來了喔？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我好擔心你會不會就這樣",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_005"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n醒不過來了……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，還不可以亂動喔！",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_006"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "要好好休息才行。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "而、而且……",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_007"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你動來動去的話，好癢喔。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是呀，因為剛剛你好像睡得很不舒服的樣子……",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_008"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這樣不好嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "欸！不行啊！",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_009"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n要是去了天堂，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n就再也醒不過來了！",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……？",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不是那個意思嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n是很舒服嗎？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，太好了。",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_011"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你這樣說我真開心。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那就再繼續躺一會兒……",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_012"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "等到你感覺舒服一點，就維持這樣吧？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "沒關係唷。",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_013"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n沒有其他人在。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "只有我們兩個人，你可以盡情撒嬌喔。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……啊！",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_014"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你的手指流血了……",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "是摔倒的時候擦傷的吧。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "讓我看看。",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_015"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……這樣大小的傷口，",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n只要舔一舔就沒事了。",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "蛤嗯……",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_016"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……嗯！這樣就沒問題了。",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_017"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "咦？怎麼了？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n臉紅通通的……",
        "unit_id": 101831
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "510211"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "我只是來看看狀況……",
        "unit_id": 1,
        "voice": "vo_adv_1018008_018"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "\n你這是在做什麼啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "竟然躺在我們伊緒的膝蓋上，",
        "unit_id": 1,
        "voice": "vo_adv_1018008_019"
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "\n還強迫她舔你的手指！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "不可原諒！極刑懲罰才行！",
        "unit_id": 1,
        "voice": "vo_adv_1018008_020"
    },
    {
        "type": "dialogue",
        "name": "男學生１",
        "words": "\n大家上吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊！",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_021"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n你要去哪裡！？",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "別跑！",
        "unit_id": 1,
        "voice": "vo_adv_1018008_022"
    },
    {
        "type": "dialogue",
        "name": "男學生２",
        "words": "\n快追！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "呵呵，太好了。",
        "unit_id": 101831,
        "voice": "vo_adv_1018008_023"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101831
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "這麼有活力的話，應該沒事了。",
        "unit_id": 101831
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？這是我給你的禮物！",
        "unit_id": 190011,
        "voice": "vo_adv_1018008_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你做了個好『夢』嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是我依照你和伊緒的記憶創造出來的『夢』，",
        "unit_id": 190011,
        "voice": "vo_adv_1018008_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n原來現在的你會採取這樣的行動啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我看了也很開心呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1018008_026"
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，你醒了嗎？",
        "unit_id": 101811,
        "voice": "vo_adv_1018008_027"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "嗯，我剛剛也睡著了……",
        "unit_id": 101811,
        "voice": "vo_adv_1018008_028"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n又做了不可思議的夢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "你也是嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "我照顧你的夢？",
        "unit_id": 101811,
        "voice": "vo_adv_1018008_029"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "果然是同樣的夢呢……",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n發生好幾次這種事，真是好不可思議呢。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "啊，話說回來，我們原本要去買保健室的用品對吧？",
        "unit_id": 101811,
        "voice": "vo_adv_1018008_030"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……所以才會做這種夢嗎？",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "那我們快去買東西吧。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "……啊，小心點。",
        "unit_id": 101811,
        "voice": "vo_adv_1018008_031"
    },
    {
        "type": "dialogue",
        "name": "伊緒",
        "words": "\n不要像夢裡面一樣跌倒受傷了。",
        "unit_id": 101811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和{player}一起去買東西的路上，\n伊緒心中期望著可以再做同樣的夢。"
    }
]