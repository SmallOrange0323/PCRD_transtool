[
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，苑，",
        "unit_id": 107111,
        "voice": "vo_adv_4012012_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "彩羽在嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我在想只交鋒戰鬥有點缺乏樂趣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n下次的休假",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可以邀她去大江戶的溫泉旅館呢☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "成熟的女人",
        "unit_id": 107111,
        "voice": "vo_adv_4012012_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一起在露天溫泉坦誠相見吧☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我們可以一起享用「神醉」，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "欣賞彼此的肉體，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n用肌肉交流……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很棒的行程吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "嗯──",
        "unit_id": 132512,
        "voice": "vo_adv_4012012_002"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "我覺得應該不可能。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "那孩子最討厭洗澡，",
        "unit_id": 132512,
        "voice": "vo_adv_4012012_003"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "沒浸在浴池裡滿一百秒過。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n最後還會，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "92、",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "93、",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "94、",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "95……！！",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "像這樣",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n念超快混過秒數。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "還有",
        "unit_id": 132512,
        "voice": "vo_adv_4012012_004"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "她也不喜歡洗髮精，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "會無故揉別人的胸部，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n一洗完澡就到處跑，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "還會勉強一口氣喝光牛奶，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n然後因為喝太多而搞壞肚子。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "另外，",
        "unit_id": 132512,
        "voice": "vo_adv_4012012_005"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "彩羽現在去外面了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n說要去玩",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n「假裝自己只能走在陰影處」的遊戲。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……根本是小孩子吧。",
        "unit_id": 107111,
        "voice": "vo_adv_4012012_006"
    }
]