[
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}！",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒事吧？",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n啊，太好了你沒事……！",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還記得嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你被當面施放了大量破壞魔法，因為那衝擊而失去了意識！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以才能像這樣和我在夢中對話啊！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但能夠進行對話，代表是還活著對吧？",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒有被大量破壞魔法，給轟飛了對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n儘管能夠預見即將發生的狀況，我也無法對這個世界做出干涉……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就算看到你陷入了危機，我也什麼都做不到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真不甘心。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n成為那從邪惡的手中守護你的最後一道防線，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n明明就是我的使命。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……不。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n氣餒的話還是留在之後吧。現在該做的，是完成我的責任。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這個夢中，給予你助言。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "得將這個可說是微乎其微的支援，貫徹始終地做下去呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這一次，你最大的敵人終於親自現身了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒錯。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這段時間以來，躲藏在故事最深處那位被稱為『陛下』的傢伙，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n終於露出真面目了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這個世界，她自稱為尤絲蒂亞娜來著。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "尤絲蒂亞娜嗎……原來如此，處於那個立場上呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若現在試著和你解釋清楚，也只會讓你更加混亂，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以關於那傢伙的真實身分，還不會和你講得太清楚呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之那傢伙，是個超越了性別、年齡、國籍種種要素的怪物喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在這個世界，擁有著可說是等同於上帝一樣的權能。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是正大光明地君臨於王宮中的龍椅，",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n且理所當然地演繹著支配人們的統治者。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不管是魔力、戰鬥力、權力、財力，全都和你不是同個層級的唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "曾經，這個世界差一點就被那個傢伙給毀滅了喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你，則是為了阻止那傢伙的野心而奮戰的英雄唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然你因為喪失了記憶，什麼都不記得就是了。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但不就這麼叫過了你很多次了嗎？叫你『主角』。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而那就是字面上的意思唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你就像是故事裡的主角一樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n曾經和那最終頭目……是身為最強大敵人的他對決過了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也與為數眾多的夥伴們同心協力，相互扶持了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而在那群夥伴之中可謂最具功勞的人，",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也是將你引領至這個世界的人物……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就是這一次，在你面前所現身的拉比林斯達唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然還另有其本名的樣子，但目前皆以此假名自稱喔。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "且並未探明她真正的目的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n只知道她率領著祕密集團【拉比林斯】，試圖解開世界之謎而已。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和我們，有相同的目標呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然無法完全斷言是否為同伴，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但當前的利害關係似乎是一致的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在這之後，若有機會與【拉比林斯】接觸，",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n試著交換各自所擁有的情報，或許也不錯。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n將能夠，大幅度逼近世界之謎的真相也說不定。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然由我來告訴你也不是不行，但我們只能像這樣在夢中對話。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n而你在這裡獲得的知識，大多無法保留到現實之中呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "倘若可以，還是希望你能夠在現實中觸及真相。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為若不這麼做，我不就會被認為是個～在夢裡反覆地，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n講著這些鬼話的怪傢伙了嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而你也許無法獲得周遭人們的協助呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n所以，你還是必須在現實之中去觸及真相唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "且這次一定要將那邪惡之敵的野心給完全粉碎，",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n與夥伴們齊心去拯救這個世界唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可是，得盡可能加緊腳步了。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_026"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "比想像中的還更沒餘裕了喔，再悠哉下去可就沒時間囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "敵人似乎將曾經阻止過他那野望的你，",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_027"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n視為一位挺危險的人物呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n警戒著，甚至使出了渾身解數的力量試著要除掉你喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "實際上，這一次也是相當不太妙的唷。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_028"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n他試著想要將還沒有任何心裡準備的你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n和這世界中重要的人物們給一次剷除。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但似乎是託了拉比林斯達做了些什麼事的福，",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_029"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n看起來勉勉強強保住了小命就是了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一般來說，有可能就這樣全結束了喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算運氣真好呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_030"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但，不可能每次都這麼幸運喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n今後也請比現在更加的小心，並抱持著更深的覺悟活下去。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想必在今後還會有更多悲傷、難受、苦痛的事，……",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_031"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然我除了眼睜睜看你被這悲劇的洪流吞噬以外，什麼也做不到。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但至少讓我為你祈禱。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_032"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n祈禱你不會輸給那惡意，並且創造奇蹟拯救了這個世界。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "若是你一定辦得到的，{player} 。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n畢竟，你可是被所有人給愛戴著，是這個世界的主角呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "加油呢",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不用擔心。",
        "unit_id": 190011,
        "voice": "vo_adv_2005010_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要還活著，就一定會有出路的唷。",
        "unit_id": 190011
    }
]