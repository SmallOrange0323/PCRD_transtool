[
    {
        "type": "background",
        "background": "500692"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "似似花跟{player}在大間的海邊享受著假期。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這時他們正在滿天星空下眺望著大海。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……被月光照耀的大海，",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n看起來還挺夢幻的呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……偶爾像這樣",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "一邊聽著海浪聲，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n一邊悠閒地度過似乎也不錯。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你說的對。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就讓大腦放空，悠閒地度過……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……雖然我很想這麼說，",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但看樣子",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是沒有辦法了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是的，",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "事情一件接一件……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……唉，算了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "機會難得，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就來好好玩玩吧。",
        "unit_id": 126611
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}正在享受暑假。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當他從便利商店買完冰回到家後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n發現客廳裡有一位意外的訪客在等著他。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "早安。",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n雖然天氣很熱，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但一早就吃冰實在是令人無法接受呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "答案很簡單。",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "因為我和你的母親關係變親，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以她讓我進了家門……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是如此而已。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "怎麼可能，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然是每天都忙得不可開交。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這麼忙碌的我",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "特地抽空為你帶來了一個好消息，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n倒是希望你能對我表達感謝之意呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是一筆交易。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要你答應我的要求，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "做為報酬，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我會實現",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你所有的願望。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "穩定的工作、",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "社會上的地位，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或是權力、",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "人人稱羨的豪宅。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "甚至等你考到駕照後，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想要買輛高級車也沒問題。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你想要什麼？",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這邊有準備一張空白支票，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你可以隨意填入想要的金額。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你的警戒心不需要那麼重。",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_011"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就直說了……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要不要捨棄晶，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "改為跟我合作？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……喔，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原來如此。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n與晶之間的羈絆更加重要，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你是這個意思吧？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我早就想到你會這樣回答了。",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "假如你接受了這個提議，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我反而會很失望。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你的判斷很正確。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是……",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你拒絕了七冠的要求。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這可是不被允許，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "且絕不能被原諒的事情。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就特別放你一馬吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "聽好了，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你可是欠了我一個人情。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要是不還，我可不知道會發生什麼事……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "事到如今還在說什麼。",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你以為我是誰？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我可是變貌大妃，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現士實似似花喔？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好了，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼就請你馬上還我這個人情吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算拖下去，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也只會增加利息罷了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "趁你還得起的時候，趕緊出發吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說到夏天，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那當然是海邊。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你有護照嗎？",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算沒有也無所謂，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這不是什麼大問題。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天，似似花與{player}兩人──"
    },
    {
        "type": "still",
        "still": "126600401"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "來到了地中海某座島嶼上的海灘。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣你多少理解到跟七冠扯上關係，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n會有什麼下場了吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……差不多到執行任務的時間了。",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我們",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再把手挽得更緊一點，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在得向對方展現出我們是很親密的關係。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "之後我會再詳細跟你說明。",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你現在",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只要知道我們正在執行",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "一項重要的作戰就可以了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n記得抬頭挺胸，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "照我說的去做。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要是失敗了……",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你知道會有什麼下場吧？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請看前方，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有一名壯碩的男人正朝我們走過來。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n他",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是某位黑手黨老大的保鑣。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "切記不要做出奇怪的舉動，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也不要露出一臉困惑的樣子。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n無論發生什麼事，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都要配合我的行動。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣我就能保證你的安全。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "……很榮幸能見到您，",
        "unit_id": 331,
        "voice": "vo_adv_1266004_025"
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "似似花小姐。",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "\n",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "您能夠特地前來，",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "老大也感到很高興。",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "\n",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "……請問這位是？",
        "unit_id": 331
    },
    {
        "type": "still",
        "still": "126600402"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是我的老公。",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……受不了，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你到現在都還不習慣這個稱呼嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真拿你沒辦法。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你就是這一點很可愛呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "原來",
        "unit_id": 331,
        "voice": "vo_adv_1266004_028"
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "是您的老公嗎？",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "那還真是失禮了。",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "\n他看起來",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "相當地年輕呢。",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這也不能怪你，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n畢竟日本人的臉看起來都比較年幼呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們明明這麼相親相愛，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你卻不相信我們是夫妻，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還真是困擾呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "老公",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你也說點什麼吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "……",
        "unit_id": 331,
        "voice": "vo_adv_1266004_031"
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "我明白了。",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "等時間一到，我會來為您帶路。",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "\n在那之前，",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "請兩位在海灘上好好享受吧。",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "\n",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "今晚的交易",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "還麻煩您多幫忙了，",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "保鑣",
        "words": "容我先走一步。",
        "unit_id": 331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……那麼，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "周圍已經沒有其他人了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "時間還沒到之前，我們就來悠閒地享受海水浴吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n畢竟這可能……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是暴風雨前最後的寧靜時刻呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我們收到情報，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說黑社會的人",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "將在今晚進行某個交易。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "表面上是一般的商務會議，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "實際上",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "卻是涉及全世界黑手黨的密談。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這項交易",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "遲早會動搖整個世界局勢──",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們是這樣判斷的。",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了阻止交易，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我扮作剛才那個黑手黨的貴客，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n潛入了這座島嶼。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要是現實世界變得一團亂，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n可就沒有閒工夫花時間在阿斯特朗上了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不是，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是我以另一個身分──",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "內閣情報調查室的間諜所接下的工作。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哦，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_037"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看你一臉愣住的表情……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你難道不清楚",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "自己老婆的工作嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們明明這麼恩愛",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "的說。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……開玩笑的。",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就算你不知道也沒關係，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n接下來還有得是時間，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可以讓我們了解彼此。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好了，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "讓我們聊回工作吧。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n今天你得要完美地扮演我的老公。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "無論發生什麼事",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都不能動搖，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "扮演好一位愛妻人士。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這可是關乎到世界的命運。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也可以說",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是為了拯救世界的",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "機密任務。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "算是很棒的蜜月旅行，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對吧？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "能跟原本無緣的世界扯上關係，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你真的很幸運呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你要感謝我也可以喔。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "既然如此，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你就更應該協助我呢。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只要達成任務就能回去了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──好好努力吧，",
        "unit_id": 107031,
        "voice": "vo_adv_1266004_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的達令。",
        "unit_id": 107031
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "──這個記憶",
        "unit_id": 190011,
        "voice": "vo_adv_1266004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是怎麼回事！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也太誇張了吧！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為",
        "unit_id": 190011,
        "voice": "vo_adv_1266004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "根據後續的紀錄來看，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只花了兩天，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n似似花就毀滅掉",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "勢力遍及全球的犯罪組織耶！？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "又不是間諜電影！",
        "unit_id": 190011,
        "voice": "vo_adv_1266004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這種事情",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "怎麼想都太離譜了！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我能想到的可能性有兩種……",
        "unit_id": 190011,
        "voice": "vo_adv_1266004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n一種，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是剛才的記憶被似似花竄改過。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "至於另一種，",
        "unit_id": 190011,
        "voice": "vo_adv_1266004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然有點難以置信……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是實際上真的發生了這件事。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對方是那位似似花，",
        "unit_id": 190011,
        "voice": "vo_adv_1266004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感覺兩種都有可能……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為七冠",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是能做到一般人無法想像的事情。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "總之……",
        "unit_id": 190011,
        "voice": "vo_adv_1266004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然似似花現在願意幫助你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但她還是充滿了祕密。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你可要好好分清楚",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哪些才是事實。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就到此為止。",
        "unit_id": 190011,
        "voice": "vo_adv_1266004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算很熱，睡覺時也不能露出肚子喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰～♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500692"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你醒了嗎，",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "早安啊。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看來",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們都做了一場好夢呢。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "至於夢的內容究竟是虛構，",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還是真實發生的事情……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這可是祕密，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就任由你來想像吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "啊啊，",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對了對了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "如果你很在意夢的後續，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我隨時都可以告訴你。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那可是如同間諜電影一般，刺激又快樂的時光。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "先不說這個。",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在時間已經很晚，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也差不多該結束這段假期了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話說回來，",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你還記得當初的約定嗎？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我們究竟經歷了怎麼樣的夏天……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_057"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你說的沒錯。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n像這樣擁有自己的祕密，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想必能讓你獲得更進一步的成長。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "今後，",
        "unit_id": 126611,
        "voice": "vo_adv_1266004_058"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你究竟會成為什麼樣的人……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就讓我抱著期待繼續關注吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}為了遵守跟似似花的約定，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在心底發誓，不會將這個夏天的回憶告訴任何人。"
