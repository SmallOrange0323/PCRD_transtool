    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聖誕節甜點大賽開始幾天後的早晨。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當參加者們忙碌地做著販售準備時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}佇立在攤位旁。"
    },
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀～",
        "unit_id": 119211,
        "voice": "vo_adv_5080002_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "璃乃突然跑走的時候，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n我完全搞不清楚狀況，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真沒想到她想出了這樣的點子～",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "而且大家的服裝",
        "unit_id": 7912,
        "voice": "vo_adv_5080002_001"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "都非常好看。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "原來璃乃會裁縫啊。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊哈哈，",
        "unit_id": 119311,
        "voice": "vo_adv_5080002_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "其實這方面才是我的專長領域。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我很高興能幫上忙。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "還跟妳借用了可麗餅攤子，",
        "unit_id": 119211,
        "voice": "vo_adv_5080002_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真不好意思啦。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這的確",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "比貨車來得可愛又華麗。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這裡有好吃的點心喔～",
        "unit_id": 119911,
        "voice": "vo_adv_5080002_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n大家靠過來～",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "多虧了布丁，",
        "unit_id": 119311,
        "voice": "vo_adv_5080002_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "宮子也很努力在工作呢。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然希望她即使沒有布丁也會努力啦，",
        "unit_id": 119211,
        "voice": "vo_adv_5080002_006"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但就那孩子來說，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "我感覺已經是沒別的辦法了。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "喔～",
        "unit_id": 4911,
        "voice": "vo_adv_5080002_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "人飄浮在半空中……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n蘭德索爾的聖誕節",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "好新潮啊。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n跟我們那裡的聖誕節大不相同。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊哈哈，",
        "unit_id": 119311,
        "voice": "vo_adv_5080002_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "該說那孩子",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "比較特別嗎？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你們讓我見識到了有趣的東西，",
        "unit_id": 4911,
        "voice": "vo_adv_5080002_009"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n讓我買你們的點心",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "作為答謝吧。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "有推薦的",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "產品嗎？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "謝謝！",
        "unit_id": 119311,
        "voice": "vo_adv_5080002_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "每一種都很好吃，很推薦喔！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗯～",
        "unit_id": 4911,
        "voice": "vo_adv_5080002_011"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我想想。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那麼，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "可以給我10包這種",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "馴鹿餅乾嗎？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦咦！",
        "unit_id": 119311,
        "voice": "vo_adv_5080002_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你要買這麼多嗎！？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "嗯，",
        "unit_id": 4911,
        "voice": "vo_adv_5080002_013"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我正在找送給村裡人的伴手禮，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n這個看起來剛好合適。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "再見啦。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "謝謝！",
        "unit_id": 119311,
        "voice": "vo_adv_5080002_014"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哎呀，",
        "unit_id": 119211,
        "voice": "vo_adv_5080002_015"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "這都多虧了宮子。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "嗯，",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "狀況很好。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "什麼都不好！",
        "unit_id": 119911,
        "voice": "vo_adv_5080002_016"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇哇！？",
        "unit_id": 119211,
        "voice": "vo_adv_5080002_017"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "妳什麼時候降落下來的！？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子好不容易聚集了人群，",
        "unit_id": 119911,
        "voice": "vo_adv_5080002_018"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n大家卻都跑去旁邊的店了！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "真陽、璃乃",
        "words": "……咦？",
        "unit_id": 1,
        "voice": "vo_adv_5080002_019"
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "多謝惠顧～",
        "unit_id": 1411,
        "voice": "vo_adv_5080002_020"
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "哎呀～",
        "unit_id": 1411,
        "voice": "vo_adv_5080002_021"
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "多虧你們吸引關注，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "\n我們店裡的客人也增加了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "謝啦。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "照這個情況來看，我們肯定會突破預賽。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "人家可不是為你而做的！",
        "unit_id": 119911,
        "voice": "vo_adv_5080002_022"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n把客人還來！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "也有我們這邊的客人順便過去買你們的商品，",
        "unit_id": 1411,
        "voice": "vo_adv_5080002_023"
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "\n所以這是互惠互利吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……？",
        "unit_id": 119911,
        "voice": "vo_adv_5080002_024"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是這樣嗎？",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 119311,
        "voice": "vo_adv_5080002_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "感覺也不是不能這麼說……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "盡量接受我們客人的施捨，賺取銷售量吧。",
        "unit_id": 1411,
        "voice": "vo_adv_5080002_026"
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "\n哈哈！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "什、",
        "unit_id": 119211,
        "voice": "vo_adv_5080002_027"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "什麼接受施捨，說話太難聽了吧？",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對購買我們點心的客人也很沒禮貌。",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "不想被說成是接受施捨，",
        "unit_id": 1411,
        "voice": "vo_adv_5080002_028"
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "就換地方做生意怎麼樣？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "不",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "過，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "就憑你們的店，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "\n不管在哪裡賣應該都不會有成果吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥！？",
        "unit_id": 119311,
        "voice": "vo_adv_5080002_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你幹嘛突然這麼說啊？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就算事到如今更換地點，",
        "unit_id": 119211,
        "voice": "vo_adv_5080002_030"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "也不會有任何……",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "……啊！",
        "unit_id": 119211,
        "voice": "vo_adv_5080002_031"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "原來如此！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n這意思是說，只要去蘭德索爾外面銷售就行了嗎！",
        "unit_id": 119211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "你",
        "unit_id": 119911,
        "voice": "vo_adv_5080002_032"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真聰明！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n這麼一來我們就沒有敵人了！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可以獨占客人！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "啊？",
        "unit_id": 1411,
        "voice": "vo_adv_5080002_033"
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "你們真的要去蘭德索爾外面銷售？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "覺得只要沒有競爭對手就會賣得好，這種頭腦簡單的想法……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那個～",
        "unit_id": 4911,
        "voice": "vo_adv_5080002_034"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "抱歉在談話中打擾了。",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我想買",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這個聖誕節甜點大賽的",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "特製蛋糕……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "啊～",
        "unit_id": 1411,
        "voice": "vo_adv_5080002_035"
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "不好意思，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "是要一個吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "參加者",
        "words": "\n我馬上準備。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "在買之前，",
