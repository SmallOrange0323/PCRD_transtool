[
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，{player}接下送信的工作，\n在蘭德索爾市內四處奔走，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當他來到最後一封信的投遞地時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "卻找不到收件者。"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_000"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來了來了～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "終於能夠見到面了～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖說是初次見面，不過真的好久不見了，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "{player}。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你過得好嗎～？　",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……？",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_001"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖然很想這樣跟他打招呼，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_002"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但現在得先忍耐……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這次特地策畫的",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "保持距離作戰，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "開始～☆　",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你好～",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你在找什麼嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n這一帶是幫派的地盤，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "危機四伏，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n最好別單獨一個人在這裡閒晃喔。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很～好，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_004"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "每一句話",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都說得一模一樣♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我真是厲害，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就這樣繼續保持下去～☆　",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還是說，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你是來找人的嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "雖說",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_006"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "他要找的人就是我♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "不過，若沒有這樣問，事情就會變得很奇怪，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "也只能先這樣問了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "暫且先這樣。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "接著要自然地表現出驚訝的樣子～☆　",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哇啊～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_008"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是巧！",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n你要找的帆稀，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就在這裡喔～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嗯嗯，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_009"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "連我自己都覺得這番話有夠虛情假意的～♪　",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "答對了～☆",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "謝謝你送信過來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "送信員♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是好險，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_011"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "明明還不認識，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n差點就叫出名字來～☆　",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，我來簽收……",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_012"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那個，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你是專職的送信員嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "如果有其他工作",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想委託你，你會接嗎？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣啊……",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_013"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這樣就可以了……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "工作辛苦了。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "回去的路上請小心～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "呼……",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_014"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就這樣暫時先跟他道別吧……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n比原先所想的更讓人感到依依不捨呢……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "哪怕是自己做的決定，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_015"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真是遺憾……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我沒辦法幫你對抗霸瞳皇帝，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還請多多加油……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……掰掰，{player}。",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我們現在的緣分連點頭之交都稱不上……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "日後，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們一定會再相見的♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好～了，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_017"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "在下次見面之前，還有很多事得去做呢♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我記得這封信是……",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_018"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我想用那種方式是最快的吧～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "時間寶貴，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_019"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "立即展開行動～♪",
        "unit_id": 106711
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你好～♪",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n方便打擾一下嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織的男性",
        "words": "唔！？",
        "unit_id": 1111,
        "voice": "vo_adv_1067005_021"
    },
    {
        "type": "dialogue",
        "name": "敵對組織的男性",
        "words": "妳、",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "敵對組織的男性",
        "words": "妳怎麼會……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "帆、",
        "unit_id": 911,
        "voice": "vo_adv_1067005_022"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "帆稀！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "妳怎麼……！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你是要問，我怎麼還活著嗎？",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_023"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我活著竟然需要理由，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這很奇怪呢～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "換言之，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_024"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這是認為我已經死了的人，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "或是希望我死的人才會有的想法，對吧～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "快、",
        "unit_id": 911,
        "voice": "vo_adv_1067005_025"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "快住手！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "妳別過來！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "真～過分！",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_026"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你怎麼這樣說～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "難不成是，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "因為這封信？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "妳、",
        "unit_id": 911,
        "voice": "vo_adv_1067005_027"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "妳在想什麼啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "該、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "該不會是想……！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "想不到你滿精明的嘛～",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_028"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我現在要在這裡，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "打開這封信喔～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "住手啊，笨蛋！",
        "unit_id": 911,
        "voice": "vo_adv_1067005_029"
    },
    {
        "type": "dialogue",
        "name": "敵對組織老大",
        "words": "妳想死嗎！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "啊哈哈，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_030"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "你緊張了你緊張了♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n嘿～☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "若要達到傷亡的目的，",
        "unit_id": 106711,
        "voice": "vo_adv_1067005_031"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "爆炸威力得再增強一點。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "看來你所委託的施術者不怎麼樣嘛。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "還有不少可以改良的餘地呢～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
