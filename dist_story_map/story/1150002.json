[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "從大間回到蘭德索爾的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n享受著悠閒的新年。"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊啊，",
        "unit_id": 411,
        "voice": "vo_adv_1150002_000"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "太好了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "終於找到你了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "你好，",
        "unit_id": 411,
        "voice": "vo_adv_1150002_001"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "能打擾一下嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "啊，",
        "unit_id": 411,
        "voice": "vo_adv_1150002_002"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "不好意思。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n這麼突然，嚇了你一跳吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "這裡有封要給你的信。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "能麻煩你現在就讀嗎？",
        "unit_id": 411,
        "voice": "vo_adv_1150002_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "「──我是似似花。",
        "unit_id": 107011,
        "voice": "vo_adv_1150002_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我在郊外等你。」",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "那麼，",
        "unit_id": 411,
        "voice": "vo_adv_1150002_005"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我就告辭了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n請你快點去大人的身邊吧♪",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……你真慢。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n竟然讓女性在這麼冷的雪中等待，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真差勁呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_007"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "新年快樂。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "竟然學會拜年了，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你也有所成長了呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "學會拜年是很值得慶幸，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但你還需要多學學如何應對玩笑話喔。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你總是太過相信別人了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "快點出發吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……你在發什麼呆呢？",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n該不會，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你以為我找你的目的，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就只是為了拜個年吧？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "放心吧，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_011"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我不會對你不利的。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不如說，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你應該感恩戴德才對。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在出發前先交給你好了。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "收下它吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "本來在大間就該給你，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但錯過時機了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是壓歲錢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "謙遜固然是美德，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但那也要選對場合。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "像個十幾歲的小孩般雀躍地收下壓歲錢，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n才是你現在的最佳選擇喔。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "難道說，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你在跟我客氣嗎？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n只是壓歲錢而已，坦率地收下就行了……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "身為大人的我，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "給小孩的你壓歲錢，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是再正常不過的事了喔？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "換個思考方式。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你就把它當成",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "一種學習。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "接觸名為壓歲錢的習俗、",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "理解這種文化，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n仔細思考要如何運用",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這筆有限的預算。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "光看書桌上的教科書",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所學不到的知識。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你好像能接受了呢。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我喜歡理解力強的孩子。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你有想買的東西嗎？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……真是的。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就料到你會這麼說……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不行。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n壓歲錢只能用在自己身上。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比起自己，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你總是優先想到別人呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n過度的自我犧牲，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n絕不是什麼值得誇獎的事喔？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "將我希望你為自己而用的壓歲錢，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n用在其他人身上，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你有考慮到我的感受嗎？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這筆",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "壓歲錢是給你的。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你打算無視",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "贈與者的心意嗎？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我可沒有要你道歉喔。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我能理解你想這麼做的心情。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "聽好了，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n學會面對自己的欲望，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也能成為一種經驗。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "盡快往鬧區出發吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就讓我來見證",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你將如何使用這筆壓歲錢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這絕對",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不是基於好奇的行為。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這點還請你別誤會，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "知道了嗎？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你會做出什麼選擇……",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我非常期待呢。",
        "unit_id": 115011
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "果然到了新年，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "人真的很多呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "為了避免走散，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你能跟緊我吧？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "欸欸，",
        "unit_id": 111,
        "voice": "vo_adv_1150002_032"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "你今天要買什麼？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "我要買年底新出的遊戲！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "我",
        "unit_id": 5311,
        "voice": "vo_adv_1150002_033"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "想買書！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n也想",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "買漫畫。",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "那剩下的錢就拿來買零食和果汁，",
        "unit_id": 111,
        "voice": "vo_adv_1150002_034"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n到我家玩吧！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "順便把漫畫借給我看！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "好哇！",
        "unit_id": 5311,
        "voice": "vo_adv_1150002_035"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "我贊成！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n我也想玩新出的遊戲！",
        "unit_id": 5311
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "好，",
        "unit_id": 111,
        "voice": "vo_adv_1150002_036"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "那我們快去買吧！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你看，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_037"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那些孩子們，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也懂得拿壓歲錢去買自己想要的東西喔。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且是十分有計畫性地使用方式。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請你向他們學習，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "去買自己想要的東西吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "找到想買的東西了嗎？",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n你似乎東張西望了好一陣子……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……居然還沒買任何東西，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我有點吃驚呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比如說……",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個嘛，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n趁這個機會",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "買件衣服怎麼樣？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你很常和女性一起行動，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那怕在外觀上，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "稍微試著打扮一下也不錯吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或是說，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_042"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "逛逛攤販，\n來場美食之旅",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "或許也不賴。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你在【美食殿堂】的經驗，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n或許幫助拓展了美食領域上的見聞，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但食用的內容有些太過來者不拒呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_044"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "福袋嗎……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "既有新年的風格、",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n偶爾試著聽天由命",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也很有趣呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "哪怕",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "裡面都是些微不足道的小東西，\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也能成為很好的談資喔。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這樣啊。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我不小心",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "干涉太多了呢……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你雙眼放光地看著各種東西的畫面實在太過有趣，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我本來只想觀察的，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "卻也忍不住給出了意見。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我會重整心情，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_048"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n見證你自己",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "做出的選擇。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "……這位客人。",
        "unit_id": 311,
        "voice": "vo_adv_1150002_049"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "您已經看很久了，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n請問決定好要買什麼了嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "唉……",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再怎麼優柔寡斷",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也該有個限度喔。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看起來不像是因為想要的東西太多而苦惱呢。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_051"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……他會這樣，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是因為沒有任何欲望嗎？　",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你終於決定了啊。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n結帳……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "已經能自己去了呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n看到你有所成長的一面真是太好了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "謝謝惠顧──！",
        "unit_id": 311,
        "voice": "vo_adv_1150002_053"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "歡迎再來──！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你買了什麼？",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這是……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "撲克牌啊。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……原來如此。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很有你風格的選擇呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "儘管預算充足，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也多次提出",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n要你以自我為中心考量，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你最終還是選擇了能與他人",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "一同玩樂的事物。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "乍看之下只是個老好人做出的決定……",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_057"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但我卻能感受到",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "除此之外的巧思。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你這個人真的",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_058"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "十分有趣呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在這一點上，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "完全不亞於七冠。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你今年又會向我展示什麼呢。",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_059"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n真是讓我無比期待啊。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "等你買東西",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "等到肚子都餓了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這餐我請客，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "去吃點好吃的東西吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "吃完飯後，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_061"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就輪到你陪我買東西了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看著你買東西，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就連我也開始有些手癢了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就讓我告訴你，",
        "unit_id": 115011,
        "voice": "vo_adv_1150002_062"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "什麼才叫真正的購物吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "心情極好的似似花"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n帶著{player}繼續逛街。"
    }
]