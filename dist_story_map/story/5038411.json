[
    {
        "type": "background",
        "background": "500751"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_5038411_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就在今天，這個學習也要跟著結束了啊……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然發生了很多事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但回想起來還是會覺得有些捨不得。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "恭喜妳畢業了，",
        "unit_id": 110911,
        "voice": "vo_adv_5038411_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "優妮學姐！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "感動到想哭耶～。",
        "unit_id": 110811,
        "voice": "vo_adv_5038411_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n只要想到我可能再也見不到學姐，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就會噴出7兆公升左右的眼淚～",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "運動會的時候",
        "unit_id": 111011,
        "voice": "vo_adv_5038411_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真的好開心喔！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n還有大家一起打倒的",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好朋友X！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n今天",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們幾個！　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們幾個！　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要畢業了！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "——才不是。",
        "unit_id": 111011,
        "voice": "vo_adv_5038411_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n別讓不習慣吐槽的我",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "做這種特別長的吐槽啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我不是說我的學習課程全部修完了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "而是特別講座結束了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼嘛～原來是在說那個，",
        "unit_id": 110911,
        "voice": "vo_adv_5038411_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嘿嘿切嚕☆",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "太好了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以優妮學姐沒有要畢業吧！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "琪愛兒，",
        "unit_id": 110811,
        "voice": "vo_adv_5038411_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳放心。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n優妮學姐會一直跟我們在一起喔。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "因為她的論文完全沒有進展啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "咦，",
        "unit_id": 111011,
        "voice": "vo_adv_5038411_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "難不成妳們幾個以為",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我會留級嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，",
        "unit_id": 110911,
        "voice": "vo_adv_5038411_008"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "愉快的女孩悄悄話就先聊到這裡。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼，",
        "unit_id": 111011,
        "voice": "vo_adv_5038411_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳說這是愉快的女孩悄悄話！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "早、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "早說嘛，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來這就是傳說中的……！？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此……",
        "unit_id": 111011,
        "voice": "vo_adv_5038411_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我竟然在不知不覺中在我那煞風景的青春日記上，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n追加了歡樂的花樣篇章……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂，",
        "unit_id": 111011,
        "voice": "vo_adv_5038411_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學弟妹們。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n再多質問我一些關於留級疑雲的事。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我也想要青春一下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來吧～質問我吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你也沒事吧？",
        "unit_id": 110811,
        "voice": "vo_adv_5038411_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n特別講座要結束了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "希望你不要留下遺憾喔。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是說啊，學長，",
        "unit_id": 110911,
        "voice": "vo_adv_5038411_013"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請將世界級的美少女琪愛兒",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n烙印在你的雙眼裡面吧！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～☆",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呵呵……",
        "unit_id": 111011,
        "voice": "vo_adv_5038411_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這就是世人所說的完全無視嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我現在正在度過我的青春時光！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n真是美好的友情啊！　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優妮們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "永遠不滅！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是啊！",
        "unit_id": 110911,
        "voice": "vo_adv_5038411_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好朋友社直到永遠！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n真是感人喵～！",
        "unit_id": 110911
    }
]