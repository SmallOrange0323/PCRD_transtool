[
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻。\n今天非常開心呢～♪",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過在『玩偶裝舞會』\n被負責警備的獸人聞出氣味，真實身分就被發現了……",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_001"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "他幾乎要喊出",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_002"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "『是魔物！快解決掉！』",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "差點就引起大騷動了呢。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過包含那件事，全都很開心。",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_003"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "雖然對於被捲進來的你來說，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n可能是場災難吧。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "多虧了似似花給我的",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "『變身蘋果』，\n才能夠含混過去。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。\n這是似似花給我的，",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_005"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n是顆不可思議的蘋果。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "只要吃了這個，\n人家隨時隨地都能變身成人類的樣子哦。",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_006"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "效果似乎只有幾個小時……",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_007"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n和之前一樣，要是受到衝擊，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就會變回原本的樣子。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以，\n這個狀態下是沒辦法戰鬥的。",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_008"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "畢竟變身算是胡亂動用肉體，",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_009"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "每一次，激烈的疼痛都會竄滿全身……",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "大概是因為這東西還在實驗階段吧。",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_010"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能讓我隨意變身，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就已經算是奇蹟了。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "似似花說，她會繼續研究，",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_011"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n讓效果的持續時間延長。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "到時候，說不定就能從早到晚\n維持人類的外貌了呢。",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "如果可以實現的話，",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_013"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我們就來約會一整天吧……♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻。\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_014"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "最重要的，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n是你能夠理解人家變身，讓人家很開心。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "畢竟你之前完全不相信嘛，\n讓人家有點深受打擊。",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_015"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過只要在你眼前吃下『變身蘋果』，",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_016"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n變身給你看……",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你總算是相信了呢。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "實在太好了～",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_017"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n人家放心了哦。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "竟然能像普通的人類情侶一樣，",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_018"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n手牽著手約會……",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我對似似花\n真是感激不盡。",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_019"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "夢想，就這樣實現了……",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_020"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "啊啊，好幸福♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "要是這一切只是一場幻夢，該怎麼辦……",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_021"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家一定沒辦法承受的。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "光是想像，\n肚子就要痛起來了。",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_022"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "開玩笑的。\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_023"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "陰沉的表情不適合我對吧。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "得積極向前，",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_024"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n樂觀地思考才行！",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪～♪",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？\n我剛才說了莉瑪莉瑪？",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_025"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "感覺最近常常這麼說呢，",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_026"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n好像是『變身蘋果』的副作用……？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "畢竟那是還在研究中，\n扭曲常理的神奇蘋果呢。",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_027"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就算有什麼副作用，也沒有什麼好吃驚的呢。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？\n不用勉強自己變身也沒關係嗎？",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_028"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你擔心副作用嗎？",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_029"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就算是平常的莉瑪，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你也不討厭……是嗎？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "謝謝。\n聽到你這麼說，真幸福。",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_030"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n讓我",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "感到誕生在這個世上，實在太好了。",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "與你相遇實在太好了……♪",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_031"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（不過，正因為這樣，",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_032"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n要是不能夠和這樣的你，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n像普通人一樣地約會……）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "（要是不能夠牽手，\n",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_033"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "人家果然會難受到無法忍耐。）",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呀？\n哇哇，",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_034"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n又發光了哦？",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "那究竟是什麼？",
        "unit_id": 105212,
        "voice": "vo_adv_1052008_035"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n看著那道光，",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105212
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "就感到非常不安心……！",
        "unit_id": 105212
    },
    {
        "type": "background",
        "background": "510140"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪～♪",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_036"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（好棒，第一次來動物園～♪）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，莉瑪……",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_037"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（抱歉呢，",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n突然對你說『想要約會』……）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_038"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪……",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（嗯，因為在阿斯特朗人家也能正常說話……）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪，莉～瑪。",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_039"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（在那裡鼓起勇氣，",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n說了『想要約會』呢。）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪♪",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_040"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（人家真的很高興你能答應我♪）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪～，莉瑪莉瑪。",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_041"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（沒有辦法～",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n人家在城鎮裡走動會引起騷動的。）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪，",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_042"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪～。",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（還讓你費心了，真抱歉。）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪～，莉瑪莉瑪……",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_043"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（如果在動物園，",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n有其他很多動物在，也比較不會引人注目……）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，莉瑪♪",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_044"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（應該不太可能引起騷動吧♪）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，莉瑪莉瑪♪",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_045"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（今天你就盡管期待吧♪）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪♪",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_046"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（呵呵呵，人家還準備了便當哦♪）",
