    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "動物園的飼育員",
        "words": "唉呀，還以為有什麼騷動……",
        "unit_id": 1,
        "voice": "vo_adv_1052008_059"
    },
    {
        "type": "dialogue",
        "name": "動物園的飼育員",
        "words": "\n真是少見呢，這不是羊駝嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "動物園的飼育員",
        "words": "我們這裡應該沒有這種動物的，\n是從哪裡跑進來的？",
        "unit_id": 1,
        "voice": "vo_adv_1052008_060"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪♪莉瑪莉瑪，莉瑪～。",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_061"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（嘻嘻♪這個人",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n有好好幫人家買了動物園入園券，一起進來的哦～）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "動物園的飼育員",
        "words": "嗯……",
        "unit_id": 1,
        "voice": "vo_adv_1052008_062"
    },
    {
        "type": "dialogue",
        "name": "動物園的飼育員",
        "words": "\n是你帶進來的嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "動物園的飼育員",
        "words": "不過可真是很有人氣呢，\n不但是稀有的動物，還很親近人、很聰明。",
        "unit_id": 1,
        "voice": "vo_adv_1052008_063"
    },
    {
        "type": "dialogue",
        "name": "動物園的飼育員",
        "words": "說不定，\n會成為我們動物園的偶像哦。",
        "unit_id": 1,
        "voice": "vo_adv_1052008_064"
    },
    {
        "type": "dialogue",
        "name": "動物園的飼育員",
        "words": "如果你不介意，\n能不能由我們動物園正式買下來呢？",
        "unit_id": 1,
        "voice": "vo_adv_1052008_065"
    },
    {
        "type": "dialogue",
        "name": "動物園的飼育員",
        "words": "希望你能將你的寵物\n讓給我們。",
        "unit_id": 1,
        "voice": "vo_adv_1052008_066"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉、莉瑪……？",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_067"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（寵、寵物……？）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，莉瑪莉瑪！",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_068"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（沒有錯呢，會被這麼認為是理所當然的！）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪～",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_069"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪！",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（畢竟我和這個人，",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n種族完全不一樣！）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪，",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_070"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪！",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（我也知道這段戀情不會有結果！）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪，莉瑪莉瑪～！",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_071"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（不過，我就只是想做做夢而已……！）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "動物園的飼育員",
        "words": "唔啊？\n等等，不要亂來！",
        "unit_id": 1,
        "voice": "vo_adv_1052008_072"
    },
    {
        "type": "dialogue",
        "name": "動物園的飼育員",
        "words": "請各位退開，\n動物興奮起來了！",
        "unit_id": 1,
        "voice": "vo_adv_1052008_073"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪～",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_074"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪！",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（雖然是這樣沒錯，",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n但是不要說我是動物啦～！）",
        "unit_id": 105231
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "莉瑪莉瑪，莉瑪～！",
        "unit_id": 105231,
        "voice": "vo_adv_1052008_075"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n（嗚哇啊啊啊，老天爺真是壞心腸～！）",
        "unit_id": 105231
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "莉瑪……！",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗚，妳是多麼地勇敢！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n多麼地可憐！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請妳不要向命運低頭，堅持下去！",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n戰勝命運，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n和那個人心手相連、獲得幸福吧！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我絕對",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_078"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是站在妳這邊的……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀。",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_079"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n抱歉，稍微興奮起來了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我對這種事沒有抵抗力呢～，",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_080"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像是沒有結果的單戀～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n或是受到命運玩弄，痛苦又悲傷的戀情～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不不。\n",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_081"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要斷定這是單戀，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n或是悲傷的戀情，都還太早了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接下來才是決勝負的時候哦，\n加油，莉瑪！",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_082"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……我想，在能夠變身成人類的『這邊』，",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_083"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n多少會有勝算的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然某種意義上來說，",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_084"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n像是從天堂打到地獄……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "似乎有種過於殘酷、\n非常過分的命運被強加在她的身上。",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_085"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對於似似花這個名字，",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_086"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我也有點在意呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這個奇怪的名字，\n我想應該不會是其他人。",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_087"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是那個『七冠』──變貌大妃似似花吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果真的是這樣，",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_088"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也不知道她是不是有什麼企圖……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "請你要多加注意，好好觀察。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為我，\n還幾乎不能造成什麼影響。",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_089"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就請你好好\n保護莉瑪了。",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_090"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不。\n請你一定要給她幸福哦。",
        "unit_id": 190011,
        "voice": "vo_adv_1052008_091"
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "{player}？\n起來了嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_092"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你突然睡著，嚇了人家一跳哦。\n沒事嗎？",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_093"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n有沒有哪裡不舒服？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯。",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_094"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n因為你有跟我說過",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n住宿的地方……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我正打算把你搬過去。",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_095"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過以人類的樣子沒辦法出力，",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_096"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n實在搬不動你……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "所以，就變回原本的樣子了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "時間也晚了，沒什麼路人，\n所以應該沒有被看到，引起大騷動。",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_097"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嘻嘻。",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_098"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n雖然人家有點憧憬",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n離別的擁吻……",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "不過也是無可奈何呢。\n",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_099"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "能夠一起約會，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n就已經非常非常地幸福了。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嗯？\n就算是這個外表，",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_100"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n也可以親吻嗎？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "也是呢～……",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_101"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n不過既然要親，",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "你還是想親人類的女孩子對吧？",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "之後的日子還長的很……",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_102"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "機會應該還多的是。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我會等待。",
        "unit_id": 105211,
        "voice": "vo_adv_1052008_103"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "等待童話故事中",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n幸福快樂的結局來臨的那一刻。",
        "unit_id": 105211
    },
    {
        "type": "dialogue",
