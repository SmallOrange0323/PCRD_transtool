[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "就如同望和紡希所說的……",
        "unit_id": 104211,
        "voice": "vo_adv_5084638_000"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n從那之後，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你就一直沉睡著呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你總是一直為了大家而努力，",
        "unit_id": 104211,
        "voice": "vo_adv_5084638_001"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n我希望你也能",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "有休息的時間……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "但其實",
        "unit_id": 104211,
        "voice": "vo_adv_5084638_002"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "像這樣長時間沒辦法跟你說話……",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "那個，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我感到",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "很寂寞。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "……",
        "unit_id": 104211,
        "voice": "vo_adv_5084638_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我這樣",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不行呢。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "像這樣沮喪的話，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n你醒來時一定會擔心的吧。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "因為",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "你非常溫柔。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "我總是一味地受到你的幫助，",
        "unit_id": 104211,
        "voice": "vo_adv_5084638_004"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n所以這次我希望",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "由我來讓你好起來。",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "等你醒來之後，",
        "unit_id": 104211
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "可以聽我唱唱歌嗎……？",
        "unit_id": 104211
    }
]