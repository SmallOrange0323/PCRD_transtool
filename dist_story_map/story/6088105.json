    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你可要記住了。",
        "unit_id": 121411
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "如果我跟真陽小姐一樣會搞笑的話當然沒問題，",
