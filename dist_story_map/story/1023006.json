[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼～哼哼～♪",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n前進～噗吉～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "前往任何地方～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哼～哼哼～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿。",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n{player}哥哥讓我騎在肩膀上，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n好輕鬆♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "蘭德索爾真的太大了，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就算是去想去的地方也很費力。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "路也感覺很複雜，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_003"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我經常會迷路。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有哥哥和我在一起，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_004"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n真是太好了～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n嘿嘿♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n會不會很重？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "先不說我，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n噗吉還挺有份量的對吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那樣的話，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你可以把噗吉放到地面上拖沒關係喔。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「喂喂，",
        "unit_id": 2111,
        "voice": "vo_adv_1023006_007"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n對待我的方式也太隨便了吧。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n麻煩再對我好一點。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我知道啦～",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "開玩笑的開玩笑的♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉是我的朋友",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也是家人呀。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就像是我身體的一部分，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我會珍惜的。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯？",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n怎麼了，哥哥？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你難道有什麼話想說嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "果然",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很重嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n還是我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "自己下來走比較好？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是嗎？",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對可是，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你走路好像搖搖晃晃的耶？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要是很辛苦，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不用勉強背我走也沒關係喔……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哇～好帥！",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_013"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥哥好可靠～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸嘿～",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那麼，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就麻煩你好好護送我囉♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……嗯？",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n怎麼了，哥哥？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n難道你還有什麼話想說嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊啊……",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你很在意",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就是說呢。",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我懂，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "大家都是這樣呀。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n看到我和噗吉說話，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "都會一臉奇怪的表情。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥你",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n果然也",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "覺得我很奇怪嗎……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你說",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_019"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不奇怪？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "好開心～",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n謝謝你，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就是……",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_020"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我的爸爸媽媽",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n一直都忙著工作。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以我，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_021"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n從小的時候，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n就一直是一個人待在家裡。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也不太能夠",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_022"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n和自己年紀相近的小孩相處……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我一個人看家，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_023"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n總是會寂寞到哭出來。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "爸爸很擔心我，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_024"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "於是就買了噗吉來給我。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "那是他去很遠的國家出差工作時，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_025"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n買回來給我當禮物的。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "多虧這樣，\n我才不再覺得寂寞了。",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_026"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "因為總是有噗吉陪在我身邊。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我有了會陪我聊天玩耍的朋友",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_027"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n和家人。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然其他人都不相信我，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_028"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "大家都會嘲笑我……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉他呀，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_029"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n是真的會說話喔。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "他有生命、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "也有心靈的。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "照爸爸的話來說，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_030"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n聽說是噗吉身上施加了有點稀有的魔法。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "所以噗吉本來應該是重量級的武器，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_031"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n可是他對我來說感覺就跟羽毛一樣輕。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "而且，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_032"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n只有我，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n能聽到噗吉的聲音喔。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然平常總是我用腹語術，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_033"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n代替噗吉說出他說過的話。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但他真的會說話，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_034"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我聽得見。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥你",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "願意相信我嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "還是會覺得我是和武器的擺飾玩偶說話，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_035"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是自己自言語的……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "奇怪的人……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你會不會嘲笑我呢？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……對不起。",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_036"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我一直",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不停問你相同的問題。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可是",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_037"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我好希望除了我之外，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n也能有人相信",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉是真的擁有生命。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "否則的話，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_038"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我就只是一個因為耐不住寂寞而產生妄想的",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n可憐孩子了嘛……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "總覺得要是這樣",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_039"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n噗吉的生命也會跟著不見。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我還是",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_040"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n不希望那種事發生。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……糟糕。",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_041"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n已經傍晚了呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我該走了。",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_042"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我之後有點事情。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥。",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_043"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n今天和我玩耍、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "聊天……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是謝謝你今天願意陪我。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "讓我心裡",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_044"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n充滿了溫暖的感覺喔♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯？",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_045"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n沒關係，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你可以不用送我。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "今天有哥哥讓我騎在肩膀上，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_046"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n讓我輕鬆多了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我一點也不覺得累，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "可以用自己走過去。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯。",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_047"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "今天就在這裡說掰掰囉。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥。",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_048"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我要是又覺得寂寞，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你願意再陪我玩嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你願意和我聊天，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_049"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n看著我，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n為了我花時間嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我呀，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_050"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "一直",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "都只想要「這樣子」而已。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_051"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我們說好囉。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "來勾手指，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "約定好囉……♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿。",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_052"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那麼，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我要走囉。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n今天真的很謝謝你！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "再見，",
        "unit_id": 102311,
        "voice": "vo_adv_1023006_053"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n溫柔的哥哥……♪",
        "unit_id": 102311
    }
]