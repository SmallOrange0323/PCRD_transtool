    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "是班比的僕從！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n你有好好記住",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "主人重要的日子呢。",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "好乖，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "好乖♪",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "哇──♪",
        "unit_id": 122331,
        "voice": "vo_adv_4010224_002"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n毛茸茸的",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "可愛小屋，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n跟貝斯的小屋很配耶！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "有這個的話，",
        "unit_id": 122331,
        "voice": "vo_adv_4010224_003"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就能跟貝斯",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "去任何地方了。",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從當然",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "也要去！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "三人一起去！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嘿嘿，",
        "unit_id": 122331,
        "voice": "vo_adv_4010224_004"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比的僕從",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "很優秀。",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n知道班比想要的",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "任何東西！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "然──後──",
        "unit_id": 122331,
        "voice": "vo_adv_4010224_005"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "知道班比為什麼",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "生日",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "要來這裡嗎？",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "這個啊，",
        "unit_id": 122331,
        "voice": "vo_adv_4010224_006"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "因為是生日，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就來見",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "最想見的人啦！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就是僕從喔。",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "在僕從成為僕從前，",
        "unit_id": 122331,
        "voice": "vo_adv_4010224_007"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "班比在",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "漫長的",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "時間裡，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n一直一──直都沒什麼",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "想在生日做的事。",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "不過，",
        "unit_id": 122331,
        "voice": "vo_adv_4010224_008"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "跟僕從之間的時間",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "是班比目前最想要的禮物！",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "嗯，",
        "unit_id": 122331,
        "voice": "vo_adv_4010224_009"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "接下來到天亮前，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "就來看繪本、",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "吃點心、",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "唱歌，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n然後",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "再玩遊戲♪",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n因為",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "你是僕從，所以要",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "一直",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "一直──",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "待在我這邊。",
        "unit_id": 122331,
        "voice": "vo_adv_4010224_010"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "約好了喔，",
        "unit_id": 122331
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "僕從！",
        "unit_id": 122331
