    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n真好吃……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "糖果呀。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "而且這個，",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_033"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "還是我喜歡的口味♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "欸嘿嘿，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真好吃♪♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼！！",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_034"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "唔……",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_035"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "幹嘛啦，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你那一副照顧小孩的溫柔眼神！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就說不要把我當作小孩子啦！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊──",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_036"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我是徹徹底底地生氣了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n今天我絕對要讓你",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "在超超超級豪華餐廳請我吃一頓，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n直到把你的錢包吃垮為止！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好了！",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_037"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們要出發了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你可別讓成熟的淑女自己一個人走啊！",
        "unit_id": 105011
    }
