[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}走在街上時，\n聽到一陣令人耳熟的童音與穿著高跟鞋的走路聲。"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊！",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n{player}，我總算找到你了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_001"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這什麼！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我才不要吃糖果！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你不要把我當成小孩子！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "比起那個！",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要給我負起責任！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "負責任！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為我被你救了的關係，",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_003"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我身為成熟淑女的尊嚴，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "都被搞得亂七八糟了啦！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你說你完全不知道我在說什麼！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我呢，",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_005"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "在那之後可是被男生們一直嘲笑！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "他們對我說「妳打不倒怪物，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n才不是什麼成熟的淑女」！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊──",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我只要一想起那群幼稚的臭男生，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n就覺得實在是",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "氣死人了！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你呀，",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_007"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "對於成熟淑女來說，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n要怎麼做才算是負責……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你應該知道吧？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "說起大人呢，",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就是要在高級餐廳享用晚餐啊。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "當然，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是要由男方請客。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "之後，",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_009"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "就讓你買個名牌包包給我吧。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "也要買雙新款的高跟鞋送我！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊啊……",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是多麼美好",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "又成熟的夜晚啊。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我光是想像一下，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "內心就激動不已♪",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呵呵，",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你可沒有任何",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "拒絕的權利喔。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "因為你讓我遭遇到那種事，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可要好好地負起責任喔？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什、",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_012"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "什麼！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "誰是小孩！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n不准把我當成小孩！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "話、",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "話說回來！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n這個才不是約會！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你是笨蛋嗎、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你是笨蛋嗎！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呵呵，",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_014"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣子你就會緊張？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你也有可愛的一面嘛。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不過呢，",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_015"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你就放心吧。",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n我身為一位成熟的淑女，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "會從頭到尾教你――",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦？",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_016"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n你說不是這樣，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "是和小孩兩個人走在一起，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "會害怕世人的眼光而覺得緊張！？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所・",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_017"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "以・",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "說！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你別把我當小孩子看──！！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的！",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_018"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n總之，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們要一起外出！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "今天，我們要度過一個優雅又成熟的夜晚♪",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_019"
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哼～哼～哼♪",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_020"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "呀！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_021"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "唔……",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_022"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好痛……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n因為我今天",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "穿了稍微高一點的跟鞋……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚……",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_023"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚嗚嗚……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚嗚嗚，",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_024"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "吵死了――笨蛋！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚嗚嗚嗚……！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "哇……",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_025"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "被摸摸頭，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "感覺好舒服……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我說，",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_026"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你別把我當小孩子！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "摸、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "摸摸頭什麼的……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真是的，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "笨蛋――！",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚……",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_027"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "真的是、",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "糟透了……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n為什麼我非得落入這種窘境不可？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "嗚……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "做、",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_028"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "做什麼啦？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你要我張開嘴巴？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你、",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_029"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你想做什麼？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "難道說，",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你要對我做什麼奇怪的事……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "啊嗯！？",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_030"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這、",
        "unit_id": 105011,
        "voice": "vo_adv_1050002_031"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這是什麼？",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你到底",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "往我的嘴裡放了什麼……",
        "unit_id": 105011
    },
    {
        "type": "dialogue",
        "name": "美咲",
