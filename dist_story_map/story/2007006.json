    {
        "type": "dialogue",
        "name": "宮子",
        "words": "好～",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_000"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "過～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "分～",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "喲～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "絕不會原諒妳的喲～！",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_001"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n偷吃宮子布丁的傢伙，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n就扔到地獄的大鍋子裡去煮一煮吧！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "氣噗噗！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "快、快",
        "unit_id": 104412,
        "voice": "vo_adv_2007006_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "冷靜一點呀蠢才！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別再鬧啦，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身的城堡都快垮了！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "垮掉的東西是布丁喲！",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_003"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n黏糊糊地融化之後，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "甜甜的味道就會在嘴裡擴散開來的喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "可是卻被伊莉亞給吃掉了喲！",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n所以宮子才會生氣的喲～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾、",
        "unit_id": 104412,
        "voice": "vo_adv_2007006_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身才沒有吃了妳的布丁！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n又不是小孩子了！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如此高貴的妾身，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "只吃高貴的料理呢！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳瞧不起布丁是不是吶？",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n布丁可是世間王公貴族都認可的",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "高級食品的喲～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "別發那種莫名其妙的火！",
        "unit_id": 104412,
        "voice": "vo_adv_2007006_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "近、",
        "unit_id": 104412,
        "voice": "vo_adv_2007006_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "近期有些奇怪的魔物，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n頻繁地入侵妾身的城裡喔？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n大概",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是它們把妳的布丁吃掉了吧？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不要怪到別人頭上喲！",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_009"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n而且，之前都是伊莉亞",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "把布丁偷吃掉的喲～！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "而且如果說會被魔物入侵的話，",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n那也全都是因為",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "伊莉亞沒有好好警備的錯喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "都是伊莉亞的錯～",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_011"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "奪走了宮子的樂趣喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "才不是這回事～？",
        "unit_id": 104412,
        "voice": "vo_adv_2007006_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不是妾身的錯呦～……？",
        "unit_id": 104412
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "？",
        "unit_id": 104412,
        "voice": "vo_adv_2007006_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "　哦哦，{player}！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來的正好♪",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "快來替妾身阻止宮子一下呀～？",
        "unit_id": 104412,
        "voice": "vo_adv_2007006_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這孩子異常地固執呢，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n怎麼就不肯聽進去別人的話啊～！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔喔……",
        "unit_id": 105812,
        "voice": "vo_adv_2007006_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好像，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小小的孩子們在吵架耶。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯，",
        "unit_id": 105913,
        "voice": "vo_adv_2007006_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那兩人都是有著不可思議氛圍的孩子呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一個人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知道怎麼的竟飄在半空中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而另一個人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "則瀰漫著一股怪異的氣息。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該如何處置呢？",
        "unit_id": 105913,
        "voice": "vo_adv_2007006_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您似乎與",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那兩位",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都認識的樣子就是了……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論吵架的理由為何，",
        "unit_id": 105913,
        "voice": "vo_adv_2007006_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若不阻止她們，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "說不定這城真的會倒也說不定。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～，",
        "unit_id": 105812,
        "voice": "vo_adv_2007006_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這到底是怎麼回事呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明明沒有特別感到什麼魔力，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但房內的東西",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "卻瘋狂地到處飛來飛去的呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家小心一點，",
        "unit_id": 105812,
        "voice": "vo_adv_2007006_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不要被砸到受傷了唷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是「騷靈現象」。",
        "unit_id": 103111,
        "voice": "vo_adv_2007006_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n是唯有蘊含著力量的幽靈，才能辦到的絕技。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n在這地方似乎稱呼它為",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "『鳴屋』呢",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "本來是指老舊朽化的建築，",
        "unit_id": 103111,
        "voice": "vo_adv_2007006_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n擅自發出些奇異聲響的現象。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而像",
        "unit_id": 103111,
        "voice": "vo_adv_2007006_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真正的幽靈在騷動時，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n也有可能會產生同樣的現象。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "比、",
        "unit_id": 102211,
        "voice": "vo_adv_2007006_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "比起冷靜地替人解說，不如阻止她們？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "宮子～",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "冷靜一點！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n布丁的話，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "等會兒就買來給妳喔！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子現在就想要吃吶！",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_025"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n像你們這種了不起的人類是不會明白的喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "唔～嗯。",
        "unit_id": 100611,
        "voice": "vo_adv_2007006_026"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n真的一點也聽不進人的話呢……？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "啊、",
        "unit_id": 100611,
        "voice": "vo_adv_2007006_027"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "{player}哥哥～？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就稍微",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "去抱伊莉亞一下吧♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "鬧哪樣呀！？",
        "unit_id": 104412,
        "voice": "vo_adv_2007006_028"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "等、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還不停下！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n別隨隨便便就碰妾身呀，{player}！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔唔～？",
        "unit_id": 104411,
        "voice": "vo_adv_2007006_029"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "變回原樣了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼哈哈，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "力量源源不絕地全湧出來了呢♪",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "果然與",
        "unit_id": 104411,
        "voice": "vo_adv_2007006_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "{player}接觸，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n就是能變回真身的關鍵嗎？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "儘管為妾身自身之事，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "卻完全沒有頭緒呢？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是愛的力量唷～",
        "unit_id": 100611,
        "voice": "vo_adv_2007006_031"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里是這麼想的♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔喔？",
        "unit_id": 105812,
        "voice": "vo_adv_2007006_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n外表變了耶……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她散發出的魔力",
        "unit_id": 105812,
        "voice": "vo_adv_2007006_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "突然變得好強大唷？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是怎麼一回事？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n她到底是什麼人？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不太好說明呢……",
        "unit_id": 103111,
        "voice": "vo_adv_2007006_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n伊莉亞她的體質，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有點特殊。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "若伊莉亞變回了原來的模樣，",
        "unit_id": 100611,
        "voice": "vo_adv_2007006_035"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就有辦法壓制住宮子了對吧？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我們",
        "unit_id": 100611,
        "voice": "vo_adv_2007006_036"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "有些話想和這些人談談，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以能不能找個地方自己解決呢？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊、嗯……",
        "unit_id": 104411,
        "voice": "vo_adv_2007006_037"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若妾身認真起來，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n說不定會傷到宮子的靈體呢。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若真變成這樣，妾身也會感到很抱歉呀，",
        "unit_id": 104411,
        "voice": "vo_adv_2007006_038"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n畢竟這孩子，一點錯也沒有呢。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一如往常相當溫柔呢……",
        "unit_id": 103111,
        "voice": "vo_adv_2007006_039"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "該怎麼做呢？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "接下來我想要和大家談的內容，",
        "unit_id": 103111,
        "voice": "vo_adv_2007006_040"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n也與伊莉亞有關係。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n如果可以的話，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "希望她也能在場。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然有點抱歉，",
        "unit_id": 103111,
        "voice": "vo_adv_2007006_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但就讓宮子",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "暫時沉睡如何？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我相當熟練操縱幽靈，",
        "unit_id": 103111,
        "voice": "vo_adv_2007006_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n如果只是簡單的封印，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還是做得到的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯～",
        "unit_id": 104411,
        "voice": "vo_adv_2007006_043"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n但就算這麼做，也沒辦法徹底解決這個問題呢。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是嘛，",
        "unit_id": 104411,
        "voice": "vo_adv_2007006_044"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "趁宮子睡著的期間……",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身趕緊飛到城內，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n去買幾個布丁回來也不失是個好主意？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個～",
        "unit_id": 105812,
        "voice": "vo_adv_2007006_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然搞不太清楚狀況……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但如果有材料，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "布丁我還是做得出來唷？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不介意的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就借一下廚房吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "咦、",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_046"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "做布丁？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n做得出來嗎？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很簡單唷～",
        "unit_id": 105812,
        "voice": "vo_adv_2007006_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然還是得看廚房的設備齊不齊全呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但我也很喜歡吃布丁，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以經常在家裡自己動手做唷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是那種又甜又軟綿綿的，",
        "unit_id": 105812,
        "voice": "vo_adv_2007006_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n充滿母親味道的布丁呢～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嗯嗯！",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_049"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳還真是識貨的喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n沒有錯喲！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁，就是愛的味道喲……♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "這麼說來。",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_050"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子好像在經常去的那家點心店裡，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n看過妳的身影喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "該不會難不成，",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_051"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "妳是位點心師傅吶？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "耶嘿嘿，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那麼還真值得期待一下了喲♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "知道了喲。",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_052"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n如果能吃得到好吃的布丁，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那宮子也沒有生氣的理由了喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "真的真的，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "要做布丁給宮子吃嗎？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的，",
        "unit_id": 105812,
        "voice": "vo_adv_2007006_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "覺得沒什麼問題唷。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n也會準備大家的份喔，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就當成等一下談話時的小點心吧～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "不行的喲～",
        "unit_id": 100711,
        "voice": "vo_adv_2007006_054"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子要一個人獨享全部的布丁喲♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喔……",
        "unit_id": 104411,
        "voice": "vo_adv_2007006_055"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n只要一扯上布丁就異常難搞的宮子，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n竟然乖得服服貼貼的呢。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這位大小姐，",
        "unit_id": 104411,
        "voice": "vo_adv_2007006_056"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "究竟是什麼來頭？",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔～呣，",
        "unit_id": 104411,
        "voice": "vo_adv_2007006_057"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總覺得好像有在哪裡見過的呀。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎麼就想不太起來呢，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "難不成妾身真上了年紀了吶？",
        "unit_id": 104411
    }
]