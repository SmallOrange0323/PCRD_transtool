    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴在",
        "unit_id": 103311,
        "voice": "vo_adv_6040104_000"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "認真努力著……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然我真的很高興，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "但果然還是",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "像在作夢一樣的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然一直都在叫她去工作去工作的，",
        "unit_id": 103311,
        "voice": "vo_adv_6040104_001"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但還是會想念原本那個在偷懶的鈴鈴呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "能夠跟往常一樣，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "真的是一件值得感謝的事情呢。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "對鈴鈴來說的獎勵，",
        "unit_id": 103311,
        "voice": "vo_adv_6040104_002"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "就是讓她休息，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "是嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "可是沒辦法讓她休息呢……",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "那就把我的全新搞笑段子當成禮物吧！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "鈴鈴其實很溫柔呢。",
        "unit_id": 103311,
        "voice": "vo_adv_6040104_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "雖然一直都知道",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "她不是只會偷懶的人，",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n但真沒想到她會這麼可靠的啦。",
        "unit_id": 103311
    }
]