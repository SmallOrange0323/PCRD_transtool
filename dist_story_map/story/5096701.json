    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼！",
        "unit_id": 122411,
        "voice": "vo_adv_5096701_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "跑了好久──！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我已經",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "精疲力盡了啦……！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是、",
        "unit_id": 122511,
        "voice": "vo_adv_5096701_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這場地的機關太豐富了，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺就像是在考驗我們的各種技術……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我",
        "unit_id": 122611,
        "voice": "vo_adv_5096701_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "剛剛在跑的時候，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真的很在意……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n那些機關到底是怎麼做的……",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿嘿～",
        "unit_id": 122411,
        "voice": "vo_adv_5096701_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣真的很厲害呢～！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "毅力相當驚人喔！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜剛剛也沒有對機關動搖，",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一直很冷靜對吧。",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 122511,
        "voice": "vo_adv_5096701_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就連我也都動搖了。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我可不能讓優衣和日和看到我丟臉的模樣呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "倒不如說，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我反而被妳們的突破能力給嚇到了喔。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為……",
        "unit_id": 122611,
        "voice": "vo_adv_5096701_005"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也想和妳們兩個",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "並肩奔跑。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怜和日和果然很厲害呢。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "嘿嘿♪\n呵……\n呵呵♪",
        "unit_id": 1,
        "voice": "vo_adv_5096701_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來來來，",
        "unit_id": 122411,
        "voice": "vo_adv_5096701_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "下一場會是什麼樣的比賽呢？",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這次我要壓倒性的拿下第一名喔──！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我想這次也一定沒辦法輕鬆獲勝的。",
        "unit_id": 122511,
        "voice": "vo_adv_5096701_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過……",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就由我來拿下第一名吧。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……怜和日和",
        "unit_id": 122611,
        "voice": "vo_adv_5096701_009"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "都一點一點地改變了。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "雖然也有發生辛苦的事，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "但我們能來到這裡真是太好了。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "平常總是齊心協力的合作，",
        "unit_id": 122611,
        "voice": "vo_adv_5096701_010"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過偶爾",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我們也會向彼此確實地傳達情感。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就這樣加深彼此之間的羈絆，",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "漸漸地互相理解。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "要是這樣的關係……",
        "unit_id": 122611,
        "voice": "vo_adv_5096701_011"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "能一直持續下去就好了呢。",
        "unit_id": 122611
    }
]