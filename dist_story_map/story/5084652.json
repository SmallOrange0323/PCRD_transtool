[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "看來小哥還在睡啊。",
        "unit_id": 105611,
        "voice": "vo_adv_5084652_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n小哥至今面對過許多危機，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但這次的情況非同小可呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n連我也有些擔心呀。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "因為小哥是那副模樣，",
        "unit_id": 105611,
        "voice": "vo_adv_5084652_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以我們公會的成員也無精打采的呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n蘭德索爾裡最危險的公會完全不成樣子了啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那些傢伙一安分下來，反而讓人不習慣啊，",
        "unit_id": 105611,
        "voice": "vo_adv_5084652_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……唉，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也沒資格說別人呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不管做什麼事，我總是會想到小哥，",
        "unit_id": 105611,
        "voice": "vo_adv_5084652_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n完全集中不了精神啊。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是丟人。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "所以，",
        "unit_id": 105611,
        "voice": "vo_adv_5084652_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "小哥，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "快點醒來吧……",
        "unit_id": 105611
    }
]