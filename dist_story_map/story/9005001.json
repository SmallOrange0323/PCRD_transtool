    {
        "type": "dialogue",
        "name": "旁白",
        "words": "4.5周年紀念日將近的某一天。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n貪吃佩可等人聚集在【美食殿堂】的公會小屋裡。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的各位，",
        "unit_id": 105812,
        "voice": "vo_adv_9005001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "紀念日就要到囉☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次究竟要吃些什麼呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，貪吃佩可？",
        "unit_id": 106012,
        "voice": "vo_adv_9005001_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n紀念日",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可不是讓妳滿足口腹之慾的日子耶？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳怎麼無視慶祝，把吃東西擺在第一優先啊？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105913,
        "voice": "vo_adv_9005001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們是【美食殿堂】啊。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "慶祝的時候，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家一起開開心心大快朵頤，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也是理所當然的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也會大顯身手準備各種餐點。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳，",
        "unit_id": 105812,
        "voice": "vo_adv_9005001_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然如此，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得去準備食材才行！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "趕緊出發去冒險吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──那個。",
        "unit_id": 106412,
        "voice": "vo_adv_9005001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小雪菲？",
        "unit_id": 105812,
        "voice": "vo_adv_9005001_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n怎麼了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不好意思。",
        "unit_id": 106412,
        "voice": "vo_adv_9005001_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n準備食材的工作",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可否",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "交給妳們？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼啊？",
        "unit_id": 106012,
        "voice": "vo_adv_9005001_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n說好了要大家一起為紀念日做準備的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳還有其他事要忙？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃……",
        "unit_id": 106412,
        "voice": "vo_adv_9005001_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我想去",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "準備禮物。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "由我自己來準備",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "要送給{player}",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "的禮物。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_9005001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是要自己一個人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "準備禮物？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯。",
        "unit_id": 106412,
        "voice": "vo_adv_9005001_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "之前都是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "由貪吃佩可小姐、可可蘿小姐",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和凱留",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n負責構思和準備的工作……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我都只能從旁協助。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……所以這次",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我想自己來。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "自己構思，",
        "unit_id": 106412,
        "voice": "vo_adv_9005001_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "投入自己的心意",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "與感謝。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "希望能夠……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "讓總是在身邊守護我們的他感受到。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……不行",
        "unit_id": 106412,
        "voice": "vo_adv_9005001_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦～～",
        "unit_id": 106012,
        "voice": "vo_adv_9005001_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳一個人",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳行嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這可是很高難度的任務喔～？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有我們的協助，妳辦得到嗎～？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "討、",
        "unit_id": 106412,
        "voice": "vo_adv_9005001_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "討厭啦，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n別把我當成小孩子好嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也能獨當一面完成這件事！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我會做出",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "前所未有的最棒禮物給妳們看看！",
        "unit_id": 106412
    },
