        "type": "dialogue",
        "name": "凱留",
        "words": "喔，",
        "unit_id": 106012,
        "voice": "vo_adv_9005001_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誇下海口了呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……這不是挺好的嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我覺得無所謂喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯。",
        "unit_id": 105913,
        "voice": "vo_adv_9005001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也沒有意見。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下會在一旁耐心守候……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n見證雪菲小姐",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "獨當一面的決心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好期待小雪菲",
        "unit_id": 105812,
        "voice": "vo_adv_9005001_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "製作的禮物喔☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請把我們的感謝心意也一起投入，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n製作出充滿小雪菲風格",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "的禮物吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可小姐、",
        "unit_id": 106412,
        "voice": "vo_adv_9005001_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好，",
        "unit_id": 106412,
        "voice": "vo_adv_9005001_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "交給我吧！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我會製作出能讓大家",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感受到幸福的禮物。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼，我得趕緊",
        "unit_id": 106412,
        "voice": "vo_adv_9005001_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "著手準備才行。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n各位，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我出發了……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "慢走唷～！",
        "unit_id": 1,
        "voice": "vo_adv_9005001_021"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，雪菲前往蘭德索爾城鎮中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了製作出適合紀念日的禮物，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她的奮鬥即將展開……！"
    }
]