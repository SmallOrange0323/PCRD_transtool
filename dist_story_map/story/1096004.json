    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在某個晴朗的日子，妮諾和{player}坐在茶館裡，\n眺望著充滿觀光客，熱鬧又和平的大江戶町。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好悠閒、",
        "unit_id": 109611,
        "voice": "vo_adv_1096004_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "好悠閒、",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n天下太平",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正是指",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這種情況呢。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這麼說來，",
        "unit_id": 109611,
        "voice": "vo_adv_1096004_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我宣傳的忍者宅邸",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n好像變成了大江戶町",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "最受歡迎的觀光設施了是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "只要忍者宅邸",
        "unit_id": 109611,
        "voice": "vo_adv_1096004_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有很多的客人的話，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍也能找到很多",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "家臣候選人是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖然現在",
        "unit_id": 109611,
        "voice": "vo_adv_1096004_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍的家臣只有我一人，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不過軍力一定能成長到",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "百萬石之多是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "到時候",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "統一天下也指日可待是也！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你的誇獎我心領了，",
        "unit_id": 109611,
        "voice": "vo_adv_1096004_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這是我的榮幸是也！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這也是將軍",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "威勢的恩賜是也！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "正是如此是也！",
        "unit_id": 109611,
        "voice": "vo_adv_1096004_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　那道光是也！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵呵，",
        "unit_id": 109611,
        "voice": "vo_adv_1096004_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍的厲害之處，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我最清楚了，",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n你不用那樣發光",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也不要緊的是也。",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "唔，",
        "unit_id": 109611,
        "voice": "vo_adv_1096004_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哇啊啊啊啊啊啊————！",
        "unit_id": 109611
    },
    {
        "type": "still",
        "still": "109600401"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍！",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　將軍！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在這裡見面",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "已經是第100年了是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這是訓練是也！",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "要學會忍法",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "得從外表開始是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯？",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　附近好像",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "有什麼騷動呢？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n什麼東西開始了嗎？",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "正式",
        "unit_id": 1,
        "voice": "vo_adv_1096004_011"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "開始！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女主角",
        "words": "請多指教～。",
        "unit_id": 1,
        "voice": "vo_adv_1096004_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哦哦？",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_013"
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "嘿嘿嘿，",
        "unit_id": 1,
        "voice": "vo_adv_1096004_014"
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "小姐，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "流氓",
        "words": "\n要不要跟我們一起玩一下啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女主角",
        "words": "呀――！",
        "unit_id": 1,
        "voice": "vo_adv_1096004_015"
    },
    {
        "type": "dialogue",
        "name": "女主角",
        "words": "　誰來救救我呀！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "交給妮諾吧！",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_016"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你被捕了是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　城裡的和平",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "由妮諾來守護是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "欸欸！？",
        "unit_id": 1,
        "voice": "vo_adv_1096004_017"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "　喂……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "妳做什麼啊！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵呵……",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我被包圍了是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒想到連將軍",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "也是惡黨的",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "手下是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不過！",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_019"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　正義是必勝的是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n看我的手裏劍攻擊是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "咻咻咻！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "嗚哇！",
        "unit_id": 1,
        "voice": "vo_adv_1096004_020"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "　好險！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "\n導、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "導演……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "不阻止她沒關係嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "還滿有趣的啊……",
        "unit_id": 1,
        "voice": "vo_adv_1096004_021"
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "\n繼續拍！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "導演",
        "words": "　不准停止拍攝！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "咦咦咦咦――！？",
        "unit_id": 1,
        "voice": "vo_adv_1096004_022"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呣呣，",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_023"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍被洗腦了，無法解除是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "既然如此……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍不應該說那種話的是也。",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_024"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n一定是",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "被鬼給利用了是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我來擊退",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "俗世之鬼是也。",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "最終奧義！",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_025"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　忍法",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "・蜘蛛絲綑綁之術是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n咻啪啪啪啪啪！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "手、",
        "unit_id": 1,
        "voice": "vo_adv_1096004_026"
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "手腳都被綁住……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "員工",
        "words": "動彈不得了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈哈哈，",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_027"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "大家都被綁住了是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n總算能守護住",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這座城市的和平是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呣呣，",
        "unit_id": 103031,
        "voice": "vo_adv_1096004_028"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那我就此……",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n隱身是也！",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "　",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "忍忍",
        "unit_id": 103031
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是也。",
        "unit_id": 103031
