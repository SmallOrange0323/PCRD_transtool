[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "歡迎光臨～☆",
        "unit_id": 1,
        "voice": "vo_adv_1058002_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "抱歉！",
        "unit_id": 1,
        "voice": "vo_adv_1058002_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n現在已經過了最後點餐的時間了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n即使現在來店，我們也沒辦法出菜喔？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這張優待券給您，",
        "unit_id": 1,
        "voice": "vo_adv_1058002_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請您明天再來光顧本店♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦？",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}！\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你蠻常來這間店呢，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你喜歡這裡的魚料理嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我懂的！",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這裡的海鮮很好吃呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像是獨特的醬油風味和魚內臟的苦味！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔唷！",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n會讓人上癮呢～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "竟然懂得這味，\n",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}很內行喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n美食家喔～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你說今天不是來當客人？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那你為什麼要來店裡？",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n迷路了嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我最後再收拾一下就可以下班了，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n要我為你帶路嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哼哼。",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小可蘿不小心弄錯，買了太多魚嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你說不知道該怎麼處理那些魚，才來店裡的嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "與其讓那些魚腐爛，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你認為拿給別人做成魚料理還比較好嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此！",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你說的很有道理呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是不浪費的精神呢♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然給人一種很可靠的感覺。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒想到她也會犯這種錯呢，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n真是令人意外！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好可愛啊♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是啊。",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n剛剛我也告訴你了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這間店正要打烊呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說回來。",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這間店是禁止客人攜帶食材入內的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "即使是料理用的食材也不行？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "唉唷，不要露出那樣的表情啦！",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "放心吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要有我在的一天，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n絕對不會輕易地任由料理用的食材腐爛的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯……",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我去跟店長商量一下，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n請他讓我們使用廚房。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為了便於保存，這些魚一部分醃製或做成魚乾，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一部分稍微料理一下，然後就在這裡吃掉吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就這樣做，\n沒問題吧？",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，\n當然我吃掉的份，會付材料費給你的！",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_023"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……你不收錢嗎？",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_024"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n反正任由它腐爛，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也只是變成廚餘而已？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不行不行，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n錢的事情不能馬虎！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你一定要收下～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼\n就請你稍待片刻囉。",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_026"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我去料理一下，馬上就好～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，\n如果還吃得下，就盡量吃喔？",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請把魚",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_028"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n給我。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "喔，好重的魚腥味～！",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不愧是新鮮的海產☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就是這個啦，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這股氣味讓人欲罷不能啊～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼我就去做料理囉！",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_031"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "{player}，\n你就坐在那邊等我吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "店長～！",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n廚房借我用一下喔～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦？\n{player}為什麼要跟我一起來？",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是不堪寂寞呢～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯？",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n你想要我教你",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如何做料理嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "每餐都讓小可蘿來做，感覺過意不去，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以自己也想學會如何做料理～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "OK！",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯，\n做料理也是很愉快的喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "最近很流行料理型男呢～",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_037"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很受歡迎的喔！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咻咻♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼把手洗一洗，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_038"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後消毒一下吧～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼做你知道嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "圍裙我這裡有備用的，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n讓我來幫你繫上喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，不要亂動啦。",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你覺得很癢嗎？",
