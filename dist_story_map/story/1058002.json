        "voice": "vo_adv_1058002_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嗯，用那邊的毛巾把手擦乾吧～？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯……",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n雖然全部都交給我來做比較快，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但這次我就在旁邊給你指示吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "料理的入門，",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就讓我來教{player}吧～♪",
