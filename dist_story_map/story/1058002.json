        "voice": "vo_adv_1058002_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "像這樣拿才對……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明白了嗎？",
