    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚哇？",
        "unit_id": 105812,
        "voice": "vo_adv_1058002_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n{player}，停下來！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
