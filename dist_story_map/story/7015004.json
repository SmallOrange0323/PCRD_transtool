[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這就是姐姐的真本事！",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_000"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n神聖懲處！",
        "unit_id": 104911
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦哦！",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "靜流的背後長出了巨大翅膀！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n以及無數個漫天飛舞的白色羽毛！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哇啊啊啊啊！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是什麼，太令人感興趣了────！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "呼……",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_002"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個區域算是暫時掃蕩乾淨了呢。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊、",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂，靜流，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "剛才的翅膀是什麼？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我也想長出那個翅膀，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那個到底是什麼原理所引發的奇蹟？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那是為了保護弟弟的力量，",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_004"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐力。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "姐力！",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_005"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "也可以稱為姐姐的力量。",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "該、",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "該怎麼做才能習得那個能力……？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這個嘛～",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_008"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要隨時隨地無時無刻都想著弟弟，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n變得",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "非常姐姐就行了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n妳說什麼？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "變成非常厲害的姐姐？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不對不對，",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_010"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是變得非常姐姐。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n連在口語會話都要求整合文法，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "有違我的文科美學，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但是，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就刻意點出問題吧，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳那是錯誤的用法。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "剛才的情況，",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n用形容詞「非常厲害」",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來修飾名詞「姐姐」才是正確的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但「非常」是副詞，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因此會影響到動詞「變」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "嗯，",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_013"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒關係喔。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "是變得「非常」姐姐。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……好難啊。",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_014"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊啊，",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_015"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我記得優妮好像是獨生女？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳如果底下有弟弟或妹妹，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就自然會理解了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳那一副自己就是那一邊的語氣雖然很令人在意，",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但是傾聽患者訴說主觀症狀也很重要吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳繼續說。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是呀……",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_017"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n為了「變成非常厲害的姐姐」，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "只要變成非常厲害的人就行了。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此。",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_018"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "像是鍛鍊身體、",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_019"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "努力學習，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n或是完成對社會上",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有意義的出色工作之類的。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此原來如此。",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_020"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可是，",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_021"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "「變得非常姐姐」這句話",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n又和那句話是不同的意思，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "應該說是更偏向觀念上的意義。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "就是提升姐姐等級",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "達到更高層次的姐姐階級。",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此，聽不懂。",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_022"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我們的集體潛意識中，",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "有應該稱為地姐神（Great Sisters），\n人類普遍對姐姐的概念，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而登上其究極的高點，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就是接近自己的靈魂，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我換成這樣說有比較容易懂嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我懂了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我懂我聽不懂了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過，",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那只是在開玩笑──",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "咦，",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_026"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那是開玩笑嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "從哪裡開始的？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "剛出生沒多久嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "──重點就是",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_027"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n抱著「希望弟弟能每天過的幸福」",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "這種祈願的心，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n就是姐姐的力量根源♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此，我懂了。",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "總之我懂靜流為「弟弟」著想的心意",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不是普通地深就對了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不如說，除了那之外我什麼都沒懂。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是，",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "停止思考就是放棄學習。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n當嘴上喊著怎麼可能而扔掉筆的時候，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "賢者就已經死了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既然思考追不上，那只有去嘗試了。",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_030"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n為了學會那什麼叫做姐力的能力",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓自己背上長出翅膀，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "從今天開始我就變成姐姐吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不對，",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_031"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我已經是姐姐了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我正是優妮姐姐，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "簡稱優姐！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊哈哈，",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_032"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "優妮妳在說什麼呀～？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "裸體的國王在嘲笑鏡中的男人──",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_033"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "記住了，靜流，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我是效仿妳這個前例，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "自己冠上姐姐之名的人。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以，同志{player}啊，",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_034"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "很抱歉事後才報告，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n身為共同研究者，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你變成了我的弟弟。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如何，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是優姐喔，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在我長出翅膀之前你可以儘管跟我撒嬌喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "啊哈哈……",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_035"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "優妮妳在說什麼呀……",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳的眼睛和聲音都沒有在笑喔，靜流。",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_036"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "別這樣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n請妳別認真接受玩笑後，對我抱有競爭意識而增長妳的殺意。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "什麼啊，",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_037"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "原來是在開玩笑啊！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "咦，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "從哪裡開始的？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "未來永遠？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我有大約兩成左右是認真的，",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_038"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但在感受到生命危險之後，現在連那兩成都煙消雲散了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_039"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我這樣臨時抱佛腳",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也無法成為多了不起的姐姐。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n看著靜流，我就深深體會到了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "因為每個人都有不同的命運和資質啊。",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_040"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所謂的姐姐",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "並不是說當就能當的，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "而是等回過神就已經變成姐姐了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我是這麼想的！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "姐姐不是一天變成的，是嗎。",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_041"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀呀，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真是了不起。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就承認妳吧，靜流。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳所提出的姐姐理論",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "已經是超越貨真價實了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這似乎不是我這個鬧彆扭而自甘墮落的人，",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_042"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "能夠出手干涉的領域了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我就撤回自己說妳將他捲入",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "妳那設定隨便的自我暗示的發言吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n很抱歉我說妳是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "假扮姐姐的假貨和裝瘋賣傻的瘋子。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "那些我全都是第一次聽說耶，",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_043"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不過優妮謝謝妳能理解我！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "今天一整天在一起我也知道了！",
        "unit_id": 104911,
        "voice": "vo_adv_7015004_044"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n優妮就算不用以什麼姐姐為目標，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我覺得妳維持",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "現在這樣也是非常棒的學姐喔♪",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂喂，",
        "unit_id": 111011,
        "voice": "vo_adv_7015004_045"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你們突然在說些什麼啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不對不對，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我這種人……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嘻嘻嘻。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n別說些一聽就知道是客套話的稱讚啦～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦呵呵。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩條長長的平行線總算是開始交會，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n優妮學姐與靜流姐姐兩人露出笑容稱讚彼此。"
    }
]