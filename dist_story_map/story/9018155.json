[
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經到達開墾村落的另一邊了的樣子。",
        "unit_id": 105911,
        "voice": "vo_adv_9018155_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n村裡似乎也有魔物……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯嗯，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "像那樣的簡易柵欄，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會被小型的魔物鑽過去呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "呀啊啊！",
        "unit_id": 411,
        "voice": "vo_adv_9018155_001"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "　是魔物啊～！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哎呀，",
        "unit_id": 105811,
        "voice": "vo_adv_9018155_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個就是在路上聽說的野獸頭目吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎是從武器到建材到糧食，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大小通吃全都偷走的惡賊！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大型的魔物",
        "unit_id": 106011,
        "voice": "vo_adv_9018155_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該是沒那麼容易侵入的樣子……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但是這隻身手好像還滿矯健的呢。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這種柵欄輕易地就會被牠翻過了。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來，",
        "unit_id": 105911,
        "voice": "vo_adv_9018155_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還會用從村裡偷來的東西武裝自己。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也是經過這一連串的冒險成長過來的！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們上吧！",
        "unit_id": 105911
    }
]