[
    {
        "type": "background",
        "background": "501992"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "流夏小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120074_000"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總是抬頭挺胸，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "同時",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她的心地",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n也一樣正直而美麗呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這也可以說是",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "很帥氣吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n不只是公會成員，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "許多人也都很依賴她呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "揮劍有如在跳舞般，",
        "unit_id": 126311,
        "voice": "vo_adv_5120074_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要活用其美姿，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就來跳舞……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要不要去當當看偶像如何？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "姿態端正凜然的偶像，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這會引發",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一股新的風潮呢！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "想當然，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也會加入喔♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得深月醫生",
        "unit_id": 126311,
        "voice": "vo_adv_5120074_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "作為醫生的處世姿態很美喔。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然街坊鄰舍",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "都說她是密醫而懼怕她，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但她是個總是以真誠態度",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n來對待患者的大好人。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對美容方面也知道得很多♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想想，",
        "unit_id": 126311,
        "voice": "vo_adv_5120074_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "深月醫生",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "常常露出一臉疲態，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我認為應該要多空出一些去重新充電的時間。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為我往後也想跟醫生",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一起提升自己的美呀♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "惠理子小姐的美",
        "unit_id": 126311,
        "voice": "vo_adv_5120074_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "在於隱藏不住的激烈之愛呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "為了表達愛意而不擇手段的行動",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "甚至令人感到恐懼。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n美得令人背脊發涼……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這句話",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "正是最切合的形容吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要我給建議的話，",
        "unit_id": 126311,
        "voice": "vo_adv_5120074_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想想，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n既然平常都是激烈地投以愛意，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那就試著反過來，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "溫和優雅地",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n輕聲低訴愛意如何？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這種反差感",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也是一種美啊♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "七七香小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120074_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對自己喜歡的事物有種勇往直前……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "或者該說，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是橫衝直撞的感覺吧？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可以直接說出心中想法的這一點",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n很美喔♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然偶爾",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "會聽不懂她在說什麼就是。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "直率表達「喜歡」的眼神光彩，",
        "unit_id": 126311,
        "voice": "vo_adv_5120074_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "跟我的美相比也絲毫不遜色，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我覺得往後",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也盡量去挑戰新事物應該會很不錯喔♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "再來的話嘛，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是希望",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "她說話能再稍微冷靜點吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "修特帕魯小姐",
        "unit_id": 126311,
        "voice": "vo_adv_5120074_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "最令人注目的，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就是那對像寶石般的",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n美麗異色瞳吧！",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雖然可以聽到",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有關她的各種傳聞，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過到底哪個才是她真正的面貌呢……？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "老實說我不太清楚",
        "unit_id": 126311,
        "voice": "vo_adv_5120074_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能提供哪些建議，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為她",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n身上一堆謎團啊。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "移動龍卷風、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "疾風之冥姬、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "熾炎……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "戰鬼……？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過謎團很多這點",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "也是她美麗的地方就是。",
        "unit_id": 126311
    }
]