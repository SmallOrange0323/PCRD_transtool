    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在營業時間結束後的店內，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n珠希與{player}正在進行關店的工作。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好，",
        "unit_id": 125111,
        "voice": "vo_adv_1251004_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我掃完這邊了喵。",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你東西也洗完了嗎喵？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "明天莫妮卡也會回來，",
        "unit_id": 125111,
        "voice": "vo_adv_1251004_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以我們兩人單獨顧店在今天就暫時結束了喵……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "…………",
        "unit_id": 125111,
        "voice": "vo_adv_1251004_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你、",
        "unit_id": 125111,
        "voice": "vo_adv_1251004_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你在說什麼喵！？",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我、",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我超有精神的喵……！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n太有精神了，眼前都發光……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呃，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵啊啊～～～！？",
        "unit_id": 125111
    },
    {
        "type": "background",
        "background": "510360"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唉……",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我不小心隨口答應了喵……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在才拒絕也會造成別人困擾……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯？",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊啊，{player}喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你路過得正好喵……！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "其實",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我被拜託在某間咖啡店進行僅限一天的支援……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為是很照顧我的店長拜託的，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以我是接受了啦喵……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但我希望你看一下這個喵……",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖……",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然看起來像那樣，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但這是一般的咖啡店制服喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那並不是有女僕服務的地方，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "非常一般！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但是，",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要用這身制服接待客人，果然還是有點羞恥喵……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那、",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那是因為",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "來拜託我的店長，是我們鯛魚燒店的常客……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n他總是稱讚我的工作認真，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我很高興，忍不住就……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那、",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那就是問題所在喵……！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這對我來說有點太可愛了……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總之我會害羞喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……不論我有多害羞，",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一旦接受就沒辦法拒絕了喵。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但要突然毫無準備直接出場還是……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵～",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……對了喵！",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你現在能陪我練習嗎喵？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n因為是我要服務客人，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以我希望你來扮演客人喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果你能幫忙，",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總覺得我就有辦法克服了喵……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你願意幫我的忙嗎～？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……可以喵！？",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你真可靠喵♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n那就馬上……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呃，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在這裡的話太引人注目了喵。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦？",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}的家要借我？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那真是太感謝了喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那就麻煩你了喵！",
        "unit_id": 104631
    },
    {
        "type": "background",
        "background": "510090"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "歡迎回家，",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n主人喵♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……我剛剛也說過了，",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我去支援的是一般的咖啡店喵。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但這可是為了消除羞恥心的練習喵……！！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以要更進一步",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "用女僕風格來練習喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要是習慣了這個，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "正式上場也一定是小菜一碟喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……所以，",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我希望你也不只是客人，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要當作自己變成了主人，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不停提出要求喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……喵呵呵。",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n跟我想的一樣，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你一副不知如何是好的表情喵～？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但不必擔心！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我已經有確實準備了喵！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵～！！",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "《新手主人講座》喵～！！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這本書中",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有示範主人的舉止喵！！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我、",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我對那還感到很害羞喵。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以我要先習慣這個，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "制服則是今天的最後階段喵！！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "重新開始練習喵～",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……主人，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我為您泡好溫熱的咖啡了喵～♪",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "…………那就來吧喵，",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "主人。",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哦，",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "來了喵……！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "正合我意喵！！",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……那",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我就為您吹涼喵……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "──",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼──",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼──",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呼──",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "來，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣的溫度可以嗎喵？",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵！？",
        "unit_id": 104631,
        "voice": "vo_adv_1251004_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你是想讓我說什麼喵……",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n不對，",
        "unit_id": 104631
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是我要你這麼說的……",
        "unit_id": 104631
    },
    {
