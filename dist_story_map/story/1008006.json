[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪參加了蘭德索爾美女選拔活動。"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "優勝者，是第八號參賽者！",
        "unit_id": 311,
        "voice": "vo_adv_1008006_000"
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "\n雪！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我是優勝！？",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "太好了──！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯，不過以我的可愛程度，這是理所當然的結果對吧？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "司儀",
        "words": "接下來，就頒發給優勝者獎金，以及次獎的獎品──",
        "unit_id": 311,
        "voice": "vo_adv_1008006_002"
    },
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊──{player}。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你來看比賽了嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我在蘭德索爾美女選拔活動得到優勝唷！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，謝謝呢。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_004"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n出自你口中的祝賀，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n比起其他人的更讓我更開心呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這麼在意芝麻小事可是不行的唷。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n美麗當前，和性別可是沒有關係的。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來嘛，你看看。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_006"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我還拿到獎金了唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，是一大筆錢唷……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯，不過之前擅自把公會的財產賣掉了，",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_007"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n所以變成把東西贖回來的資金了呢……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要有這些錢，似乎就能全部贖回來了，",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_008"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n大家應該也會原諒我了吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，不過我不是為了錢才參加選美的唷。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_009"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "獎金說到底也只是順便拿的呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我真的想要的，是這個次獎獎品唷。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_010"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這是一面魔法之鏡呀。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "據說只要用這個，就能創造分身。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "可愛的我就會變成兩個人唷？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果是普通的鏡子，不管怎麼調角度就是有很難看到的地方呢。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_012"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n為了好好呵護我的全身，這個是一定要的啦。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是期待呢～趕快來用用看！",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好厲害！",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我真的變成兩個人了！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊啊，我果然很可愛呢……",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_015"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n多麼地美麗啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "唔～嗯……",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_016"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，果然分身還是不行呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我覺得還是我比較可愛唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "你在說什麼？",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_017"
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "\n當然是我比較可愛唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什……！？",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "明明只是分身，還真敢說呢……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n絕對是我比較可愛！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "不對，",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_019"
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "可愛的是我才對唷！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "你看，這個瀏海的處理方式……是我比較厲害對吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那又怎樣呢。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "像我，可是整頭頭髮都散發出可愛氣息唷。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "既然這樣，我全身都很可愛唷！",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果是全身，那當然就是我比較可愛呢！",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "明明是我的分身，美感卻令人懷疑……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "那是我的台詞才對吧。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_023"
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "明明是我，卻完全察覺不到真正的可愛……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，竟然敢找我吵架，真是好膽量呢。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_024"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那就問問{player}吧。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "不錯呢。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_025"
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "如果是{player}，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "\n就能清楚分出誰比較可愛了。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "{player}！\n你認為我和分身，",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_026"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "誰比較可愛？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那是理所當然的吧！",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_027"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我是在問你可愛的我們之間，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n誰才更可愛啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "如果你不選出一個，我們會很困擾的。",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "靠近點，再仔細看看！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "就只能靠你來決定了！",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_029"
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "我，還有我……誰比較可愛？",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_030"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來吧，快點說出來吧！",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_031"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n說我比較可愛！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "不對，可愛的是我對吧！",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_032"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊！",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_033"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "{player}，你要去哪裡！？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "分身雪",
        "words": "在你說出誰比較可愛之前，不會讓你逃走的唷！",
        "unit_id": 100811,
        "voice": "vo_adv_1008006_034"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是在魔法的效果消失之前，\n{player}不斷被兩位雪四處追趕……"
    }
]