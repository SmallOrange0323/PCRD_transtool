    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳稍微忍耐一下啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在調查完這裡的生態系之前，",
        "unit_id": 106011
