        "voice": "vo_adv_9057155_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就只能先平息風暴了……！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n為了貪吃佩可小姐……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為了【美食殿堂】……",
        "unit_id": 106411
