    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "先專心對付魔物吧！",
        "unit_id": 106411
    }
]