    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n光靠我們現有的食材",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該也能做出很好吃的東西才是。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿……",
        "unit_id": 105811,
        "voice": "vo_adv_9057155_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳說",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "得對。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "食物不光只有魔物而已。",
        "unit_id": 105811
