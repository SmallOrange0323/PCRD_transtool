[
    {
        "type": "background",
        "background": "502060"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在成功轉移到埃拉的複製品世界後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n日和與埃拉會合了。"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈！",
        "unit_id": 135511,
        "voice": "vo_adv_5208065_000"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "怎麼樣？日和，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n大家比以前",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "還更有活力",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對吧！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯！",
        "unit_id": 135712,
        "voice": "vo_adv_5208065_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "鎮上的人們",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "比以前",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還更有精神呢！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一定是因為埃拉用笑容陪伴著他們，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以大家才能總是帶著笑容吧♪",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哦，",
        "unit_id": 135511,
        "voice": "vo_adv_5208065_002"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳真會誇人！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "日和，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大姐姐請妳吃冰吧♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳看那邊！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那是最近很紅的移動冰淇淋店！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 135712,
        "voice": "vo_adv_5208065_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有好多種類，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不知道該挑哪個好呢♪",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不好意思，店員小姐～！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有什麼推薦的口味嗎……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊！？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊！",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "日和，歡迎光臨！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "歡迎來到珠希的冰淇淋店～♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……咦，",
        "unit_id": 135712,
        "voice": "vo_adv_5208065_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "珠姐？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……啊，",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "妳該不會是",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "基礎世界的日和吧！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我說得沒錯吧？埃拉大人……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哈哈，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "果然！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我就想說她給人的感覺跟平常的日和不太一樣♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦……",
        "unit_id": 135712,
        "voice": "vo_adv_5208065_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "給人的感覺",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "跟平常不同的，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n應該是珠姐妳才對吧……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "主要是",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "語尾方面……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "──哦，",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "基礎世界的我會在語尾加上「喵」嗎！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊哈哈，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那是怎樣啊，真有趣耶～♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n該不會是因為",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我是貓的獸人族吧，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊哈哈♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "先不說這個，",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我看到妳之前的精采表現囉！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n多虧妳跟埃拉大人，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n讓我們能像這樣",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "用自己的意志自由地賣冰淇淋了！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "除了我個人之外，",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我還要代表喜歡我們冰淇淋的那些客人向妳道謝。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……這、",
        "unit_id": 135712,
        "voice": "vo_adv_5208065_011"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這妳完全不用在意啦。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是……",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總覺得",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有些按捺不住呢。",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……好。",
        "unit_id": 135712,
        "voice": "vo_adv_5208065_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對了，日和！",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我送妳冰淇淋當謝禮吧！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這次就給妳個大優惠，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓妳選三種口味！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……喵。",
        "unit_id": 135712,
        "voice": "vo_adv_5208065_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我推薦紅豆口味的冰淇淋♪",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n吃起來很清爽，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "非常適合在天氣炎熱的時候吃！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……喵。",
        "unit_id": 135712,
        "voice": "vo_adv_5208065_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦，",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "基礎世界的我是賣鯛魚燒？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊哈哈，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在這座鎮上應該會因為太熱而賣不出去吧！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……喵。",
        "unit_id": 135712,
        "voice": "vo_adv_5208065_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "從剛才開始就在語尾補上了「喵」！？",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_019"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈！",
        "unit_id": 135511,
        "voice": "vo_adv_5208065_020"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n是不是沒有「喵」就會覺得不自在喵～？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊、",
        "unit_id": 135712,
        "voice": "vo_adv_5208065_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊哈哈，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對不起～！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我就收下冰淇淋了！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就這樣，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "下次見～！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊哈哈，",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "再見囉～！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n祝妳觀光愉快～～～",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……喵。",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……",
        "unit_id": 104611,
        "voice": "vo_adv_5208065_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哎呀哎呀。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒想到好像還挺合適的……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是複製品世界的珠希"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n迷上了在語尾加上「喵」。"
    }
]