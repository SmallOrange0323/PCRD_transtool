        "voice": "vo_adv_1013007_026"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這超稀有魔法借我一用！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n就用這魔法一決勝負吧！",
