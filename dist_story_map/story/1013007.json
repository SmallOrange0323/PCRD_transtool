        "voice": "vo_adv_1013007_013"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "如果再害他受傷就更煩惱了……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n不帶他來是正確的吧……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "氣死人了，遇到了倒楣事啊。",
