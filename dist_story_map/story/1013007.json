        "voice": "vo_adv_1013007_022"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "又來搗亂！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "\n因為妳我們可是吃了牢飯呢！",
