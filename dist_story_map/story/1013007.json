    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "叔叔們就在這裡等著！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "啊、",
        "unit_id": 1411,
        "voice": "vo_adv_1013007_010"
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "喂！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "小姐！",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "循著強力魔力的痕跡，",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "追到了這裡，但……",
