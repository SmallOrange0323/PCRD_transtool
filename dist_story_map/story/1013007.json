        "voice": "vo_adv_1013007_014"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "嗯不過，",
        "unit_id": 811,
        "voice": "vo_adv_1013007_015"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "雖然繞了遠路但也達到目的了，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "\n也算不錯了啦。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真的在……",
