    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "若不是兩個人一起詠唱就使不出來呢！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "而且是一種需要擁有「互信關係」的兩人詠唱的特殊咒語……",
        "unit_id": 811,
        "voice": "vo_adv_1013007_031"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "\n這就是這本魔導書被當成貴重物品的理由！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你說……",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_032"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "什麼！",
