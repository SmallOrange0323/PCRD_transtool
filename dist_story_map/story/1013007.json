        "voice": "vo_adv_1013007_017"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "就來試試魔導書的力量吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "啊啊，",
        "unit_id": 811,
        "voice": "vo_adv_1013007_018"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "要開始囉。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼可能讓你得逞呢！",
