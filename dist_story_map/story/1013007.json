    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "唉……",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_012"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為什麼到了這個節骨眼，\n還會想到{player}呢──！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但是，",
