        "voice": "vo_adv_1013007_033"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但我可是魔法少女七七香，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n沒有這本魔導書也是超可愛又超強！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒問題！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "妳這女人還真敢講……",
        "unit_id": 911,
        "voice": "vo_adv_1013007_034"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "喔啦！",
        "unit_id": 911
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦！哇……",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_035"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你們的魔法果然很強呢……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但爺可是不會輸的喔？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "輪到",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我的回合了！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "還早得很！",
        "unit_id": 811,
        "voice": "vo_adv_1013007_036"
    },
    {
        "type": "background",
        "background": "500220"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "喂！",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "果然現實世界中的戰鬥沒有回合制啊！",
        "unit_id": 101311
