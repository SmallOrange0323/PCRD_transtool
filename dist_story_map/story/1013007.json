        "voice": "vo_adv_1013007_016"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "好。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "在這裡應該不會有什麼東西搗亂，",
