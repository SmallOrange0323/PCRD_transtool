    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "成功了……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗎？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "……竟然……",
        "unit_id": 911,
        "voice": "vo_adv_1013007_076"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "敗在這種地方。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚哇……",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_077"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "真頑強呢……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你同伴都躺平了說。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "怎麼會……",
        "unit_id": 911,
        "voice": "vo_adv_1013007_078"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "嗚！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "\n……我、",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "我們和",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "那位大人……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "要朝「暮光之都」……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "暮光之都！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_079"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n為、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "為什麼是那個名字！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "對……",
        "unit_id": 911,
        "voice": "vo_adv_1013007_080"
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "……不……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "魔法師1",
        "words": "……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "欸等等！",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_081"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……嗯嗯嗯，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "就是……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這麼一回事吧。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "神秘男所找的正是……",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_082"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "暮光之都。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼為何要帶著魔導書到處走到處發呢……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚嗚嗚謎團越來越多了──！",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_083"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯，不過徒弟們都被打倒了，",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_084"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "等送他們進牢後再問個清楚吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……比起這些事……",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_085"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "謝謝你。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那魔法，",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_086"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "若沒有互信關係是無法發動的……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "願意相信我……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "明明因我而受過傷……",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_087"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "……咦！？",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_088"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊、那個……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "一定是因為我們是夥伴嘛！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗯對的！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我可不接受其他論點！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "但、但是、",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_089"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "被這麼當面一說……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n很、",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "很害羞呦～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "嗚哇～",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_090"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "怎麼覺得好熱！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n為什麼！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊、",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_091"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "原來是因為火山啊！",
