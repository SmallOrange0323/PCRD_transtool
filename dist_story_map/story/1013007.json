    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "對叔叔們不太好意思，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n但這可是為{player}報仇的好機會……？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我、",
        "unit_id": 101311,
        "voice": "vo_adv_1013007_009"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我會幫你拿回魔導書，",
