        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "商人１",
        "words": "\n還奪走了魔導書！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "咦──！？",
