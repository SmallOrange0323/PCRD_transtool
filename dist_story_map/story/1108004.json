[
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天放學後。\n克蘿依在找正經的打工時，\n看到了佈告欄張貼的招募訊息。"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗚哇，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "時薪好低。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……啊不，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這個價錢算一般啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "因為以前的酬勞比較有感，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以才搞不清楚了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好遜，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "注意點吧。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "比起錢的問題，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "地點更麻煩啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "因為我們學校不",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "允許打工，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n所以不太能在",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "會被詢問來歷的地方工作。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒有合適的地方？",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n學校附近的話，會有被老師發現的危險？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "但是，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "太遠的話，等放學後再去就太晚了……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "頭好痛。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "因為前途堪憂，真的要生病了啊……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "呀！",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊啊、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼啊是{player}啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我說啊。",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_007"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是啊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n我不是和你說了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不要突然從背後叫住我嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n害我不小心說了「呀！」。那很可愛嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "今天不是打工，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_008"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "而是要找打工。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯不是，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_009"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不是那種的。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就是那種，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "商店店員之類的？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我想說既然要打工，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不如就在自己有興趣的地方――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n一個勁地",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "在想像中。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "因為我，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喜歡服飾之類的東西。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "而且至少，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也有服務業的經驗？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "雖然被要求得親切或有親和力之類的時候，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "會覺得",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "「為什麼」，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過我並不、",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "完全不",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "討厭，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "和人說話這件事。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n雖然從旁人的眼光看來，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好像看不出來……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "而且，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_013"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不知為何，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我在學校的時候，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n別人常會和我",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "保持著微妙的距離。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不太知道為什麼，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_014"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那些人都莫名其妙地怕我。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等等，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這樣很失禮吧？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n明明我可是那種會不小心『呀─』地叫出來的",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嬌弱少女耶…",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "…………啊？",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "咦，什麼，{player}。",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_016"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n明明別人正用有點認真的語氣說話，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n為何突然拿出這種亮亮的東西。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你在開玩笑嗎。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "話說回來，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_017"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那道光到底是什麼。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n而且來勢洶洶，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗚哇，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好難受……",
        "unit_id": 110811
    },
    {
        "type": "background",
        "background": "510150"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "抱歉，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_018"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我遲到了。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "哎呀，",
        "unit_id": 1231,
        "voice": "vo_adv_1108004_019"
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "花子。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "\n",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "難得妳會遲到，",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "在學校發生了什麼事嗎？",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_020"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "因為……",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "幫學生會處理一些事……",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "真是抱歉，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我會在那邊換衣服去外場。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "啊啊，",
        "unit_id": 1231,
        "voice": "vo_adv_1108004_021"
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "等等！",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "\n",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "二號桌的客人，",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "\n是和花子同校的學生們呢？",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊？",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_022"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n啊……",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "對，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "沒錯呢。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "甚至是",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "同班同學呢。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "其實他們站在那一會了，",
        "unit_id": 1231,
        "voice": "vo_adv_1108004_023"
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "還沒點餐呢。",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "\n在換衣服之前，",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "咖啡店長",
        "words": "能不能幫我去問一下？",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "咦，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_024"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我來嗎？",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_025"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯……",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "是可以啦……",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "噗呼……",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_026"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "歡迎光臨，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_027"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "決定要點什麼了嗎――",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1108004_028"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "是。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n那麼",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "兩杯特調咖啡――",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "――咦？　",
        "unit_id": 1,
        "voice": "vo_adv_1108004_029"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "黑江！？　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "在幹嘛？　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "在做什麼呢？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "為什麼用敬語。",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_030"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "店員店員。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我在這邊打工。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_031"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "總之",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "希望你們能替我和學校保密。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "因為父母蓋章之類的事很麻煩，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "所以我沒去申請許可。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_1108004_032"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "好！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "我們口風很緊的沒問題！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "請放心！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "所以說，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_033"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "為什麼說敬語。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "真好笑。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "啊哈哈……",
        "unit_id": 1,
        "voice": "vo_adv_1108004_034"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "哈哈……",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_035"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊――",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_036"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "對了，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "……抱歉，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我正在工作。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "兩杯特調咖啡對嘛，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "請慢慢享用――",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "噗……",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_037"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "原來大家放學途中，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "都會四處晃晃啊――",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "這樣很開心嗎，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_038"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "雖然不太懂。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "呀！？",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_039"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "欸……",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_040"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嚇死我了，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "咦，你是誰。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊？",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_041"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊啊，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "這樣啊。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n只有這週被叫來幫忙，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "店長好像是這麼說……",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "那個，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_042"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我是外場的黑江花子。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n如果有任何不清楚的事，不用客氣請去看工作守則。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n那就這樣。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊？　",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_043"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "怎麼那麼突然。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不，抱歉雖然是廢話，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_044"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n不過窗外的天氣不要說好，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n雲層厚到炸，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "根本可以稱為壞天氣了吧。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊。",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_045"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "也是――。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我知道。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "…………",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_046"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "所以？",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_047"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "咦，什麼啊。",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_048"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n這種久違的",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "親戚叔叔般的行為是怎麼回事。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n為什麼一碰上就",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "突然開始講些不著邊際的話。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "炸吐司邊。",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_049"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "蕎麥湯。",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_050"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "咦，這算什麼，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_051"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不重要吧。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n是怎樣，這種空虛的問答題。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你到底想做什麼。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n你想把這些空虛的話塞在辛勤打工少女的耳朵裡嗎。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不過，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_052"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "說真的這樣超可怕的。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n為什麼，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我會被",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "第一次見到的男人盤問。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊？",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_053"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊……",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_054"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n該不會……",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你是那種？",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n剛剛，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你看到我和那些女孩的互動？",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "唉……",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_055"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "原來如此，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "所以才會。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "簡單來說就是對我有所關心？",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "……咦，等等。",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_056"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n我剛剛，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "散發出了那種寂寞到",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n要被人家安慰的氣場嗎。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "好遜。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_057"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "沒什麼……",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我在這裡",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "幾乎沒什麼朋友，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n也不是說",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "和那些女孩子們關係不好，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "所以沒問題啦。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "算了，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_058"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不過，",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "還是謝謝你。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你，",
        "unit_id": 110831,
        "voice": "vo_adv_1108004_059"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "是個好人呢。",
        "unit_id": 110831
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n雖然說的話沒內容又無聊。",
        "unit_id": 110831
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好，",
        "unit_id": 190011,
        "voice": "vo_adv_1108004_060"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看到的，",
        "unit_id": 190011,
        "voice": "vo_adv_1108004_061"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是如同夢境一般的情景唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n反正你醒來以後很快就會忘記的，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在不用想太多呦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話說回來……",
        "unit_id": 190011,
        "voice": "vo_adv_1108004_062"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n克蘿依，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "無論在這邊還是那邊，個性都很麻煩呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "該說笨拙，",
        "unit_id": 190011,
        "voice": "vo_adv_1108004_063"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還是喜歡耍帥。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "大概就像",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "沒辦法對人撒嬌的野貓一樣吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1108004_064"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然和那種性格的人",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "相處會有些辛苦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但也只有心胸寬闊的你，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n能用豁達的心",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "悠閒地和她相處對吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然她本質上是個有骨氣的堅強孩子，",
        "unit_id": 190011,
        "voice": "vo_adv_1108004_065"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但在一旁看著她，有時也覺得挺危險的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "{player}，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要好好照顧人家唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就到這邊。",
        "unit_id": 190011,
        "voice": "vo_adv_1108004_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "再見囉。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500390"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嗯嗯……",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_067"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……咦，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_068"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "奇怪？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n這是什麼，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "糟糕……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不知道為何倒頭就睡。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "等等，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_069"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "{player}也是。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n好了，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "起來了――？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "會感冒喔――",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "唉，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_070"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是怎麼了……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n竟然會睡在這種地方，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n也許我比",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "自己想的還要累。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "可能最近一直在上學和打工，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_071"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n睡眠時間太少，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "才會這樣吧……",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？　",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_072"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "重點是這個嗎？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "這個城鎮治安超好的所以還好。",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_073"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n一般面對弱女子在路邊倒頭就睡的狀況，",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n難道會說真是太好了的感想嗎？　",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "也太相信人性本善了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "……唉，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_074"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "算了。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "你這傢伙，",
        "unit_id": 110811,
        "voice": "vo_adv_1108004_075"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "果然是好人呢。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n雖然說的話沒內容又無聊。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在連自己都沒注意到的時候，\n克蘿依展露出了溫暖的笑容。"
    }
]