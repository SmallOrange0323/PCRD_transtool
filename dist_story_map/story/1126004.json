    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "嗚嗚……",
        "unit_id": 231,
        "voice": "vo_adv_1126004_012"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "1、",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "2、",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "3、",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "4 ……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "Stop Stop，",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_013"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不用這麼用力也沒關係喔～！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "怎麼了嗎？",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "那個啊，",
        "unit_id": 231,
        "voice": "vo_adv_1126004_014"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "我覺得要把大姐姐教的動作，",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n全部做到",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "最好……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "可是，",
        "unit_id": 231,
        "voice": "vo_adv_1126004_015"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "這樣一來",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "如果失敗的話該怎麼辦呢。",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "嗚嗚，",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "我搞不清楚啦……",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊～",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_016"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這樣啊。",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是覺得自己",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不跳好的話不行啊。",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "吶，大家～",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "妳們是抱著怎麼樣的心情在跳舞的呢？",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "人家",
        "unit_id": 1,
        "voice": "vo_adv_1126004_017"
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "就是這樣哇～地在跳喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "\n反正人家一跳起舞來就什麼都不知道了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊哈哈，",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_018"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "同感同感！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "氣氛一嗨起來",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "就會變成那樣了呢～",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "女孩子3",
        "words": "我啊，",
        "unit_id": 1,
        "voice": "vo_adv_1126004_019"
    },
    {
        "type": "dialogue",
        "name": "女孩子3",
        "words": "倒是盡量不跳得太努力呢～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女孩子3",
        "words": "\n因為努力過頭的話很累人的嘛～。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "呣呣，",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_020"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "小小年紀就知道跳舞時的輕重緩急！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "將來無可限量啊……",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "咦？",
        "unit_id": 231,
        "voice": "vo_adv_1126004_021"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n大姐姐，",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "妳不會生氣地說",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "「這樣不行」嗎？",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我才不會說這種話呢，",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_022"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "大家照自己喜歡的方式做就好了！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不用完美地做到",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我所教的所有東西也沒關係喔。",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊哈哈！",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_023"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "感覺是有點超現實的風格呢。",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不過，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "就是這樣。",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "就照著自己的風格去做就好了！",
