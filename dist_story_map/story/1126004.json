    {
        "type": "dialogue",
        "name": "旁白",
        "words": "和【new generations】一同在村裡停留的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在陪著未央等人結束練習後──"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊，",
        "unit_id": 112611,
        "voice": "vo_adv_1126004_000"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "辛苦了～！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你在休息嗎？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n我",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "剛剛和後援會的大家",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "聊了很多事情！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "接著",
        "unit_id": 112611,
        "voice": "vo_adv_1126004_001"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "再稍微做一下自主練習，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "再來就想好好休息了呢。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n也快要傍晚了……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……話說",
        "unit_id": 112611,
        "voice": "vo_adv_1126004_002"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不覺得有點亮嗎？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "咦，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "是你在發光！？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n是有什麼機關嗎！？　",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你是",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "怎麼……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "呀啊啊！",
        "unit_id": 112611
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "假日正在散步的{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n正走到公園附近的時候——"
    },
    {
        "type": "still",
        "still": "112600401"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "好了～",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_003"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "各位！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "跟著老師一起動起來──！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "首先",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "在跳舞之前要先暖身唷──！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "女孩子們",
        "words": "好～！",
        "unit_id": 1,
        "voice": "vo_adv_1126004_004"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊，",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_005"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "哈囉～！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……你問我在做什麼？",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我現在啊，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "在教這些孩子們，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "什麼是",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "偶像的工作喔！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "剛剛在這裡跳舞，",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_006"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "然後這些孩子們就來找我說話了呢。",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "他們喜歡模仿偶像，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "所以希望我教她們～",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "對吧──！",
        "unit_id": 112631
    },
    {
        "type": "still",
        "still": "112600402"
    },
    {
        "type": "dialogue",
        "name": "女孩子們",
        "words": "對～！",
        "unit_id": 1,
        "voice": "vo_adv_1126004_007"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……對了！　",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_008"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你有空的話，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n能不能稍微幫我個忙呢？",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "來炒熱",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "模仿偶像遊戲的氣氛！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "再說，",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_009"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "如果你來幫忙",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "……",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "就有那個俗話說的，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "初學者的角度？",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "遇到問題的時候，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "你應該可以以不同的觀點回答問題吧～",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我覺得。",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "好嗎，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "拜託了！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "謝謝！",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_010"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "那麼各位～，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這位大哥哥也會一起幫忙，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "就以偶像為目標",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "加油吧～☆",
        "unit_id": 112631
    },
