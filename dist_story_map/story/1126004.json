        "name": "女子１",
        "words": "那",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "該怎麼做才好呢？",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這樣的話……",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_029"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "好！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n那麼，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "把我教妳的事",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "先全部都忘記吧！",
