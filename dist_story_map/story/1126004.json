    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "不用做得很好也沒關係嗎？",
        "unit_id": 231,
        "voice": "vo_adv_1126004_024"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n因為，",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "偶像不都做得很好嗎？",
        "unit_id": 231
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這個",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_025"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "嘛。",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "雖然現在只是模仿遊戲，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "但一當上偶像，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n就會有種不得不保持完美的心情，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這點我明白的。",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "不過，",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_026"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "如果滿腦子只想著那些事，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "讓開心的",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "心情因此跑不見，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這樣就有～點可惜了呢！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "勇敢做自己，盡情享受其中，",
        "unit_id": 112631,
        "voice": "vo_adv_1126004_027"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n以此為基礎，",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "再要求完美才是最棒的呢。",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "無論如何一定要和觀眾們一起同樂！",
        "unit_id": 112631
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "大概是這種感覺♪",
        "unit_id": 112631
    },
    {
