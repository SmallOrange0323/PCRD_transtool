    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1004011_066"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "竟然說要尋找只有兩人知道的地方，",
        "unit_id": 190011,
        "voice": "vo_adv_1004011_067"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n還真是浪漫呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過，",
        "unit_id": 190011,
        "voice": "vo_adv_1004011_068"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我想禊她應該完全沒有那個意思就是了，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "正因為如此，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才會在成為大人之後，發覺這份回憶有多麼寶貴吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "然後呢，",
        "unit_id": 190011,
        "voice": "vo_adv_1004011_069"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "關於你們找到的地方……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "由我說出來就有些太不識趣了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1004011_070"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n嗯，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "用你自己的雙眼和雙腳去確認吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n畢竟你可是禊探險隊重要的隊員啊，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對吧？",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯嗯……",
        "unit_id": 100411,
        "voice": "vo_adv_1004011_071"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯～？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n奇怪？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "又在不知不覺中睡著了……？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "總覺得在夢裡面，",
        "unit_id": 100411,
        "voice": "vo_adv_1004011_072"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好像也在跟哥哥一起",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n到處玩耍……？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦，",
        "unit_id": 100411,
        "voice": "vo_adv_1004011_073"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥也是嗎？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這樣啊，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "總覺得很高興呢！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "簡直開心得讓人捨不得那是一場夢呢～！",
        "unit_id": 100411,
        "voice": "vo_adv_1004011_074"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 100411,
        "voice": "vo_adv_1004011_075"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "對了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "下次我們一起畫地圖吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n畫一張只屬於你和禊的藏寶圖！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊認為那樣一定會很有趣！",
        "unit_id": 100411,
        "voice": "vo_adv_1004011_076"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "一定要一起畫哦！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們約好囉！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}點頭同意後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n禊開心地露出了燦爛的笑容。"
