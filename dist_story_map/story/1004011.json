[
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "順利抓住了地痞們以後，\n禊與{player}正走在返回蘭德索爾的路上。"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "今天雖然遇上了很多麻煩事，",
        "unit_id": 100411,
        "voice": "vo_adv_1004011_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n不過能夠拿回哥哥被偷走的東西真是太好了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "而且也讓很多人掉進了陷阱地洞，",
        "unit_id": 100411,
        "voice": "vo_adv_1004011_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n果然跟哥哥在一起就會很開心呢～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "唉～",
        "unit_id": 100411,
        "voice": "vo_adv_1004011_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真不想現在就回家呢。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n可惜太陽已經要下山了。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要是一直都是大白天的話，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n就能夠跟哥哥再玩久一點……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是不是",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "有什麼在發光？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這是什麼！？",
        "unit_id": 100411,
        "voice": "vo_adv_1004011_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這是可以繼續玩的意思嗎～～！？",
        "unit_id": 100411
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "發現哥哥了～！",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_004"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊就知道在這附近閒逛，一定能夠遇見你！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "看得出來嗎？",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸嘿嘿嘿～",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你看這個！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n在國外的爸爸寄信給禊了～！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "上面寫了許許多多的事情，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n像是關於爸爸探險的地方，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "還有探險時遇見的人等等，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n非常有趣哦～",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "然後呢，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊也想要回信給爸爸，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n不過單純寫信回覆他太無聊了，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n所以禊打算要放藏寶圖進去！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯！",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_008"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊想要讓爸爸知道，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊平常探險的地方是怎樣的地方！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "所以",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊希望哥哥也能夠幫禊這個忙！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你願意幫禊嗎……？",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "太棒了！",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那麼必須先決定好起點！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n果然尋寶的旅程，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就是要從會令人興奮的地方開始才行呢。",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "已經決定好要當作起點的地方了！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "來吧，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要開始快樂的畫藏寶圖時間了！",
        "unit_id": 100431
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "起點就是",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_012"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "有許多好玩東西的公園哦！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n嗯～",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過只有公園有些太單調了，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n其他有沒有什麼可以畫上去的呢？",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_013"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那個可麗餅店或許不錯！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n它常常都在那裡，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "而且非常顯眼！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_014"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好像沒有藏寶圖",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "會把可麗餅店畫上去呢。",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n嗯──",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "對了！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "就把它當作是酒館吧！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "像是遊戲裡",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "也會在酒館中召集夥伴嘛。",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "召集完夥伴後出發去尋寶！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯嗯，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真是個不錯的起點呢！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可是這間可麗餅店，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "總是沒什麼客人對吧？",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n真的能夠順利召集到夥伴嗎……",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "算了！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那麼終於要輪到",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "通往寶藏的路途了！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "一定要準備一條超棒的路徑，讓爸爸能夠好好享受！",
        "unit_id": 100431
    },
    {
        "type": "background",
        "background": "510100"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……吞口水。",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_018"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥你小心點，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_019"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這條路可是非常危險的。",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "如果",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不是為了爸爸的話，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊也不想來這種危險的地方……",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "太天真了，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_021"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n比如說那邊那戶人家，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "看起來雖然很普通，但實際上……",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "裡面有一隻很大，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_022"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "而且非常會叫的狗哦！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "牠現在已經跟禊變得很要好，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n所以看到禊會搖著尾巴湊過來就是了～",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "初次見到的人會覺得牠非常可怕，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_024"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥你可要小心囉！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_025"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "還有還有！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你看那邊那戶人家！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n感覺起來就有很恐怖的人住在那裡對吧……！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n而且圍籬也尖尖的！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "唉～",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_026"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你已經忘記禊跟你說過，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n叫你要小心了嗎？",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "聽好囉？",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那戶人家裡……",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "住著會大聲罵人的大叔哦！！",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_027"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "之前禊打算摘那戶人家裡結的柿子時，被他給發現了，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n那時候真的超恐怖的。",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_029"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這裡也要好好畫在地圖上才行。",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可不能讓爸爸遇上可怕的事呢。",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "讓禊想想～",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_030"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可怕的狗就當作是魔物～",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "大叔就當作是～",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "山賊！！",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "然後",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "把道路畫得看起來很危險，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "像是會噴出岩漿～",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "完成了！",
        "unit_id": 100431,
        "voice": "vo_adv_1004011_031"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n嗯嗯，",
        "unit_id": 100431
    },
    {
        "type": "dialogue",
        "name": "禊",
