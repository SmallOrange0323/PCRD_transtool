[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霞逮捕了透過神秘戒指變身的犯人。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n另外擇日後，霞與{player}在約定碰面的地點會合。"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……那麼，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要再重新展開調查囉，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才不會呢！",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我有說過了吧？　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我要將魔法少女封印！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "之前我會變身",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是因為你有危險，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那是非不得已的……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之！",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我要以一個偵探的身分，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "用知識與邏輯來解決事件！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唉呀，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們說話不能太大聲呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你那表情是在問",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為什麼要來餐廳對吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n很遺憾，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們並不是來吃飯的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你還記得之前變身成魔物般姿態的那個人嗎？",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "他之所以可以變身，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "似乎是因為他戴在手上的戒指。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "——解放潛藏的力量。",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聽說就是以這種宣傳句子",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來販賣的魔導具。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在重新調查他在事件前後行動的結果……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n發現那個戒指",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "似乎就是在這裡入手的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "魔導具的交易地點，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也就是這麼一回事呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請你盡量別做出太引人注目的行為喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才剛說完就叫得那麼大聲！？",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "沒事，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "有幹勁是好事。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n那就麻煩你了，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你只是單純在發呆而已吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然存在感的確是變低了……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你聽得到",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我的聲音嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n助手先生？　",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "喂～助手先生～！？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總之。",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n解決這個事件的使命",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就背負在你我身上。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n讓我們來迅速地解決事件吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哦，助手先生，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我雖然說是迅速，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但行動過於焦急的話可不像個偵探喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "其實啊，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我從進入這家店之後，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就一直在觀察周圍的樣子了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n然後……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我發現了可疑的地方。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你很在意嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就讓你見識我的觀察力吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看看我的斜後方",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "店裡角落的桌子。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "別被對方注意到，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "自然地看向對方。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "…………",
        "unit_id": 1111,
        "voice": "vo_adv_1122002_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如何？",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你有注意到什麼特別的地方嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "毫不猶豫就放棄思考啊……",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "坦率是你的優點，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但你好歹也稍微裝作有在思考的樣子",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓我看看吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個男性所坐的位子",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n桌子上",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "放了兩份咖啡與蛋糕的套餐",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "對吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "乍看之下，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "會讓人以為他有其他同伴。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "他在進來這家店的時候，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "並沒有和其他人一起來。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是啊。",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當然也是可以考慮到那個可能性。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n事先約在這家店碰面，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後先替之後要來的人點好餐點，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這樣的可能性。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但若是那樣，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你不認為先幫別人點好熱飲",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n有點欠缺考慮嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "實際上，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "目前也早就看不到咖啡的熱氣了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再加上。",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n他從剛才開始",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就一直低著頭",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一動也不動的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n簡直就像要避開他人的耳目，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "刻意隱藏氣息的感覺。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若是有和他人約碰面，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n應該會頻繁地",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "確認這家店的入口吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也就是說……",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "他在等的是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不認識的對象。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n然後，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "他點的咖啡和蛋糕……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我想就是記號。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "——交易用的",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "記號。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也就是說，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要像那樣等著，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "交易對象就會過來了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "歡迎光臨～！",
        "unit_id": 413,
        "voice": "vo_adv_1122002_028"
    },
    {
        "type": "dialogue",
        "name": "店員",
        "words": "\n請問是一位嗎？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "不是……",
        "unit_id": 1411,
        "voice": "vo_adv_1122002_029"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我和人約好了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哦……",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看來",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "能夠驗證我推理的答案了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "聽好了，助手先生，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_031"
