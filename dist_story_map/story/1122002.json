        "type": "dialogue",
        "name": "霞",
        "words": "\n你似乎記得我的樣子，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但卻好像不記得他呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "做得好，助手先生。",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_068"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你那個若無其事的演技，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "似乎有好好發揮作用呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "黑商",
        "words": "可惡，",
        "unit_id": 1411,
        "voice": "vo_adv_1122002_069"
    },
    {
        "type": "dialogue",
        "name": "黑商",
        "words": "把那東西還來！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那可不行。",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_070"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "給我束手就擒吧——",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "束縛之徑！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "黑商",
        "words": "可、",
        "unit_id": 1411,
        "voice": "vo_adv_1122002_071"
    },
    {
        "type": "dialogue",
        "name": "黑商",
        "words": "可惡……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "黑商",
        "words": "\n不過是區區的偵探……！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_072"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n區區的偵探也很能幹對吧？",
        "unit_id": 101411
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "辛苦你了，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_073"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n能順利逮捕犯人真是太好了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "他之後",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_074"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "將會接受審問。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "得逼他吐出有關魔導具的情報才行呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……呼。",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_075"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，呃……",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_076"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在助手先生看來，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_077"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我今天",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感覺如何？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "！　",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_078"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是這樣嗎？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這次……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看來你不是在說謊呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你、",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_079"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你那表情是什麼意思？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "露出一臉不可思議的表情。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "別看我這樣，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我可是很在意的喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "完全不像個偵探……",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_080"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n什麼的，我不想被人",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這麼認為",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "或許只要是小孩子，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_081"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n都會很憧憬魔法少女……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但對我來說，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_082"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是「名偵探」。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "然後我",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "現在也依然對那點抱持憧憬。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以那個……",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_083"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唯獨這一點",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我是絕不會退讓的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_084"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "能聽到你說我是個很出色的偵探，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n讓我覺得心情舒暢多了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "謝謝，",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_085"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你今天也是一名",
        "unit_id": 101411,
        "voice": "vo_adv_1122002_086"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "很出色的「偵探助手｣喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "解決一個事件的霞，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n又再次確認了自己兒時就對「名偵探」的憧憬。"
    }
]