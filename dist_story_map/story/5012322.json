[
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "為什麼……",
        "unit_id": 11111,
        "voice": "vo_adv_5012322_000"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "為什麼我被打倒了……！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n被妳這樣的人……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "像以前的我，",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n什麼都辦不到的愚者……！！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "正如你所說，",
        "unit_id": 105511,
        "voice": "vo_adv_5012322_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n我只會看著別人，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n但卻是個什麼都不會的愚者……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是，",
        "unit_id": 105511,
        "voice": "vo_adv_5012322_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這麼懦弱的我，卻也有著夥伴守候。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以我",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "現在才站在這裡。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "連這樣的我都做得到，",
        "unit_id": 105511,
        "voice": "vo_adv_5012322_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳一定也可以。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "現在開始也不遲。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n和大家……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還有我一起重新開始吧……！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "我才不認同……",
        "unit_id": 11111,
        "voice": "vo_adv_5012322_004"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "我怎麼可能會認同你們！！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "不要說絕望……",
        "unit_id": 11111,
        "voice": "vo_adv_5012322_005"
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "希望和……",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "世界也是讓人憎恨！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "\n整個世界都",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "哀嘆之女神",
        "words": "永遠的墜落到無盡的黑暗裡吧！",
        "unit_id": 11111
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 105511,
        "voice": "vo_adv_5012322_006"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我不會讓妳這麼做的！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "世界、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "還有妳",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "都會被救贖的……！",
        "unit_id": 105511
    }
]