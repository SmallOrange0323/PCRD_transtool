[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真步和香織還有{player}，\n為了尋找對付吸血鬼的道具而在街道上走著。\n另一方面，這一頭還有另一個人也在街上走著……"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗚嗚……",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "今天的陽光也太強了吧……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就算是妾身，",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣也很難熬呢……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織，那個女孩的樣子怪怪的……",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好像很虛弱耶。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真的呢。在那種地方搖搖晃晃很危險啊──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_003"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "馬上去幫她！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊……那女孩附近有魔物……！",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_004"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯？你想做什麼……",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_005"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂喂……可惡的傢伙！",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n趁人家虛弱的時候偷襲，真是……！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "危險──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "欸……？你，你們是誰！？",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦，原來是你啊！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "出現得正是時候！",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不愧是妾身的眷屬，得好好褒獎！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哎呀呀……",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊嗚，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "又頭暈了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，嗯，這裡就交給你們吧。",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不知名的人啊，就為了妾身而戰吧！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喂喂！別把我當小孩子！沒禮貌！",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這種魔物，只要用妾身的力量根本算不上什麼──！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "小妹妹請先退下吧～！",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這隻魔物就交給咱們對付！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可惡的魔物──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n攻擊小孩是禁止的──！",
        "unit_id": 101711
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "太好了！解決它了──！",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦哦……挺有一套的嘛……！",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呃……",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "太刺眼了，頭昏眼花的……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喂──咿！沒事吧──？",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔嗯……",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_019"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "陽、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "陽光太強烈了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "快被曬死了……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "糟糕了！咱們趕快帶她到樹蔭下吧！",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_020"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好！我去拿冷水來～！",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "她是王子先生認識的女孩對吧。",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n沒事真是太好了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯嗯，感激不盡呢……",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n突然被太陽猛曬，身體還來不及適應吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就是啊。臉色好蒼白呢！",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n真的不必去醫院嗎～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "臉色是天生的啦……！",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "小姐一個人在這種地方很危險耶，",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們送妳到城裡去吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不，沒事了……妾身沒有那麼弱啦。",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "話說，三位是要去哪裡的路上嗎？",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗯。我們正在找『像苦瓜的東西』和",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_029"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n『烏龍麵擀麵棍』啊──！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦，還真有這種找些奇怪東西的人呢。",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_030"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n……到底要做什麼用呢……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "對了。為了感謝各位相助，妾身也一起幫忙找吧。",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咦咦？　",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可是……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n妳可以活動了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不可以勉強自己哦？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "多虧了妳們所以休息了不少，沒問題的。",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "更何況，要是有狀況還有他在呢！",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "{player}，",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_034"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這個女孩很崇拜你呢─",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生果然厲害呢。",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n連這麼小的女孩都喜歡王子先生，連人家都覺得驕傲了♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "另外啊，我知道哪裡有『像苦瓜的東西』哦。",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_036"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咦？妳知道哪裡有嗎──！？",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_037"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……在妾身醒來之前，",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_038"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n覺得好像在密林裡看過野生生長出來的。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但已經是不知道多久以前的事了，現在變成怎樣也不知道……",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "以前的事……既然是醒來之前的話，應該是昨天吧？",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這孩子拐彎子說話的方式很有趣呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "對小孩來說，每天都很長嘛！",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_041"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n一定是昨天也覺得像從前的感覺吧！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就算是這樣，這也是貴重的線索！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "幫大忙了～。真是體貼的小妹妹呢～",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_042"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身也是……畢竟旅行就該有伴！",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_043"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哦哦。忘記自我介紹了。妾身名叫伊莉亞。",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_044"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身是統御黑夜之人，亦是他的主人。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳好呀──！我叫做香織！",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_045"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我是【哞哞自衛隊】公會的成員，守護著蘭德索爾的和平！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "請多指教呢～，四海皆兄弟嘛～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家就是那個【哞哞自衛隊】的公會會長，",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n叫做真步哦～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在雖然住在蘭德索爾，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n但人家也是真步真步王國的公主唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "話說統御黑夜之人這個頭銜也太帥了吧！",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_047"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那我也自稱南國的統治者好了！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "並不是為了耍帥才用這個頭銜啦……",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_048"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "至於，真步真步王國？原來有這個國家啊……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然地圖上沒有，但確實存在哦～",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_049"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "原來如此，也對啦，世界那麼大。",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_050"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "『像苦瓜的東西』在這一帶不是很少見嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是啊～。在這一帶好像吃不太到那種東西～",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_051"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "我也沒有吃過……",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_052"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n似乎有獨特的苦味。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳竟然知道！",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_053"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不過那種苦味和它的形狀是必要的哦─！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔嗯……",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_054"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是要用於特殊的料理嗎……",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也罷。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不管怎麼說，",
        "unit_id": 104412,
        "voice": "vo_adv_5003002_055"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "和３個人比起來，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n４個人能做的事情也比較多吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "請多指教囉。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好像變成熱鬧的旅行了呢。",
        "unit_id": 101011,
        "voice": "vo_adv_5003002_056"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家開開心心出發吧！",
        "unit_id": 101711,
        "voice": "vo_adv_5003002_057"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，真步和香織和伊莉亞，還有{player}\n朝『像苦瓜的東西』生長的密林前進了。"
    }
]