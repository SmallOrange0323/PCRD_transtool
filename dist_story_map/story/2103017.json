[
    {
        "type": "background",
        "background": "500092"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "另一方面，在蘭德索爾宮殿正門口——"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "——喝！",
        "unit_id": 191711,
        "voice": "vo_adv_2103017_000"
    },
    {
        "type": "background",
        "background": "500092"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哎唷唷……！",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊～",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好可怕好可怕……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是的，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣下去有幾條命都不夠呀，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喔！",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……",
        "unit_id": 191711,
        "voice": "vo_adv_2103017_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "講真的，",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓我這麼不想和人交手的情況，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還是第一次發生呀～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n再怎麼說你可是把我的陷阱全靠蠻力拆了個稀巴爛呢～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……\n能摸透我全部的意圖，",
        "unit_id": 191711,
        "voice": "vo_adv_2103017_005"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "見招拆招籌劃出反擊。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n真不愧是「迷宮女王」。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "欸欸，",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你說",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你叫贊恩來著？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我們倆，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "互相不都消耗了不少了嘛～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要不要就",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "當作我們打成平手啊？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "——我拒絕。",
        "unit_id": 191711,
        "voice": "vo_adv_2103017_007"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "我手邊能用的攻勢還未盡。",
        "unit_id": 191711,
        "voice": "vo_adv_2103017_008"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n況且若比毅力，",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "我似乎更勝於妳。",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯，",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是嗎？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯的確啦，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "把戰鬥拖得又臭又長",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不合我的喜好嘛。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "既然這樣的話……",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_010"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "唔……",
        "unit_id": 191711,
        "voice": "vo_adv_2103017_011"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "——那就，",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓我把局勢逆轉一下",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "吧。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "看來並非只是單純的地震呢。",
        "unit_id": 191711,
        "voice": "vo_adv_2103017_013"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "\n",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "是妳的能力嗎？",
        "unit_id": 191711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "呵呵。",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就是這麼一回事。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n儘管準備上稍～",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "微花了一點時間……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但我將你原本的目標，位於王城地下，",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "關著千里真那的前寶物庫……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n也就是那座監牢的位置，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "整個打包移動走囉。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可惜啊，",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就算靠蠻力挖個一下兩下也抵達不了那裡的。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n說穿了，我想你們根本連位置都找不到呢♪",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……",
        "unit_id": 191711,
        "voice": "vo_adv_2103017_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不但得小心不讓真那",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "趁機逃出來，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n還得連同似似花所設下的防範轉移用結界，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "靠著「物件變更」進行替換，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這麼做可折騰死人了呢……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過嘛，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "結果看起來是安全完事了呢。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我事也辦完了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就辛苦你跑這趟囉～♪",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "——喝！",
        "unit_id": 191711,
        "voice": "vo_adv_2103017_020"
    },
    {
        "type": "background",
        "background": "500092"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……",
        "unit_id": 191711,
        "voice": "vo_adv_2103017_021"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "……意圖被看穿了、",
        "unit_id": 191711,
        "voice": "vo_adv_2103017_022"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "嗎？",
        "unit_id": 191711
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……嘿咻。",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "…………",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊～",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是難搞啊……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不只是龍人族的角色外型……",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒想到，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "竟然連奪魂武器都被端出檯面了呀。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然真那沒有被他們搶走……",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但從結果來看，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這把算是他們贏了吧。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n畢竟我們這的情報，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有一半以上被他們試探出來了呀。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……那麼……",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_028"
    },
    {
        "type": "dialogue",
        "name": "萬能人偶們",
        "words": "「嗡——嗡——」",
        "unit_id": 191912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……接下來，",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "得將對方在城中佈下的",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "「眼線」都給毀了才行。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "包括了小型的種類在內，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我想數量可不少才是……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果真那的位置又被他們尋找出來了，",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那可就真賠夫人又折兵了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "萬能人偶們",
        "words": "「嗡——嗡——」……！",
        "unit_id": 191912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嘿～咻。",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_030"
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "萬能人偶們",
        "words": "「嗡——嗡——」……！",
        "unit_id": 191912
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊～",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是夠了。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n到底有多少隻啊？",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看來這邊也很難搞呀……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "希望少年他們那邊，",
        "unit_id": 106811,
        "voice": "vo_adv_2103017_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "平安無事就好……",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n抱歉啦。",
        "unit_id": 106811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n看起來，我大概是沒時間趕過去了……",
        "unit_id": 106811
    },
    {
        "type": "background",
        "background": "500353"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在激戰之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}一行人\n總算是勉強擊退了卡里莎與阿澤爾德兩人。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而……"
    },
    {
        "type": "dialogue",
        "name": "萬能人偶們",
        "words": "「嗡——嗡——」……",
        "unit_id": 191912
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚、",
        "unit_id": 106414,
        "voice": "vo_adv_2103017_033"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗚嗚……！",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "日和、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "可可蘿、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "咲戀、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "綾音、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "胡桃，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n甚至包括{player}在內，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
