    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "也認為他說得沒錯喔。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "\n因為，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "神明並沒有命令妳必須要這麼做。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "祭司大人……",
        "unit_id": 112111,
        "voice": "vo_adv_1121002_033"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我不是很懂，",
        "unit_id": 211,
        "voice": "vo_adv_1121002_034"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "可是我",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "比較喜歡鈴莓姐姐笑嘻嘻地工作的樣子！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "像剛才那樣",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "板著臉的樣子，",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "感覺怪怪的。",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……也許是",
        "unit_id": 112111,
        "voice": "vo_adv_1121002_035"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "因為我滿腦子都在想著不能失敗，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以才沒有辦法確實地做好份內的工作呢。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我之後",
        "unit_id": 112111,
        "voice": "vo_adv_1121002_036"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會像平常那樣子工作的！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n籤的結果",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "再怎麼說都只是一種叮嚀呢。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "謝謝妳。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嘿嘿嘿，",
        "unit_id": 211,
        "voice": "vo_adv_1121002_037"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "不客氣！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對了。",
        "unit_id": 112111,
        "voice": "vo_adv_1121002_038"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "作為回禮，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我再去拿一杯甜酒來。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n等一下喔，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我馬上……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊啊啊啊啊！？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "……沒想到",
        "unit_id": 511,
        "voice": "vo_adv_1121002_039"
    },
    {
        "type": "dialogue",
        "name": "祭司",
        "words": "會被甜酒的瓶子絆倒而引發大雪崩啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊哈哈哈",
        "unit_id": 211,
        "voice": "vo_adv_1121002_040"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "鈴莓姐姐好厲害～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n還是這樣子比較有趣～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對、",
        "unit_id": 112111,
        "voice": "vo_adv_1121002_041"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起～！　",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我馬上收拾～！！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然鈴莓一如往常發揮了冒冒失失的本性，\n但旁邊的人卻露出了笑容幫忙她收拾。"
    }
]