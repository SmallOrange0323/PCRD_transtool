[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "習得加護的數天後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}和可可蘿來到了海邊。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇……！",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不管來多少次，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海洋都是一樣這麼寬廣……！",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無限延伸的海平線，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一望無際的藍天……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就是",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "盛夏的大海。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "以被稱為「星海」的海溝為目標，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起加油吧。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只要是和主人在一起，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下相信",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "必定能夠達成目標的。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……不過，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下似乎有點太著急了。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "太陽公公",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "目前還在我們的頭頂上。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "神秘的景象",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只會在夜晚出現……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在那之前，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們該做什麼呢？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是盯著海浪瞧，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實顯得",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有些無聊了。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對了，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n對於夏天的海灘，您是不是很有經驗了？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以的話，請您",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "告訴在下",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您都做了哪些事情。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在無人島上……？",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "居然選擇到殘酷的環境下度過假期，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下真是佩服主人。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦！",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那真是寶貴的經驗。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能和名人一起度過夏天，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可不是能輕易辦到的事情。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下有聽說過，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "夏天正適合運動。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想必這對您來說是一段非常珍貴的回憶。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還能告訴在下",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其他事情嗎？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人的夏日回憶，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下十分感興趣。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來主人您在海邊，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n體驗過這麼多在下未曾體驗過的事。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "每一件事情都這麼有趣、",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這麼引人入勝。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真不愧是主人。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過……",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無人島比較危險，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而偶像也不可能",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "每次都剛好出現在附近。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果可以的話，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以和在下",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起運動嗎？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "海之家就在附近，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n需要的用具",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "應該有辦法在那裡弄到手。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有什麼",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "進行過這類運動的經驗，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請主人",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不吝指教。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的！",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們就先從這項叫做沙灘棒球的球類運動開始吧。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯……",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "把這顆小小的球",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "扔出去就行了嗎？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該怎麼做才能丟得好呢……？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若一不小心",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "打到主人的話……！",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……！",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n真是威風凜凜的架勢啊……！",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看到您的架勢，連在下這種新手都覺得，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n自己能放心享受這項運動了……！",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這就是在下從未見過的，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人身為沙灘棒球選手的一面……！",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那就",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請主人不吝賜教了，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下會全力投出這顆球！",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喝！",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喔喔！",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "球竟然飛得那麼遠……！",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下記得這種時候……",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n通常會有人大聲稱讚打者。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "打得漂亮，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對了，主人，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說您之前透過沙灘棒球，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n遇見了無可取代的隊友，是嗎……？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "認真投入運動，雖然和冒險不太相同，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但也有其獨特的美妙之處呢。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "相信",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在和那些隊友",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "切磋琢磨的過程中，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人您的",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "肉體和精神",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都有了不少成長。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "多虧了主人的經驗，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也能享受到這門運動，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的很感謝",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的隊友們。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107612,
        "voice": "vo_adv_1076006_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您還體驗過",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其他海邊的運動嗎？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喝……",
        "unit_id": 107612,
