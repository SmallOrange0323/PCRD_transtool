[
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "莫妮卡跟梅杜莎在新年熱鬧的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n蘭德索爾鬧區散步著。"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "這裡也有蛇，",
        "unit_id": 133611,
        "voice": "vo_adv_5160611_000"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "那裡也有蛇。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "伴手禮店也有蛇。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n城鎮裡裝飾了很多以蛇為主題的東西呢！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "大家居然從新年就祭祀著蛇，",
        "unit_id": 133611,
        "voice": "vo_adv_5160611_001"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n看來這個國家",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "有好好理解蛇有多偉大呢。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……抱歉在妳感動時潑冷水，",
        "unit_id": 133212,
        "voice": "vo_adv_5160611_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n那只是因為",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "今年的生肖",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是蛇的關係喔。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "明年之後",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會裝飾著不同的動物。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "咦？",
        "unit_id": 133611,
        "voice": "vo_adv_5160611_003"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "那是為什麼啊？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "──原來如此，",
        "unit_id": 133611,
        "voice": "vo_adv_5160611_004"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "在神明大人舉辦的比賽中勝出的12隻動物，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n輪流被祭祀一年嗎。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "那是個挺有趣的故事呢。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "但是，",
        "unit_id": 133611,
        "voice": "vo_adv_5160611_005"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "只有一點我沒辦法接受。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼了，",
        "unit_id": 133212,
        "voice": "vo_adv_5160611_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有哪裡讓妳不滿了？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "為什麼蛇不是第一名啊！",
        "unit_id": 133611,
        "voice": "vo_adv_5160611_007"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n而且撇開蛇拿到第一名的",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "居然是老鼠？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "老鼠",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "不就只是蛇的食物嗎！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我不能接受呢。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不是，",
        "unit_id": 133212,
        "voice": "vo_adv_5160611_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就算妳跟我抱怨故事的內容……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "這種東西",
        "unit_id": 133611,
        "voice": "vo_adv_5160611_009"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "是要去哪裡抗議才可以啊？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我要好好告訴對方蛇的偉大，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "讓大家每年都祭祀蛇啊！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳先冷靜下來。",
        "unit_id": 133212,
        "voice": "vo_adv_5160611_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……聽好了，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那場比賽是在",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "寒冷的季節舉行的，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也就是說，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對蛇來說",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "條件非常嚴峻。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "牠會落後別人也是沒辦法的事吧。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就算有那種不利的條件，",
        "unit_id": 133212,
        "voice": "vo_adv_5160611_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n牠依然超過眾多的動物們，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "進到了十二生肖裡面了。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就算不是第一名，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "應該也充分地傳達蛇有多厲害了啊。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且，",
        "unit_id": 133212,
        "voice": "vo_adv_5160611_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "比起每年都出現，",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "12年出現一次",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n稀有度比較高。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "更能讓人感受到牠的價值不是嗎？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "……",
        "unit_id": 133611,
        "voice": "vo_adv_5160611_013"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "確實。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "正如妳所說呢。",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "哼哼，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "蛇果然很厲害呢！",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼，",
        "unit_id": 133212,
        "voice": "vo_adv_5160611_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "似乎總算讓她接受了呢……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我說，",
        "unit_id": 133611,
        "voice": "vo_adv_5160611_015"
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "我現在注意到了，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "蛇跟龍角色是不是重複了？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "只要出現其中一個，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "應該說",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "只要出現蛇就好了吧？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "\n妳覺得如何啊，",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "梅杜莎",
        "words": "莫妮卡？",
        "unit_id": 133611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊──真是的！",
        "unit_id": 133212,
        "voice": "vo_adv_5160611_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳真讓人傷腦筋呢！　",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "梅杜莎投下新的火種讓莫妮卡抱頭苦惱。"
    }
]