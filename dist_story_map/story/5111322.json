[
    {
        "type": "dialogue",
        "name": "望",
        "words": "呀啊！",
        "unit_id": 124811,
        "voice": "vo_adv_5111322_000"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "望！",
        "unit_id": 124911,
        "voice": "vo_adv_5111322_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什麼……",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "這些傢伙是！",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是",
        "unit_id": 125011,
        "voice": "vo_adv_5111322_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我們嗎……！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哦，",
        "unit_id": 106211,
        "voice": "vo_adv_5111322_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "想用冒牌貨這種無聊的手段來動搖心理啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好啊，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那就由我來──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "謝謝你替我們操心，",
        "unit_id": 124911,
        "voice": "vo_adv_5111322_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不過，這場面不需要你出手。",
        "unit_id": 124911
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "嘉夜說得沒錯，",
        "unit_id": 124811,
        "voice": "vo_adv_5111322_005"
    },
    {
        "type": "dialogue",
        "name": "望",
        "words": "我們要靠自己做個了斷。",
        "unit_id": 124811
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就是這樣，",
        "unit_id": 125011,
        "voice": "vo_adv_5111322_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你就在旁邊看吧！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "區區冒牌貨，我們馬上就能解決！",
        "unit_id": 125011
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……唉呀，",
        "unit_id": 106211,
        "voice": "vo_adv_5111322_007"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "真是可靠呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "那麼，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我就先休息一下了，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳們加油喔～",
        "unit_id": 106211
    }
]