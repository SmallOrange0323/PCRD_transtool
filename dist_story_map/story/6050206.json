    {
        "type": "dialogue",
        "name": "怜",
        "words": "虛幻的女幽靈……",
        "unit_id": 114011,
        "voice": "vo_adv_6050206_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希為什麼要我扮成那樣……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我覺得再更好戰一點的幽靈比較適合我啊。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "虛幻……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "果然還是不太懂啊。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "舉例來說，",
        "unit_id": 114011,
        "voice": "vo_adv_6050206_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "像是迅速地踏著步伐將獵物逼上絕路……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "與其說是幽靈更像是妖怪？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果是那種我就……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "算了，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那不太適合鬼屋吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果有你這樣的人在，",
        "unit_id": 114011,
        "voice": "vo_adv_6050206_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也就不會變成幽靈了吧。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這麼說來，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那可憐的女性就是……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣想的話就好了吧？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我好像稍微抓到一點感覺了呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "被你這樣講，",
        "unit_id": 114011,
        "voice": "vo_adv_6050206_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也沒什麼能說的了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可是",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "茉莉的不就是很符合她個性的衣服嗎？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n既然如此，我也……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "算了，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這次還是",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "替紡希實現願望吧。",
        "unit_id": 114011
    }
]