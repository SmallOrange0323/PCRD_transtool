    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "……不好意思，",
        "unit_id": 104011,
        "voice": "vo_adv_5084637_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "如果不逞強，我就覺得好寂寞，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以才說了無稽之談……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你不在，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我就不可能擺脫邊緣人了吧。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "哈哈哈……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "因為BB團",
        "unit_id": 104011,
        "voice": "vo_adv_5084637_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是我們兩人創立的呀。",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "想和你一起去交朋友……",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "所以，",
        "unit_id": 104011,
        "voice": "vo_adv_5084637_003"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "為了能在你醒來的那天擺脫邊緣人，",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n我會每天想出1000個",
        "unit_id": 104011
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "交朋友的練習方法，等著你醒來的……！",
        "unit_id": 104011
    }
