    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "──你是……",
        "unit_id": 129631,
        "voice": "vo_adv_4010165_000"
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n今天也有",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "清掃環境的工作嗎。",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "姑且說一聲──",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "辛苦了。",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "──不是工作，",
        "unit_id": 129631,
        "voice": "vo_adv_4010165_001"
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "是有事",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "找我？",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "我不太理解……",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "你",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "只是",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "工讀生對吧，",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n找只見過幾次面的",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "患者，",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "有什麼事──",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "……………………",
        "unit_id": 129631,
        "voice": "vo_adv_4010165_002"
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "──不好意思。",
        "unit_id": 129631,
        "voice": "vo_adv_4010165_003"
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "實在是──",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "遠遠超出我的預料外。",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n而且……",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "我被嚇到了。",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "嚇得不輕。",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "──因為，",
        "unit_id": 129631,
        "voice": "vo_adv_4010165_004"
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "那是患者的",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "個人情報",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "對吧。",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n你竟然會知道──",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "太奇怪了。",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n隱私權、",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "還有法規上的問題──",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "唉──",
        "unit_id": 129631,
        "voice": "vo_adv_4010165_005"
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "嗯，",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "算了。",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "你是個",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "脫離常識的人這點，",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n我已經",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "十分──",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "清楚了。",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "──反正，",
        "unit_id": 129631,
        "voice": "vo_adv_4010165_006"
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "那個你所謂的",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "慶祝……",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n就算我說不需要，",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "你也會",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "勉強推給我吧。",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "………………",
        "unit_id": 129631,
        "voice": "vo_adv_4010165_007"
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n──",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "那麼──",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "──請再，",
        "unit_id": 129631,
        "voice": "vo_adv_4010165_008"
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "說給我聽。",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "\n你所體驗的──",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "在遊戲中的，",
        "unit_id": 129631
    },
    {
        "type": "dialogue",
        "name": "牡丹",
        "words": "冒險故事。",
        "unit_id": 129631
    }
]