[
    {
        "type": "background",
        "background": "502330"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……我有點事要拜託你。",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_000"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "喂，",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n聽從別人的請求前，要先聽完內容再說喔？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是我是騙子怎麼辦？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……算了，",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "要你懷疑別人很勉強吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "協助你那方面也是我的職責嘛。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以……",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那個……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我要拜託你。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你可以──",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "稍微讓我碰一下嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以就叫你稍微考慮一下了……",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "算了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我會做出這種請求",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是有原因的。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你想，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不是",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "一直都只是看著你嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以前……",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我是菲歐的時候，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n雖然也可以輕易碰觸你。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但我會忍不住想著，",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以這個模樣來做那件事",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "會怎麼樣。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以，",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就覺得要不",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "先像這樣，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n以拜託的形式來習慣吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有自覺你變成了說「可以喔」的機械嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真是的。",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_011"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "既然也得到許可了，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那我就稍微失禮一下喔。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……首先是",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_012"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "手臂。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "肌肉挺發達的呢。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也對啊，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "畢竟你有確實",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在做劍的訓練之類的",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嘛。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接著是……",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_013"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "腿。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "呵呵，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很緊實嘛。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n畢竟",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你這雙腳總在迷路，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓人很困擾呢。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "肚子……",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_014"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哦，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "原來變成這樣了啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嘿～",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "戳戳。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑的啦。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "胸……",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_015"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "以後有機會再說。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n並不是",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為我害羞喔？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "最後是",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_016"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "臉……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嗯。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n是我很熟悉的臉。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n用兩手摸的話……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是這種感覺啊。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "…………",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_017"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "啊！",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_018"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不小心",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "忘我了，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉喔。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是因為我的體型不同嗎？",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_019"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n總覺得",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好不可思議。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "在碰之前取得許可是正確答案呢。",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_020"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是像以前一樣不客氣地觸碰，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我可能也成為變態可疑分子的同夥了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我姑且",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_021"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "先叮嚀你喔，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是有",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "其他的誰拜託你這種事，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n可不能二話不說就說可以喔？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "該說你是毫無防備",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_022"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還是警戒心不夠呢？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n因為你感覺不管對誰都很信任。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "！",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……",
        "unit_id": 131711,
        "voice": "vo_adv_5150070_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "可以喔……",
        "unit_id": 131711
    }
]