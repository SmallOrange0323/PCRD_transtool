        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "話說，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "把我那副模樣放到英雄奇談裡實在太丟臉了，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n拜託別說了……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "啊，",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "不過",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "這般丟臉的感覺好像也不錯……！？",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "鎮民1",
        "words": "果然還是",
        "unit_id": 1,
        "voice": "vo_adv_5015007_039"
    },
    {
        "type": "dialogue",
        "name": "鎮民1",
        "words": "應該要製作將軍的周邊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鎮民1",
        "words": "\n總之，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鎮民1",
        "words": "先做將軍饅頭吧！",
