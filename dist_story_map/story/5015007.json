[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "打倒了惡代官後，\n大家在公會小屋渡過了和平常一樣的時光，\n此時【純白之翼 蘭德索爾分部】收到了一封信。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "各位，",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這封信上的內容，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是大江戶町給我們的邀請函。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n因為想要再次向各位道謝，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "希望各位務必再來遊玩。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是邀請函嗎！？",
        "unit_id": 103011,
        "voice": "vo_adv_5015007_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n那就是說，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們還能",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "再去大江戶町囉！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "事情就是這樣呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來如此，",
        "unit_id": 100811,
        "voice": "vo_adv_5015007_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "他們想要看到美麗的我，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還送了邀請函來啊。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n才一下子",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我竟然就奪走了城鎮上居民的心，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我偶爾也會",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "對自己的美貌感到害怕呢……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不，",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我想不是那樣的……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "打倒惡代官之後，",
        "unit_id": 105511,
        "voice": "vo_adv_5015007_005"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n大江戶町",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "變成怎樣了呢。",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "關於那個，",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這張邀請函上寫了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n惡代官死後，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "與它共謀的王宮成員也遭逮捕，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n從那之後",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "城鎮好像就恢復了原本的和平。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不需要繳交上納金給惡代官後，",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_007"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也不會有像之前那樣的強行推銷了吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "既然如此，",
        "unit_id": 103011,
        "voice": "vo_adv_5015007_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們就去看看吧！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "應該已經恢復成",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "原本開心的大江戶町了！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我開玩笑的……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "――也是，",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不如就玩個過癮吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦……！？",
        "unit_id": 100811,
        "voice": "vo_adv_5015007_010"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可、",
        "unit_id": 104511,
        "voice": "vo_adv_5015007_011"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "可以嗎……！？",
        "unit_id": 104511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我、",
        "unit_id": 103011,
        "voice": "vo_adv_5015007_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我只是",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "抱著輕鬆的心情\n想說看看而已，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒想到竟然OK……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個……",
        "unit_id": 105511,
        "voice": "vo_adv_5015007_013"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "莫妮卡，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳該不會是",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "吃了剛才\n我買的鯛魚燒",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "吃太飽了，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n然後有點",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "呆滯了吧……？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你、",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你們那是什麼反應啊！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我說了什麼很奇怪的話嗎？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那是……",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_015"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是沒錯啦。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……那樣說",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好像我平常都很不溫柔一樣。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "今次的事件",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_017"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "大家真的都辛苦了呢。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "偶爾",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這樣也不錯吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且那個……",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這次的事件",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n感覺讓夥伴之間的羈絆更堅固了呢……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "感到很開心……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "莫妮卡……",
        "unit_id": 105511,
        "voice": "vo_adv_5015007_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好、",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好了，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就別說這些了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "比起那個，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們前往大江戶町吧！",
        "unit_id": 105311
    },
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "每、",
        "unit_id": 109511,
        "voice": "vo_adv_5015007_021"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "每次來都覺得街上好美……",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n真的是很棒的地方呢。",
        "unit_id": 109511
    },
    {
        "type": "dialogue",
        "name": "鎮民1",
        "words": "喂！",
        "unit_id": 1,
        "voice": "vo_adv_5015007_022"
    },
    {
        "type": "dialogue",
        "name": "鎮民1",
        "words": "\n看那個！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "鎮民2",
        "words": "那些人該不會……！！",
        "unit_id": 1,
        "voice": "vo_adv_5015007_023"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎、",
        "unit_id": 105511,
        "voice": "vo_adv_5015007_024"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎麼回事啊？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "民眾的目光",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好像都集中在這裡……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "竟然這樣子盯著我看，",
        "unit_id": 100811,
        "voice": "vo_adv_5015007_025"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n果然我的美貌",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不管在哪裡都會引人注目呢……！",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "歡迎光臨，",
        "unit_id": 2511,
        "voice": "vo_adv_5015007_026"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "將軍一行人！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊，",
        "unit_id": 109611,
        "voice": "vo_adv_5015007_027"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "是町長！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "謝謝您接受我的邀請……",
        "unit_id": 2511,
        "voice": "vo_adv_5015007_028"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "還有更重要的是",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "謝謝您救了這個町，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "真的是太感激您了！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "……事不宜遲，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "請您看看這個，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "這是我們感激的證明！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "那是……",
        "unit_id": 109611,
        "voice": "vo_adv_5015007_029"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍的人像！",
        "unit_id": 109611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "真的耶……",
        "unit_id": 105511,
        "voice": "vo_adv_5015007_030"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我有點",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "想要呢……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "這是我們感激的證明，",
        "unit_id": 2511,
        "voice": "vo_adv_5015007_031"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "特地請專家製作出來的！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n其他還有",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "讚頌將軍一行人",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "活躍表現的英雄奇談，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "就讓我來說給大家聽！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咦，",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_032"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "英雄奇談！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n還有那種東西嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "那麼，",
        "unit_id": 2511,
        "voice": "vo_adv_5015007_033"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "就從事件的起源開始。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n在平日壞事做盡的",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "惡代官面前，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n將軍大人英勇的出現。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "從、",
        "unit_id": 100811,
        "voice": "vo_adv_5015007_034"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "從一開始感覺就不太一樣……",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "將軍大人帶領著一群",
        "unit_id": 2511,
        "voice": "vo_adv_5015007_035"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "毫不遜色於他的英雄們。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "一開始，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "在惡代官和莫妮卡大人小試身手時，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "天空驟裂，閃光一現――",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喂、",
        "unit_id": 105311,
        "voice": "vo_adv_5015007_036"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喂，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你會不會加油添醋的太過火了！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我最初的一擊被擋下了啊，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "小試身手時天空驟裂，閃光一現什麼的，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我到底什麼時候能夠放出閃光了啊！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "身著有如天女羽衣般",
        "unit_id": 2511,
        "voice": "vo_adv_5015007_037"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "美麗衣裳的空花大人……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "毫不屈服於暴虐無道的",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "惡代官的卑劣攻擊……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我、我我、",
        "unit_id": 109511,
        "voice": "vo_adv_5015007_038"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "我才沒有做那麼厲害的事……！",
        "unit_id": 109511
    },
