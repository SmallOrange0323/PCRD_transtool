[
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呼、",
        "unit_id": 100911,
        "voice": "vo_adv_9073155_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呼……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n總、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "總算是跑掉了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是啊……",
        "unit_id": 103111,
        "voice": "vo_adv_9073155_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這附近，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "看起來似乎沒有殭屍群。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n初音短時間內應該也醒不過來，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "稍微休息一下好了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "本以為掉進了凍結地獄，",
        "unit_id": 100911,
        "voice": "vo_adv_9073155_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "結果卻是活屍橫行的泥濘之地……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "適合我的",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "耽美黑暗幻想譚到底在哪裡！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "全是些腐敗，",
        "unit_id": 2411,
        "voice": "vo_adv_9073155_003"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "或只剩骨頭的傢伙們還真是無聊。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n要是沒多長點肉，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不就不能享受胸部跟屁股了嗎！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 103111,
        "voice": "vo_adv_9073155_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你要是再說奇怪的話",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我就把你埋在這裡哦。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "比起這個，來吧，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "來幫一下這邊。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "忍妳在做什麼？",
        "unit_id": 100911,
        "voice": "vo_adv_9073155_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n那個莫非是，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "占卜的道具？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的，",
        "unit_id": 103111,
        "voice": "vo_adv_9073155_006"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "用占卜尋找來到這個世界……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n吉歐‧尼布爾黑爾",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "的大家的位置。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "應該會比毫無線索地尋找還要來得好一點。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哦哦，",
        "unit_id": 100911,
        "voice": "vo_adv_9073155_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不愧是忍！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "雖然我也能感覺到與吉格魯特之間靈魂的共鳴，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但如果有忍的占卜",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "肯定能更確定。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "拜託妳了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "…………",
        "unit_id": 103111,
        "voice": "vo_adv_9073155_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這、",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是……！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "如何？",
        "unit_id": 100911,
        "voice": "vo_adv_9073155_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "找到了嗎？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不是，",
        "unit_id": 103111,
        "voice": "vo_adv_9073155_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "並沒有找到……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但占卜顯示出會有很大的災難降臨。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那、",
        "unit_id": 100911,
        "voice": "vo_adv_9073155_011"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那是……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "什麼時候？在哪邊？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "現在，",
        "unit_id": 103111,
        "voice": "vo_adv_9073155_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就在……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這裡。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "意思是要離開這裡嗎？",
        "unit_id": 2411,
        "voice": "vo_adv_9073155_013"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "別開玩笑了！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n這不是要我們再去給殭屍群追著跑嗎！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……我說，",
        "unit_id": 100911,
        "voice": "vo_adv_9073155_014"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "忍。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我突然發現……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "剛剛明明有那麼多的殭屍",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "卻只有這裡沒有，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "難道說……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "很、",
        "unit_id": 103111,
        "voice": "vo_adv_9073155_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "很有可能呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "莫非這個地方，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "有比殭屍還要危險的東西存在……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "出現啦────！！！",
        "unit_id": 2411,
        "voice": "vo_adv_9073155_016"
    }
]