[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過",
        "unit_id": 111711,
        "voice": "vo_adv_6029302_000"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "聖誕老人啊。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n到底為什麼要分送禮物給大家呢？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "身為統治者的妾身",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是被進貢的一方，所以不是很懂～",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "因為希望大家開心，",
        "unit_id": 111711,
        "voice": "vo_adv_6029302_001"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "所以付出不求回報",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "啊。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "身為統治者，妾身必須要理解",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "世間也有這樣的價值觀呢。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "要了解這個，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "最好的方法就是實際去體驗！　",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "好～",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "我們來去分送禮物吧！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你窸窸窣窣地在做什麼？　",
        "unit_id": 111711,
        "voice": "vo_adv_6029302_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯……",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你要送禮物給妾身？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這是",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雪人嗎？　",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雖然小小一個，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但是好可愛喔。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n……你說是因為想看到妾身開心的笑容，",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是嗎？",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身明白的！",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "吾之眷屬啊。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你失去了記憶，所以不知道也是理所當然。",
        "unit_id": 111711,
        "voice": "vo_adv_6029302_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯～",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "越想越搞不懂。",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 111711
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "聖誕老人到底是……？",
        "unit_id": 111711
    }
]