    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "正月はどんな風に過ごすのかって？",
        "unit_id": 114711,
        "voice": "vo_adv_6056404_000"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "アタシは今まで、",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "あんまり正月って気にしてなかったからな……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "そんなに楽しいものなのか？　",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "なんかやることあるのか？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "おせちって食べ物だったのか！？",
        "unit_id": 114711,
        "voice": "vo_adv_6056404_001"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "正月だけの特別な物を食べられるのは、",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "確かに楽しいかもな。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "そんなにうまいならアタシも食べてみたいぞ！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "お参りぃ？　",
        "unit_id": 114711,
        "voice": "vo_adv_6056404_002"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "……お金を投げて、",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "神様にお願いごとをするのか？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "それで願いが叶うなんて思えないけどな……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "どんなことをするのかは気になるぞ。",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "今度アタシも連れてってくれよな！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "羽子板？　",
        "unit_id": 114711,
        "voice": "vo_adv_6056404_003"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "なんだっけ……",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "板で玉みたいなのを打つやつか？",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ああ、",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "やっぱりそれだ！　",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "それならアタシでも楽しめそうだな！",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ボッコボコにしてやるから、",
        "unit_id": 114711
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "早く遊びに行くぞ！",
        "unit_id": 114711
    }
]