[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了要完成統一天下的目標，\n妮諾與{player}在城鎮外進行忍法的開發。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將軍，我要上囉！",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_000"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我現在要來試試新忍法・滋文字斬是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n請仔細看！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "欸？不是十文字斬。",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_001"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n是滋文字斬喔？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "說完之後妮諾便站到了燒燙的鐵板前。\n在她手上還拿著大碗，裡頭的麵粉已加水攪拌均勻。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哦呀！",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_002"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我要做文字燒囉――！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n在這裡一口氣、",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將餡料",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "倒入是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "滋～！文字燒……滋文字……",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯，好香的味道是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "哈，就是現在！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我要切開來了是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊ー！邊緣坍掉了～！",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_004"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯嗯嗯……",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "失敗了是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "沒想到滋文字斬竟然如此之深奧……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "難道說，我應該要",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_006"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n先完成忍法・醋昆布地獄才是嗎……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就在此時，有幾位小孩站到了妮諾面前。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗯？你們怎麼了是也？",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_007"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你們是小忍者嗎？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "喂喂！你們是得到了誰的許可，",
        "unit_id": 1,
        "voice": "vo_adv_1030002_008"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n居然敢到這裡來訓練！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "這裡是屬於我們菲尼克斯家族的地盤！",
        "unit_id": 1,
        "voice": "vo_adv_1030002_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "啊哇哇……",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n看來，這裡好像是孩子們的遊玩場所是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "等、",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "等等，請等一下是也……！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "妮諾制止了{player}，並且飛快地往前踏出一步。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你們這些家臣，還不住手？",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_012"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "肅靜、肅靜！",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你們可知道站在這裡的這位大人是誰嗎！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "誠惶誠恐，這位可是天下的將軍大人是也！！",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n登登登登！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "將軍……？",
        "unit_id": 1,
        "voice": "vo_adv_1030002_015"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n那是什麼？好遜～我才不認識呢～",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗚……將軍的威信竟然沒有效……",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_016"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n看來他們是忍法・不拘禮數的使用者是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "將、將軍！",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_017"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "讓他們看看將軍的力量吧！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "什、什麼啊……！",
        "unit_id": 1,
        "voice": "vo_adv_1030002_018"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n你們竟然想認真地跟小孩子計較啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "對、對啊……！你們若打我們的話……我們會哭喔！",
        "unit_id": 1,
        "voice": "vo_adv_1030002_019"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n我、我們會去跟媽媽說喔！",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "103000201"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "嗚哇～將軍好厲害～！將軍最棒了！",
        "unit_id": 1,
        "voice": "vo_adv_1030002_020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "小孩們的手上都拿著各式各樣的點心。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "呵呵呵……見識到將軍的厲害之處了嗎？",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_021"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "不愧是將軍，讓我刮目相看是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n這可是忍法・收買之術是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "啊啊，冰淇淋真好吃～！",
        "unit_id": 1,
        "voice": "vo_adv_1030002_022"
    },
    {
        "type": "dialogue",
        "name": "小孩２",
        "words": "\n那麼今天就先原諒你們囉！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "再見啦～下次再一起玩啊～！",
        "unit_id": 1,
        "voice": "vo_adv_1030002_023"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n妮諾姐姐跟有錢的將軍！",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "再見啦小忍者們！",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_024"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "希望你們不會遇到突擊，小心回家是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "嗚呼呼，看他們現在的樣子，還真是率直又可愛的小孩們呢！",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_025"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你怎麼了呢？將軍，",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_026"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n不可以嘆氣是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "你是在煩惱忍法開發沒有任何進展嗎？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "請將軍不要露出那種表情。",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_027"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "在今天的領土爭奪之戰裡，我們可是取得了城鎮外圍。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "我們朝著統一天下的目標邁進了一大步是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "妮諾看著{player}的臉露出了溫柔的微笑。"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所以呢，請將軍不要再嘆氣了！",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_028"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n我會一直追隨在將軍身旁的！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "只要笑口常開，福氣就會來到我們身邊是也～！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "……欸？",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_029"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n因為將軍把錢花掉了，所以今天晚餐要少一道菜，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n嗎……？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "這是為了統一天下……？",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_030"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "雖、雖然這麼說也沒錯是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "可是那件事跟這件事……不該混為一談是也……",
        "unit_id": 103011,
        "voice": "vo_adv_1030002_031"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "所謂的武士道，就是要尋找忍辱負重的目標是也……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "妮諾一邊嘆著氣，\n一邊沮喪地垂著肩膀踏上歸途。"
    }
]