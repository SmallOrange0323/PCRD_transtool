[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某天，{player}在蘭德索爾郊外，\n發現了把許多貓聚在一處的珠希。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊！",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "上次真是謝謝你喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你問我在做什麼……？",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這當然是在餵貓啦喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這附近的貓，",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n全部都是我在照顧喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "欸嘿！",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你很驚訝嗎喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，若要照顧這麼多貓，",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n飼料的費用實在是不少呢喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "也許你會覺得我很小氣，",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但我需要賺取這些孩子們的飼料費，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n並非是單純的小氣鬼喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為貓很可愛，我最喜歡了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "當然喵！ 最喜歡了喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可愛到讓人招架不住喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而且，養貓的話，牠們會派上用場的喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你問我會派上什麼用場？",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是祕密喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "小貓",
        "words": "喵―。",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你怎麼了喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈，你想要我摸你嗎喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣的話，我不得不回應你的要求喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你瞧瞧，摸肚子好嗎喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "摸喉嚨好嗎喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "直到你滿足為止，我會一直撫摸你的喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n咕嚕咕嚕咕嚕―♪",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈。",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總覺得這隻小貓很像你喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我還沒幫牠取名字，",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就取和你一樣的名字吧喵―。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我已經決定了喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不管你怎麼抱怨，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這隻小貓的名字就是要跟你一樣的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "小貓",
        "words": "喵―。",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈，",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這孩子似乎也很喜歡這個名字喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯，",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你不能那麼舔我喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真是好色的孩子喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我不是在說你，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n所以不要有那種微妙的表情喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喂，",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你也跟我一起和貓玩吧喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一週後――"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊…",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "…",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有一隻我很疼愛的貓不見了喵……",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就是取了跟你相同名字的那隻小貓喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為還是小貓，牠一定正為了沒有食物吃而為難著呢喵……",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "牠到底去哪裡了喵……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……你要幫我嗎喵……？",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……謝謝你的安慰喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你要去哪裡喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你說去找找看……",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難道，你要幫我嗎喵？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……真的嗎喵？",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": " 謝謝喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我們快點去找吧喵！",
        "unit_id": 104611
    },
    {
        "type": "background",
        "background": "500012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你在哪裡喵―",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "如果你在的話，就回答我一下喵―！",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不行啦喵……果然還是找不到喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_031"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這麼晚了還找不到，也就是說可能……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你叫我不要放棄……？",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_032"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……我又被安慰了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "對喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_033"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n牠才不見一天而已喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我絕對會找到牠的喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你如果聽到我的聲音，就回答我一下喵―！",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_034"
    },
    {
        "type": "dialogue",
        "name": "小貓",
        "words": "喵―。",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這個叫聲是……",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_035"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是從哪裡傳來的喵！？",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "小貓",
        "words": "喵―。",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊！",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_036"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n找到了，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "在這家的屋頂上喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "牠一定是爬的太高，",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_037"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n沒辦法下來喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "等等我喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_038"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我現在就去救你喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "小貓",
        "words": "喵―，喵―。",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯―，好孩子好孩子喵。不能再迷路喔喵。",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_039"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "顫抖成這樣……",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_040"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我會在你身邊，所以你可以安心了喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "謝謝你今天幫我找小貓喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_041"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "果然你也有像貓一樣可愛的地方喵！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "作為謝禮，下次賣什麼給你時會給些優惠的喵",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_042"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "！",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你說結果是優惠啊？ ",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_043"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯―……",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒有發生什麼大事的話，",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n可是無法獲得我無償的愛的喵。",
        "unit_id": 104611
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為我是任性的貓嘛喵！",
        "unit_id": 104611,
        "voice": "vo_adv_1046002_044"
    },
    {
        "type": "dialogue",
        "name": "珠希",
