[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在盯上霸瞳皇帝的【憤怒‧軍團】發動襲擊的數天後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拉比林斯達在蘭德索爾的可麗餅店賣力工作。"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "痛痛痛……",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看來要回到原本的狀態還差得遠呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那個好像叫贊恩的，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_001"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "竟然使出這麼危險的攻擊……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我就再安分個幾天吧……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哦，那個是……",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_002"
    },
    {
        "type": "still",
        "still": "106800201"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗨，少年！",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉這麼突然叫住你，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n要不要",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在來吃個可麗餅？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很突然嗎？",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "算了，無所謂。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "特別招待你！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……嗯，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你和之前見面的時候一樣呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n看來你也不會再變得像個小嬰兒那樣了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是喔，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那就太好了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你能有精神那就是最好的了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "話說回來，少年！",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_007"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我都已經回來這裡了，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n今後也會",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "再從頭開始努力經營可麗餅店的！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為此，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也讓璃乃和靜流她們幫了我忙，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我在此宣言，這個用來掩人耳目的假身分，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "將變成我的正職！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你也帶貪吃佩可和優衣",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_009"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "她們大家一起來吃吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我會給你們優惠的♪",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……嗯？",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_010"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "怎麼了？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有什麼在意的事嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n啊啊，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是價格嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "咦……？",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_011"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不對不對！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不對不對不對！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這件事和那件事",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是兩碼子事啊！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這間可麗餅店",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "之前因為沒有店長而前途黯淡，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n可是成了這個世界的損失啊！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且做可麗餅，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_013"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對我來說",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是個應盡的義務！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這可是",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了世界呢！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……咦？",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你還在懷疑我？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n真奇怪呢～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我可是非常認真耶。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唉呀，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_015"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年你真的不懂耶〜！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n透過飲食",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "獲得的營養自然重要，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但有時，能否讓心靈獲得滿足也很重要啊！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年你",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_016"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在與真那戰鬥而身心疲憊的時候，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n也會想吃點好吃的東西對吧？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那是因為",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_017"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "比起身體",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "心靈更重要！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n身體為了使心靈安定，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而在尋求好吃的東西啊！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_018"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "希望能做出使大家",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "心靈平靜的食物……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我想用可麗餅，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "來療癒被囚禁在這個世界",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "人們的心靈！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能行的！",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_019"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "別看我這樣，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我在那邊世界的正職可是醫師。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n說到治療，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不如說是我的擅長領域喔。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊～",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_020"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你那眼神是不相信我吧！？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我看得出來喔，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真難過……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我還以為如果是少年你，就能懂我的說……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_021"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在讓你懂之前，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是不會放棄的！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n好了，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你先吃吃看那個可麗餅吧！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼一來，你一定……",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_022"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不對，是絕對，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n就能了解我想做的事情才對！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這一口",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是那第一步！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我相信你喔，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_023"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年……！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……味道感覺如何？",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_024"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯嗯！",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_025"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然後呢？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真正的感想是什麼？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是……",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_026"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喔……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我的研究還不夠啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "分我吃一口。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "啊唔……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嗯，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這的確",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "離最棒的味道",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還差得很遠呢……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒錯，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_027"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我今後要挑戰的，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是世界上最",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "棒的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "滋味……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是那種，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "美味得只要吃過後就會改變對世界的觀點，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我希望讓大家",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "品嚐到那種可麗餅！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我啊，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_028"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是個天才所以學什麼都馬上能做好。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n可麗餅呢，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是我普通地憧憬著，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "能讓我實現普通的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n唯一一件事。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然而，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_029"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在事態不一樣了，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n今後我必須以最棒為目標才行。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真是諷刺，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_030"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一旦想把可麗餅做好吃，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就反而辦不到呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n所以，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我每天都在和挑選材料",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有麵糊的煎烤程度",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "認真搏鬥中……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "換句話說，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_031"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這對我而言",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "又是一場戰鬥！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我要用最棒的可麗餅，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "給大家最棒的治療！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n為此，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我必須要有人反覆來幫我試吃！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_032"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年你不會對有困難的人棄之不顧吧，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_033"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我相信你喔！",
        "unit_id": 106812
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "不好意思。",
        "unit_id": 1211,
        "voice": "vo_adv_1068002_034"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "歡迎光臨！",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_035"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你等我一下喔！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "我要一個巧克力香蕉口味。",
        "unit_id": 1211,
        "voice": "vo_adv_1068002_036"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "請給我一個芒果口味。",
        "unit_id": 413,
        "voice": "vo_adv_1068002_037"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "巧克力香蕉和芒果……",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_038"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "請稍候！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唷！",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_039"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喝！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "刷刷刷，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嘿……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "好厲害～！",
        "unit_id": 1211,
        "voice": "vo_adv_1068002_040"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "好像在變魔術！",
        "unit_id": 413,
        "voice": "vo_adv_1068002_041"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為我們也提供客人視覺上的享受啊。",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_042"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n……來，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓妳們久等了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "看起來好好吃的樣子～！",
        "unit_id": 1211,
        "voice": "vo_adv_1068002_043"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "謝謝妳～！",
        "unit_id": 413,
        "voice": "vo_adv_1068002_044"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "歡迎再來光臨～！",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_045"
    },
    {
        "type": "still",
        "still": "106800202"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "讓你久等了，少年！",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_046"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "多虧你，幫大忙了！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "其實啊，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_047"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "因為實在都沒客人上門，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "所以我就利用少年來吸引客人了！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n抱歉囉！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然後",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "謝謝你！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在旁人的眼中來看，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_048"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你大概像個因為可麗餅實在太好吃而與店長熱情歡談，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n立志要開可麗餅店的有為青年吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你看啊，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_049"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "剛才來買可麗餅的那些女孩子的表情。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不覺得她們的心靈",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "有被滿足了嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "等一下！",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_050"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "拜託你，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "繼續在這裡吃一個小時左右的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可麗餅啦〜！",
        "unit_id": 106812
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我知道了！",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_051"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "都是我不好！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我不會再留住你了！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "最後",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "再聽我說一件事，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "可以嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "身為可麗餅店老闆，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_052"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "兼祕密結社【拉比林斯】的首領，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我以拉比林斯達身分要說的事，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就到剛才為止。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "接下來，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_053"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是以選擇你作為公主騎士的迷宮女王",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n──模索路晶的身分",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "與你談話。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "盯上我和你的【憤怒‧軍團】，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_054"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n他們不是能以普通的辦法來對付的人。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "贊恩對我來說也很棘手。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我們不僅要和那種麻煩的對手對抗，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_055"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n還必須想好對策讓大家返回那邊的世界。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "除此之外，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_056"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還要確認被關在這裡的人們現況如何，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n若是有必要也得進行治療。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我現在所說的，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是我回來這個世界的目的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就結果而言，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_057"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然我無法再靠自己的力量回去那邊的世界，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但我覺得也覺得無所謂就是了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "畢竟目前",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你所在的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是這一側嘛。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……你該不會在想",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_058"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我為什麼要為你",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "做到",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這種程度嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這個嘛……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也和你的夥伴一樣，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n是在那邊的世界受過你幫助的人。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在你喪失記憶之前，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_059"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n若是沒有你，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我就只能一直",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "孤軍奮戰……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我真的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "到現在也都一直很感謝你。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "沒關係。",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_060"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "是我自己想牢記著而已。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n或許在你內心，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我只不過是一大群夥伴的其中一人，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但那樣就行了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不如說，如果不是那樣反而會讓人困擾。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年不只是能幫助我，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_061"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也是能幫助大家的人啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我可不能",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "再繼續",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "扭曲你應有的樣貌。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你應有的樣貌，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_062"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "應該要",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "由你自己決定。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n過去我希望你能幫助我，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而把mimi交給了你。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n今後",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你要做什麼，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就由你自己決定吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，少年。",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_063"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "打倒了真那，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "在這個總算開始流動的世界中，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你今後打算怎麼辦？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這個嘛……",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_064"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "若是說我的願望，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我希望這次絕對要和你，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一起拯救",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大家",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "還有這個世界。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了拯救大家，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_065"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你果然還是",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不可或缺的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n若是能實現這個願望，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我願意賭上性命去戰鬥。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這是我選擇你並將你捲進來的責任，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_066"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這一點我自己很清楚。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "正因為如此，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我才在早已下定了決心。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "若是少年心中沒有浮現出答案，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_067"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼去找就行了。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你一定能找到",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "只屬於你自己的答案。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我是個",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_068"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "將自己與世界的命運託付給少年的人。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n無論發生什麼事情。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我都會尊重你和那群孩子們的選擇。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "人的一生就與迷宮相同，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_069"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "迷惘才正是其價值所在。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "現在的你大可多多煩惱、",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "思考、",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "嘗試錯誤。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但是，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_070"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "最終該由誰選擇你要走的路……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n少年，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那非你自己莫屬。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_071"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不讓那時候的少年後悔，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "提供你協助。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我也只能做到這種程度而已。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你可以",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_072"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "先嘗試從整理現況開始著手。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n現在自己在哪裡，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "又該朝哪個方向前行才好。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "然後",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_073"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那並不是你一個人的問題。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這是和夥伴、",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "和這個世界的人們，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "大家各自都擁有的問題。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了尋找答案，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_074"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你可以去和大家聊聊看。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n想想世界與自己等人應該朝哪裡前進。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "順帶一提，",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_075"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唯一要給你的忠告是，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "時間是有限的。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n這點你可別忘了喔。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "剛才的話",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_076"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我並沒有告訴可可蘿，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你要小心點喔。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這問題要讓她一個人背負，責任實在太大，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "也太過沉重。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "其他的人也是，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我希望你告訴他們時要認清時機。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣啊……",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_077"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你見過她了啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這只是我猜想的，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n但她應該也很困擾吧，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "若是可以，請你也幫幫她吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "時間",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_078"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "的確有所限制。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "但如果是少年，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "一定能做出沒有迷惘的選擇，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我相信你。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……因為少年你",
        "unit_id": 106812,
        "voice": "vo_adv_1068002_079"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n可是我所選中",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "最",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "棒的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "公主騎士啊。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是拉比林斯達溫柔地拍了拍{player}的肩，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n說著對他的期待。"
    }
]