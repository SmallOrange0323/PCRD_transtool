[
    {
        "type": "dialogue",
        "name": "貪吃佩可的聲音",
        "words": "──然後呢！",
        "unit_id": 1,
        "voice": "vo_adv_9008015_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可的聲音",
        "words": "\n榮登蘭德索爾的飯糰美食第一名的是──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留的聲音",
        "words": "──給我等一下，",
        "unit_id": 1,
        "voice": "vo_adv_9008015_001"
    },
    {
        "type": "dialogue",
        "name": "凱留的聲音",
        "words": "貪吃佩可！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留的聲音",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留的聲音",
        "words": "明明",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留的聲音",
        "words": "第二名和第三名都還沒介紹啊──",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501620"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}拿著廣播的收訊設備，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了北方山脈，厄莉絲所居住的城堡中。"
    },
    {
        "type": "background",
        "background": "500510"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_9008015_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………騎士先生。",
        "unit_id": 129011,
        "voice": "vo_adv_9008015_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "你來找我了呀。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 129011,
        "voice": "vo_adv_9008015_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n是",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有什麼事嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "廣播……",
        "unit_id": 129011,
        "voice": "vo_adv_9008015_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "即使聽了，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我也仍然，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒辦法",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "到外面去喔。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "更何況，",
        "unit_id": 129011,
        "voice": "vo_adv_9008015_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我聽了也不會感到開心有趣。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也是……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "既然這是騎士先生喜愛的事物……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "只是收聽一會，",
        "unit_id": 129011,
        "voice": "vo_adv_9008015_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "或許無妨。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生很努力地",
        "unit_id": 129011,
        "voice": "vo_adv_9008015_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "在幫忙，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n這我知道喔。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "偶爾，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也能稍微聽見你的聲音。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還請你，",
        "unit_id": 129011,
        "voice": "vo_adv_9008015_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "努力到最後。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我",
        "unit_id": 129011,
        "voice": "vo_adv_9008015_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……我",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "辦得到嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "既然騎士先生都這麼說了……",
        "unit_id": 129011,
        "voice": "vo_adv_9008015_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "目前的我",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還無法做到。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n所以，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我先待在這裡收聽吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "不過，",
        "unit_id": 129011,
        "voice": "vo_adv_9008015_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有朝一日……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可的聲音",
        "words": "──好了接下來！",
        "unit_id": 1,
        "voice": "vo_adv_9008015_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可的聲音",
        "words": "\n備受關注的蘭德索爾肉類美食第一名是──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留的聲音",
        "words": "就──說──了──！",
        "unit_id": 1,
        "voice": "vo_adv_9008015_014"
    },
    {
        "type": "dialogue",
        "name": "凱留的聲音",
        "words": "\n別突然就從第一名開始介紹啦",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留的聲音",
        "words": "～！",
        "unit_id": 1
    }
