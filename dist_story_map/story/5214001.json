        "voice": "vo_adv_5214001_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但相對的也很嚴苛。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n完全不會手下留情。",
