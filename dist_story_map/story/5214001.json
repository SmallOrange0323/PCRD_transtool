    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "能成為傳說「桃鬥者」的",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "器量的少女……！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊，",
