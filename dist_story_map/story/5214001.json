    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是逸臀才對！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……怎麼辦……",
        "unit_id": 138712,
        "voice": "vo_adv_5214001_009"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "她在說什麼我完全聽不懂……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "話說回來，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "要在大家面前把屁股翹起來也太羞恥了……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "總、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "總之先拒絕好了……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個……",
        "unit_id": 138812,
        "voice": "vo_adv_5214001_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "美冬小姐，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個淘汰賽，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也可以參加嗎？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
