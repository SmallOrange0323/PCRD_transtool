        "voice": "vo_adv_5214001_016"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "已經出現第二個人了……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n與其說是傳說，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "更像是廉價拋售……？",
