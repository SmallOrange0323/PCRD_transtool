    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "地板上清晰地留下的若菜臀部痕跡，簡直就像「桃子」一樣。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就在捕捉到那臀部的瞬間，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美冬的墨鏡閃過一道銳利的光芒──"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呼……",
        "unit_id": 138812,
        "voice": "vo_adv_5214001_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "謝謝你們。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n{player}，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "若菜小姐。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我已經完全恢復了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或許是那瓶飲料發揮效果了……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "太好了～！",
        "unit_id": 138712,
        "voice": "vo_adv_5214001_001"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這個「蜂蜜莎」，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "好像",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "超級爆紅呢？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "雖然是上週才剛上市，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "但大家好像都在喝，說是可以提振精神。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n布武機的發明竟然能幫上別人，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "感覺還挺少見的呢。",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "欸，",
        "unit_id": 108013,
        "voice": "vo_adv_5214001_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那邊那位！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……沒錯，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是妳！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那位屁股像蜜桃一樣",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "的可愛女孩！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "咿！？",
        "unit_id": 138812,
        "voice": "vo_adv_5214001_003"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呀、",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "呀啊～！！",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n為、",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "為什麼突然摸人家的屁股啊！？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "妳、",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "妳是誰啊！！",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……這種多汁的手感……",
        "unit_id": 108013,
        "voice": "vo_adv_5214001_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "果然我的眼光沒有錯。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我是",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "【墨丘利財團】的美冬。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我是來挖角妳參加「蜜桃碰撞淘汰賽」的。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜、栞",
        "words": "蜜桃碰撞",
        "unit_id": 138812,
        "voice": "vo_adv_5214001_005"
    },
    {
        "type": "dialogue",
        "name": "若菜、栞",
        "words": "淘汰賽？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "沒錯──",
        "unit_id": 108013,
        "voice": "vo_adv_5214001_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那是決定世界上最強又最美臀部的戰場。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "簡略地來說，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是墨利村屁股相撲之類的東西吧。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "太、",
        "unit_id": 138712,
        "voice": "vo_adv_5214001_007"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "太簡略了吧……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "那個～",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "為什麼是我去參加那種比賽呢？",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "確實最近，",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "體重好像增加了一點點……",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "但還不到能當相撲選手的程度啦……",
        "unit_id": 138712
    },
