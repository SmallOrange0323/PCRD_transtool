        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……正、",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "正合我意！",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我會全力",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "加油的！",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好，我明白了！",
        "unit_id": 108013,
        "voice": "vo_adv_5214001_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n從現在開始叫我教練！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我會把妳們兩人",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "培育成超一流的臀士！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "栞、",
