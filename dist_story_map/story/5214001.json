        "type": "dialogue",
        "name": "美冬",
        "words": "妳的屁股，",
        "unit_id": 108013,
        "voice": "vo_adv_5214001_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "可是被稱為百萬人之中才有一人的「蜜桃臀」。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "具備成為超一流臀士，",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "傳說中的「桃鬥者」的素質！",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是絕對有機會奪冠的逸材，",
        "unit_id": 108013
