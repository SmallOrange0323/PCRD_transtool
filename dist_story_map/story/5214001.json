    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對嗎？",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我記得栞好像",
        "unit_id": 108013,
        "voice": "vo_adv_5214001_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "身體不太好，聽說比較虛弱。",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108013
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "看起來也是纖細又柔弱的類型，",
