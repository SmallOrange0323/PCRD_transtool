[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "贏了！　",
        "unit_id": 106011,
        "voice": "vo_adv_9029156_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們贏了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "貪吃佩可！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是的♪　",
        "unit_id": 105811,
        "voice": "vo_adv_9029156_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "賭上肚子餓得咕嚕咕嚕叫的貪吃佩可之名，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n絕對不能在食慾上敗北的呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此一來貪吃佩可小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_9029156_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可正式成為",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n食慾比鱷魚龍",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還要旺盛的人了呢……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "討厭，",
        "unit_id": 105811,
        "voice": "vo_adv_9029156_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "人家會害羞啦～☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……那樣真的值得高興嗎？　",
        "unit_id": 106011,
        "voice": "vo_adv_9029156_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "受不了妳們。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105811,
        "voice": "vo_adv_9029156_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我就不客氣囉～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n頭部周圍看起來像裙帶菜的部分似乎可以生吃呢♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嗯嗯嗯，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我拔！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？　",
        "unit_id": 106011,
        "voice": "vo_adv_9029156_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n連這傢伙妳也要吃嗎……？　",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且是生吃……？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯嗯……",
        "unit_id": 105811,
        "voice": "vo_adv_9029156_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "和一般的海藻有點不太一樣呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "散發著鱷魚的風味，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也很有嚼勁～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "十分美味☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯。",
        "unit_id": 106011,
        "voice": "vo_adv_9029156_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳的食慾果然",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是在鱷魚之上呢。",
        "unit_id": 106011
    }
]