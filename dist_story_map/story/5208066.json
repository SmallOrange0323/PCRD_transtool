[
    {
        "type": "background",
        "background": "502521"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在另一天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n當埃拉與日和在街上散步時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n有位帶著開朗笑容的少女前來搭話。"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊～！",
        "unit_id": 101711,
        "voice": "vo_adv_5208066_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n妳就是這個世界的管理者呀～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "嗨",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呵～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈！",
        "unit_id": 135511,
        "voice": "vo_adv_5208066_001"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是前",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "管理者才對。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "更重要的是，妳是誰呀？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n妳不是這座城鎮的居民吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我是從很～遠的島國來的香織～♪",
        "unit_id": 101711,
        "voice": "vo_adv_5208066_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我一直很想見妳喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "埃拉大人♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳好，",
        "unit_id": 135712,
        "voice": "vo_adv_5208066_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "香織！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今天",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是從蘭德索爾來這裡旅行的嗎～？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不，",
        "unit_id": 101711,
        "voice": "vo_adv_5208066_004"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我不是來旅行的。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我是為了潮流傳道啊～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦？",
        "unit_id": 135712,
        "voice": "vo_adv_5208066_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n潮流舞蹈？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "不對不對，",
        "unit_id": 101711,
        "voice": "vo_adv_5208066_006"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不是潮流舞蹈～也不是船到橋頭自然直的船到～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是潮流傳道啊～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "因為想把故鄉的文化傳播到世上各地，",
        "unit_id": 101711,
        "voice": "vo_adv_5208066_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n所以我成為了潮流傳道者喔～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "薩拉薩利亞是日頭之國不是嗎？",
        "unit_id": 101711,
        "voice": "vo_adv_5208066_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這裡的人和空氣",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "都有著跟我故鄉一樣的氣味啊～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "日頭",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "是指太陽喔～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哦～",
        "unit_id": 135511,
        "voice": "vo_adv_5208066_009"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "香織的故鄉是個什麼樣的地方呀？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這個嘛～",
        "unit_id": 101711,
        "voice": "vo_adv_5208066_010"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "雖然步調有點緩慢，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但大家",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "都像太陽一樣開朗，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而且很喜歡唱歌和跳舞♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳看，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就像這樣啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊咿呀，",
        "unit_id": 101711,
        "voice": "vo_adv_5208066_011"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "咿呀",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哈──哈♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哦哦～",
        "unit_id": 135511,
        "voice": "vo_adv_5208066_012"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好令人開心的節奏！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "日和，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我們也一起跳吧！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯、",
        "unit_id": 135712,
        "voice": "vo_adv_5208066_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和、埃拉",
        "words": "啊咿呀，",
        "unit_id": 1,
        "voice": "vo_adv_5208066_014"
    },
    {
        "type": "dialogue",
        "name": "日和、埃拉",
        "words": "咿呀哈──哈♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "唔哦，",
        "unit_id": 311,
        "voice": "vo_adv_5208066_015"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "這是怎麼回事！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n身體不由自主地……",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "跳起了舞！？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "的確……",
        "unit_id": 411,
        "voice": "vo_adv_5208066_016"
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "\n該不會",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "我們又開始",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性",
        "words": "按照程式設定來行動了……！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈♪",
        "unit_id": 101711,
        "voice": "vo_adv_5208066_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一旦響起了歡樂的音樂，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "身體就會不由自主地跳起舞！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n那並不是什麼程式設定，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "而是本能啦～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈哈哈！",
        "unit_id": 135511,
        "voice": "vo_adv_5208066_018"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不錯呢，香織！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我應該會",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "非常喜歡妳的故鄉喔♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "啊哈哈，",
        "unit_id": 101711,
        "voice": "vo_adv_5208066_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "妳這麼說真令人開心～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "那麼",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "大家一起心兒怦怦跳起來吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "今天要一直跳到天亮喔～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "全員",
        "words": "啊咿呀，",
        "unit_id": 1,
        "voice": "vo_adv_5208066_020"
    },
    {
        "type": "dialogue",
        "name": "全員",
        "words": "咿呀哈──哈♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n薩拉薩利亞與香織的故鄉城鎮結為了友好城市。"
    }
]