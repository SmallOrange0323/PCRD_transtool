        "voice": "vo_adv_6114202_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那樣大家肯定會很高興的喵！",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就立刻寫在菜單上……",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "等等，",
        "unit_id": 125111
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣店裡會被抓爛的喵～！",
        "unit_id": 125111
