    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}為了帶露娜外出到街上去，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n和露娜約了地點碰面。"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥！",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_000"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "嘿嘿，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "對不起呢。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n露娜，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "剛剛在準備。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……我和平常有點不一樣唷？",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_001"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥，你看得出來嗎？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "才不是！",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_002"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n我的髮型跟往常一樣啦！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "才不是！",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_003"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n我的衣服和往常一樣啦！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "真是的，",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_004"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥這樣不行。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不可以沒注意到淑女的儀容唷，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n媽媽也有說過這句話。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……呵呵。",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_005"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n但是，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "爸爸也從都沒注意過。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "所以媽媽和露娜，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "都會生氣。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "所以我原諒你。",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_006"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n但是作為交換……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……能像爸爸一樣",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_007"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "牽著露娜的手嗎？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……呵呵！",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_008"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n好大啊，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥的手！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "好，走吧！",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_009"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "雖然有點害怕……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……但是，",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_010"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "好期待呢！",
        "unit_id": 111411
    },
    {
        "type": "background",
        "background": "500132"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "哇……",
        "unit_id": 111411,
        "voice": "vo_adv_1114005_011"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n在那邊能看到的東西，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "是什麼？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n這邊呢？",
