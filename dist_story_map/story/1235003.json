[
    {
        "type": "background",
        "background": "500158"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "鈴和{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n買到了蘭祭的限定版遊戲。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n這天兩人約定要一起通關遊戲。"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼啊～",
        "unit_id": 102611,
        "voice": "vo_adv_1235003_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "蘭祭順利結束了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這下終於可以回到",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "和平的懶散生活了呢～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哦，",
        "unit_id": 102611,
        "voice": "vo_adv_1235003_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "終於來了，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "辛苦啦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你今天也去打工了對吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然說好要一起玩遊戲，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不挑假日玩沒問題嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……原來如此原來如此，",
        "unit_id": 102611,
        "voice": "vo_adv_1235003_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "受到蘭祭的影響，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "配送的工作增加，\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很難排休啊？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "光是要排明天早上休息，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "都已經很勉強了嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總覺得不小心聽見了社會的殘酷啊……",
        "unit_id": 102611,
        "voice": "vo_adv_1235003_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "大家能在蘭祭上享受購物的樂趣，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "都是你的功勞呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "一直以來",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "都辛苦你啦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 102611,
        "voice": "vo_adv_1235003_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你今天這麼忙不會很累嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "今天要通宵玩遊戲耶，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "沒問題嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哦～",
        "unit_id": 102611,
        "voice": "vo_adv_1235003_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "居然可以說這種話，還蠻游刃有餘的嘛。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "既然如此，那我就恭敬不如從命，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n用限定版遊戲當作",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "蘭祭的續攤吧～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "因為遊戲和工作不一樣，",
        "unit_id": 102611,
        "voice": "vo_adv_1235003_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再怎麼努力都不會累啊。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且這還是蘭祭限定版遊戲，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那就更不用擔心了～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不卯足全力",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "通關可說不過去喔。",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "501600"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所以，",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我去換了萬聖節的服裝喔。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "畢竟要玩蘭祭的限定版遊戲，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n穿普通的衣服玩實在太失禮了～",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "遊戲機也準備好了。",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼就，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "開玩囉！",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "標題畫面",
        "words": "《十四天的萬聖節～殺人魔VS幽靈～》",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說回來我買到的時候就在想，",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n總覺得，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "遊戲標題跟氛圍很像恐怖遊戲呢～",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我明明記得這個社團，",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n一直以來都是在做經典奇幻風的動作遊戲呀？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "難不成，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是給錯遊戲了嗎？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總之，",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "來看看說明書吧……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我看看……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯～",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "本作為蘭祭限定發售的遊戲，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n同時也是本社活用動作遊戲的技術，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n以巔峰為目標所製作的終極恐怖遊戲。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "聽說在測試階段，",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "測試人員做了一個月的惡夢。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n既然得到了這麼好的結果，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "敬請各位玩家務必好好享受。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n攤主筆。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我、",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我真是買到不得了的東西了啊……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "恐怖遊戲",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "本來就不在我的興趣內，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n而且也不太擅長……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我、",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我才沒有害怕喔？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然我不會怕啦，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "怎麼說。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要是不小心驚醒了牧場的大家，那不就太可憐了嗎？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是很貼心的獸人嘛，",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我可是很注重這方面的喔～",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……你那個表情，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你完全不相信對吧？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你、",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你在說什麼啦～",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我可是遊戲玩家小鈴喔？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n才不可能因為一點點的恐怖畫面",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就逃跑咧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……雖然我不曉得會讓人連續做一個月惡夢的遊戲，",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n到底算不算一點點的恐怖畫面啦。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "算了，",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在標題畫面磨磨蹭蹭也不是辦法。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "而且我還跟攤主約好要給他感想，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這下子一定得玩才行了……",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再說了，",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "明明我還自稱喜歡遊戲，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n要是避開特定遊戲不玩也不太好呢～",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "從這點來說",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我也要通關這個遊戲！",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼，",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就開始吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "標題畫面",
        "words": "咕哦哦哦哦哦！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "噫",
        "unit_id": 123511,
        "voice": "vo_adv_1235003_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "！？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……我剛剛沒有",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "慘叫喔？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "只是打嗝而已喔？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n是說，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在標題畫面就被嚇到也太丟臉了吧～",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "遊戲畫面",
        "words": "「你不小心進入了",
        "unit_id": 1,
        "voice": "vo_adv_1235003_023"
    },
    {
        "type": "dialogue",
        "name": "遊戲畫面",
        "words": "一幢被詛咒的洋房……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "遊戲畫面",
        "words": "\n要是無法解開謎題，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "遊戲畫面",
        "words": "打倒殺人魔及幽靈，",
