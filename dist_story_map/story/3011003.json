    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──{player}正在協助暮光流星群的成員們，\n追捕一位通緝犯。"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好啦～你已經沒可地方可逃了喔！",
        "unit_id": 105612,
        "voice": "vo_adv_3011003_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n我勸你死心吧！",
        "unit_id": 105612
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "啊啊啊！對、對了！",
        "unit_id": 811,
        "voice": "vo_adv_3011003_001"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "這個！我把這個給妳！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n拜、拜託妳了！放過我吧～！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "看來這是被邪念支配了的人會做的行為呢。",
        "unit_id": 100911,
        "voice": "vo_adv_3011003_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……但是呢，我還是看看是什麼東西吧。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這是什麼啊……？紙屑？……",
        "unit_id": 100911,
        "voice": "vo_adv_3011003_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不，是地圖啊。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "啊、啊啊、對了。這是標示出暮光之都的地圖。",
        "unit_id": 811,
        "voice": "vo_adv_3011003_004"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "你們也知道的吧？這是真的！絕對沒有錯！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "你說這是暮光之都的地圖！？",
        "unit_id": 101311,
        "voice": "vo_adv_3011003_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那種東西真的存在呢……",
        "unit_id": 102711,
        "voice": "vo_adv_3011003_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嘿……",
        "unit_id": 100911,
        "voice": "vo_adv_3011003_007"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嘿哈哈哈！終於時機降臨啦！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "果然這世界不變的道理都會聚集於我的魔瞳之中！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n這樣離暮光之都就不遠了！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……啊、是啊！",
        "unit_id": 105111,
        "voice": "vo_adv_3011003_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "杏奈，這是重要的地圖喔！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不見就糟糕了，交給我保管吧！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我拒絕！這地圖是我收下的！",
        "unit_id": 100911,
        "voice": "vo_adv_3011003_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n所以，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這地圖就是我的！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這種說法是行不通的喔。",
        "unit_id": 105111,
        "voice": "vo_adv_3011003_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這地圖是大家的共有財產喔！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "話需如此，但深月……妳應該不會說著要破解地圖，",
        "unit_id": 101311,
        "voice": "vo_adv_3011003_011"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "然後就這樣消失了吧？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "唉呀……我像是會做這種事的人嗎",
        "unit_id": 105111,
        "voice": "vo_adv_3011003_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "？",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "當然像呀……",
        "unit_id": 102711,
        "voice": "vo_adv_3011003_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "倒不如說，不這樣做的話，反而不像深月……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "這裡～就交給魔法少女七七香吧！",
        "unit_id": 101311,
        "voice": "vo_adv_3011003_014"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "杏奈美眉啊～那地圖呢～",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n我想用妳之前一直想要的那本魔法書交換～開玩笑的……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "沒有這個必要！",
        "unit_id": 100911,
        "voice": "vo_adv_3011003_015"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "當到達暮光之都後，我就能拿回前世的記憶，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n就算沒有什麼魔法書，我都會是最強的！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "沒辦法了……不快點做什麼的話。",
        "unit_id": 101311,
        "voice": "vo_adv_3011003_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呵呵……",
        "unit_id": 102711,
        "voice": "vo_adv_3011003_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "杏奈，我是不會容許妳超過我的喔……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嗚……",
        "unit_id": 100911,
        "voice": "vo_adv_3011003_018"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "就、就算妳用這樣的眼神看著我，我也不會害怕的！？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "為了找到暮光之都，我是不會在這裡讓步的！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這張地圖是我的！",
        "unit_id": 100911,
        "voice": "vo_adv_3011003_019"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我不會交給任何人！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "再見吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "等等！這地圖是屬於我的喔！",
        "unit_id": 105111,
        "voice": "vo_adv_3011003_020"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "啊！妳剛才說了「是妳的」！",
        "unit_id": 101311,
        "voice": "vo_adv_3011003_021"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "妳果然想據為己有啊！？",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "我不會容許妳這樣做的！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也不會客氣，要盡全力搶過來……",
        "unit_id": 102711,
        "voice": "vo_adv_3011003_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呵呵……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的……",
        "unit_id": 105611,
        "voice": "vo_adv_3011003_023"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n明明現在不是起內訌的時候說……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "很好很好，趁這時候……",
        "unit_id": 811,
        "voice": "vo_adv_3011003_024"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "──等一下，你想去哪裡？",
        "unit_id": 105611,
        "voice": "vo_adv_3011003_025"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n不會是想要逃走吧？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "不、",
        "unit_id": 811,
        "voice": "vo_adv_3011003_026"
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "不是吧！我不是給你們地圖了嗎！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "通緝犯",
        "words": "妳答應說會放過我的啊！？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們之間的交易還沒有成立喔！",
        "unit_id": 105611,
        "voice": "vo_adv_3011003_027"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n在那之前你就把地圖交給我們，是你太大意了喔。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你就放棄逃走，束手就擒吧！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你呀～抱歉啦！我要將這個人移交出去，",
        "unit_id": 105611,
        "voice": "vo_adv_3011003_028"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你可以幫我阻止深月她們嗎？",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "如果她們認真亂來的話，",
        "unit_id": 105611,
        "voice": "vo_adv_3011003_029"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n會破壞一、兩條街呢。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我就想說如果是你的話一定會這麼說的。",
        "unit_id": 105611,
        "voice": "vo_adv_3011003_030"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼，快去阻止她們吧！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你說得對。那如果是真正的地圖，",
        "unit_id": 105611,
        "voice": "vo_adv_3011003_031"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就會跟街道一起變成塵土了喔。",
        "unit_id": 105611
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的……",
        "unit_id": 105611,
        "voice": "vo_adv_3011003_032"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n那些傢伙們，去哪裡了啦……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊～啊……這裡已經一片混亂了。",
        "unit_id": 105611,
        "voice": "vo_adv_3011003_033"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "各個地方的地形也都產生變化了……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是的、那些傢伙……就算是同伴也不會手下留情呢！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯～也幸好她們這麼放肆，",
        "unit_id": 105611,
        "voice": "vo_adv_3011003_034"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n應該很容易找到她們所在地……",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你呀！走了唷！",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "──乖乖地把地圖交給我吧。",
        "unit_id": 105111,
        "voice": "vo_adv_3011003_035"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n不照做的話，我下一擊會用盡全力了喔！",
        "unit_id": 105111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "嘿哈哈哈！",
        "unit_id": 100911,
        "voice": "vo_adv_3011003_036"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n做得到的話，妳試試做吧！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "極‧魔瞳開眼……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "做得好啊杏奈美眉！",
        "unit_id": 101311,
        "voice": "vo_adv_3011003_037"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "那麼，我的最強終極魔法也",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n華麗的舞動吧！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呵……",
        "unit_id": 102711,
        "voice": "vo_adv_3011003_038"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好危險喔，七七香小姐。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "大家請放心……我會把妳們全部一併搞定的。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那些傢伙們是真的在認真打鬥呀……",
        "unit_id": 105611,
        "voice": "vo_adv_3011003_039"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
