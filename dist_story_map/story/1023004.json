        "voice": "vo_adv_1023004_051"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你怎麼了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "身體不舒服嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n怎麼在發呆？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "果然是因為",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_052"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n被我的噗吉全力揮擊給直接擊中……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n結果受傷",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "渾身無力了？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對不起，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_053"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對不起！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我跟你道歉，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "原諒我好嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_054"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不對嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你說好像",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "作夢了……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你站著睡著了啊，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_055"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "真是厲害～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_056"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "奇怪的哥哥……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "咦？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n有蟲在你的",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "肩膀那裡喔。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我來幫你拿掉。",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_057"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿咻……♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯？",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_058"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你說",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我不是怕蟲……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你怎麼會知道那件事，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗯～",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_059"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我以前是很怕蟲。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n或許是因為【咲戀育幼院】",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n建築老舊的關係，經常有蟲跑出來。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "要是每次都害怕到大吵大鬧，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_060"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n那也很累人啊。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "而且，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_061"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我是姐姐呀。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n怎麼能害怕什麼蟲呢。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃好像也拿蟲沒辦法，只要看到就會害怕，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_062"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n所以都是由我來幫她趕蟲的。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "為了這點，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_063"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我才會像這樣，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n進行噗吉全力揮擊的特訓喔。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我要從胡桃和大家各自害怕的事物中，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_064"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n保護好他們才行。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "雖然不管怎麼說，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_065"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n都沒辦法一開始就做得很好啦……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "誇獎我，哥哥！",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_066"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "越來越有所成長了對吧～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿……",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_067"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你說我",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "很了不起？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "再多誇獎我一點！",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_068"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我呀，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "是越被人誇獎就進步得越快的類型喔♪",
        "unit_id": 102311
    }
]