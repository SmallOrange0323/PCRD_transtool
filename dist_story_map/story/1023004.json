    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "上啊！",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_000"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉全力揮～擊☆",
        "unit_id": 102311
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……唔唔？",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_001"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n好像",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有奇怪的手感！？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔哇！",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_002"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "有人倒在地上！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對對對、",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "對不起！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n該不會是",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "被噗吉全力揮擊給直接擊中了！？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「啊……",
        "unit_id": 2111,
        "voice": "vo_adv_1023004_003"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n妳闖禍了，",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「年紀輕輕就成了殺人犯，",
        "unit_id": 2111,
        "voice": "vo_adv_1023004_004"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "真是前途一片黯淡。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n好可憐。",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n我一定",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "每天都會去監獄探望你的。」",
        "unit_id": 2111
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "就、就算是開玩笑，也別說那種話！",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_005"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "噗吉，你有時候很壞心眼耶～！",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你、你、",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_006"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你沒事吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸，咦？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n你該不會是……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "{player}哥哥？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "前陣子讓你送我回家……",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_007"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n還有很多事情，都非常感謝你。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "應該說是託你的福嗎……",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_008"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "胡桃感冒也完全好了，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n請放心♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "話說，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_009"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "你還好嗎……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n被噗吉全力揮擊",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n打中了……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "欸～",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "正打算要避開，結果沒站穩跌倒了？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n真的嗎？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "不是因為顧慮我，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "而隱瞞實話了吧……？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "啊啊，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_011"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "膝蓋那裡擦破皮了。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n我有帶療傷藥，我來幫你擦藥。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "感覺真對不起，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嘿嘿。",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_012"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n自從前陣子那件事之後，",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我就開始向咲戀媽媽",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n請教藥草相關的知識。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "這個療傷藥也是，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_013"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n雖然費了不少工夫，但這是我自己做的。",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "我技術還不是很好，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_014"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n可能會沒什麼效果……",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "但應該至少能讓人安心",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "吧？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "痛痛、痛痛，",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_015"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "飛走吧～♪",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "唔呀！？",
        "unit_id": 102311,
        "voice": "vo_adv_1023004_016"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n哥、哥哥你怎麼好像在發光？",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n全身",
        "unit_id": 102311
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "都閃閃發亮的～！？",
        "unit_id": 102311
    },
    {
        "type": "background",
        "background": "510200"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "嗚嗚～",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_017"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "\n嗚哇啊……！",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "……",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_018"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "呀唔！？",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_019"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「嗨，{player}小子。",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_020"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n有什麼事嗎？",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n綾音的話，她沒事，",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "不用擔心。」",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「所以我就說她沒事啊。",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_021"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "對吧，綾音？」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「有嗎？",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_022"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n綾音她一直都是這種感覺啊。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「{player}小子才是，\n不覺得你氛圍和平時不太一樣嗎？」",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_023"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_024"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "應該說是變得更開朗，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n還是感覺變得比較裝熟，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n感覺莫名地有精神。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「很好很好。",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_025"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n看來綾音這傢伙，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n情緒穩定不少了。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「抱歉讓你擔心了。",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_026"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n放心吧，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "她並沒有跌倒受傷，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n也不是被人給欺負",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "之類的事啦。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「就是……",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_027"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n剛才，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n有蜜蜂飛到綾音的身旁。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「啊啊，她並沒有被刺傷，沒事啦。",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_028"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n只是嚇了一跳，",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "結果害怕到哭起來。",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "她沒有任何地方受傷，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "別擔心。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「以前，",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_029"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n綾音曾經被蜜蜂刺傷過。",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n或許就是那次經驗給她留下了陰影……」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「就只有蟲，\n她一直都不太喜歡，",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_030"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "應該說她似乎很怕蟲。」",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「只要有蟲接近就會陷入恐慌，",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_031"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n然後失控地大鬧特鬧。」",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「噗吉全力揮擊啊，",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_032"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "原本就是",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "為了驅趕蟲而創造出來的技能喔。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「拿著手上的包包全力亂揮，",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_033"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n來驅趕飛蟲。」",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「不過，",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_034"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "有時會不小心打到在附近的人，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n給人造成麻煩……",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n這不是什麼好習慣，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "我倒覺得還是改掉比較好。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「不對。",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_035"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n若是不克服對蟲的恐懼心，",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n也無法根本解決問題吧。」",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「我覺得",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_036"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音自己也很明白這一點。",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n不過她還是",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "真的拿蟲沒有辦法。",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "但像蝴蝶之類的，",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "她就覺得很可愛很喜歡。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "…………♪",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_037"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「咦，",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_038"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音那傢伙……",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n不知不覺間就不哭了。",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n而且還天真無邪地",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "追著飛在附近的白粉蝶呢。」",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「看那感覺，",
        "unit_id": 102331,
        "voice": "vo_adv_1023004_039"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n她是連自己為什麼哭都不記得了吧。」",
        "unit_id": 102331
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「謝啦，{player}小子。",
        "unit_id": 2131,
        "voice": "vo_adv_1023004_040"
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n只要和你在一起，",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "綾音的心情也會跟著開心起來……",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "\n就仿佛「悲傷」、",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "「寂寞」",
        "unit_id": 2131
    },
    {
        "type": "dialogue",
        "name": "噗吉",
        "words": "之類的心情都消失了一樣。」",
        "unit_id": 2131
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "嘿，",
        "unit_id": 190011,
        "voice": "vo_adv_1023004_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n噗吉全力揮擊居然還有這樣的誕生祕密……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "原來如此，",
        "unit_id": 190011,
        "voice": "vo_adv_1023004_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我終於知道我只要飛過綾音身旁，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就很容易被她擊墜的原因了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n原來她",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "很怕蟲啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不對，",
        "unit_id": 190011,
        "voice": "vo_adv_1023004_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我可不是什麼蟲喔？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n綾音也曾經稱讚我說",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n「仔細一看就像蝴蝶一樣好可愛」！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……啊，",
        "unit_id": 190011,
        "voice": "vo_adv_1023004_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抱歉抱歉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我應該姑且先做各種說明才對。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "每次都要這麼做真麻煩～",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過這也無可奈何。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛才看到的，",
        "unit_id": 190011,
        "voice": "vo_adv_1023004_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就是類似夢境的東西。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你應該一醒來就會馬上忘記，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n現在不需要去想太多。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不～過，",
        "unit_id": 190011,
        "voice": "vo_adv_1023004_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "「那邊」的綾音……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n該說她是內向嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n她本人完全沒有說話呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你似乎也因為失去記憶的影響，變得很寡言，",
        "unit_id": 190011,
        "voice": "vo_adv_1023004_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我還以為你們不會搭上話了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "有噗吉在真是幫大忙了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "得謹慎",
        "unit_id": 190011,
        "voice": "vo_adv_1023004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n選擇回想場面才行呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……啊啊，這是我自言自語。",
        "unit_id": 190011,
        "voice": "vo_adv_1023004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就算在那滔滔不絕也不能怎麼樣，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n這次就這樣先告辭了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，{player}。",
        "unit_id": 190011,
        "voice": "vo_adv_1023004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n讓我們在夢中再會吧♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "綾音 ",
        "words": "哥哥……？",
