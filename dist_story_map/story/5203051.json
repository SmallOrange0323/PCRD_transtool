[
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那一天──",
        "unit_id": 1,
        "voice": "vo_adv_5203051_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "光芒燒盡了整個世界。",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500135"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "所有的一切，",
        "unit_id": 1,
        "voice": "vo_adv_5203051_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "都燒成了一片火紅，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "化為灰燼。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n家人、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "朋友……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "甚至是那些重要的人們。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在那座城鎮裡，",
        "unit_id": 1,
        "voice": "vo_adv_5203051_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "只有一個少女。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "存活了下來。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在燒熔成赤紅的世界裡、",
        "unit_id": 1,
        "voice": "vo_adv_5203051_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "被灰燼掩埋的此處──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n唯有一樣事物，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "未被燃燒殆盡。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那就是在胸口焦黑的復仇之心。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在火星飛舞的平原上、",
        "unit_id": 1,
        "voice": "vo_adv_5203051_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n在染上紅蓮色彩的陰鬱天空下，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n她以殘破的身體和生命為燃料",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "奮力向前奔馳。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "已經沒有任何人了──",
        "unit_id": 1,
        "voice": "vo_adv_5203051_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "孤身一人少女。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n她成為了唯有一人的旅團中──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n唯一的士兵。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5203051_006"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "「Bocchi Battle Brigade",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n　～邊緣人的最後一天～」",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──沒錯。",
        "unit_id": 53013,
        "voice": "vo_adv_5203051_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n果然，",
        "unit_id": 53013
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我就是「邊緣人」──",
        "unit_id": 53013
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n因為，",
        "unit_id": 53013
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的朋友全部都死了啊。",
        "unit_id": 53013
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──向害我成為孤身一人的所有敵人，",
        "unit_id": 53013,
        "voice": "vo_adv_5203051_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "展開復仇──",
        "unit_id": 53013
    }
]