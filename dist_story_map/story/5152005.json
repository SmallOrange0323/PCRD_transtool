    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓各位久等了。",
        "unit_id": 107612,
        "voice": "vo_adv_5152005_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "找到了找到了，",
        "unit_id": 107812,
        "voice": "vo_adv_5152005_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那塊大冰塊果然是你們施放的啊。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "哼。",
        "unit_id": 109812,
        "voice": "vo_adv_5152005_039"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n妳還真是慢悠悠的呢，凱留。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這也沒有辦法，",
        "unit_id": 107812,
        "voice": "vo_adv_5152005_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們可是很忙的啊。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n直到剛剛為止都還在海上拼命奮戰。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為事發突然，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連信號都沒辦法發出來呢？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "拼命奮戰……？",
        "unit_id": 132112,
        "voice": "vo_adv_5152005_041"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "信號……？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀，",
        "unit_id": 107612,
        "voice": "vo_adv_5152005_042"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還沒有恢復原樣嗎？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛剛在下等人──",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "──",
        "unit_id": 131911,
        "voice": "vo_adv_5152005_043"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "對了，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "貪吃佩可妳聽我說！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那隻白島鯨",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "被我們打倒了喔。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "美食殿堂",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_5152005_044"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "──白島鯨的話，",
        "unit_id": 107512,
        "voice": "vo_adv_5152005_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們已經打倒了耶……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "拉姆、愛蜜莉雅、雷姆",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_5152005_046"
    },
    {
        "type": "dialogue",
        "name": "全員",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_5152005_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那個～",
        "unit_id": 107812,
        "voice": "vo_adv_5152005_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也就是說。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們也在剛剛",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "打倒了白島鯨是嗎？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的，",
        "unit_id": 132112,
        "voice": "vo_adv_5152005_049"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "沒有錯。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n確實是由愛蜜莉雅大人",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "一擊消滅了白島鯨。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人也確認過，",
        "unit_id": 107612,
        "voice": "vo_adv_5152005_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在貪吃佩可小姐火力全開之下",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n擊倒了白島鯨。",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～",
        "unit_id": 107512,
        "voice": "vo_adv_5152005_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是怎麼一回事呢。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道說，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是從一開始就有兩隻嗎？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "白島鯨這種魔物有那麼多隻嗎？",
        "unit_id": 109812,
        "voice": "vo_adv_5152005_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 107512,
        "voice": "vo_adv_5152005_053"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "照理來說，",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "應該是沒有這種事──",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 3
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這個聲音……！",
        "unit_id": 131911,
        "voice": "vo_adv_5152005_054"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不會有錯，",
        "unit_id": 107512,
        "voice": "vo_adv_5152005_055"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是白島鯨！",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼會……！？",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼了嗎，",
        "unit_id": 107612,
        "voice": "vo_adv_5152005_056"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您好像在指著什麼東西……",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哎呀？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有什麼東西，",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "漂浮在空中……？",
        "unit_id": 107612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又白、",
        "unit_id": 107812,
        "voice": "vo_adv_5152005_057"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "又大的……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鯨、魚……？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有鯨魚──",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "美食殿堂",
        "words": "在天上飛────────！？",
        "unit_id": 1,
        "voice": "vo_adv_5152005_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且，",
        "unit_id": 107512,
        "voice": "vo_adv_5152005_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一隻、",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "二隻、",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "三隻……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "增加了呢。",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n花凜小姐……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們沒有收到這樣的資訊啊……",
        "unit_id": 107512
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "這是……",
        "unit_id": 2612,
        "voice": "vo_adv_5152005_060"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "嗯。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你這毛茸茸的傢伙為什麼這麼冷靜啊！",
        "unit_id": 107812,
        "voice": "vo_adv_5152005_061"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n有鯨魚在天上飛耶！？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "啊啊，抱歉抱歉。",
        "unit_id": 2612,
        "voice": "vo_adv_5152005_062"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "不過，",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "我對這情景有印象呢。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "這該不會是",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "白島鯨",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "受到了我們的影響……？",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說有印象，",
        "unit_id": 107812,
        "voice": "vo_adv_5152005_063"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "意思是在你們的世界裡，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "鯨魚會飛是正常的嗎！？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n異世界也太可怕了吧！？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "姊姊……",
        "unit_id": 132112,
        "voice": "vo_adv_5152005_064"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n長在白島鯨上的那支角，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "該不會是魔獸的……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "有種不妙的感覺。",
        "unit_id": 109812,
        "voice": "vo_adv_5152005_065"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n得考慮撤退呢。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n我們應該",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "要以愛蜜莉雅大人的安全為優先──",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "不行。",
        "unit_id": 131911,
        "voice": "vo_adv_5152005_066"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "昴有說過。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "他說海邊",
        "unit_id": 131911,
        "voice": "vo_adv_5152005_067"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是讓大家露出笑容的地方。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "要是放著那隻白島鯨不管，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n愉快的海邊就會毀於一旦。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "而且，",
        "unit_id": 131911,
        "voice": "vo_adv_5152005_068"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "也是為了讓這孩子恢復原樣，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我們可不能在這裡放走白島鯨。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "這孩子",
        "unit_id": 131911,
        "voice": "vo_adv_5152005_069"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "和大家的「夏日佳期」，",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "都要守護才行！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "愛蜜莉雅……",
        "unit_id": 107511,
        "voice": "vo_adv_5152005_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳！",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "坦白說，",
        "unit_id": 107611,
        "voice": "vo_adv_5152005_071"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這情況已經不是在下等人所能應對的了。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "能有您們幫忙，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實屬萬幸。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們真的",
        "unit_id": 107811,
        "voice": "vo_adv_5152005_072"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都是好人呢。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n……",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "拉姆要怎麼做。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "只要是愛蜜莉雅大人決定的事，拉姆就沒有異議。",
        "unit_id": 109812,
        "voice": "vo_adv_5152005_073"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "記得想好討伐白島鯨後要跟拉姆",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n道謝的話喔，",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "凱留。",
        "unit_id": 109812
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆也要戰鬥！",
        "unit_id": 132111,
        "voice": "vo_adv_5152005_074"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n我還沒有和昴享受海邊！",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "要是讓白島鯨在這裡搗亂，",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "把海邊給破壞掉，可就傷腦筋了。",
        "unit_id": 132111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雷姆小姐，",
        "unit_id": 107611,
        "voice": "vo_adv_5152005_075"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要不要試試看",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和昴先生在海中漫步呢？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n氣氛非常地好喔。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n等討伐白島鯨後，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下再告訴您詳細。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "我也得稍微鼓起幹勁才行呢。",
        "unit_id": 2612,
        "voice": "vo_adv_5152005_076"
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "\n",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "莉雅，",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "帕克",
        "words": "要注意千萬別亂來喔。",
        "unit_id": 2612
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "嗯，",
        "unit_id": 131911,
        "voice": "vo_adv_5152005_077"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我知道了。",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 107511,
        "voice": "vo_adv_5152005_078"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "愛蜜莉雅。",
        "unit_id": 107511
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "我們走吧，",
        "unit_id": 131911,
        "voice": "vo_adv_5152005_079"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "貪吃佩可！",
        "unit_id": 131911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "白島鯨身上發生了不應該有的變化。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了守護能讓人露出笑容的夏日海邊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可她們和愛蜜莉雅一行人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拿起武器，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "同心協力，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "投身於激戰之中。"
    },
    {
        "type": "background",
        "background": "502340"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那是什麼呀！？",
        "unit_id": 190011,
        "voice": "vo_adv_5152005_080"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n增殖？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那巨大的身軀？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我沒見過那種魔物……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不對，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不可能有這麼破壞平衡的東西存在……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那跟棲息在這個世界裡的白島鯨不同，",
        "unit_id": 190011,
        "voice": "vo_adv_5152005_081"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n反應明顯異常……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是怎麼一回事啊……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那是……",
        "unit_id": 132012,
        "voice": "vo_adv_5152005_082"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "看來似乎混雜進去了呢。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "艾姬多娜……",
        "unit_id": 190011,
        "voice": "vo_adv_5152005_083"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳知道些什麼嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "我沒有辦法對異世界的未知事件下定論，",
        "unit_id": 132012,
        "voice": "vo_adv_5152005_084"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n但是可以推測出眼前所發生的現象。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "知道的話就告訴我。",
        "unit_id": 190011,
        "voice": "vo_adv_5152005_085"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n那到底是什麼？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "所以我說，",
        "unit_id": 132012,
        "voice": "vo_adv_5152005_086"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "有東西混雜其中。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n那隻被稱為白島鯨的魔物",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "會奪取記憶對吧？",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "也就是說，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "牠把東西吸收進去了。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那東西……",
        "unit_id": 132012,
        "voice": "vo_adv_5152005_087"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "就是菜月昴他所擁有的",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "異世界的因子。",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為接收到異世界這個原本不存在的資訊，",
        "unit_id": 190011,
        "voice": "vo_adv_5152005_088"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n導致白島鯨",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "產生了bug嗎……？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "相當有趣的現象呢。",
        "unit_id": 132012,
        "voice": "vo_adv_5152005_089"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n身懷這邊世界的因子的魔物，",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "\n如今",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "居然",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "會有著和那個「暴食」所孕育出的魔獸類似的性質──",
        "unit_id": 132012
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "那麼，",
        "unit_id": 132012,
        "voice": "vo_adv_5152005_090"
    },
    {
        "type": "dialogue",
        "name": "艾姬多娜",
        "words": "他們會選擇怎麼樣的結局呢──",
        "unit_id": 132012
    }
]