[
    {
        "type": "background",
        "background": "502111"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吉歐‧格黑納某處。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在擺放好的和太鼓前。"
    },
    {
        "type": "dialogue",
        "name": "拿娜、鳳凰",
        "words": "喔喔……？",
        "unit_id": 1,
        "voice": "vo_adv_9009013_000"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "嗯嗯……",
        "unit_id": 134712,
        "voice": "vo_adv_9009013_001"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "這就是這次夏日祭典借給我們的，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n名為和太鼓",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "的樂器嗎。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n聽說，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "這和位於阿斯特朗上的",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "東國有些關聯。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "不過不過，",
        "unit_id": 136212,
        "voice": "vo_adv_9009013_002"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "這個樂器要怎麼發出聲音呀？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "是像鑼一樣，",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "鏘鏘鏘",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "地敲打嗎？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不、",
        "unit_id": 134712,
        "voice": "vo_adv_9009013_003"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不可以粗暴地對待樂器啦！？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我想，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "應該是要用這個小棍棒吧……",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n但到底哪一邊",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "才是前端呀？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "而且為什麼",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "會有兩支？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "一支是備用的嗎？",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯～",
        "unit_id": 106113,
        "voice": "vo_adv_9009013_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這一帶看起來很和平啊～",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n果然",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是因為正在舉辦夏日祭典嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "明明聽說這裡以弱肉強食為宗旨，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是個適合大壞蛋",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "的地方呢。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "唔唔？",
        "unit_id": 134712,
        "voice": "vo_adv_9009013_005"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n那個人好像",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "是來自阿斯特朗的人呢。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n正好，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我們向她打聽一下怎麼演奏和太鼓吧！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "妳好──！",
        "unit_id": 136212,
        "voice": "vo_adv_9009013_006"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n那個那個，妳啊，",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "是佩可他們那個世界的人對吧？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106113,
        "voice": "vo_adv_9009013_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳們是什麼人。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n傳說中的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妖魔人嗎？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n乍看之下比較像是兔子和雞的獸人族啊……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拿娜、鳳凰",
        "words": "「我是獨角兔啦～！」\n「我才不是雞啊～！」",
        "unit_id": 136212,
        "voice": "vo_adv_9009013_008"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "……咳。",
        "unit_id": 134712,
        "voice": "vo_adv_9009013_009"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "初次見面，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "來自異國的人。",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n我是主宰這個世界的天空，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "偉大優雅的聖鳥，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "鳳凰！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n事不宜遲，",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我賦予妳教我如何演奏這個樂器的權利！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然並不是",
        "unit_id": 106113,
        "voice": "vo_adv_9009013_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所有阿斯特朗的人",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n都知道怎麼演奏太鼓……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過別管這個了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n就讓妳們見識一下我和搭檔",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在電玩中心練習的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大壞蛋流派撥擊！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拿娜、鳳凰",
        "words": "喔喔～！",
        "unit_id": 1,
        "voice": "vo_adv_9009013_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，",
        "unit_id": 106113,
        "voice": "vo_adv_9009013_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "華麗地上了～！！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看招看招看招～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喝啊～！！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拿娜、鳳凰",
        "words": "哇啊～！！",
        "unit_id": 1,
        "voice": "vo_adv_9009013_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯，",
        "unit_id": 106113,
        "voice": "vo_adv_9009013_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "差不多就這樣吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n雖然或許對於真的會演奏的人來說，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我可能只是在亂打一通啦。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "不過，",
        "unit_id": 134712,
        "voice": "vo_adv_9009013_015"
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "非常地帥氣……！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "我們第一次見到的太鼓演奏",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "鳳凰",
        "words": "\n是大壞蛋流派，真是太好了！",
        "unit_id": 134712
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看來",
        "unit_id": 106113,
        "voice": "vo_adv_9009013_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "吉歐‧格黑納的人很有品味嘛！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n接下來妳們就學我這樣",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "來打看看吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n用整個身體，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "總之要演奏得很華麗喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "感覺好有趣～！",
        "unit_id": 136212,
        "voice": "vo_adv_9009013_017"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "拿娜也要來玩來玩♪",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "好！",
        "unit_id": 106113,
        "voice": "vo_adv_9009013_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼這裡就交給妳們了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我要去別的世界",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尋找我的搭檔啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n妳們",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可要好好用大壞蛋流派來炒熱氣氛啊～！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拿娜她們的大壞蛋流派和太鼓周圍，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在不知不覺間聚集了一群人。"
    }
]