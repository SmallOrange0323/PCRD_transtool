[
    {
        "type": "background",
        "background": "500893"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "儘管順利當上了年神，但在激戰過後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n筋疲力盡的祈梨氣喘吁吁地一屁股坐了下來。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉，",
        "unit_id": 128311,
        "voice": "vo_adv_1283004_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "贏了雖然很好，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是有點累了呢……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我要稍微休息一下……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼啊啊……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……不覺得周遭很刺眼嗎？",
        "unit_id": 128311,
        "voice": "vo_adv_1283004_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "算了……",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呼嚕……",
        "unit_id": 128311
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}走在充滿新年氣氛的熱鬧商店街上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n注意到了一個眼熟的嬌小身影。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個是……",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "果然沒錯！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n錯不了的！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀啊啊啊啊啊！？",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n怎怎怎、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "怎麼了！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呃，",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "還以為是誰，原來是小哥啊。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我才要問你在這麼多人的地方做什麼？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n是發生什麼要報案的事件嗎？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "現在不是說這個的時候。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你看，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒錯，",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是擺在那個攤位上的玩偶！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n懂了吧？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "懂了吧？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啥？",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你不懂……？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以說外行人就是不行啊。",
        "unit_id": 106631
    },
    {
        "type": "still",
        "still": "128300401"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個是",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "龍膽掃帚老師以前設計的",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "龍寶寶！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我記得當初即將要製作成商品的時候，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n卻因為版權相關的爭議，而告吹了……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也就是說！",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那很有可能是夢幻稀有的打樣喔！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n沒想到竟然可以遇到這個，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "新年才一剛開始我就這麼走運！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "喔，",
        "unit_id": 1,
        "voice": "vo_adv_1283004_010"
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "小姑娘妳還滿識貨的嘛。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "\n雖然我們家的生意",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "老是被說什麼賣仿貨、假貨……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "\n不過也因為這樣，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "偶爾會有像這種有故事的東西來到我們這裡呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個當然是非買不可啊……",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我的壓歲錢全部給你，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "請你賣給我！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_1283004_012"
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "這可不行啊，小姑娘。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "\n我是擺攤的攤販，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "這邊擺的是抽獎攤。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "\n妳想要獎品的話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "就要實際抽中了才行。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只要抽獎就行了是吧？",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看我三兩下就抽中，把那個玩偶帶回家！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "哦，",
        "unit_id": 1,
        "voice": "vo_adv_1283004_014"
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "加油喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個小事一件啦，",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小事一件！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n總之，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你看著吧！",
        "unit_id": 106631
    },
    {
        "type": "still",
        "still": "128300402"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呃，",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "根本就抽不中啊啊啊！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是怎麼搞的啊！？",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你知道我花了多少錢嗎！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "哎呀，",
        "unit_id": 1,
        "voice": "vo_adv_1283004_018"
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "小姑娘的運氣不好呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "\n別難過，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "應該再抽幾次就會中了吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喂，",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這裡面真的有放中獎的籤嗎？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不管怎麼想都有問題吧！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我今年的壓歲錢已經全部都花在這上面了……",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n手邊卻只有跟垃圾沒兩樣的獎品……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "喂喂喂，",
        "unit_id": 1,
        "voice": "vo_adv_1283004_021"
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "別在那邊汙衊人啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "\n而且",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "還說跟垃圾沒兩樣，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "妳什麼意思啊？",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "128300403"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀、",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_022"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "呀啊！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "我們做的可是童叟無欺的老實生意，",
        "unit_id": 1,
        "voice": "vo_adv_1283004_023"
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "\n妳說那種話，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "已經等於是來砸攤子了啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不是，",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可是……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "要是搞得客人都不來了，妳要怎麼負責啊？",
        "unit_id": 1,
        "voice": "vo_adv_1283004_025"
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "\n妳說啊！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可、",
        "unit_id": 106631,
        "voice": "vo_adv_1283004_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可是",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我的壓歲錢……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥你說我們去其他攤位，你請客",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是嗎？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可是，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那怎麼好意思！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "怎麼，",
        "unit_id": 1,
        "voice": "vo_adv_1283004_027"
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "小兄弟",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "你很懂得分寸嘛。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "\n沒錯沒錯，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "這樣就對了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "\n趕快給我滾吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "小兄弟啊，",
        "unit_id": 1,
        "voice": "vo_adv_1283004_028"
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "你應該知道",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "射擊遊戲攤販",
        "words": "你在說什麼吧？",
        "unit_id": 1
    },
