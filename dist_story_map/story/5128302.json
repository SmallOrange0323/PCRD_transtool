[
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "當心點，",
        "unit_id": 127611,
        "voice": "vo_adv_5128302_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "它的狀態和剛才不一樣。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那傢伙",
        "unit_id": 127511,
        "voice": "vo_adv_5128302_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是一直被埋在沙漠中",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "被封印起來的對吧。",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "它是終於暖機好，",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以輸出開始提升了……",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是嗎？",
        "unit_id": 127511
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "意思是對方還沒有展現出真正的實力嗎？",
        "unit_id": 127611,
        "voice": "vo_adv_5128302_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那傢伙還真是相當小看我們呢。",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然如此，",
        "unit_id": 127611,
        "voice": "vo_adv_5128302_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就讓那個機關裝置明白……",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 127611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "它所面對的對手究竟是誰吧！",
        "unit_id": 127611
    }
]