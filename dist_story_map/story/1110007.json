[
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "因為優妮似乎有什麼話想說，\n於是{player}今天也被叫到「象牙之塔」了。"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗨，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n抱歉啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓你特地跑一趟。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為我也受了你很多的照顧。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所以我想，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "姑且有向你報告的義務呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我有兩件事要說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n有好消息與壞消息，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你想先聽哪一個？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你毫不猶豫地選了正向的選項呢。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你的這一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我倒是",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不討厭呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你呀，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你難道不知道這笑話的公式嗎？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "給我記好了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這種時候，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "從好消息開始選擇才是正確的做法。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "先從好消息開始。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我要說囉。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n把雙手舉高，做好大喊萬歲萬歲的準備吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個～",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "萬萬沒想到，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我弄丟的筆記本竟然找到了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你看在這裡。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n剛才有個不知名的教職員拿過來了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "謝謝你，同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n看見你如此雀躍地替我感到開心，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我也很高興呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好像是在焚化爐裡。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "似乎是工友碰巧看見，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n猜想著是不是被不小心丟掉了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以送到了學務處。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聽聞那句話的瞬間，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我全身上下剎那間不寒而慄。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想起來了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "換句話說就是我忘掉了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那的確是我",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "自己拿去丟掉的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我沒在開玩笑，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是真的忘得一乾二淨了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我可不是言而無信的話者啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這可不是妨礙認知這種小兒科的現象。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這已經可以說是操縱記憶的等級了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "甚至也能看成是維護著這個世界的系統",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "對我提高了警戒度。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "儘管能用感覺真不舒服來一語蔽之，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過算了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "無所謂。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這種不愉快的感覺終究會被洗淡然後忘卻吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這次的事件，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我認為能夠看做是世界對我發出的警告。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好漢不吃眼前虧。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我往後會成熟一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n比起主動糾正這個世界，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不如讓它來保護我還比較好。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "儘管難以釋懷，然而這也無可奈何。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "以後就不要懷疑神與世界，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n無知愚昧地活下去吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然我是無神論者就是了",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "反正，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "總而言之，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我拿回筆記本了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這樣這件事就算解決了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "世界和平安泰。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_018"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可喜可賀可喜可賀，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "耶～",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "原來如此，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_020"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來你",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還沒有搞清楚事態的發展呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你就保持這樣就行了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n被神盯上的只要有我一個就綽綽有餘了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "再來，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我要說壞消息了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n關於那個論文的事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這次決定不算數了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你問原因嗎？　",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "很簡單。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "「盤據在這世界上的根源性虛構」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我已經明白這個主題超出了我的能力範圍。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嚴格來說，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_023"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要把這個主題傳達給世界這事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是辦不到的就是了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_024"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "若要說得再具體一點。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n學院對我提出請求，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要求修改研究主題。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "應該說……",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_025"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n是「學會」透過學院，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "提出請求的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "反正，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_026"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "講白一點，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就是我的申請表",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒有通過審核。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "教務主任的修女希爾達也挺可憐的。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_027"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n她看起來好像相當困擾的樣子呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "似乎被嘲笑說「你們到底教導了些什麼給學生們」。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "據他們說，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我的研究",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "明顯地超出學問的範疇了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "似乎還說",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這種誇大的妄想給我到戲曲文藝中去做。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然他們根本聽不進去是很教人遺憾，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哼，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但不如說他們的反應跟我預期的一模一樣呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "至於為什麼？",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_030"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因為為了不讓身分卑微的我們胡思亂想，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所以這個世界總是平等地對所有人造成影響。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "即使對在學會被稱為有識之士的階層，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_031"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也無一例外。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "要是我的論文能成為契機，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓他們的妨礙認知被化解的話……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我本來是如此期待的——",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "——只可惜，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_032"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒能順我的意。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以說，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_033"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "{player}同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就遵從世界的意志，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓這個研究在今天畫下句點吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "從明天起，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們再來努力研究以前附近的考古學吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_034"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "為了養精蓄銳，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n總之今天就在此解散吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你在說什麼呢？",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_035"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我當然是很懶得重寫一次論文，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但只要撇開了這一方面，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我的求知慾已經得到了十分的滿足呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……怎麼了？",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_036"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n不是，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我是說真的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你不要一直用那種眼神看我啦。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_037"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n或許是有誤會，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我再補充一下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "聽好了，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_038"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我在此撤退，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "未必就是妥協了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也就是說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我雖然輸了比賽，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "卻贏得了這場勝負呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真要說的話，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_039"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是我心情好得不得了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你想想，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_040"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n世界對我造成了影響，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "也就是說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那位神妨礙了我的企圖呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "換個角度想，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_041"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n這不就是我更加接近了真理的反證嘛。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我說的沒錯不是嗎？",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_042"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是因為我接近了那不得讓人知曉的祕密，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n因此世界才對我進行了牽制。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這麼說你懂了沒？",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_043"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n對於我這從空想中所立下的假設，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那位神還特地畫了個圈告訴我在這呢！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這樣啊。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_044"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼我換個新的論述。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我以前應該",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "跟你這樣說過。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我的目的是「去知道」這件事本身。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "揭穿",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_045"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "亦或是散布，都不是我最終的目的。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我的終點是在那前面一點的地方。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "只要我知道，這樣就足夠了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "簡單來說。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_046"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n當我走到了能夠明白",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個世界是個大騙子的這個局面時，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那麼在這場遊戲中，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就算我「贏了」唷。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就算沒有拿到獎品，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_047"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我的勝利還是不可撼動的事實。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "來吧，同志，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓我們悄悄地為這場勝利舉杯歡慶吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n瞞著世界來細細品嚐這份喜悅吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不要緊，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_048"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我既不是勇者，也不是英雄。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不論是使世界回到那應有的模樣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "還是奪回那些失去的真相，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那些了不起的野心，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我打從一開始就沒有了呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "從明日起我這餘生，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_049"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就讓我更平穩地活下去吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我會離開塔，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "再次去挑戰過去所憧憬的薔薇色的學園生活，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n也不失是一種樂趣。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "一般上課、",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_050"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "社團活動、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "放學後女孩悄悄話大會……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不知道是否能再交到第二個、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "第三個朋友呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯嗯，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "夢想這不是更廣闊了嘛，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我也想要青春一下。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "對了，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_051"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我聽說近期會引進獎學金制度呢，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "畢竟也不能一直仰賴老人們給生活費，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n就算一次也好，我也去那說明會上露露面好了……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "因此這場遊戲就在這畫下句號，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_052"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "剩下的就遵從主的意思便行。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我想寬宏大量之神，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_053"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n只要看我乖乖忘記這件事，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n應該就不會特地對我降下審判之雷吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既然如此，盤據在這世界上虛構——",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_054"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那我不如就接受妨礙認知，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "和耿直的民眾一樣，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "把所有的謊言都吞下去。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如果世界說那就是真相的話，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_055"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那就隨便這世界吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_056"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這場遊戲。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n在我心裡，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是我贏了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "乾杯。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "優妮的臉上露出得意洋洋的勝利微笑。\n{player}雖然不懂那些困難的事，\n不過既然優妮都那樣說了，他也只好接受並踏上了回家的路。"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……嗯。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_057"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "如此一來，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_058"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嘛，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "對{player}來說，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n只要講了這些話大概就沒問題了吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "畢竟他很純真嘛。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_059"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n若我不好好讓他心滿意足地放棄去思考的話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "感覺他似乎會去胡思亂想許多事呢。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "…………還有就是，他似乎不太會隱瞞事情。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_060"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_061"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "反正",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我跟他說的大都是事實。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我不會揭穿世界的真理。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_062"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "既不是勇者也不是英雄的我，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "僅僅是知曉，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "然後獨自在心中愉悅地露出微笑就夠了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過啊，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_063"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "世界。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你這傢伙的祕密，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我可是有一瞬間握在了手中哦。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "縱使這一事實，或許終有一天會被我給遺忘掉也說不定，",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_064"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n然而在你的歷史上，這毫不起眼的汙點，卻會永遠留在上頭。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "活該啦你。",
        "unit_id": 111011,
        "voice": "vo_adv_1110007_065"
    }
]