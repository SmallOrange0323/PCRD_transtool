[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼……呼……",
        "unit_id": 106011,
        "voice": "vo_adv_9018156_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "成功了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n的確有點棘手……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n才第一天就這樣子……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看來這工作會變得很辛苦呢……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然武器的用法有點亂來，",
        "unit_id": 105811,
        "voice": "vo_adv_9018156_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但使用上卻莫名地熟練呢～",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "相較於阿斯特賴亞，這裡的野獸還比較兇惡……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這裡要被稱為充滿希望的樂園……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "似乎～有點不對勁喲？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊……！",
        "unit_id": 106011,
        "voice": "vo_adv_9018156_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　那傢伙好像又在偷偷收集什麼東西了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "偷到寶物就立刻閃人還真是有種啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別逃！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　貪吃佩可，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "快追～！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦……？",
        "unit_id": 105811,
        "voice": "vo_adv_9018156_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n啊、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "站住站住～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　不守規矩的傢伙～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也真是大顯身手了。",
        "unit_id": 105911,
        "voice": "vo_adv_9018156_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這下子村子可以暫時恢復安穩了吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "長期航海之後又討伐魔物……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "想必應該很累了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n回到村裡會開始準備晚膳，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "今天就請您好好讓身體休息吧。",
        "unit_id": 105911
    }
]