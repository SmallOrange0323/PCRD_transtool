[
    {
        "type": "dialogue",
        "name": "紅霧精靈",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 10712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "！",
        "unit_id": 128711,
        "voice": "vo_adv_5136322_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n分裂了！？",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "小心不要被附身了！",
        "unit_id": 135512,
        "voice": "vo_adv_5136322_001"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n就像我們剛才那樣子！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳們的話，",
        "unit_id": 135512,
        "voice": "vo_adv_5136322_002"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "應該不至於被它排除……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "頂多",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "會變得無法自由活動！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n藉此來奪走妳們的攻擊能力吧！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "奪走攻擊能力……",
        "unit_id": 128811,
        "voice": "vo_adv_5136322_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "意思就是讓我們失去力量嗎！",
        "unit_id": 128811
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……或許吧。",
        "unit_id": 135613,
        "voice": "vo_adv_5136322_004"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n從效率上來看，",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "它應該會鎖定最需要警戒的對手。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "意思就是它會以最強的人當作目標是吧！",
        "unit_id": 128711,
        "voice": "vo_adv_5136322_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要是攻擊的主力被牽制了，",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "會很傷呢……！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……不過，",
        "unit_id": 135613,
        "voice": "vo_adv_5136322_006"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n就算被附身還是可以把它趕出去的。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n就像我們剛才一樣。",
        "unit_id": 135613
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "它一定還會使出其他招式……",
        "unit_id": 128911,
        "voice": "vo_adv_5136322_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳們也要小心喔！",
        "unit_id": 128911
    }
]