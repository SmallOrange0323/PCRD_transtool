    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由於突發事故而與{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一起露宿野外的薇歐莉特。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n隔天，當她醒來時──"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "陽光好刺眼……",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_000"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "果然不習慣",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這樣的光亮呢……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生──",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_001"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "他",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還在熟睡著。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n看來，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "果然很疲憊呢……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這都是因為",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "昨天我給他添了麻煩的關係。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……趁現在，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_002"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "至少",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "整理一下儀容……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "昨天連在意的時間都沒有……",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_003"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "但我現在",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "既未打理頭髮，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "也沒有入浴。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "味道……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "沒有問題，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "應該吧……",
        "unit_id": 133111
    },
    {
        "type": "background",
        "background": "501370"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這邊這條河川的話，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_004"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "看來可以洗個臉呢。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "太好了……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "…………",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_005"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "好美……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "在這個世界，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_006"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就連水都能感受到生命力呢。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "而且……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "剛才水中發出亮光的，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是魚嗎？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "稍微",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "靠近一點看看──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呀",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_007"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……我、",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_008"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "啊……",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_009"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "看得到水面……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n看來，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我是掉進河川裡了呢……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我是已死之軀。",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_010"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n雖然",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不會溺死……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "但我不能",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_011"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "再讓騎士先生",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "擔心了。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n得快點",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "返回陸地才行……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……？",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_012"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n這種感覺……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "好像在哪裡……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……河水彷彿結凍般冰冷，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_013"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "手腳也變得無法動彈……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n只能束手無策地向下沉去……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這種感覺──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "知道？　",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "──在過去，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_014"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "應該也發生過這樣的事。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "但是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "當我試圖回想，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "胸口",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就好難受……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就像是",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_015"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "連心底最深處，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "都悄悄地逐漸結凍一樣……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n這份情感",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "究竟是……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……難道說，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_016"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是生前的……？　",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……！",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_017"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n騎士、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "先生……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不對──",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_018"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生應該正在休息才對。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我一定是因為太思慕騎士先生，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "才會出現幻聽──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……！",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_019"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不是、",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_020"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "幻聽……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "難不成，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是跟在我後面",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "跳進水裡……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n為了、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我……",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_021"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "真的，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "可以抓住這隻手嗎……？　",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "就連曾經一度死去，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_022"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "抵達彼岸之人……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n也能握住生者的手……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n並期望",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "一同攜手生活嗎……？　",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……騎士先生？",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_023"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n您為什麼",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "逐漸往下沉呢……？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n…………",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "難不成，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生您",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不會游泳……！？",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_024"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還請振作一點！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "請、",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_025"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "請您等一下！",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n盲目亂動的話，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "反而會……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呀！",
        "unit_id": 133111
    },
    {
        "type": "still",
        "still": "133100301"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呼、",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_026"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "呼……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是……",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_027"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n如果是水深的地方，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這身子會無法浮起……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
