    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "騎士先生……",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_050"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "他很在意",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我當時說的那些話呢……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……謝謝您。",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_051"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n那我就恭敬不如從命，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "來享用了。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……在蘭德索爾，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_052"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "會像這樣子",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "吃魚呀。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "在吉歐‧尼布爾黑爾，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_053"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不太能取得",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "「活著的」鮮魚。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "而且，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "說到火的話也是鬼火……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "在我們居住的世界，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_054"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "多半是像幽靈或殭屍，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n這類每天不進食也無所謂的存在……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "或許因為這樣，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "很少有",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "關於用餐的方式或想法。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "然而……",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_055"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那也是",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "吉歐‧尼布爾黑爾那邊的情況。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "現在，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我也想嚐嚐看",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "這條魚的滋味呢。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "可以的話……",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_056"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我想要吃到肚子撐的程度。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "那麼，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_057"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我要開動了……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n啊嗯……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "…………",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_058"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "真好吃……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "以新鮮的……",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_059"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "方才為止還活著的魚，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "現烤出來的肉。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "口感鬆軟，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "入口即化……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "明明很樸實，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "卻非常地好吃……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "果然我",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_060"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還是沒辦法",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "像騎士先生一樣吃下很多……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "但是，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我能吃得出這份美味。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "即便這副身軀十分冰冷，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_061"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "但依然可以熱愛生物、",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "感受喜悅，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "一同分享情感……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "倘若我對騎士先生的心意，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_062"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "已經壓抑不了。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "至少，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "想和他",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "更加親近一點……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我好希望能用同樣溫暖的手，",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_063"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "觸摸他看看……！　",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "好的。",
        "unit_id": 133111,
        "voice": "vo_adv_1331003_064"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我想格蕾斯她也正在擔心。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "不過……",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "接下來的路程，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "一定沒有問題的。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "察覺到自身心中願望的薇歐莉特。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雖然明白無法輕易實現，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但在雙眸中萌生出了對於未來的希望。"
    }
]