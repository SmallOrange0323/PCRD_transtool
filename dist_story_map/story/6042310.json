[
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ロゼッタの容態？",
        "unit_id": 111011,
        "voice": "vo_adv_6038310_000"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "　ああそうか、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ユニコプターもろとも炎上したから",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\nその後の安否が気になっていたのか。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "安心しろ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "やつは石だ",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "燃えん。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "試しにほれ、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "挨拶がてら、",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "なにか適当にオーダーしてみればいいさ。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "ぽーん！",
        "unit_id": 1,
        "voice": "vo_adv_6038310_001"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "　♪ぽぽんがぽん",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "（あそれ）",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "　♪ぽぽんがぽん",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "（よいしょ）",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\n顔が恐いぞクロエ君",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "　頭ちぇるったチエル君",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "　才色兼備のユニちゃん先輩",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\n三人揃えばユニちゃんズ",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "　ユニちゃん音頭でドソル晴れ",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "（うぇーい）",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "ぽーん！",
        "unit_id": 1,
        "voice": "vo_adv_6038310_002"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "　当該情報",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "「管理者の３サイズ」は",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "厳重にロックされています",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\n関連情報として",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "ミス・クロエの数値を取得！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\n上から順に、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "はちじゅ――",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ＯＫロゼッタやめるんだ。",
        "unit_id": 111011,
        "voice": "vo_adv_6038310_003"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "殺される。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君が無事でも",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ぼくと彼は殺される。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "きゅーん！",
        "unit_id": 1,
        "voice": "vo_adv_6038310_004"
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "　只今のコマンドに対して",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "乙女の脆弱性が発見されました！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "\nもう友達ではいられません！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "　この石の高鳴り、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "もしかして",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ロゼッタ",
        "words": "これが恋？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "ロゼッタ、",
        "unit_id": 111011,
        "voice": "vo_adv_6038310_005"
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "君メスだったのか……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "ユニ",
        "words": "そもそも雌雄の別があったのか……",
        "unit_id": 111011
    }
]