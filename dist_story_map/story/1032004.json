[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在蘭德索爾城鎮的雜貨店前\n發現了正在買東西的秋乃。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀！",
        "unit_id": 103211,
        "voice": "vo_adv_1032004_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是碰巧呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n能遇到{player}大人真是開心啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？你問我正在做什麼？",
        "unit_id": 103211,
        "voice": "vo_adv_1032004_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那個啊，我正出來採購我的公會「墨丘利財團」",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n所需要的東西啦！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦，你問我要買什麼？",
        "unit_id": 103211,
        "voice": "vo_adv_1032004_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是這個壺……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哎呀，",
        "unit_id": 103211,
        "voice": "vo_adv_1032004_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "壺在發著光呢，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為什麼呢……？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "光",
        "unit_id": 103211,
        "voice": "vo_adv_1032004_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "變強了……！　",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呀、",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呀啊啊啊啊！",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "510070"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "喂――球飛到那邊去囉――！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……他們看起來很開心呢……",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……{player}大人，你是從什麼時候開始在那裡的？",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你人真壞呢，對我搭個話不就好了……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你問我這麼專心的在看什麼，",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是嗎？",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我在看那群孩子們在玩的遊戲。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n看起來是相當有趣的東西。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "棒球？　",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是叫做棒球嗎？",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這名字，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好像聽過的樣子……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我記得父親大人似乎經營過類似的公司。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "原來如此，",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "先丟球，把球打出去，然後開始跑……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "最後比較彼此得來的分數啊！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那真是好主意呢！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n學習庶民的遊戲也是件好事呢。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n打擾一下，那邊的孩子們――！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "哦――？大姐姐，你們有事嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1032004_012"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果可以的話，能不能讓我們也加入",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_013"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那個叫做棒球的遊戲呢？",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "棒球？是可以啦。",
        "unit_id": 1,
        "voice": "vo_adv_1032004_014"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n大姐姐，妳是第一次玩棒球嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n妳先稍微丟個球看看啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這個就是棒球的球呀……",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這樣……丟嗎？嘿！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "好球―――！",
        "voice": "vo_adv_1032004_016"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "好厲害――！大姐姐，沒想到妳很會投球嘛！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵。我很擅長什麼都不想，",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_018"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n用盡全力投出去啊！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "那麼，妳也試著打擊看看吧！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可以啊。看來，我好像很擅長打棒球呢。",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這次我會很華麗地打回去給你看的！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "拿好這個金屬棒……好了。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "來吧，就麻煩你啦！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "…………嘿！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_022"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大姐姐……球棒跟球",
        "unit_id": 1,
        "voice": "vo_adv_1032004_023"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n完全沒有擦到邊啊――",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "打擊方面完全不行呢――",
        "unit_id": 1,
        "voice": "vo_adv_1032004_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "因、",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_025"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "因為跟投球時不同，球正在動啊！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我做不了那麼難的事情啦！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果可以的話",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n可以幫我把球先放在那邊嗎？",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "大姐姐，那樣就不是棒球，是高爾夫球啦……！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_026"
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n嗯，算了。喂――大家，人數也增加了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩１",
        "words": "\n我們來比賽吧！比賽！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那真是個好主意呢",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，移動到草坪上的秋乃及孩子們，\n分成了2個隊伍來進行比賽。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵呵，跟{player}大人同一個隊伍，",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_028"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真是令人安心呢。我們絕對要贏喔！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "話說回來，這位先生是哪位呢？",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_029"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "我出於興趣，正在當這些孩子們的棒球教練。",
        "unit_id": 1,
        "voice": "vo_adv_1032004_030"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "\n今天就冒昧地由我擔任主審。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "原來如此……棒球是種",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n受到大家喜愛的運動呢。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那麼，我們就開始吧――！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "１號小孩",
        "words": "我是1號打者，哲人！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_032"
    },
    {
        "type": "dialogue",
        "name": "１號小孩",
        "words": "\n來，儘管投吧！我會華麗地打回去的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嘿噫",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_033"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "１號小孩",
        "words": "嗚哇―――！好快～！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_034"
    },
    {
        "type": "dialogue",
        "name": "１號小孩",
        "words": "\n大姐姐，妳面對小孩子居然還那麼認真！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "雖說只是遊戲，",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_035"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但只要比賽就不可以輸。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這就是藤堂家的家訓！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "哇――！揮棒落空――！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_036"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "打者出局！三出局換場！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_037"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我成功啦～！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_038"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "謝謝！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_039"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我就用擊掌……來跟你分享喜悅吧！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵呵！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "來吧，輪到我上場打擊啦！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_040"
    },
    {
        "type": "dialogue",
        "name": "王牌小孩",
        "words": "嘻嘻嘻，妳打得到我的球嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1032004_041"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "那傢伙是我們的王牌！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_042"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n他可是能投出七彩變化球跟快速球的小川！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n大姐姐打得到的話，就試試看啊――！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我會華麗地打回去的！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_043"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n請投球吧！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "王牌小孩",
        "words": "哦呀啊啊啊！！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_044"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "好球―――！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_045"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這……！……抱歉，請暫停一下。",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_046"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我有點事情想跟主審說。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "暫――――停！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_047"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "妳怎麼了嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1032004_048"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "\n突然要求暫停……有什麼事情想跟我說？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "剛剛的球真的是好球嗎？",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_049"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "就我看來是好球沒錯……",
        "unit_id": 1,
        "voice": "vo_adv_1032004_050"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "\n妳、妳對主審的判決有意見嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "50萬日圓怎麼樣？",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_051"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "…………咦？",
        "unit_id": 1,
        "voice": "vo_adv_1032004_052"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只要你每將一顆好球說成壞球，",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_053"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我就給你50萬日圓喔。",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "比賽只要贏了就好了！　",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_054"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "假比賽？",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n棒球裡也不准比賽相關人士間的",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "金錢往來嗎……？",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "虧我還覺得這是個不錯的點子的說……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接著，比賽進行到最終回合。\n秋乃隊正以一分之差落後，\n迎向最後一局。"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嘿嘿――大姐姐，妳今天都沒有安打喔――！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_055"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n大姐姐出局的話，比賽就結束啦――！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "最終回合，兩人出局……",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_056"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n壘上有跑者，如果我打出全壘打，似乎就會是再見全壘打了……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n但我如果沒打出去，比賽就結束了……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒打出去就結束了……",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_057"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n沒有打出去就會結束了哦，",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "藤堂秋乃……！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "王牌小孩",
        "words": "嘿嘿嘿，妳緊張得全身僵硬呢。",
        "unit_id": 1,
        "voice": "vo_adv_1032004_058"
    },
    {
        "type": "dialogue",
        "name": "王牌小孩",
        "words": "\n我就用變化球來解決妳囉。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦、咦！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_059"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人……\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……說得也是！不把事情想得太複雜，可是我的優點呢！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嘿噫噫噫噫噫噫噫噫噫！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "王牌小孩",
        "words": "什、",
        "unit_id": 1,
        "voice": "vo_adv_1032004_060"
    },
    {
        "type": "dialogue",
        "name": "王牌小孩",
        "words": "怎、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "王牌小孩",
        "words": "怎麼可能！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呀―――――――！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_061"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我打到了！我打到啦啊啊啊！！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "都是多虧了你啊！謝謝你―――！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_062"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……咦？",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_063"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呀！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真、",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_064"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是抱歉……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n做了這麼難為情的……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦，怎麼了嗎？",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_065"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "好啦，我把球撿過來了……",
        "unit_id": 1,
        "voice": "vo_adv_1032004_066"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n碰一下大姐姐！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "出局――――！",
        "unit_id": 1,
        "voice": "vo_adv_1032004_067"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "\n比賽結束！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦咦咦咦咦咦！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_068"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "？",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "因為妳打出去的球沒有變成全壘打，",
        "unit_id": 1,
        "voice": "vo_adv_1032004_069"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n所以比賽持續進行了喔――",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎麼這樣……",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_070"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我竟然輸掉了……",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但是我沒有任何遺憾！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_071"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "因為我已經盡全力比賽了！",
        "unit_id": 103231
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "棒球……棒球真是種很棒的運動呢！",
        "unit_id": 103231,
        "voice": "vo_adv_1032004_072"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n改天再來一起玩吧！{player}大人！",
        "unit_id": 103231
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，辛苦了",
        "unit_id": 190011,
        "voice": "vo_adv_1032004_073"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "棒球嗎，",
        "unit_id": 190011,
        "voice": "vo_adv_1032004_074"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "感覺好像很有趣的樣子。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "充滿了人生歡喜與悲傷的運動……",
        "unit_id": 190011,
        "voice": "vo_adv_1032004_075"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "真好呢～我也來打看看吧……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑的啦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你剛剛看見的，是如同夢境一般的情景唷。",
        "unit_id": 190011,
        "voice": "vo_adv_1032004_076"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我想你醒來以後很快就會忘記的，所以不用太在意哦。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多的「記憶碎片」，",
        "unit_id": 190011,
        "voice": "vo_adv_1032004_077"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我就會再讓你做「夢」的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要好好加油喔。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～ ♪",
        "unit_id": 190011,
        "voice": "vo_adv_1032004_078"
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "奇怪……這裡是蘭德索爾……？",
        "unit_id": 103211,
        "voice": "vo_adv_1032004_079"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦，",
        "unit_id": 103211,
        "voice": "vo_adv_1032004_080"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人，你說你",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也看見了\n相同的夢了嗎……？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還真是件不可思議的事呢……",
        "unit_id": 103211,
        "voice": "vo_adv_1032004_081"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n話說回來，那個叫做棒球的遊戲，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真的是很有趣的東西呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對了！",
        "unit_id": 103211,
        "voice": "vo_adv_1032004_082"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我來把它推廣至蘭德索爾吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如此一來，我的前景就是成功的全壘打囉！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}看到秋乃開心地笑著，覺得真是太好了。\n日後，在蘭德索爾真的有棒球隊組成，\n又是別的故事了……"
    }
