[
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "噗……",
        "unit_id": 116211,
        "voice": "vo_adv_5064322_000"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "怎麼樣，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "只剩最後一擊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊！",
        "unit_id": 116311,
        "voice": "vo_adv_5064322_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "請看那邊！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n那傢伙好像開始在做奇怪的事！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "竟然展開了魔法陣？",
        "unit_id": 116411,
        "voice": "vo_adv_5064322_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可惡的憂妮們，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "到底想做什麼……",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我也不太清楚，",
        "unit_id": 116211,
        "voice": "vo_adv_5064322_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過到處都是破綻嘛。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n就趁現在速攻打倒那傢伙就行了吧。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我就上啦……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "等等，克蘿依！",
        "unit_id": 116411,
        "voice": "vo_adv_5064322_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n當心點，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這可能是個陷阱。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我現在開始解析，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在完成前不要隨意出手。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "喔，",
        "unit_id": 116211,
        "voice": "vo_adv_5064322_005"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好啦，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "既然我們的軍師都這樣說了……",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 14511
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀，",
        "unit_id": 116411,
        "voice": "vo_adv_5064322_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這是……！",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦？",
        "unit_id": 116311,
        "voice": "vo_adv_5064322_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "什麼什麼？",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "解析完畢了。",
        "unit_id": 116411,
        "voice": "vo_adv_5064322_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那個魔法陣",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是吸收空氣中的瑪那，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "再轉換成動力源。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是讓憂妮們的火力、輸出、運動性，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "讓一切都飛躍性地提升。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "雖然我說那只是個小垃圾，",
        "unit_id": 116411,
        "voice": "vo_adv_5064322_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但仔細想想，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "本來就是個一流的藝術品。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n相關規格也一定是一流的吧。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "創造出那個的人，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "肯定是個有名的藝術家。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "好啦，",
        "unit_id": 116211,
        "voice": "vo_adv_5064322_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那種話就免了。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n講白一點就是？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不該放著不管的。",
        "unit_id": 116411,
        "voice": "vo_adv_5064322_011"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "嘿～",
        "unit_id": 116211,
        "voice": "vo_adv_5064322_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "有趣喔。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "所以？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳還有其他話要說嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "欸嘿嘿，",
        "unit_id": 116411,
        "voice": "vo_adv_5064322_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "對不起。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "如果對不起有用，\n還要【王宮騎士團】做什麼！",
        "unit_id": 116311,
        "voice": "vo_adv_5064322_014"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊～真是的，",
        "unit_id": 116211,
        "voice": "vo_adv_5064322_015"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒辦法。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "我們上，琪愛兒。",
        "unit_id": 116211
    }
]