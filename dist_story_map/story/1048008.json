[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}在早上散步時，\n遇見正在送報紙的美冬。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼、呼、呼……",
        "unit_id": 104811,
        "voice": "vo_adv_1048008_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀，早安。",
        "unit_id": 104811,
        "voice": "vo_adv_1048008_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你在散步嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我從早上開始就在打工喔。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "必須送的報紙還有這麼多呢……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀？ 這是什麼，從報紙縫隙中透出了光……",
        "unit_id": 104811,
        "voice": "vo_adv_1048008_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呀啊啊啊啊啊！",
        "unit_id": 104811,
        "voice": "vo_adv_1048008_003"
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你！ 謝謝你今天過來！",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好期待採草莓呀！",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n情侶參加的話入場費只要半價，機會難得呢！",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為採草莓有時間限制，我們有效率地採吧！",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "外帶的份也要喔！",
        "unit_id": 104831
    },
    {
        "type": "still",
        "still": "104800801"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯――，在有限的時間內，",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n要怎麼做才能有效地採草莓呢……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "草莓似乎未必大顆就一定好呢。",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "必須綜合性地判斷甜度、顏色、光澤，",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n查出草莓的「品質」才行……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你從那邊開始判斷草莓的「品質」，",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n然後放進外帶盒裡。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "加油！ 你一定做得到！！",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "話說回來，這個盒子也太小了吧……",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "對了。",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n將草莓塞在腋下或兩胸之間帶回去如何？",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你不能放在褲子裡嗎？",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯，果然還是太過違反規定啊……",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "算了，沒關係，只要有外帶盒的草莓就好。",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……我想帶弟弟妹妹們的份回去啊。",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為我們家有很多食慾旺盛的孩子嘛。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "原本我會總是在打工，過著節儉的生活，",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n是因為我想讓家人過著舒適的生活。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯，對。剛剛坦白的那些事情，你是第一個知道的喔？",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n不要……告訴別人喔？",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？ 你說如果有什麼幫得上忙的，你也會幫忙？",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵呵，謝謝。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣的話，乾脆……你要不要也成為我的家人？",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n當作我家的支柱……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵呵，我開玩笑的。嗯，摘不了這麼多草莓呢。",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n來，嘴巴張開，啊――。",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好吃嗎？ 呵呵，太好了。",
        "unit_id": 104831,
        "voice": "vo_adv_1048008_022"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "儘管美冬有意無意地岔開話題，但仍\n一邊細細品嘗草莓的酸甜，一邊在心中\n想著：今天真是美好的一天阿。"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如何呢？ 這是我給你的禮物！ 你做了個好『夢』嗎？",
        "unit_id": 190011,
        "voice": "vo_adv_1048008_023"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這是我依照你跟美冬以前的記憶創造出來的『夢』，",
        "unit_id": 190011,
        "voice": "vo_adv_1048008_024"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n原來現在的你會採取這樣的行動呀。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而且還是採草莓，真羨慕啊～。",
        "unit_id": 190011,
        "voice": "vo_adv_1048008_025"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我也好想去呢，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "開玩笑的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，下次見囉～♪",
        "unit_id": 190011,
        "voice": "vo_adv_1048008_026"
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊！ 這裡是……",
        "unit_id": 104811,
        "voice": "vo_adv_1048008_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "剛剛的是夢？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦，你也做了一樣的夢啊……",
        "unit_id": 104811,
        "voice": "vo_adv_1048008_028"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵，我努力賺錢是為了弟弟妹妹們的事，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n被你知道了呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "又被你知道",
        "unit_id": 104811,
        "voice": "vo_adv_1048008_029"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我新的一面了啊……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但、但我也不討厭這樣……啦。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "是說，我送報紙的工作遲到了！",
        "unit_id": 104811,
        "voice": "vo_adv_1048008_030"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "再見……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦，你也要幫忙？",
        "unit_id": 104811,
        "voice": "vo_adv_1048008_031"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好――，那就有效率地邊慢跑邊送報紙",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n來鍛鍊體力喔！ 跟著我！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美冬和{player}今天也度過了\n有效率且愉快的一天……"
    }
]