        "type": "dialogue",
        "name": "社員1",
        "words": "不，",
        "unit_id": 911,
        "voice": "vo_adv_5046001_070"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "我會照約定來參加社團活動。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "久違地活動一下身體，對健康也不錯呢！",
        "unit_id": 911
    },
    {
