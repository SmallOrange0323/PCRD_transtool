        "words": "哎呀～？",
        "unit_id": 113511,
        "voice": "vo_adv_5046001_065"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我把掉在球場的球全部擦乾淨的話，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你們就會來練習的",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不是嗎～",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "妳真的從那時候開始就一直做到現在嗎！？",
        "unit_id": 5212,
        "voice": "vo_adv_5046001_066"
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n那種隨便說說的話",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "妳竟然當真？",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "腦袋沒問題嗎！？",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "你看？",
        "unit_id": 911,
        "voice": "vo_adv_5046001_067"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "我就說這老師果然",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "和其他傢伙不一樣吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n她真的是在為我們著想……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "要不然做不出這種事。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "說什麼蠢話！",
        "unit_id": 5212,
        "voice": "vo_adv_5046001_068"
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "老師什麼的，",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "全都一樣。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n根本沒一個是可以相信的！",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "她一定有什麼企圖！",
        "unit_id": 5212,
        "voice": "vo_adv_5046001_069"
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n我是不知道特約講師是來幹嘛的，",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n反正就是想拿我們找樂子裝好人吧！",
        "unit_id": 5212
