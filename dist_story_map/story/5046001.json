[
    {
        "type": "background",
        "background": "501090"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "成為沙灘棒球社顧問的美里，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n放學後，讓社員們到教室集合。"
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "幹嘛啊，",
        "unit_id": 5112,
        "voice": "vo_adv_5046001_000"
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "突然叫我來。",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "\n我很累想快點回去啊。",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀～",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大地，你來了",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我好高興呀～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這邊就是全部的社員了嗎～？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "是的。",
        "unit_id": 5013,
        "voice": "vo_adv_5046001_002"
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "大家都到齊了。",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "喂，",
        "unit_id": 5112,
        "voice": "vo_adv_5046001_003"
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "這個組合……",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒錯。",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "其實呢，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我有事要向沙灘棒球社的大家",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "報告～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我呀，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "成為社團的顧問了～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "啥？",
        "unit_id": 5112,
        "voice": "vo_adv_5046001_005"
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "妳說什麼？",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "美里老師",
        "unit_id": 5013,
        "voice": "vo_adv_5046001_006"
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "成為",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "我們的顧問了喔。",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家，",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "接下來就請多多指教了唷。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們一起往夏季全國大賽邁進吧～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "哼……",
        "unit_id": 5112,
        "voice": "vo_adv_5046001_008"
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "現在才找顧問已經太遲了。",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "\n而且我早就說過好幾次，",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "\n我再也不打什麼沙灘棒球了。",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "畢竟我們說到底是連規則都不懂的外行人。",
        "unit_id": 911,
        "voice": "vo_adv_5046001_009"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n現在才開始練，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "根本來不及啊。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "……哼，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "我本來就沒有要認真參加啦！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀～",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那為什麼要加入沙灘棒球社呢？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就算沒經驗",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也有點興趣吧～？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "妳才剛來，不知道也情有可原啦……",
        "unit_id": 911,
        "voice": "vo_adv_5046001_011"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n這個學校",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "有個無聊的規定，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n就是",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "所有的學生都必須加入社團。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "不過啊……",
        "unit_id": 5212,
        "voice": "vo_adv_5046001_012"
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "沙灘棒球會用到球棒和釘鞋對吧。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "這邊到處都是",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "適合用來打架的工具啊。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n成為社員的話，",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "這些道具就可以",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "隨我們用了嘛。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "我只是喜歡可以隨意地玩、不受拘束的社團。",
        "unit_id": 911,
        "voice": "vo_adv_5046001_013"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n我們的青春，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "不管是特約講師還是誰，都不准來阻礙！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "怎樣？",
        "unit_id": 911,
        "voice": "vo_adv_5046001_014"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "我看起來不像熱烈歌頌著青春的學生嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "是啊，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "你想得沒錯……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "不要緊，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "我就特別告訴你們吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "我就是這所學校裡反覆留級十多年……",
        "unit_id": 911,
        "voice": "vo_adv_5046001_015"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "人稱留級王的男人！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "所以啦，",
        "unit_id": 911,
        "voice": "vo_adv_5046001_017"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "我們不聽任何人的指導。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "如果無論妳如何都希望我們打沙灘棒球，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n就先讓我們看看妳有沒有當顧問的資格吧。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "說的沒錯……",
        "unit_id": 5212,
        "voice": "vo_adv_5046001_018"
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "沙灘球場上應該到處都有球。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "如果妳去把球全部撿起來，",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "幫我們擦乾淨的話，",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n倒是可以考慮考慮。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "不過我們只顧著玩，",
        "unit_id": 5212,
        "voice": "vo_adv_5046001_019"
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "東西到處亂丟都沒在收的，",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n現在應該髒得不得了啦。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n……大地，",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "你也覺得這樣可以吧？",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "哼，",
        "unit_id": 5112,
        "voice": "vo_adv_5046001_020"
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "關我什麼事。",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "要怎麼做隨便妳。",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "\n這跟我一點關係也沒有。",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "美里老師，",
        "unit_id": 5013,
        "voice": "vo_adv_5046001_021"
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "我也會幫忙！",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "\n我作為隊長，",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "請讓我協助您！",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "等等，",
        "unit_id": 5212,
        "voice": "vo_adv_5046001_022"
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "旭。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "這件事如果不讓老師自己做就沒有意義了。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n這是為了要證明，",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "她適不適合當顧問嘛。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n……所以要是你敢多管閒事的話，",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "就給我走著瞧。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "唔……",
        "unit_id": 5013,
        "voice": "vo_adv_5046001_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_024"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒問題唷～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我會和{player}一起完成，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "交給我們吧～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "抱歉，",
        "unit_id": 5013,
        "voice": "vo_adv_5046001_025"
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "老師……",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "不過，",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "我很高興您願意成為我們的顧問。",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "\n我入社的時候，",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "社團裡",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "就沒有顧問了，",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "\n這件事對這個社團來說，",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "是相當大的進步呢！",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "搞不好",
        "unit_id": 5013,
        "voice": "vo_adv_5046001_026"
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "因為這樣，",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "\n其他人也會想來打沙灘棒球呢……",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "別看大地那樣，",
        "unit_id": 5013,
        "voice": "vo_adv_5046001_027"
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "其實他非常喜歡沙灘棒球的。",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "\n如果社團能夠重整旗鼓的話，",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "也許他會願意回來……",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵，",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_028"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "為了大家",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我會加油的～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一起為社團努力吧～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "非常謝謝您，老師！",
        "unit_id": 5013,
        "voice": "vo_adv_5046001_029"
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "\n",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "……我會",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "去找個沙灘，",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "旭",
        "words": "自己練習的！",
        "unit_id": 5013
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，{player}，",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_030"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們去",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "球場吧～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "喔呀，",
        "unit_id": 2512,
        "voice": "vo_adv_5046001_031"
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "美里老師。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "妳和社員們談過了吧。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "\n",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "他們肯定",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "為了妳成為顧問一事在抗議吧。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "他們一開始好像感到很困惑沒錯……",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_032"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "只要我作為顧問展現出可靠的一面，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n他們就會來練習唷，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們已經約定好了～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "事情會這麼順利嗎……",
        "unit_id": 2512,
        "voice": "vo_adv_5046001_033"
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "\n就算妳打算履行約定，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "也不曉得他們真的有心要遵守啊。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀，",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_034"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這是怎麼回事～？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "啊糟糕，",
        "unit_id": 911,
        "voice": "vo_adv_5046001_035"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "忘了東西。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "……嗯？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "是新來的老師和校長嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "他們在聊什麼……？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "社員們大多是外行人，",
        "unit_id": 2512,
        "voice": "vo_adv_5046001_036"
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "沒有認真要參與的意思。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "\n只不過是按照學校規定加入社團，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "\n而球棒也不是用來打球的，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "只會用來做些下三濫的事情。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "和這麼差勁的學生談什麼約定？",
        "unit_id": 2512,
        "voice": "vo_adv_5046001_037"
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "光是和他們說話都浪費時間。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "\n妳可是任期有限的",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "特約講師。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "\n做這些沒意義的事，",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "並不會讓妳的時間變得有價值哦？",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "他們不過是一群什麼事都做不成，",
        "unit_id": 2512,
        "voice": "vo_adv_5046001_038"
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "\n一輩子自甘墮落、",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "毫無用處的人而已。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀哎呀……",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_039"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n那些孩子，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "絕不是",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "毫無用處的唷。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "每個孩子，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "都會有屬於自己的天賦～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "只是有些孩子，",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_040"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n在成長過程中，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還沒察覺到自己的潛能而已。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這一點，",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_041"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我認為",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不管是這邊的學生們，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n還是我平常照顧的孩子們，都是一樣的唷～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "肯定都能擁有美好的未來。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "雖然",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_042"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大部分的社員都沒有經驗，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但是若不試試看也不知道結果如何呀～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "說不定，",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_043"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家都能成為優秀的選手。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "而在旁守望著這樣的可能性，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n不就是身為老師的職責嗎？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "如果",
        "unit_id": 101511,
        "voice": "vo_adv_5046001_044"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "校長您還是認為不可能的話……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那就由我證明給您看。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我絕對會和他們，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一起去參加",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "夏季全國大賽的～！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "……我會誠心希望，",
        "unit_id": 2512,
        "voice": "vo_adv_5046001_045"
    },
    {
        "type": "dialogue",
        "name": "校長",
        "words": "妳這個不成熟的心願真的能夠實現。",
        "unit_id": 2512
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "那傢伙……",
        "unit_id": 911,
        "voice": "vo_adv_5046001_046"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "是認真這麼想的嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n還是",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "跟其他老師一樣，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "只是在有權勢的人面前裝模作樣而已……？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "就讓我們見識一下吧。",
        "unit_id": 911
    },
    {
        "type": "background",
        "background": "501100"
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "啊～",
        "unit_id": 811,
        "voice": "vo_adv_5046001_047"
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "真想睡。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "上課好無聊，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "乾脆翹掉吧。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "\n就沒有什麼",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "新鮮事可做嗎……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "\n",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "要不還是來欣賞一下鈴奈的寫真集吧……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "啊，",
        "unit_id": 5112,
        "voice": "vo_adv_5046001_048"
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "抱歉。",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "寫真集",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "還放在我家耶。",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "什麼！？",
        "unit_id": 811,
        "voice": "vo_adv_5046001_049"
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "你這傢伙，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "差不該還給我了吧！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "\n要是敢占為己有，我可饒不了你！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "新鮮事嗎……",
        "unit_id": 911,
        "voice": "vo_adv_5046001_050"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "話說回來，那位叫美里的老師，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "不就蠻有趣的嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n昨天，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "我看到她在和校長說話，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n總覺得她跟以往來我們學校的老師",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "都不一樣。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "感覺",
        "unit_id": 911,
        "voice": "vo_adv_5046001_051"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "她好像挺不賴的。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "感覺是來自森林，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "現在罕見的",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "熱血老師喔。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "……！",
        "unit_id": 5212,
        "voice": "vo_adv_5046001_052"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "很痛耶！",
        "unit_id": 911,
        "voice": "vo_adv_5046001_053"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "敢突然打我很有種嘛！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "不懂什麼叫敬老尊賢嗎！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "「感覺她好像挺不賴的」？",
        "unit_id": 5212,
        "voice": "vo_adv_5046001_054"
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n老師全都是一群",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "看不起我們的垃圾，",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "\n別說傻話了。",
        "unit_id": 5212
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "唔……",
        "unit_id": 911,
        "voice": "vo_adv_5046001_055"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "可是啊……",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "喂，",
        "unit_id": 811,
        "voice": "vo_adv_5046001_056"
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "大夥們！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "看那邊！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "社員2",
        "words": "\n球場的角落好像有人耶？",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "哼……",
        "unit_id": 5112,
        "voice": "vo_adv_5046001_057"
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "雖然不知道是哪個學校的傢伙，",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "\n就讓我們來教教他，",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "亂闖進別人的學校裡會有什麼下場！",
        "unit_id": 5112
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "等、",
        "unit_id": 911,
        "voice": "vo_adv_5046001_058"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "等一下。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "那個，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "該不會是……！",
        "unit_id": 911
    },
    {
        "type": "still",
        "still": "504600101"
    },
    {
        "type": "dialogue",
        "name": "大地",
        "words": "那傢伙……！？",
        "unit_id": 5112,
        "voice": "vo_adv_5046001_059"
    },
    {
        "type": "dialogue",
        "name": "社員1",
        "words": "一大早的到底在幹什麼？",
        "unit_id": 911,
        "voice": "vo_adv_5046001_060"
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "誰知道。",
        "unit_id": 5212,
        "voice": "vo_adv_5046001_061"
    },
    {
        "type": "dialogue",
        "name": "社員3",
        "words": "快點把她趕走。",
        "unit_id": 5212
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "501100"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家，",
        "unit_id": 113511,
        "voice": "vo_adv_5046001_062"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我等你們好久囉～",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "依照約定，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我正好把球",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "全都擦乾淨了喲。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "還有，",
        "unit_id": 113511,
        "voice": "vo_adv_5046001_063"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "髒掉的球衣也",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "都洗好了～",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我總是在幫孩子們洗衣服，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對自己的技術還蠻有信心的哦！",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n呵呵，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "是不是純白無暇～？",
