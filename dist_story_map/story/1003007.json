[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜與{player}\n正一如往常地進行修練……"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總是無俚頭的做同樣的修練不太好呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天要不要來點新挑戰？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要做什麼好呢……？",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了。這樣的如何？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果今天日落前，你能擊中我一劍的話，",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我就聽從你任何一件要求。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "像這樣有獎勵的話，",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你也會比較有幹勁對吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼？ 沒自信嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確，我要是拿出真本事，",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你在擊中我之前就會被我解決了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，不如這樣吧。",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不進行反擊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只防禦或迴避你的攻擊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣的話你也會多些勝算吧？",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但我倒是有自信可以逃到底就是。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，開始有幹勁了呢。",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那趕快開始吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n從哪開始進攻都無所謂喔。",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈！ 喝！ 呀！",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_009"
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種程度的攻擊打不中我的喔。",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且你若不更加集中精神──",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看吧？ 很容易就被我繞到你背後去了。",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果沒有我不反擊這條規則，",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這場對決剛才就結束了喔？",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真不錯。即使讓你見識到這麼大的實力差距，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你還是一副不放棄的表情呢。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這樣的心境是很重要的喔。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來吧，繼續進攻！",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你的實力只有這樣嗎？",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n快要日落了。時限快到囉。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你連擦邊都還沒做到呢，",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這樣下去就是我的勝利喔。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "直到最後都不放棄很了不起喔。",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是持續你現在的攻擊方式，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你絕對沒辦法擊中我一劍。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從剩餘的時間來看，下一次進攻就是你最後的機會了。",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "來吧，儘管攻過來！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這是！？",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今天最有氣勢的一擊呢！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "(但是不僅如此。",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這麼猛烈的攻擊是……？)",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你難道……捨棄防禦了嗎？",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "捨身的猛攻……",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n原來如此，你以自己的方式思考過了呢。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是對我不管用喔！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這種狀態下要是劍被彈開，就會破綻百出喔！",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n吃我最後一擊！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──啊，不好！",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我不能反擊！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦……？",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_025"
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……",
        "unit_id": 100312,
        "voice": "vo_adv_1003007_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n被擊中……一劍了？",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看來是我輸了……",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你最後的攻擊實在太猛烈了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n害我下意識就想反擊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，非常好的劍法",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是那種捨身攻擊不是什麼好策略。",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_029"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n如果一直選擇那種戰鬥方式，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n總有一天你會嘗到苦頭的。好好記住喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "即使戰鬥勝利，如果因此失去同伴……失去你，",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也無法稱作勝利。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果你發生了什麼事，",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果你有在反省，",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這次我就原諒你。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也確實地反省了，",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n接著該是給你獎勵了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "正如我們約好，你說什麼我都聽你的。",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有什麼想要我為你做的事嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有這麼多嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我倒是很怕被你要求什麼……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣就不算是獎勵了。",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼都可以啦，說來聽聽。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒辦法立刻決定的話，待會也沒關係喔。",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為這是你努力的獎勵，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我想好好地完成。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖說我有讓步，",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n能夠擊中我一劍還是很厲害喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你變得越來越強了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我對你很期待喔。",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就像我們曾經約定過的，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是時候將我的身後交給你也不用擔心了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，天也快黑了……我們回去吧。",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在這之後你有空嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要不要和日和她們一起吃頓飯？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了一直很努力的你，",
        "unit_id": 100311,
        "voice": "vo_adv_1003007_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們決定要辦場餐會來慰勞你。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "朝向歡樂的餐會，\n{player}和怜悠閒地走在回去的路上。"
    }
]