[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "紡希著手進行著時裝秀的準備工作，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但她卻發現了某個問題，獨自一人陷入沉思。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "事情怎麼會變成這樣……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我是報名了蘭德索爾時裝秀沒錯，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_001"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "可是卻沒注意到",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "報名的組別分得很細……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒想到我居然還搞錯，報名到了男裝組……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但重新送出報名申請好像會來不及……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果是男裝組，就不能請怜大人來當模特兒了，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_003"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且也得重新構思衣服的設計……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這種事能拜託的人就只有騎士先生……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是又委託工作給騎士先生，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n不就會搞得像是",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我很想見到他一樣嗎！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我這是怎麼了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "顧慮太多了嗎……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔啊！？",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_007"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你怎麼會在這裡！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "重要的是，你是什麼時候出現在這裡的？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你沒聽到我剛剛說的話吧！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……只是因為我一臉悶悶不樂，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以你很在意？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是這樣啊，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那就好……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好、",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好險啊……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我把腦中想的事",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "講出來了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你現在是在忙送貨的工作嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是這樣的話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我覺得你趕快把工作忙完比較好喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我的事不要緊……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這也不是什麼需要騎士先生你擔心的事啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好了好了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "工作加油喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……唉，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是嚇了一跳。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼會正好在",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我想到他的時候出現啦……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "難得都遇見了，那我請他幫忙不就好了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我為什麼要想這麼多呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唉……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_015"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總之，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "模特兒的事就先不管了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n至少得先來構思一下衣服的設計……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我幾乎沒有構思過男性的衣服，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要是有什麼不錯的人選就好了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……對了，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_017"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然騎士先生的體格稍微矮小了一點，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n但他有著恰到好處的肌肉，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "應該能當作設計衣服的參考……？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果是我認識的人，各方面確認起來也會很方便……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我接下來",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "跟在騎士先生的身後，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n才不是為了拜託他當模特兒，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而是為了時裝秀！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我到底是在向誰",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "解釋呀。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不管這個了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生好像是朝那邊……",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "跟上他了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哼哼哼，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "畢竟我平常追著怜大人跑可不是追假的呢！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要悄悄地跟在別人後頭，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過是小菜一碟！　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那麼，騎士先生他……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他好像在和老婆婆說話？　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "哎呀，",
        "unit_id": 611,
        "voice": "vo_adv_1054010_022"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "真不好意思，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "還麻煩你搬我的行李……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他好像還是跟往常一樣在幫助別人。",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_023"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "反正還滿剛好的，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就來觀察他一下吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣一看，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_024"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他果然很不可靠……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不是啦。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要看的並不是給人的印象，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而是體格。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……他的身高稍微低於成年男性的平均……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_025"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "反倒因此獲得了「不會帶給他人壓迫感」的好處……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他在幫忙搬送貨物。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "感覺很重耶……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他的胸部與雙腳",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "看起來並沒有過多的肌肉，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "卻意外地很有力。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他這個人，就是會立刻去幫助",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "有煩惱的人呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然看起來靠不住，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_027"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但實際上很溫柔……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呃，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "內在明明就和衣服的設計沒有關聯呀！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一看著他，思緒就會不小心偏向那裡去……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總之，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我已經差不多了解騎士先生的體型了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n接下來",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就得想想什麼樣的衣服比較好了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是說，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是忘記送貨的工作了……？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他總算開始送貨了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "沒錯沒錯……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好好地把貨送到……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那裡是送達地點嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還滿近的……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "嗚哇──！",
        "unit_id": 211,
        "voice": "vo_adv_1054010_031"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n這件衣服",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "是我剛買的耶～！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "哎呀呀……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_032"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "弄髒衣服了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n要是不馬上擦掉的話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "感覺會留下汙漬──",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_033"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生真是的，居然把披風當成是手帕在用！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "披風不是用來擦東西的吧……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不過，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_034"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算自己的衣服髒掉了，他也完全不在意。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生就是這樣的人呢……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果是要給他那樣的人穿的衣服，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_035"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不光是整體的設計，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n活動時的便利性",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "及布料的耐穿程度也得考慮進去才行……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……雖然很不甘心，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_036"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但我學到了一課。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "接下來要去……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他也差不多該回去送貨了吧？",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_037"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算再怎麼愛幫人，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "總是在繞路的話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n是沒辦法做好送貨工作的喔……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "差不多該回想起來了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_038"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "他又跑去找有困擾的人了！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個人",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "到底是怎樣啊……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n再怎麼無法對有困擾的人置之不理，也該有個限度吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "能夠率先去",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_039"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "幫別人的忙固然是好事一樁，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但這樣一來，不管過多久都沒辦法把貨送到吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "算、",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_040"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "算了，反正困擾的是騎士先生……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我呢，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "正好可以慢慢觀察他……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……啊──",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_041"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "討厭！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n真是拿這個人沒轍耶！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……騎士先生接下來應該會經過這附近才對！",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_042"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "搶先他一步過來，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是有人遇上困難，就去幫助那個人。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真是的……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為什麼我要做這種事情啊。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_044"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果是能像那樣幫助他人的騎士先生……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n他一定",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也會對我的請求……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_045"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就說那個人是",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "跟在怜大人身後的壞蟲了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "畢竟我只是無計可施，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "才把工作委託給他的……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而他也只是",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "因為是打工，所以才接受的……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……但為什麼",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_046"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要想到我們的關係僅止於工作，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我就會感到有些寂寞呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "那個～",
        "unit_id": 311,
        "voice": "vo_adv_1054010_047"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_048"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳、",
        "unit_id": 311,
        "voice": "vo_adv_1054010_049"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "妳該不會是",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "慈樂之音的紡希",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "吧？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_050"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我不是……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我果然沒認錯人！",
        "unit_id": 311,
        "voice": "vo_adv_1054010_051"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n我是",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "慈樂之音的粉絲，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "所以就算是從遠處看，也認得出來！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_052"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你稍微小聲──",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "咦？",
        "unit_id": 413,
        "voice": "vo_adv_1054010_053"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "有慈樂之音的成員在嗎？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "啊，",
        "unit_id": 411,
        "voice": "vo_adv_1054010_054"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "快看！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n站在那裡的人",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "不就是紡希嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "真的嗎？",
        "unit_id": 413,
        "voice": "vo_adv_1054010_055"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "\n不知道她願不願意和我握手？",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "但是",
        "unit_id": 411,
        "voice": "vo_adv_1054010_056"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "忽然這樣拜託她，搞不好會很失禮……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "糟、",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_057"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "糟糕了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是引起太大的騷動，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n之後會被製作人罵的……！　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊、",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_058"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊哈哈……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "經、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "經常有人跟我這麼說耶，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n說我長得很像她什麼的……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不不不，",
        "unit_id": 311,
        "voice": "vo_adv_1054010_059"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "才不可能是那樣的啦！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
