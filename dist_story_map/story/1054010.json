        "voice": "vo_adv_1054010_064"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗚嗚，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼辦……！　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_065"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是誰",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "忽然握住我的手……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好、",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_066"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "大、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "大家，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對不起！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們之後",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還會再辦演唱會的，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請一定要來參加喔──！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "咦？",
        "unit_id": 311,
        "voice": "vo_adv_1054010_067"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我難得遇見紡希耶！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "咦──",
        "unit_id": 411,
        "voice": "vo_adv_1054010_068"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "已經要走了嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對、",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_069"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對不起──！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "得、",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_070"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "得救了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好在有騎士先生拉著我的手，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n總算是擺脫人群了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……嗯？",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_071"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "拉著我的手……？　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等、",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_072"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等一下！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你想握我的手握到什麼時候啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "反正這裡已經沒有人了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不用再握了吧！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_073"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在不是生氣的時候呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那個，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_074"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "幫了我。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還有……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "打擾到你工作了，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對不起。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "唔……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_075"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那是因為……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "該說是我為了時裝秀",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n而在觀察其他人",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "吧，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我正在找模特兒……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我本來是想找怜大人當模特兒的，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_076"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過出了一點差錯，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "導致我需要找男性模特兒……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_077"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我並不是想拜託騎士先生……！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦、",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_078"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也沒跟他說會有酬勞，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這麼說，這明明不是工作，但他也願意接受……？　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……不過，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_079"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "模特兒可是很辛苦的喔？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這麼輕易地答應真的好嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算你握拳表示肯定……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_080"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "你真的有了解我說的話嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要是你真的有心做到那種程度的話，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是可以交給你啦……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的真的嗎？",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_081"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我真的",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "能拜託你嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……後悔什麼的，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "事到如今要放棄什麼的，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我可不允許你這樣喔！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……騎士先生同意幫忙了。",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_082"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我對男裝組的服飾",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "完全沒有信心……不過，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "雖然只有一點，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "但我感覺有幹勁可以好好努力了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "早知道就不要煩惱這麼多，",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_083"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n再更早一點來拜託他就好了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好……",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_084"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不光是穿起來要舒適合身，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也得讓騎士先生看起來很帥氣才行！　",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……我的苦瓜臉不見了？",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_085"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這一定是你的錯覺啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這",
        "unit_id": 105411,
        "voice": "vo_adv_1054010_086"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "肯定、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一定、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "絕",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "～對不是託騎士先生你的福啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雖然紡希嘴上否定了{player}所說的話，"
    },
