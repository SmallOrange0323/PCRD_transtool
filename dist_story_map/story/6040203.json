    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "既然小栞正在努力，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我也沒辦法偷懶了呢……",
