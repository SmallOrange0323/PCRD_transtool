    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "玩具工廠的午休時間──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n珠希正在工廠裡向職員宣傳自己的鯛魚燒。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "「珠希鯛魚燒店」",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "開張喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要不要來份飯後點心喵～？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "職員1",
        "words": "珠希！",
        "unit_id": 1,
        "voice": "vo_adv_1168001_001"
    },
    {
        "type": "dialogue",
        "name": "職員1",
        "words": "我要一份鯛魚燒！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員2",
        "words": "也能給我來一份嗎！？",
        "unit_id": 1,
        "voice": "vo_adv_1168001_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "謝謝惠顧喵♪",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我馬上做喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "呵呵呵……",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "肚子咕嚕叫我也開心喵……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n因為這表示我生意好到連午飯都沒時間吃喵……！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過……",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣下去，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "下午會撐不住的喵……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真是連貓咪的手都想借來用喵……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要給我吃喵！？",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚嗚……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "謝謝喵……！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯～！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就跟鯛魚燒一樣，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這單純的口感真叫人愛不釋手喵……！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "職員3",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_1168001_007"
    },
    {
        "type": "dialogue",
        "name": "職員3",
        "words": "沒有人……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員3",
        "words": "\n今天的鯛魚燒",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員3",
        "words": "已經賣完了嗎……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在不是細細品嘗的時候喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "等",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一下喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我馬上開始烤鯛魚燒──",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……咦？",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你要幫忙……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那真是太感謝了喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那我專心做鯛魚燒，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n{player}，請你去幫客人點餐喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "而謝禮當然就是！",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "鯛魚燒員工餐請你吃到飽喵♪",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與珠希同心協力，努力賣起了鯛魚燒。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}，",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "謝謝你喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "托你的福，賣了好多出去喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "只是……",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "一個人能做到的事終究有限，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要更有效率地製作鯛魚燒，不然就太嚴峻了。",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "看樣子，",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "將工廠的經驗學以致用的時候終於到了喵……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我要來開發",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "「自動鯛魚燒機」喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "下班之後",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就馬上來挑戰製作喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……呼，",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "又認真工作了一天喵。",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n已經獲得工廠長給予使用許可了，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "趕快開始動工喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "咦？",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為什麼{player}在這裡喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我以為你已經回去了喵。",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "看你一臉充滿幹勁的樣子……",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "莫非，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你還想要繼續幫忙喵？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不愧是我的搭檔喵♪",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "歡迎你一起幫忙喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "話是這麼說，",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但這也是我要面對的挑戰喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}，你就充當顧問，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n從旁支援我喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼馬上就開始喵……",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "看我的呀呀呀呀喵──！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "──如此這般，",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "「驚奇背包喵號‧第1版」",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "完成了喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "哼哼哼……",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可不能光看外表來判斷喵。",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "讓我來說明喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我現在揹的這個背包，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n裡頭會自動烤鯛魚燒出來喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "也就是說……",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "它從原本的工具包，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "進化成蘭德索爾首創的自動鯛魚燒機了喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過呢，雖然說是自動，",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "其實還是得用這個遙控器來操作喵……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總之，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "試著讓它做鯛魚燒看看喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "看好喵，",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n在背包中烤好的鯛魚燒，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "會由內部搭載的手臂拿出來，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n然後交到你手上喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你看，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就像這樣……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……嗯嗯？",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n手臂沒有拿出鯛魚燒喵……？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真奇怪喵……",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "難道是訊號沒有接上喵？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然如此，就拿遙控器",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我揮我揮我揮！！！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n只要這樣用力揮……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "看吧，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "動起來了喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好啦，",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "把鯛魚燒拿過來喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……咦？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈哈哈哈哈！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n好癢喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是怎麼回事喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}！",
        "unit_id": 116811,
        "voice": "vo_adv_1168001_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "快阻止這支手臂喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不是，",
        "unit_id": 116811
    },
    {
