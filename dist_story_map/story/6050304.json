[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "鬼魂教父",
        "unit_id": 114111,
        "voice": "vo_adv_6050304_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就像是馬修他們的團長",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n一樣的人吧？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真不想在那種人手下工作呢。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒錯，",
        "unit_id": 114111,
        "voice": "vo_adv_6050304_001"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "你說的對！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "說出那種話是不行的吧！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在這方面，",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "純是絕對不需要擔那種心的！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可以安心跟隨她！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "對啊，",
        "unit_id": 114111,
        "voice": "vo_adv_6050304_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "現在的團長是紡希呢。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果是紡希的話，",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就可以安心跟隨她了！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "她雖然很嚴厲，",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過很溫柔呢！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "就是一點都不坦率！",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那是指在鬼魂教父手下工作",
        "unit_id": 114111,
        "voice": "vo_adv_6050304_003"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "的話吧？",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "在紡希手下工作沒必要逃跑啦。",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "而且，",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "如果逃走的話……",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一定",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "會更可怕，",
        "unit_id": 114111
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "還是別想了。",
        "unit_id": 114111
    }
]