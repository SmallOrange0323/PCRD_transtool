    {
        "type": "dialogue",
        "name": "旁白",
        "words": "伊莉亞理解了蘊藏在自己體內的力量有多巨大。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她展現出的力量超越了被收集起來的「傳說的吸血鬼之力」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n粉碎了布拉德的盤算。"
    },
