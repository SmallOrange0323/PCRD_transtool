    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣好嗎？",
        "unit_id": 100811,
        "voice": "vo_adv_5120007_020"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n剛剛明明有那麼多粉絲在這裡。",
