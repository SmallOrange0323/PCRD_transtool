        "name": "伊莉亞",
        "words": "雪啊。",
        "unit_id": 126212,
        "voice": "vo_adv_5120007_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在也還在追求永恆之美嗎？",
        "unit_id": 126212
    },
