    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真是太好了呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n你能見證永恆之美誕生的瞬間喔♪",
        "unit_id": 100811
