    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "能被世界第一美麗的我認可，",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這可是件很光榮的事呢。",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呼……",
