    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來征服世界。",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身不打算照著名為傳說的過去",
