    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妳不照平常一樣",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "說「如果是美麗的我的話就怎樣怎樣」嗎？",
