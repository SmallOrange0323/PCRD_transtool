        "voice": "vo_adv_5120007_005"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "要征服世界是輕而易舉的吧……",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……或許吧。",
        "unit_id": 126211,
        "voice": "vo_adv_5120007_006"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "崇拜您的部下們",
        "unit_id": 9811,
        "voice": "vo_adv_5120007_007"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "也聚集過來了……",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "伊莉亞大人……！",
        "unit_id": 1611,
        "voice": "vo_adv_5120007_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……哼。",
        "unit_id": 126211,
        "voice": "vo_adv_5120007_009"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n追尋傳說而聚集起來的魔物們啊！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "看好了！",
        "unit_id": 126211,
        "voice": "vo_adv_5120007_010"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "！？",
        "unit_id": 1611,
        "voice": "vo_adv_5120007_011"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這就是",
        "unit_id": 126212,
        "voice": "vo_adv_5120007_012"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身現在的樣子。",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "身高變矮，",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "魔力變弱，",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "完全沒有威嚴！",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "你們追尋的傳說",
        "unit_id": 126212,
        "voice": "vo_adv_5120007_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "已經不在這裡了！",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "忘掉一切──",
        "unit_id": 126212,
        "voice": "vo_adv_5120007_014"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "想去哪",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就去哪吧！",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "……是，",
        "unit_id": 1611,
        "voice": "vo_adv_5120007_015"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "遵命……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "這是為什麼啊……",
        "unit_id": 9811,
        "voice": "vo_adv_5120007_016"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "伊莉亞大人……",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "征服世界",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "是您的宿願……！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……確實是那樣沒錯。",
        "unit_id": 126212,
        "voice": "vo_adv_5120007_017"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身總有一天",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "會征服全世界。",
