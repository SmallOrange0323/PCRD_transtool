        "voice": "vo_adv_5120007_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是魔力耗盡了嗎？",
        "unit_id": 100811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "……這是多麼、",
        "unit_id": 9811,
        "voice": "vo_adv_5120007_002"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "強大的力量……！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "居然超越我耗費漫長時光，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "收集起來的魔力……！",
