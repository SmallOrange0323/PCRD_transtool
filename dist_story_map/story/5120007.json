    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "現在在這裡的妾身才是統御黑夜之人。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身沒有理由會輸。",
        "unit_id": 126211,
        "voice": "vo_adv_5120007_004"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "如果有那個力量的話……",
