        "voice": "vo_adv_5120007_021"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "如果利用那傢伙準備的東西，",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n或許能走近路征服世界吧。",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "照著傳說的內容征服世界。",
        "unit_id": 126212,
        "voice": "vo_adv_5120007_022"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "但那樣子──",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
