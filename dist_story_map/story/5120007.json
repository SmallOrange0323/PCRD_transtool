        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身",
        "unit_id": 126212,
        "voice": "vo_adv_5120007_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n要跟自己挑選的夥伴一起，",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "靠自己獲得的力量",
        "unit_id": 126212
