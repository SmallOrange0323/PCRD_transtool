        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那是當然的。",
        "unit_id": 126211,
        "voice": "vo_adv_5120007_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n不管是傳說之力還是什麼的，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那些都是過去的遺物。",
