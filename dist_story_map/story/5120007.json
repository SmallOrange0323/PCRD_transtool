        "voice": "vo_adv_5120007_018"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "並不是現在。",
        "unit_id": 126212
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "……是",
        "unit_id": 9811,
        "voice": "vo_adv_5120007_019"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
