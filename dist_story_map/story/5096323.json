[
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……雖然勉勉強強戰鬥到了現在，",
        "unit_id": 122611,
        "voice": "vo_adv_5096323_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n不過牠真的好強……！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是啊，",
        "unit_id": 122511,
        "voice": "vo_adv_5096323_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對方也拚盡了全力。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n從現在開始，我們可不能有絲毫疏忽喔……！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "儘管如此，",
        "unit_id": 122411,
        "voice": "vo_adv_5096323_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們也不會輸的！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n因為打贏牠之後，",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們要一起",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "開心地在海邊玩！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈哈……",
        "unit_id": 122511,
        "voice": "vo_adv_5096323_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不愧是日和呢。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n戰鬥的理由真是簡單。",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不過，",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "卻讓我湧出了",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "空前絕後的力量……！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯……",
        "unit_id": 122611,
        "voice": "vo_adv_5096323_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也還想",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在海邊盡情玩耍。",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n和大家、",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "還有騎士先生一起！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們和魔物，",
        "unit_id": 122411,
        "voice": "vo_adv_5096323_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哪邊的願望更強烈！",
        "unit_id": 122411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就讓我們在這個夏天的陽光下，",
        "unit_id": 122511,
        "voice": "vo_adv_5096323_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "證明這件事吧！",
        "unit_id": 122511
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果要比誰的願望更強烈，",
        "unit_id": 122611,
        "voice": "vo_adv_5096323_007"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我是不會輸的……！",
        "unit_id": 122611
    },
    {
        "type": "dialogue",
        "name": "三人",
        "words": "我們上吧！",
        "unit_id": 1,
        "voice": "vo_adv_5096323_008"
    }
]