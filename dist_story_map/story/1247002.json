        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "患者1",
        "words": "我不太想再繼續吃了。",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "患者1",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "患者1",
        "words": "醫生，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "患者1",
        "words": "有適合的中藥能代替嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
