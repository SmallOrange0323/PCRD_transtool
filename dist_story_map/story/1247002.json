        "voice": "vo_adv_1247002_004"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「技術高超、口風緊」引起了話題，患者不斷增加。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n深月與{player}忙到連喘口氣的時間都沒有──"
    },
    {
        "type": "background",
        "background": "501892"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呼，",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "終於把第一天的患者都看完了呢。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你也辛苦了。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "之後就剩晚上的急診患者而已，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們趁現在休息一下吧。",
        "unit_id": 124711
    },
    {
        "type": "background",
        "background": "500653"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我記得是在這附近……",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "找到了，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "足浴！",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "在這裡",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就能跟你一起泡了。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "來，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "脫掉吧脫掉吧……♪",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呼……",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_008"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n真溫暖……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還以為外面的公共浴池會很冰，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "竟然還滿燙的呢……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是啊……",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但即使如此，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "若要開發新藥，這些還是完全不夠……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……咦？",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "「明明都這麼已經不擇手段賺錢了」",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "嗯，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你會這麼想也不奇怪……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "…………\n開發新藥，",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_011"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "大多都會失敗。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不斷地反覆試驗，",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就像在失敗的沙漠中，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "尋找那唯一一粒的成功……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n即使是我也是如此。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_013"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "錢",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "無論再多，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "都還是完全不夠。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就像是朝熊熊燃燒的火焰車，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不斷投進香油錢一樣……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……啊。",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_014"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "討厭，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我怎麼說這種事……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可不是喪氣話喔？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……不過，",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要對惠理子她們保密哦，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "知道嗎……？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "──咦？",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "「不再多收點費用嗎？」",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這樣？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這麼單純的問題，真有你的風格。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是啊……",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_017"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n反正都不合法，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n把價格再哄抬得更高也行……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……不過啊。",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n可惜的是，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "密醫也是在做生意啊。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n得讓地下社會的人成為常客，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "才經營得下去。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以，",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_019"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "呵呵，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然這麼說很奇怪……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n即使索求高額治療費，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "把握「分寸」也是很重要的。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒錯。",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n……而且。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我也是生活於黑社會的人啊。",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n和患者是一丘之貉。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n沒辦法做出那麼殘忍的事情啦。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……是密醫。",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_022"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……你、",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_023"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "你啊……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "討、",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "討厭……！",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我先說清楚，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我會臉紅是因為溫泉很燙。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這裡的溫泉，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是不是太燙了啊……",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我說，領班～！？",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "──啊，",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_025"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "足浴根本就沒有領班嘛！",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "………………",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真是的，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不要捉弄大人。",
        "unit_id": 124711
    },
    {
        "type": "background",
        "background": "500653"
    },
    {
        "type": "dialogue",
