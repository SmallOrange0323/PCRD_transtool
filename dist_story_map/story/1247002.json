    {
        "type": "dialogue",
        "name": "患者2",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "患者2",
        "words": "醫生，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "患者2",
        "words": "妳口風緊，技術又高超吧？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "患者2",
        "words": "能幫我看看嗎？",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "當然可以。",
        "unit_id": 124711,
        "voice": "vo_adv_1247002_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n舊傷新傷未來的傷，",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "全部都來給我看吧。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "高價安心的",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "祕密治療定額契約，我也受理喔～！",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "患者們",
        "words": "唔喔喔喔喔喔！",
