    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可以照顧你一輩子喔。",
        "unit_id": 124711
    },
    {
        "type": "dialogue",
        "name": "患者2",
        "words": "這是舊傷。",
        "unit_id": 6311,
        "voice": "vo_adv_1247002_002"
    },
    {
        "type": "dialogue",
        "name": "患者2",
        "words": "\n沒辦法給正經醫生看……",
        "unit_id": 6311
