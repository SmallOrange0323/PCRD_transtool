        "voice": "vo_adv_9058155_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為主人吃得太香",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也不知不覺被影響",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n吃了很多……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如此資源豐富的森林",
