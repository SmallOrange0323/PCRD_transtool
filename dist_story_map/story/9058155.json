        "type": "dialogue",
        "name": "雪菲",
        "words": "更要想辦法把佔據在森林裡的魔物",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n擊退才行……",
        "unit_id": 106412
    },
