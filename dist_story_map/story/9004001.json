[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}收到了公會管理協會的聯繫，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n於是和花凜見了面。"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "久等了！",
        "unit_id": 118511,
        "voice": "vo_adv_9004001_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "讓你特地跑一趟，非常感謝。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "其實，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有點事想和你商量一下。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們公會管理協會",
        "unit_id": 118511,
        "voice": "vo_adv_9004001_001"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n需要收齊上一年的活動紀錄……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以我們正在尋找能夠幫忙的調查員。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "由於需要眾多人士的協助，",
        "unit_id": 118511,
        "voice": "vo_adv_9004001_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n所以我認為務必要將這項工作",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n交給人脈廣大的{player}先生……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請問意下如何呢？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "謝謝♪",
        "unit_id": 118511,
        "voice": "vo_adv_9004001_003"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "這是要麻煩你前去的地點清單。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請{player}先生向當地成員拿取",
        "unit_id": 118511,
        "voice": "vo_adv_9004001_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n裝有報告的信封。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "特別的獎勵已經準備好了，",
        "unit_id": 118511,
        "voice": "vo_adv_9004001_005"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以請多多努力哦！",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那麼，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我很期待成果豐碩的報告哦♪",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}接下花凜的調查委託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n動身前往清單上的第一個目的地。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……好像",
        "unit_id": 105812,
        "voice": "vo_adv_9004001_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "走掉了呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人……",
        "unit_id": 105913,
        "voice": "vo_adv_9004001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會祈求主人平安無事的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "事情沒有這麼誇張吧。",
        "unit_id": 106012,
        "voice": "vo_adv_9004001_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n又不是此生永別……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "照那傢伙冒失的德行來看，還真有點不放心呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼，",
        "unit_id": 106412,
        "voice": "vo_adv_9004001_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "花凜小姐。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n甚至要我們瞞著{player}不說，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那件想拜託我們的事情究竟是……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "好的。",
        "unit_id": 118511,
        "voice": "vo_adv_9004001_010"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "要麻煩【美食殿堂】的事情是……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "原來如此！",
        "unit_id": 105812,
        "voice": "vo_adv_9004001_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是好主意呢☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "就是這樣，",
        "unit_id": 118511,
        "voice": "vo_adv_9004001_012"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "有關這件事的一切，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n還麻煩各位先保密哦？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然如此，就不能讓主人知道了。",
        "unit_id": 105913,
        "voice": "vo_adv_9004001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下身為嚮導，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "要離開主人身邊，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是痛心……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那暫且先不提……",
        "unit_id": 106412,
        "voice": "vo_adv_9004001_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n花凜小姐所說的事情，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "格局還挺龐大的呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "得好好制定計畫並行動才行。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "關於這點，絕對萬無一失，",
        "unit_id": 105812,
        "voice": "vo_adv_9004001_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以敬請放心☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要大家同心協力，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定馬上就能完工的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難得有這種機會，就全力去做吧！",
        "unit_id": 106012,
        "voice": "vo_adv_9004001_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要讓那傢伙嚇一跳！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼……",
        "unit_id": 105812,
        "voice": "vo_adv_9004001_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "「至今為止＆從今以後大計畫」",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "正式開始！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，在{player}接受委託的背地裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n由花凜和貪吃佩可一行人主導的計畫祕密開始了。"
    }
]