        "voice": "vo_adv_5210051_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n突然之間，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "被誰這樣定罪的話，",
