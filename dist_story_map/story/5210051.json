    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但是，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果失去了記憶，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "連自己是否犯了罪都不知道的話呢──",
        "unit_id": 137412
