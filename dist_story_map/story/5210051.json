    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果是你，會怎麼做呢？",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要能證明自身清白，",
        "unit_id": 137412,
        "voice": "vo_adv_5210051_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也就是",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你自己，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "相信著自身的無罪──",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你會反抗吧。",
