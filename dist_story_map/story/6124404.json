        "unit_id": 2415,
        "voice": "vo_adv_6124404_000"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]就算是常常被女生包圍的你，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]應該也有「其實我最喜歡這個女生」",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]這種內心的想法吧？",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]說吧，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]你最喜歡的其實是誰？",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]",
        "unit_id": 2415,
        "voice": "vo_adv_6124404_001"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]惡",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]、靈",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]、退",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]、散！！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]",
        "unit_id": 2415,
        "voice": "vo_adv_6124404_002"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]喔、",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]喔……",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]她確實身材很好呢。",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]身材方面是啦。",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]不過，我說你啊，那個……",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]不，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]沒什麼。",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]",
        "unit_id": 2415,
        "voice": "vo_adv_6124404_003"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]巨乳！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]美腿！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]真讓人受不了對吧──！",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]可是啊──",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]我要是很陽光地跟她搭話，",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n[FFFFFFFF]她就會露出一副世界末日的表情……",
        "unit_id": 2415
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]好受傷啊……",
        "unit_id": 2415
    }
]