[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎、",
        "unit_id": 102511,
        "voice": "vo_adv_2002002_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎麼了？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大家一臉可怕的樣子……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "噓……",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n安靜一點，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看來是緊急情況。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說不定得要戰鬥。",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓客人們，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "先去避難可能比較好。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～……不行，雖然人家用了搜尋敵人的魔法，",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但看來公會之家被包圍起來了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n輕舉妄動的話，恐怕會受到攻擊。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦，咦？",
        "unit_id": 102511,
        "voice": "vo_adv_2002002_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "怎怎怎、怎麼回事？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，就是所謂的敵人來襲。",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然咱們【哞哞自衛隊】",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一直以來都很和平地進行活動……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "到底是誰呢？",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n實在摸不著頭緒為何會被襲擊。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……嗯？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "有腳步聲～！",
        "unit_id": 101711,
        "voice": "vo_adv_2002002_007"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n而且從正面而來！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好，讓我來迎擊～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等……等一下！",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是我，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不要攻擊啊～！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喔～？",
        "unit_id": 101711,
        "voice": "vo_adv_2002002_009"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n真琴，妳這樣會讓人弄錯啦～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "差點就要給妳一記空手道了～♪",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊哈哈……",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n太好了，看樣子妳已經準備好要迎擊敵人了呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "像往常一樣漫不經心的話，可是會被一網打盡喔～",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "敵人到底是誰呢？",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們都不清楚狀況。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯～……",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好像沒有時間仔細說明呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "反正，這整件事都是我的錯！",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n對不起！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n都是我輕率的舉動造成的，由不得辯解！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不需要道歉，真琴。",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們【哞哞自衛隊】是命運共同體，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不會把責任歸到一個人身上的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果是真琴的責任，那就是大家的責任。",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以呢，大家一起來想辦法吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "盡可能地跟我們說明來龍去脈吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃……",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "因為尾狗刀前輩感覺怪怪的，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n所以我才狠狠地逼問了他。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n一問之下，才開始看出這次一連串騷動的內幕。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "感覺尾狗刀前輩他……",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "當然，他的目的確實是捕捉那個叫矛依未還是諾維姆的女孩。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "但似乎還有其他事情逼得他無路可退呢。",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為了捕捉一個女孩，也太大費周章了。",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "使用了地雷魔方陣，還動用這麼多人襲擊……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我在那個時候就該察覺有問題了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為了召集戰力，",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n他甚至還拜託我這種",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n至今為止幾乎沒什麼聯繫的後輩……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "似乎有誰在暗地裡操控著一切。",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "尾狗刀前輩也被巧妙地利用了呢。",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "感覺那個笨蛋好像無法違抗幕後之人的意思。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是不是被抓住了什麼把柄呢？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "襲擊那輛馬車，",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n也是難以置信般的輕率胡鬧。",
        "unit_id": 104311
    },
    {
        "type": "still",
        "still": "200200201"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗚喔？",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n竟然破牆登場，還真是浮誇呢！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我記得這傢伙是【王宮騎士團】的……？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，按照禮貌還是報上名好了。",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n騎士只是一個稱謂，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n並沒有特別學習什麼優雅的禮節。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "來自地獄的禮物。",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n將我的名字烙印在腦海中吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我正是克莉絲提娜・摩根。",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可是榮耀的【王宮騎士團】中\n強悍美麗的副團長唷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今晚",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n為了驅逐在鎮上閒晃的野獸們，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n特地前來囉。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好，誰想第一個被殺呀？",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n至少死法和先後順序，我就讓你們自己選吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈哈……☆",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳這突然殺出來的傢伙，搞什麼啊！",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n竟敢襲擊我們的公會小屋，膽子很大嘛。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳是打算挑起戰爭嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果要打架的話，我奉陪到底！",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n放馬過來！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "忍耐一下，真琴。",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n出手的話就讓對手稱心如意了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那就真的會變成一場戰爭唷……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "別阻止我了，公主！",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_033"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n已經沒有商量的餘地了，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n他們個個可都是全副武裝啊！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這表示他們存心就是想來找碴的！",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_034"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不打倒他們，就會被他們給打倒喔！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈。",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真是有活力的小狗狗啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳想先死嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊？",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_036"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n妳可太得意忘形了，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n殺得了我的話就來試試啊！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不、不要受到對方的挑釁啊……",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真琴，幹嘛那麼激動呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸，克莉絲提娜？",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "身為【哞哞自衛隊】公會之家的公會長，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家想問問看，妳有何貴幹？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "到底是打什麼主意呢？",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "像這樣隨便來打擾，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是不是有點沒禮貌啊？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就算【王宮騎士團】是",
        "unit_id": 101011,
        "voice": "vo_adv_2002002_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n直屬王室的公會，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也不能這樣恣意妄為吧",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊～……",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈，真有膽識♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "以如此毫無畏懼的氣勢對我大放厥辭，",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然值得肯定，但妳的說話口氣不太討喜呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳這自作自受的無禮之徒！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正如妳所說，",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n國王陛下就是我們的後盾……是我們的錦旗！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也就是說，正義是屬於我們【王宮騎士團】的☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒用的，公主。",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_044"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n事到如今已經沒啥好談了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我說過我們是被陷害的了吧……",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_045"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那邊的，嗯，女僕小姐？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "問題出在那傢伙當時身處我們所襲擊的馬車上。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "欸？",
        "unit_id": 102511,
        "voice": "vo_adv_2002002_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是、是在說我嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對不起，都是我害的！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不，不是妳害的啦。",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_047"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不過，妳隸屬的公會很不妙。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳是隸屬於【公主騎士】旗下的公會吧？",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_048"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "啊，是的。",
        "unit_id": 102511,
        "voice": "vo_adv_2002002_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我隸屬的【咲戀育幼院】，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n是【公主騎士】旗下的公會。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "但那說到底也只不過是書面上的關係，",
        "unit_id": 102511,
        "voice": "vo_adv_2002002_050"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n實際上兩者幾乎沒有關聯。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "實際上有無關聯並不是什麼大問題。",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_051"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "糟糕的是，襲擊那輛馬車的……主要是",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們【哞哞自衛隊】所為。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "【哞哞自衛隊】是獸人們的互助組織，",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_052"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n為【動物苑】旗下的公會。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這點妳應該知道吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而【動物苑】和【公主騎士】，",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_053"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n無論是在過去的歷史或實際現況，關係都惡劣到極點。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "至今為止，到處都有小規模的衝突呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "直接了當的說，雙方是一觸即發的緊張關係。",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_054"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而這次的事件，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n成了引爆戰爭的導火線。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "襲擊那輛馬車，客觀上來看……",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_055"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就變成「【動物苑】襲擊【公主騎士】的成員，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n並打算殺了他們」。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "也就是說，",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_056"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們成為先挑起戰爭的那一方了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咦？",
        "unit_id": 102511,
        "voice": "vo_adv_2002002_057"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n但是我只是恰巧搭上馬車……？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大家也並不是將我當成目標對吧",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "沒錯，但他們把事情導向了這副局面。",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_058"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那幫人捏造了戰爭的理由，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "而襲擊那輛馬車，也是陰謀的其中一環。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "【王宮騎士團】，",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_059"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n正以「替被襲擊的自家人報仇」……為名目，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n藉此進攻我們的公會之家。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "實際上，從世人的角度來看，他們才是正義的一方。",
        "unit_id": 104311,
        "voice": "vo_adv_2002002_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正是如此，真是個聰明的孩子！",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真想抱抱妳、摸摸妳的頭呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過呢，實際上不論是什麼理由都好。",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正好尾狗刀小少爺處在一個好位置，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我只是趁機利用一下而已♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我已經厭倦單純溫吞的和平了！",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為想引發戰爭，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以我只是稍微從中做了點小動作唷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想不到這麼簡單就如我所願。",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "正覺得有點意外呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈哈……☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "相信管理這個世界的眾神們，",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_065"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n比起無聊的每一天，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "更想看看鮮血淋漓的世界！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這就是命運，你們只能放棄然後接受這一切了！",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_066"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一起愉快地展開死鬥吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果不想的話也無所謂，",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_067"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我來負責虐殺就好了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算對方沒興致，這場舞會還是可以繼續的！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧，【王宮騎士團】的同胞們，",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_068"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n一起一掃厭倦天下太平的憤鬱吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "用獸人們的血盡情地舉杯慶祝吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "愉快的宴席即將開始了，啊哈哈哈哈……",
        "unit_id": 107111,
        "voice": "vo_adv_2002002_069"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "☆",
        "unit_id": 107111
    }
]