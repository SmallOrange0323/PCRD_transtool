        "name": "現場負責人山田",
        "words": "啊，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "我",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "是隸屬紫藤工程股份有限公司，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n擔任本次排水企畫現場負責人的",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "山田。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "山田，",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_068"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "立刻報告！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n到底發生什麼事了！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "危險章魚",
        "unit_id": 1111,
        "voice": "vo_adv_5122002_069"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "出乎意料地過於危險，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "導致無法控制吸水側的水管……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "自稱「危險」，",
        "unit_id": 191011,
        "voice": "vo_adv_5122002_070"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "卻又說出乎意料過於危險……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "漁夫們",
        "words": "呀啊啊啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_5122002_071"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "不論是海裡、海面還是海灘上，",
        "unit_id": 1111,
        "voice": "vo_adv_5122002_072"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n它把各式各樣的東西都吸進去後，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "現在已經失控了！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "水管也因此",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "被異物給塞住了……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "吸水濾網呢？",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_073"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n難道沒有裝嗎！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "是的……",
        "unit_id": 1111,
        "voice": "vo_adv_5122002_074"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "雖然很難以啟齒，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "不過危險章魚",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n雖然名字裡有「危險」，但它原本是用於蓄水池的規格。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "由於非常非常突然地，",
        "unit_id": 1111,
        "voice": "vo_adv_5122002_075"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n收到了「現在立刻升級成海洋用規格」",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "這個緊急最優先指令……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "為了讓吸水效率達到最高極限，",
        "unit_id": 1111,
        "voice": "vo_adv_5122002_076"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "於是做出了「不裝設濾網」這個現場判斷。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "遵從上頭突如其來下達的指令，",
        "unit_id": 1111,
        "voice": "vo_adv_5122002_077"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n結果就是造成「偏離企畫原本的意圖」",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n這種大企業常見的犯蠢現象呢，是的。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你說……",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_078"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "什麼……？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "雖然這種話不是我該說的，",
        "unit_id": 1111,
        "voice": "vo_adv_5122002_079"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n但是海洋用規格的排水機器什麼的，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "不管怎麼想都太超乎常理了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "這種狀況下要是不裝設濾網，",
        "unit_id": 1111,
        "voice": "vo_adv_5122002_080"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n正如您所見，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "這已經稱得上",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "是兵器了呢。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "哈哈哈，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "這道理就連章魚都懂呢。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "…………原來如此。",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_081"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "為了不讓您成為專橫獨斷的大小姐，",
        "unit_id": 1111,
        "voice": "vo_adv_5122002_082"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n向您說出現場真相的忠誠部下正是我，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "山田，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "是山田我。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "在下次的人事調動，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "請務必讓我跳等升職。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "山田，",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_083"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是吧。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好的，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我記下來了。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "完全不負責任，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只報告現狀的職員，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "山田。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "看來你無論是",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_084"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在商家工作的自覺和技能都有所不足呢。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就讓你去參加我跟爸爸舉辦的",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "「熱血商人集訓」吧。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我會把你加入名單當中。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "……噫！？",
        "unit_id": 1111,
        "voice": "vo_adv_5122002_085"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n熱血商人集訓……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "是在職員當中被稱為地獄的那個……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "\n咦、",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "不、",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "不是的……！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "我接下來",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "才要負起責任──",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼你",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_086"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "現在就立刻……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "把濾網裝上去！！",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_087"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "遵、",
        "unit_id": 1111,
        "voice": "vo_adv_5122002_088"
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "遵命──！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "我現在、",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "馬上、",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場負責人山田",
        "words": "立刻就去！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……真是受不了。",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_089"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "看來",
        "unit_id": 6411,
        "voice": "vo_adv_5122002_090"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "水管阻塞",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n得由我們",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "來想辦法處理才行呢。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "不過看這暴衝的程度……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "會很棘手喔。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……哈、",
        "unit_id": 191011,
        "voice": "vo_adv_5122002_091"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "哈哈。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "似似花大人，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n看來",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "事情進行得不太順利呢。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不，",
        "unit_id": 191011,
        "voice": "vo_adv_5122002_092"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "這也是當然的吧。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "這種事情，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我打從一開始就覺得是辦不到的。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n看來不用擔心似似花大人的祕密曝光──",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不。",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_093"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……？",
        "unit_id": 191011,
        "voice": "vo_adv_5122002_094"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "憑藉秋乃的力量，",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_095"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要解決這個狀況只是時間早晚的問題……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "海水被抽光這件事",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_096"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "已經是無可避免的了。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……咦！？",
        "unit_id": 191011,
        "voice": "vo_adv_5122002_097"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "………………",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_098"
    }
]