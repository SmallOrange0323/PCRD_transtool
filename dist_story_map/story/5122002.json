[
    {
        "type": "background",
        "background": "502010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "得知異變的原因後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一行人移動到大間的海岸。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而對於秋乃所宣告的「把海水全部抽乾」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n大家仍舊一臉困惑──"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "秋乃……",
        "unit_id": 126811,
        "voice": "vo_adv_5122002_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "妳說要把海水全部抽乾？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是要抽乾、",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這片大海的、",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "水？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哦～呵呵呵！",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n除此之外還有哪片海嗎？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不、",
        "unit_id": 191011,
        "voice": "vo_adv_5122002_002"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不不不不不，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "等等等等！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n妳以為",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "大海究竟是什麼啊？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "這已經超過不知世事，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "完全是異想天開了。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "對吧，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "漁協協會長閣下。",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "謝謝……",
        "unit_id": 7511,
        "voice": "vo_adv_5122002_003"
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "太謝謝了……！",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "咦？",
        "unit_id": 191011,
        "voice": "vo_adv_5122002_004"
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "如果能幫幫我們，",
        "unit_id": 7511,
        "voice": "vo_adv_5122002_005"
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "那我真的是太感激了。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "就趁這個機會",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "徹底結束祕密廢棄服務……",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "所以……",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "拜託了，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "請淨化這片大海吧……！",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好的。",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "交給我們吧！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "不，",
        "unit_id": 191011,
        "voice": "vo_adv_5122002_007"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "請等一下──",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……請問一下。",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "萬一",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真的成功抽乾所有海水……",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n妳是打算將沉在海底的大量祕密魔物",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n一個一個",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "擊退嗎？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒錯，",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我是這麼打算的。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n只要大家同心協力，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就不可能會做不到。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "而且公主騎士大人",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "也在啊♪",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_011"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "漁協協會長。",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n從海底浮上來的",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那些小氣泡是什麼呢？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我從剛剛開始，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就覺得能聽見某種細微的聲音。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不是海浪聲，",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也不是少數觀光客對話的",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "某種聲音。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "啊啊，",
        "unit_id": 7511,
        "voice": "vo_adv_5122002_014"
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "那是祕密魔物的",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "「輕聲低語」。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "似乎",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "是各個魔物在呢喃著自己的「祕密」。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦……",
        "unit_id": 126811,
        "voice": "vo_adv_5122002_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "在呢喃祕密！？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在進行回收的當下，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就會讓祕密曝光",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "對吧？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "啊啊，",
        "unit_id": 7511,
        "voice": "vo_adv_5122002_017"
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "不過怎麼說，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "那恐怕是非常小聲的碎唸。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "如果不伸長耳朵貼著它、",
        "unit_id": 7511,
        "voice": "vo_adv_5122002_018"
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "拚命地仔細聆聽，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "\n應該是無法聽到各個魔物所說的祕密吧。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "那個音量就是這麼地小。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那、",
        "unit_id": 126811,
        "voice": "vo_adv_5122002_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼應該是沒問題吧。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "──啊，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "而且",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就算不小心聽見了，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n也不會知道",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "究竟是誰的祕密",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對吧……？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "啊啊，",
        "unit_id": 7511,
        "voice": "vo_adv_5122002_020"
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "關於這點，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "\n祕密魔物的身體上，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "也是會浮現出",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "\n",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "非常淺，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "淺到如果不把眼睛瞇到極限是看不見的，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "寫有物主的",
        "unit_id": 7511,
        "voice": "vo_adv_5122002_021"
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "名字、",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "地址、",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "以及聯絡方法，",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "\n的文字。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "聽說。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "聽海上的傳聞是這麼說的。",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這、",
        "unit_id": 126811,
        "voice": "vo_adv_5122002_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣不行吧！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這樣會讓祕密的內容跟主人曝光啊！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "…………確實、",
        "unit_id": 7511,
        "voice": "vo_adv_5122002_023"
    },
    {
        "type": "dialogue",
        "name": "漁協協會長",
        "words": "是呢……",
        "unit_id": 7511
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我覺得這樣風險太高了。",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "風險？",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "祕密",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是人人都想隱藏、廢棄的東西。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不該把那種東西，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "而且還是如此大量的祕密",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "攤在陽光下吧。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這樣是侵害隱私。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就算有個萬一，",
        "unit_id": 126711,
        "voice": "vo_adv_5122002_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "在淨化過程得知了那些祕密，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "但只要我們",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不把祕密說出去，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不就沒事了嗎？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那會是如此簡單的問題嗎？",
        "unit_id": 126611,
        "voice": "vo_adv_5122002_028"
    },
    {
