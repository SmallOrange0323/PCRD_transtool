[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啦啦啦，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n魔法～靈……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咕嚕靈，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咕嚕靈～……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，今天也是好天氣呢。",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n蘭德索爾也",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n非常和平♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "連人家也覺得很幸福呢。",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，明明在街上，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家卻覺得很想睡呀♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "乾脆到某個長椅上，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n睡一覺好了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一定超舒服的……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那種半睡半醒之間輕飄飄的感覺，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一定是最棒的享受♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n正好對面就有長椅呢……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嘿咻♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n陽光有點強。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "比起人家的故鄉，陽光有點太強了呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有帶陽傘來",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n就好了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要是曬黑了，就會變得像香織一樣了呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是人家不大能曬太陽……",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒辦法曬出健康膚色，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n只會皮膚變得紅腫刺痛呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "得做好防曬對策才行～",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n來研究看看那種魔法好了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "把那個魔法加上那個魔法，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n應用在一起的話……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，好像可以耶。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n果然像俗話說的擇日不如撞日呢♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "神奇真步魔法靈，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咕嚕靈波～……☆",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀？",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "又失敗了呀，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家真不擅長小型魔法。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯～……",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為了抵擋紫外線產生了水蒸氣，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n結果擾亂氣流就像引起爆炸了？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，可是……用魔法冷卻的空氣，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n輕飄飄地吹過來好涼爽呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還是個好結果呢～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "魔法公式再更精準一點的話，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n感覺可以當冷氣用了♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯？",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n咦？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "倒在那裡的是……王子先生？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這怎麼行？",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n躺在路邊的話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "衣服可是會髒掉的唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n弄得髒兮兮的……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好吧，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家用魔法讓衣服變得乾乾淨淨～♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯，那人家要施展魔法囉～",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "最近城鎮上很和平，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家的魔力都沒有發揮的機會♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，變乾～淨吧！",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "神奇真步魔法靈，咕嚕靈波～……☆",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生？",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_024"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n為什麼您在地上",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n滾來滾去的呢……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣做的話",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_025"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n衣服會變髒的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "別人說的話，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_026"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "得好好聽進去才行呀。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生是被人家的魔法",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_027"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n給吹跑了？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真抱歉呀……",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_028"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不知道為什麼，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家不管用什麼魔法都會變得像攻擊魔法。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "明明人家就",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_029"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不喜歡互相爭執或彼此傷害。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀～？",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_030"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "為什麼您要害怕呢，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生怕人家嗎？",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_031"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為人家是獸人？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們的確",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "和一般人類不同。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "古時候在蘭德索爾，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n獸人好像還被當成是魔物的一種……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊啊，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n因為種族問題而受到擺布的悲情戀曲……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生是普通的人類，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n所以不可能和人家這樣的獸人在一起嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嘿～",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生因為被剛剛的魔法直接命中所以快死了？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以才會這麼害怕呀。真抱歉耶～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家施展復原魔法看看吧？",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯、",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n雖然大概會有一半的機率",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n變得像攻擊魔法一樣……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那就不用了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗚～嗚嗚？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……真的是對不起呀。",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n會努力更精準地操控魔法的。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_040"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n都是人家不好，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n害您衣服變得破破爛爛的……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生願意的話，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_041"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要不要過來【哞哞自衛隊】公會之家呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_042"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n那裡有很多可以替換的衣服，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家也希望幫王子先生包紮傷口。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這樣會給王子先生",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_043"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n帶來麻煩嗎……？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的可以過來嗎？",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_044"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家太開心了，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這樣的話就讓人家來照顧王子先生吧……♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然人家笨手笨腳老是失敗，",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_045"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是人家想幫上",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n王子先生的忙。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "欸嘿嘿。",
        "unit_id": 101011,
        "voice": "vo_adv_1010005_046"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n時時刻刻地支持帥氣的王子，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是公主的職責嘛……♪",
        "unit_id": 101011
    }
