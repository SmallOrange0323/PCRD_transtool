[
    {
        "type": "background",
        "background": "500031"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "那天，諾維姆和尾狗刀完成工作，正在回家路上。"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯～",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_000"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "今天很順利就完成了呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "總之，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "先去吃個飯吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "……喂，尾狗刀，",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_001"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "有件事我之前就想問你，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n你用能力操縱怪物，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那樣有趣嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "怎麼",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_002"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "突然提這個？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "戰鬥不就是",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_003"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "要親手揍飛敵人嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n這樣子才有樂趣吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "但是，",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_004"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你卻交給怪物來戰鬥，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "自己在旁邊看戲，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我完全搞不懂這樣有什麼好玩的！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯～",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_005"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "關於這點，我們應該一輩子都找不到共識吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "首先，",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_006"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我並不喜歡戰鬥，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "而且也很不希望挨打受痛。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "而操縱怪物的能力能讓戰鬥落個輕鬆，",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_007"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n對我這種人來說，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是再適合不過了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "……這樣啊。",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "咦，",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_009"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳剛剛",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "是不是用帶著憐憫的眼神看我？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我沒有喔！",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_010"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你有喜歡哪種怪物嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這個嘛，",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_011"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "純粹火力強大的怪物還不錯。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n可以很快地結束戰鬥，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "相當方便喔。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "反過來說，如果要進行長期戰，",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n能賦予減益效果的怪物就會很出色。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "將對手蠶食鯨吞，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "也有一番風味。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還有，",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_013"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "弱小的怪物",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "依照使用方式不同，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "也能用來製造對手的破綻，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n這就是我",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "展現本事的地方了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "是喔，",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_014"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "原來你戰鬥時要考慮這麼多啊？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳終於明白啦？",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這樣可是挺勞心費力的呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "對了，",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_016"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "話說，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "最近我手上有一匹難以駕馭的野馬呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n強度雖然沒話說，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "但就是不受控這點讓我有些頭疼。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喔，",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_017"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "畢竟是怪物嘛，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "這也沒辦法。",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這樣就算了，",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_018"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "她小小一隻卻又吵到不行，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就算是我，也常被她搞得焦頭爛額呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喂，尾狗刀，你給我等一下，",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_019"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你說的野馬該不會──",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "啊～",
        "unit_id": 106211,
        "voice": "vo_adv_5111607_020"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "肚子好餓啊。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我們趕快去吃飯吧♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喂，站住！",
        "unit_id": 106114,
        "voice": "vo_adv_5111607_021"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你這傢伙，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "給我好好回答喔──！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看見尾狗刀落荒而逃，諾維姆氣得追了上去。"
    }
]