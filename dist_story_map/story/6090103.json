    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嘉夜小姐",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "原來和我同年齡呢……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "她不僅為人可靠",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "又很強，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我還以為她比我年長。",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "既然同年齡……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "如果也能和嘉夜小姐變親近……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我會很開心的……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嘉、",
        "unit_id": 121511,
        "voice": "vo_adv_6090103_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嘉夜……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "唔唔，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "感覺好難為情……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n要直呼其名",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好像還太早了……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n還是",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "繼續讓我叫她嘉夜小姐吧……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦？",
        "unit_id": 121511,
        "voice": "vo_adv_6090103_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "前輩也一起",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "是嗎……！？",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖、",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然會很緊張……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但這或許",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "的確是和嘉夜小姐變親近",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "的好機會吧……？",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "而且……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "和嘉夜小姐還有祈梨一起玩耍，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "感覺會很開心……♪",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "和嘉夜小姐打架嗎！？",
        "unit_id": 121511,
        "voice": "vo_adv_6090103_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這、",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這我怎麼可能",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "做得到啦！",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……啊，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "不過，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只要一直躲起來",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "就不會輸……",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "了吧……？",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "可是我也無法攻擊，",
        "unit_id": 121511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "所以也絕對不會贏就是了……",
        "unit_id": 121511
    }
