[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霸瞳皇帝被【憤怒‧軍團】盯上，\n因而被移送至地下深處的牢獄關押。\n同為七冠的迷宮女王拉比林斯達前來探望他。"
    },
    {
        "type": "still",
        "still": "106900201"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你好呀～",
        "unit_id": 106812,
        "voice": "vo_adv_1069002_000"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "最近過得怎麼樣，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真那？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "給我滾。",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_001"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳是我在這世上第二痛恨到想殺死的人，別讓我看到妳。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你就不能",
        "unit_id": 106812,
        "voice": "vo_adv_1069002_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好好回答我的問題嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "而且，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我怎麼不知道自己退步到第二名了？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n不過",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我跟少年畢竟是命運共同體，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "這樣也算霸榜吧？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳已經沒有閒工夫",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_003"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "特地跑來觸怒我了吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……真慘啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看來妳已經淪落要被小嘍囉任意使喚了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "哦，",
        "unit_id": 106812,
        "voice": "vo_adv_1069002_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "看得出來？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就是說嘛，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那些傢伙究竟什麼來頭？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "喔，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真那也不知道吧……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n畢竟「這個周次」",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就連你也是第一次經歷呢。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "愚鈍如妳想必毫無頭緒吧？",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_005"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n連這點程度的事態都無法預測，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "未免太過可悲了……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "什麼～！？",
        "unit_id": 106812,
        "voice": "vo_adv_1069002_006"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為了保護你免於敵人的迫害，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n儘管真～～的",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "很不情願，我還是做了許多努力耶！？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n光是沒淪為敵方工具這點，你就該感恩戴德了！",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "誰要感謝妳啊。",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_007"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n堂堂迷宮女王，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "竟然解不開別人的迷宮，笑死人了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "你這態度再不改一改，我可不會再保護你了喔。",
        "unit_id": 106812,
        "voice": "vo_adv_1069002_008"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你覺得",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那樣好嗎？",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就算妳想見死不救，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_009"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "終究還是會屈服於某個人，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n所以不保護我的機率無限趨近於零。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "底牌被你摸透透的結果就是這樣嗎……",
        "unit_id": 106812,
        "voice": "vo_adv_1069002_010"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我本來還期望你已經有反省之意的說。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我現在忙得不可開交，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好希望你能像從前一樣助我一臂之力……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我的答案",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_011"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳應該心裡有數吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n克莉絲跟似似花",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "比妳要明事理得多了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……是喔。",
        "unit_id": 106812,
        "voice": "vo_adv_1069002_012"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我果然還是無法說服你嗎……",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "就換下一棒",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "出場～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_013"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "晶。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳是明知會有反效果還這樣安排的吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n妳果然跟我是同類。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "陰險的女人……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "以其人之道還治其人之身囉。",
        "unit_id": 106812,
        "voice": "vo_adv_1069002_014"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那麼，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n接下來就讓你們兩個慢慢聊～",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "晚點見啦，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "少年。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_015"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在我心情最惡劣的時候不請自來，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你究竟",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "想要幹什麼？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……那孩子還是一樣蠢呢。",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_016"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n話說還真遺憾，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "世界竟然還沒毀滅。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哎呀？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "跟上次有些許不同呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "在你那得到某種東西的充實感背後，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_017"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我能明確感覺到。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n焦躁、",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "動搖、",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不安……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你在害怕？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_018"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵呵……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "就你這狀態，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_019"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n還想為其他人挺身而戰啊……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "令人作嘔。",
        "unit_id": 106911
    },
    {
        "type": "still",
        "still": "106900202"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "活該♪",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_020"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n知道在轉捩點後方等待著你的是什麼東西後，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你的臉上再也掩藏不住心底的恐懼了……！",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是蠢斃了。",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_021"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "以為打倒了我，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你們就有辦法戰勝「那個」嗎……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_022"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不對。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "「那個」甚至還沒現身……？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也對。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "畢竟你還安然無恙嘛……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那好吧。",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_023"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這次你的敵人很棘手喔。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "再怎麼掙扎也是徒勞。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "早早放棄圖個解脫吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_024"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你這句反問還真叫人火大。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你自己也曾經",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "無數次想要解脫，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n不會不懂我的心情吧？",
        "unit_id": 106911
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "106900201"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_025"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "沒錯。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "不信就算了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n反正現在的你還不明白那種",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n「一切都是白費力氣」的心情。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "話說都沒有人試圖灌輸你這種觀念也挺奇怪的……",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_026"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n可能是不想傷害到你",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "或是某個其他人的心靈吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我會坐在特等席上，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_027"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n細細品味你對上那傢伙時那悲慘掙扎的醜態。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "即便最終，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_028"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我又得因此再度",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "回到抗爭的輪迴……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……在先前那場戰鬥中，我已經向你透露一切了。",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_029"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那邊的世界",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_030"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "無法拯救我。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我無法得到能如我所願、",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "能如願以償的世界。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只要靈魂被困在人類的身體裡一天，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_031"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我就……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你就這麼容易開始同情我啦？",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_032"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "呵呵呵，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "未免太看不起我了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我本來",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_033"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "打算成為完全的神，君臨這個世界的。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n偏偏好死不死，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "出現了意料之外的阻礙……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那就是晶和你們一行人。",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_034"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "明明乖乖臣服於我就不會有事，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你們卻一而再地惹事生非。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "拜你們之賜，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_035"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我的計畫越來越脫軌，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n結果就是現在這樣……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "魔法神燈壞了，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_036"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n關在裡頭的魔神精靈",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也失去控制……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "現在支配這個世界的存在，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_037"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n即使對其說出一千零一夜的故事，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n也會被割下腦袋。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "只有你",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_038"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "一個人例外……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n儘管我不想承認，但確實如此。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那當然。",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_039"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你試想看看。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "除了你以外，其他不管是誰死了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這個世界都不會回溯。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我也好、",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "晶也罷，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "任誰都是一樣。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我還以為你在那場戰鬥中復活過來時，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_040"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就該有所覺察了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "看來並沒有啊……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我不知道那傢伙想除掉我們七冠的原因，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_041"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n和你挺身而戰的原因是否相同。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "但是，就我所知，敵人的目的，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_042"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "是你。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_043"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這麼說也不對。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n還有另一個人。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那孩子……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "這個嘛，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_044"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "究竟是誰呢……？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我被關在這裡太久，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "都已經忘記了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……稍微想一下就知道的事，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_045"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n別來問我好嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你這種情緒化的行動有多讓人頭痛，你明白嗎……",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_046"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n打從第一次見面起，你一直都是這副德性。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還有，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_047"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你要多點疑心，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "萬一我是騙你的呢？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "多讓我看看",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你那茫然失措的表情。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你說呢……？",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_048"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "對現在的我而言，怎樣都無所謂。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你們的未來我一點興趣都沒有。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n無法入手的東西，再怎麼在意也毫無意義……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……無論過去如何，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_049"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "現況就是我輸了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你們贏了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n作為敗者，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我會對自己的行為負起責任。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "雖然不知道那個囂張的紅眼鏡，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_050"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n是不是把跟你講廢話也列入我的責任之一了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你自己也要當心",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_051"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "別被他人使喚過度了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……要是落到連我都替你擔心，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "你可就前途堪憂囉？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那孩子",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_052"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是學不乖呢……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "還是一樣愚笨嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我不會吃的，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "給我也只是被丟掉",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "或是放著讓它腐敗而已。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "帶著它快走吧。",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_053"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我沒興致跟你多說了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……你究竟什麼時候，",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_054"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n才會實現我的願望呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……少年他沒有那個意願吧？",
        "unit_id": 106812,
        "voice": "vo_adv_1069002_055"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "偷聽？",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_056"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳還是一樣沒品呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "真那。",
        "unit_id": 106812,
        "voice": "vo_adv_1069002_057"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "如果你想要成為神，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n你就不應該",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對任何人做任何事。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n因為神的行動，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "對人類而言大多都是災難一場。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我不需要心理諮商。",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_058"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳給我出去。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "好嘛，",
        "unit_id": 106812,
        "voice": "vo_adv_1069002_059"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "出去就出去。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……話說少年他，",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n或許是想讓你看看",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "悲劇結局之後的發展吧。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n他應該也同樣想要",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "為打倒你這件事負起責任。",
        "unit_id": 106812
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……誰要他",
        "unit_id": 106911,
        "voice": "vo_adv_1069002_060"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "負那種責任啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霸瞳皇帝喃喃說道。聽到這句話，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n拉比林斯達對這位昔日夥伴的態度露出苦笑，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並轉身離開牢獄。"
    },
