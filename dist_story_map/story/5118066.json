        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]果然還是有點難為情哪。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]啊哈哈……",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]不過，",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_035"
    },
    {
