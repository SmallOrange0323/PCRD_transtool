    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]那之後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n情緒高昂的吉塔和妮諾就維持著該氣勢，"
    },
    {
        "type": "dialogue",
