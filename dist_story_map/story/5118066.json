[
    {
        "type": "background",
        "background": "500651"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]{player}和吉塔接下了給騎空團的委託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]運送貨物來大江戶。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n兩人送完貨後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]便在鎮上悠閒地逛著。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]畢竟都難得來到大江戶了。",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我們稍微觀光一下再回去吧。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]搞不好",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]還可以在這裡挖到什麼珍品喔。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]溫泉嗎……",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_001"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]聽起來也不錯呢！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n工作正好也都結束了，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]要不要乾脆就去泡泡溫泉呀？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "[FFFFFFFF]泡溫泉一事，",
        "unit_id": 1,
        "voice": "vo_adv_5118066_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "[FFFFFFFF]請暫且稍候是也！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "[FFFFFFFF]\n喝！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]著地！",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_003"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]我乃將軍之忠臣，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]妮諾！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n白晝下正大光明來參上！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]從、",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_004"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]從屋頂上跳了下來……？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n該不會，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]這女孩也是你認識的人？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]豈止認識，",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_005"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]我乃家臣是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]並且為",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]最重要的家臣是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]家……",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_006"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]什麼！？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]{player}對吃驚的吉塔"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n仔細地說明了自己與妮諾的關係──"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]原、",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_007"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]原來如此……",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]雖然剛才嚇了一跳，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]但我明白了。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]請多指教唷，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]妮諾！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]我才要請妳多多指教，",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_008"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]吉塔！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n今後還請多多關照是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]喔喔～！",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_009"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]好的，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]小的樂意奉……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]不對！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n真是太大意了……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]我有話想和兩位談談是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]之後",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_010"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]在大江戶",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]將會舉辦祭典。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]我正在幫忙進行該祭典的籌備是也。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]然後，",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_011"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]今天原本要拍攝",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]宣傳海報的照片……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]但",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]未料，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]模特兒卻感冒了是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]真糟糕！",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_012"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n那麼，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]現在對方沒辦法進行拍攝嗎？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]是的……",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_013"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]再加上，以目前的行程安排，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]拍攝也無法再延期了。",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n因此我才會四處奔波，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n尋找願意在這個危機狀況下出手相助的武士……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]就在此時，",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_014"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]正巧遇見我的將軍是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n還有",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]吉塔，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]妳！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我、",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_015"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我嗎？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]吉塔的身材",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_016"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]和模特兒幾乎一模一樣是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]相信服裝也一定會非常合身！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]今日在此相遇也是緣分，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]還請妳務必要幫助我是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]原來是這麼一回事呀。",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_017"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]好，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]交給我吧！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]感激不盡是也！",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_018"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]那麼，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]首先──",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]請讓我見識一下吉塔的靈魂吧！",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_019"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]竟然不是先換服裝嗎！？",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_020"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]祭典的靈魂……",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_021"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]那便是，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]充滿熱情的呼喊聲！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n聲音沒辦法拍進照片裡吧……",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]可別這麼說喔？",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n即使聽不見聲音，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]也是可以傳達心意的是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]這麼說確實有道理……",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_022"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]應該？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]也就是所謂的有感情的作品才能打動人心吧。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]嗯，",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_023"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我明白了！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n既然要幫，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]就要幫到底！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]就是這個志氣是也！",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_024"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]那麼，",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]還請妳跟著我喊出聲！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]嘿咻！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]嘿咻！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]嘿、",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_025"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]嘿咻！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]嘿咻！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]繼續！",
        "unit_id": 103011,
        "voice": "vo_adv_5118066_026"
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]要抬起心中的神轎是也！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]嘿咻！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
        "name": "妮諾",
        "words": "[FFFFFFFF]嘿咻！",
        "unit_id": 103011
    },
    {
        "type": "dialogue",
