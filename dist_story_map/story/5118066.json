        "name": "吉塔",
        "words": "[FFFFFFFF]反正拍攝時也很開心，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]結果好就行了吧。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]嗯！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]……啊啊，",
        "unit_id": 105712,
        "voice": "vo_adv_5118066_036"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]但果然還是有點丟臉啊～！",
        "unit_id": 105712
    },
    {
