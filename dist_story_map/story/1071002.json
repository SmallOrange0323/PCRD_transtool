[
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "不幸遭到【王宮騎士團】\n逮捕的{player}，\n正被克莉絲提娜半玩樂地審問中。"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喪失記憶啊……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼聽都像是在找藉口，充滿說謊的感覺呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然有可以看穿提出偽證與否的魔法存在，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但不巧的是我並沒有準備魔法師或魔法道具呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖是這麼說，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但要你提出",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n自己並非【拉比林斯】同夥的證據也很難吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不論何時，與其道出真相，說謊反而更簡單。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以，這樣吧。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_002"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我現在開始會給你簡單的測驗。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你只要能順利通過就無罪釋放，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就能回家了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如何，要試試看嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_003"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你要拒絕也無所謂。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只不過到時候，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會把你帶回「王宮」、關進地下監獄，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "並且在那裡花時間好好審問你一番就是了……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "無論你選什麼，我都會很愉快。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所以我才讓你選擇，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你想選哪個？",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n地點在這附近就行了吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好～測驗開始♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我很高興你選擇了能讓我更加愉快的選項，\n{player}。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "一直關在地窖裡也讓人要喘不過氣了，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_008"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我正好想活動活動身體。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而且，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很遺憾的是，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這傢伙的嫌疑老早就洗清了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我指派部下們去調查，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但他這次似乎真的只是湊巧路過而已。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "他在送郵件到深山裡的牧場途中，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不幸地碰到我們，遭到懷疑就被逮捕了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真無趣啊。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真希望能準備些更戲劇性的展開呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只不過，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不曉得「陛下」為何對這傢伙很執著……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我是不清楚什麼理由，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但我會以自己的方式稍～微調查看看的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好，要開始囉。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_013"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n測驗的內容很簡單，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我要你在這裡和我比試。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……既然喪失記憶了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那我說比試你也不懂吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "模擬戰、",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "練習對戰……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔～",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "想不到什麼好聽的說法。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "簡單來說，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就是希望你和我戰鬥。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我沒打算取你的性命，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這只是遊戲罷了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n但是萬一，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你能打倒我的話……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不對，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是能碰到我的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就無罪釋放你。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我和你約定。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_016"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n別看我這樣，我可是很重視義理的女人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我說過的誓言就是「絕對」。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好了，過來吧小子……",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_017"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不設定時間限制，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要用武器或是魔法什麼都可以。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n你就絞盡自己的智慧和勇氣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "上前來挑戰我吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來殺了我的無聊吧。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_018"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂喂，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不需要客氣啊♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……都不動呢。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_019"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難道是害怕了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還是你想說「不傷害女人」的那種蠢話嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我來讓你提起幹勁吧？",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "憑我們的話，要調查你身邊的事是輕而易舉。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你若不願當我的玩樂對象的話……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就把你心愛的家人、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "友人、",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "戀人碎屍萬段♪",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦哦～？　",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "乖孩子，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再更積極地攻過來吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n放心，我剛才說的只是玩笑話！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你要是壞了我的心情，可就很難說了！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好，儘管上吧！",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_023"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那就是你的全力嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "動作生澀又天真，真讓人不耐煩。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你是男孩子吧……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "加油啊加油啊♪",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看啊，你的腳邊出現破綻囉♪",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_024"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這麼輕易就被足掃給絆倒了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "連基本的劍術都沒有呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要不要我溫柔地教你啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n仔仔細細地……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓彼此",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_026"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "相親相愛直到衰老吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n直到死將我們分開為止！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "站起來！",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不准睡，小心我殺了你！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再讓我更愉快點啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "拜託你了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……喔。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不錯的眼神，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你在打什麼算盤吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "很好，就算是靈光乍現也好，全都試試看吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "否則的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你想碰到我就只能是痴人說夢喔！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哦哦？",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那道光是……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哈哈。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_030"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真可愛呢，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你是在尋求幫助嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這種杳無人煙的深山裡，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼可能這麼湊巧就有夥伴前來相助啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_031"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這傢伙全身都在發光？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊啊，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我有聽「陛下」說過。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這傢伙擁有強化他人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "尤其是能強化夥伴的能力。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但我聽說那能力\n有著無法強化自己的制約在……",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "實際上，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "使用能力讓他疲憊了吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n動作都變遲鈍了呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真不解他的意圖。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你在打什麼主意，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小子……？",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……呣！？",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n怎麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "野獸和野鳥都突然衝過來了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "連魔物也是……",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_037"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "所有傢伙都殺氣騰騰的，連肌力都增強了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是你用能力強化牠們的吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "要應付這些傢伙",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_038"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "會有些費力……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但這可是愚策啊，小子。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你不過是能夠強化周圍的對象罷了，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n並不能夠操縱牠們吧？",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看啊，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這不是連你都被動物和魔物襲擊了嗎……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "蠢貨，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "再多考慮後果啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那表情……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "是連這情況都設想過了啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不惜讓自己身陷危險也要強化野獸們？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你是想讓我忙著應付這狀況，再伺機行動嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不惜捨身也要讓對手陷入危機啊，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有趣！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不錯嘛，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "比想像中更像個男孩子呢……☆",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是太天真了！",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那種小聰明對我沒效，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "光這種程度還不夠！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你就更絞盡腦汁擬定計策吧，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_044"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我會華麗地把全部都給粉碎掉！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呣？　",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_045"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雨滴……？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "天氣預報",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "應該說過最近都會是晴天才對啊？",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500173"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "莫非……",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_046"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這傢伙連包含在大氣中，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n掌管水的精靈都強化……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "而讓雨降下來了？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "怎麼可能……",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_047"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n居然能改變天氣，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算是魔法也不可能。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這應該是只有我或「陛下」這樣的人才能夠發動的，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_048"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n超越人類智慧的奇蹟。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不好。",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_049"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不管是偶然或什麼原因，下雨可不妙。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "雖然不曉得原因，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但雨天會鈍化我的感覺。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我會下意識去計算降下的每一顆雨滴的動靜，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_050"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n這會讓腦內的運轉不過來……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不妙，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在這種環境下，會造成「絕對攻擊、絕對防禦」的機能出現缺陷。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "況且野獸們也仍然處於失控狀態，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_051"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我得忙著應付這情況，會無法集中在小子身上！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嘖，我太大意了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是非常不妙的狀況！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是！",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_052"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n輕易跨過這種程度的難關，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "才正是我克莉絲提娜啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈！",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_053"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n謝謝，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "比我想像中更愉快呢！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500173"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "接下來要怎麼辦？",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_054"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n難道想試試看瞬間移動嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n還是說你要變身成無敵豪傑嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你就引發無數次的奇蹟，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_055"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來攻略我看看吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……咦，哦哦？\n唔、呀？",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_056"
    },
    {
        "type": "still",
        "still": "107100201"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "大傻瓜！　",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_057"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "為什麼要倒向我這邊啊！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是被雨淋濕的地面讓你腳打滑了嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你這冒失的傢伙！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這裡要是戰場，你可早就死了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算了，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_058"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "重新開始！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n繼續交手吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這次我也會主動進攻了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……嗯？　",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_059"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你那是什麼表情？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n有什麼意見嗎？",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "107100202"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊……",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_060"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n的確，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "你碰到我了呢。",
        "unit_id": 107111
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500173"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "好不容易才正開始有趣了……",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_061"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我想說你要是一個跌倒昏過去就太無趣了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以才不禁上前抱住你。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "唔，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_062"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是我一生的失策。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "約定就是約定。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒辦法了，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_063"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就無罪釋放你吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但是，",
        "unit_id": 107111,
        "voice": "vo_adv_1071002_064"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我可完全沒有滿足喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我記住你的名字和長相了……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
