    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "妳說，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是不是超～級簡單？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……雖然有很多想說的，",
        "unit_id": 109811,
        "voice": "vo_adv_5017321_010"
    },
