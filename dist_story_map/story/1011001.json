[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哼～哼哼♪",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n舊舊二手衣～光彩奪目～♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哎呀，發現一家好店了！",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我真是幹得太好了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這也是多虧我平常表現良好的關係，",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是人間處處有洋蔥呢！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "媽媽很少給我零用錢……",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "【拉比林斯】也是個窮酸的公會，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "或者該說是會長的可麗餅店生意實在太慘澹了，發不出薪水。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "明明我也正值愛打扮的年紀～結果卻得度過灰色的青春。",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我好想把自己打扮得更亮麗，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "用色彩繽紛的二手衣讓自己光彩奪目～♪這樣！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呵呵呵。我有把裁縫技能學起來真是太好了！",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要收購便宜的舊衣服，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n再自己重新縫製成時髦的服裝，就能省錢了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "錢不夠的部分就花時間來做，時間就是搖錢樹！",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，我又發現一件漂亮的毛線衣……",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "非常便宜，只要100盧幣？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "價格便宜到讓人懷疑擁有者是否曾陸續遭逢不幸呢，",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個要買！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要將毛線鬆開，",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就能轉而織成手套或是圍巾之類的什麼都行。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過因為蘭德索爾周遭的氣候出奇穩定，",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不太需要那麼厚重的防寒衣物，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以才會賣得那麼便宜吧，嗯嗯？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔，我又發現一塊殘破不堪的布……",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯嗯，不過只要用同色的線縫補破損部分，就能用了吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n價格是～？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇！？",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，對不起！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我以為這是販售物品，不小心就摸下去了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦……哥哥？",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，是的！",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n午安！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "很、很平常地被哥哥問候，反而會嚇一跳！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "很抱歉，我不小心摸了哥哥的衣服……",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n因為購物太愉快了，我沒有注意到周遭！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "弓箭手的視野必須要寬廣，我會反省！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊……不是，那個？",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個，我呢，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不管對誰都會忍不住喊他們哥哥或是姐姐的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥有過這種經驗嗎？",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒遇過嗎？\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對不起！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（唔～怎麼辦……",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n會長說過，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n要我盡可能地別和哥哥接觸。）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（我都向哥哥搭話又摸了哥哥，",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "事到如今要我默默閃人也很沒禮貌，或者該說是很尷尬！）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（說不定哥哥還會覺得",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n『那孩子搞什麼？』而因此討厭我？）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個，",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請問哥哥是在找什麼東西嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "話說哥哥的衣服非常破舊……",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是遇到什麼事了嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥感覺就像經歷過爆炸一樣！？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔，哥哥是散步時遇到魔物襲擊呀？",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "明明是在城鎮裡？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，最近魔物是偶爾會跑到城鎮裡的。",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真的很危險呢，真受不了♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（啊，",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不小心和哥哥閒話家常了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n好痛恨自己有強大的溝通能力，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是和哥哥聊天真愉快～☆）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "（我一直都想這樣面對面地和哥哥聊天。",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是我總是忍耐著，盡量不接近哥哥……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥，我好寂寞喔。）",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。話說回來……",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥是因為衣服變得破舊，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以來買新衣服吧。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n讓我替哥哥斟酌挑選一件感覺不錯的吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，哥哥問我為什麼要這麼親切？",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個……是因為我家的哥哥告訴我",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n要溫柔對待有困擾的人！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，哥哥說他真是一個很棒的哥哥？",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是的，我最喜歡哥哥了……♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可是，這家舊衣店賣的都是女裝……那個，",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n只有賣女性服飾喔。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "難得哥哥是個帥哥，穿女裝的話感覺怪怪的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我有帶縫紉用具……",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_031"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥願意的話，我替哥哥把破掉的部分修補一下吧？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然我可能會縫得不太好。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為哥哥就這樣穿著破衣走在路上，實在太難看了。",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_032"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我先做個緊急處理稍加修補，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n之後哥哥只要再到男裝店添購新衣就可以了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇哇？",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_033"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n為什麼要摸我的頭，是表示哥哥覺得這是好主意嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥是在稱讚我吧。",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_034"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n雖然我很開心，可是在大庭廣眾下被摸頭很丟臉……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是的，哥哥真令人傷腦筋呢。",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n像這樣的肢體接觸，我只允許戀人或家人做的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "什麼？",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n啊，話說回來，我好像還沒自報名字……？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我叫璃乃。",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_037"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為總覺得和哥哥不像是第一次見面，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n連自我介紹也覺得怪怪的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，以後就請哥哥多多指教了！",
        "unit_id": 101112,
        "voice": "vo_adv_1011001_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果哥哥能好好地記住我的名字……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不要忘記的話，我會很開心的，哥哥♪",
        "unit_id": 101112
