        "voice": "vo_adv_1223001_008"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "沒人教過你嗎！？",
        "unit_id": 122311
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n不趕快收起來的話──",
