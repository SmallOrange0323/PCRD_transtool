    {
        "type": "dialogue",
        "name": "班比",
        "words": "啊──！",
        "unit_id": 122311,
        "voice": "vo_adv_1223001_006"
    },
    {
        "type": "dialogue",
        "name": "班比",
        "words": "\n你為什麼拿著小刀呢！？",
