[
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "background",
        "background": "510120"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "被可蘿約出來的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到了會合地點公園。"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您來了呀，",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_000"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不對，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "大人。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您忠誠的僕人",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "棗可蘿……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "前來見您了。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "是呀，",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_001"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下必須先解釋一下……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "請您先收下這個。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這是在下剛才在那邊的攤販買的可麗餅。",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_002"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "趁鮮奶油還沒流下來，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "快……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "請吃吧。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那個……",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_003"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "或許您已經不記得了。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "今天是在下和您初次見面的",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "日子。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "當在下問",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_004"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "「您是在下的主人嗎？」時，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您那訝異的表情，在下至今仍記得很清楚。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您也還記得嗎？",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_005"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n這真是",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "太令人高興了，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "謝……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n怎麼了嗎？",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您說",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_006"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "要付可麗餅的錢？",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您就直接收下吧。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這個可麗餅是用在下的零用錢買的，",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_007"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n讓在下聊表",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "祝賀和感謝之意。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n如果不會造成您的困擾的話，希望您能收下。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "好的。",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_008"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n那在下也一起品嚐吧。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呵呵，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您真的很體貼呢。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嚼嚼……",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_009"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "好甜呀。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n像這樣在外面吃東西，總覺得很神奇呢。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "該說是很開心呢，",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_010"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還是很雀躍呢……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n那個……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "怎麼了嗎？",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您突然摸在下的臉頰……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您幫我擦掉鮮奶油了呀。",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_011"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n謝謝您……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這……",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_012"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真是太讓人難為情了。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下的臉頰發燙，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "心跳得好快……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "一開始",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_013"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "只是米奈娃要在下見他一面……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n但正如米奈娃所說，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "他是一位很棒的人呢。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "難道在下現在感受到的雀躍和",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_014"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "心動，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n都是因為和這個人",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在一起嗎？　",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "啊，",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_015"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "嗯……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "在下沒事。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n那個……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您和在下",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "待在一起不會覺得無聊嗎？",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這樣啊……",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_016"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "謝謝。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在下",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "和您待在一起",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真的、",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真的很開心。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "包括",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_017"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "阿斯特朗傳奇在內，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n您帶在下去過很多地方，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "遇見了許多人。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這一切",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "全都是",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "託您的福。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_018"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "確實",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "拓寬了在下的世界。",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……如果",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您不嫌棄",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "的話，",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n今後在下也想與您一同看看新的景色……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "謝謝您！",
        "unit_id": 105932,
        "voice": "vo_adv_9006003_019"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n雖然在下還是個不成熟的僕人……",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n以後也請您",
        "unit_id": 105932
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "多多關照了。",
        "unit_id": 105932
    }
]