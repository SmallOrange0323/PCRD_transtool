[
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呀啊啊啊啊啊啊啊──────！！",
        "unit_id": 102511,
        "voice": "vo_adv_9078155_000"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n那、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那邊的人快逃啊～～！！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咦咦咦！？！？！？",
        "unit_id": 135512,
        "voice": "vo_adv_9078155_001"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n為什麼有人從天而降──",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哦、哦哦。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "接得好♪",
        "unit_id": 135512,
        "voice": "vo_adv_9078155_002"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "雖然不太清楚事情的經過，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但沒事吧？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n妳們兩位，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "有沒有受傷？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您",
        "unit_id": 105911,
        "voice": "vo_adv_9078155_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接住在下等人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n素昧平生的好心人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們",
        "unit_id": 102511,
        "voice": "vo_adv_9078155_004"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "迷路了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "所以想說爬到高聳的岩石上或許就能認清路……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真的很抱歉～～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "而且還讓妳接住我們……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "真不知該如何感謝妳才好……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_9078155_005"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不用在意啦！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n反正大家都沒事！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大姐姐我的確是",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "很有力氣啦♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "話說回來，",
        "unit_id": 135512,
        "voice": "vo_adv_9078155_006"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嚇了我一跳！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n沒想到會有女孩子從天而降！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "還以為又是日和呢！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "可可蘿、鈴莓",
        "words": "「您是日和小姐的熟人啊。」\n「妳是日和小姐的熟人嗎！？」",
        "unit_id": 102511,
        "voice": "vo_adv_9078155_007"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯？",
        "unit_id": 135512,
        "voice": "vo_adv_9078155_008"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我叫埃拉。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "跟日和算是熟人、朋友、",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也是自己人，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "或者該說是更～密切的關係？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以，",
        "unit_id": 135512,
        "voice": "vo_adv_9078155_009"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "能在這樣的地方",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n遇到認識日和的人，我很高興呢！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n幸好我有忍著寒冷走過來～！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊，",
        "unit_id": 135512,
        "voice": "vo_adv_9078155_010"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那個啊，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大姐姐我，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "經歷了很多事。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "現在有～點算是，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "正值冒險的年紀啦。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n但其實我也迷路了呢……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哈啾！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………嗯。",
        "unit_id": 105911,
        "voice": "vo_adv_9078155_011"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……♪",
        "unit_id": 102511,
        "voice": "vo_adv_9078155_012"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……嗯？",
        "unit_id": 135512,
        "voice": "vo_adv_9078155_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "兩位，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "怎麼了？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從埃拉小姐的服裝來推測，",
        "unit_id": 105911,
        "voice": "vo_adv_9078155_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您是從溫暖的地區迷路到這裡的吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然有您救了鈴莓小姐在先……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n恕在下冒昧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓在下來溫暖埃拉小姐吧……♪",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、",
        "unit_id": 102511,
        "voice": "vo_adv_9078155_015"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我也來！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "從另一邊溫暖妳～！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我抱──！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_9078155_016"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "超級溫暖的♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n兩位，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "謝謝妳們！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "既然都溫暖起來了，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "接下來那該往哪裡走呢……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哇哇！？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "咿啊！",
        "unit_id": 102511,
        "voice": "vo_adv_9078155_017"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n抱、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "抱歉！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我剛剛、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好像被什麼絆到了……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 105911,
        "voice": "vo_adv_9078155_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下有些",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不祥的預感。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "…………",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊……",
        "unit_id": 135512,
        "voice": "vo_adv_9078155_019"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n是妨礙",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你午睡了嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那麼，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳們兩位，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "稍微後退一下。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好──",
        "unit_id": 135512,
        "voice": "vo_adv_9078155_020"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大姐姐要上囉──！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n給我放馬過來！",
        "unit_id": 135512
    }
]