    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊……",
        "unit_id": 110832,
        "voice": "vo_adv_4010191_000"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "那個，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不好意思，雖然你都邀我了。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n但是，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "今天",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我不能太晚回家。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n如果要通宵的話，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "下週五晚上或許可以──",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "咦……",
        "unit_id": 110832,
        "voice": "vo_adv_4010191_001"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "謝謝。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "是說，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "怎麼了，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "原來你知道？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "是啊，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "今天",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "其實是我的生日。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我的家人好像",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "晚上要辦生日派對的樣子。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "很搞笑吧。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "咦咦？",
        "unit_id": 110832,
        "voice": "vo_adv_4010191_002"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不、",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不用啦，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你不用這麼費心──",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗚哇，好大！",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n這是什麼，好大！",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "這巨大的箱子",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "到底是什麼？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我有不好的預感。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n你要我打開看看？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "呃，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "那麼，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我要把膠膜撕開了哦……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯？",
        "unit_id": 110832,
        "voice": "vo_adv_4010191_003"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "這是什麼……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "地球",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "防衛……？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啥，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "五隻合體……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "哦～",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "還是DX啊，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "真厲害──",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "這不是玩具嗎。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "難道是在玩哏。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不對，這不是玩哏就能說得過去的體積。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "咦，",
        "unit_id": 110832,
        "voice": "vo_adv_4010191_004"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不是在玩哏嗎……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "那個，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我是無所謂啦。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n雖然我無所謂，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "但如果你要送我以外的人禮物時，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n要再多考慮一下對方的喜好和年齡哦。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "說是這樣說，",
        "unit_id": 110832,
        "voice": "vo_adv_4010191_005"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "不過，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "這種玩具",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "弟弟他們應該會喜歡吧……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "男孩的喜好真的很難搞……",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "那些傢伙",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "很有自己的主張。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "之前買了花車促銷品的變身腰帶給他們，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "卻吵著說不是這個。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊？",
        "unit_id": 110832,
        "voice": "vo_adv_4010191_006"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "為什麼你會知道這──",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "是嗎，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "這是那個嗎。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "就是，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你之前來我家時，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "跟弟弟們在電視看的那個。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "啊──",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "原來我在處理便宜肉的肉筋時，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "男生們在聊這個話題啊。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "OK，我了解了，",
        "unit_id": 110832,
        "voice": "vo_adv_4010191_007"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "原來是這樣。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n不錯啊。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "謝謝你，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "NICE玩具。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "你啊，將來應該能成為一個好爸爸。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "雖然我也不太清楚。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "嗯……",
        "unit_id": 110832,
        "voice": "vo_adv_4010191_008"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "是啊。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "剛好最近",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "我也沒怎麼陪那群孩子們玩。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n就讓花子姊姊我，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "用這個來讓全家人開心聚一下吧。",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "那麼，",
        "unit_id": 110832,
        "voice": "vo_adv_4010191_009"
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n這場「扮家家酒」",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "當然你也會奉陪吧？",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "\n",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "很",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "好，",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "跟我來吧──",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "孩子們都在等你回家哦──",
        "unit_id": 110832
    },
    {
        "type": "dialogue",
        "name": "花子",
        "words": "爸爸。",
        "unit_id": 110832
    }
]