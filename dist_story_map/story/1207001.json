[
    {
        "type": "background",
        "background": "501480"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "新年隔天早上──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪菲等人出現在"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【美食殿堂】的玄關前。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯。",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和服穿這樣就行了。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n那麼，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們去逛祭典吧。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但是",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "媽媽……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐真的不一起去嗎？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……雖然兩位難得邀請在下，",
        "unit_id": 105913,
        "voice": "vo_adv_1207001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是年末沒做的家事和洗衣服等等，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下必須要完成這些工作才行。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……這樣啊。",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "貪吃佩可小姐和凱留也都回王宮了。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n大家一起過的時間",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "只有除夕呢……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐……",
        "unit_id": 105913,
        "voice": "vo_adv_1207001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "後",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "天的話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就能大家一起參加祭典了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會期待那天到來的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯，",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "馬上就能再和大家見面了呢。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "今天我就和這個人",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一起去逛祭典吧。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我們也會確實去領收",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐訂購的金槍鮪！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 105913,
        "voice": "vo_adv_1207001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "交給擅長跑腿的雪菲小姐去辦，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也很放心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下會期待",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位回來分享逛祭典時的趣事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請兩位路上小心。",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "501470"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這就是",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "新年的祭典……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家都穿著和服走在路上，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "氣氛好熱鬧。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "媽媽！",
        "unit_id": 1,
        "voice": "vo_adv_1207001_008"
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "那邊在打太鼓耶！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "喂，",
        "unit_id": 1,
        "voice": "vo_adv_1207001_009"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "別突然跑起來！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n要是走丟就不好了，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "來牽好媽媽的手吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "嗯♪",
        "unit_id": 1,
        "voice": "vo_adv_1207001_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……而且，",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "很多都是跟著家人一起來呢。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「喪失記憶之前的我」，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是不是也像那樣和某人一起度過呢……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我們也要牽手嗎？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你說為了防止走失……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真是的，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我可不是小孩子啊。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也是呢。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "畢竟風也很冷……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n就稍微",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "借一下你的手好了。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……嗯，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那我們走吧。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "話說回來，",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "祭典是要做些什麼？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n咦？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "邊走邊吃？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n又、",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "又要吃東西……？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我是不討厭吃東西……",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但新年都已經吃這麼多了，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "竟然還要再吃。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個，",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感覺會變胖……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "哦，",
        "unit_id": 1,
        "voice": "vo_adv_1207001_016"
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "在那裡的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "\n不是【美食殿堂】的雪菲嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "哎呀？",
        "unit_id": 1,
        "voice": "vo_adv_1207001_017"
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "真的耶！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "\n妳過來這裡一下！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦？",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "前陣子",
        "unit_id": 1,
        "voice": "vo_adv_1207001_019"
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "多虧妳幫我們從小偷那裡拿回食材，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "\n我們才能順利迎接新年喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "也讓我向妳道謝。",
        "unit_id": 1,
        "voice": "vo_adv_1207001_020"
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "\n能像這樣順利做成生意，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "真不知叫人有多放心！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "\n妳是我們的恩人！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "謝謝囉！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不會……",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "別這麼說……",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "對了！",
        "unit_id": 1,
        "voice": "vo_adv_1207001_022"
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "\n說到【美食殿堂】，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "就是邊走邊吃的公會對吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "\n不然",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "來喝喝我們店的甜酒吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "這是謝禮，免費請妳喝！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "也來吃我們店的紅豆湯吧！",
        "unit_id": 1,
        "voice": "vo_adv_1207001_023"
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "我們的紅豆很好吃喔！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "\n如果吃了喜歡，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "請務必要幫我們宣傳！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "\n……啊，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "旁邊的男朋友也請用！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "男、",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_024"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "男朋友……！？",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不是，那個……！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "還牽著手，",
        "unit_id": 1,
        "voice": "vo_adv_1207001_025"
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "真是火熱呢……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販大叔",
        "words": "\n你們這是新年第一次的約會啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不是，",
        "unit_id": 120711,
        "voice": "vo_adv_1207001_026"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這個人不是男朋友……！",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "哎呀，妳在害羞嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1207001_027"
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "他看起來很溫柔嘛，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "真是羨慕！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "\n你們是怎麼相戀的？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "交往幾個月了？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "攤販阿姨",
        "words": "……妳喜歡對方什麼地方？",
