    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "「那個，",
        "unit_id": 133131,
        "voice": "vo_adv_4010250_000"
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "騎士先生？",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n您從方才",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "就一直站在",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "『冰箱』",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "前面做什麼呢？」",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "是在準備晚餐嗎……",
        "unit_id": 133131,
        "voice": "vo_adv_4010250_001"
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "看上去倒也不像。",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n他叫我",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "待在「客廳」就好……",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "但我是不是",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "該過去幫忙比較好呢……？",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "「哇……！",
        "unit_id": 133131,
        "voice": "vo_adv_4010250_002"
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n這個",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "『蛋糕』",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "是為我而準備的……？",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "謝謝您，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "騎士先生！」",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "「不僅為無處可去的我",
        "unit_id": 133131,
        "voice": "vo_adv_4010250_003"
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "提供了棲身之所，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n甚至還如此大費周章地幫我慶祝生日。",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "我都不知道",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "該說什麼來表達心中感激了……！」",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "「說來慚愧，",
        "unit_id": 133131,
        "voice": "vo_adv_4010250_004"
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "我就連『生日』",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "都忘得一乾二淨了。",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n雖然今天是『那邊的我』甦醒的日子，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "但『這邊的我』",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n至今仍不知自己的生日是何時，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "怎麼好意思接受祝賀……」",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "「真的很感謝您",
        "unit_id": 133131,
        "voice": "vo_adv_4010250_005"
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "願意如此貼心相待。",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "不過……",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "那個，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "騎士先生",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "若不嫌棄，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n不如與我一同享用這個",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "『蛋糕』",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "如何？」",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "「我曾聽人說過，",
        "unit_id": 133131,
        "voice": "vo_adv_4010250_006"
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "所謂生日，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "並非只是誕生在這世上的日子，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n也是慶祝自己",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "平安度過了一整年",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "的日子。」",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "「我之所以能夠",
        "unit_id": 133131,
        "voice": "vo_adv_4010250_007"
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "在這片陌生土地上",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "平安度日，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "都是多虧了",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "騎士先生的大力相助。",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "這只是聊表",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "我對您的",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "一絲",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "感激之情。」",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "而且，",
        "unit_id": 133131,
        "voice": "vo_adv_4010250_008"
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "之所以",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "會忘記如此重要的日子……",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "正代表了",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "如今我與騎士先生",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "相處的每一天",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n是多麼歡喜、多麼充實。",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "「謝謝……！",
        "unit_id": 133131,
        "voice": "vo_adv_4010250_009"
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "呵呵，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "那我這就去拿",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "『刀子』過來。」",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "「兩人共享一個",
        "unit_id": 133131,
        "voice": "vo_adv_4010250_010"
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "『蛋糕』，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n感覺",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "就像故事中的一幕似的。",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "\n",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "感謝您安排了",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "如此美妙的生日祝賀，",
        "unit_id": 133131
    },
    {
        "type": "dialogue",
        "name": "菫",
        "words": "騎士先生……♪」",
        "unit_id": 133131
    }
]