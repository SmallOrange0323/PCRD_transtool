        "voice": "vo_adv_9006603_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n別大意了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "……姊姊，",
        "unit_id": 130113,
        "voice": "vo_adv_9006603_003"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這樣已經……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "請停手吧，",
        "unit_id": 125811,
        "voice": "vo_adv_9006603_004"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "倭小姐！",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n別再繼續爭鬥了……！",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "雖然也很擔心妳們的身體……",
        "unit_id": 126011,
        "voice": "vo_adv_9006603_005"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "但這根本不像是倭小姐妳們的作風！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n居然會對他人言聽計從，",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不顧自身性命……！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嘖！",
        "unit_id": 130013,
        "voice": "vo_adv_9006603_006"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n說得好像很懂我們似的，",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真讓人火大……！",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n說到底──",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我們才不會",
        "unit_id": 130013,
        "voice": "vo_adv_9006603_007"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "因為這點程度就認輸！",
        "unit_id": 130013
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "沒錯沒錯！",
        "unit_id": 130213,
        "voice": "vo_adv_9006603_008"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n看不起人也要有個限度啊！",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……！",
        "unit_id": 105911,
        "voice": "vo_adv_9006603_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "竟然",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有這樣的力量……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "或許",
        "unit_id": 105811,
        "voice": "vo_adv_9006603_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是憤怒變成了力量……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們是不會輸給那種力量的！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "還、",
        "unit_id": 130113,
        "voice": "vo_adv_9006603_011"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "還要打嗎？",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n果然……",
        "unit_id": 130113
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "這次──",
        "unit_id": 130213,
        "voice": "vo_adv_9006603_012"
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "\n你就超越小雜碎哥哥，",
        "unit_id": 130213
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "變成小渣渣哥哥吧～！",
        "unit_id": 130213
