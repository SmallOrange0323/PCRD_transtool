[
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}與凱留\n為了報告已討伐了巨大魔物，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "而走在前往王宮的路上。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～",
        "unit_id": 106012,
        "voice": "vo_adv_1806004_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "累了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n趕快解決煩人的報告就回去吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且我的肚子已經餓到不行了……",
        "unit_id": 106012,
        "voice": "vo_adv_1806004_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也不可能在那個村子要吃的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還要留意不能讓肚子叫出聲來。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊──真是的，",
        "unit_id": 106012,
        "voice": "vo_adv_1806004_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "肚子餓到眼前一片白……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不對！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是真的在發光啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是怎麼一回事────！？",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "510351"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "…………",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_003"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "…………",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_004"
    },
    {
        "type": "background",
        "background": "510201"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "唉……",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_005"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n為什麼我會這麼悲慘啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什麼「沒有必要去畢業旅行」啊。",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_006"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n明明都在一些沒意義的事情上花錢，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n為什麼對小孩的花費就就這麼小氣啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "既然妳要把錢都花在那些無聊的地方，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_007"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我就自己去打工賺那筆錢了啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊──那也不可能是嗎。",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_008"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "反正肯定會說我是在幹壞事，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n然後叫我把打工辭掉吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我的人生，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_009"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "還真的是一塌糊塗呢……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我也想要去畢業旅行……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n跟大家一起開心度過，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "吃好吃的東西……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "到底是",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_010"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "為什麼，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "連這樣理所當然的事情都……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什、",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_011"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什麼！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是、",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是你！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "為什麼你會在這種地方！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊！？",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_012"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "為什麼要做這麼噁心的事情啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你是我的跟蹤狂嗎！？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……你說一直跟著我，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_013"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n也就是說，我剛剛的自言自語都被你聽到了對吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是啊，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_014"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就是這麼無可救藥的不幸，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n所以才會一個人沉浸在不幸裡。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n如果不這樣做就沒辦法繼續活下去呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你笑啊。",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_015"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不只是媽媽，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你也是。\n就讓我這樣悽慘下去就好。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "反正我的人生都已經沒救了。",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_016"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "對啊，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "乾脆就這樣讓人嘲笑著活下去吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "哈哈！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "真是充滿笑容的美好人生呢！！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你那是什麼臉啊，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_017"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是在可憐我嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "別了吧，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那種事情可是一點用都沒有呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "對了，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_018"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "要像之前那樣把錢包丟過來嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n那樣的話我會很高興喔。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "說的是呢，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_019"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那樣也好。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你也不要跟我扯上關係比較好。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "在學校也是，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_020"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我媽媽很糟糕這件事",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n也在私底下傳開了呢……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "以往會跟我說話的人也開始漸漸疏遠了……",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_021"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這樣的話，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就算可以參加畢業旅行……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "也只會……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你！！",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_022"
    },
    {
        "type": "still",
        "still": "180600401"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你說我是哪裡沒問題啊！",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_023"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n有個無可救藥的媽媽，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n身為小孩的我也束手無策！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "又見不到真那大人！",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_024"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n結果在我身邊的，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n就只有像你這種莫名其妙的傢伙！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你到底是什麼意思啊！",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_025"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n放著不要管我不就好了！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我可是會在這種地方，自己一個人說個不停的危險人物喔！",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_026"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你就跟班上的同學一樣離開就好！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊～啊。",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_027"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你啊，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你是個天賦異稟，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n還有一堆錢的人嘛。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "既然如此你別待在這裡，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_028"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n隨便去個地方都能獲得幸福吧！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你這人……",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_029"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你這人……",
        "unit_id": 106031
    },
    {
        "type": "background",
        "background": "510201"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "…………哈哈。",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_030"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "如果依靠你的話，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我也就到此為止了吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就跟把一切都賭在我身上的媽媽毫無區別嘛。",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_031"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n笨蛋中的笨蛋，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "大笨蛋。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "真的是，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "無藥可救。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "啊？",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_032"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什麼啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你想說我是好孩子所以沒問題嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這個世界才沒有這麼天真……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你、",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_033"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你突然說什麼啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "請不要這麼光明正大地，說些跟蹤狂的發言好嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我打算怎麼做……？",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_034"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_035"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……這樣啊。",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_036"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "的確，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是這樣呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n跟媽媽才沒有關係。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "跟班上的同學也是，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_037"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n他們要怎麼看我",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就怎麼看吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我跟媽媽才不一樣，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_038"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n這點我可以很有自信地說。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "只要像以往一樣、好好地過日子，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_039"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n讓班上的人看到我……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不能參加畢業旅行雖然很遺憾，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_040"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但是，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n旅行的話我自己也可以去對吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "等我長大之後，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_041"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就可以靠我自己的能力去到更好的地方。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過……",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_042"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "果然還是想去海邊呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n都特地去挑泳衣了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "什麼？",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_043"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "所以就說我不能去畢業旅行……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "等等，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這樣啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n想去海邊的話，直接去就好了對吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "好啊，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_044"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "走吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "既然是你提的，那你會負責出交通費吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……啊啊，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_045"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "所以你剛剛才沒把錢包拿出來啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就算有帶那時候你也不會拿出來吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嗯，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_046"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "算了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "一步一步慢慢地，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n靠著自己的力量來實現也不錯呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我們走路過去海邊吧，",
        "unit_id": 106031,
        "voice": "vo_adv_1806004_047"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我可不准你說不要喔！",
        "unit_id": 106031
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1806004_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你們在那之後還真的走路到海邊了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_1806004_049"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n花了不少時間啊。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "到了的時候天色暗到什麼都看不見，",
        "unit_id": 190011,
        "voice": "vo_adv_1806004_050"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n凱留還發了一堆牢騷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "即便如此，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她的表情卻出乎意外地爽朗呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "凱留的遭遇雖然真的很辛苦，",
        "unit_id": 190011,
        "voice": "vo_adv_1806004_051"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n但是她本性不壞，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "只要有願意好好看著她的人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就沒問題了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為有你好好地看著她……",
        "unit_id": 190011,
        "voice": "vo_adv_1806004_052"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以我沒有太擔心，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n不過如果能有更多像你這樣的人就好了呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你就成為她與人們之間的那座橋梁吧。",
        "unit_id": 190011,
        "voice": "vo_adv_1806004_053"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼下次再見了。",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦、",
        "unit_id": 106012,
        "voice": "vo_adv_1806004_054"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道我……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剛剛睡著了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "累積太多疲勞真的是沒好事呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且我好像還夢到了什麼很奇怪的夢……",
        "unit_id": 106012,
        "voice": "vo_adv_1806004_055"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你！？",
        "unit_id": 106012,
        "voice": "vo_adv_1806004_056"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "突、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "突然說什麼啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且被你這樣說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總覺得有種很奇怪的感覺啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的！",
        "unit_id": 106012,
        "voice": "vo_adv_1806004_057"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，趕快去報告吧！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一步一步慢慢地，",
        "unit_id": 106012,
        "voice": "vo_adv_1806004_058"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總有一天，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也會成為像你這樣的人喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這樣說著的同時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "凱留邁著輕盈的步伐，\n朝向通往王宮的道路前進。"
    }
]