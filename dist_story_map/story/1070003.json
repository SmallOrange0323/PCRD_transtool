    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "研究設施遭【王宮騎士團】襲擊的似似花，\n正嘗試與真軌一同逃離。"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "喝！",
        "unit_id": 711,
        "voice": "vo_adv_1070003_000"
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "接招！　",
        "unit_id": 191011,
        "voice": "vo_adv_1070003_001"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "喝！",
        "unit_id": 191011
    },
    {
        "type": "background",
        "background": "500250"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士1",
        "words": "哇啊啊啊啊啊！！",
        "unit_id": 711,
        "voice": "vo_adv_1070003_002"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "您沒事吧，",
        "unit_id": 191011,
        "voice": "vo_adv_1070003_003"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "主人！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "當然沒事了。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看到就該知道了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這設施受到襲擊，",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是預先設想的事態中",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "最糟糕的一個。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真軌。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你先逃。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我暫時在這裡拖住他們。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "但似似花大人，",
        "unit_id": 191011,
        "voice": "vo_adv_1070003_007"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "您剛才已經受傷了……！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真笨呢，你啊。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我是在叫你先去確保退路。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我身有負傷，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可無法維持太久。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "明白！　",
        "unit_id": 191011,
        "voice": "vo_adv_1070003_009"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "主人……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "我絕對……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "絕對會來迎接您的！！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這樣真軌就平安無事了。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_010"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……設施即將崩毀。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_011"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "待命的戰鬥用分身也全都",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "被騎士團擊敗了。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "看這樣子要逃走也會相當費勁呢。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那到底對這裡的動靜掌握到什麼程度了？",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "做出這種行動，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只靠霸瞳天星的能力，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "實在無法說明這一切。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "若只有真軌一人就算了，",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_013"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "他連幾乎從不現身的",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我的動向",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也瞭若指掌了？　",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "簡直就像",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所有事情都看透了一般……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……怎麼可能。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但也無法否認這個可能性……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真那完全讀透了我的行動……",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還有過去也是，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不僅如此，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "連未來也是……？　",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……若真是如此，",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我現在就故意隨著他的猜測去行動吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "發現目標！　",
        "unit_id": 711,
        "voice": "vo_adv_1070003_017"
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "在這邊！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過是個雜兵也想當我的對手？",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n接下小看變貌大妃的報應吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "王宮騎士2",
        "words": "哇啊啊啊啊啊！！",
        "unit_id": 711,
        "voice": "vo_adv_1070003_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "才這種程度就發出哀嚎了？",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真軟弱……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好歹再多掙扎一會啊。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "王宮騎士3",
        "words": "哇啊啊啊啊啊！！",
        "unit_id": 711,
        "voice": "vo_adv_1070003_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "全滅了啊。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有點做過頭了。",
        "unit_id": 107011
    },
    {
        "type": "background",
        "background": "500341"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……果然會被發現呢。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "並沒有到全滅的程度。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n但我也是經過了",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "相當的奮戰之後才被捉住的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "之後，",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_024"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就如我剛才所說的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我在洗腦魔法裝置啟動之前，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就放出了小分身。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "接著，",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "與尤絲蒂亞娜公主……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "貪吃佩可接觸之後，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n總算是想辦法逃出了王城。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "現在的我並沒有戰鬥能力。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_026"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真軌參加的反攻作戰，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我會安分地在旁邊看著。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我也傳達給你知道貪吃佩可平安無事了，",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這次的作戰可以算是成功吧。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_028"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我是似似花小姐喔。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很驚訝嗎？",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟我",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是刻意不告訴你名字的。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那是為了防止被真那發現的",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "必要措施。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n以後就不必客氣，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "用名字叫我也無所謂。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那不是你該介意的事情。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_031"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "再說那時候……",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒什麼。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "下次和大家一起來救我，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就原諒你。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是你",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "應該有著比我還要優先的",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "重要夥伴才對。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "先以那裡為優先吧。",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "別看我這樣，我可是很強壯的，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n之後再救我也無所謂。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "況且也還有真軌。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "嗯，",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我等你。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n別忘了我，",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "絕對要來救我。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……這也是為了",
        "unit_id": 107011,
        "voice": "vo_adv_1070003_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "讓我們能合力打倒真那。",
        "unit_id": 107011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在似似花微笑的表情之中，\n感受到不只有喜悅，以及對下次戰鬥的堅定意志。"
    }
]