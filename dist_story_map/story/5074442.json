        "words": "這麼一來",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "手術也結束了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雪，妳也辛苦啦。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "身體狀況沒事吧？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "非常有事～",
        "unit_id": 117611,
        "voice": "vo_adv_5074442_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "拚過了頭，累死我了，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "使不上半點力氣啦……",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
        "unit_id": 117611,
        "voice": "vo_adv_5074442_002"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為筋疲力盡",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而顯得有些慵懶的我，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n應該醞釀出有別平時的美麗了，對不對！？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵，",
        "unit_id": 117611,
        "voice": "vo_adv_5074442_003"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣的我可不常見喔。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "仔細看清楚，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好好烙印在眼裡吧♪",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……我之前就一直這麼覺得了，",
        "unit_id": 117511,
        "voice": "vo_adv_5074442_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就各種方面來說，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n妳也許真的很厲害呢。",
        "unit_id": 117511
    }
]