[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "呼～",
        "unit_id": 105411,
        "voice": "vo_adv_7005001_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如此一來這附近的魔物就都收拾完畢了吧？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "狀況不錯呢紡希。",
        "unit_id": 100311,
        "voice": "vo_adv_7005001_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不知不覺進步很多了呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "咦～",
        "unit_id": 105411,
        "voice": "vo_adv_7005001_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "真的嗎！？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "竟然被怜稱讚了……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也謝謝你呢。",
        "unit_id": 100311,
        "voice": "vo_adv_7005001_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "多虧你的幫忙順利爬上來了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊、",
        "unit_id": 105411,
        "voice": "vo_adv_7005001_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n你還在試圖想要吸引怜的注意嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就算你強化怜想要獻殷勤，",
        "unit_id": 105411,
        "voice": "vo_adv_7005001_005"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我也不會讓你得逞的唷！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希……",
        "unit_id": 100311,
        "voice": "vo_adv_7005001_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "無論如何",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也不能這樣說吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這些都是紡希自己的揣測唷。",
        "unit_id": 100311,
        "voice": "vo_adv_7005001_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他並不是像紡希說的一樣是卑鄙的人唷。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不行不行，",
        "unit_id": 105411,
        "voice": "vo_adv_7005001_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "請小心呀怜。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "男人大家都是狼呀，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n絕對不能掉以輕心！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "狼這是什麼概念……",
        "unit_id": 100311,
        "voice": "vo_adv_7005001_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "男人是狼，",
        "unit_id": 105411,
        "voice": "vo_adv_7005001_010"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是狼人呀！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要一轉頭他們就在背後，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "要把我們吃下去唷！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希妳也太誇張了……",
        "unit_id": 100311,
        "voice": "vo_adv_7005001_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "聽好了唷，",
        "unit_id": 105411,
        "voice": "vo_adv_7005001_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了不讓騎士先生對怜出手，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我可是一路努力監視過來的。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "所以，絕對",
        "unit_id": 100311,
        "voice": "vo_adv_7005001_013"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不能去",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我看不到的地方！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "還有……",
        "unit_id": 105411,
        "voice": "vo_adv_7005001_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "走散的話",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n也一定要回到我這裡唷？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真希望兩人能感情變好……",
        "unit_id": 100311,
        "voice": "vo_adv_7005001_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣下去可真讓人擔心呢。",
        "unit_id": 100311
    }
]