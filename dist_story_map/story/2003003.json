[
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "still",
        "still": "200300301"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們的城市……",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "蘭德索爾，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是管轄這片阿斯特賴亞大陸多年的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n國家的首都哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很傳統保守，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也就是大家所說的中央集權的國家……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n皇家的每一代，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都作為執政者統治天下。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "皇家的居所，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也就是在城中央的王宮呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n而皇家也負責國家的營運和政治，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n以及公共機關和索爾之塔等等的管理呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所謂的【公主騎士】，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就是皇家直屬的公會的總稱呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "郵政，警察，消防，防水……",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "還有其他不同的公共機關的營運，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n都是分別隸屬於【公主騎士】下的公會在處理。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "說到這個。",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_005"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n為什麼，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n要取名為【公主騎士】呢？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "小矛依未……",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_006"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "小諾維姆她，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對那個名字的反應很奇怪。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊……好像起源於很久之前的傳說呢，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有興趣的話可以去圖書館查查呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "以我的權力，大概連禁書都可以看到哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "諾維姆呀……那孩子也很令人擔心呢，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像被【拉比林斯】那一班人擄走了？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總覺得有點不放心，是不是該派人追查下落比較好呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "言歸正傳。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n隸屬於【公主騎士】的其中一個公會，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n【王宮騎士團】……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "正如其名，他們是為了守護王宮而成立的公會。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也就是皇家直屬的親衛隊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他們是皇家平時所保有的武力。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在很和平，所以他們沒有機會大顯身手，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是如果有戰爭的話，他們就會站在最前線。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "是真正的軍隊呢。",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_012"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好可怕。",
        "unit_id": 102511
    },
    {
        "type": "still",
        "still": "200200201"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那個襲擊【哞哞自衛隊】的花俏女人也是…………",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_013"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n不僅非常強，還殺氣騰騰。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n因為是軍人吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，克莉絲提娜呢。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那也是個目前家世背景不清的奇怪之人呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【王宮騎士團】就是，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n以王侯貴族為主的，地位超然的公會。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也許，那個人的身份是確實的。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖說最近治安有惡化的趨勢……",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但這個大陸，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "長時間以來",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒有過真正意義的戰爭。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n一直維持著",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和平的時代。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以【王宮騎士團】軍隊，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也挺空閒的呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "慢慢的削減人手和預算，規模也因此變小了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "克莉絲提娜就是對這個狀況感到不滿，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n才發動戰爭呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一旦開戰，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n身為軍隊的【王宮騎士團】規模，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就會被擴大呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣就可以恢復從前的權力。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n衰落的【王宮騎士團】，\n也能東山再起了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個會不會是克莉絲提娜的目的呢。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這都是我的推測。 ",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "當中可能有深奧的隱情。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "順便一提，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因地理上的優勢，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n令普通人類在我們國家歷史上稱霸一方。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "獸人，精靈族",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和魔族等只屬少數派呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在其他地區，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也存在普通人類以外的種族國家。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而在蘭德索爾的話其他種族會感到丟臉的呀。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因此在其他的種族中，也有對普通人類感到不滿呀。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說不定，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n他們都是被這次的事情觸發，而發起了暴動。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果是真的話，那就完蛋了。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n種族之間的對立，很有可能演變成血腥內戰。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "終點是地獄哦。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果外國也插手干預的話，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n將會變成世界大戰呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "會……",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_029"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "演變成那樣的戰爭嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n大家平常明明就沒有去意識種族不同這件事，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n彼此好好相處的說～？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "到底，這只是最壞的情況吧。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n還未到一觸即發的狀態啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "普通人類們，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n對其他種族也沒有很明確的岐視啦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然我們的族群是精靈族，但亦被冠以貴族的稱號。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是，感覺是暴發戶爸爸硬要用高價買下這稱號的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可是……種族呀文化呀宗教，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就是說思想觀念不同的話很容易引起戰爭呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這可是有歷史証明，是個嚴峻的事實哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "以防萬一，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是有必要先做最壞打算和做好準備呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【王宮騎士團】……",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n對獸人的互助組織",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【動物苑】的隸屬公會",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【哞哞自衛隊】進行了襲擊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "獸人跟普通人類形成了對立狀態。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n埋下了戰爭的火種哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一旦知道自己人受到攻擊……",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n別說【動物苑】，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n其他地區的獸人國家都不會坐以待斃的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最糟糕情形，大概就是戰爭啦。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在演變成戰爭前，盡量把爭鬥的火種弄熄。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "僅僅是公會間的小衝突就好了。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n現在已發動了襲擊，這是不可否認的事實。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n事後處理很重要呀，即使要通宵也在所不辭。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一旦發生戰爭最先犧牲的往往是弱小的群體。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_040"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n婦人，病人，老人，小孩……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n絕對要阻止令無辜平民流血和流淚的事情發生。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的。早知道會發生這樣的事情，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_041"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我真不應該離開【王宮騎士團】的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果有我在，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_042"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不會讓克莉絲提娜為所欲為。",
        "unit_id": 102811
    },
    {
        "type": "still",
        "still": "200300202"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐～",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_043"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n手停下來了喔，請趁熱吃吧。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "來，啊～……♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喂，不要這樣啦好害羞呀。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_044"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n真是的，現在是在說很認真的事情呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐只要一熱衷於某件事，就會忘了吃飯。",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_045"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n就算是強迫，也得讓她吃下去才行……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "{player}也不要客氣，啊～♪",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇，真聽話！",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_046"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n一般來說，不是應該要再害羞一點嗎？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "好，",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_047"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "請盡量多吃一點哦。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "雖然我對料理並不是那麼擅長……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不覺得自己這樣說有點哀傷嗎？鈴莓。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_048"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我來教你一些做料理的訣竅吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "嗚～",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_049"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n我也不知道為什麼，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一直以來都很不擅長做料理呢。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我已經很努力地特訓過了的說？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_050"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n鈴莓是",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "空有幹勁的類型呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不如說，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "別努力的太過頭的話，也許會比較好唷？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不是好或不好的問題呀。",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_051"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "冷靜地想想以後，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n對著年長的男性說「啊～」好像有點奇怪。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "不過總覺得，",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_052"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}你這個人會讓人不禁想好好疼愛呢。",
        "unit_id": 102511
    },
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哎呀，剛才的話被打斷了呢……",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_053"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n你似乎還不清楚來龍去脈的樣子，",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n{player}，就讓我向你說明吧……",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐原本是隸屬於【王宮騎士團】喔。",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_054"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "在【王宮騎士團】中，\n公會長被稱為『團長』。",
        "unit_id": 102511,
        "voice": "vo_adv_2003003_055"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "大小姐則是僅次於該地位的『副團長』。",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對呀，只是繼承父親的地位呀。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_056"
    },
    {
        "type": "still",
        "still": "200300301"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那裡世世代代，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_057"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n都是由貴族擔任團長等要職的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我們也只是因為暴發戶的關係，才勉強成為貴族呀。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "現在【王宮騎士團】的\n規模縮小了還人手不足呢……",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_058"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "亦因為沒有其他更適合的人選，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_059"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我是不得已才當上副團長的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是在和平的時代，是不需要軍隊吧。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_060"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為真的是沒什麼事做而閒置，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n所以就隨意找了個藉口離開了哦。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "剛才有提到的",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_061"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "【公主騎士】是",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n作為皇家直屬的公共機關進行管理和營運。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "之中也有收養戰爭孤兒，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_062"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n就像是孤兒院那樣的公會存在唷。",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500113"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但這現在也只有文件上有所記載，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_063"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n算是一個拿不到預算，有名無實的公會。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "於是我復興了這個公會，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_064"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n並取名為【咲戀育幼院】，然後開始營運。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n比起在王宮發呆，我覺得做這件事有意義多了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "最近，有一個叫做「消失」的奇怪現象……",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_065"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n父母和親友等突然消失的不可思議事件不斷增加。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "其中有些孩子因此失去家庭，變得無處可去。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "胡桃那孩子也是這樣，你應該認識她吧。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_066"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我把那些孩子帶了回來，並保護他們。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要讓孩子們有一個安全幸福的環境生活。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_067"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n為此而努力的公會正是【咲戀育幼院】唷。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我為所做的事情感到自豪。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_068"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這是很有意義的，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n是值得我奉獻人生的崇高使命。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝你。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_069"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只不過，現階段都盡是一些理想的空談……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n實際上的進行並不順利，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因此說來也挺不好意思的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "守護，教育好孩子們。",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_070"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n為此，我可以做任何事情。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不管怎樣一定要譴責發起戰爭的笨蛋們，",
        "unit_id": 102811,
        "voice": "vo_adv_2003003_071"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不能讓孩子們有個染血的未來。",
        "unit_id": 102811
    }
]