[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了收齊公會管理協會的年度活動紀錄，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}來到【破曉之星】的所在地──"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，",
        "unit_id": 100111,
        "voice": "vo_adv_9004013_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你好！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n今天是為了來辦公會管理協會的事，對吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿──♪",
        "unit_id": 100111,
        "voice": "vo_adv_9004013_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "之前聽花凜小姐說過了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為騎士先生這次會來，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以連同活動紀錄──",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哇啊！？",
        "unit_id": 100213,
        "voice": "vo_adv_9004013_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "日和！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n那是必須",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "保密的事情……！",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊！",
        "unit_id": 100111,
        "voice": "vo_adv_9004013_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對喔！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想想──",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "日和，",
        "unit_id": 100311,
        "voice": "vo_adv_9004013_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要給他的信封就是這個嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──啊，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是{player}呀。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "歡迎。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111,
        "voice": "vo_adv_9004013_005"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怜！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來得正好！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "來，",
        "unit_id": 100111,
        "voice": "vo_adv_9004013_006"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "請你拿著這個信封哦。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……啊！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不可以打開來看哦！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "絕對不行哦？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……原來如此。",
        "unit_id": 100311,
        "voice": "vo_adv_9004013_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我了解大致情況了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話說回來，",
        "unit_id": 100311,
        "voice": "vo_adv_9004013_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是嗎……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "自從和你一起旅行開始，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也已經過了四年啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們到過許多不同的地方，",
        "unit_id": 100311,
        "voice": "vo_adv_9004013_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也和形形色色的人相遇。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n因為和你攜手走來，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們才得以變強。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "與你的羈絆之力──",
        "unit_id": 100311,
        "voice": "vo_adv_9004013_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "公主型態。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這股力量在未來的戰鬥中，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "依然是必要且不可欠缺的事物吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我想變得更強。",
        "unit_id": 100311,
        "voice": "vo_adv_9004013_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了用這雙手守護重要的人們。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "所以，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "今後也多多指教。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯。",
        "unit_id": 100111,
        "voice": "vo_adv_9004013_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "也要變得更強，保護騎士先生……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n不論是優衣，還是怜，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有全世界的大家，我都想保護！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "接下來",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要加倍再加倍地努力向前哦，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生♪",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也抱持著同樣的想法。",
        "unit_id": 100213,
        "voice": "vo_adv_9004013_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "和騎士先生、和大家一起，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "像這樣一同度過的和樂時光，",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我想要",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "它永遠持續下去。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯，",
        "unit_id": 100311,
        "voice": "vo_adv_9004013_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也是這麼想的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……話說，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "從剛才開始，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我就聞到",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n一股讓人餓扁的香氣呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哇──",
        "unit_id": 100111,
        "voice": "vo_adv_9004013_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的耶！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "味道好香！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那是因為我正在烤餅乾呀。",
        "unit_id": 100213,
        "voice": "vo_adv_9004013_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我想",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一定餓了。",
        "unit_id": 100213
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了！",
        "unit_id": 100111,
        "voice": "vo_adv_9004013_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝妳，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我說，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生就一起來喝杯茶吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不錯。",
        "unit_id": 100311,
        "voice": "vo_adv_9004013_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你應該也因長途跋涉而累了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就在這裡休息一下。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和大家一起",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "度過一段平靜的時光吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在短暫的時間裡，{player}與大家一起"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n享受了開心的茶會。"
    }
]