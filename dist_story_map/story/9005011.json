    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "經過了一段漫長的摸索，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n雪菲終於找到自己想做的東西了。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我要把至今為止",
        "unit_id": 106412,
        "voice": "vo_adv_9005011_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "與他一同經歷過的冒險故事",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "畫出來。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我要把那些經歷過的、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感受過的事生動有趣地傳達出來。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "能夠辦到這件事的表現方法，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那就是──",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──漫畫！",
        "unit_id": 106412,
        "voice": "vo_adv_9005011_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這正是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "前所未有的禮物……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106412,
        "voice": "vo_adv_9005011_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "突然要我畫漫畫，我行嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n雖然有幫忙畫過圖……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不對。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "相信這個靈感……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我辦得到！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "很有志氣呢～♪",
        "unit_id": 106711,
        "voice": "vo_adv_9005011_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "可是，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳把畫漫畫這件事想得那麼簡單，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我覺得有點太天真囉～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳是……",
        "unit_id": 106412,
        "voice": "vo_adv_9005011_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "帆稀小姐……！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳怎麼會──",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "別管我為什麼會在這裡～",
        "unit_id": 106711,
        "voice": "vo_adv_9005011_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "現在妳所需要的是",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "畫漫畫的技術。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n妳說是吧～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……是、",
        "unit_id": 106412,
        "voice": "vo_adv_9005011_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是的……！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼，",
        "unit_id": 106711,
        "voice": "vo_adv_9005011_007"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "就讓我來傳授妳",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "基本工夫吧～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "祈梨、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "嘉夜，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "妳們在吧～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n我要的東西",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "都買回來了嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫！",
        "unit_id": 106611,
        "voice": "vo_adv_9005011_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不要背對著我們說話好嗎！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳背後有長眼睛啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳到現在還沒適應啊，祈梨？",
        "unit_id": 106511,
        "voice": "vo_adv_9005011_009"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "來，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "老大。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳要的東西都在這裡。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n全套畫具。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "幸好祈梨意外地很懂這些東西。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "好的～辛苦囉～",
        "unit_id": 106711,
        "voice": "vo_adv_9005011_010"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "那麼雪菲，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "快來學漫畫的技巧……",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "等一下。",
        "unit_id": 106412,
        "voice": "vo_adv_9005011_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "話題進展得太快了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我不懂妳為什麼要這樣幫我。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……莫非，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "妳是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有什麼企圖……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "咦？",
        "unit_id": 106711,
        "voice": "vo_adv_9005011_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嘉夜夜、嘉夜夜！",
        "unit_id": 106611,
        "voice": "vo_adv_9005011_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n老大她愣住了……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這是什麼情況啊！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "平常她都會微笑帶過的啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "啊……",
        "unit_id": 106511,
        "voice": "vo_adv_9005011_014"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我說妳啊。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我覺得老大她",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "真的沒有任何企圖啦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n雖然她平時老愛打歪主意，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "但這件事她不會。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……這、",
        "unit_id": 106412,
        "voice": "vo_adv_9005011_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這樣啊……！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對不起！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我擅自誤會……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒關係啦，",
        "unit_id": 106711,
        "voice": "vo_adv_9005011_016"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "我們趕緊開始吧～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "來，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "首先準備紙和筆～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "先嘗試畫出框線吧～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……老大",
        "unit_id": 106611,
        "voice": "vo_adv_9005011_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好像很開心耶。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總覺得有點不是滋味。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "怎麼？",
        "unit_id": 106511,
        "voice": "vo_adv_9005011_018"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "妳想求老大的關愛啊？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那妳也去幫忙不就好了？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "誰、",
        "unit_id": 106611,
        "voice": "vo_adv_9005011_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "誰說我想要老大關愛了！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我才不要被她使喚咧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "祈梨～",
        "unit_id": 106711,
        "voice": "vo_adv_9005011_020"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n可以過來幫忙一下嗎～？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫……",
        "unit_id": 106611,
        "voice": "vo_adv_9005011_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真沒辦法！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n老大",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是這麼愛使喚人！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "……哎呀呀。",
        "unit_id": 106511,
        "voice": "vo_adv_9005011_022"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n那我也來幫忙吧，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "畢竟這似乎是要送給我死黨的東西。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲打好畫漫畫的基礎，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在製作禮物的道路上邁出一大步。"
    }
]