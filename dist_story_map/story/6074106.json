    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "雪投げをするのは生まれて初めてでしたけれど、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\nとても楽しかったですわ♪",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "ええ、",
        "unit_id": 114411,
        "voice": "vo_adv_6054106_001"
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "これでまた一つ",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "社会勉強ができましたわ！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "そうです！　",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "今度雪投げのチームを結成して、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "大会を開くのはいかが？",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "その時はあなたさま、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "ぜひとも運営を手伝ってくださいませ♪",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "私もまさか",
        "unit_id": 114411,
        "voice": "vo_adv_6054106_002"
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "ここまで夢中になるとは思っていませんでしたわ！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "最初はうまくできなくて焦るばかりでしたが、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "あなたさまの機転のおかげで、",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "今では楽しい思い出です！",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "まさか",
        "unit_id": 114411,
        "voice": "vo_adv_6054106_003"
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "誘っていただけるなんて……",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "どんな魅力的な商談があったとしても",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\nあなたさまとの約束がうれしいのです。",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "\n",
        "unit_id": 114411
    },
    {
        "type": "dialogue",
        "name": "アキノ",
        "words": "これからも思い出をたくさん作ってまいりましょう！",
        "unit_id": 114411
    }
