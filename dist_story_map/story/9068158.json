        "words": "\n",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "再會囉，",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "布武機",
        "words": "雜碎哥哥你們～♡",
        "unit_id": 130211
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "喂，布武機，",
        "unit_id": 130011,
        "voice": "vo_adv_9068158_023"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "別那麼搖晃啊……",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗚噗。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "啊～！！",
        "unit_id": 130111,
        "voice": "vo_adv_9068158_024"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n不能吐啦～～！？！？",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_9068158_025"
    },
    {
        "type": "dialogue",
