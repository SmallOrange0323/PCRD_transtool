[
    {
        "type": "dialogue",
        "name": "倭",
        "words": "──哎呀，",
        "unit_id": 130011,
        "voice": "vo_adv_9068158_000"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "挨了很棒的一招耶。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "葡萄酒的瓶子都破了，",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "真是的。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個人",
        "unit_id": 105811,
        "voice": "vo_adv_9068158_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然非常地強！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等等！",
        "unit_id": 106011,
        "voice": "vo_adv_9068158_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n跟先前在吉歐‧提格尼亞戰鬥時相比，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n怎麼好像當時的妳還比較認真……！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "我並沒有",
        "unit_id": 130011,
        "voice": "vo_adv_9068158_003"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "手下留情之類的喔。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "剛才也說過了吧？",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n我今天",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是來跟你們商量的。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那麼……",
        "unit_id": 126013,
        "voice": "vo_adv_9068158_004"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n妳真的是",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "想把哥哥當成弟弟……？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "沒錯。",
        "unit_id": 130011,
        "voice": "vo_adv_9068158_005"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n是要我講幾遍啦……",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "嗝。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "我們。",
        "unit_id": 126113,
        "voice": "vo_adv_9068158_006"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n拒絕。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "普蕾西亞小姐？",
        "unit_id": 105911,
        "voice": "vo_adv_9068158_007"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "因為。",
        "unit_id": 126113,
        "voice": "vo_adv_9068158_008"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n姐姐。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n夠多了。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "……啥？",
        "unit_id": 130011,
        "voice": "vo_adv_9068158_009"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "那位小豬女孩",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "是在說什麼啊。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呃……",
        "unit_id": 126013,
        "voice": "vo_adv_9068158_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也就是說，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "普蕾西亞「拒絕」的理由，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n是因為一旦變成哥哥的姐姐，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對身為哥哥的妹妹的",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "普蕾西亞來說，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n倭小姐就變成姐姐了……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對嗎？",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 126113,
        "voice": "vo_adv_9068158_011"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n謝了，不必。",
        "unit_id": 126113
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "一下姐姐一下哥哥，",
        "unit_id": 125813,
        "voice": "vo_adv_9068158_012"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n詞彙交錯到好像有些混亂了……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n而且我也是，",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "並不需要姐姐大人……",
        "unit_id": 125813
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "什麼啊。",
        "unit_id": 130011,
        "voice": "vo_adv_9068158_013"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n不必跟我客氣喔。",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n不管妹妹有兩人三人還是十人，",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "都沒什麼差別啦……",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……？",
        "unit_id": 105811,
        "voice": "vo_adv_9068158_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n從剛才起，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "感覺對話好像不太有交集。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道說，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "倭小姐……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊～～！",
        "unit_id": 130111,
        "voice": "vo_adv_9068158_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是……！",
        "unit_id": 105911,
        "voice": "vo_adv_9068158_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "蠻賊貪鯊號……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "呦，若菜。",
        "unit_id": 130011,
        "voice": "vo_adv_9068158_017"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n妳也是來喝一杯的嗎？",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "才不是！",
        "unit_id": 130111,
        "voice": "vo_adv_9068158_018"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "真是的，",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "姊姊妳居然醉成這樣……",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n就算再喜歡吉歐‧格黑納的香露",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n跟八鹽折，",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也喝得太多了啦……",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105811,
        "voice": "vo_adv_9068158_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "她果然是喝醉了呢。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雖然臉上完全看不出醉樣，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "身手也跟先前一樣，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n一點異樣都沒有就是了……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "喂，若菜，",
        "unit_id": 130011,
        "voice": "vo_adv_9068158_020"
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "去做點下酒菜～",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "\n",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "要不然……",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "來點表演！",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "跳肚皮舞！",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "倭",
        "words": "快脫！",
        "unit_id": 130011
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "才不脫！",
        "unit_id": 130111,
        "voice": "vo_adv_9068158_021"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "好了啦，姊姊，",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "要回去了，快上車……！",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "布武機，",
        "unit_id": 130111
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "拜託快出發吧……！",
        "unit_id": 130111
    },
