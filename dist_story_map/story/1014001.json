[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唉……",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n關於「闇影」的調查，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "遲遲沒有什麼進展呢～",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "最近被害案例不斷增加，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n好不容易有件像樣的偵探案件，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "才讓我幹勁十足。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過我啊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是不是直覺變遲鈍了呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還是說，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n「闇影」的這種存在，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n遠遠比我們所料想的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還要更加難以理解呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真討厭～",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好可怕……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要是演變成驚悚發展，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我或許不太在行呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "算了，無論如何。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n再這樣下去，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我不過就只是個沒用的食客而已。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "【哞哞自衛隊】的大家",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一直很照顧我，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為了她們我也得努力啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "得加油一點，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_006"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不趕緊把這事件解決可不行。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n總之只能先老實地",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "從訪查開始呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但「闇影」的目擊者，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_007"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "大多當下都挺混亂的。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且我本身也不擅長問話，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以要從這方面查出些情報也不容易。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，加油吧。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但在那之前，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_009"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "先喝杯咖啡來讓腦袋清醒一下……♪",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……嗚呀！？",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_010"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊啊嚇我一跳！",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "希、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "希望你別一聲不吭就這樣跑進來啊！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_012"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你是……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哪位呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "來到【哞哞自衛隊】的公會小屋有何貴事？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，等會，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_013"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "讓我來推理看看。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟我是個偵探呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為了令稍帶睡意的思緒清醒，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n像你這樣的陌生訪問者的來意，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就讓我來猜猜吧♪",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔、",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_015"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔嗯。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總覺得被這樣期待，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n反而變得有些難以應付了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那個……",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好像在哪裡見過你的樣子。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如果記得沒錯，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_017"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這裡好像有資料……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯、",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "喂，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_018"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "別擅自偷看人家手上的資料啊……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這些可不是隨便就能給外人看的資料唷，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你懂的吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "真囉唆呢。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_019"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n因為「闇影」的目擊情報多發於夜間，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以我也在",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "通宵調查啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "生活的步調，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_020"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n也得隨著不同事件",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一併調整配合呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不愧是偵探的榜樣對吧。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_021"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哼哼……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所以我",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "絕對不是睡過頭喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "話說回來。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_022"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原來如此，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我大概知道了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你叫做",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_023"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "{player}對吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說起來",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好像也看過你幾次。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "況且【哞哞自衛隊】的其他成員，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_024"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n在提到你的事時，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總是很開心的樣子喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看來你",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_025"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還真是備受愛戴呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "之前聽過別人對你的評價，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_026"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是個溫柔貼心的好人。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "雖然避免先入為主，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "公平地去對待事物可說是偵探的美學，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但你看起來確實也不像是個壞人呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_027"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總而言之……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n姑且再讓我",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "重新做一次自我介紹吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_028"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "所謂的人類，是會對身分不明或未知的事物",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感到恐懼的生物呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我隸屬於【哞哞自衛隊】之下，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_029"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "名字叫做霞。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n雖先前多以單獨行動為主，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但因諸多因素，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "目前暫時叨擾於此處。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "前職是",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_030"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "解決城內所發生的奇怪事件的",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "偵探哦。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "總而言之，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "比起粗活，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "現在仍多擔當負責動腦的職務為主。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我之前大多在外頭調查，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_031"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以比較沒機會能和你打照面呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n總之，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "之後還望你能多指教。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯？",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_032"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n嗯……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "手中拿著張傳單呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n看起來挺眼熟的呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "啊……",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_033"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "果然是",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我在單獨行動時",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在城內多處張貼過的，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n「偵探助手」徵人啟事啊。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這還真是，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_034"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "又讓人勾起回憶了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "當初在單獨行動時，我也曾因為忙到不行，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_035"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "想徵個助手來幫忙喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但因為現在已經隸屬於【哞哞自衛隊】之下，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_036"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以沒有在徵助手了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "咦，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_037"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "奇怪。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你好像有點失望呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣啊，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_038"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你正打算要找份打工對吧？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n然後",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "碰巧看到了這張啟事，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以就想應徵當「偵探助手」啊？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "接著向人打聽到我現在的所在處，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_039"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n然後來到了這【哞哞自衛隊】的據點嗎……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "原來如此，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣就說得通了呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "該怎麼辦呢。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_040"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n「闇影」的調查也陷入了窘境……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "【哞哞自衛隊】的大家，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_041"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n各自有其他工作……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我正好",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "想要個助手。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "{player}，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_042"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "看來也不像是個壞傢伙。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那就麻煩他一下吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_043"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n你的運氣還真不錯呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我正好在想要不要重新徵個助手唷。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "若有幹勁的話，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_044"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要不要來幫忙",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我這裡的偵探工作呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這個嘛。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_045"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要給你的助手薪水，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就從我的薪水裡來支付吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也還只算是",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_046"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "【哞哞自衛隊】裡頭的新人，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n因此薪資還很微薄。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n所以大概沒辦法給你太豐厚的工資。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這樣也沒問題的話，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_047"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "如何呢？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_048"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n如果可以，希望你能從今天",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就開始幫忙呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "首先，",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_049"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "要不要喝杯咖啡？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一邊喝咖啡，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我一邊告訴你，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "關於我們需解決的棘手事件詳細內容吧。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵。",
        "unit_id": 101411,
        "voice": "vo_adv_1014001_050"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "今後也請多指教囉，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生♪",
        "unit_id": 101411
    }
]