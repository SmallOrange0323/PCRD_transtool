        "type": "dialogue",
        "name": "怜",
        "words": "喝！",
        "unit_id": 180311,
        "voice": "vo_adv_2108006_039"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嘿──！",
        "unit_id": 180111,
        "voice": "vo_adv_2108006_040"
    },
    {
        "type": "background",
        "background": "501300"
    },
    {
        "type": "dialogue",
        "name": "贊恩",
        "words": "唔……！",
