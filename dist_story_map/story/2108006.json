    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 180111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "勸你還是",
        "unit_id": 180111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "早點投降吧！",
