    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "能夠一發就幹掉的情況反倒還比較稀奇，",
        "unit_id": 104911,
        "voice": "vo_adv_2001004_052"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n因此箭矢要射要害，最少一次就得射兩發！",
