[
    {
        "type": "background",
        "background": "500201"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哎唷……",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_000"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n一不注意就聊了起來，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就連太陽都快要下山了呢～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "難不成，",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_001"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n是在爭取療傷的時間嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這樣可不行啊～，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我可真是悠哉過頭了一點啊？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是啊，",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_002"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒錯。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n所以，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "才和急性子的我總是搭檔得很好呢。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我說呀～……",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_003"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳究竟在說什麼？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n說得好像我們從很久以前就認識了一樣耶～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n如果妳的妄想症這麼的嚴重，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "應該趕緊去看醫生才對喔。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "關於妳的事，我已經調查過囉。",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_004"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n因為妳實在太礙眼了呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "畢竟還是個需要讓人照顧的年紀嘛，",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_005"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我還想趕緊把妳送回去妳老爸老媽的身邊呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳呀，",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_006"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "在戶籍上可是某個實驗設施研究員的女兒～……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我這話沒說錯吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那個設施的人呀，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "可一直很想要把妳給回收呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我啊，",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_007"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "相當擅長調查事物唷。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n所以也就知道了許多妳的事情……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳呀，",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_008"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就和那所謂的實驗動物沒有什麼兩樣對吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就在對自己的處境感到絕望之際，意外逃了出來的感覺～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……。",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_009"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "不過，",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_010"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我對妳的事情一點興趣都沒有就是了～？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "只是呀……",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_011"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n妳一直在宅邸附近鬼鬼祟祟的，很煩人啊～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "所以我才會接受了這份捕捉妳的委託。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "換句話說，雙方的利益一致呢～♪",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_012"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "順帶一提，委託人說過，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n只要能把妳帶回，她不會過問妳的生死唷。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "如果妳盡給我添麻煩，",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_013"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我就直接解決妳……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n再把妳的屍體繳給委託人，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "大功告成～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就可能會變成這樣囉",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "所以呀。",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_014"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "可別讓我再多費事啦，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n能不能死了那條心趕緊束手就擒呀～……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n小矛依未♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……我，",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不是矛依未。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在這個世界中，",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我才不是什麼矛依未。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n是你，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "讓我找到了人生的意義。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是你告訴了我呢……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你不僅怕麻煩，",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且還一點都不溫柔……",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但是，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你還是我最喜歡的搭檔。",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是誰都無法取代的，搭檔啊！",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n貌似你全都給忘光光了，所以我就再次鄭重的告訴你！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不論多少次，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我都會報上名號給你聽的！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你就，",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在那給我好好聽仔細啦！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我叫諾維姆！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是【永恆集會】的、",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "【萬花筒】的、",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "【圓桌武士】的……",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不，",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_023"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是你的搭檔諾維姆！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我不是矛依未！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆？",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_024"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n諾維姆、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆、",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "嗯～？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n抱歉囉，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "果然是個沒聽過的名字啊～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳一定是沒辦法區分妄想和現實了吧～",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_025"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "還真可悲呢。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "哇哈哈，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "這在青春期也不是什麼稀奇事嘛～♪",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……但總覺得，",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_026"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "只要一聽到妳的聲音，就會讓人不太爽呢～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那張嘴，可不可以稍微閉起來呢～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "反正，妳也都說完了嘛？",
        "unit_id": 106211,
        "voice": "vo_adv_2001004_027"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n我會趕緊把妳抓起來交給我的委託人，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好讓妳從此消失在我的人生中唷～",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唔……",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_028"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n喂！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算是只有你們也趕快逃啊！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我會替你們拖延一點時間，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算是把你們捲進來的賠罪吧♪",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "放馬過來吧，",
        "unit_id": 106112,
        "voice": "vo_adv_2001004_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我可是，早就很想要狠狠的揍你一頓啦！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "哇呀，",
        "unit_id": 102511,
        "voice": "vo_adv_2001004_030"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "別做傻事啊！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n妳這樣子，傷口會裂開的啦！",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該該該、",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "該怎麼辦呀……！？",
        "unit_id": 102511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯～。",
        "unit_id": 105911,
        "voice": "vo_adv_2001004_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "既然人家都說要我們趕快逃了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下是想恭敬不如從命，趕緊退散比較要緊就是了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但總覺得，",
        "unit_id": 105911,
        "voice": "vo_adv_2001004_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不能就這麼放著她不管呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n該怎麼辦呢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105911,
        "voice": "vo_adv_2001004_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n的確是這樣，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下能夠明白。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正如同愛梅斯大人的諭示……",
        "unit_id": 105911,
        "voice": "vo_adv_2001004_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人不是一位會放著有困擾的女孩子不管，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n而只顧著要自己逃命的人。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦？",
        "unit_id": 105911,
        "voice": "vo_adv_2001004_035"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為已經沒有什麼餘裕能夠考慮就是了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "正如同愛梅斯大人的諭示……",
        "unit_id": 105911,
        "voice": "vo_adv_2001004_036"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人是一位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍微有點優柔寡斷的人呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂！{player}！",
        "unit_id": 104311,
        "voice": "vo_adv_2001004_037"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n在那裡的你，是{player}嗎！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哦哦，",
        "unit_id": 105911,
        "voice": "vo_adv_2001004_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又冒出了新的女孩子了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n果不其然，她也是主人您的舊識嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105911,
        "voice": "vo_adv_2001004_039"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不過就是短短的一個月間，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您究竟和多少位女孩子像那樣搞好關係了呢……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來是這麼一回事呢。",
        "unit_id": 105911,
        "voice": "vo_adv_2001004_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就正如同",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "愛梅斯大人的諭示。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還是一位，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有節操……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咕噥咕噥。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂！",
        "unit_id": 104311,
        "voice": "vo_adv_2001004_041"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這到底是，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "什麼狀況呀？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "坐在那輛馬車上的，難不成是你嗎……{player}？",
        "unit_id": 104311,
        "voice": "vo_adv_2001004_042"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這裡很危險啊，趕緊去避難！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 105911,
        "voice": "vo_adv_2001004_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果妳們不襲擊我們的話，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如今在下等人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就還在繼續和樂融融的享受著這趟馬車之旅囉。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唔？",
        "unit_id": 104311,
        "voice": "vo_adv_2001004_044"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那我也沒辦法呀，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這可是工作！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不管三七二十一就用上了這種粗暴的手段，",
        "unit_id": 104311,
        "voice": "vo_adv_2001004_045"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我也感到很抱歉呀！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這全部都是那笨蛋的錯，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是尾狗刀前輩的錯啦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前輩……？",
        "unit_id": 105911,
        "voice": "vo_adv_2001004_046"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總而言之，",
        "unit_id": 104311,
        "voice": "vo_adv_2001004_047"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就算只有你們，我也會放你們走的啦！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n至少，趕緊逃到安全的地方！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "先跟我來，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "自我介紹就等等再說吧！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……唔喔！？",
        "unit_id": 104311,
        "voice": "vo_adv_2001004_048"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "　\n真危險，",
