    {
        "type": "dialogue",
        "name": "忍？",
        "words": "唔唔唔～！",
        "unit_id": 103111,
        "voice": "vo_adv_9006506_021"
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "我已經莫名其妙了啦～！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍？",
        "words": "\n誰快來想想辦法啊～～～！！",
        "unit_id": 103111
    }
