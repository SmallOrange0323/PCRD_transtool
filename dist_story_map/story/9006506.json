        "voice": "vo_adv_9006506_002"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "的確，一直維持在身體交換的狀態下，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "會有極限呢……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n該怎麼辦……！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "妖精",
        "words": "啾啾啾！",
        "unit_id": 15511,
        "voice": "vo_adv_9006506_003"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "咦？",
        "unit_id": 2411,
        "voice": "vo_adv_9006506_004"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "那傢伙是",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "偷吃的愛吃鬼妖精喲！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "\n牠為什麼在灑點心來的？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "\n布丁呢？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "有布丁嗎～！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "弓箭",
        "words": "……！",
        "unit_id": 13811
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "啊！",
        "unit_id": 102211,
        "voice": "vo_adv_9006506_005"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "姐姐，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "弓箭的注意力被點心吸走了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "\n它是要吃嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "但它沒有嘴巴耶。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這、",
        "unit_id": 100611,
        "voice": "vo_adv_9006506_006"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "這部分我不太清楚呢……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "不過幫大忙了！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "牠",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "幫助了我們呢……！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "呵呵呵，",
        "unit_id": 7912,
        "voice": "vo_adv_9006506_007"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "有多少幫到忙了嗎？",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "幸好有將店裡",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "所有的點心都帶來。",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "啊──！",
        "unit_id": 2411,
        "voice": "vo_adv_9006506_008"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "是老婆婆喲～！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "\n宮子的布丁呢！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸？",
        "words": "有帶來嗎～！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "哎呀呀，宮子？",
        "unit_id": 7912,
        "voice": "vo_adv_9006506_009"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n妳在不知不覺間",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "變得相當嬌小了呢……",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n到底",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "發生什麼事了？",
        "unit_id": 7912
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我、",
        "unit_id": 100611,
        "voice": "vo_adv_9006506_010"
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "我覺得她變化的程度不是用變嬌小就能帶過的耶……！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "那個！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "其實我們",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "靈魂交換了──",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "弓箭",
        "words": "──！",
        "unit_id": 13811
    },
