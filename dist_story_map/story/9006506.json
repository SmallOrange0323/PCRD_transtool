        "voice": "vo_adv_9006506_001"
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "不對，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "忍，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "變成依里的茜里",
        "words": "妳還好嗎～！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "變成茜里的依里",
        "words": "唔唔，",
