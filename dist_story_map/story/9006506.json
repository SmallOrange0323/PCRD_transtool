        "voice": "vo_adv_9006506_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞？",
        "words": "如果亂摸就是犯罪喔，",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞？",
        "words": "爸爸。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "妖精？",
        "words": "啾啾！\n（雖然沒辦法說話，但宮子要布丁喲～！）",
