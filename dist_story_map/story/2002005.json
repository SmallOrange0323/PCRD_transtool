[
    {
        "type": "background",
        "background": "500092"
    },
    {
        "type": "still",
        "still": "200200501"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "嗯。",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可是，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是騎士會做的事嘛……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n真是不懂人情世故呀，小姐。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "騎士這回事，即使裝模作樣也好。",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n說穿了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只不過是雙手沾滿鮮血的壞蛋而已。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳，",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就是因為妳這樣墜落！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我們【王宮騎士團】的聲望，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n才名譽掃地呀！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳就沒有一點榮譽感嗎！？",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_003"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500092"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不要這麼激動，很煩耶。",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳經常說話輕佻又表現得很從容吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那樣的妳才比較可愛哦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵♪",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n要是太過認真的話，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可是會吃大虧的哦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不。",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_006"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳這個平民出身的傢伙，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n像這樣自以為是的行為……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "透過扮演『好像騎士』的遊戲，",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_007"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n是不是讓妳克服了自卑感啊？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "別隨便解讀我，",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "克莉絲提娜！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小心妳說話的方式，",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "小丫頭。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "今天有一個很暢快的經驗……",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真想保持著這個愉快心情去睡覺呀。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "整天匆匆忙忙，我也累了。",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n沒有力氣和妳耗下去。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "明天再跟你玩吧。",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_012"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳今天趕快回家，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "吃了媽媽親手做的料理就睡覺吧。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不、",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_013"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "不要當我是小孩子！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "純妳也是啊，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳也說點什麼！",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_014"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "團長。",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_015"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n難道，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳也要把我當作不斷做出蠻橫行為的笨蛋來斥責我嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "關於對妳的處置，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就交由陛下負責的軍事法庭決定吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒有權利制裁妳。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳好像",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是身負陛下的密令而行動的吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳也只是個受人操控的傀儡而已。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "要是妳有這個自覺，而且也願意接受的話，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那我也無話可說。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果那個立場會使妳痛苦的話，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我想幫助妳。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真是善良。",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我只不過是，",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "厭倦了和平而已。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過因為這次事件也埋下了導火線，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "算是滿足了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "接下來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就看會延燒到哪種程度了……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……哎呀。",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我沒有閒功夫可以悠哉聊天。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "…………",
        "unit_id": 106012,
        "voice": "vo_adv_2002005_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不好意思，",
        "unit_id": 106012,
        "voice": "vo_adv_2002005_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在妳們聊得高興的時候打斷妳們了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n克莉絲提娜副團長，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下想要召見您。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n請馬上，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "動身前往會議大廳。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "了解，",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_025"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "陛下要召見我的話，就不能不去了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n到底是什麼事情呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "難不成要獎賞我嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這我也不知道。",
        "unit_id": 106012,
        "voice": "vo_adv_2002005_026"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想要問陛下找您有什麼事，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請您直接問陛下吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵呵。",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_027"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "叫做凱留是嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳應該也是獸人吧，",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_028"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "有這個耳朵和尾巴……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n關於這次的事情，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳應該也有一些想法吧？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧，",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_029"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "就算妳想盡情地罵我也沒關係喔。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n把我當作，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "襲擊妳獸人同胞的無禮之徒。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……和妳玩玩，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "感覺也挺愉快的♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我只是個",
        "unit_id": 106012,
        "voice": "vo_adv_2002005_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "負責傳話的人而已。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還請您不用在意我。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且……",
        "unit_id": 106012,
        "voice": "vo_adv_2002005_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我跟陛下，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n都與這個國家的獸人沒有任何關係。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "那，",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_032"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳們到底是什麼？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂團長，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "還有那裡的智小姐……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n妳們都不覺得不自然嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "在歷史上，",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "蘭德索爾王族和獸人們是水火不容的。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n不斷地發生一些，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "血淋淋的對立和鬥爭。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然最近，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "進入了休戰狀態。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只是……",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_034"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n最近我們的首領陛下，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n身邊的心腹凱留也是獸人。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這不是很奇怪嗎？",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_035"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我啊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可是怎麼想都難以釋懷呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "說不定。",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_036"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n我們所有人，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "都被那位陛下給騙了呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "您說得有些過火了，",
        "unit_id": 106012,
        "voice": "vo_adv_2002005_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "克莉絲提娜副團長。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n您這樣可是會被問不敬之罪喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "比起那個，",
        "unit_id": 106012,
        "voice": "vo_adv_2002005_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "請您馬上動身。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可別讓陛下，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "等太久了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊，",
        "unit_id": 107111,
        "voice": "vo_adv_2002005_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "知道了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n牽我的手送我過去吧，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n可愛的小姐……♪",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "…………",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_040"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……純，",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_041"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "妳覺得呢？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總而言之，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我希望妳不要那麼",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "劍拔弩張的呢～",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小克莉絲……",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "克莉絲提娜副團長",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n和妳合不來這件事我是知道的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也不會強迫妳們",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "非得要合得來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但好歹都是夥伴，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n希望妳可以再努力去理解她一點。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n別看她那樣，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "其實她也有自己的難處。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好啦，",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_045"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我會努力啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "比起這個，",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_046"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "有件事情我挺在意的……",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "那個傳令使，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "好像叫做什麼凱留的吧？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "她到底是什麼人啊？",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_047"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n不知道從什麼時候開始，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n她似乎就已經以陛下侍女的身分在工作了。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "的確，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很難理解呀。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也是剛剛副團長提到才知道，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n之前也沒覺得很奇怪。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很自然地，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就接受了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n明明是個挺不自然的存在。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "說起來，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_050"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "的確很奇怪。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為什麼歷史以來和我們對立的獸人族，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n做了統治我們的領導？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "總覺得很矛盾。",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_051"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n怎樣想都不合邏輯。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我不擅長說話，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_052"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不能好好的說明。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但總覺得，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這跟我的認知似乎有點出入……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有一種，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "古怪的違和感。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小智。",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_053"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我身為",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "守衛王宮的人，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有義務需坐鎮在此處。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我不能隨意走開。",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_054"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以希望妳可以代替我，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n去調查這些事情。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這股違和感，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_055"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "以及這次的騷動……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n說不定，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "全是某個巨大陰謀的一環也說不定。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看樣子，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_056"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "事情的隱情比我想像中的還多。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有必要慎重並謹慎地抽絲剝繭，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "查明真相。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n如果能去親自調查就好了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但礙於身分我沒辦法這樣做。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以，",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_057"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就拜託妳了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n或許會有危險，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但也沒有其他辦法了",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "沒關係哦。",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_058"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "能夠被信任，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我感到很光榮。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "況且，我也有點頭緒……",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_059"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n我會去到處打聽一下的。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我本來，",
        "unit_id": 103711,
        "voice": "vo_adv_2002005_060"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就很清楚這相當危險啦。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n即使賠上性命也要",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "拯救國難，",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "懲治皇家的敵人。",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n這不就是，我們",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "【王宮騎士團】的使命嗎？",
        "unit_id": 103711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_2002005_061"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這一切，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "都是為了我們所堅信的正義。",
        "unit_id": 104711
    },
    {
        "type": "still",
        "still": "200099901"
    }
]