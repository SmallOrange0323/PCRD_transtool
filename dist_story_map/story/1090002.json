[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某一天，{player}突然被惠理子\n叫出來，\n來到了市區的集合地點。"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您來了呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "惠理子……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一直在等您……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有哪裡不對勁嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是您的錯覺啦。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我跟平常一樣……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就是原本的惠理子喔……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這是……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "能見到{player}大人\n才高興的",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "顫抖。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是因為在這裡等了３小時左右，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "身體都著涼了。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您可以這樣想啦……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哈啾。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "被{player}大人\n用那種眼神盯著看……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我的身體熱得像著火一樣呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我等不及能見到{player}大人，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n所以３小時前就過來等，實在值得了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對了，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我今天\n找{player}大人過來是――",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……咦，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人！？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "　……呀！？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您怎麼突然握住我的手……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n是發生什麼事了嗎！？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "難道是……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要幫我溫暖我的手嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "可是，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣做的話，\n{player}大人的手會變冰的……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您的手真溫暖……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "簡直就像{player}大人的心一般。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那個……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我今天找您到這裡是……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您能就這樣",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "和我一起出去嗎……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "太感謝您了！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如此溫柔的{player}大人真的是",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我命中注定之人……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻嘻。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "竟然會如此的順利……！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "約會作戰，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "第一階段成功了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要去逛昨天在雜誌上看到的約會地點。",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n上面寫說如果能和喜歡的人去過所有的地點，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n二個人就能在一起呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "約會好像還是自然地做最好，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n只要今天不要說些會讓他意識到是約會的話就行了。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就請先陪我去逛街吧。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有一個非常想要的東西。",
        "unit_id": 109011
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "歡迎光臨〜",
        "unit_id": 411,
        "voice": "vo_adv_1090002_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是這裡沒錯吧……？",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有賣雜誌上寫的造成話題的胸針嗎……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "想買到",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "然後現在就送給他……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那個……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我正在找胸針……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "是指雜誌上介紹的胸針嗎？",
        "unit_id": 411,
        "voice": "vo_adv_1090002_021"
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "實在非常抱歉。",
        "unit_id": 411,
        "voice": "vo_adv_1090002_022"
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "那是我們的暢銷商品，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "\n現在已經沒有庫存了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣啊……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是啊，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但是沒有什麼特殊意思啦。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n{player}大人不需要在意。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只要送給異性，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "對方就會愛上你，\n是大受好評的胸針……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣說明就太庸俗了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哈啊……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_026"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哈啊……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哈啊……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我是怎麼了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "全身好疲倦，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好像不是自己的身體一樣了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "難道是在哪吃了自製的藥嗎？",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "才不是，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我今天沒有把藥帶出來。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "還是說被對我懷恨在心的人下毒了？",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不對，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今天一整天，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "應該沒有人對我有殺氣……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "感……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "冒……？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您要去哪裡啊！？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_032"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "他走掉了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然要我在這裡稍微等一下……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n可是他到底是要去哪裡呢？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我沒想到您竟然是去幫我買藥了……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_033"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "多虧有您，我的狀態也已經好多了。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒想到我會有被{player}大人餵藥的一天，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_034"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n真是嚇到我了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "其實……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_035"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我最後還有一個想去的地方，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您能陪我一起去嗎？",
        "unit_id": 109011
    },
    {
        "type": "background",
        "background": "500142"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_036"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您看。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n到處都有螢火蟲在飛。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我一直",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "夢想著和{player}大人來這裡。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？　",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_037"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要說是為什麼的話……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那個……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_038"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為這裡是非常浪漫的地方。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "雖然雜誌上說，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_039"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在這裡接吻的情侶，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n能夠永遠地在一起……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我該怎麼靠近他呢。",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_040"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這時候還是要",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "裝作不經意地……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_041"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您鼻子上沾到東西了。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我幫您拿下來。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣一來，就能自然的靠近他的臉……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_042"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_043"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您不需要自己這樣粗暴的擦鼻子呀。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "上面已經沒有東西了……！",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_044"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "應該還有其他對策的……！",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_045"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_046"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好痛……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好像有灰塵飛到我眼睛裡了。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這次一定",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_047"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要跟他縮短距離……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呀！？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "竟然是{player}大人先靠過來！？",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_048"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "　您為什麼往我眼睛吹氣……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n咦，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是要把灰塵吹走嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是的！　",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_049"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣下去沒有進展……！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "既然這樣，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就乾脆強吻他……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您稍微閉上眼睛，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_050"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "他的臉好靠近……！",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "難道說，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_051"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人他……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "要吻我！？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請問……",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_052"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人……？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n您遮住我的視線，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是想做什麼呢？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "有東西想給我？",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_053"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n咦，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這個是……！",
        "unit_id": 109011
    },
    {
        "type": "still",
        "still": "109000201"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我在一開始的店裡找的",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_054"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "胸針！？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n這個……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您是在哪裡……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_055"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "原來您記得在旁邊的雜貨店有賣呢。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "可是，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您是什麼時候買的呀？",
        "unit_id": 109011
    },
    {
        "type": "still",
        "still": "109000202"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_056"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是去買藥的時候，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "特地一起去買的嗎？",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了我做這麼多，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "實在是太感謝您了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "可是，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_057"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這東西不是由我送給{player}大人，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n就沒有意義了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為您就算",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_058"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒有送這個胸針給我，",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我早就已經喜歡上{player}大人了……",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "總有一天我會靠自己的魅力，",
        "unit_id": 109011,
        "voice": "vo_adv_1090002_059"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n讓{player}大人回頭看我的。",
        "unit_id": 109011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "讓{player}大人回頭看著我。\n惠理子滿臉微笑，幹勁十足的下定了決心。"
    },
    {
        "type": "still",
        "still": "end"
    }
