        "name": "空花",
        "words": "而忘記目的了……！",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "被虐狂夏日慶典，",
        "unit_id": 127011,
        "voice": "vo_adv_1270001_066"
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "\n",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "空花",
        "words": "看來會是個超開心的慶典呢～♪",
        "unit_id": 127011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "空花以一如往常的言行舉止使周遭喪失了鬥志。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n對於在熱沙道路上悠然前進的她，有一群人露出了充滿興趣的眼神。"
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "哦……",
        "unit_id": 6511,
        "voice": "vo_adv_1270001_067"
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "那孩子，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "挺有意思的嘛。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "在火熱的沙灘上居然也能笑著。",
        "unit_id": 6311,
        "voice": "vo_adv_1270001_068"
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "\n",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "看來她說不定和我們一樣",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "也是貨真價實的呢。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "哼，",
        "unit_id": 6511,
        "voice": "vo_adv_1270001_069"
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "這可不好說。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "\n那點程度居然就說是貨真價實，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "女被虐狂",
        "words": "你的標準也變低了呢？",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "究竟是不是貨真價實，馬上就會揭曉了。",
        "unit_id": 6311,
        "voice": "vo_adv_1270001_070"
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "\n畢竟只要進入正式比賽，",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "男被虐狂",
        "words": "就會直接對上我們啊。",
        "unit_id": 6311
    },
    {
        "type": "dialogue",
        "name": "受虐狂們",
        "words": "呵呵呵呵呵……",
        "unit_id": 1,
        "voice": "vo_adv_1270001_071"
    }
]