        "type": "dialogue",
        "name": "可可蘿",
        "words": "……啊……",
        "unit_id": 115511,
        "voice": "vo_adv_5059323_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請相信我們。",
        "unit_id": 105811,
        "voice": "vo_adv_5059323_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請依靠……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可靠的夥伴。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是啊……",
        "unit_id": 115511,
        "voice": "vo_adv_5059323_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一個人感到焦慮……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以……",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "忽略了身邊。",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "明明大家",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都這麼關心",
