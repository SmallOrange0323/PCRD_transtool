        "voice": "vo_adv_5059323_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "必須獲勝……！",
        "unit_id": 115511
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
