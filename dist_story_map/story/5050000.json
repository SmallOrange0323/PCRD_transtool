[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}揹著沉重的包裹，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與紡希、怜一同走在城外大道上。"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "快點啊，騎士先生，",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_000"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "步伐再輕快一點。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果要趕路，",
        "unit_id": 100311,
        "voice": "vo_adv_5050000_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也幫忙拿一半吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怎麼可以讓怜大人拿行李呢！",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_002"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "而且我有付騎士先生打工的薪水，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n所以沒有任何問題喔。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "對吧，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的確，",
        "unit_id": 100311,
        "voice": "vo_adv_5050000_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你很常在做配送的工作呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我應該也算擅長勞力工作吧",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "怜大人是好心陪我過來的，",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_004"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n什麼都不做也沒關係！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只要跟我待在一起，就算是幫了大忙了！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既然紡希都這樣講了，那好吧……",
        "unit_id": 100311,
        "voice": "vo_adv_5050000_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "對了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": " 他揹著的是什麼東西啊？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是我做的衣服。",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_006"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n現在就是要去把衣服交給客人喔。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "光是衣服",
        "unit_id": 100311,
        "voice": "vo_adv_5050000_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就有這麼多？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是製作了哪個公會的制服嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "現在要去的地方",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_008"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是充滿萬聖節氣氛的城鎮，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n甚至被暱稱為萬聖節樂園呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "今年好像要舉行大規模的遊行，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這些就是遊行的衣服。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "之前",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_009"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "舉辦慈樂之音的演唱會時有去過那裡，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "鎮上的裝飾真的是太厲害了，嚇了我一跳。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼厲害的城鎮竟然委託紡希做衣服，",
        "unit_id": 100311,
        "voice": "vo_adv_5050000_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳的手藝",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "很受大家欣賞呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_011"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "這樣嗎……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "聽妳這樣說我很高興呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "畢竟我最近一～～",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "直關在房間裡忙工作嘛！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n這麼努力是有價值的！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也要謝謝騎士先生",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_012"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "幫忙收集素材。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果沒有你，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也沒辦法完成這次的委託呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既然這麼辛苦，",
        "unit_id": 100311,
        "voice": "vo_adv_5050000_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n怎麼不跟我說一聲呢？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那、",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_014"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "那是因為！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "只是因為",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生比較好差遣而已啦！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵，",
        "unit_id": 100311,
        "voice": "vo_adv_5050000_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我知道啦。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話說回來，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "手上空空的果然還是有點無法冷靜呢，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n{player}，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可以把行李分我一點嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "啊，",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_016"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "就說不必了嘛！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "如果怜大人要提東西，那我也要拿！",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣嗎？",
        "unit_id": 100311,
        "voice": "vo_adv_5050000_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過紡希剛完成工作，現在很累吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "提一點點沒事的，",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_018"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n三個人分工合作",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "趕快一起送過去吧！",
        "unit_id": 105411
    },
    {
        "type": "background",
        "background": "501130"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我們送來",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_019"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "各位委託的遊行用服裝了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "喔喔，",
        "unit_id": 511,
        "voice": "vo_adv_5050000_020"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "謝謝你們啊。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n如此一來今年的萬聖節",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "應該也能好好熱鬧一番啦。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "能派上用場就好，",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_021"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "希望會是個愉快的遊行呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "妳就好好期待吧。",
        "unit_id": 511,
        "voice": "vo_adv_5050000_022"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n我們和鎮上的鬼屋合作，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "編排了盛大的遊行……",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "啊，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "說人人到。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "喂──",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "組長！",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "組長",
        "words": "怎麼了？",
        "unit_id": 1411,
        "voice": "vo_adv_5050000_023"
    },
    {
        "type": "dialogue",
        "name": "組長",
        "words": "鎮長。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "這位就是",
        "unit_id": 511,
        "voice": "vo_adv_5050000_024"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "一手操辦",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "樂園鬼屋的組長。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n然後這邊這位是",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "負責製作這次遊行服裝的",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "紡希小姐。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "組長",
        "words": "喔！",
        "unit_id": 1411,
        "voice": "vo_adv_5050000_025"
    },
    {
        "type": "dialogue",
        "name": "組長",
        "words": "我有聽說是位手藝很好的人，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "組長",
        "words": "\n沒想到是這麼年輕的小妹妹啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也、",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_026"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "也沒你說的那麼好啦……",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝誇獎。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "組長",
        "words": "我可不能輸給小妹妹，",
        "unit_id": 1411,
        "voice": "vo_adv_5050000_027"
    },
    {
        "type": "dialogue",
        "name": "組長",
        "words": "一定會帶出最棒的遊行，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "組長",
        "words": "\n你們就好好期待吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "我們接下來",
        "unit_id": 511,
        "voice": "vo_adv_5050000_028"
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "還有遊行的會議，",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n就先暫時失陪了。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "\n",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "再次感謝妳",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "鎮長",
        "words": "製作了這麼棒的服裝。",
        "unit_id": 511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我之前很擔心他們會不會滿意，",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "不過能順利交貨真是太好了。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n怜大人、",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "騎士先生，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "謝謝你們陪我一起來。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "紡希一定沒問題的……",
        "unit_id": 100311,
        "voice": "vo_adv_5050000_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然我也想這樣說，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不過看到這個城鎮，多少能理解妳擔心的心情呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
