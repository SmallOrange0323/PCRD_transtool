        "name": "紡希",
        "words": "要我們陪妳去什麼很難以開口的地方嗎？",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒、",
        "unit_id": 100511,
        "voice": "vo_adv_5050000_062"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "沒有那種事啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我只是",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "希望你們",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "陪、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "陪我一起去鬼屋！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "鬼屋啊？",
        "unit_id": 100311,
        "voice": "vo_adv_5050000_063"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就是指剛剛那位組長負責操辦的那個呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "是不是該說",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_064"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "來得",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "正是時候呢。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "雖然不知道是不是時候啦，",
        "unit_id": 100511,
        "voice": "vo_adv_5050000_065"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不過萬聖節樂園的鬼屋",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "好像非常恐怖，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n我很想去看看，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "可是一個人進去、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那個、",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "有點……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "嗯。",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "嗯……",
        "unit_id": 105411,
        "voice": "vo_adv_5050000_066"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "我也很在意\n會是什麼樣的人穿上我的衣服，",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "好啊。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "一起去吧。",
        "unit_id": 105411
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果是為了紡希的工作，",
        "unit_id": 100311,
        "voice": "vo_adv_5050000_067"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就令人無法拒絕呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也一起去吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "真的嗎！",
        "unit_id": 100511,
        "voice": "vo_adv_5050000_068"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那就大家一起去吧！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "跟隨著意氣風發地邁開腳步的茉莉，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}一行人便朝著鬼屋出發了。"
    }
]