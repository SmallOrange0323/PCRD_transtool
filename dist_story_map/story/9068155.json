[
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯……",
        "unit_id": 126811,
        "voice": "vo_adv_9068155_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n為什麼我們穿著泳裝啊？",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "都是優花梨的錯吧！\n都是優花梨的錯喔！\n都是優花梨的錯喵！",
        "unit_id": 1,
        "voice": "vo_adv_9068155_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果要視察吉歐‧格黑納，",
        "unit_id": 126711,
        "voice": "vo_adv_9068155_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "最好穿少一點才好生活。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n因為很熱，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以泳裝是最佳選擇。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這樣說的人不就是勘查回來的優花梨嗎！？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣說來，",
        "unit_id": 107911,
        "voice": "vo_adv_9068155_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "印象中出發前的優花梨滿身麥酒味喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "但實在沒想到，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "門的出口會是熊熊大火的叢林喵……",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "難不成，",
        "unit_id": 108011,
        "voice": "vo_adv_9068155_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "說能運用在商業上的那個泉水，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n其實也只是優花梨的一廂情願……？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "確、",
        "unit_id": 126811,
        "voice": "vo_adv_9068155_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "確實是我提議的……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "是，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我已經酒醒了喔！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以說，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒問題的！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n而且，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "會湧出麥酒泉水的情報是真的喔！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "盯……",
        "unit_id": 1,
        "voice": "vo_adv_9068155_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "別、",
        "unit_id": 126811,
        "voice": "vo_adv_9068155_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "別用那種眼神看我嘛……！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n雖然泳裝的事",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真的很抱歉，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但只要找到麥酒的泉水，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就會形成商機了……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對不對！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不過，",
        "unit_id": 126711,
        "voice": "vo_adv_9068155_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總不能少根筋到穿泳裝在",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n熊熊大火的叢林裡探索吧？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n各位，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總之先以居住區為目標前進吧。",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "等一下喵！",
        "unit_id": 107911,
        "voice": "vo_adv_9068155_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n讓路癡的秋乃打頭陣",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可不好喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "最糟的結果，",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "會穿著泳裝橫死在叢林喵！",
        "unit_id": 107911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也是……",
        "unit_id": 108011,
        "voice": "vo_adv_9068155_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "優花梨，",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "妳知道居住區在哪裡嗎？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗯，",
        "unit_id": 126811,
        "voice": "vo_adv_9068155_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然不是很確定，但我知道喔。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "往居住區的路……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "記得是這邊。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "跟我走吧。",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "話說回來，",
        "unit_id": 126811,
        "voice": "vo_adv_9068155_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "熱成這樣就好想喝一杯呢……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n麥酒的泉水，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "能不能快點找到呢……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "優花梨……？",
        "unit_id": 108011,
        "voice": "vo_adv_9068155_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們真的是",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "往居住區的方向走對吧？",
        "unit_id": 108011
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？",
        "unit_id": 126811,
        "voice": "vo_adv_9068155_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "當、",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "當然啊！",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "看，",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這裡有人的氣息……",
        "unit_id": 126811
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "優花梨……！\n優花梨……！",
        "unit_id": 1,
        "voice": "vo_adv_9068155_015"
    }
]