    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "——放箭！！",
        "unit_id": 191411,
        "voice": "vo_adv_2101012_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咳、咳……",
        "unit_id": 100211,
        "voice": "vo_adv_2101012_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咳、",
        "unit_id": 106414,
        "voice": "vo_adv_2101012_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咳。",
        "unit_id": 106414
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這究竟是……！？",
        "unit_id": 100311,
        "voice": "vo_adv_2101012_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是凱留小姐的魔法嗎，",
        "unit_id": 105913,
        "voice": "vo_adv_2101012_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "方才的爆炸……！？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才不是咧！",
        "unit_id": 106012,
        "voice": "vo_adv_2101012_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不過，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "到底是怎麼一回事！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "唔……！",
        "unit_id": 191411,
        "voice": "vo_adv_2101012_006"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n終於露出本性了嗎！這群逆賊！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n既然如此，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "就由我親手……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "——豪紳議長！",
        "unit_id": 4312,
        "voice": "vo_adv_2101012_007"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n剛才的爆炸，",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "使得天花板開了一個洞……",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "\n而從上頭",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "好像有什麼出現了！",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "什麼！？",
        "unit_id": 191411,
        "voice": "vo_adv_2101012_008"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n竟然是魔物！！",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "\n",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "雖說是地下，但這裡可是王宮中啊，",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "哨兵在做些什麼……",
        "unit_id": 191411
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "豪紳",
        "words": "嗚哇啊啊！？",
        "unit_id": 191411,
        "voice": "vo_adv_2101012_009"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "豪紳議長——！？",
        "unit_id": 4311,
        "voice": "vo_adv_2101012_010"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "放箭、",
        "unit_id": 4312,
        "voice": "vo_adv_2101012_011"
    },
    {
        "type": "dialogue",
        "name": "士兵１",
        "words": "放箭！",
        "unit_id": 4312
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "……沒、",
        "unit_id": 4311,
        "voice": "vo_adv_2101012_012"
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "沒有用！",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "士兵２",
        "words": "\n箭矢被彈開了！",
        "unit_id": 4311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500340"
    },
    {
        "type": "dialogue",
        "name": "士兵們",
        "words": "哇啊啊啊啊～！",
        "unit_id": 1,
        "voice": "vo_adv_2101012_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "吶！",
        "unit_id": 100111,
        "voice": "vo_adv_2101012_014"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n那隻魔物難道是……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯！",
        "unit_id": 100311,
        "voice": "vo_adv_2101012_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n和數小時之前，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "襲擊了廣場的魔物是相同的個體！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也就是說……！",
        "unit_id": 106012,
        "voice": "vo_adv_2101012_016"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "——唷。",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_017"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n終於找到",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "你們了。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那孩子……！",
        "unit_id": 100211,
        "voice": "vo_adv_2101012_018"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n果然又來了呀！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "找到我們了……",
        "unit_id": 105913,
        "voice": "vo_adv_2101012_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "換句話說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這次相當明確地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是以在下等人為目標而來的嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n與先前不同……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "就是這麼一回事。",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_020"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n為了達成我的「目的」，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n似乎先把礙事的傢伙幹掉比較好的樣子。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "目的……？",
        "unit_id": 100311,
        "voice": "vo_adv_2101012_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "你",
        "unit_id": 100211,
        "voice": "vo_adv_2101012_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "究竟是……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我的名字是",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_023"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "卡里莎。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "\n——【憤怒‧軍團】的卡里莎。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "卡里莎",
        "unit_id": 100111,
        "voice": "vo_adv_2101012_024"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……【憤怒‧軍團】……",
        "unit_id": 105913,
        "voice": "vo_adv_2101012_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那會是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那位人士所屬的公會名稱嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不認為你會突然變得如此有禮。",
        "unit_id": 100311,
        "voice": "vo_adv_2101012_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n方才詢問你的名字時，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "得到的答案可是嗤之以鼻。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "究竟是什麼改變了你的態度？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "妳說我有禮貌？",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_027"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "那種事我壓根都沒想過啦。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那，",
        "unit_id": 106012,
        "voice": "vo_adv_2101012_028"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你到底是想怎樣！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不管是剛剛還是現在，",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_029"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "若是要我把你們像是小石子一樣捏碎，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我一點都不覺得會有什麼困難。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……不過，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就是這種想法讓我失敗了一次呢。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "所以呢，",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_030"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n這一次我會確實地",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "把你們當成敵人來看了。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n把你們當成敵人，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "再徹底捏碎。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我會這麼特地報上名號，",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_031"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n也只是為了提高你們的價值而已。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n畢竟若只是塊小石子，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "才沒有辦法喊出我的名字呢。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……雖然有點聽不懂……",
        "unit_id": 100211,
        "voice": "vo_adv_2101012_032"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n但是不是在表示，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "他不會再大意了呢？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然最好的情況，",
        "unit_id": 100111,
        "voice": "vo_adv_2101012_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是不用戰鬥就能解決呀……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "然而對方，",
        "unit_id": 100311,
        "voice": "vo_adv_2101012_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "似乎沒有想要收手的意思。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n甚至，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "特別報上了名號，也是為了這場戰鬥……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我沒說錯吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "是啊。",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_035"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "不過嘛，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "要說別的理由……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就是被那隻垃圾貓叫什麼矮子還小鬼的，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n讓人聽起來很煩所以才會這麼做就是了？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "誰是垃圾貓啊！",
        "unit_id": 106012,
        "voice": "vo_adv_2101012_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們不但被關在這裡頭，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且還差點被下三濫的貴族給殺掉，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以我現在可是超級不爽的呀！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你這個臭矮子！",
        "unit_id": 106012,
        "voice": "vo_adv_2101012_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n死小鬼！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這一次，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我絕對要宰了你啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "——哈。",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_038"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "——幹掉他們。",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_039"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "你們這些垃圾魔物。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n連同這座牢籠，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "給我把這些人的內臟撕得四分五裂。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咿！",
        "unit_id": 106414,
        "voice": "vo_adv_2101012_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管是為了阻止逃獄而附加了防禦魔法的柵欄……",
        "unit_id": 105913,
        "voice": "vo_adv_2101012_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n但若遭受到如此的攻勢，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "仍舊撐不了多久……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大家，",
        "unit_id": 106011,
        "voice": "vo_adv_2101012_042"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "閃遠點！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果是對人類用的話比較難拿捏，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但若是這些傢伙的話就用我的攻擊魔法……！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "慢著！",
        "unit_id": 100311,
        "voice": "vo_adv_2101012_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n只要魔物身上仍散發著那個能量，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們的攻擊就起不了作用！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這麼說來對呀！　",
        "unit_id": 100111,
        "voice": "vo_adv_2101012_044"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那麼～這樣的話，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "優衣！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n剛剛那個發光的魔法，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳用得出來嗎！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦咦！？",
        "unit_id": 100211,
        "voice": "vo_adv_2101012_045"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唔、",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "唔～～嗯……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "靠妳了，",
        "unit_id": 100311,
        "voice": "vo_adv_2101012_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "優衣！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要突破現狀，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就只剩那個了……！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……對不起！",
        "unit_id": 100211,
        "voice": "vo_adv_2101012_047"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n果然",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咒文和效果都不清楚的狀況還是沒辦法使用……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哈！",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_048"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n跟我想的一樣……",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "剛才那個奇怪的光芒，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n妳好像根本就還不太會用嘛！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "只要解除不了我的強化，",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_049"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n那你們就完全動不了我的魔獸啦！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "馬上就把妳幹掉啊，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "粉紅毛……！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那種事，",
        "unit_id": 100111,
        "voice": "vo_adv_2101012_050"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "才不會讓你得逞的唷……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "啊啊！",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_051"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n不只是那個粉紅毛！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "等我把你們全都碾碎後，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "我再順便把這整座王宮剷平啦！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "為什麼……",
        "unit_id": 100211,
        "voice": "vo_adv_2101012_052"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n為什麼要做出這種過分的事……！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "難不成，",
        "unit_id": 105913,
        "voice": "vo_adv_2101012_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是對這個國家",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱有何等的深仇大恨嗎……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哈！　",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_054"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "才沒有那種東西。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "這全部，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "都只是為了——「實現我的願望」啦！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n若只是普通地幹，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "再怎麼辦都辦不到的願望就是了！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了",
        "unit_id": 100311,
        "voice": "vo_adv_2101012_055"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "實現願望……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那便是你方才說的「目的」嗎……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "可是可是！",
        "unit_id": 100111,
        "voice": "vo_adv_2101012_056"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n就算你破壞城鎮",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "又傷害我們……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "做出這麼壞的事情來，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "你的願望也沒辦法實現啦！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！",
        "unit_id": 100211,
        "voice": "vo_adv_2101012_057"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n比起你這麼做，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不如和我們一起",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n目標登上索爾之塔的頂端還比較好……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "……啊？",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_058"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n索爾之塔？",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "——哈！",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_059"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n你們還真的是什麼都不知道耶。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "那邊早就已經",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_060"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "是空殼了啊。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n就算你們爬到了頂端也什麼都沒有，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "那裡就只是空空的鳥籠罷了。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "哪有辦法",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "實現什麼願望。",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦……？　",
        "unit_id": 100111,
        "voice": "vo_adv_2101012_061"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦～～……！？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "怎麼這樣……！",
        "unit_id": 100211,
        "voice": "vo_adv_2101012_062"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那麼我們",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "【破曉之星】做的一切究竟是為了……！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "卡里莎，",
        "unit_id": 100311,
        "voice": "vo_adv_2101012_063"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你說的是真的！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n若是真的，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那你又究竟是如何知……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500342"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊！",
        "unit_id": 105913,
        "voice": "vo_adv_2101012_064"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n柵欄",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被魔物給咬穿了……！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "來呀，",
        "unit_id": 191611,
        "voice": "vo_adv_2101012_065"
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "就給我抵抗看看吧！",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "看我怎麼把你們無謂的掙扎踩在腳底下，",
        "unit_id": 191611
    },
    {
        "type": "dialogue",
        "name": "卡里莎",
        "words": "\n然後再把你們全都砸到那骯髒的牆上！",
        "unit_id": 191611
    },
    {
        "type": "background",
        "background": "500342"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗚！",
        "unit_id": 100312,
        "voice": "vo_adv_2101012_066"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊！",
        "unit_id": 100111,
        "voice": "vo_adv_2101012_067"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咿～～……！",
        "unit_id": 106414,
        "voice": "vo_adv_2101012_068"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "――咕喔喔喔喔喔！",
        "unit_id": 1611
    }
]