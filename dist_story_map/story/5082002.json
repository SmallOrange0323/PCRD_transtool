        "name": "凱留",
        "words": "\n",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "前往下個目的地吧。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是……",
        "unit_id": 111811,
        "voice": "vo_adv_5082002_089"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是啊……",
        "unit_id": 120912,
        "voice": "vo_adv_5082002_090"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "接著要去哪裡？",
        "unit_id": 120912
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前往大間吧。",
        "unit_id": 111911,
        "voice": "vo_adv_5082002_091"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不錯呢。",
        "unit_id": 120811,
        "voice": "vo_adv_5082002_092"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我們趕緊走吧！",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n喏喏！",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "快點出發！",
        "unit_id": 120811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是啊，",
        "unit_id": 111811,
        "voice": "vo_adv_5082002_093"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "打起精神來吧！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "美味的海鮮在等著我們喔！",
        "unit_id": 111811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 111911,
        "voice": "vo_adv_5082002_094"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "流夏小姐和貪吃佩可小姐看起來很開心呢。",
        "unit_id": 111911
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "嘿嘿嘿……",
        "unit_id": 811,
        "voice": "vo_adv_5082002_095"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "簡單啦。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "\n嗯，雖然把母錢花掉了，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "不過這點錢馬上就能……",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀！",
        "unit_id": 112011,
        "voice": "vo_adv_5082002_096"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "走路看前面啦！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "囉嗦！",
        "unit_id": 811,
        "voice": "vo_adv_5082002_097"
    },
    {
        "type": "dialogue",
        "name": "可疑男子",
        "words": "別擋路！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒事吧？",
        "unit_id": 120711,
        "voice": "vo_adv_5082002_098"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留。",
        "unit_id": 120711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我沒事……",
        "unit_id": 112011,
        "voice": "vo_adv_5082002_099"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙搞什麼啊？",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還面露賊笑。",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "氣死人了！",
        "unit_id": 112011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
