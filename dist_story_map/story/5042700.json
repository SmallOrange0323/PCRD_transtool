[
    {
        "type": "background",
        "background": "500850"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "【ドラゴンズネスト】の3人はふたたびエルピス島の密林にある、\nドラゴンもどきの住む遺跡を訪れていた。"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "お～い、",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_000"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "いるですか～？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "出てくるですよ～！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "お土産もあるですから～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "土産って",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_001"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "なに持って来たんだ？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "お菓子ですよ！",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_002"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nきっと気に入るです！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "そういえば",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_003"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "アイツが最初に襲撃してきた時、",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "\nキャンプからチョコがごそっとなくなってたな……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "イノリちゃん。",
        "unit_id": 106711,
        "voice": "vo_adv_5027700_004"
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "\nあそこでこっちの様子見てるよ？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "じゃあ",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_005"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "さっさと引っ張り出そうぜ。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "待つですよカヤぴぃ！",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_006"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nカヤぴぃにボコボコにされてビビってやがるです。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "大丈夫ですよ～、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "こわくないですよ～……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "ドラゴンもどき",
        "words": "ぐもも……",
        "unit_id": 12311,
        "voice": "vo_adv_5027700_007"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "こっちくるです！",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_008"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nおいしいチョコもあるですよ～！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "お、",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_009"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "来た来た。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "\n見た目通り食い意地はってるな……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "さっそく話聞いてみようぜ。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ふむふむ……",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_010"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ドラゴンが、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "うらやましかったんですね。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "コイツ……",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_011"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ドラゴンになりたくてこういう格好してたですよ。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "やっぱり言ってることが分かるみたいだな。",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_012"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "なんとなくですけど……",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_013"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "あたしたちのキャンプに来たのも、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ドラゴンの気配を感じたから",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nみたいなこと言ってるですよ。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "確かに話は通じてるみたいだね。",
        "unit_id": 106711,
        "voice": "vo_adv_5027700_014"
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "それで、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "遺跡のことは何て？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "……むむぅ、",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_015"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "なんか言いたいことは分かるですけど",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n細かいところがはっきりしないというか……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "うう～！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "分からないですよ！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "なんだそりゃ？",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_016"
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "感情は伝わっても",
        "unit_id": 106711,
        "voice": "vo_adv_5027700_017"
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "具体的なことは言語化できない、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "ってことかな。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "細かい聞き取りは無理そうだね～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "ボスにも何言ってる分かんないんだよな？",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_018"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "なんでイノリにだけ分かるんだ？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "そもそもの相性",
        "unit_id": 106711,
        "voice": "vo_adv_5027700_019"
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "ってのもあると思うけど～",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "\n",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "やっぱり",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "知能の程度が近い",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "ってことなんだと思うな〜☆",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "そっか……",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_020"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "こいつもかなりのマヌケってことか。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "かわいそうに……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "カヤぴぃ！？　",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_021"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "今とっても失礼なこと言ったです！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "だってさあ、",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_022"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "結局何の役にも立たないってことだろ？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "わざわざ二回来てダメだったとか……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "はぁ……",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "あううぅ！　",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_023"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ま、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "待つですよ！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nこいつは役立たずなんかじゃないです！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "そうだ、",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_024"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "教えるですよ！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "言葉を教えればきっと聞き出せるです！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "できるのかぁ？",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_025"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "\nこいつ見た目からして相当バカそうだぞ？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "ちょうどいいし、",
        "unit_id": 106711,
        "voice": "vo_adv_5027700_026"
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "この石板を使ったらどうかな〜？",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "\n物の名前や概念を",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "ゆっくり教えていけば、",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "\nもしかしたら",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "ホマレ",
        "words": "私たちとも会話できるかも〜",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "それです！",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_027"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nこれでカヤぴぃより頭がいいことを",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "見せつけてやるですよ！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "いやいやいや、",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_028"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "さすがにそれはないって。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "そうと決まればまずは名前です。",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_029"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nあたしがゴッドマザーになってやるですよ。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ドラゴンもどき……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ドラモ！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "おまえの名前はドラモです！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "ドラモ",
        "words": "ぐももも！",
        "unit_id": 12311,
        "voice": "vo_adv_5027700_030"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ふふふ、",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_031"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "そうですか、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "気に入ったですか……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "カヤぴぃ！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "首を洗って待ってるですよ！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "へいへい、",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_032"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "分かったよ。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "せいぜいがんばんな。",
        "unit_id": 106511
    },
    {
        "type": "background",
        "background": "500520"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "そして、イノリによるドラゴンもどきの教育が始まった。\n時に厳しく、時に熱く……\n主にチョコで釣るイノリの教育は続き……"
    },
    {
        "type": "background",
        "background": "500850"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ふふ、",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_033"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "ふふふふふふふ……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "勝てる！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "これで勝てるです！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "カヤぴぃ！　",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "勝負です！！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "なんだ？　",
        "unit_id": 106511,
        "voice": "vo_adv_5027700_034"
    },
    {
        "type": "dialogue",
        "name": "カヤ",
        "words": "どうしたんだ？",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "あたしとドラモの修行が実を結んだです。",
        "unit_id": 106611,
        "voice": "vo_adv_5027700_035"
    },
    {
        "type": "dialogue",
        "name": "イノリ",
        "words": "\nこの石板を使ったしりとりで",
        "unit_id": 106611
