[
    {
        "type": "background",
        "background": "501132"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一走在路上，",
        "unit_id": 114011,
        "voice": "vo_adv_6050208_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "孩子們就會來要糖果呢！",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可惜手上沒有糖果只好都讓他們惡作劇。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但一想到這是萬聖節，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就覺得很開心呢！",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 114011,
        "voice": "vo_adv_6050208_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你也來？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呃，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不管怎樣，被你惡作劇還是很不好意思啊……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "開玩笑的？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來如此，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "剛剛那個是惡作劇啊？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "敗給你了呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哇，",
        "unit_id": 114011,
        "voice": "vo_adv_6050208_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這麼多？",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有這麼多糖果的話，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺就可以分給剛剛那些孩子們了。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n一起去分糖果吧，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他們一定會很開心收下呢。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是，",
        "unit_id": 114011,
        "voice": "vo_adv_6050208_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "只是看到那些一臉開心的孩子們，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就連我",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也會有種開心的感覺……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "該不會，",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你這個提問",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是想要對我惡作劇吧？",
        "unit_id": 114011
    }
]