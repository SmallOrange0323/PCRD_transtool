[
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "魔女啊……",
        "unit_id": 11511,
        "voice": "vo_adv_5017211_000"
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "魔女啊！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "魔女啊！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "魔女啊啊啊！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "\n請給我愛……",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "貝特魯吉烏斯",
        "words": "給我寵愛……！",
        "unit_id": 11511
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "……他已經完全",
        "unit_id": 109911,
        "voice": "vo_adv_5017211_001"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "被瘋狂吞沒了。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雖然我很想說要發瘋就儘管發瘋吧，",
        "unit_id": 109811,
        "voice": "vo_adv_5017211_002"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n但現在似乎也不能這麼說。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是啊。",
        "unit_id": 109711,
        "voice": "vo_adv_5017211_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "簡直就像是被那瘋狂所牽引，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n魔女教徒們也",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "明顯地變強了。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "兩位，",
        "unit_id": 109911,
        "voice": "vo_adv_5017211_004"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "妳們看那個！",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那、",
        "unit_id": 109711,
        "voice": "vo_adv_5017211_005"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那個是……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "難不成，",
        "unit_id": 109811,
        "voice": "vo_adv_5017211_006"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "那個就是闇影嗎……！",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "貪吃佩可曾說過。",
        "unit_id": 109911,
        "voice": "vo_adv_5017211_007"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n有一種擁有人類姿態",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "的特殊魔物。",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "但沒想到，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "竟然會和雷姆及拉姆長得一模一樣……",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "而且，",
        "unit_id": 109711,
        "voice": "vo_adv_5017211_008"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "似乎和魔女教徒們一樣，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n受到大罪司教的掌控！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "就算是魔物，",
        "unit_id": 109711,
        "voice": "vo_adv_5017211_009"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "對那種化身為我們姿態",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n還成為魔女教徒的東西……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "絕對無法原諒！！",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "……看來似乎連拉姆都",
        "unit_id": 109811,
        "voice": "vo_adv_5017211_010"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n都無法繼續保持冷靜了！",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "兩位！",
        "unit_id": 109911,
        "voice": "vo_adv_5017211_011"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n我會掩護妳們，",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "讓妳們盡情地攻擊對方！",
        "unit_id": 109911
    }
]