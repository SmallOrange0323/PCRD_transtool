[
    {
        "type": "background",
        "background": "500100"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……以上為報告。",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "辛苦了。",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n情報的操作，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就照我說的繼續進行下去。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "先前",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和【王宮騎士團】有關的，\n大規模軍事行動……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全部",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都是為了討伐",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n會將死病蔓延開的可怕魔物。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而操縱那些魔物的，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "正是反政府組織【拉比林斯】。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n為了殲滅那些可憎的罪犯與魔物，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們王宮才因此派遣出了軍團。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "將這故事大幅的宣傳出去，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "並讓百姓們相信唷。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在現場，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們也留下了煞有其事的東西來作為證據，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以我認為大概是沒什麼問題。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "且蘭德索爾的居民，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "平時也不會離開和平的城鎮到外頭。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以也應該不會有什麼目擊者……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對我們公布的內容，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該很輕易就相信才對。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算是有了違和感，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也會馬上忘掉呢。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "陛下，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在陷入昏睡狀態以前……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就將能把人們的思考，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "朝著對我方有利的方向扭曲的魔法裝置，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n在城鎮的各地中都設置好了呢。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "民眾不會有任何遲疑，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既悠哉又和諧的，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n今天也一如以往過著日常的生活唷。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "時間已經刻不容緩了呢。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n魔法裝置",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只有陛下本人能夠啟動，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n陛下",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不親自將魔力給注入的話，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "遲早也會停擺的。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在那之前，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不將陛下的敵人",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "一個不剩的剿滅可不行。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n【拉比林斯】那群傢伙的屍體",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都還沒有找到半個……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n仍在苟且偷生的可能性很高",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "徹底的進行搜索，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n視情況",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要下達通緝也沒關係，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把他們給活捉起來。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最壞的情況，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是殺掉也無妨……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "災禍的芽苗，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在成長茁壯前就得除掉對吧。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那些傢伙的搜索與捕獲，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "亦或者是處死，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n全權交給【王宮騎士團】負責了。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "王國最大的軍事能力，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就盡情的發揮吧。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也就是為此，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "才會支付你們高額的維持費用唷。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……這其中幾點有些問題。",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我認為這全都有問題。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "確實【拉比林斯】以及，{player}……",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那些協力者們，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "或許真是群可恨的惡黨也說不定。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "然而對於他們進行犯罪行為，",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "卻沒有任何直接的證據，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我不明白其中的理由。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這到底是否真為正義……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這先擱一旁吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "為了搜索與捕獲他們，",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而分散了【王宮騎士團】大半的戰力之事，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也深感不解。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "先前，",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "由於曾任副團長克莉絲提娜的反叛行為，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n【王宮騎士團】的整體戰力已有低落的趨勢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在將她投進牢內之際，",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也因為她大鬧一番的緣故，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不少人因此而負傷。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對此應該已有增派了戰力才對？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "全都是些沒經過什麼訓練的菜鳥。",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n該說還派不上用場，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "或者說",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "無法期待",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "能成為戰力啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "先前",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "與【拉比林斯】交戰，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n又多了大量的傷者。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在城外，",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖說仍有陛下所操控的魔物",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "能增添我方的戰力……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但再怎麼說，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也無法讓魔物",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "於城內中閒逛。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "魔物從根本上，",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就是危險與恐懼的惡之化身。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n前陣子，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "光是隻小魔物闖到城內，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就引起陣大騷動了吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n下一次可會讓整座城",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "都陷入恐慌啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯……",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_027"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n總之，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我就只是國王陛下的的代理人而已，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n請不要用『陛下』來稱呼我。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這真是失禮了，",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "代理人閣下。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很好。",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "確實",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是不能使用魔物呢。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我所操縱的那群魔物，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就讓他們在城外",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "搜索【拉比林斯】的殘黨吧。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在城內，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_030"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就讓從【王宮騎士團】引以為傲的",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n團長底下鍛鍊出來的菁英",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來執行行動。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該還有",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "剩下一些人手吧？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "只剩一些",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而已呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n然而，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們也無法隨心所欲的行動。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n下個週末，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "蘭德索爾街上",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "將會開始舉辦大規模的祭典。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這是自建國以來，",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "延續至今的一場祭典。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不可能就此而中斷，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我等不僅得做準備",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還必須擔綱當日之警衛，可說是分身乏術。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因此，",
        "unit_id": 104711,
        "voice": "vo_adv_2009003_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在兼任有關【拉比林斯】的搜索上",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是相當艱困。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嘖，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "都忘了還有這種事呢……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難怪",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總覺得最近街上到處都吵吵鬧鬧的。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "祭典呢，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很想",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把這東西中止或延期啊。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但這可是蘭德索爾的人們期盼著的例行節日，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是季節性的祭典嘛。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果莫名其妙把它給中止了，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n可能會讓人民察覺違和感，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對王宮的不滿也會增加吧。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且。",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "祭典也會有諸國的賓客來訪，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那些招待狀陛下也早就送出去了。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_037"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒想到陛下竟然，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n把這種季節性的祭典",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或者是祭祀看得相當重呢。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "城內的人先不說，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n外國的人們沒有被陛下的魔力給滲透控制……",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果我們有些可疑的舉動，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也可能讓賓客察覺",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而抱有疑問呢。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "從外頭來看，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_039"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n蘭德索爾的內情可說是相當異常的狀態，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這任誰都能夠一目了然。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不想讓人隨便做出臆測，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這祭典",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不按原定計畫舉辦是不行了呢。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果被抓到了弱點或把柄，",
        "unit_id": 106013,
        "voice": "vo_adv_2009003_041"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在外交上",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可不是值得高興的事呢。",
        "unit_id": 106013
    }
]