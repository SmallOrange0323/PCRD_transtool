        "voice": "vo_adv_5114000_049"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "開始著手進行吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我想想……",
