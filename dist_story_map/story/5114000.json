        "voice": "vo_adv_5114000_044"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "先等一等！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n現在通知還太早了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個地方",
