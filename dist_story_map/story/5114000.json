    },
    {
        "type": "dialogue",
        "name": "老婦人",
        "words": "我也很想替他實現。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老婦人",
        "words": "\n",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老婦人",
        "words": "畢竟",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老婦人",
        "words": "在他出生以前就已經算是店裡的一分子了。",
