    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "採買懷舊點心！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n……餓著肚子就無法戰鬥。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n沒甜食就建不了公會小屋，",
