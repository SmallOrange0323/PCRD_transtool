[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在某個晴朗的日子，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n莫妮卡和一群小孩子奔走於市區之中。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好，",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "抓到你了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "唉唷，",
        "unit_id": 111,
        "voice": "vo_adv_5114000_001"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "又被莫妮卡姐姐抓到了啦。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n姐姐，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "妳跑得有夠快的。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為我平常",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就有在鍛鍊啊！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "身為軍人，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "體力可是基礎中的基礎！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n體力不好",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就什麼都辦不到啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好，",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就繼續……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "先暫時別玩鬼抓人了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n你",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是有什麼事在煩惱吧？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看你從早上就悶悶不樂的。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還有剛才也是一下子就被我抓到。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "咦！？",
        "unit_id": 111,
        "voice": "vo_adv_5114000_004"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "才沒那回事呢！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "跟莫妮卡姐姐",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "一起訓練",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "很開心啊！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你裝模作樣",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也瞞不過軍人的眼睛喔！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……有煩惱就跟我說吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "……",
        "unit_id": 111,
        "voice": "vo_adv_5114000_006"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "莫妮卡姐姐，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "妳好厲害，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n為什麼妳看得出來？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看到盟友有難，我不能坐視不管啊。",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_007"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗯",
        "unit_id": 111,
        "voice": "vo_adv_5114000_008"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "……其實，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我想姐姐應該已經知道了，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n我奶奶",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "不是在廣場旁邊開餐廳嗎？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯，",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我曾光顧過喔！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "地點隱密，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但經常客滿而無法入內……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "店裡的鹹派超級無敵好吃！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還有飯後的咖啡，",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_010"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "店長替我加了滿滿的鮮奶，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n砂糖也給得恰恰好……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下也去過不只一次了吧？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大哥哥也知道吧？",
        "unit_id": 111,
        "voice": "vo_adv_5114000_011"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "培根和",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "香腸都很好吃！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我也超喜歡的喔！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "可是……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n奶奶她",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "最近腰的狀況變差，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "已經不能站著在店裡工作了。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "竟然……",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我不知道有這件事……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真遺憾。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n之前光顧的時候，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看她還滿有精神的呢……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "然後，",
        "unit_id": 111,
        "voice": "vo_adv_5114000_013"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大家都說這是大人的事，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "所以不肯告訴我……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "但是",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我知道，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "奶奶她要收掉餐廳。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "這沒辦法，",
        "unit_id": 111,
        "voice": "vo_adv_5114000_014"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "因為土地和房子是從以前跟人租來的。",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "只要開著餐廳，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "不是就得付房租不可嗎？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "等收掉餐廳，",
        "unit_id": 111,
        "voice": "vo_adv_5114000_015"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "不用再付房租，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "奶奶的店",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "有可能馬上就會被拆掉……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我說，",
        "unit_id": 111,
        "voice": "vo_adv_5114000_016"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "姐姐、",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大哥哥！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n有沒有方法",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "可以阻止呢？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n這樣下去，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "奶奶她很可憐啊……",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大哥哥！",
        "unit_id": 111,
        "voice": "vo_adv_5114000_017"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "可以嗎？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "真的可以嗎？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下！",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n喂，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "老是那樣衝動行事",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可是你的壞習慣喔！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那個……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "畢竟身為公會長，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我總是想著",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要去協助市井小民啊……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "市井小民？",
        "unit_id": 111,
        "voice": "vo_adv_5114000_020"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我不懂是什麼意思，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "不過謝謝姐姐，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "還有大哥哥！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "奶奶她",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "一定會很高興的！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "很好，",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "先去聽聽看她怎麼說吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "老婦人",
        "words": "……哎呀呀，",
        "unit_id": 7911,
        "voice": "vo_adv_5114000_022"
    },
    {
        "type": "dialogue",
        "name": "老婦人",
        "words": "你們聊到了那種事嗎？",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老婦人",
        "words": "\n謝謝你們，",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老婦人",
        "words": "但是不要緊的。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "老婦人",
        "words": "\n我不能給外人添麻煩啊。",
        "unit_id": 7911
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "可是！",
        "unit_id": 111,
        "voice": "vo_adv_5114000_023"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "莫妮卡姐姐和",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大哥哥，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n是真心想要幫忙這家店啊！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n對吧！？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "我沒說錯吧，",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "大哥哥、",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "姐姐！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是啊。",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然妳應該是做了各方面考量才下決定……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但我們是來商量的，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "至少形式上把店面保留下來也好。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我沒辦法經營",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_025"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "像以前那樣的餐廳，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就算用模仿的……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我也做不出那無比好吃的鹹派和香腸。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但……",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_026"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我想至少",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "形式上把大家深愛的這家店",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "保留下來。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "突然提出這些可能讓妳很不安，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但能否讓我們",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "試一次看看呢？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "老婦人",
        "words": "說得也是……",
