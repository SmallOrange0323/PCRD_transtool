    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "是要賣什麼啊？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n點心之類的嗎？",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼都不賣喔。",
        "unit_id": 105311,
        "voice": "vo_adv_5114000_037"
    },
