    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗯……",
        "unit_id": 105511,
        "voice": "vo_adv_5090101_000"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "平時總是受到前輩的照顧……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n所以我想",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "送點禮物感謝他……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但以我的零用錢，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好像也買不起什麼好東西……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……要不要",
        "unit_id": 105511,
        "voice": "vo_adv_5090101_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "找個打工來做呢？",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因為想送前輩好一點的禮物，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n有沒有時薪",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "比較高的工作呢……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……啊！",
        "unit_id": 105511,
        "voice": "vo_adv_5090101_002"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這個打工好像不錯！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n「誠徵賭場大廳清潔人員！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "無經驗可，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "熱烈招募中！」",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n……上面是這樣寫的！",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然賭場",
        "unit_id": 105511,
        "voice": "vo_adv_5090101_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "感覺是……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "大人的遊樂場所……",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但、",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是為了前輩，",
        "unit_id": 105511
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我會加油的……！",
        "unit_id": 105511
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──隔天，於【龍族巢穴】的據點。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫噫噫！？",
        "unit_id": 106611,
        "voice": "vo_adv_5090101_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "果汁灑到老大的書上了！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊哇哇哇哇……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "鐵、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "鐵定要被處罰了……！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔嗚嗚……！",
        "unit_id": 106611,
        "voice": "vo_adv_5090101_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "如果我是透明人的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就可以躲掉老大的處罰了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唉。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有沒有這種方便的道具",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "或魔法呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "至少",
        "unit_id": 106511,
        "voice": "vo_adv_5090101_006"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "我從來沒聽說過。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "弄髒書的事情，",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "之後要好好向老大道歉哦。",
        "unit_id": 106511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔嗚",
        "unit_id": 106611,
        "voice": "vo_adv_5090101_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我知道啦……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "比起那個，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "已經到這個時間了啊。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n差不多",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "得去賭場了呢。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "老實說，",
        "unit_id": 106611,
        "voice": "vo_adv_5090101_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我對去那個賭場，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一點興趣也沒有。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……不過，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是老大的命令，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也只能去了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……啊～",
        "unit_id": 106611,
        "voice": "vo_adv_5090101_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要是能變成透明人的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就能偷走那間賭場的寶物，把那給毀了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……現在可不是做白日夢的時候。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "現實是殘酷的……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨一行人",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5090101_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨一行人",
        "words": "「交出寶物！　",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨一行人",
        "words": "透明怪盜雙人組」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……嗯！？",
        "unit_id": 106611,
        "voice": "vo_adv_5090101_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "剛才，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有沒有聽到除了我以外的聲音！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "明明這裡就只有我和嘉夜夜而已……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "難、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "難道是……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "幽靈之類的嗎！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫噫噫噫噫！？",
        "unit_id": 106611
    }
]