        "words": "\n",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "迷宮女王",
        "words": "現在正是身為《阿斯特朗傳奇》的開發者",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "迷宮女王",
        "words": "齊心協力的時候。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "齊心協力？",
        "unit_id": 106912,
        "voice": "vo_adv_5201311_001"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哈，",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "真是太蠢了。",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n你們自己合力就好。",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我可以允許你們在四周徘徊亂竄。",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "啊哈哈☆",
        "unit_id": 133911,
        "voice": "vo_adv_5201311_002"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "這可真是寬宏大量啊！",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n那就由我來擔任先鋒吧！",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "對方能夠用單一個體",
        "unit_id": 133811,
        "voice": "vo_adv_5201311_003"
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "施展我們的權能。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "\n",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "變貌大妃",
        "words": "有必要特地分散，對我們自己造成不利嗎？",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "真是的，",
        "unit_id": 107311,
        "voice": "vo_adv_5201311_004"
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "在必須打倒的敵人面前",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "竟然還悠閒暢談，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "實在可嘆。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "\n",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "難得能與強敵對戰，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "跳躍王",
        "words": "我要照自己的意思行動。",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "嚮導老君",
        "words": "嗯。",
        "unit_id": 107211,
        "voice": "vo_adv_5201311_005"
    },
    {
        "type": "dialogue",
        "name": "嚮導老君",
        "words": "\n這股喧囂……",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "嚮導老君",
        "words": "還真是令人懷念啊。",
        "unit_id": 107211
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "這──",
        "unit_id": 134011,
        "voice": "vo_adv_5201311_006"
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "些傢伙簡直是一盤散沙！",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "\n",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "菲歐",
        "words": "這樣真的沒問題嗎！？",
        "unit_id": 134011
    },
    {
        "type": "dialogue",
        "name": "七冠",
        "words": "妳在問誰？",
