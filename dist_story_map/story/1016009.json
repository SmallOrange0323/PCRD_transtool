    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "他總是會來替人家加油打氣。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家會開始當模特兒，",
