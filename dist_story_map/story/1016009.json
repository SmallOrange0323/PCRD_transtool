        "type": "dialogue",
        "name": "鈴奈",
        "words": "希望秀才未來也繼續注視著出席各種活動的人家，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n人家想讓秀才",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "玩得盡興呀！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "採訪員",
        "words": "原來如此，",
        "unit_id": 1211,
        "voice": "vo_adv_1016009_055"
    },
    {
        "type": "dialogue",
        "name": "採訪員",
