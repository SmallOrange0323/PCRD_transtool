    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "那也滿有意思的。",
        "unit_id": 411,
        "voice": "vo_adv_1016009_044"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "還可以聊聊",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n為什麼這次拍攝可以成功拍到鈴奈發自內心的笑容呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "採訪員",
        "words": "……原來如此。",
