        "voice": "vo_adv_1016009_050"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n是在路上被星探發掘，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像很有意思就試試看了。",
