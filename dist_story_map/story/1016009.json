        "name": "攝影師",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "構圖也都非常完美，無可挑剔。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "那我們可以進入訪談環節了吧？",
