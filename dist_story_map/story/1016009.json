    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "糟糟糕！",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_041"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "都這個時間了！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和秀才在一起就覺得時間過得飛快呢！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家還想和秀才再多享受一下約會……",
