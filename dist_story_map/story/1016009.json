        "voice": "vo_adv_1016009_047"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n是因為他真的很像秀才，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以人家才叫他秀才的。",
