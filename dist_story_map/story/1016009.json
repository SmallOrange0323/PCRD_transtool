    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "多虧有你，感覺這個特輯會很成功呢！",
