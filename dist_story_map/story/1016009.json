    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才他呀，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_051"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n常常混在人家的粉絲裡，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "用超大嗓門從觀眾席替我加油打氣。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的超搞笑的吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一開始人家還嚇了一大跳，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_052"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "但在舞台上找到秀才的位置",
