    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n聽聞鈴奈有事相求，便來到了鬧區赴約。"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_000"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這裡這裡！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哈嚕──！",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "時間一分不差呢！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真不愧是秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "抱歉呀，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_002"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "突然把你約出來！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n不過，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這件事無論如何都只能拜託秀才了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是呀，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今天",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和人家約會一天吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "你就是{player}嗎？\n非常感謝你",
        "unit_id": 411,
        "voice": "vo_adv_1016009_004"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "今天來協助我們拍攝。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "我們雜誌這次策畫了",
        "unit_id": 411,
        "voice": "vo_adv_1016009_005"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n一個特輯……",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "叫做",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n「超級名模‧鈴奈的一日幻想約會」！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "而鈴奈表示",
        "unit_id": 411,
        "voice": "vo_adv_1016009_006"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "無論如何都",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n不想找職業模特兒作為搭檔，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n指定要由{player}你擔任這個角色。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對對對！",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就是這麼一回事！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "提到約會，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_008"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不就需要一個男朋友嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那肯定非秀才莫屬呀。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n所以人家就想說",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "拜託你試試看！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "我們這麼合拍，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "約會起來肯定會超開心的，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n這場拍攝一定會很成功的！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以今天一整天",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_010"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你就陪人家約會吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "請多指教～♪",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "不用顧慮我們幾個工作人員，",
        "unit_id": 411,
        "voice": "vo_adv_1016009_011"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "兩位盡情享受就可以了。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "我們會拍下鈴奈最自然的模樣的。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "那我們就",
        "unit_id": 411,
        "voice": "vo_adv_1016009_012"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "馬上開始拍攝吧！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_013"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "走吧！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家已經",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "規劃好約會行程了！",
        "unit_id": 101611
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "哎呀！",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_014"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這條項鍊",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超級可愛的！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才，你也這麼覺得吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……奇怪？",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_015"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家想試戴看看，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是這個項鍊扣頭解不開……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝你，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_016"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那你可以",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "直接幫人家戴上項鍊嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈！",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_017"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "欸秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n很癢啦──！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "……什麼？",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_018"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "已經戴好了？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "謝謝！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "怎麼樣？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "適合人家嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才果然也這麼覺得嗎？",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_019"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "既然你都這麼說了，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家不如就買下來吧。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就當作是和秀才約會的紀念！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "鈴奈剛才的笑容",
        "unit_id": 411,
        "voice": "vo_adv_1016009_020"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "有清楚拍下來嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "有，",
        "unit_id": 311,
        "voice": "vo_adv_1016009_021"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "非常清楚喔。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "我到現在幫鈴奈拍過很多次照了，",
        "unit_id": 311,
        "voice": "vo_adv_1016009_022"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "但還是第一次看見她露出這麼自然的笑容。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "是呀。",
        "unit_id": 411,
        "voice": "vo_adv_1016009_023"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "這就代表",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "她和{player}在一起的時候真的很開心呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "幸虧有答應鈴奈的要求。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "這個企劃",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "感覺行得通呢！",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "……奇怪？",
        "unit_id": 411,
        "voice": "vo_adv_1016009_024"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "鈴奈他們呢？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "這麼說起來，沒看見人影呢……",
        "unit_id": 311,
        "voice": "vo_adv_1016009_025"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "雖然我叫他們盡情享受，",
        "unit_id": 411,
        "voice": "vo_adv_1016009_026"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "他們該不會忘了現在還在拍攝，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "自己移動到下個地點了吧！？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "這就代表鈴奈興致很高昂吧！",
        "unit_id": 411,
        "voice": "vo_adv_1016009_027"
    },
    {
        "type": "dialogue",
        "name": "攝影師",
        "words": "\n我們趕快追上去，千萬別錯過按快門的好時機！！",
        "unit_id": 411
    },
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這個聖代",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_028"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好好吃喔！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這在人家的模特兒朋友間討論度超高的，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_029"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "之前人家就一直很想吃看看了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可是，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_030"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家最近忙著拍攝，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "還沒有機會來吃。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "所以人家就想說，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今天約會的時候，一定要跟秀才一起來吃！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_031"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才你的聖代",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "是草莓口味的，對吧？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "要不要跟人家的麝香葡萄口味",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "交換一口吃吃看呀？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "來，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_032"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊──",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊哈哈，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "開玩笑的啦！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家又不是小孩子了，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "可以自己吃的啦。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_033"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "你認真！？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那麼……",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "啊呣。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "天啊天啊，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_034"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "超級好吃！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家可能比較喜歡草莓口味！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "吶吶吶吶，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "秀才！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "再給人家吃一口！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "跟秀才一起來吃真是來對了。",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_035"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "如果人家一個人來的話，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "就只能吃到一種口味了。",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "拜託秀才",
