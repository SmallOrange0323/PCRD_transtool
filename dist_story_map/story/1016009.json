        "voice": "vo_adv_1016009_036"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "來參與今天的拍攝，真是找對人了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n男朋友這個角色",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "，除了秀才以外，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "沒有其他人選了！",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "平時我們兩個人出去玩的時候，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_037"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n一被人家的粉絲發現，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不就得逃跑嗎？",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "不過，",
        "unit_id": 101611,
        "voice": "vo_adv_1016009_038"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "今天人家是來工作的，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和秀才在一起也沒關係。",
