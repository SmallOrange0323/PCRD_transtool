        "voice": "vo_adv_1016009_048"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n是他解救了當時傷透腦筋的人家，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n他真的很可靠，",
        "unit_id": 101611
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "跟人家也合拍到電波嗶嗶嗶的感覺。",
