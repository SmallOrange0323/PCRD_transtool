[
    {
        "type": "background",
        "background": "500164"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "純跟{player}走在岸邊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n時時注意在海裡玩耍的孩子們的狀況。"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呼……",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真是和平呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "剛才受到少年跟小咲戀邀請時，",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我原本還有些擔心。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n畢竟自從小咲戀辭去【王宮騎士團】一職後，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我們就沒見過幾次面。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就算見到面，",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也都是基於公會長的身分，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像這樣處於跟公會無關的立場時，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我不禁擔心起彼此",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會不會無法好好對談。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是啊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小咲戀很溫柔，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我很清楚",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "她不會在意那種事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就曾經浮現過那樣的想法啦。",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……就算是我，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有時也會感到膽怯。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "她會不會是因為辭去【王宮騎士團】的工作，",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不得已",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "才開辦【咲戀育幼院】……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我曾經有過這樣的疑慮。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "親眼看到小咲戀跟育幼院的孩子們後，我總算明白了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小咲戀",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是有明確的目的才會獨立，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n她是為了孩子們在努力。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而孩子們",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也都很喜歡小咲戀，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n彼此帶著笑容互相幫助……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n小咲戀當時的選擇是正確的，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而我這時才明白這點。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "今天，",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "能來這裡真是太好了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也要感謝【王宮騎士團】的大家才行。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "遊客",
        "words": "有魔物──！",
        "unit_id": 1,
        "voice": "vo_adv_1136003_009"
    },
    {
        "type": "dialogue",
        "name": "遊客",
        "words": "有魔物出現了──！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年！",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這位先生，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想知道詳細狀況。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "遊客",
        "words": "好、",
        "unit_id": 1,
        "voice": "vo_adv_1136003_011"
    },
    {
        "type": "dialogue",
        "name": "遊客",
        "words": "好……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "遊客",
        "words": "聽說有人在水裡看見了魔物。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "遊客",
        "words": "\n所以你們也快點去避難吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "純！",
        "unit_id": 110311,
        "voice": "vo_adv_1136003_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大家呢？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小咲戀，",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳來得正好。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n可以點名一下孩子們是否都在嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好、",
        "unit_id": 110311,
        "voice": "vo_adv_1136003_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "咲戀媽媽！",
        "unit_id": 113,
        "voice": "vo_adv_1136003_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "太好了，",
        "unit_id": 110311,
        "voice": "vo_adv_1136003_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原來你在那裡啊！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "其他人呢？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "妹妹她……",
        "unit_id": 113,
        "voice": "vo_adv_1136003_017"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "我妹妹她不見了！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "！？",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看那裡！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那個游泳圈是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "剛才沙灘搶旗的獎品……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "糟糕，",
        "unit_id": 110311,
        "voice": "vo_adv_1136003_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "游泳圈被沖走了！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "得快點去救她才行！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我這就──",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "等等。",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我希望小咲戀留下來陪這些孩子。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那孩子由我來救。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 110311,
        "voice": "vo_adv_1136003_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "穿著那身鎧甲……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這確實不是",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "適合游泳的打扮……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但可以靠泳技克服！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "純……！",
        "unit_id": 110311,
        "voice": "vo_adv_1136003_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "她走掉了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過她好厲害，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "竟然真的穿著鎧甲在游泳……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "純好厲害……",
        "unit_id": 113,
        "voice": "vo_adv_1136003_024"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "咲戀媽媽──！",
        "unit_id": 213,
        "voice": "vo_adv_1136003_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "已經沒事了。",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n好了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "快過去找小咲戀吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗯！",
        "unit_id": 213,
        "voice": "vo_adv_1136003_027"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "純，謝謝妳！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝妳，純……",
        "unit_id": 110311,
        "voice": "vo_adv_1136003_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "後面！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "水裡面有東西！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年！？",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼會！{player}！",
        "unit_id": 110311,
        "voice": "vo_adv_1136003_030"
    },
    {
        "type": "dialogue",
        "name": "少年",
        "words": "大哥哥被抓住了！",
        "unit_id": 113,
        "voice": "vo_adv_1136003_031"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "好可怕……",
        "unit_id": 213,
        "voice": "vo_adv_1136003_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔……",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "成功救回孩子讓我大意了……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是我害了少年……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小咲戀先帶孩子們去避難！",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "動作快！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我知道了。",
        "unit_id": 110311,
        "voice": "vo_adv_1136003_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n純……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這裡就交給妳囉。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n{player}就麻煩妳了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好……",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我當然會救他回來。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這也是我一時輕忽大意所招致的狀況……",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n無論如何我都會救你回來，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年！",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那個像魚又像人的模樣……",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這個魔物",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n或許就是流傳在這個沙灘上的人魚傳說的起源……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "糟糕！",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "牠居然抓著少年潛進海裡……！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "要穿著鎧甲跟水生魔物進行水中戰的話，",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "應該不能用平時的戰鬥方式。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n可是，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年不會游泳……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "現在沒時間思考了！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這麼一來，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "方法就只有一個……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "無論有多熱，",
        "unit_id": 104711,
        "voice": "vo_adv_1136003_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "無論有多重，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
