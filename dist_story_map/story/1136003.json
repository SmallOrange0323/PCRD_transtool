        "words": "太好了……",
        "unit_id": 113611,
        "voice": "vo_adv_1136003_053"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "要道謝的是我才對。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真的很謝謝你。",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "喔……",
