    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沙灘上的人都沒有受傷。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n孩子們也都平安無事喔。",
