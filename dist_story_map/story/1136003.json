        "type": "dialogue",
        "name": "純",
        "words": "\n",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我現在可以使出比平時更強的力量……！　",
        "unit_id": 113611
    },
