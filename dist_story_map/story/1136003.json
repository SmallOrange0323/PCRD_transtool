    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在這種狀況下，",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "依然提供我助力……",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒有比這個更可靠的了……！　",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "身體好輕盈！",
        "unit_id": 113611,
        "voice": "vo_adv_1136003_050"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "簡直就像是沒有水阻力一樣！",
