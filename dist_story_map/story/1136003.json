        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n再這樣下去，會被魔物擊中……",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是，",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "即使如此！　",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我也一定",
        "unit_id": 113611,
        "voice": "vo_adv_1136003_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "會拯救他……！",
        "unit_id": 113611
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不管我會有什麼樣的下場！　",
