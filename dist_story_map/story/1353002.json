        "words": "兄長大人──",
        "unit_id": 131611,
        "voice": "vo_adv_1353002_067"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "讓您久等了，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我們買好泳衣了！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "款式沒有很多，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n希望您會喜歡……！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "丟出去，",
        "unit_id": 135211,
        "voice": "vo_adv_1353002_068"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n會飛回來的、",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n泳衣。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "什麼！？",
        "unit_id": 135311,
        "voice": "vo_adv_1353002_069"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n那個……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是說形狀像迴力鏢的三角泳褲嗎！？",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵，",
        "unit_id": 135311,
        "voice": "vo_adv_1353002_070"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "看來哥哥似乎很喜歡。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……那麼，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我有點累了，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就先去",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "休息一下。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "莉莉、",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "普蕾西亞，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "接下來交給妳們囉♪",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就是這樣，兄長大人！",
        "unit_id": 131611,
        "voice": "vo_adv_1353002_071"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n好好抓住浮板，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "用力踢水！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "咦……？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "為什麼，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "往這邊退過來了……？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "迴力鏢。",
        "unit_id": 135211,
        "voice": "vo_adv_1353002_072"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n哥。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "…………\n……",
        "unit_id": 135311,
        "voice": "vo_adv_1353002_073"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "只要和哥哥在一起，",
        "unit_id": 135311,
        "voice": "vo_adv_1353002_074"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就會非常開心。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "發自內心地，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "感到快樂。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n……理由，",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "只有一個。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "但是……",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "但是，",
        "unit_id": 135311,
        "voice": "vo_adv_1353002_075"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那一定要保密才行。",
        "unit_id": 135311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "盛夏日照強烈的海邊。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在遮陽傘之下的可璃亞面帶笑容，"
    },
    {
        "type": "dialogue",
