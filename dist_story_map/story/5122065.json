    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "Hi！",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "King！」",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n「掃墓",
