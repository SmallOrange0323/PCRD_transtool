        "type": "dialogue",
        "name": "真陽",
        "words": "咦？",
        "unit_id": 103311,
        "voice": "vo_adv_5122065_003"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你說是怎樣的笑哏？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "哇啊──",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "你想聽嗎？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥你還真有勇氣呀。",
