        "voice": "vo_adv_5122065_005"
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "難笑到嚇死你了吧？",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "現在回頭看簡直就無法想像的啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n年輕還真是罪過啦～",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "\n",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "老哥你也這麼認為對不對？",
