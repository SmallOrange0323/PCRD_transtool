    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "太糟糕了啦。",
        "unit_id": 103311
    },
    {
        "type": "dialogue",
        "name": "真陽",
        "words": "笑哏實在太不成熟，",
