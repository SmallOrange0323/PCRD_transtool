    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜參加了在王都舉辦的劍術大賽，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在{player}的見證下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她順利地挺進了決賽。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝啊！",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_000"
    },
    {
        "type": "background",
        "background": "500380"
    },
    {
        "type": "dialogue",
        "name": "劍士",
        "words": "唔！",
        "unit_id": 1011,
        "voice": "vo_adv_1803001_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "之前受到他出手相助，",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n那時，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我最後還是沒能戰勝敵人……",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我到現在仍",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為自己的失敗而慚愧。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我想",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "變得更強……",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不對！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我必須變得更強！　",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看招！",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_004"
    },
    {
        "type": "dialogue",
        "name": "劍士",
        "words": "還沒完呢！",
        "unit_id": 1011,
        "voice": "vo_adv_1803001_005"
    },
    {
        "type": "background",
        "background": "500380"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "什麼！？",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "糟糕！",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "把對手逼入絕境，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n反而讓他發揮出超越極限的實力了──！！　",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "劍士",
        "words": "唔喔喔喔喔喔喔！",
        "unit_id": 1011,
        "voice": "vo_adv_1803001_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "照這樣下去",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我會被打敗……！　",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "休想、",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "得逞！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500380"
    },
    {
        "type": "dialogue",
        "name": "劍士",
        "words": "哇啊啊啊！",
        "unit_id": 1011,
        "voice": "vo_adv_1803001_011"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "勝負已定！",
        "unit_id": 1,
        "voice": "vo_adv_1803001_012"
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "勝利者是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "裁判",
        "words": "怜選手！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼、",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼、",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼……",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然驚險，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但總算是贏下來了……",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……謝謝。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你特地來觀賽，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我卻贏得這麼狼狽。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的修練",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還遠遠不夠呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明持續與【憤怒‧軍團】對戰著，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我卻贏得這麼艱辛……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "下次一定得戰勝",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "叫阿澤爾德的男人……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咦？",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喔、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喔喔。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "知道了。",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我說啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你不是說「一下」嗎，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n怎麼感覺走了很久，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "到底要去哪……",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……這裡啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n是平時的修練場嘛。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他為什麼要帶我來這裡……？　",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "總之，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡就是目的地了吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "希望你能說明一下帶我來的原因──",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "──！",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來是這樣啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n依你的個性，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我還以為",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是打算找我談談呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n沒想到會來這一手。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過對我而言，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "確實是更喜歡以劍交心。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這把劍",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "勝過一切雄辯。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "話說回來，",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這還是第一次呢，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你竟然",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "比我早拔出了劍……",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算大賽結束了，",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_025"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也不會手下留情喔！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝啊！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看招！",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "噠啊！",
        "unit_id": 100312
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "雖然恢復了往常狀態也是原因之一，",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_027"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n但他的劍術確實進步了啊，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我的攻擊都被精準防下了……",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和他比起來，我……",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我卻！　",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "喝啊啊啊！！",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_029"
    },
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100312,
        "voice": "vo_adv_1803001_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "連這樣都被擋下來了呢。",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "果然還不夠，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "維持現況是不行的……！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你應該也",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_031"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感受到了吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我認為",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "現在的我還不夠強大！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "以我這種水準……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我能夠斷言，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "以我這種水準，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是無法應付接下來的戰鬥的！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "明明終於能以公主型態戰鬥了，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n卻換來那種結果……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我必須",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "變得更強！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不能",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_034"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就此止步！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……然而，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_035"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我卻充滿了迷惘。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就連揮劍的手",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都變得越來越遲鈍。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_036"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "公主型態",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是你與我們的羈絆，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也就是人與人的羈絆之力。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "像我這種",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_037"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想親手斬斷與家人間羈絆的人，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n不該有資格使用這份力量。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_038"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有時會閃過這樣的念頭……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也因此變得無法再",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一心一意地追求強大。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……你可能會覺得這是在鑽牛角尖。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_039"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但我",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是那種善於變通的人。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我或許得回去",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_040"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和家人……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "做個了斷。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為了向前邁進，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "斬斷與他們之間的羈絆。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個……",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_041"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我也越來越不明白了。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_042"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不想讓父母支配我的人生。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_043"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我抗拒的",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就只有這點而已。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我理解家族的立場，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_044"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也絕不是討厭他們……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我只是想要自由。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_045"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n希望能夠保持自由。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n無論是我，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還是家人……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……原來啊。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_046"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在能夠使用羈絆之力後，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_047"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我就已經察覺到了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "自己並不想斬斷羈絆。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來是這樣啊……",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_048"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我會努力看看的。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_049"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……啊啊，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_050"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不知為何，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我現在的心情比",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "贏得大賽時更加暢快呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……你",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_051"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "發現了我的迷惘嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……就算不是如此，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也是因為有你在，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我才能找到自己心中的答案……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一直以來謝謝你了。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_052"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "全都是多虧了你。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n要是沒有你在身邊，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我肯定還是會",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "繼續迷惘下去。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真不可思議啊……",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_053"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n若是面對你，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "感覺什麼心事都能通通說出來呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就連我對你的心意也是……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒、",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_054"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒什麼！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n剛剛那是開玩笑，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你別在意！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_055"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒事，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你沒聽到就好！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是什麼重要的事啦！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我剛才到底打算說什麼啊！？",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_056"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n對他的心意！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "說什麼蠢話啊……！　",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……不，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_057"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但是，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "既然是羈絆之力，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就有必要加深與他之間的羈絆……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "等等。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_058"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該有不這麼做也能變強的方法。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n先找找那種方法吧……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒錯，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就這麼辦！　",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你聽我說，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_059"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "其實，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我最近在尋找方法，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n想引出比現在更為強大的公主型態之力。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "若你方便，",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_060"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "希望你能來幫我……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可以嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝。",
        "unit_id": 100311,
        "voice": "vo_adv_1803001_061"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有你的幫助，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n感覺很快就能找到呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜與{player}一同開始尋找"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n能夠變得更強的方法。"
    }
]