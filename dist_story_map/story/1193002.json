    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "別慌張、別慌張。",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_053"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你先拆掉一行後再重新編織就沒問題了！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "怎麼辦、怎麼辦！",
        "unit_id": 415,
        "voice": "vo_adv_1193002_054"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "毛線都糾纏在一起了！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "快救我！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "嗯！",
        "unit_id": 415,
        "voice": "vo_adv_1193002_055"
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "啊～！",
        "unit_id": 5411,
        "voice": "vo_adv_1193002_056"
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "毛線球滾走了……",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "等等！",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_057"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喂～",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "毛線球，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "快停下來！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……呼。",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_058"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總算在滾遠前撿到了……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……咦？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "剛剛",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_059"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好像有感受到某種氣息……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是我的錯覺嗎？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n呃，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好像在那棵樹的樹蔭下……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "看來，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_060"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "或許真的是我的錯覺吧！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n總覺得",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好像有魔物在附近，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以感到有點在意。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你說……",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_061"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "魔物嗎？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "原來如此……！",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_062"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "大概是我們",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "看起來玩得很開心吧！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "若是這樣，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "附近會有被我們吸引而來的魔物，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n那也沒什麼好奇怪的了。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只要它們不對孩子們出手，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_063"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們就不管它們。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為我之前曾在書本上讀過，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_064"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n有不少魔物只要我們不發動攻擊，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "它們也不會襲擊我們！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想躲在附近的，肯定是這類魔物……",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_065"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對吧，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "璃乃老師！",
        "unit_id": 416,
        "voice": "vo_adv_1193002_066"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "請幫幫我！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "棒針上的毛線脫落了～！",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好的！",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_067"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不可以拉扯喔，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我現在馬上過去！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們走吧！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "…………",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "姐姐，",
        "unit_id": 415,
        "voice": "vo_adv_1193002_068"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "妳看！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "妳剛剛教我的地方，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "我已經順利織好了！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真的耶──！",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_069"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳很努力呢。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "再加把勁就可以完成囉！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "好的！",
        "unit_id": 415,
        "voice": "vo_adv_1193002_070"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……呵呵。",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_071"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為哥哥的提議而開始的編織教室，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n進行得很順利呢！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿……",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_072"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果是這樣就好了。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是我第一次嘗試，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以不怎麼有信心自己可以教得好……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不過，看到大家認真學習的模樣，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也覺得開心。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "再說",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_073"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……我原本以為準備過聖誕節",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "會是只屬於我們兩個人的活動，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然而，像這樣跟大家",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "一起準備禮物，感覺也挺不錯的。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "為了傳達各自的心意而親自動手製作，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_074"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n你不覺得",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是件很棒的事嗎？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "能夠找到新的樂趣，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_075"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "讓我稍微有賺到的感覺。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這也是多虧了……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "有哥哥在！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聖誕節就快到了……",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_076"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真令人期待……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就讓我們過個最棒的聖誕節吧。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好了，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_077"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "各位。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "最後再加把勁，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "卯足全力編織吧！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "好──！",
        "unit_id": 1,
        "voice": "vo_adv_1193002_078"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "璃乃與{player}兩人就這樣面帶笑容，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n默默注視著編織教室的學生們努力奮戰的身影。"
    }
]