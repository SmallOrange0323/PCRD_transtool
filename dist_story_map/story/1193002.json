[
    {
        "type": "background",
        "background": "500036"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "前去森林找尋適合當聖誕樹的樹木後又過了數天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}被璃乃叫了出去。"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我等你很久了！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "快來這邊，來這邊！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "謝謝你跑這一趟！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然有點突然，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可以請你脫掉",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "身上的披風嗎",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "另外還有手套和",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "外套。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可以脫的，希望都可以脫掉。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣比較好快速又精準地掌握。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我馬上進行測量。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "手掌的大小是……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯嗯，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n大概跟書本上所記載的標準尺寸差不多一樣。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "接著是肩寬。",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你肩膀很寬呢。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥是穿衣顯瘦類型嗎？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "肩寬比我所料想的還來得寬……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "的說。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "抱歉！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我忘了做說明了。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我要測量，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "測量尺寸。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n具體而言，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是測量哥哥身體各部位的尺寸。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "若要說得更清楚，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這是為了禮物。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n具體而言，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是為了準備要送給哥哥的禮物。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我只能說到這裡。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你該不會是",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "感到有點不安吧？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那我就再說明清楚點，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "例如手套或",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "圍巾",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "之類的！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是這季節常被當成禮物的",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那個",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘛！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "若說",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "聖誕節就快到了……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這樣你就懂了吧？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我總不能",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "直接說出，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n聖誕節要送什麼禮物給你吧……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "編織類禮物的作戰計畫，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n對我這個做妹妹來說挺不賴的。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "話說回來，難得有這機會，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就讓我一次量完你身體各部位的尺寸吧！　",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "以後",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "說不定還有機會，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n能替哥哥做件衣服呢。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖說到了明年，尺寸可能就得重新測量。",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為哥哥也還處於發育期嘛！　",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我看看……",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "手臂長度、",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "腰圍，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還有身高……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "接著，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "可以請你脫掉靴子嗎？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "機會難得，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也想量一下腳的大小……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是的，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "當然沒問題！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不管多久我都可以等！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……我是很想這麼說，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但我差不多該去打工了！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "得趕過去了。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真的很謝謝你。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "今天還沒測量完的，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們下次再繼續吧。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這也是聖誕節準備工作的一環，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以很希望可以兩個人一起度過。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒錯！",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "下次見！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "也歡迎你來可麗餅店找我玩喔。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "第一針、",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "第二針……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "別焦急、別焦急。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "距離聖誕節還有很多時間，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "得好好地完成。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "要有耐心，以同樣的力道……",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "手套的形狀複雜，好難哪……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "呃，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這情況該怎麼說呢……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "對了，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "就是千里之行唯有一道！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，我不會認輸的！",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n這都是為了我和哥哥的聖誕節……！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "那個……",
        "unit_id": 415,
        "voice": "vo_adv_1193002_023"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "不好意思，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "姐姐。",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哇哇，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "是的！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳想要點可麗餅嗎？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "啊，",
        "unit_id": 415,
        "voice": "vo_adv_1193002_025"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "不。",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "對不起，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "我不是要點餐。",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "那個，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "請問妳在做什麼呢？",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "手上的毛線……",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個是",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "手套喔。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n是我打算送給重要的人的聖誕禮物！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "好棒喔！",
        "unit_id": 415,
        "voice": "vo_adv_1193002_027"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "手套看起來好暖和……",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "我可以",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "請姐姐也幫我織一副嗎？",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "雖然我沒有錢，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "但我可以在店裡幫妳做任何事！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "手套是",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳自己要用的嗎？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "啊……",
        "unit_id": 415,
        "voice": "vo_adv_1193002_029"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "呃……",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "不是我要用的，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "那個……",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "還是說",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳有想送禮物的對象",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "之類的？",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "對。",
        "unit_id": 415,
        "voice": "vo_adv_1193002_031"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "姐姐所織的手套……",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "看起來似乎很暖和，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "所以我想當作禮物送給爸爸媽媽。",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n我想他們一定會很高興……",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "可是",
        "unit_id": 415,
        "voice": "vo_adv_1193002_032"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "我不知道該怎麼編織，",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n也從來沒有織過任何東西……",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n我很想謝謝他們",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "總是在寒冷中辛苦地工作。",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "而且媽媽也曾說過，",
        "unit_id": 415,
        "voice": "vo_adv_1193002_033"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "聖誕老人是不會",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "送大人禮物的……",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以妳就想自己來當他們的聖誕老人對吧！",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_034"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "嗯！",
        "unit_id": 415,
        "voice": "vo_adv_1193002_035"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣啊……",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_036"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳想送父母親",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "禮物。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "果然，",
        "unit_id": 415,
        "voice": "vo_adv_1193002_037"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "不行",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "嗎？",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我是很想幫妳這個忙，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_038"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不過，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我也得編織要送給哥哥的禮物。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "再說，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_039"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳如果是要送禮，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n自己親手做的，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "收到的人肯定會更開心。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯～",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "該怎麼辦呢……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_040"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥！",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "你來啦。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n原來如此，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "雖然沒辦法幫她做，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
