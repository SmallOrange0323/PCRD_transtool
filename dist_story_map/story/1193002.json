    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n如果是妳自己親手做的，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我想收到的人",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "肯定會更開心。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "好、",
