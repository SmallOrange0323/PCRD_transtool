        "voice": "vo_adv_1193002_048"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "只有我一個人，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總覺得有點不安……",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "太好了！",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_049"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，璃乃的編織教室一開辦後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在不知不覺中便廣為人知，學生人數也增加不少。"
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "那個，",
        "unit_id": 5411,
        "voice": "vo_adv_1193002_050"
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "大姐姐。",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "女子２",
        "words": "這裡要怎麼做啊？",
        "unit_id": 5411
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這裡啊……",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_051"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "妳先織一針，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然後再翻到背面去……",
