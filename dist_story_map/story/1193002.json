        "voice": "vo_adv_1193002_043"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "好的！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "那麼，",
        "unit_id": 119311,
        "voice": "vo_adv_1193002_044"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我就利用打工的空檔",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "來教妳吧。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n在這裡教的話就很難當祕密禮物了，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以我們去森林裡吧。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嘿嘿，",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "知道一個好地方喔。",
        "unit_id": 119311
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "謝謝妳，",
        "unit_id": 415,
        "voice": "vo_adv_1193002_045"
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "姐姐！",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "\n",
        "unit_id": 415
    },
    {
        "type": "dialogue",
        "name": "女子１",
        "words": "雖說我是",
