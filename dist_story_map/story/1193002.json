        "voice": "vo_adv_1193002_052"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "不知道怎麼搞的針目對不起來啦～",
        "unit_id": 416
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n這樣是不是失敗了！？",
