[
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚……",
        "unit_id": 105811,
        "voice": "vo_adv_9035155_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得有點奇怪……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我的肚子一直咕嚕咕嚕地叫……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這是怎麼回事呢……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您沒事吧？　",
        "unit_id": 105911,
        "voice": "vo_adv_9035155_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是否是因為",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛剛生吃豆子的緣故呢……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳真是太貪吃了，",
        "unit_id": 106011,
        "voice": "vo_adv_9035155_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "每次都這樣。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這次吃過苦頭，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "下次會注意了吧？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您太可憐了，",
        "unit_id": 105911,
        "voice": "vo_adv_9035155_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n等等就回去製作藥材給您，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請先稍微忍耐一下吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但是很奇怪耶……",
        "unit_id": 105811,
        "voice": "vo_adv_9035155_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我平常即使生吃",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也都完全沒事哦？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只因為這樣就讓我吃壞肚子，太讓人難以接受了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "話說，",
        "unit_id": 105811,
        "voice": "vo_adv_9035155_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "出現了，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在那裡！　",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是剛剛的豆子呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n咦，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "奇怪……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小可蘿，",
        "unit_id": 105811,
        "voice": "vo_adv_9035155_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "知道原因了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "因為只有吃到一點點豆子而已，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n所以反而讓肚子更餓了呢！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "果然我的肚子才不會輸呢！",
        "unit_id": 105811,
        "voice": "vo_adv_9035155_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哼哼～！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……啊～",
        "unit_id": 106011,
        "voice": "vo_adv_9035155_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好啦好啦，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正最後事情一定是這種發展……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果不是吃壞肚子的話，",
        "unit_id": 105911,
        "voice": "vo_adv_9035155_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那就好了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很好～！　",
        "unit_id": 105811,
        "voice": "vo_adv_9035155_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們趕快把那個豆子魔物打倒，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n然後讓我飽腹一番吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "唉……",
        "unit_id": 106011,
        "voice": "vo_adv_9035155_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "算了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正這種魔物也不能放任不管，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也只能上了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然我不想去想打倒牠之後的事……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大家上吧！",
        "unit_id": 106011
    }
]