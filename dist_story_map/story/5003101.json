        "words": "怎、",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "怎麼了？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "有誰在說妾身的閒話嗎？",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呵呵，",
        "unit_id": 104412,
        "voice": "vo_adv_5003101_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "想必是眷屬們在讚美我吧。",
        "unit_id": 104412
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n太受歡迎也很辛苦呢♪",
        "unit_id": 104412
