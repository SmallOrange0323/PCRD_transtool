    {
        "type": "dialogue",
        "name": "香織",
        "words": "真步，",
        "unit_id": 101711,
        "voice": "vo_adv_5003101_000"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "糟糕了─！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n發生大事了─！！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "香織真是的，",
        "unit_id": 101011,
        "voice": "vo_adv_5003101_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這麼驚慌失措的，怎麼了嗎？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "先深呼吸冷靜下來吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "吸─吐─，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "吸─吐─……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "現在不是做這種事的時候了─！",
        "unit_id": 101711,
        "voice": "vo_adv_5003101_002"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n傳說中的吸血鬼，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "在蘭德索爾裡復活了啦─！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "吸血鬼？",
        "unit_id": 101011,
        "voice": "vo_adv_5003101_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊啊，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好像有聽說過呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n是種會吸年輕公主的血、",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可怕～的怪物對吧？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……那這麼說，",
        "unit_id": 101011,
        "voice": "vo_adv_5003101_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家有危險了！？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n我",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要被吸血了！？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "為了不讓那種事情發生，",
        "unit_id": 101711,
        "voice": "vo_adv_5003101_005"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "去消滅吸血鬼吧─！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "蘭德索爾的和平，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "就由我們來守護─！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說得沒錯呢……",
        "unit_id": 101011,
        "voice": "vo_adv_5003101_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不能讓那種怪物，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n把咱們的另一個故鄉",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "弄得亂七八糟的呢！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "從現在開始……",
        "unit_id": 101011,
        "voice": "vo_adv_5003101_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "咱們就是吸血鬼獵人了！",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "香織・真步",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5003101_008"
    },
