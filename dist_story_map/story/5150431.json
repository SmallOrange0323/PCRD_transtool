[
    {
        "type": "background",
        "background": "501683"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "はぁ……",
        "unit_id": 129811,
        "voice": "vo_adv_5142431_000"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "魔物のやつ、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "しぶといな～……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\nあたしとエリコが力を合わせてるってのに、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "こんなに時間かかるなんて。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "毎日戦い詰めで体が痛いぜ……",
        "unit_id": 129811,
        "voice": "vo_adv_5142431_001"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "ちくしょ～！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "ええ……",
        "unit_id": 129911,
        "voice": "vo_adv_5142431_002"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "私も耐えられません。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "このおかたにまで無茶をさせているという事実にっ！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "あぁ……",
        "unit_id": 129911,
        "voice": "vo_adv_5142431_003"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "早く帰りたい……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n早くあたたかいご飯を用意して差し上げたい……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "早くお風呂に入れて差し上げたい……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "早く、",
        "unit_id": 129911,
        "voice": "vo_adv_5142431_004"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "早く……！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\nこのおかたを外敵のいない",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "私と",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "ず～っと二人きりになれる空間に",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n閉じ込めて差し上げたいっ！！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "り、",
        "unit_id": 129811,
        "voice": "vo_adv_5142431_005"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "理由はともかく、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "帰りたいのは同意だ。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "それもこれも",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "全部魔物の討伐が終わんねえせいだよ！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "ちくしょ～！　",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "魔物のやつ～っ！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "おのれ魔物……！",
        "unit_id": 129911,
        "voice": "vo_adv_5142431_006"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\nこのおかたを独り占めできないのは",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n全部あのケダモノのせいですわっ！",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "うおおおっ！　",
        "unit_id": 129811,
        "voice": "vo_adv_5142431_007"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "何かイライラしてきた！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n今ならあいつをボッコボコにぶっ飛ばせる気がするぜ！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "奇遇ですね、",
        "unit_id": 129911,
        "voice": "vo_adv_5142431_008"
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "私もです。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "\n",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "今日が奴の……",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "エリコ",
        "words": "最期の日となるでしょう。",
        "unit_id": 129911
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "だなっ！　",
        "unit_id": 129811,
        "voice": "vo_adv_5142431_009"
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "へへっ……！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "\n絶対にあいつを倒そうぜ、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "マコト",
        "words": "エリコっ！！",
        "unit_id": 129811
    }
]