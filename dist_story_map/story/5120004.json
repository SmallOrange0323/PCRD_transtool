    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "他們滯留在此一段時間後，城鎮變得熱鬧了起來。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n黑暗勢力順利地增加，而位於其頂點的伊莉亞，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n也逐漸確立起身為傳說存在的地位。"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "伊莉亞大人。",
        "unit_id": 9811,
        "voice": "vo_adv_5120004_000"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "關於今天的行程，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n接下來要與軟泥怪族進行交流。",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "\n",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "在與牠們握手時，",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "可能會感到有點濕滑……",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦，",
        "unit_id": 126311,
        "voice": "vo_adv_5120004_001"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是真的嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我非常想看",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞變得濕濕黏黏的樣子呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一定會很藝術啊……♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咕、",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_002"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "唔唔──",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞？",
        "unit_id": 126311,
        "voice": "vo_adv_5120004_003"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "──呃啊啊！",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_004"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不要不要！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身幹不下去了──！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哇。",
        "unit_id": 126311,
        "voice": "vo_adv_5120004_005"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n像小孩子一樣鬧起脾氣了呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "……請問您怎麼了嗎？",
        "unit_id": 9811,
        "voice": "vo_adv_5120004_006"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還說什麼怎麼了！",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "自從妾身到這個城鎮之後，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n每天都只是坐在椅子上，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "聽魔物們的願望！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n而且大部分",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都是誤解傳說的無理要求！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身原本",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_008"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是為了讓自己完全復活，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "才到這裡來的啊！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這樣下去妾身不就什麼都做不了嗎！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "但、",
        "unit_id": 9811,
        "voice": "vo_adv_5120004_009"
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "但是伊莉亞大人……！",
        "unit_id": 9811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "咱們到鎮上去，{player}，",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_010"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "還有",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "來不來都可以的雪！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "真拿妳沒辦法呢。",
        "unit_id": 126311,
        "voice": "vo_adv_5120004_011"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我就給予妳帶著我這個美一起行動的幸福吧♪",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "布拉德",
        "words": "…………",
        "unit_id": 9811,
        "voice": "vo_adv_5120004_012"
    },
    {
        "type": "background",
        "background": "501980"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "呼，",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_013"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "終於能轉換一下心情了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "就算是統御黑夜之人，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "也是需要休息的啊。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "呵呵。",
        "unit_id": 126311,
        "voice": "vo_adv_5120004_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n雖然是傳說的吸血鬼，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "但是妳卻",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "意外地通俗呢，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "伊莉亞。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳說什麼！？",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_015"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳說誰俗氣了！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是、",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_016"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "是嗎。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n是那樣嗎……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那就好。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯。",
        "unit_id": 126311,
        "voice": "vo_adv_5120004_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "該說是通俗嗎……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有種很好打發的感覺呢。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "很好打發！？",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_018"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼，",
        "unit_id": 126311,
        "voice": "vo_adv_5120004_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳是要來找恢復力量的方法嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我記得",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這座鎮上有書店，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要我帶路嗎？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "喔，",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_020"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "雪意外地挺周到呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "那麼",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳就帶路吧！",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我想想，",
        "unit_id": 126311,
        "voice": "vo_adv_5120004_021"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "應該是這附近吧。",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎哦哦哦哦哦！",
        "unit_id": 1611,
        "voice": "vo_adv_5120004_022"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "\n啊，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "伊莉亞大人，",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "歡迎光臨──！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯。",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_023"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n妾身稍微看看喔。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_024"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這裡真的是書店呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "交易時是用什麼當貨幣啊……？",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "擺在這邊的書籍全部都是",
        "unit_id": 1611,
        "voice": "vo_adv_5120004_025"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "一本10伊莉亞──",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "10伊莉亞！？",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_026"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_027"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "變成貨幣了……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾、",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身還是不要繼續想下去了。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "總覺得有點害怕起來了……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "重點是商品齊不齊全呢？",
        "unit_id": 126311,
        "voice": "vo_adv_5120004_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有沒有暗黑美容法的書，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "或是暗黑時尚雜誌之類的呢～？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妳是不是以為，什麼都在前面加個「暗黑」就可以了？",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_029"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我看看，",
        "unit_id": 126311,
        "voice": "vo_adv_5120004_030"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "什麼什麼？",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n《暗黑圖解，",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "吸血鬼的一切！》、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "《推薦的暗黑眷屬百選》、",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n《從明天開始就能用的",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "暗黑吸血鬼笑話》……",
        "unit_id": 126311
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "……看來是有加「暗黑」就行了啊。",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_031"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "都是關於吸血鬼的書籍呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "不過，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這也難怪。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "嗯，",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_032"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這是……",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "《挑戰神的魔族之王，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "傳說的吸血鬼》。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n這就是在街上流傳的傳說嗎。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "哼嗯……",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_033"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "裡面寫的內容，",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "跟布拉德所說的沒有差太多呢。",
        "unit_id": 126211
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "這寫法與其說是",
        "unit_id": 126211,
        "voice": "vo_adv_5120004_034"
    },
    {
