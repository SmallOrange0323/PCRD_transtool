        "voice": "vo_adv_2000002_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被取了個可愛的綽號呢～太讚了吧☆",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只有這些魔物的話，我一個人就能輕易～地殲滅牠們呦♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這可不行呢，怎麼可以老是讓人幫忙！",
        "unit_id": 100211,
        "voice": "vo_adv_2000002_060"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我也要參戰！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "我們也一起參戰吧，主人。",
