    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就算要避難，這裡這麼多魔物也很難行動啊。",
        "unit_id": 105911,
        "voice": "vo_adv_2000002_057"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，",
        "unit_id": 105911,
        "voice": "vo_adv_2000002_058"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n饑腸轆轆的貪吃佩可小姐……先這樣稱呼您吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在我們是在同一條船上了，一起脫離險境吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咦～貪吃佩可是在叫我嗎？",
