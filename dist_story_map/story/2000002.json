[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "早安",
        "unit_id": 190011,
        "voice": "vo_adv_2000002_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "抱歉抱歉，把你吵醒了呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2000002_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你可以繼續睡沒關係，反正我也想要集中精神工作……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n現在可沒有功夫陪你呢",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯？你怎麼露出『妳是誰呀？』的表情呢，",
        "unit_id": 190011,
        "voice": "vo_adv_2000002_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我可是很清楚你的說……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n看到你像是第一次看到我的樣子，內心還是會覺得有點難過。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我的名字是……嗯，你就叫我愛梅斯好了。",
        "unit_id": 190011,
        "voice": "vo_adv_2000002_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n最近大家都是這樣稱呼我的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不用勉強記住也沒關係喔，反正你大概馬上就會忘記了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "因為，",
        "unit_id": 190011,
        "voice": "vo_adv_2000002_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這也像是，類似夢境之類的東西。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如你所見我現在已經渾身是傷完全損壞了，",
        "unit_id": 190011,
        "voice": "vo_adv_2000002_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n在自我修復完成之前都沒有辦法活動。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n也無法干涉現實。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以呢。",
        "unit_id": 190011,
        "voice": "vo_adv_2000002_006"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我派出了一位代理人，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n由她負責擔任你的『嚮導』。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她是你的人生、也就是現實裡的領航員。",
        "unit_id": 190011,
        "voice": "vo_adv_2000002_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n詳細的內容你就去問她吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "……哎呀。",
        "unit_id": 190011,
        "voice": "vo_adv_2000002_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "對不起，看來這一次的碰面差不多就只能到這裡了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然我還有好多好多話想跟你說呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "現實是很殘酷的。",
        "unit_id": 190011,
        "voice": "vo_adv_2000002_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過我們也不能夠老是做夢呢。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，再見囉。",
        "unit_id": 190011,
        "voice": "vo_adv_2000002_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我會祈禱你的人生、和你的現實裡都充滿了幸福。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "小火開始慢慢蒸……♪",
        "unit_id": 1,
        "voice": "vo_adv_2000002_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "途中大火滾一滾……♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n寶貝哭了要忍忍，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "莫揭鍋蓋悶一悶……♪",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "200000201"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……啊。",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您從睡夢中醒來了呢，主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是受到偉大的愛梅斯大人差遣而前來的「嚮導」……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "名叫可可蘿。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從今以後請多多指教。",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "保護主人的安危，",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從早晨到夜晚……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從出生到死亡，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "誠心誠意地照顧主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是在下的職責。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請儘管吩咐命令，主人。",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_016"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀，您看起來似乎一臉茫然呢。",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，雖然這樣不太禮貌……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下可以問問您的名字嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。\n太好了，您的確是在下服侍的主人沒有錯呢。",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是抱歉，居然還懷疑是否認錯人了。",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果惹主人不開心了，請儘管懲罰在下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論是鞭笞還是如何對待在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下都不會介意的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從愛梅斯大人的諭示中得知，",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人好像「幾乎喪失了所有的記憶」……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在應該不太清楚整個狀況吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會引導主人的，請您放心。",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_022"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我肚子餓了～……",
        "unit_id": 1,
        "voice": "vo_adv_2000002_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我肚子餓了～……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，在下知道了。",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n已經是午餐時間了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下剛剛還想著主人醒來的話，",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就讓主人用餐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n剛好在下已經煮好飯了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇呀，是白飯耶～！",
        "unit_id": 105812,
        "voice": "vo_adv_2000002_026"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是太謝謝妳了太謝謝妳了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我肚子餓到快死掉了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "謝謝招待，我開動～了☆",
        "unit_id": 105812,
        "voice": "vo_adv_2000002_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嚼嚼嚼♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……請問您是哪位呢？",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嚼嚼嚼♪",
        "unit_id": 105812,
        "voice": "vo_adv_2000002_029"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼呼，真～好吃！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我活過來了～，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "果然米飯是生命的能量啊……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊啊，吃飽了吃飽了！",
        "unit_id": 105812,
        "voice": "vo_adv_2000002_030"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呀，你們真的幫了大忙！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "願意將美味的食物分給我這個陌生人，",
        "unit_id": 105812,
        "voice": "vo_adv_2000002_031"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你們真是好人！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我會一輩子記住這份恩情的，謝謝～囉☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，與其說是分給妳，應該說我們反應過來時妳已經在吃了……",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_032"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下為主人煮的飯一瞬間就全部消失了？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妳、妳到底是誰啊？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我……",
        "unit_id": 105812,
        "voice": "vo_adv_2000002_034"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "算了，比起這個。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那女孩是你們認識的人嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那女孩，指的是？",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_035"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇呀，救命啊！",
        "unit_id": 100211,
        "voice": "vo_adv_2000002_036"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n魔物、有大量魔物朝這邊衝過來了～！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀……好像發生大事了。",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有一位不知道是誰的人正被大群的魔物追捕。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該，該怎麼辦呢主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "魔物們正朝著這邊而來，不能坐視不管呢。",
        "unit_id": 105811,
        "voice": "vo_adv_2000002_038"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我盡速去收拾牠們一下，請兩位去避難吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我這就去幫妳～那邊的人♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦、呃妳是？",
        "unit_id": 100211,
        "voice": "vo_adv_2000002_039"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妳要來幫我嗎……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……",
        "unit_id": 105911,
        "voice": "vo_adv_2000002_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔物實在是太多了，我們也去幫忙吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛好在下也可以順便向主人說明一下『戰鬥方式』呢♪",
        "unit_id": 105911,
        "voice": "vo_adv_2000002_041"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "非常感謝你們！",
        "unit_id": 100211,
        "voice": "vo_adv_2000002_042"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "多虧了你們的幫助……\n我差點就要被吃掉了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不用客氣，您沒事就好。",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_043"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您為什麼會被那一大群魔物追捕呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "比起那女孩，我想牠們的目標應該是我喔。",
        "unit_id": 105812,
        "voice": "vo_adv_2000002_044"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那女孩應該只是剛好路過，",
        "unit_id": 105812,
        "voice": "vo_adv_2000002_045"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n而被捲了進來吧…………",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "很抱歉造成了你們的困擾",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是您嗎？",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，是怎麼回事呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說回來，您到底是什麼人……？",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n甚至連您的名字都還不清楚呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，我也還沒報上我的名字呢。",
        "unit_id": 100211,
        "voice": "vo_adv_2000002_048"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我叫優衣。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真的非常感謝你們的幫忙……♪",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，好的。在下名叫可可蘿。",
        "unit_id": 105913,
        "voice": "vo_adv_2000002_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這位是在下的主人。{player}大人",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……我們是不是在什麼地方有見過呢？",
        "unit_id": 100211,
        "voice": "vo_adv_2000002_050"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂～！",
        "unit_id": 105812,
        "voice": "vo_adv_2000002_051"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n大家請過來這裡！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好像有人昏倒了喔～",
        "unit_id": 105812,
        "voice": "vo_adv_2000002_052"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡應該有人會使用回復魔法吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100211,
        "voice": "vo_adv_2000002_053"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我擅長回復魔法！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "至於那個昏倒的人……嗯？",
        "unit_id": 100211
    },
    {
        "type": "still",
        "still": "200000202"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2000002_054"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這個人是怎麼了呢？",
        "unit_id": 100211,
        "voice": "vo_adv_2000002_055"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "跟我一樣都是因為剛好經過而被捲入的嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n看上去雖然沒有外傷，卻不知道為什麼昏過去了！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "治療之類的就交給妳囉。",
        "unit_id": 105811,
        "voice": "vo_adv_2000002_056"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n附近還有魔物在蠢蠢欲動，我去把牠們趕走！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "請大家帶著那位昏倒的人一起避難吧～♪",
