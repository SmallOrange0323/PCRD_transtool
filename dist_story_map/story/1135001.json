[
    {
        "type": "background",
        "background": "501100"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天是假日，沒有社團活動。\n然而美里卻一個人默默處理著社團的雜事。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呼，",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "洗完衣服了",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n今天天氣很好，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "衣服應該很快就能乾了呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "啊，",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "早安。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "怎麼了嗎？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天沒有社團活動喔。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我在幫大家",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "洗衣服喔。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n想說可以趁現在",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "做點事。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "咦？",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你問我",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天不是放假嗎？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "說得也是呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "明明是難得的休假日……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那個……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我說了你可不要笑我喔？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "因為我",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一直住在精靈之森，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "所以那個……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我對大海",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不太了解，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不曉得該怎麼過。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "明明作為老師，",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我應該要能教導他們",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n如何享受",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大海的美好才對……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你要",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "教我嗎？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "關於享受大海的方法……？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯……",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真開心。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我就恭敬不如從命吧♪",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_008"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "今天一天",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就請多多指教囉♪",
        "unit_id": 113511
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "明明還是早上，",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就已經",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "聚集了這麼多人，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "而且大家看起來都好開心♪",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n這裡所有的一切都和精靈之森不同，非常新鮮。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我已經好久沒有",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這麼興奮了。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "問你喔，",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "到了海邊",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "應該要做什麼？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "說得也是。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "無論做什麼",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "都該先填飽肚子。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好期待",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "海邊的食物喔。",
        "unit_id": 113511
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "炒麵、",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "烤香腸、",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "烤花枝和刨冰。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "每一樣看起來都好好吃♪",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在戶外站著吃東西",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "總覺得不太禮貌，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "但也讓人有點小激動，食物都變得更美味了呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "不過──",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "呦──！",
        "unit_id": 811,
        "voice": "vo_adv_1135001_014"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "海邊的食物",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "真是有夠好吃──！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n我全吃光啦──！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那下一攤",
        "unit_id": 414,
        "voice": "vo_adv_1135001_015"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "就吃那個吧！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "大海萬歲──！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "仔細一看，",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沙灘上堆滿了垃圾呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n明明大海這麼漂亮……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對不起喔。",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我呀，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "去稍微撿一下垃圾。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "海邊還是要乾乾淨淨的才好。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "謝謝你。",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你能變成這麼值得信賴的孩子，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師我真開心。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那麼，",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "我們分頭撿吧。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呼，",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "少了垃圾，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "整個沙灘都變得不一樣了呢。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "果然沙灘變乾淨之後，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "心情也",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "跟著好起來了。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "欸～欸～大姐姐你們",
        "unit_id": 113,
        "voice": "vo_adv_1135001_021"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "在做什麼？",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n也讓我們加入嘛。",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀。",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "可以嗎？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n我們在撿垃圾喔？",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對你們來說",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "或許會很無聊……",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "可以呀──！",
        "unit_id": 213,
        "voice": "vo_adv_1135001_023"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我也想讓海邊變乾淨！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "我們要一起幫忙撿垃圾～！",
        "unit_id": 213
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀呀，",
        "unit_id": 113511,
        "voice": "vo_adv_1135001_024"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "大家真是好孩子～",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那我們就",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一起來撿垃圾。",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n和哥哥姐姐一起，",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "把這裡變得",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "更～",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "加",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "乾淨吧♪",
        "unit_id": 113511
    },
    {
        "type": "dialogue",
        "name": "男孩子、女孩子",
        "words": "好──！",
        "unit_id": 213,
        "voice": "vo_adv_1135001_025"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "啥啊？",
        "unit_id": 811,
        "voice": "vo_adv_1135001_026"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "那群傢伙在幹什麼。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "特地跑來海邊撿垃圾？",
        "unit_id": 414,
        "voice": "vo_adv_1135001_027"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "笑死人了！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n這麼愛撿的話，",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "就把垃圾全都給你們吧！",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "太好了──！",
        "unit_id": 113,
        "voice": "vo_adv_1135001_028"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "得到一分了！",
        "unit_id": 113
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "啊～",
        "unit_id": 213,
        "voice": "vo_adv_1135001_029"
    },
    {
        "type": "dialogue",
        "name": "女子",
