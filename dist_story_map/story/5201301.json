        "words": "……感覺，",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "有點難為情呢。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "會嗎？",
