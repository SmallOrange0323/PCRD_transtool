        "voice": "vo_adv_5201301_001"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我倒是雀躍不已……♪",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "畢竟這可是",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "當時千里真那斥責說",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n「別做這種破壞戰鬥平衡的事」，就沒實裝的模型啊。",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "我也是，",
        "unit_id": 133711,
        "voice": "vo_adv_5201301_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "被拉基拉基教訓說",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不要破壞世界觀。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "唉，我承認這模型是參入太多個人喜好了啦。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……都是因為年輕犯下的錯誤呢。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "不過到了現在，",
        "unit_id": 133811,
        "voice": "vo_adv_5201301_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "那些力量成了可靠的一線希望。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n我要感謝以前的我。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "呵，",
        "unit_id": 133911,
        "voice": "vo_adv_5201301_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這是規格之外的東西，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "妳們要是被捲進去，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "可別抱怨喔！",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "來展現一下",
        "unit_id": 133811,
        "voice": "vo_adv_5201301_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "夢幻職業的力量吧。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "格列戈爾──",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "命令你殲滅我的敵人。",
        "unit_id": 133811
    },
    {
