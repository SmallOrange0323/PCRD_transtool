[
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "小火開始慢慢蒸……♪",
        "unit_id": 1,
        "voice": "vo_adv_2000005_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "途中大火滾一滾……♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n寶貝哭了要忍忍，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "莫揭鍋蓋悶一悶……♪",
        "unit_id": 1
    },
    {
        "type": "still",
        "still": "200000201"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……啊。",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您從睡夢中醒來了呢，主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n是受到偉大的愛梅斯大人差遣而前來的「嚮導」……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "名叫可可蘿。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從今以後請多多指教。",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "保護主人的安危，",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從早晨到夜晚……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從出生到死亡，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "誠心誠意地照顧主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "便是在下的職責。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請儘管吩咐命令，主人。",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_005"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀，您看起來似乎一臉茫然呢。",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個，雖然這樣不太禮貌……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下可以問問您的名字嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。\n太好了，您的確是在下服侍的主人沒有錯呢。",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是抱歉，居然還懷疑是否認錯人了。",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果惹主人不開心了，請儘管懲罰在下。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無論是鞭笞還是如何對待在下，",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下都不會介意的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從愛梅斯大人的諭示中得知，",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人好像「幾乎喪失了所有的記憶」……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在應該不太清楚整個狀況吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下會引導主人的，請您放心。",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我肚子餓了～……",
        "unit_id": 1,
        "voice": "vo_adv_2000005_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我肚子餓了～……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，在下知道了。",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n已經是午餐時間了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下剛剛還想著主人醒來的話，",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就讓主人用餐……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n剛好在下已經煮好飯了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇呀，是白飯耶～！",
        "unit_id": 105812,
        "voice": "vo_adv_2000005_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "真是太謝謝妳了太謝謝妳了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我肚子餓到快死掉了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "謝謝招待，我開動～了☆",
        "unit_id": 105812,
        "voice": "vo_adv_2000005_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嚼嚼嚼♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……請問您是哪位呢？",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嚼嚼嚼♪",
        "unit_id": 105812,
        "voice": "vo_adv_2000005_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "呼呼，真～好吃！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我活過來了～，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "果然米飯是生命的能量啊……☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊啊，吃飽了吃飽了！",
        "unit_id": 105812,
        "voice": "vo_adv_2000005_019"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哎呀，你們真的幫了大忙！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "願意將美味的食物分給我這個陌生人，",
        "unit_id": 105812,
        "voice": "vo_adv_2000005_020"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你們真是好人！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n我會一輩子記住這份恩情的，謝謝～囉☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呃，與其說是分給妳，應該說我們反應過來時妳已經在吃了……",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下為主人煮的飯一瞬間就全部消失了？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妳、妳到底是誰啊？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我……",
        "unit_id": 105812,
        "voice": "vo_adv_2000005_023"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "算了，比起這個。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n那女孩是你們認識的人嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那女孩，指的是？",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_024"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哇呀，救命啊！",
        "unit_id": 100211,
        "voice": "vo_adv_2000005_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n魔物、有大量魔物朝這邊衝過來了～！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀……好像發生大事了。",
        "unit_id": 105913,
        "voice": "vo_adv_2000005_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有一位不知道是誰的人正被大群的魔物追捕。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "該，該怎麼辦呢主人？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "魔物們正朝著這邊而來，不能坐視不管呢。",
        "unit_id": 105811,
        "voice": "vo_adv_2000005_027"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我盡速去收拾牠們一下，請兩位去避難吧！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我這就去幫妳～那邊的人♪",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦、呃妳是？",
        "unit_id": 100211,
        "voice": "vo_adv_2000005_028"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妳要來幫我嗎……？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔……",
        "unit_id": 105911,
        "voice": "vo_adv_2000005_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "魔物實在是太多了，我們也去幫忙吧。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛好在下也可以順便向主人說明一下『戰鬥方式』呢♪",
        "unit_id": 105911,
        "voice": "vo_adv_2000005_030"
    }
]