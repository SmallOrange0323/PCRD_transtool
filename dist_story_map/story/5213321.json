[
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "先遣下級魔物作餌試探，",
        "unit_id": 129711,
        "voice": "vo_adv_5213321_000"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n自身卻高居一旁，坐壁上觀。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "獄蜂──",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "自命女王，著實可笑之至。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
        "unit_id": 126511,
        "voice": "vo_adv_5213321_001"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "竟能一次操控",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "如此數量的魔物。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "六凶之力……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "不，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "即便不是那股力量。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n也的確……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "是極大的威脅呢……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "那還用說哈尼！",
        "unit_id": 20111,
        "voice": "vo_adv_5213321_002"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "\n梅莉莎大人可是超級厲害哈尼！",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "來吧，",
        "unit_id": 20111,
        "voice": "vo_adv_5213321_003"
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "各位奴隸們",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "哈尼哈尼",
        "words": "上吧哈尼！",
        "unit_id": 20111
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "你們也被蜂蜜的力量",
        "unit_id": 138012,
        "voice": "vo_adv_5213321_004"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "強行驅使著……",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我很快就會把你們從奴役的枷鎖之中解放出來，",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n請再稍微忍耐一下。",
        "unit_id": 138012
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "以這滿溢掌心的，",
        "unit_id": 138012,
        "voice": "vo_adv_5213321_005"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "慈愛為名。",
        "unit_id": 138012
    }
