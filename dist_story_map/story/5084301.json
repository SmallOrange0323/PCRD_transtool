[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這傢伙就是花凜說的魔物吧！",
        "unit_id": 106011,
        "voice": "vo_adv_5084301_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那就照平常的方式戰鬥吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n貪吃佩可！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "給我向前衝！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "凱留小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_5084301_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐並不在這裡喔。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "目前能採取的戰鬥陣型和往常不同，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請多加注意。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人還請躲到在下身後去。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可可蘿小姐，",
        "unit_id": 106411,
        "voice": "vo_adv_5084301_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個人現在也不在這裡呀……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他們兩人不在，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "確實會感覺有些失常呢。",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎怎怎、",
        "unit_id": 106011,
        "voice": "vo_adv_5084301_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼辦哪！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n前衛怎麼辦！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我來當嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n邊喊火力全開，邊用法杖打下去就好了嗎！？",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還請冷靜下來，凱留小姐。",
        "unit_id": 105911,
        "voice": "vo_adv_5084301_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若到前方去，凱留小姐將會無法順利詠唱魔法！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這裡還請讓在下來試著使出公主突襲……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……失常也要有點限度啊。",
        "unit_id": 106411,
        "voice": "vo_adv_5084301_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "兩位！",
        "unit_id": 106411,
        "voice": "vo_adv_5084301_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "前衛就交給我吧！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我會以速度攪亂敵方，使其露出破綻，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n還請可可蘿小姐支援我，",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凱留則麻煩用魔法給對方致命一擊！",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "雪菲小姐……\n雪菲……",
        "unit_id": 1,
        "voice": "vo_adv_5084301_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怎麼回事，",
        "unit_id": 106411,
        "voice": "vo_adv_5084301_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這種感覺像是看到女兒成長的欣慰眼神……",
        "unit_id": 106411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好，",
        "unit_id": 106011,
        "voice": "vo_adv_5084301_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就重整氣勢，三人一起上吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "攻擊的時候記得要喊「火力全開」喔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前方就交給雪菲小姐了！",
        "unit_id": 105911,
        "voice": "vo_adv_5084301_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這邊準備好了飯糰，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請在戰鬥中吃！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一定要模仿貪吃佩可小姐不可嗎！？",
        "unit_id": 106411,
        "voice": "vo_adv_5084301_011"
    }
]