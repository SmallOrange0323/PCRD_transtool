    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這是在【幻變少女】擊退美空後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n過了一陣子的某天裡所發生的事。"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對。",
        "unit_id": 126012,
        "voice": "vo_adv_1261001_002"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n有時候會發現",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "她突然就不見了。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "看樣子，",
        "unit_id": 126012,
        "voice": "vo_adv_1261001_003"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "她似乎是一個人外出了。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n而且",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "每次都會花上相當長的時間……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "雖然和蘭德索爾的居民漸漸打好了關係，",
        "unit_id": 126012,
        "voice": "vo_adv_1261001_004"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "但以她的年紀，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "要一個人外出還是有點太早了。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "而且，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "她還在成長期，因為體質的緣故很快就會肚子餓……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我跟莉莉都很擔心，",
        "unit_id": 126012,
        "voice": "vo_adv_1261001_005"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n所以會默默地在一旁守著她。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不過等我們注意到的時候，她已經",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "「咻」",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "地",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "消失了……",
