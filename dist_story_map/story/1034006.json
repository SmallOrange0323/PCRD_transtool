[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當{player}走在城鎮裡時，被優花梨搭話。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你明天能來我房間嗎？",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_000"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦？ 啊，",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "的、的確是只有我們兩人……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n但、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但我沒有奇怪的意思喔！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……最近總是讓你",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_002"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n看見我丟臉的模樣呢？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚嗚，你太溫柔了……",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "照理說明明會對我更感到失望……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我也對自己感到失望……\n我其",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "實是想讓你看見",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n自己更加成熟女性化的一面。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "所以……\n",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_005"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我想請你吃我親手做的料理。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n可以讓我……「款待」你嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "可以嗎？ 真的嗎？ ",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_006"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n那、那麼，我會準備好飯菜等你的！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n明天見！",
        "unit_id": 103411
    },
    {
        "type": "background",
        "background": "500070"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}來到墨丘利財團的公會小屋。\n當他打開玄關門時，\n優花梨正行三指禮等著他。"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你來啦。\n歡迎。",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_007"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呵呵，是嗎？ 謝謝。",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_008"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "那麼，房間在那裡。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我也會馬上跟過去的。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦，你問我為什麼不一起過去？",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_009"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n對、",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "對呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我有一些沒辦法過去的理由……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊，等一下，不要靠近我！",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_010"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n我、我現在真的沒有辦法動！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊嗚……\n我、",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_011"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我一跪坐……腳就麻了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n變得沒辦法動了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我、我要重新振作！",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_012"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n烹調招待你的料理！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然我平常只做簡單的料理，但是今天很特別喔。",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_013"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n有培根蛋麵、奶汁焗菜、布丁……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我要做特製西式全餐！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚呀！？\n……雞、雞蛋爆炸了。",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_014"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "沒、沒事沒事！",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_015"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n剛才只是有點失敗而已。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "接下來我會扳回一城，做出最棒的西式全餐……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……咦，這個味道……",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_016"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "培根烤焦了！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊哇哇哇，完全變成碳了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不、不不，不要緊，不要緊的！",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_017"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n現在開始才要扳回一城！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊――！ 等等等等，不能打開壁櫥！",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_018"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n打開的話垃圾袋會……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "嗚哇――雪崩啊――！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "奇怪――，盤子在哪裡……",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_019"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "呼呀",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "跌倒了……",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_020"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "真是的，是誰把瓶子放在這裡～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……是我。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你怎麼了？ 臉很紅呢……",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_021"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "咦，那是我的內衣！？ 我忘了整理了！？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "討、討厭啊啊啊啊啊！ 忘掉它～！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……我真是個沒用的女生呢……",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_022"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我的成熟女性印象加分作戰，",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_023"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n已經結束了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "果然人類是不會突然改變的……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝……",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_024"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是，已經無所謂了……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n像我這樣沒用的女生…………咦？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你的手臂受傷了嗎？",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_025"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n被魔物弄傷的嗎？",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "不可以哦，",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_026"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "很痛吧？\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "等一下哦，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "馬上幫你治療。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……好了，治療完成。",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_027"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n受傷",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "時要馬上說喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n這麼客氣可不行啊。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "欸……我、我是成熟的女性？",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_028"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "討厭，你、你在說什麼啊，真是的……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "你那樣很狡猾呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我和你在一起的時候，\n總覺得會鬆懈下來，",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_029"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n或者該說是太過放鬆了呢。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但是……當我有事想找人商量時，",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_030"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n首先浮現在腦海的就是你，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n所以我覺得你也是個出色的男性喔。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "……討、",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_031"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "討厭，我在說什麼啊。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n把、把剛剛說的忘了吧！ ",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "吃、吃飯吧！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "為了怕料理失敗，所以我有準備預先做好的料理！",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_032"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n嗯，",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然遠遠不及時尚的西式全餐……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "這樣也沒關係嗎？ ",
        "unit_id": 103411,
        "voice": "vo_adv_1034006_033"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "謝謝……",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n嗯，一起吃吧。",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "晚餐的同時，也是喝酒時間――！",
        "unit_id": 103411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在那之後\n陪著很開心的優花梨狂歡到早上――"
    }
]