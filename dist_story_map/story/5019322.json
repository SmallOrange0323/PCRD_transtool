[
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好，",
        "unit_id": 110211,
        "voice": "vo_adv_5019322_000"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "這樣子也除掉屏障了！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "你差不多該冷靜下來了吧……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "那是什麼？",
        "unit_id": 110011,
        "voice": "vo_adv_5019322_001"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n雨吉的旁邊有個像結晶的東西……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n好、",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好像有什麼在發光！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "咦，",
        "unit_id": 110211,
        "voice": "vo_adv_5019322_002"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雨水的顏色也突然改變了……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好冰！？",
        "unit_id": 110011,
        "voice": "vo_adv_5019322_003"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "感覺突然",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "雨水變得像冰塊一樣冰！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "而、",
        "unit_id": 110211,
        "voice": "vo_adv_5019322_004"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "而且，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一被這陣雨滴到，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n就感覺",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "莫名的難過起來……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "奇怪，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "可是這股心情……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "好像在哪……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "真的耶……",
        "unit_id": 110011,
        "voice": "vo_adv_5019322_005"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家也覺得情緒變得很低落……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n美、",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "美咲，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "被這陣雨滴到就糟糕了！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "……",
        "unit_id": 110211,
        "voice": "vo_adv_5019322_006"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "難道這是",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "雨吉的眼淚？",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "這陣雨嗎？",
        "unit_id": 110011,
        "voice": "vo_adv_5019322_007"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "　什麼意思？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "被這陣雨滴到時感受到的",
        "unit_id": 110211,
        "voice": "vo_adv_5019322_008"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "難過心情……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "跟我和鈴奈吵架時一樣……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "人家好像也是",
        "unit_id": 110011,
        "voice": "vo_adv_5019322_009"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "和那個時候一樣難過……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那個結晶",
        "unit_id": 110211,
        "voice": "vo_adv_5019322_010"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "一定是",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "凝結了雨吉的難過、",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "痛苦等……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n各式各樣的心情吧……",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "那種心情",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "把周遭的雨水都變成了他的淚水。",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "所以說，鈴奈！　",
        "unit_id": 110211,
        "voice": "vo_adv_5019322_011"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "要破壞那個結晶喔！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "我們得幫助他",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "脫離難過和痛苦才行！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "好！　",
        "unit_id": 110011,
        "voice": "vo_adv_5019322_012"
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "總之，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "非做不可呢！",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n……",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "咦？　",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "對了，美咲，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "\n妳說和人家吵架時，",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "鈴奈",
        "words": "一直是相同的心情嗎？",
        "unit_id": 110011
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "現在的事",
        "unit_id": 110211,
        "voice": "vo_adv_5019322_013"
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "跟那個無關吧～！",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "\n",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "不要胡思亂想，",
        "unit_id": 110211
    },
    {
        "type": "dialogue",
        "name": "美咲",
        "words": "給我專心破壞那個結晶啦～！",
        "unit_id": 110211
    }
]