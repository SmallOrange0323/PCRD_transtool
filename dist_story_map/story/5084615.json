[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "唔，",
        "unit_id": 101411,
        "voice": "vo_adv_5084615_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生還沒甦醒過來嗎。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "……哎呀，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不行！",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "太過擔心，導致我無法理清思緒了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "儘管對於可用邏輯解釋的現象，有的是對應手段，",
        "unit_id": 101411,
        "voice": "vo_adv_5084615_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "但沉睡不醒可就不屬於偵探能夠處理的範圍了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "偵探並非萬能。",
        "unit_id": 101411,
        "voice": "vo_adv_5084615_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這點我相當清楚。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n但是，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "什麼也辦不到，確實令人感到不甘心呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "既然如此，我目前辦得到的就是──",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "相信助手先生，等待他回來。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "畢竟當偵探也得有耐心呢。",
        "unit_id": 101411,
        "voice": "vo_adv_5084615_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "你早點清醒，我也是不會介意的唷？",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "助手先生。",
        "unit_id": 101411
    }
]