[
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，哥哥，哥哥～！",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_000"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "能在這裡遇到哥哥，真是人生百面！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "請安慰我～！",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我明明努力準備考試，卻沒有考上！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因、因為我犯了忘記寫名字這種初級錯誤的關係……！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我自己算了一下，",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_002"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n明明應該有拿到勉強及格的分數的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊，真是的，好不甘心，",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_003"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我還因為打擊太大，而把記起來的內容全都忘光了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚嗚，我真是太窩囊了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "枉費哥哥自從在城鎮裡相遇以來，",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_004"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n就常常陪我準備考試！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n明明哥哥都替我加油了，對不起～！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚嗚，我一直都是這麼一個不中用的孩子。",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_005"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "花時間縫製的衣服也忘了縫最重要的接線，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n只要一扯就會四分五裂。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔～……雖然我的特色是不論何時都情緒高昂，",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_006"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n但至少今天請讓我情緒低落吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我無法打起精神，雖然哥哥的安慰讓我很開心？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是的～我真討厭迷糊過頭的自己！",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_007"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "如果有個洞的話，我想把灰倒進去！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，哥哥為什麼厚著臉皮參加考試！",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n欸，我都沒發現，哥哥當時也在考場嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "恭、恭喜哥哥合格……？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "啊……",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_009"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "原來哥哥不是考上設計師培訓學校，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n而是打工面試合格了呀？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "真是的，請別用曖昧的說法。",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_010"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為我現在對考試、合格之類的單字很敏感！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥不夠細心體貼喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過，恭喜哥哥♪",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_011"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥如果打工拿到薪水，要請我吃點甜食之類的喔！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "實際上，我只能靠糖分治癒這份哀傷了！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_012"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哭鬧一番後，我已經平靜許多了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我要正向思考。",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_013"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n考試是定期舉辦的，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這次的考試結果雖然很遺憾，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但只要我不放棄，總有一天一定會合格。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "倒不如說下次考試時因為有花時間讀書，",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_014"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n說不定可以讓我考到能拿獎學金的高分。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這樣的話，這次落榜反而可以說是幸運的♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔，落榜這個詞由自己來說也是會感到意志消沉的。",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_015"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唉……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "總覺得纏著哥哥很不好意思。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我要回家了，我還得向父母報告考試結果。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "唔呀！？\n",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_016"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "等等，請哥哥不要扯我頭髮紮成圓圈的部分！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為我總是綁這種髮型，所以對髮根負荷很大～？",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_017"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "這個圓環的部分是很容易掉髮的！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "咦，哥哥說它看起來好像吊環，會想去抓？",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_018"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "什麼是吊環？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥有時候會說一些不明所以的話呢。",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_019"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過我經常記錯格言，也沒有資格說哥哥就是了。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "喔……",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_020"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥已經拿到打工的第一份薪水，所以要請我吃些什麼嗎？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "因為是託和我一起準備考試的福，哥哥才能通過打工面試？",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_021"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以要以此作為謝禮？",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "沒有啦～……我什麼都沒有做。",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_022"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥是憑著自己的實力合格的。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥是一個很厲害的人喔♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿。",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_023"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我很清楚的，哥哥什麼都辦得到。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n無論是我做不到的事，或是其他任何事。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我很尊敬哥哥喔，哥哥是我的超人♪",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_024"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗯嗯，這次我就接受哥哥的好意吧。",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_025"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我們去找間甜點店之類的吧，我想暴飲暴食。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n不管是心裡的疙瘩還是什麼，都讓它們在今天內飛散吧！",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "其實我是不能太和哥哥扯上關係的。",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_026"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不過就算之後挨罵也沒關係，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我要久違地向哥哥撒嬌♪",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "哥哥或許不記得了……",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_027"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "每次我意志消沉、無精打采時，",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n哥哥都會來找我呢。",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "然後哥哥會安慰我、鼓勵我、寵溺我。",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_028"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n所以我才沒辦法意志消沉……",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "而成長為這麼有精神又開朗、情緒亢奮的孩子～☆",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "欸嘿嘿，哥哥應該不懂我在說什麼吧……",
        "unit_id": 101112,
        "voice": "vo_adv_1011003_029"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101112
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "所以說，謝謝哥哥♪",
        "unit_id": 101112
    }
]