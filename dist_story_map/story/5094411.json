    {
        "type": "dialogue",
        "name": "碧",
        "words": "唉……",
        "unit_id": 122111,
        "voice": "vo_adv_5094411_000"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "今天是露營的最後一天……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n必須回家了呢……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "雖然發生了很多事，",
        "unit_id": 122211,
        "voice": "vo_adv_5094411_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "但這次的露營還是很好玩呢～",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我能理解小碧想要嘆氣的心情。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n要是時間允許，",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我也還想再多住幾晚。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過……",
        "unit_id": 104715,
        "voice": "vo_adv_5094411_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣才能稱作休閒吧。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n若不是有限的時間，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也不會有養精蓄銳的感覺了。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為悠閒自適",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就會變成日常的一部分了嘛。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "啊……",
        "unit_id": 122211,
        "voice": "vo_adv_5094411_003"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "就跟忍了一陣子後喝的麥酒會特別美味一樣吧。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "分清楚日常跟休閒是很重要的呢。",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 104715,
        "voice": "vo_adv_5094411_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對啊。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n所以……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小碧也不用那麼沮喪。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而且，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這次也不會是最後一次啊。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "下次再來就好。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "下次再來……",
        "unit_id": 122111,
        "voice": "vo_adv_5094411_005"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "對耶，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "妳說得沒錯。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "下次再來就好了嘛。",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我和",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "優花梨小姐、",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "純小姐……",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "還有你！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "下次要找更多的人來！",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
