    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是因為牠不可怕吧？",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為這孩子，",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "就只是隻貓……",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這表示埃拉與志那都",
        "unit_id": 128812,
        "voice": "vo_adv_5208007_071"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "以往對這個世界而言就是威脅。",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n……確實，",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "她們作為管理者潛藏著難以想像的力量呢。",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "警戒她們也是無可厚非……",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那個……",
        "unit_id": 128911,
        "voice": "vo_adv_5208007_072"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "不過埃拉和",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "志那都，",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n都已經失去",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "管理者的權限了吧？",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……也就是說，",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那兩人……",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊啊啊！！！",
        "unit_id": 128812,
        "voice": "vo_adv_5208007_073"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵……！",
