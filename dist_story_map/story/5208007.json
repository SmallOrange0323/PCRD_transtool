    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n然而，",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為什麼紅色天空跟",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "霧之魔物都沒出現……？",
        "unit_id": 128812
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……那、",
        "unit_id": 128711,
        "voice": "vo_adv_5208007_070"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "那應該",
