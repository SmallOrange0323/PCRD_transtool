        "voice": "vo_adv_5208007_081"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "那就趕快刪啊？",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我與妳無話可說。",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我跟這個世界一樣是仿造品，",
        "unit_id": 1,
        "voice": "vo_adv_5208007_082"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n只是作為仿造品，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我對一件事產生了興趣。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……那是、",
        "unit_id": 1,
        "voice": "vo_adv_5208007_083"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "刻意的行動嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "刻意的？",
        "unit_id": 106912,
        "voice": "vo_adv_5208007_084"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯，",
