    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "打從心底對這個世界絕望，",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "毫不猶豫地想抹消它。",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "而且當時，",
        "unit_id": 106912,
        "voice": "vo_adv_5208007_090"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "我以為這個世界很快就會輕易地消失。",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n輕風一吹就會散去的微弱燈火，",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "根本一文不值。",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……我雖是這麼想的。",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……但這世上就是會發生一些荒唐的事呢。",
        "unit_id": 106912,
        "voice": "vo_adv_5208007_091"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "好，",
        "unit_id": 106912,
        "voice": "vo_adv_5208007_092"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "無意義的閒聊也該結束了。",
