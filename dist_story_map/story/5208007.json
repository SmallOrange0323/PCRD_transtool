        "voice": "vo_adv_5208007_089"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n……我從頭到尾，",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "既沒有說謊，",
