        "unit_id": 1731
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135511,
        "voice": "vo_adv_5208007_015"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "安布拉，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你也很寂寞嗎喵～？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這下得告別了。",
        "unit_id": 135511
    },
