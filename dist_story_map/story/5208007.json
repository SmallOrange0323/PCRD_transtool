        "voice": "vo_adv_5208007_066"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n但是，",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "天空",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "沒有因此變紅呢？",
        "unit_id": 128911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦…………",
