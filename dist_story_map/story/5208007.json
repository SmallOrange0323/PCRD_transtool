        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "牠好像很親近我，",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "一起跟過來了──",
