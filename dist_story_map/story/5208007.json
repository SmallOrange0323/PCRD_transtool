    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n我應該，",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "消失了才對……",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是的。",
        "unit_id": 1,
        "voice": "vo_adv_5208007_080"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你的資料很快",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "就會被徹底刪除。",
