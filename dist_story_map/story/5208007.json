    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "什麼？",
        "unit_id": 106912,
        "voice": "vo_adv_5208007_086"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然極為罕見，",
        "unit_id": 1,
        "voice": "vo_adv_5208007_087"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但在過去的輪迴中，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你也曾經敗給她們。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可是……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你當時在最後展露的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是強烈的憤怒與",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "痛惜的情感。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……呵呵，",
        "unit_id": 106912,
        "voice": "vo_adv_5208007_088"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳想說我是為了讓愚民們團結一致才故意落敗的？",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哈哈……",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "哈哈哈！",
        "unit_id": 106912
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "妳真的如字面上一般",
