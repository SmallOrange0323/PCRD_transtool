    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是不自然的。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n你是不是為了複製品世界的未來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n才刻意扮演壞人？",
