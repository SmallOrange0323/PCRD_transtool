        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對不起啊日和，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "其實妳可以直接回去沒問題喔！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是這樣嗎！？",
        "unit_id": 135712,
        "voice": "vo_adv_5208007_012"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以啦，",
        "unit_id": 135511,
        "voice": "vo_adv_5208007_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "麻煩你囉，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生♪",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "抱歉啊，",
        "unit_id": 135511,
        "voice": "vo_adv_5208007_014"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "日和。",
        "unit_id": 135511
