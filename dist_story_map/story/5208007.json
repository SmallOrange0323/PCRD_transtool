    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "霸瞳皇帝被打倒過了幾天的某日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n日和見證完城市和人們取回平穩的生活後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n該回去基礎世界的日子到了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "但是……"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135511,
        "voice": "vo_adv_5208007_000"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "抱",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "歉，日和！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我沒辦法",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "讓日和回到原本的世界了！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦咦咦咦～～～！？",
        "unit_id": 135712,
        "voice": "vo_adv_5208007_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦，",
        "unit_id": 135712,
        "voice": "vo_adv_5208007_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "等等，埃拉，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這樣我很困擾啊！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼回事！？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯──",
        "unit_id": 135511,
        "voice": "vo_adv_5208007_003"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就是啊，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我啊。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n好像沒有管理者的權限了呢──！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哎呀──",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這下頭疼啦──",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈哈哈！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "妳完全不覺得頭疼吧！？",
        "unit_id": 135712,
        "voice": "vo_adv_5208007_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n所以，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "到底是怎麼回事啦～～～！？",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈！",
        "unit_id": 135511,
        "voice": "vo_adv_5208007_005"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不知道！！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "志那都應該會懂吧～？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我有告訴怜，妳去問她！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "說笑的～",
        "unit_id": 135511,
        "voice": "vo_adv_5208007_006"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "日和回不去，所以問不了吧。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那麼",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "日和，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我們去街上找要一起住的家吧！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦咦～",
        "unit_id": 135712,
        "voice": "vo_adv_5208007_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……嘿嘿嘿！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……嗯？",
        "unit_id": 135511,
        "voice": "vo_adv_5208007_008"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為",
        "unit_id": 135712,
        "voice": "vo_adv_5208007_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "當管理者",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很辛苦吧，",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "今後",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "有身為普通女孩子的",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "快樂未來在等著妳喔！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太好了呢，",
        "unit_id": 135712,
        "voice": "vo_adv_5208007_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埃拉！",
        "unit_id": 135712
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n辛苦妳了！",
