    {
        "type": "dialogue",
        "name": "職員2",
        "words": "大家，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "職員2",
        "words": "快看看這個～！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵喵喵！？",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_060"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "聚集了好多客人喵……！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然我不是美冬，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還是要有效率喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "工廠裡因為貓咪模型而大排長龍。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n造成了非常大的反響，許多職員們買了之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n臉上都浮現出滿意的笑容。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵哈哈♪",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_061"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "史上最高的銷售額喵♪",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這些貓咪模型",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就是我的招財貓喵♪",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為了感謝那些貓咪成為我的模特兒，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_062"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我要送牠們很多放了金槍鮪的高級貓罐頭來答謝喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……嗯喵？",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_063"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n{player}也想要貓咪模型，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "所以也要買鯛魚燒喵？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "謝謝惠顧喵♪",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_064"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就從這盒子裡抽出一個膠囊喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n真期待會抽到什麼喵♪",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n接下來",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就由我來實況轉播喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喔！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_065"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "看來他邂逅了命中注定的膠囊了喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "他將膠囊高高舉起！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "裡頭裝的到底是哪個模型呢！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "打開喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "………………………………喵？",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_066"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵呀啊啊啊啊啊！？！？",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_067"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為什麼喵？",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_068"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是為什麼喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "為什麼「珠希模型」會在盒子裡喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我不是沒有採用喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "…………難道說！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_069"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "給我確認一下喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "喵～！！！！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_070"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我就知道！！！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n珠希模型的模具裝在設備上喵！！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "因為準備得太匆忙了，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可能是我不小心混進去了喵！！！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}！！！！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_071"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n快把那個",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還給我喵────！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是這麼說沒錯啦……",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_072"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "可是……！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……啊！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有隻飛天貓咪在天上飛喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "騙你的喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_073"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "趁現在喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚嗚嗚……！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_074"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這傢伙反應還真快喵……！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "好啦，",
        "unit_id": 1411,
        "voice": "vo_adv_1168002_075"
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "我也來買個鯛魚燒……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "咦？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "你們倆",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "在做什麼？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還我喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_076"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還給我喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n快給我",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還來喵！！！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "看到珠希這樣跳來跳去，",
        "unit_id": 1411,
        "voice": "vo_adv_1168002_077"
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "\n不禁令人聯想到",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "被逗貓棒玩弄的貓咪呢……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "看他們忙著玩耍，",
        "unit_id": 1411,
        "voice": "vo_adv_1168002_078"
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "我看來是明天",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "再來買吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "\n就這樣啦，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "工廠長",
        "words": "打擾了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "討厭！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_079"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "討厭！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你年紀明明比我小，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "乖乖聽長輩的話喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要是不聽話，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你就沒鯛魚燒可以吃喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊啊，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_080"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我亂說的，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "開玩笑的喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你踮起腳尖我就搆不到了，不要這樣喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n總之，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "總之……！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我給你錢，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_081"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "拜託把那個模型給我喵──！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "滿臉通紅的珠希放聲呼喊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就這樣在整間工廠裡迴響。"
    }
]