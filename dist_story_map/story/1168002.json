    {
        "type": "dialogue",
        "name": "旁白",
        "words": "午休時間還沒結束就將鯛魚燒全部賣完的珠希與{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n他們倆一邊吃著午飯，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "一邊討論下一個計畫。"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "銷售十分穩定喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_000"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然銷售穩定，就該準備下一步了喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "來擬訂計畫喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "話是這麼說，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_001"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "要想計畫也不簡單喵……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n有沒有什麼好點子喵……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "貓1",
        "words": "喵～",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_002"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你是之前的……！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "等我一下喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我想說你可能還會來，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就準備了貓罐頭喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "貓2",
        "words": "嗚喵～",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這些貓咪似乎都住在玩具工廠周邊喵。",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_003"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n牠們經常來玩喵。",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "好乖好乖喵～♪",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_004"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n貓罐頭好吃吧喵～♪",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你們那個像洗臉一樣的動作，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "真的好可愛喵～♪",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "貓1",
        "words": "喵～",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你也要一起想吧喵～？",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_005"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n有沒有什麼好點子，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "能讓鯛魚燒店生意更興隆喵～？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "貓1",
        "words": "喵～",
        "unit_id": 1711
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……？",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_006"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "什麼喵？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n要我跟著你走喵？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗚喵！？",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_007"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "是工廠喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我都不知道這裡還有其他工廠喵。",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……我懂了，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_008"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "原來如此喵～",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n因為這裡的設備壞掉了，所以無法使用了喵。",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "現在的我應該修得好喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這樣一來，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_009"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就可以繼續製造很多玩具……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……對了喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我想到一個好點子了喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n就在這裡",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "製作我的原創玩具喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "概念是這樣喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_010"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n「收到前好期待！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "收到後笑開懷！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "買鯛魚燒就送玩具」喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "蘭德索爾有好多間鯛魚燒店喵。",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_011"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n要在味道的品質以外做出差別，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "就只能靠服務了喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然決定了，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_012"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n午休結束後就立刻去找工廠長商量喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當天業務順利結束之後──"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你聽我說喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_013"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n工廠長准許我",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "使用那間老舊工廠了喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}，我希望你一起來幫忙喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……如此這般，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_014"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "完成了喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n怎麼樣喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "沒錯喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_015"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "然後只要按下它的肚子……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "鯛魚燒玩具",
        "words": "「來買鯛魚燒喵～♪」",
        "unit_id": 1,
        "voice": "vo_adv_1168002_016"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……就會發出聲音喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_017"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是不是很創新喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "嗯嗯～",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_018"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你的反應好普通喵。",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然如此……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我繼續追加新的語音喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n順便也增加",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不同配色的玩具喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……嗯，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_019"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "雖然會有點超出預算……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "不過，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這玩具肯定會大賣，沒問題的喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "放心喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_020"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n我對鯛魚燒的味道很講究，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n對玩具的品質當然也會嚴格把關喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "既然決定了，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_021"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n明天馬上就來送玩具贈品喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天的午休時間──"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "啊！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_022"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "{player}，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我在等你喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "開店之前，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "你先看看這個玩具喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n外皮的質感、",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "觸感、",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "還有氣味，我都十分講究喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "……嗯喵？",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_023"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n你問我做了這麼多沒問題嗎？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我還嫌做得不夠多喵！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_024"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n畢竟，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這些玩具的品質那麼棒喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "客人一定也感受得出來，",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "肯定會大吃一驚喵！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "那麼就馬上開賣喵────！！",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_025"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唉…………",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_026"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "這是為什麼喵？",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_027"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n為什麼大家都不肯收下這個玩具喵！？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n這玩具明明……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "明明就",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_028"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "做得很棒啊！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "換作是我，別說一個了，",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_029"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n送我一百個也不嫌多喵！！",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "有的拿來保存用、",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "觀賞用、",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "日常用、",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "推廣用……",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "唉……",
        "unit_id": 116811,
        "voice": "vo_adv_1168002_030"
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "怎麼辦喵？",
        "unit_id": 116811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "\n剩下了這麼多庫存……",
        "unit_id": 116811
    },
