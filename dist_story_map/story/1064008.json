[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，雪菲和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n也一邊尋找記憶，一邊進行【美食殿堂】的公會活動邊走邊吃。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯……♪",
        "unit_id": 106412,
        "voice": "vo_adv_1064008_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n果然",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那間店的冰淇淋最好吃了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n{player}，你也有同感吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊，{player}。",
        "unit_id": 106412,
        "voice": "vo_adv_1064008_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你轉過來一下？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n臉頰上沾到冰淇淋了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……好，",
        "unit_id": 106412,
        "voice": "vo_adv_1064008_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "擦掉了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真是的，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你都不是小孩子了。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……呵呵。",
        "unit_id": 106412,
        "voice": "vo_adv_1064008_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n總覺得",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "今天很和平呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不用戰鬥，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也不會被奇怪的人搭話……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……如果這樣的時光",
        "unit_id": 106412,
        "voice": "vo_adv_1064008_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "可以永遠持續下去的話……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "咦……？",
        "unit_id": 106412,
        "voice": "vo_adv_1064008_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n怎麼又是這道光……！？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "{player}……！",
        "unit_id": 106412,
        "voice": "vo_adv_1064008_006"
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嘿咻……",
        "unit_id": 1,
        "voice": "vo_adv_1064008_007"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "唔……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在公園裡散步的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看見了一位單腳裹著石膏的少女，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n撐著拐杖搖搖晃晃地走著。"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嘿咻……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_008"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嘿咻……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……啊！",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "！？",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_009"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n……謝、",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "謝謝……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}攙扶著腳步不穩的少女，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n讓她在附近的長椅上坐下。"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……不好意思。",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_010"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n我還沒有",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "習慣撐拐杖走路……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n早知道就不要意氣用事，",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "老老實實借張輪椅了。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "咦？",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_011"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "不、",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "不用啦。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "接我的人",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "應該快到了。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "…………",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "那個……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_012"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我是不是",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "在哪裡",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "和你見過面呢？",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "雖然我也說不清楚",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "為什麼會有這種感覺……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "唔……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_013"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "算了。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n既然",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我們彼此",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "都想不起來的話……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "可能就是我的錯覺吧。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "啊……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_014"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n這個是",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "因為……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……其實我呀，",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_015"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n很喜歡花式滑冰。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "雖然自己講有點奇怪，",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_016"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "但我做了很多練習……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n為了避免體重增加，",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我也很克制飲食。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "不過……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_017"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "至今為止的練習，",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "似乎漸漸地對身體造成了負擔。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "結果就因為小小的因素",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "而傷到膝蓋……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……醫生告訴我，",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_018"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "只要努力復健就可以康復，",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n不會對日常生活",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "造成影響。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "但是……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我已經",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_019"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "不能再像以前那樣",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "跳躍了……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n然後……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "啊……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_020"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "抱歉。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n居然對剛認識不久的你",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "說了這些……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……謝謝……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_021"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_022"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我問你喔。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n你知道一款",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "「實現願望的遊戲」嗎？",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "這樣啊……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_023"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n果然",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "很知名呢。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我完全沒有",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_024"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "玩過遊戲，",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "所以不是很了解……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "用遊戲實現願望",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "到底是怎麼一回事呢？",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……就算能實現願望，",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_025"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "肯定",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "也是在遊戲裡吧。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n把現實中的腳",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "也治好……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "不太可能",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "發生這種事吧……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……但是……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_026"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "…………\n如果是在遊戲裡的話……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_027"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我是不是",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "還跳得起來呢……",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗯……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_028"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "接我的人到了。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "讓妳久等了。",
        "unit_id": 1,
        "voice": "vo_adv_1064008_029"
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "\n這位是……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "……不認識的人。",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_030"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "只是稍微聊了幾句。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "青年",
        "words": "這樣啊。",
        "unit_id": 1,
        "voice": "vo_adv_1064008_031"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "嗯。",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_032"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "那麼……",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_033"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "我先走了。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n謝謝你",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "願意聽我說這些。",
        "unit_id": 106431
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "…………",
        "unit_id": 106431,
        "voice": "vo_adv_1064008_034"
    },
