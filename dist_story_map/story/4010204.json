        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "剩下一件……",
        "unit_id": 118531,
        "voice": "vo_adv_4010204_001"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "重要的工作。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "沒想到",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "他會來向我預約……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "您好。",
        "unit_id": 118531,
        "voice": "vo_adv_4010204_002"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "呵呵，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "時間正好呢。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "感謝您",
        "unit_id": 118531,
        "voice": "vo_adv_4010204_003"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "今天聯絡我。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "您像這樣約我出來，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "是終於想要來敝公司了嗎？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "是為了別的事？",
        "unit_id": 118531,
        "voice": "vo_adv_4010204_004"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這樣啊……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "那麼，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "是什麼事情呢？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n如果有任何需要我幫忙的，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "請盡量開口。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "畢竟是能吸引您注意的",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "好機會！",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "咦？",
        "unit_id": 118531,
        "voice": "vo_adv_4010204_005"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n啊……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "沒想到您知道我的生日……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "原來如此，",
        "unit_id": 118531,
        "voice": "vo_adv_4010204_006"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "難怪您聯絡我的時候，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n會說等工作結束就好。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "……呵呵呵，",
        "unit_id": 118531,
        "voice": "vo_adv_4010204_007"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "謝謝您。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "那麼就先",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "結束工作模式。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n今天就不計算卡路里了，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "盡情的吃蛋糕吧♪",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "每次見面談話時，",
        "unit_id": 118531,
        "voice": "vo_adv_4010204_008"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "都會不自覺地放鬆下來。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "您真的是不可思議的人。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "……被吸引注意的，",
        "unit_id": 118531,
        "voice": "vo_adv_4010204_009"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "原來是我呢。",
        "unit_id": 118531
    }
]