        "words": "鮮嫩多汁的水果搭配",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_063"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "高品質的鮮奶油……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n海綿蛋糕體",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "像雲一樣蓬鬆柔軟，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "毫無疑問",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是一流的極品。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果有受到【墨丘利財團】秋乃小姐的投資，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_064"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n有如此品質也是合理的呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "確實",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_065"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "很好吃呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不只是外觀上有衝擊力而已……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不過。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_066"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "雖然很好吃……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但感覺完全沒有減少……！",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "滋味貨真價實，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_067"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "份量毫不手軟……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "完全配得上",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "蜜桃碰撞博覽會的名號呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……這如果",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_068"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不訂定計畫就魯莽挑戰",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "只會一敗塗地。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們先",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "暫停一下吧。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "畢竟好好休息",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_069"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "才是",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "今天的主題。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "裡面的鮮奶油，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "味道我好喜歡。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "推薦２～３人，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_070"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "原來",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是這個意思啊……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n{player}，有你在真是太好了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真的。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_071"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "休息的「後續」……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n一起加油吧。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "已經超過一半了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……不過，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_072"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "在那之前。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可以稍微",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "轉換一下心情嗎？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "即使是同一件事，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_073"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "稍微改變一下作法，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n就可以有轉換心情的感覺。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "所以……",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_074"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n如果可以的話，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一口……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_075"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓我",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "餵你",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n吃一口……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可以嗎？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊──",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_076"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "感覺有點",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "心跳加速呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咦？",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_077"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我、",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我也要嗎？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n……啊、",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊──",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……嗯。",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_078"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_079"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "真好吃。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n總覺得，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "味道雖然一樣……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但比剛才還要開心。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……呵呵。",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_080"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "兩個人一起的話，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_081"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "能夠確實往前推進呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n果然",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「推薦２～３人一起分享」",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是正確的。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就這樣，配合時不時轉換心情的「啊──」，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人笑著將博覽會的餐點全部吃完了。"
    }
]