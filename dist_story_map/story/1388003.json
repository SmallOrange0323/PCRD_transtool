[
    {
        "type": "background",
        "background": "502223"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "栞和{player}運用兩人的祕密暗號在漂漂河"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n玩得十分盡興。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就在他們玩完一輪，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "要上來泳池邊時──"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_000"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呼。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n光是漂漂河",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就玩得很開心了呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們也用了好多次祕密的暗號。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "跟你在一起的",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「快樂」，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "也多到數不清……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "還好，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我沒事。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n好久沒有像這樣遊玩了……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "呵呵。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我想想……",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n要不要去滑水道看看呢？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我們兩個一起去。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是的。",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_004"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果我一個人去的話，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "感覺在滑下來的途中",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n會不小心滑出去。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "滑球監視員",
        "words": "接下來是一位對吧！",
        "unit_id": 1,
        "voice": "vo_adv_1388003_005"
    },
    {
        "type": "dialogue",
        "name": "滑球監視員",
        "words": "\n這就是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "滑球監視員",
        "words": "本度假村引以為豪的",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "滑球監視員",
        "words": "滑水道！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "滑球監視員",
        "words": "\n那麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "滑球監視員",
        "words": "祝您玩得愉快！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_006"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "這個力道……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "速度好快……！",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n整個身體被往外帶……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "啊，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_007"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "彎道彎不過……",
        "unit_id": 138812
    },
    {
        "type": "background",
        "background": "502223"
    },
    {
        "type": "dialogue",
        "name": "滑球監視員",
        "words": "啊啊，",
        "unit_id": 1,
        "voice": "vo_adv_1388003_008"
    },
    {
        "type": "dialogue",
        "name": "滑球監視員",
        "words": "客人滑出滑水道飛到空中了！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "哇啊啊啊～",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_009"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "可能會變成類似這樣的事件。",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_010"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "事實上，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_011"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我也確實被{player}",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "救了好幾次呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "被強風吹跑的時候之類的……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_012"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "說的也是呢，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "都做過那些特訓了，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n如果再多加鍛鍊，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "說不定就能夠單獨去挑戰看看",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "了呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我還是",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "感到有點不安……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "好的！",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_013"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……咦？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}的腳步，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_014"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "跟剛剛不一樣……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那個……{player}。",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_015"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你的腳",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎麼了嗎？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "如果有什麼狀況的話，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們就休息一下吧。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "{player}！？",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_016"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你沒事吧！？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "──",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_017"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "請不要硬撐著走動。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我扶著你，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你就靠在我身上就好。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "別擔心，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_018"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我會好好撐住你的。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n你放心吧……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嘿",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咻。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我們去坐在那張椅子上吧。",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_019"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n往這邊，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "慢慢來，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "一步一步走。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "對，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "就照著你的步調走就好。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "能夠",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_020"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "深呼吸嗎？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……別擔心，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我就在這裡。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n以一個輕鬆點的姿勢",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "坐在這吧……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "讓我",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_021"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "看看你的腳。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n單純只有抽筋嗎？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n有踩到什麼東西，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或扭到腳嗎？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是小腿肚這邊",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_022"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "抽筋對吧。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "那麼，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "必須要把筋拉開呢。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "首先，",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_023"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "把腳伸過來……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嘿",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "咻。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我要",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "摸腳尖囉。",
        "unit_id": 138812
    },
    {
        "type": "still",
        "still": "138800301"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "感覺",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_024"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "怎麼樣？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n如果",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會痛的話要告訴我喔。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n不可以硬撐。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_025"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不用擔心。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n我會……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "慢慢來的。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "配合節奏，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "深呼吸……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "沒錯，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "你做得很好。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "我把小腿",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_026"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "往脛骨的方向推喔。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會痛對吧。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "不好意思。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n……",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "但是，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "現在停下來的話",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "會很容易又抽筋。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "最不舒服的",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_027"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "是小腿肚嗎？",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_028"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "或許是因為我們一直待在漂漂河裡面，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n小腿部分累積太多疲勞了。",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "比如說要踩穩",
        "unit_id": 138812,
        "voice": "vo_adv_1388003_029"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "以避免被沖走，",
        "unit_id": 138812
    },
    {
        "type": "dialogue",
        "name": "栞",
