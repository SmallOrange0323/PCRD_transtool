[
    {
        "type": "background",
        "background": "500102"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊，唔……",
        "unit_id": 106012,
        "voice": "vo_adv_2005005_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n嗚，唔……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "吶，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_001"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "凱留。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我接下來，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_002"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n要跟{player}稍微聊聊天……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n妳別光是躺在那邊，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "可以幫我們泡個茶嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是的……",
        "unit_id": 106012,
        "voice": "vo_adv_2005005_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n您的吩咐我會照辦……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以，請您別再對我做出那種殘忍的事情了……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "嗯，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_004"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "真乖。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "哎呀，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_005"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "怎麼了嗎……{player}？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n你有什麼意見嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我只是在管教我的寵物而已～",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_006"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n沒什麼不對，不需要被你指責吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦……？　",
        "unit_id": 106012,
        "voice": "vo_adv_2005005_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n喂，你做什麼？　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別碰我啦，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "很痛耶！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "哎呀，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_008"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你是在幫她包紮啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n你真的是很溫柔呢～。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "溫柔到我都想吐了♪",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不過正好，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_009"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你就這樣聽我說吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n{player}、\n我有一些問題想要問你。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "在我們聊天的時候，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_010"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n我不會再對凱留出手。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "如果你很重視這孩子，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_011"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "可別讓我覺得無聊唷。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "凱留妳給我忍住，別再慘叫了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "很吵的啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "吶，{player}。",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_012"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n你會不會覺得這個世界是『刻意製造』出來的呢？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "明明是個和平的時代，但武器店卻異常的多，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_013"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n反而是幾乎沒什麼販賣生活用品的店。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n也沒有生產食物用的田地",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "或是灌溉用的水道。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不過……",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_014"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這部份，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n我已經很努力地補足了就是。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "但歷史、地理，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_015"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "和政治體系，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n還有一些其他地方，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "都有著很不自然的空白呢……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你覺得這是為什麼呢？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "是前人太過愚蠢了嗎？",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_016"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n這種像是小孩子想出來的社會，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不，該說是世界觀……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n為什麼這世界沒有被消滅，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "還存留到現在呢？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "吶，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_017"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你難道不覺得奇怪嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n光是要維持正常生活就很不方便呢，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n因為缺少太多東西了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "明明針對那些魔物留有很詳細的資料，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_018"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n但關於動植物卻什麼都不清楚呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n這類不自然的地方，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "簡直不勝枚舉呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "即使治安跟經濟惡化，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_019"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n也全都被歸咎於政治家的無能……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "好像是這樣呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n這也讓我覺得有點頭痛啊。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "該責怪的對象不是王族，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_020"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "而是神才對吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n究竟是誰做出這種",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "爛到不行的世界啊？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "吶，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_021"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你不會這樣覺得嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "　\n還是說你覺得這些是愚蠢的妄想，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "毫無意義的戲言？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "呵呵。",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_022"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n我記得你好像失去記憶了是吧……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "如果是這樣的話，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_023"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n或許會覺得",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "『大概本來就是這樣』然後就接受了吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這世界上大部分的人，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_024"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "可都不覺得哪裡奇怪呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n因為他們都像這樣受到調整，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "並重新建構過了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "對這不自然的世界",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_025"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "存疑的人……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "包含我在內，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "只有極少部份的一些人。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所以，每當我說這些事情就會被當成怪人看待。",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_026"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這樣實在很討厭，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "也讓人很煩躁……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你失去了記憶可真是幸運呢，讓我都有點羨慕你了呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "話說回來。",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_027"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n你還記得哪些事情？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "失去了多少記憶、",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_028"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "是怎麼失去的……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n你現在對這世界來說，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "是怎麼樣的一種存在呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我很想搞清楚這件事情。",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_029"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n所以才會命令凱留，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "去調查關於你的事情。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "雖然，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "完全沒有收穫就是了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "要是給你過多刺激，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_030"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n讓你的記憶恢復，也會讓我很頭痛……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n而且，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "要是你來阻礙我也是件麻煩事。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所以我才",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_031"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "決定，\n像這樣",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "直接跟你面對面對話，確認這些事情。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "啊哈哈。",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_032"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "如果這是演技的話，那演的可真好，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n是開玩笑的話，也超有趣的……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你不記得的話就算了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "那對我來說都是些很不愉快，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_033"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不想提起的往事罷了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "如果你什麼都不記得的話，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_034"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n也算是實現了我的願望。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "吶，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_035"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你知道『阿斯特朗傳奇』嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "　\n知道『米奈娃』",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "是什麼嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "　\n你以為『公主騎士』，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "單純只是個公會名嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你能夠說出，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_036"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所有『七冠』的名字嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n或是你有遇過，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "自稱為『七冠』的人嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "那個惹人厭的妖精……",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_037"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我想想，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "叫做菲歐是吧。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n你還記得她嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "哎呀，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_038"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "看你都聽呆了呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "真是可愛……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這樣啊，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你聽不懂我在說什麼嗎？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "嗯嗯，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_039"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "原來如此啊？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n好像有聽過的印象，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "對吧？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "…………",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_040"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "呵、呵呵呵。",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_041"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n這樣啊……你真的全都忘記了呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "有件事情我忘了跟你說。",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_042"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n在這謁見之廳裡，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "設有像是測謊機一樣的魔法。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n你是不是說真話，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "靠這就能知道了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所以說，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_043"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n已經確定你真的是什麼都不知道，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n就像是個小嬰兒一樣。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "呼，這樣我就安心了。",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_044"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n看來『這次』你不會成為我的威脅呢。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "當然……",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_045"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n即使什麼都忘記了，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你還是你哦。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "明明誰都不是，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_046"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n只是個四處可見的平凡男子，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n但卻是能夠左右世界命運，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "像是主角一樣的存在♪",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "過去輕忽了你的存在，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_047"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n讓我在許多世界線裡都輕忽了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我有在反省唷，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "裝出一副游刃有餘的樣子是我不好。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "就算是有『晶』跟『米奈娃』的幫助，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_048"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n但我卻沒想到……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "會讓你這種既無趣又毫無價值的男人成為我的阻礙，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_049"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n到最後終究只能空手而回。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "所以這次，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_050"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n即使不完全，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "但在這個世界線建構了",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n對我來說還算方便的『前提』……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "不能有任何輕忽。",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_051"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n我一定要排除萬難，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "完美地實現我的夢想。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "『米奈娃』她，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_052"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n實在是很傲慢，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n似乎很不喜歡我的夢想……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "倒是很熱衷於戀愛啦，友情什麼的，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_053"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n忙著實現那些愚蠢小女孩的願望。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我不需要那種既膚淺，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_054"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "又無能的神明。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n我要自己成為神明，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "作為太陽君臨這個世界。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n只差一步，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "就只差一步……",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我的夢想就能實現了。",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "這樣是不是很棒呢，{player}？　",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_055"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n啊哈，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "啊哈哈哈哈♪",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "你一副完全聽不懂的表情呢。",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_056"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n是不是覺得",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "我是一個奇怪的人，",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n一直在講些莫名其妙的事情？",
        "unit_id": 106911
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "如果你只能理解到這種程度，",
        "unit_id": 106911,
        "voice": "vo_adv_2005005_057"
    },
    {
        "type": "dialogue",
        "name": "尤絲蒂亞娜",
        "words": "\n那我也只能請你節哀了。",
        "unit_id": 106911
    }
]