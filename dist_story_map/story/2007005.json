[
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哈啊，",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哎……♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "已經不行了～連",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "站都站不起來了啦……♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "別、別每次都故意講得那麼色啦！",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_001"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n這孩子真是夠了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "會覺得色色的，",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "是因為聽的那個人本身就色色的唷姊姊～♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我、",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_003"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我才不色呢……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "話說{player}，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "你們沒問題嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n還跟得上嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒問題！",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "怎麼會踏進這個看起來像是地下城的地方呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那位占卜師",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在這裡嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯～",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們的公會呀……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n因為各種緣故，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以現在是以這個古城作為據點呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "平時，",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "大家其實都是自顧自地逕自在街上活動唷。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n而當有什麼特定目的時，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "就會先在這邊集合呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是因為我們公會的，",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_007"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "說是會長也……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n總之就是公會裡最大的人，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "是因為她住在這裡的關係唷。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "其實原本是想和忍，",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_008"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n約在街上的哪個咖啡店見面就好了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "沒想到用通訊魔法聯絡上了以後，",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n就被",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "約在古城了呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "「若在這說起話來比較省事。」",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_010"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "她這麼說。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n雖然茜里也不懂是什麼意思就是了。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……哎、",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咿呀！？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎、",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "怎麼了，茜里？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n還好嗎？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯、",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_013"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "嗯。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n好像是從天花板、嘩啦嘩啦～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "掉了什麼碎片下來的樣子。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "然後剛好又掉進了有一點敏感的部位上呢，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不小心就哎出聲來了……♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "欸嘿嘿。",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_014"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n大家也要小心一點喔。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n這古城，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "到處都已經破破爛爛了呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "若不小心遇上崩落什麼的，",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_015"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "可能就掰掰囉？",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "話說，",
        "unit_id": 105913,
        "voice": "vo_adv_2007005_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總覺得能聽見從地面傳來的陣陣低鳴呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n也很像爭執吵鬧的聲響。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那是什麼呢？",
        "unit_id": 105913,
        "voice": "vo_adv_2007005_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是附在這個古城中的亡靈",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在騷動嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_018"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳搞不好猜對了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯～",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "該不會是宮子那傢伙",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n又引起什麼騷靈現象了吧？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊，",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_019"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "那個叫宮子的也是我們公會的一員唷。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "她是個明顯有點奇怪的女孩子，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "如果見到她可別太驚訝喔。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呀哈哈。",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_020"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我們這，幾乎都是像那樣的傢伙就是了呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "忍也是，",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_021"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "甚至還帶著個會講話的骷髏頭。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n伊莉亞也是，會突然變大人又變回小孩的，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n是個不可思議的生物呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但老實說，這裡的怪人越多，",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_022"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里反而過得更開心呢……♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "嗯。",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_023"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n大概是大家都有點奇怪的緣故，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n所以大多吃過不少苦，並且被人抱持偏見看待。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "所以若有什麼意想不到的情況發生，",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_024"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "也請別被嚇到呦。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我們倆也是，",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_025"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "因為是雙胞胎所以也受過些奇怪的目光對待。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "而我們這可說是集合各式各樣奇怪傢伙的公會，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n就盡可能不要欺負他們了唷。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "話說呢。",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_026"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n所以平時這裡的人，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "都盡可能不和世俗有所牽連就是了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "但既然是{player}的委託那就沒辦法了，",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_027"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "畢竟這傢伙也經常受到你關照呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "而且近期城裡也不太安穩，",
        "unit_id": 100611,
        "voice": "vo_adv_2007005_028"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "弄得人心惶惶的呢。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果能夠改變這窘境與狀況的話，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n茜里這邊也會盡可能幫忙唷♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "謝謝妳。",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_029"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n說的沒錯呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "讓大家能夠安然無恙地生活是最重要的。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n必定得打倒邪惡，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "然後一起奪回那屬於我們的和平生活吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……嗚哇？",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "哇唔哦！？",
        "unit_id": 105913,
        "voice": "vo_adv_2007005_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呀！？您、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您怎麼了嗎貪吃佩可小姐？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請別這麼冷不防地攬住人家，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都快喘不過氣來了！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對、",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n總覺得突然感受到一股寒意。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n該不會是真的有幽靈跑出來了吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_033"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不用擔心啦。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "願意這麼替人家著想，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真溫柔～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_034"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實我，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是很擅長對付這種妖魔鬼怪呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為吃不下肚。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_035"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n沒想到{player}，偶爾也會像個孩子一樣呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真可愛……♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒問題的！",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就算有幽靈出現，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我也會驅逐它的！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不，",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不是幽靈……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這個古城裡，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "除了宮子以外幾乎沒有幽靈唷。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n它們似乎很害怕伊莉亞，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "都躲得遠遠的呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "啊！",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_038"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "忍！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n真是的，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "不要突然從暗處冒出來啦～！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "妳這樣就好像真的幽靈一樣，",
        "unit_id": 102211,
        "voice": "vo_adv_2007005_039"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n連我都有點被嚇到了！",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "抱歉。",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_040"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n因為視線不太好，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n所以我也覺得至少要設置間接照明。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但是伊莉亞她討厭光線，所以……",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_041"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而且",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "對我來說，黑暗也完全沒問題呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "各位，",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "非常感謝你們",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "特地勞師動眾的前來。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我就是",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_043"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "占卜師忍。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你們的來意我早已知悉。",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_044"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n這邊有準備了一些茶，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n就讓我們慢慢地來討論吧。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "（哦哦……",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_045"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n明明看起來也還很年輕，卻是一位很有",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "氣場的人呢。）",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這人，",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就是那位也許擁有和「那男人」一樣能力的占卜師嗎？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "（有種獨特，",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "又可疑的感覺……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n更應該說，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有種怪怪～的可怕氣息？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嘎～嘿～嘿！",
        "unit_id": 2411,
        "voice": "vo_adv_2007005_048"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n小伙子，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "幹得好！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "這不是又準備了一票美麗的小姐姐嘛？",
        "unit_id": 2411,
        "voice": "vo_adv_2007005_049"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n就這麼想要討老子歡心嗎！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "那個大胸部的美眉，",
        "unit_id": 2411,
        "voice": "vo_adv_2007005_050"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "妳叫什麼？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n要不吃頓飯？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n老子",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "可知道不少不錯的餐廳呢！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸……",
        "unit_id": 105812,
        "voice": "vo_adv_2007005_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n骷骷骷、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "骷髏頭說話了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n該不會是腹語術吧？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "真的很抱歉。",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_052"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是寄宿了父親靈魂的骷髏頭，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不時就會插上句話。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸。",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_053"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n請不要對初次見面女孩子，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "用這麼吊兒啷噹的口氣說話。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "第一印象可是很重要的唷！",
        "unit_id": 2411,
        "voice": "vo_adv_2007005_054"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n不管是驚悚電影還是戀愛，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "都一樣！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "在那看著囉忍～",
        "unit_id": 2411,
        "voice": "vo_adv_2007005_055"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n馬上就能替妳找到個新媽媽囉♪",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "只要有父親您在就好了。",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_056"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n而且最近夥伴也增加了不少，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不會感到寂寞了。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過……",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_057"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n明明說要在這好好談話，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "好像卻又有點太吵鬧了點呢。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "抱歉。",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_058"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n看來伊莉亞和宮子，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "又在吵架的樣子。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果還這麼吵吵鬧鬧，",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_059"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n也會影響到我們的談話吧……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}，",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_060"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n若你不介意，是否可以調解一下她們的紛爭呢？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "她們倆……",
        "unit_id": 103111,
        "voice": "vo_adv_2007005_061"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n如果是{player}說的話，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n應該都會聽進去才對。",
        "unit_id": 103111
    }
]