[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在收他為徒的\n美冬身邊磨練劍術。"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不夠不夠！ 你沒有用心啊！",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不對不對，聽好？ ",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這邊要這樣……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "瞄準目標一舉突破！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n然後馬上向後退！ ",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這種打帶跑是最基本的喔！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就是這樣！ 很不錯呢！",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_002"
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "喂――，",
        "unit_id": 311,
        "voice": "vo_adv_1048002_003"
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "誰能幫幫我―――――！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哎呀，城鎮裡的人正邊大聲呼叫邊跑過來呢。",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "怎麼了？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "呼、呼……",
        "unit_id": 311,
        "voice": "vo_adv_1048002_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "發生什麼事了？",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_006"
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "那是，孩子們在成為廢墟的古城玩耍時……",
        "unit_id": 311,
        "voice": "vo_adv_1048002_007"
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "\n魔物突然來襲，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "孩子們就被留在古城裡了！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "拜託你們！ 如果你們對自己的武功有信心的話，",
        "unit_id": 311,
        "voice": "vo_adv_1048002_008"
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "\n就去救出孩子們吧！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這樣啊。如果救出孩子們的話，你會付我們多少盧幣？",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_009"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我、我知道啦，",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "只是說說看而已……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我、我不是認真要那麼說的啦……",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我明白了，我們會去救出孩子們的。",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不收錢……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "敵人大概有幾隻？ 我們會有效率地打倒對方，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n若能事先告訴我們的話就幫了大忙。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗯嗯，原來如此……",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "好了，我們前往古城吧！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這裡就是古城啊……",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "來吧，馬上實踐你的練習成果吧！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n要有效率地打倒敵人喔！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "哦啦啊啊啊啊啊啊啊！ 閃開閃開――",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嗚啦啊啊啊啊啊啊！ 衝啊―――",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500260"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘰歐歐歐歐歐！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "孩子們到底在哪裡……",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊！ 他們在那裡呢！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n他們正攀著高窗的窗沿逃離魔物！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "嗚哇啊啊！ 誰來救救我啊啊啊啊！",
        "unit_id": 111,
        "voice": "vo_adv_1048002_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "魔物也幾乎都消滅了嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們現在就過去救你們！ ",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "嘿呦……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "哇──啊！ ",
        "unit_id": 111,
        "voice": "vo_adv_1048002_020"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "好可怕啊啊！",
        "unit_id": 111
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "謝謝強大又溫柔的",
        "unit_id": 211,
        "voice": "vo_adv_1048002_021"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "姐姐你們！",
        "unit_id": 211
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……不、不客氣。",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呵呵，偶爾像這樣也不錯呢。",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_023"
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "大姐，謝謝喔！",
        "unit_id": 311,
        "voice": "vo_adv_1048002_024"
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "那個……雖然無法給你們謝禮，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "街上的人",
        "words": "但是至少讓我為你們修補衣服吧！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……衣服？",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_025"
    },
    {
        "type": "still",
        "still": "104800201"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊啊，衣服破得很誇張呢。",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "真討厭啊，真是的……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但是算了，暫時就這樣吧。",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_027"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "因為我們還有收到今後討伐魔物的委託。",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_028"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "到時候衣服可能又會弄破，",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n所以就保持這樣不是更有效率嗎？",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？ 你要我用這個遮住嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_029"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦？ 你是說，你要把斗篷借我？",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_030"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "女孩子不能這副模樣……啊。",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_031"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這麼說來，的確是這樣呢。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我完全忘了自己也是個女孩子。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……謝謝你呢。",
        "unit_id": 104811,
        "voice": "vo_adv_1048002_032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美冬想起了自己所遺忘的另一面，\n{player}和美冬之間的羈絆也更加深刻了。"
    }
]