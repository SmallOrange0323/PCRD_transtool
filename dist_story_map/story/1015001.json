[
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美里正在執行公會的工作，巡視著森林。"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯……聽說最近這一帶，有孩子看見了小魔物，",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_000"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n因此我才過來巡視的……看來似乎沒什麼異常呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也有些孩子經常會在這裡玩，",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_001"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師我好擔心啊……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……哎呀？",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_002"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n哎呀哎呀糟糕了！",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "有人倒在那裡呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒事吧――？",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_003"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n怎麼了嗎？說給老師聽聽看。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "麻痺了？哎呀哎呀哎呀，難不成，",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_004"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n是誤食了什麼東西嗎？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "蘑菇？哎呀哎呀，",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_005"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n或許那就是使你身體麻痺的原因也說不定喔。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一定是毒蘑菇呢……",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_006"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n從外表看來就相當嚇人對吧？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真可憐，老師現在馬上幫你解毒喔～",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_007"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "稍～微忍耐一下下喔――",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_008"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀！小魔物究竟是何時……",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_009"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n老師嚇了一跳呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "抱歉，你先當個乖孩子等著唷。",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_010"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n老師去和小魔物溝通一下。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你好啊。",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_011"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你就是在這一帶徘徊的小魔物吧～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "對不起喔。",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_012"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n孩子們都很害怕，所以要請你回家――",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_013"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你身體還麻痺著，跑到前面來是很危險的唷。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "小魔物也沒事的唷～",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_014"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500180"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀！沒事吧～？",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_015"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "小魔物也突然嚇了一跳對吧──",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_016"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "真是對不起喔。好～乖孩子乖孩子……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "沒什麼好害怕的唷。",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_017"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n沒有人會欺負你的喔……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "回家吧。",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_018"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n爸爸和媽媽，一定都在擔心著喔。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕嗚……咕嗚……",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "嗯……是個懂事的好孩子，真是幫大忙了。",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_019"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，受傷了呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_020"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "麻痺的身體狀況下，太逞強是不行的唷。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "為了要保護我嗎？",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_021"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "你真是個非常溫柔的孩子呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師很高興喔～",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_022"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n謝謝……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "很有勇氣呢。",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_023"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "好孩子好孩子，真乖真乖。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "痛痛、痛痛，飛走囉──♪",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_024"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "呵呵呵，怎麼樣。",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_025"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "這樣一來，中毒跟受傷都不要緊了喔。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "……嗯，已經沒事了。",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_026"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "話說如此，還真是不可思議呢～",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "那個毒蘑菇，雖然外表也相當驚人，但在大陸上算是非常有名，",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_027"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n幾乎沒有人會食用唷……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "就連小魔物也不會吃呢……",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_028"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n你不知道嗎？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀哎呀！",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_029"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n若是這樣，不知道也是有可能的呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "一路走來想必相當辛苦吧……",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_030"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n真是不容易呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "雖說如此，但是因為肚子餓了，",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_031"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n就把生長在地面上的毒蘑菇給大口吃下去，真是不得了呢。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "簡直就像個什麼都會放進嘴裡的",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_032"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "小孩子一樣……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，對了～",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_033"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "老師想到了一個好主意♪",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "其實我呢，",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_034"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "在精靈族之村中擔任幼稚園的老師。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n然後呢，",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "若你願意的話……",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "讓我當你的老師如何呢～？",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_035"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "若是再次吃到毒蘑菇之類的就糟糕了……",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_036"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "重要的是，我想還有許多事情能夠教你唷。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "當然，討厭的話也不會強迫你的。",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_037"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n……覺得如何呢？",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "哎呀哎呀，太好了呢～",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_038"
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "\n",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "也請你多多指教喔",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "。",
        "unit_id": 101511
    },
    {
        "type": "dialogue",
        "name": "美里",
        "words": "請稱呼我為美里老師喔♪",
        "unit_id": 101511,
        "voice": "vo_adv_1015001_039"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}也成為了美里所照顧的孩子們之一。"
    }
]