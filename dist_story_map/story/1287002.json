        "words": "\n對騎士先生你──",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好，",
        "unit_id": 135512,
        "voice": "vo_adv_1287002_065"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咚─────！！！！！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呀啊！！？",
        "unit_id": 128711,
        "voice": "vo_adv_1287002_066"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……等等，",
        "unit_id": 128711,
        "voice": "vo_adv_1287002_067"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埃拉！？",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n妳不是在喝酒嗎！？",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈，",
        "unit_id": 135512,
        "voice": "vo_adv_1287002_068"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我沒錢了！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我自掏腰包招待了跟我喝酒的所～有人啊，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "結果就在不知不覺間",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "變得錢包空空了──",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "等等，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好燙──！？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "埃～～～",
        "unit_id": 128711,
        "voice": "vo_adv_1287002_069"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "～～～",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "拉～～～！！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我明明照埃拉說的，",
        "unit_id": 128711,
        "voice": "vo_adv_1287002_070"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n心想不能光是等待，",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以努力付出行動了！！",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "為什麼要妨礙我～～～！！？",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈哈……",
        "unit_id": 135512,
        "voice": "vo_adv_1287002_071"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我沒打算妨礙妳啦～？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n只是，該說時機不太對嗎……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "話、",
        "unit_id": 135512,
        "voice": "vo_adv_1287002_072"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "話說回來，日和！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳馬上就實踐姐姐給妳的建議啦？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "妳這麼率直，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我覺得很可愛喔♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊──",
        "unit_id": 135512,
        "voice": "vo_adv_1287002_073"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但是，抱歉！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n再讓我囉嗦一件事吧？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "雖然氣勢很重要，",
        "unit_id": 135512,
        "voice": "vo_adv_1287002_074"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但光憑氣勢上場很危險喔！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要好──好判斷時機才行呦♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……！！",
        "unit_id": 128711,
        "voice": "vo_adv_1287002_075"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……",
        "unit_id": 128711,
        "voice": "vo_adv_1287002_076"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "確實，",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我好像有點，",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "太心急了。",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n熄火……",
        "unit_id": 128711
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "火勢太強的話會燒焦，",
        "unit_id": 135512,
        "voice": "vo_adv_1287002_077"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "太弱的話會烤不熟。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不管是戀愛還是料理，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "控制火勢都很重要喔♪",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "原來如此──！",
        "unit_id": 100111,
        "voice": "vo_adv_1287002_078"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒、",
        "unit_id": 100111,
        "voice": "vo_adv_1287002_079"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒什麼！！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我們回去吧～～～！！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……啊哈哈。",
        "unit_id": 100111,
        "voice": "vo_adv_1287002_080"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n真的是",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "像火焰一樣的人啊。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……埃拉，",
        "unit_id": 100111,
        "voice": "vo_adv_1287002_081"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會加油的。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我會更磨練自己，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "然後有所成長的。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "為了讓自己成為",
        "unit_id": 100111,
        "voice": "vo_adv_1287002_082"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "像妳那樣優秀的大人！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊，",
        "unit_id": 100111,
        "voice": "vo_adv_1287002_083"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "士先生──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這裡這裡──！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在晴空萬里的天空下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n今天兩人也開始修行了。"
    }
