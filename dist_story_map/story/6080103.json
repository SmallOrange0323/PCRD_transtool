[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "日差しは気持ちいいんだけど、",
        "unit_id": 113111,
        "voice": "vo_adv_6044103_000"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "日焼けが気になっちまうねぇ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n明日になって痛くならないといいんだけど……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "お前さん、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "日焼け対策は何かしてるのかい？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "そうなんだよねぇ。",
        "unit_id": 113111,
        "voice": "vo_adv_6044103_001"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "遊んでる時は気にならないんだけど、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n次の日にヒリヒリしてから後悔しちまうんだよ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "……今からでも日焼け止め、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "塗っておいた方がいいかね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "へぇ、",
        "unit_id": 113111,
        "voice": "vo_adv_6044103_002"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "お前さん",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "日焼けで痛くならないタイプなのかい。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n日焼けしてる人も",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "元気そうで好き？　",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "なるほどねぇ。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "……いい機会だから、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "もう少しアタシも焼いてこうかね。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "対策はバッチリってことかい、",
        "unit_id": 113111,
        "voice": "vo_adv_6044103_003"
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "やるじゃないか。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "……",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ここへ来る前に、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "ギルドハウスで塗ってもらった……？",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "\n",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "いや、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "お前さん。",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "それ、",
        "unit_id": 113111
    },
    {
        "type": "dialogue",
        "name": "ルカ",
        "words": "どう考えても落ちてるからね？",
        "unit_id": 113111
    }
]