    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "芙菈瓦村",
        "unit_id": 130711,
        "voice": "vo_adv_6144201_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n真的是充滿了花朵的村莊呢。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n{player}，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你有喜歡的花嗎？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "像鈴莓小姐的花？",
        "unit_id": 130711,
        "voice": "vo_adv_6144201_001"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那個，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你是指有著開朗氛圍的花嗎？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "確實，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "如果用這種花裝飾，感覺會讓人產生活力呢♪",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你、",
        "unit_id": 130711,
        "voice": "vo_adv_6144201_002"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你在胡說些什麼啊！？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我聽不懂你在說什麼，",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n但是感覺有點像變態喔！",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……不過，",
        "unit_id": 130711,
        "voice": "vo_adv_6144201_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我也不是不高興你這樣說。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "謝謝你。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……那個，",
        "unit_id": 130711,
        "voice": "vo_adv_6144201_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我不是想問你這個。",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n請你在這個村子裡",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不要什麼東西都放進嘴裡吃喔？",
        "unit_id": 130711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你可不是小嬰兒啊。",
        "unit_id": 130711
    }
]