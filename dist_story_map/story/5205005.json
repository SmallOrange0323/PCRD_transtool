        "words": "出發吧！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n高貴的大小姐怎麼可以一直垂頭喪氣！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……我明白了。",
