    {
        "type": "dialogue",
        "name": "旁白",
        "words": "華音的一切卻徹底毀滅。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被可恨的仇敵拯救性命，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "甚至被告知"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n自己是因為{player}才能活著，"
