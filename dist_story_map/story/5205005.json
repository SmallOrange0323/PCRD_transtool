    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "啊啊……",
        "unit_id": 134912,
        "voice": "vo_adv_5205005_039"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n當時我竟然背叛主人……",
