[
    {
        "type": "background",
        "background": "502170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "由於黑暗精靈和哥布林女士的計謀，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n涅妃‧涅羅看似結晶化。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而她卻"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "出現在陷入困境的華音面前。"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這這這、",
        "unit_id": 134912,
        "voice": "vo_adv_5205005_000"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "這是怎麼回事！？",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n涅妃！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "妳的確是",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "在那化為結晶",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "噁噗！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "居然在我給妳致命一擊前就變成幽靈，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "太卑鄙了",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "嗚咳咳……！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不過輕淺之傷，竟能如此啁啾。",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_001"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "按世俗所言，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "是謂「嘰嘰喳喳」？",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "空泛鳥鳴",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "尤為刺耳。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "為什麼……！",
        "unit_id": 3312,
        "voice": "vo_adv_5205005_002"
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "\n我的咒術",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "無疑發動了啊……！",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝之詛咒，",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_003"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "確實已展現威力。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n計謀已然奏效──",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "直抵奴家一層薄皮。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "哥布林女士",
        "words": "咦──",
        "unit_id": 19411,
        "voice": "vo_adv_5205005_004"
    },
    {
        "type": "dialogue",
        "name": "哥布林女士",
        "words": "地上、",
        "unit_id": 19411
    },
    {
        "type": "dialogue",
        "name": "哥布林女士",
        "words": "有洞！？",
        "unit_id": 19411
    },
    {
        "type": "dialogue",
        "name": "哥布林女士",
        "words": "\n這傢伙難道",
        "unit_id": 19411
    },
    {
        "type": "dialogue",
        "name": "哥布林女士",
        "words": "只分離了表層……",
        "unit_id": 19411
    },
    {
        "type": "dialogue",
        "name": "哥布林女士",
        "words": "化為液體避開了！？",
        "unit_id": 19411
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "……可是，",
        "unit_id": 3312,
        "voice": "vo_adv_5205005_005"
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "結界還在發動。",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "\n要分離自己的部分也有極限，",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "\n我們依舊",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "占據優勢！",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "嗯。",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_006"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n那麼奴家",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "亦當逆轉局勢。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──米亞。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "有～！",
        "unit_id": 51611,
        "voice": "vo_adv_5205005_007"
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "\n結界",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "米亞",
        "words": "重新啟動～！",
        "unit_id": 51611
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "……！",
        "unit_id": 3312,
        "voice": "vo_adv_5205005_008"
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "這麼短的時間裡",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "就進一步蓋掉我的結界啊。",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "\n",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "妳似乎有個優秀的部下呢。",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "\n",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "哎呀呀……",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "看來只能暫時",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "撤退了。",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "哥布林女士",
        "words": "可是可是！",
        "unit_id": 19411,
        "voice": "vo_adv_5205005_009"
    },
    {
        "type": "dialogue",
        "name": "哥布林女士",
        "words": "\n都到這裡了──",
        "unit_id": 19411
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "──乖乖聽話。",
        "unit_id": 3312,
        "voice": "vo_adv_5205005_010"
    },
    {
        "type": "dialogue",
        "name": "哥布林女士",
        "words": "好、",
        "unit_id": 19411,
        "voice": "vo_adv_5205005_011"
    },
    {
        "type": "dialogue",
        "name": "哥布林女士",
        "words": "好的……",
        "unit_id": 19411
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "以為真能遁逃？",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_012"
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "這個嘛，",
        "unit_id": 3312,
        "voice": "vo_adv_5205005_013"
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "全看皇女您了──",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "喝！",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──嗯？",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_014"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "在哪兒……",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "咦？",
        "unit_id": 134912,
        "voice": "vo_adv_5205005_015"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "伏下。",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_016"
    },
    {
        "type": "background",
        "background": "502170"
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "哼哼！",
        "unit_id": 3312,
        "voice": "vo_adv_5205005_017"
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "\n竟連那種廢物都要庇護，",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "黑暗精靈",
        "words": "真是辛苦啊──？",
        "unit_id": 3312
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "佯裝攻擊做目眩之計，",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_018"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "真是",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不得大意的小賊。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "剛剛是",
        "unit_id": 134912,
        "voice": "vo_adv_5205005_019"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "怎麼回事……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "何事？",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_020"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "為什麼要保護我！？",
        "unit_id": 134912,
        "voice": "vo_adv_5205005_021"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "我直到剛剛",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "都還想打碎妳！",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_022"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n為何多問？",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "不過是因汝乃騎士閣下之奴隸。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "否則，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝早已身首分離，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "懸於外郭。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "唔！？",
        "unit_id": 134912,
        "voice": "vo_adv_5205005_023"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "汝之性命無恙一事。",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_024"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "當予汝主騎士閣下",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "深深、",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "深深之",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "感謝。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……竟在只差一步之處",
        "unit_id": 134912,
        "voice": "vo_adv_5205005_025"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "再次失敗……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n……偏偏被",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "涅妃‧涅羅",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "保護……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "因為我是那個阿貓阿馬的",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "奴隸，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "才保住",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "一命……？　",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……也太……",
        "unit_id": 134912,
        "voice": "vo_adv_5205005_026"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "滑",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "稽、",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "了……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "看。",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_027"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n汝之主人來迎接汝了。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳在啊這個豎捲髮叛徒！",
        "unit_id": 134812,
        "voice": "vo_adv_5205005_028"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n在那站好，",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我要把妳狠狠揍一頓！",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……？",
        "unit_id": 134812,
        "voice": "vo_adv_5205005_029"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n華音……？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "……我……",
        "unit_id": 134912,
        "voice": "vo_adv_5205005_030"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "等等……？",
        "unit_id": 134812,
        "voice": "vo_adv_5205005_031"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n怎麼啦？",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "妳眼裡的光都消失了……",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "──呵呵呵。",
        "unit_id": 129712,
        "voice": "vo_adv_5205005_032"
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "\n",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "沒事，",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "毋需多慮，",
