        "words": "讓賊人逃脫",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "涅妃‧涅羅",
        "words": "皆是奴家疏失。",
        "unit_id": 129712
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "那也都是我的錯……",
        "unit_id": 134912,
        "voice": "vo_adv_5205005_042"
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "\n全～",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "部，",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "全～",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "部",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "華音",
        "words": "都是我的錯……",
        "unit_id": 134912
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "……我們不是為了把錯誤歸咎給誰而來。",
        "unit_id": 134812,
        "voice": "vo_adv_5205005_043"
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "\n我是",
        "unit_id": 134812
    },
    {
        "type": "dialogue",
        "name": "紡希",
        "words": "為了親手救出怜大人在行動，",
