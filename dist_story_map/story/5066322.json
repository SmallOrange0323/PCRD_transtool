[
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好像有什麼出現了耶！",
        "unit_id": 116511,
        "voice": "vo_adv_5066322_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這些傢伙是……",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我、",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們？",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "哦？",
        "unit_id": 116611,
        "voice": "vo_adv_5066322_001"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "可以和自己戰鬥的意思嗎？",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "還不賴嘛……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "讓人熱血沸騰了起來！",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "等一下嘉夜夜！",
        "unit_id": 116511,
        "voice": "vo_adv_5066322_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n如果這是過去的我們的話就糟糕了！",
        "unit_id": 116511
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "沒事的，",
        "unit_id": 106711,
        "voice": "vo_adv_5066322_003"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "這只是如同妳們的複製品一般的東西，",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n就算毫無顧忌的打倒它們",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "應該也沒關係唷。",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "確實看起來好像跟我們有點不同……",
        "unit_id": 116511,
        "voice": "vo_adv_5066322_004"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "什麼嘛，",
        "unit_id": 116611,
        "voice": "vo_adv_5066322_005"
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "不是跟自己打嗎……",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "\n",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "算了！",
        "unit_id": 116611
    },
    {
        "type": "dialogue",
        "name": "嘉夜",
        "words": "總之擊潰就對了！",
        "unit_id": 116611
    }
]