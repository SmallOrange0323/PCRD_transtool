[
    {
        "type": "dialogue",
        "name": "美空",
        "words": "奇怪？",
        "unit_id": 131211,
        "voice": "vo_adv_5148302_000"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n牠看起來很有精神耶──",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "不如說，",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "牠好像變得比剛剛更強了？",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是魔導具的影響嗎～？",
        "unit_id": 131111,
        "voice": "vo_adv_5148302_001"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "魔力也變多了，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "似乎失控得比剛剛更嚴重了。",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不如說……",
        "unit_id": 131611,
        "voice": "vo_adv_5148302_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n有種讓人不舒服的氣魄傳了過來啊……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n是我的錯覺嗎？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這麼說來～",
        "unit_id": 131211,
        "voice": "vo_adv_5148302_003"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "那隻史萊姆。",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n看起來好像在用下流的表情笑著呢～",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "牠是不是在想著，",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這次我絕對要",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "把泳裝溶掉～",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "之類的呀？",
        "unit_id": 131211
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "嗯～",
        "unit_id": 131111,
        "voice": "vo_adv_5148302_004"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "真的呢。",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "牠是像到誰啊～？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "真是隻恐怖的史萊姆呢……",
        "unit_id": 131611,
        "voice": "vo_adv_5148302_005"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n無論如何，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "要提高警覺才行……！",
        "unit_id": 131611
    }
]