[
    {
        "type": "background",
        "background": "502330"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呵呵♪",
        "unit_id": 190912,
        "voice": "vo_adv_5150063_000"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n這邊喔這邊～♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n試著抓住我吧♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "給我等一下，涅比亞！",
        "unit_id": 131711,
        "voice": "vo_adv_5150063_001"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "妳這……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "夠了……",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "太小了，根本抓不到……！",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "是因為試圖用手抓",
        "unit_id": 131711,
        "voice": "vo_adv_5150063_002"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "才行不通的吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n要是有抓捕用的道具之類的就好了。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不管準備什麼都沒用喔，沒用♪",
        "unit_id": 190912,
        "voice": "vo_adv_5150063_003"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "咦，",
        "unit_id": 131711,
        "voice": "vo_adv_5150063_004"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "什麼？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你說「交給我」？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也對呢……",
        "unit_id": 131711,
        "voice": "vo_adv_5150063_005"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你多過頭的打工經驗，",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n就是應該在這種時候發揮吧。",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哦，",
        "unit_id": 190912,
        "voice": "vo_adv_5150063_006"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "挺有趣的嘛。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哎呀，真是忠於基礎。",
        "unit_id": 190912,
        "voice": "vo_adv_5150063_007"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "抓起來先放著會很方便呢。",
        "unit_id": 131711,
        "voice": "vo_adv_5150063_008"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯、涅比亞",
        "words": "就只是個捕蟲少年而已！",
        "unit_id": 190912,
        "voice": "vo_adv_5150063_009"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你是怎樣？",
        "unit_id": 131711,
        "voice": "vo_adv_5150063_010"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n暑假的小學生嗎？",
        "unit_id": 131711
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "格外適合也很令人惱火，",
        "unit_id": 190912,
        "voice": "vo_adv_5150063_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "而且還連蜂蜜都準備了，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "這已經是對嚮導小妖精的污辱了！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我是獨角仙嗎！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你還真的老是這個樣子耶！",
        "unit_id": 131711,
        "voice": "vo_adv_5150063_012"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我明白菲歐的辛苦了啊！",
        "unit_id": 190912,
        "voice": "vo_adv_5150063_013"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊。",
        "unit_id": 190912,
        "voice": "vo_adv_5150063_014"
    }
]