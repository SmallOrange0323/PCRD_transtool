[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在露娜之塔裡前進的{player}一行人"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n遭到一大群魔物包圍。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "被這麼多魔物包圍的話，",
        "unit_id": 105311,
        "voice": "vo_adv_7019003_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "無論是要前進還後退都沒辦法啊……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你們兩個",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不要離開我身邊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n少年麻煩照顧好莫妮卡。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可是。",
        "unit_id": 105311,
        "voice": "vo_adv_7019003_002"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就算是純閣下，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要獨自對付這麼多的敵人──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "喝啊啊啊！！",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_003"
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "…………不。",
        "unit_id": 105311,
        "voice": "vo_adv_7019003_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是我杞人憂天了啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "現在要",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "以閣下的安全為最優先。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然很不甘心，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但我們就退後吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這樣就結束了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唉。",
        "unit_id": 105311,
        "voice": "vo_adv_7019003_006"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我原本還想說",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這次一定要大顯身手的……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但事情沒有那麼順利啊。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……唔！？",
        "unit_id": 105311,
        "voice": "vo_adv_7019003_007"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下！",
        "unit_id": 105311,
        "voice": "vo_adv_7019003_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "小心後面！",
        "unit_id": 105311
    },
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……呼。",
        "unit_id": 105311,
        "voice": "vo_adv_7019003_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是好險。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要是我沒殺牠，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下就會被劈成兩半了！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡，",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳沒事吧！？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喔。",
        "unit_id": 105311,
        "voice": "vo_adv_7019003_011"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這點小傷不成問題。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "抱歉。",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "明明有我在現場……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "快別那麼說。",
        "unit_id": 105311,
        "voice": "vo_adv_7019003_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n或許在純閣下眼裡，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我看起來既嬌小又不可靠，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但我也是軍人。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "身為軍人，",
        "unit_id": 105311,
        "voice": "vo_adv_7019003_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然侍奉的國家不同，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但守護人民就是我們的職責。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "既然他平安無事，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這個傷口",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就是我的勳章！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡……",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "說得也是呢。",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "傑出的軍人。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……是我不明白那點呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，{player}一行人在用完餐後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n便各自小睡片刻。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n接著過了一段時間後──"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……喔。",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "少年，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你已經可以起來了嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n莫妮卡她──",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "…………",
        "unit_id": 105311,
        "voice": "vo_adv_7019003_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼喵呼喵。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "她應該是累了吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n那麼，為了不要吵醒她，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我們就小聲說話吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……說是這麼說，",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但要說什麼才好呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像這種時候，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我對根本不會閒聊，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n無聊透頂的自己",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "感到很失望。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我想想。",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡的睡臉……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像小孩子一樣天真無邪，很可愛呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且我剛才抱起她的時候，",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "她輕到讓我嚇了一跳。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n感覺一受到魔物攻擊",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就會被打飛。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以身體才會擅自做出反應，",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "認為自己必須要保護她才行。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n……我明明很清楚",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "她是大人，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且是很有本事的軍人。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "當然。",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看過她一路上的言行舉止和身手後，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "很難不明白。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "而且她也跟我一樣，",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n擁有想保護人民的堅定信念。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "明明是那樣，",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我這人卻……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我總會不由得盯著她",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "比茉莉更加嬌小的身體。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n順便",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "連手跟嘴巴都動了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這已經",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "像是反射動作一樣。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "都是我害",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "莫妮卡看起來很沮喪。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我該怎麼做才好……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵，",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "說得也是呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n要開口才能傳達給她。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我想找機會",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "好好跟她聊聊。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "畢竟她也是",
        "unit_id": 104711,
        "voice": "vo_adv_7019003_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n跟我有相同抱負的",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "「同志」。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "即使隔著堅固的頭盔，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}也能感覺到純正用溫柔的眼神"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看著莫妮卡可愛的睡臉。"
    }
]