[
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "接受了來自【new generations】的委託，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}等人正前往繆思小鎮，但是——"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看來修理馬車",
        "unit_id": 106012,
        "voice": "vo_adv_1125002_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還需要花一點時間呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "車輪突然就壞掉是怎樣啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "唯有這件事，我們是真的束手無策呢。",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_001"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "只希望能在今天之內出發就好了……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對方說他會努力試試看，",
        "unit_id": 106012,
        "voice": "vo_adv_1125002_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要我們等他。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要是靠幹勁就能解決",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那就不用那麼辛苦了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大叔就是這樣讓人受不了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "委託修理的人是我，我在這裡等就好了。",
        "unit_id": 106012,
        "voice": "vo_adv_1125002_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你就算留在這也只是礙事啦礙事！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然那麼閒，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就去把糧食給買齊吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "這樣的話，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_004"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "就我們兩人一起去吧。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "反正其他人也都在休息，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我們順便散散步。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……我說你啊，",
        "unit_id": 106012,
        "voice": "vo_adv_1125002_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "難道沒有自己一天到晚迷路的自覺嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我不准你一個人去散步，不准！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然你那麼閒的話，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n就和凜一起去把糧食給買齊吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽到了嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_006"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我是無所謂。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "畢竟大家也都出去了。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……話說回來，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "一天到晚迷路……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "你之前都發生些什麼事了……？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "哼嗯……",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_007"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "旅行的休息地，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "原來是這種感覺啊。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我是第一次來這種地方，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "感覺有點新鮮呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "食物好像也有很多種類，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_008"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "看來應該能把數量湊齊呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "希望會有能夠久放，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "又盡可能便宜的東西就好了。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……嗯？　",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_009"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "怎麼了嗎？{player}。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n怎麼突然停下腳步，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "難道有什麼在意的東西嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "唉唉唉唉唉……",
        "unit_id": 1411,
        "voice": "vo_adv_1125002_010"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "唉唉唉唉唉……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "啊啊，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_011"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "你是在意那個人啊。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "他好像一直在嘆氣，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "是發生什麼事了嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……去問問看他怎麼了吧。",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_012"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n我看你",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "也沒打算對他置之不理呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "那個，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_013"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "大叔。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n看你好像很煩惱的樣子，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "請問怎麼了嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "嗯？　",
        "unit_id": 1411,
        "voice": "vo_adv_1125002_014"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "喔，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "有點事啦。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "我只是在思考到底該拿這些東西怎麼辦才好。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "唉……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "……花？　",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_015"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "數量還滿多的呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "就是這樣啊……",
        "unit_id": 1411,
        "voice": "vo_adv_1125002_016"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "其實大叔我",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "是在做花朵批發的。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n我本來是打算從這裡進貨運往蘭德索爾。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "可是沒想到，",
        "unit_id": 1411,
        "voice": "vo_adv_1125002_017"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "我居然把訂單的數字搞錯一位數了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n這個數量我也沒辦法運到蘭德索爾，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "正在煩惱到底該怎麼辦……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "唉……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "贊成。",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_018"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "都聽完來龍去脈了，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "可沒辦法就這麼不管呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我說，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "大叔。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "如果你不介意的話，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我們可以幫你喔。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "能聽妳這麼說我是很開心，",
        "unit_id": 1411,
        "voice": "vo_adv_1125002_019"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "但妳要怎麼做？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "就算要現場販賣，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "數量這麼多也賣不完啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "是啊，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_020"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "也不可能一朵一朵去賣。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯～",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我看這裡好像有各個種類的花……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "對了，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_021"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "把大約每10朵綁在一起，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "做成花束試試看吧。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n那樣就能一次販賣了呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "有像是",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "紙之類的東西嗎？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "嗯，",
        "unit_id": 1411,
        "voice": "vo_adv_1125002_022"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "有包裝用的紙。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "不過，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "妳可以嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n小姐，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "就我看來，妳應該是冒險者吧？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "呵呵，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_023"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "總之，你先看著。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "——好了，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_024"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "大概就像這個樣子。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "感覺應該還不差吧？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "哪會差啊，",
        "unit_id": 1411,
        "voice": "vo_adv_1125002_025"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "根本是可以拿來當商品賣的等級了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "小姐，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "拜託妳教我怎麼做吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "我們分工！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_026"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "交給我吧。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "首先，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "先把葉子摘掉，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n選擇一朵花當做基準，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "再以那朵花為中心，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "環繞著它增加花朵——",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "歡迎光臨——！",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_027"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n要不要買一束花",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "作為旅行的伴手禮呢——！",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不好意思！　",
        "unit_id": 1,
        "voice": "vo_adv_1125002_028"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "請給我這束紅色的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "好的，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_029"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "收您500盧幣。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "謝謝惠顧！",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那個——",
        "unit_id": 1,
        "voice": "vo_adv_1125002_030"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我想送女朋友當禮物，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n請問有什麼推薦的花嗎……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "既然這樣，",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_031"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "要不要讓我以您女朋友的形象為題",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "現場製作呢？",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "那樣子",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "應該能做出一束非常適合您女朋友的花束喔。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "可以嗎！？　",
        "unit_id": 1,
        "voice": "vo_adv_1125002_032"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "務必麻煩妳了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "哎呀～",
        "unit_id": 1411,
        "voice": "vo_adv_1125002_033"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "託了那女孩的福，花越賣越好了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "只是，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "人聚集得太多，開始忙起來了……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "原來你們在這種地方啊！？　",
        "unit_id": 106012,
        "voice": "vo_adv_1125002_034"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "總算是找到了！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說你，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是想遊蕩到什麼時候啊！！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "馬車馬上就要修理好了，",
        "unit_id": 106012,
        "voice": "vo_adv_1125002_035"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "大家也早就都回來了啊！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我看你糧食也都沒買，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你剛才到底都在——",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啥！？　",
        "unit_id": 106012,
        "voice": "vo_adv_1125002_036"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為什麼我——",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "哦哦，",
        "unit_id": 1411,
        "voice": "vo_adv_1125002_037"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "你有熟人願意來幫忙啊？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "那幫忙把放在那裡的花束拿過來吧！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106012,
        "voice": "vo_adv_1125002_038"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別在那邊自說自話——",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "那邊的店員小姐——！　",
        "unit_id": 1,
        "voice": "vo_adv_1125002_039"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "請給我一束這個——！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽我說話啊——！！！",
        "unit_id": 106012,
        "voice": "vo_adv_1125002_040"
    },
    {
        "type": "background",
        "background": "500131"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "哎呀～",
        "unit_id": 1411,
        "voice": "vo_adv_1125002_041"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "多虧有你們，幫大忙了！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "剩下的數量要帶到蘭德索爾去也沒問題了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "能聽你這麼說真是太好了。",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_042"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "花要是枯掉",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "就太可惜了呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "這個，",
        "unit_id": 1411,
        "voice": "vo_adv_1125002_043"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "是你們今天幫我忙的謝禮。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n請把這個當成打工的酬勞收下來吧。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "那麼，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "我差不多該走了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "今天非常謝謝你們！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "到蘭德索爾也要加油喔！",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_044"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "比想像中花了更多時間呢，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "抱歉。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就是啊，",
        "unit_id": 106012,
        "voice": "vo_adv_1125002_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "本來應該可以更早出發的說。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "收到的錢可以用來當做馬車的修理費用，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n或許也可以說是剛剛好呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那我",
        "unit_id": 106012,
        "voice": "vo_adv_1125002_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就先去支付修理費用了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n你們",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也趕快回馬車來喔。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "剛才謝謝你幫忙。",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_047"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "總覺得，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我總是受到你們的幫助呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯……",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_048"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "其實我自己也不是很清楚。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我也沒有在蘭德索爾的花店工作過啊。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "該怎麼說才好呢？",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_049"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "應該說是不知不覺就會做了吧……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "隱隱約約知道要怎麼做花束",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "和怎麼搭配花朵，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "大概是這種感覺。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "很奇怪對吧？",
        "unit_id": 112511,
        "voice": "vo_adv_1125002_050"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我平常明明都過著和花無緣的生活呢。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "可是，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "總覺得……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "身體卻很不可思議地有股熟悉的感覺。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "邊這麼說著邊盯著遠方的凜，\n露出了彷彿懷念起什麼的溫柔表情——"
    }
]