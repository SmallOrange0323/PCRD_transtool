[
    {
        "type": "background",
        "background": "500110"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在咲戀育幼院休息時，\n安走了過來。"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "啊、{player}！",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_000"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n吶吶，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "你現在有沒有聽到一陣很美的聲音？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗓音純淨清澈，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_001"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "沁入心底深處的動人旋律……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那個",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "是歌聲對吧？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "不曉得",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "是誰在唱歌呢……？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "咦，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_002"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "是嗎！？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n原來可可蘿",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "這麼會唱歌嗎……！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "啊……",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_003"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "有了。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我想到一個好主意了！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n我",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "去一下可可蘿那裡唷！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "欸，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_004"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "{player}也要一起來嗎？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "欸嘿嘿，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "謝謝。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那我們走吧！",
        "unit_id": 109211
    },
    {
        "type": "background",
        "background": "500351"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有安小姐也來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請問有什麼事嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "可可蘿，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_006"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "妳的歌聲相當優美呢！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我被妳感動到了！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦……",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝、",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您的讚美。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被稱讚了有點害羞，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過在下很開心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "超級超級好聽～！",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_008"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那麼優美的旋律，我還是第一次聽到！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "可可蘿，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_009"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "妳喜歡唱歌嗎？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯呢。",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那當然",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是因為喜歡",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以才會唱歌……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由於在下是精靈族，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這大概也是從小養成的習慣吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "原來如此，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_012"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "精靈族……！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我也有一位",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_013"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "名叫漢娜的精靈族朋友，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "她也和妳一樣非常擅長音樂……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "阿斯特賴亞",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "看來也是一樣的呢。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您所在的世界",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也同樣存在著精靈族呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "順帶一提，",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "特別是",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下的村子裡，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n有著各式各樣",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "流傳千古的歌曲，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n從遙遠的上古時代便不斷地歌詠傳承至今。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "哇……",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_016"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "這樣呀，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "阿斯特賴亞的歌曲……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "……吶，可可蘿。",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_017"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n方便的話，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "希望妳也能教我一些歌曲。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "歌曲",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗎？　",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "由在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "教安小姐……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗯。",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_019"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "不行嗎……？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然也不是不行……",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是為何",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您突然想學呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "因為古蕾婭",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_021"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "很喜歡音樂啊。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "要是我記住這個世界的歌曲，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我想她應該會很高興。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "然後，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_022"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "回到原本的世界後，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "如果能和古蕾婭一起\n邊彈奏鋼琴邊唱著這裡的歌，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我想那一定會很開心……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n欸嘿嘿。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此……",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那真是個美好的想法呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這件事就交給可可蘿。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如果是在下知道的歌，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下非常樂意協助您。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "謝謝妳，可可蘿！",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_025"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "好，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我要努力學～！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "呵呵，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_026"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那當然！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "古蕾婭對我來說，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "是個很重要的存在唷。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "是嗎？　",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_027"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "呵呵，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "連{player}也看得出來\n這種事嗎，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "總覺得有點開心呢！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "……之前，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_028"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "學校裡的同學們",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "認為『公主和我們不同』，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n這我之前提過",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "對吧？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "從那之後",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_029"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我漸漸開始感受到和大家的距離感。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "大家還是",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "像往常一樣對我很好……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "但聽到『好厲害』",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "或是『不愧是公主』這種話時，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "總覺得彼此間有著隔閡。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "但是，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_030"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "就在之後的某一天……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n我一個人在校園裡閒晃時，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "聽到了音樂聲。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "是鋼琴聲。",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_031"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "一道非常溫柔……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "卻又",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "摻了些許揪心落寞的……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "鋼琴聲。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "因為太好奇那陣鋼琴聲",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_032"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "究竟是從哪裡傳來的，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n我尋著聲音，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "上到了音樂塔……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "那就是，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_033"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我和",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "古蕾婭的相遇。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "總覺得。",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就好像是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "命運般的邂逅。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "呵呵，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_035"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "是嗎？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "命運嗎……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "也許",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "真的是那樣唷。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我啊，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_036"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "見到她",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "的那一瞬間，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "就覺得無論如何都要當她的朋友！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "　所以……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "總是跑去找她聊天，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "一起度過兩人時光。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "不久後，古蕾婭也",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_037"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "開始慢慢地",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "願意敞開心扉！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此。",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "兩位的關係從此，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變得像現在一樣要好了呢。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "欸嘿嘿……",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_039"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "對啊。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n雖然古蕾婭",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "不是一個愛說話的人，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "但是她心思細膩又很溫柔……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "是一個非常為朋友著想的好孩子唷。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我每次",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_040"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "和古蕾婭在一起時，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "總是不由自主地想要依賴她。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我平時",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "都告訴自己要成為一個可靠的人。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "但待在她身邊",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_041"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "讓我感到安心……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "一不小心",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "就鬆懈下來了。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "古蕾婭總是",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_042"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "一次又一次地支持著我……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n所以，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "如果有任何我能夠為古蕾婭做的事，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "無論是什麼事我都願意去做。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我想對她說謝謝妳一直陪伴在我身旁，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_043"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "還有",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "非常感謝……",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我想要將這份心意傳達給她。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原來如此。",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n……安小姐對古蕾婭小姐的那份心意，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "深深地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "打動了可可蘿的心。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "為此，",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_045"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下有個拙見……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不只是學會歌曲，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "直接在古蕾婭小姐面前獻唱給她聽，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n作為送給她的禮物，您覺得如何呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "欸……",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_046"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "當作禮物",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "唱給古蕾婭聽？",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下所學的",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "精靈族之歌中，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n正好有一首",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "表達感謝與親愛之情的歌曲。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果您願意的話……",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "安小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n要不要",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "試著將這首歌學起來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "獻唱給古蕾婭小姐呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "可可蘿……！",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_049"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗯，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_050"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我要學！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "想要將那首歌獻給古蕾婭……！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下明白了。",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_051"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "除了歌曲以外，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下就先從唱歌方式開始教起。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "好的！",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_052"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n可可蘿老師，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "一切就拜託您了！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵，",
        "unit_id": 105913,
        "voice": "vo_adv_1092004_053"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是可可蘿老師。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "啊，",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_054"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "對了，{player}。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "聽完後我也會試著唱唱看，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n到時候你也仔～細地聽一下唷！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "有聽到",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_055"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "任何不好的地方，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "或是需要改進的地方，",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "儘管糾正我沒關係！",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "這可是",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_056"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "要唱給古蕾婭的重要歌曲。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "\n",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "我想要把這首歌唱好。",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "所以就",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_057"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "拜託你囉，{player}！",
        "unit_id": 109211
    },
    {
        "type": "background",
        "background": "500352"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然後，就在某一天――"
    },
    {
        "type": "still",
        "still": "109200401"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "沒想到露竟然",
        "unit_id": 109411,
        "voice": "vo_adv_1092004_058"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "能夠做出這麼豐盛的料理。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "\n嚇了我一大跳……",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "對吧，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "安。",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "……安？　",
        "unit_id": 109411,
        "voice": "vo_adv_1092004_059"
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "妳一直低著頭，",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "古蕾婭",
        "words": "怎麼了嗎？",
        "unit_id": 109411
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "咦！？　",
        "unit_id": 109211,
        "voice": "vo_adv_1092004_060"
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "啊、",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "呃、",
        "unit_id": 109211
    },
    {
        "type": "dialogue",
        "name": "安",
        "words": "嗯、",
        "unit_id": 109211
    },
    {
