        "words": "全力登山！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好耶，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_068"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "目標是山頂！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n釘入岩釘吧！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n斷崖絕壁根本不算什麼啦～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "接下來要做的就是剛剛說的那些的假想訓練。",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_069"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "很遺憾，太陽已經快下山了呢，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "今天只能在這裡望梅止渴，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "進行虛擬登山了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "順帶一提琪愛兒，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_070"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "應該說虛擬的琪愛兒，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n在經過數十天嚴酷的冒險之旅後，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就在剛才",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "稱霸山頂了呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "虛擬學長的情況如何？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哦哦，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_071"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "恭喜你！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "克服了艱難困苦，在山頂等著我們的是",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "天空的居民！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n她是讓人無法想像世上竟有如此存在、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "簡直該要說是美麗化身的女神！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這麼想的時候，哎呀，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_072"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "原來是學長搞錯了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "仔細一看，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "原來是像女神一樣可愛的琪愛兒！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，把我誤認成女神這種事，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒身上常常發生呢！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊啊，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_073"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的耶！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n{player}學長不小心腳滑了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n救生索也斷了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就這樣頭下腳上地掉進了遙遠的黑暗深處！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長！　",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_074"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長～！！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過沒問題，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_075"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為是虛擬的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n每次玩都有3條命。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "來，從關卡開頭",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "重新來過！",
        "unit_id": 110911
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "最終幕，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_076"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "全力反省大會～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "蹦♪　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "蹦♪　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "蹦蹦蹦蹦～♪",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那～",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_077"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就是這樣，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n今天過了充滿娛樂的一天。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n您覺得如何呢，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "作為來賓的{player}學長？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_078"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "你說什麼？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n你累了，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "可是感覺累得很暢快？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n一結束，一切就像令人懷念的青春回憶？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_079"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對，你是沒那樣說啦。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不好意思，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我有點過度解讀你說的話了呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "咦，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_080"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "真的假的……？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不好意思，你這樣連琪愛兒都有點嚇到了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "今天行程真的塞太滿了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我已經很滿足了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_081"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "在這裡不說道歉，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是琪愛兒的作風。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "因為琪愛兒玩得很開心，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_082"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "學長也很開心吧？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "欸嘿嘿，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_083"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "太好了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n真的",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "非常謝謝你今天陪了我一整天。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "下次我會安排比較小型的旅行的。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然琪愛兒",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_084"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一直想要了解、",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n想去體驗",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這世界上各種開心的事——",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "但今天，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_085"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我有一個重大發現。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "歸根究底，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_086"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只要和開心的人在一起，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不論要去哪裡，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不論要做什麼，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "都一定會很開心呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "琪愛兒開心地"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n說著十分理所當然的事情。"
    }
]