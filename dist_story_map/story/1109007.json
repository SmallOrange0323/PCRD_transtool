[
    {
        "type": "background",
        "background": "500080"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "某個假日，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n琪愛兒一早就閒得發慌，她潛入了聖德蕾莎女子學院——"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不對，是潛入了月光學院。"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "早安～！",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "像這樣，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_001"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "即使是不同學校的學生，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n只要表現得光明正大，就意外地不會被懷疑呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "雖然說，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_002"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "本來就因為是假日，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "只有社團或補習的人會過來，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n所以來學校的人數本身也比較少就是了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_003"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "話說回來，今天沒有認識的人在喵～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "鈴奈和美咲，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "她們的課業都是毀滅性等級的糟糕，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n還以為她們一定會要補習的……",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，算了。",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_004"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n沒有朋友的話，就去交朋友就好了。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "早安安～！　",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_005"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我可以坐這裡嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "啊，",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_006"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "早安啊……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "呃妳誰啊？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我是琪愛兒哦，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "切嚕～☆",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "咦，",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_008"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "不認識耶。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "不過很有趣就算了。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "切嚕～☆",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "那件制服……",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_009"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "是其他學校的吧。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "妳是偷潛進來接受補習的嗎？　",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "就找個位子坐吧？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我坐我坐，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_010"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "謝謝切嚕～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "討厭，真是的，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我真愛月學這種大咧咧的感覺！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我們學校是名校，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所以很死板呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "咦，",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_012"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "琪愛兒是哪間學校的？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "聖德蕾莎女子學院的～",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_013"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "德蕾女？",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_014"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n那不是一流的千金學校嗎！",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n不會吧，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "琪愛兒是千金小姐嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊～",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_015"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "如果單就家裡的資產來比的話，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "算是吧。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "咦咦，",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_016"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "我還以為千金小姐應該是……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "更閃閃發亮，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "或者說",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "更優雅優雅",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "的感覺，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "或是一直說",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "是呢是呢的生物……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_017"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那種人很多哦。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒家從爸爸那代突然暴富的，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n不過其他人大都是傳統名門世家的掌上明珠呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "不過，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_018"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "就算是那些會說是呢的女孩，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n和她們熟了之後，會意外地發現大家的個性很不一樣，很有趣！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "其中",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_019"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "也有像美衣子她們這種，從中學開始就在都是女性的環境中",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "毫無顧慮地學習成長，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "升上高中之後，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n就完全變得很堅強的特殊類型。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊啊，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_020"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "還有！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n學姐當中，好像也有不良少女",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "和繭居族的樣子。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "是怎樣也太好笑了吧，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "啊哈，超～想見見她們。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "是喔～",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_021"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "好像很有趣的樣子呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "嗯，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_022"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "很有趣喔！　",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "德蕾女超棒！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "……咦？",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_023"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n那琪愛兒，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "妳今天為什麼來我們學校？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n不是過來辦轉學手續",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "還是來勘察的嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "沒有哦～",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_024"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n只是一時興起。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "俗稱冒險心態。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n咦，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "散步一般不是都這樣嗎？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "啊，",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_025"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "原來妳現在是在散步啊……",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "對。",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_026"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n今天難得休假，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n我打算一整天切嚕地到各種地方去逛逛。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "這樣啊。",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_027"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "一個人嗎？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "畢竟是要",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_028"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "一整天切嚕地到各種地方去逛逛嘛。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n雖然和朋友一起會比較有趣，",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n但就不太好意思帶著她們到處跑了呢。",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "事情就是這樣，",
        "unit_id": 110911,
        "voice": "vo_adv_1109007_029"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "琪愛兒差不多該走了！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "下次見～",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "掰切嚕～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "咦？　",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_030"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "奇怪，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "那補習呢——",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "——",
        "unit_id": 1211,
        "voice": "vo_adv_1109007_031"
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "她走掉了。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "還真是有趣的人呢，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女學生",
        "words": "呵呵。",
        "unit_id": 1211
    },
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哇～",
        "unit_id": 110911,
