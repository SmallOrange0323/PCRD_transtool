        "voice": "vo_adv_4010239_000"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "感謝你今天",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "陪我一起過生日。",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "嗯。",
        "unit_id": 126531,
        "voice": "vo_adv_4010239_001"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "我早就想跟你一起來逛逛了。",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "聽說這裡有許多饒富趣味的點心，",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "跟綿滑的生奶油",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n還有香濃的奶油都大不相同……",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "哎呀……",
        "unit_id": 126531,
        "voice": "vo_adv_4010239_002"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "真的有好多不同種類的點心呢。",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "這個是……",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "什麼東西啊？",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n紅通通的",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "乾貨，",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "好幾個串成一串……",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "烏賊……？",
        "unit_id": 126531,
        "voice": "vo_adv_4010239_003"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "跟我所知道的烏賊",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "很不一樣呢。",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n……咦，",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "那這個呢？",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "黃色",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "圓圓的三顆……",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "口香糖嗎？",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n其中摻雜了一顆超級酸的？",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "竟、",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "竟然還有那樣的考驗……",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "……騎士。",
        "unit_id": 126531,
        "voice": "vo_adv_4010239_004"
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n請你來選擇",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "我的命運吧。",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "\n",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "無論結果如何，",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "我都會欣然接受。",
        "unit_id": 126531
    },
    {
        "type": "dialogue",
        "name": "耶兒",
        "words": "那麼──",
