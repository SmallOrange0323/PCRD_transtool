[
    {
        "type": "background",
        "background": "500141"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……一分鐘，",
        "unit_id": 106013,
        "voice": "vo_adv_2008014_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "已經過去了。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "做最後的確認。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們並沒有投降的打算，",
        "unit_id": 106013,
        "voice": "vo_adv_2008014_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我如此判斷可以嗎？",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在的話，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "仰賴陛下的恩澤，至少能留下你們所有人的性命喔。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "為了讓目前處於昏睡狀態的陛下甦醒，",
        "unit_id": 106013,
        "voice": "vo_adv_2008014_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n大量的魔力與生命力是不可或缺的。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把所有人都捉起來，",
        "unit_id": 106013,
        "voice": "vo_adv_2008014_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接上魔法裝置，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n成為讓陛下復活的苗床吧。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留……",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底發生了什麼事？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好久都沒看到妳的蹤影，",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們大家，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都非常的擔心妳唷。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "為什麼要這樣，像壞蛋、像敵人一樣……",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n威脅我們，像是把我們當成害蟲一樣對待呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們應該是被友情、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "被重要的牽絆綁在一起的朋友對吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吶、小凱留，",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個傲嬌又可愛的小凱留……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳剛剛說的全部，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "都像平常一樣只是怕羞對吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實妳還是打從心底，",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "替我們每一個人著想的對吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……",
        "unit_id": 106013,
        "voice": "vo_adv_2008014_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "看來是沒有想要投降的意願呢。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那麼就如同說好的，",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "將妳們所有人全數剿滅。",
        "unit_id": 106013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "【王宮騎士團】，全員進軍！",
        "unit_id": 106013,
        "voice": "vo_adv_2008014_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物唷，將那群人吞食殆盡！",
        "unit_id": 106013,
        "voice": "vo_adv_2008014_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……小凱留！",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "吶、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "全都是騙人的",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是開玩笑的吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請住手……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n現在的凱留小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很明顯有哪裡怪怪的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那並非是在下等人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所孰悉的凱留小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚……",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這麼說來，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像跟平常有一點不一樣？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那是什麼呢？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個詭異的面具？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "難道說……",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是因為那個面具的關係，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留才會變得這麼奇怪嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "該不會是什麼洗腦裝置？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定是這樣。",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n因為小凱留，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n才不是會說出這種話的壞孩子啊。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不管我說出了怎麼樣的傻話，",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只會發一點小脾氣就原諒我的對吧？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n直到現在，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一直都是！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們是會一起打鬧、",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一起歡笑，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "相隨至今的好朋友啊！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是那個假面，",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_019"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是因為洗腦裝置的關係……",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n小凱留是被人給操縱了！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大概，",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "是被稱呼為『陛下』的那個人！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我們所有人的敵人！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "尤絲蒂亞娜。",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_021"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不對，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "他本名叫做千里真那來著……？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n不僅是我的名字與身分，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n就連我的朋友都要奪走嗎！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底有什麼權利、",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_022"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有什麼理由，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可以做出這樣的壞事啊……！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐！？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不行呀，那樣衝出去！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "周圍到處都是魔物和士兵，",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n隻身闖進去",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "被包圍起來就糟了呀！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可是，",
        "unit_id": 105811,
        "voice": "vo_adv_2008014_025"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果不把那個假面拆下來的話！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n如果不把小凱留給奪回來的話、",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不去救她的話……！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……不行呀，",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您已經失去理性了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n完全不顧周遭的樣子，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣下去真的會死的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n快阻止貪吃佩可小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然後找個地方逃走……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "危險！",
        "unit_id": 104911,
        "voice": "vo_adv_2008014_028"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "現在可沒有擔心別人的餘裕了唷，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n敵人全軍都攻過來了……！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "璃乃！",
        "unit_id": 104911,
        "voice": "vo_adv_2008014_029"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n死角被遠距離攻擊給瞄準的話就躲不掉了，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n所以優先把射手和魔法師給打倒！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好，",
        "unit_id": 101111,
        "voice": "vo_adv_2008014_030"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好的！",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "嗚嗚，",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "但是這數量再怎樣也都除不盡唷……！？",
        "unit_id": 101111
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "歐～拉！",
        "unit_id": 190711,
        "voice": "vo_adv_2008014_031"
    },
    {
        "type": "dialogue",
        "name": "大吾",
        "words": "\n有種就一個一個正面上啊，這群雜魚！",
        "unit_id": 190711
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "毫無計畫的戰鬥是不行的，",
        "unit_id": 191011,
        "voice": "vo_adv_2008014_032"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "大吾！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n得聚集眾人且相鄰以背，",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n互相顧及死角",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "一面單點突破，除此之外別無他法了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真受不了。",
        "unit_id": 107111,
        "voice": "vo_adv_2008014_033"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "簡直就像快被碾爛的蘋果一樣呢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "儘管我樂於戰鬥，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但單方面被蹂躪可讓人開心不起來呀。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "大家，",
        "unit_id": 106112,
        "voice": "vo_adv_2008014_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快過來這裡！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我會召喚出天樓霸斷劍，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "把敵人的陣型給破壞！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n然後我們再從那裡逃脫，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "快點！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "各位，",
        "unit_id": 107311,
        "voice": "vo_adv_2008014_035"
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "盡可能待在我身邊！",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "\n最糟糕的情況，",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "就算硬來我也會用空間跳越",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "拉基拉基",
        "words": "讓大家逃出這裡！",
        "unit_id": 107311
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你會死的！笨蛋！",
        "unit_id": 106112,
        "voice": "vo_adv_2008014_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n至少也得稍微遠離敵人，",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n再挑個空間魔法陷阱較微弱的地方才行！",
        "unit_id": 106112
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍、",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "稍等一下！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n貪吃佩可小姐她已經衝出去了，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若不將她帶回來的話！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不能只有",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下等人逃離而已！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "……最糟糕的情況，",
        "unit_id": 107111,
        "voice": "vo_adv_2008014_039"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "也得做好把她丟下的打算。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n僅管殘忍，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但總比全滅還好。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "怎麼可以……！",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_040"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不能接受！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這樣的吧，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "……主人？",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_041"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您究竟在看哪裡呢？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "討厭討厭討厭，",
        "unit_id": 103611,
        "voice": "vo_adv_2008014_042"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不要靠近我們！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n不要過來呀！",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 100411,
        "voice": "vo_adv_2008014_043"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥在那裡！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "幫幫我啊～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "嗚哇呀呀呀！",
        "unit_id": 102011,
        "voice": "vo_adv_2008014_044"
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n不管再怎麼逃魔物先生都會追過來呀，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "好可怕～！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "\n救命呀，",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "美美",
        "words": "哥哥！",
        "unit_id": 102011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "……那群孩子究竟是？",
        "unit_id": 191011,
        "voice": "vo_adv_2008014_045"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "為什麼",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "會在這種地方？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "難不成是敵人所設下的陷阱，",
        "unit_id": 191011,
        "voice": "vo_adv_2008014_046"
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "倒也不太像……",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n是偶然誤闖戰場的孩子們嗎？",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "\n",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "真軌",
        "words": "這也太不巧了！",
        "unit_id": 191011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯？",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_047"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您認識那些孩子們嗎？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【小小甜心】……？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒錯。",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_048"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可不能見死不救……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n幸好",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "距離此處沒有很遠，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n是只要將眼前少數魔物擊倒就能抵達的距離！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人！",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_049"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "會對魔物發動猛烈的攻勢，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請於魔物受到在下的阻撓時，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "趁機將孩子們給救出！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘿呀……！",
        "unit_id": 105911,
        "voice": "vo_adv_2008014_050"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n偉大的愛梅斯大人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請您賜予可可蘿",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您那崇高的庇護！",
        "unit_id": 105911
    }
]