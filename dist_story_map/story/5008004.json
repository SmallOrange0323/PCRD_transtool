[
    {
        "type": "background",
        "background": "500240"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "杏奈與{player}正在進行採掘作業，\n但因為沒有休息不停工作，體力早就來到了極限。"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哈，",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哈，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哈啊……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n還沒到",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "午休時間嗎……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "乾脆放棄用手挖，",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_001"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n直接用魔法破壞不就好了嗎……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "的確，",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "只要有我疾風之冥姬的一擊，根本小事一樁。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n擁有強大的魔力還真令人困擾啊，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵、呵、呵……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "唉。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特也這麼想嗎？　",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那麼，馬上來――",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不對，等一下。",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "如果在這裡施放魔法的話，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n似乎也會把其他工人一起給炸飛的。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還是算了吧……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "進度如何？",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_005"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "是的，",
        "unit_id": 1111,
        "voice": "vo_adv_5008004_006"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "雖然停滯了一段時間，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "但最近幾天都有達成目標。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "很好。",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_007"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我這裡也得到資料了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "這下總算能開始解讀了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "那真是太好了！　",
        "unit_id": 1111,
        "voice": "vo_adv_5008004_008"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "那麼，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "裡面請。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "……吉格魯特。",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_009"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "你看那邊。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n一看就很了不起的傢伙，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "和監督人員往洞窟深處走去了。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們跟在後面吧。",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_010"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這是調查的絕佳機會。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "當鄰近村子的勞動力用盡的時候，一時間我還在想該怎麼辦……",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_011"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "看來在蘭德索爾發出的徵人廣告，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "十分有效果呢。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "是。",
        "unit_id": 1111,
        "voice": "vo_adv_5008004_012"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "一大群的蠢蛋，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "被這傳單上的內容吸引而來了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "附三餐、",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_013"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "住宿設施完善，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n有前輩們親切細心的指導，\n是個大受好評如在家般舒適的陽光職場――",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哈哈，",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_014"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "不管看幾次都覺得",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "這真是我的傑作！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "沒想到會被這種東西欺騙，跑到這種偏僻的深山裡來，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n果然平民的思考就是讓人無法理解！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "也來了不少",
        "unit_id": 1111,
        "voice": "vo_adv_5008004_015"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "像是通緝犯，\n或是另有隱情的人。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "嗯。",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_016"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "看來沒有錢就無法生存的現實，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n是不分貴賤的啊。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "您說得沒錯。",
        "unit_id": 1111,
        "voice": "vo_adv_5008004_017"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "\n畢竟沒有錢要生活下去是很艱辛的。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "而且，",
        "unit_id": 1111,
        "voice": "vo_adv_5008004_018"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "這張傳單的內容，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "並沒有任何一字一句是錯的。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "我們供應了食物，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "也確實提供了睡眠的地方。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "哈哈哈！　",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_019"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "讓人吃從村子裡搶來的食物，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n和睡在如家畜小屋般的乾草床上，你還真能說啊！",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "這麼說真是嚴格呢，",
        "unit_id": 1111,
        "voice": "vo_adv_5008004_020"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "哈哈哈……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "他、",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_021"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "他說什麼！？　",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們剛才吃的東西，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n居然是從別人那裡搶來的食物……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "可惡的傢伙，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "居然做這種壞事！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "那麼……",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_022"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "採掘速度也再次上軌道了，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n我的計畫也終於要大功告成了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "只要以我帶回來的這份文獻為基礎解讀古文書的話，",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_023"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我就能逼近神……",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "不對，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我就能得到連神都能超越的力量。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "如此一來，",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_024"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "就算要推翻蘭德索爾的王政，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "也是輕而易舉。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "然後，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我將成為新的王。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "推翻王政？　",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_025"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "成為新的王……？",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這些傢伙",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "居然有這種企圖。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "等那計畫成功之時，",
        "unit_id": 1111,
        "voice": "vo_adv_5008004_026"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "請務必也分些好處給我……",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我明白。",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_027"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你那個拐騙平民的才能，",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "就讓你在我的新政府擔任要角好好發揮吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "哈哈！　",
        "unit_id": 1111,
        "voice": "vo_adv_5008004_028"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "這是我的榮幸！",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "剛才的話你聽到了嗎？",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_029"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "吉格魯特。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我對政治沒有興趣。",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_030"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "雖然沒有興趣，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但我絕對不接受有那種國王的國家。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "因為工作過頭身體好沉重，",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_031"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "但我可不能在這裡退縮……！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "走吧！　",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_032"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我要在這裡粉碎那些傢伙的野心！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n賭上「熾炎戰鬼煉獄血盟暗黑團」之名！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "那麼，",
        "unit_id": 2511,
        "voice": "vo_adv_5008004_033"
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "我要開始解讀古文書了。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "\n",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "你就",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "貴族",
        "words": "盡快挖掘那個吧。",
        "unit_id": 2511
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "到此為止了，這些惡徒！！",
        "unit_id": 100911,
        "voice": "vo_adv_5008004_034"
    },
    {
        "type": "dialogue",
        "name": "現場監督",
        "words": "你們是，",
