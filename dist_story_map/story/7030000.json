    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……露娜之塔。",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_000"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這是我第一次",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "見到實物……",
        "unit_id": 129011
    },
    {
        "type": "background",
        "background": "510500"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──最後的七冠‧幻境龍后。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了奪回被她擄走的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n厄莉絲跟美空一起介入現實世界，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "總算成功阻攔。"
    },
    {
        "type": "background",
        "background": "510490"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「其實……",
        "unit_id": 129015,
        "voice": "vo_adv_7030000_001"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我也想，",
        "unit_id": 129015
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n在『這邊』碰觸騎士先生……」",
        "unit_id": 129015
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "「但是很遺憾，",
        "unit_id": 129015,
        "voice": "vo_adv_7030000_002"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我沒有時間尋找可行的方法。",
        "unit_id": 129015
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我們要快點回去，",
        "unit_id": 129015
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "把『封鎖模式』的程式藏起來。」",
        "unit_id": 129015
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在迷宮女王等人的認可下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "厄莉絲利用管理者權限，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n阻止了50億人的強制潛入，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n並為了守住權限程式而再次潛入LoA……"
    },
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "儘管",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_003"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "暫且脫離困境……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "幻境龍后的力量，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "卻超乎我的想像。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "事態依舊是刻不容緩……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "最適合隱藏程式的場所──",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n沒有時間來慢慢考慮。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可是",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "又不能隨便找個地方放。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這種時候，",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "如果騎士先生在的話……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這股氣息是……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "露娜之塔──",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n居然在不知不覺間來到了這裡。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……不過，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "這樣的話。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "露娜之塔",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_007"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "內部，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "或許是個適合隱藏程式的地方。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "問題是……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒有騎士先生，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "就進不了塔內……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "可是",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_008"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "去找他的話，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一定會被幻境龍后發現。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n怎麼辦……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "咦……",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n你怎麼會在這裡……？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "唔……",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_010"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎、",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n你是為了我，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "特地……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "過來的嗎？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n因為擔心？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "怎麼辦。",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "想著我的事情……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n不是為了別人，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "而是為了我……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "趕到這裡……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "啊啊……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "感覺",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "好開心……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "那麼，",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_012"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我會來到這裡……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也一定不是",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "單純的偶然。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n兩人一起前往這座塔，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "一定有什麼意義才對。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "命運，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "雖然不想說這種非理性的東西……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "但是，",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_013"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "沒關係。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "因為這是……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我想著騎士先生，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n愛著騎士先生的程度……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "強到足以顛覆邏輯的證明，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "所以……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "拜託你，",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生……",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "能不能",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "助我一臂之力？",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "為了隱藏「封鎖模式」的程式，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我想進入露娜之塔。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "為此──",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "嗯……",
        "unit_id": 129011,
        "voice": "vo_adv_7030000_015"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "謝謝你，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "騎士先生。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……我們一起，",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "去冒險吧。",
        "unit_id": 129011
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "兩人朝著露娜之塔"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "邁出步伐。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n而厄莉絲的臉上"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "流露出藏不住的興奮……"
    }
]