[
    {
        "type": "background",
        "background": "501440"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}接受招待，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到埃拉所在的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "複製品世界觀光。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n昨晚把埃拉送回去之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "就回到自己的旅店就寢──"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……啊哈哈哈哈！",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_000"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "沒關係，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "別在意。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "老婆婆，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那個行李很重吧？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n妳家在哪？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我來幫妳搬。",
        "unit_id": 135511
    },
    {
        "type": "background",
        "background": "502060"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "埃拉大人，",
        "unit_id": 1,
        "voice": "vo_adv_1355002_001"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "謝謝妳啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n多虧有妳，真是太好了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不用在意啦！",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_002"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "有困難的時候就要互相幫助幫助，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對吧。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過，",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_003"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這邊的路還沒有鋪設完，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "即使慢慢來也好，我想一步步推進整備工作呢～",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "口會不會渴？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要喝水嗎？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哎呀？",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_004"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "在那裡的是……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "早安──！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n騎士先生，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "怎麼啦，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你怎會在這裡？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哎呀呀，",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_005"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我的聲音有那麼大嗎？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "抱歉啊，吵醒你了～！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就當作是我提供的叫醒服務，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "原諒我吧。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊，",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_006"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對了對了！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n謝謝你昨天送我回家！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "本來想說等等也要去騎士先生那邊露臉的。",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_007"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "因為我想跟你道謝，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嘿嘿嘿。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……啊，",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_008"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "昨天的事是祕密喔。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "別看我這樣，我可是一直都在扮演「可靠的大姐姐」呢。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "雖然被騎士先生看到自己丟臉的地方了……",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_009"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗚咕……",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_010"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好的～",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不可沉溺於麥酒之海……",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是吧。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我深刻體會到了，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "真的。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對了，",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_011"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "等巡邏結束，我再為你導覽！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要在大街上晃晃也可以，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "或是換個路線",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "去綠洲也很推薦。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你先想想要看哪裡──",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "找到了！",
        "unit_id": 1,
        "voice": "vo_adv_1355002_012"
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "埃、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "埃拉大人……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "\n大事不好了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯？",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_013"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "怎麼了？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這麼慌慌張張的。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "沙、",
        "unit_id": 1,
        "voice": "vo_adv_1355002_014"
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "沙漠裡",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "有魔物襲擊商隊……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "\n我們想說要找人求救……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "只有我總算是",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "逃到了這裡……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "\n大家",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "都動彈不得……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "────！！",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_015"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "知道了，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我馬上過去！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n能麻煩你帶我到附近嗎？",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n大家都先準備好治療傷患的用品！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "抱歉，",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_016"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生。",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n明明說好要為你帶路的──",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生……",
        "unit_id": 135511,
        "voice": "vo_adv_1355002_017"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "謝",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "謝你，",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "真是幫大忙了！",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135511
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那就跟我一起來吧！",
        "unit_id": 135511
    },
    {
        "type": "background",
        "background": "501530"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生！！",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_018"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "喝啊啊啊啊啊啊！！",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_019"
    },
    {
        "type": "background",
        "background": "501530"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1614
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這下",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_020"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "可見範圍內的魔物都打倒了……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大家",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "有沒有受傷！？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "得、",
        "unit_id": 1,
        "voice": "vo_adv_1355002_021"
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "得救了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "\n埃拉大人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "謝謝妳！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "\n我還以為",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "真的要完了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好了好了，",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_022"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "笑一個！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "有困難的時候就是要互相幫助幫助，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對吧！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_023"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……唔。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊哈哈……",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_024"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大家都沒事真是太好了。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但是",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "或許有其他魔物會因為剛剛的騷動靠近，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n趕快離開沙漠吧。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我已經請人在城裡準備好救護站了，",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_025"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n受傷、想休息的人都去那邊。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n運貨的動物們也能喝水喔。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "好、",
        "unit_id": 1,
        "voice": "vo_adv_1355002_026"
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "好的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "\n總有一天",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "請讓我報答您的恩情！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不用在意那種事啦♪",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_027"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n下次有人碰到麻煩時，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就出手幫忙吧！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也謝謝騎士先生的強化。",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_028"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "多虧了你，大家都平安無事。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哇喔，",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_029"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "真不愧是騎士先生，看得真清楚呢！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不過，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這點擦傷我沒問──",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "呃，",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_030"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "等……！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n你手伸過來是想幹嘛！？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "唔……！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "什麼勉強，",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_031"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這算不上勉強啦……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "真的不需要擔心……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……真是的，",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_032"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我都說沒關係了。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊──我知道了啦。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那就麻煩你",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "幫我包紮了……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗚……",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_033"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n騎士先生偶爾會變得很固執呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n不過這個世界的你也是這樣……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯～",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_034"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "可是啊，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我沒辦法對有困難的人置之不理呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "如果我能幫忙的話，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就必須出手相助才行。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……我的願望",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_035"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是讓大家都露出笑容。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n這是我最大的願望，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "如今也沒有改變。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "所以，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我沒辦法放著一臉悲傷的人不管。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "畢竟",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_036"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我過去都在擔任「管理者」，守護這個世界嘛？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n雖然現在",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "頂多就是在城裡巡邏而已啦。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗚嗚……",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_037"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "是嗎，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這樣啊。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n抱歉，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "本來沒打算讓你擔心的，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n我也不希望",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "你因為這樣而失去笑容。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "原來你看得出來",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_038"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我在逞強啊……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "謝謝，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "感覺很安心呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "但是，",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_039"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要不逞強",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好像很難……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n因為平常都覺得理所當然，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n就像是在要求我",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "「別當作理所當然」呢。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "互相幫助……",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_040"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這樣啊。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n有困難的時候",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "去依靠別人",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "也沒關係吧？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我知道了！",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_041"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n那我會試著去拜託別人，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不讓自己努力過頭！",
        "unit_id": 135512
    },
    {
        "type": "background",
        "background": "502060"
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "埃拉大人，",
        "unit_id": 1,
        "voice": "vo_adv_1355002_042"
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "謝謝妳",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "救了我們……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "\n如妳所見，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "商隊所有人都平安無事。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "\n謝謝妳",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "趕走魔物！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "太好了太好了♪",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_043"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n有困難的時候就要互相幫助幫助，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對吧！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "老爺，",
        "unit_id": 1,
        "voice": "vo_adv_1355002_044"
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "因為魔物襲擊的關係，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "攤位的準備延誤了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "\n不趕快處理的話",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "會來不及的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "是啊……",
        "unit_id": 1,
        "voice": "vo_adv_1355002_045"
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "但",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "大家都到極限了吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "\n剩下的就交給我，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "大家去旅店休息吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "這怎麼行，",
        "unit_id": 1,
        "voice": "vo_adv_1355002_046"
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "老爺才是最累的吧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "\n您一個人是無法處理的……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "哎呀，",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_047"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "看來有需要人手呢？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那麼",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我也來幫忙──",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗚……",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_048"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要依靠別人，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對吧。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "呃，",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_049"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "那麼……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "能請你幫幫這些人嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "可以嗎？",
        "unit_id": 1,
        "voice": "vo_adv_1355002_050"
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "謝謝你！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "那麼",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "這邊的行李……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "可以麻煩你小心處理嗎！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "請把這個搬到那邊……",
        "unit_id": 1,
        "voice": "vo_adv_1355002_051"
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "然後那邊也麻煩了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……行李看起來好重。",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_052"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咦，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "一個人沒問題嗎？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "……啊啊，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "快要跌倒了！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n好危險啊……！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "蠢蠢欲動……",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_053"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "蠢蠢欲動……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊！",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_054"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不行不行！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這時候就要忍耐、",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "忍耐……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我已經決定好，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要依靠他人了……！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "旅行商人",
        "words": "哈……",
