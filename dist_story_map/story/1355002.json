    },
    {
        "type": "dialogue",
        "name": "商人的隨從",
        "words": "呼……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "…………",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_057"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好坐立難安！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "啊──不行！",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_058"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我果然忍不了！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我也要幫忙──！！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嘿嘿嘿……",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_059"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "可是，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我果然還是放不下。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "因為",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這就是我！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "對吧。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嘿、",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_060"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咻……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "這個行李",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "真的好重呢！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要是我早點來幫忙就好了……",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "咦？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n突然變輕了？",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生……",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_061"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "謝謝你。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我大概",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_062"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "就是這樣的人吧。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "不會改，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "應該也改不了。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n因為我的天性就是這樣。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "嗯……",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_063"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "知道了，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "我保證。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "作為交換，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "騎士先生也是。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n有困難的時候，",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "要來依靠我喔。",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "好──！",
        "unit_id": 135512,
        "voice": "vo_adv_1355002_064"
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "大家一起的話馬上就能做完的！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "\n",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "接下來我也要",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "埃拉",
        "words": "使出全力加油囉──！",
        "unit_id": 135512
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "埃拉奮力揮動手臂衝了出去。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被她格外開朗的活潑笑容所感染，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}的臉也自然浮現出笑容。"
    }
