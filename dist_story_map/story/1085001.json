[
    {
        "type": "background",
        "background": "500111"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "聖誕節的兩個禮拜前，在【咲戀育幼院】裡……\n{player}和胡桃一起，\n為聖誕節進行佈置。"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥，",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_000"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你再稍微往旁邊移一點……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊，不對是往右邊……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇哇，",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_001"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不要搖來搖去的……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "要掉下去了要掉下去了要掉下去了，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "好恐怖……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_002"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥對不起，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我太害怕了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "照這個進度下去、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不知道要佈置到什麼時候了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "讓我騎在哥哥肩膀上",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_003"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n佈置果然還是不太好……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n還是拿個梯子之類的，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "讓個子高的哥哥來弄比較好……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……？",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_004"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥喪失了記憶，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n所以不知道如何佈置聖誕樹嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸、",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_005"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥真的是什麼都不知道呢，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真、真可愛……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊哇哇！？",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_006"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n都說不要搖來搖去了啊，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥你生氣了嗎……？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "對不起啦，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是說可愛是誇獎你……！",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嗚嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_007"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n哥哥明明是很溫柔的人，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "偶爾也會捉弄人呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "嚇唬我讓我害怕，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "有那麼好玩嗎？",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_008"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "倒、倒也是無所謂啦……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "比起像陌生人那樣注意禮貌，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "相互捉弄、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n互相開玩笑的關係……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "感情能變得更好呢……",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_009"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不對，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是變得更像真的家人了……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "唉……\n",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_010"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，對不起……",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_011"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "最近有點鬱悶，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總是唉聲嘆氣的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "和綾音比起來，",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_012"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我總是像陰天一樣陰沉……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚，",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就像哥哥說的呢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n不過",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "總是這樣唉聲嘆氣的，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n誰都看得出來我很煩惱吧……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "欸嘿……",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥今天話真多……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n說起來哥哥總是會向我搭話呢，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "一想到哥哥這麼為我操心，就讓我很開心……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那個，",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_015"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就和哥哥商量看看吧……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "兩個禮拜後，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n城鎮中央的場地不是會舉辦一個聖誕派對嗎……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "那是和我們的【咲戀育幼院】一樣的",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_016"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "看護設施還有醫院、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n孤兒院大家一起出錢共同舉辦的派對……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是咲戀媽媽從大家的想法總結出來的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "想為那些住院",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_017"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "以及失去家人，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n只能孤單一人度過聖誕節的人……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "帶來歡笑，相當棒的一個企劃……♪",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "然後我，",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_018"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在這場派對的餘興戲劇裡，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n居然被選為主角……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "雖然每天都有在排練，",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_019"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "但是我真的沒有能在大家面前演出的自信……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥和咲戀媽媽，",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還有大家都誇我演技很棒……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我也想在演技上多努力一點、",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n也在其他孤兒院演出過好幾次了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為這樣的評價，",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "讓我這次得到分量如此重的角色，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我是很開心……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不過這次的聖誕派對，",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_022"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n是專業的劇團演員也會參加的正式表演……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "而且，還有那麼多客人……",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_023"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "沒有自信能演好主角……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我好害怕……",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_024"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n最近還一直夢見自己忘記台詞，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "呆站在舞台上的惡夢……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是準備和宣傳的工作，",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_025"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還有舞台設置都已經開始進行了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "大家都在替我打氣，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我也想試著努力演出，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "都這個時候了「果然還是辦不到」這種話根本說不出口……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是、",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_026"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "真的辦不到……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n光是想想就要哭出來了……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊嗚……",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_027"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n我知道，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我要忍住，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "不應該哭的……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "討厭，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我居然是這種膽小鬼……",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哇啊……！？",
        "unit_id": 102111,
        "voice": "vo_adv_1085001_028"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我還騎在哥哥的肩膀上，",
        "unit_id": 102111
    },
    {
        "type": "dialogue",
        "name": "胡桃",
