    {
        "type": "dialogue",
        "name": "若菜",
        "words": "\n",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "這樣",
        "unit_id": 138712
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "也是為了布武機好。",
