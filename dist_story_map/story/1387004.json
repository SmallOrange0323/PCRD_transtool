    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "待在這裡的期間，",
        "unit_id": 138712,
        "voice": "vo_adv_1387004_002"
    },
    {
        "type": "dialogue",
        "name": "若菜",
        "words": "發生了很多讓人害羞的事。",
