    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]碧卡拉增加了老鼠耳朵的庫存，再次來到跳蚤市場擺攤。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n就在某一天──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]\n她抓住人潮變少的時機，稍作短暫的休憩。"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]那個……",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n不好意思，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]那邊的陽光少女……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n方便打擾妳一下嗎？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哎呀，",
        "unit_id": 125611,
        "voice": "vo_adv_5118072_001"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]這肯定是在說我囉♪",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那個，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]請問妳是……？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]我叫做忍。",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n目前在此",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]開設一家占卜攤位……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]原來如此，",
        "unit_id": 125611,
        "voice": "vo_adv_5118072_003"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]妳是占卜師呀！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]難怪妳散發一種神祕的氛圍呢。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]尤其是這個骷髏頭裝飾，感覺──",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]世上哪有我這麼紳士的裝飾啊～！！",
        "unit_id": 2411,
        "voice": "vo_adv_5118072_004"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]骷、",
        "unit_id": 125611,
        "voice": "vo_adv_5118072_005"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]骷髏頭說話了！？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]沒錯，",
        "unit_id": 2411,
        "voice": "vo_adv_5118072_006"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]我說話啦！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]\n有沒有嚇到啊，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]小丫頭！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]哇哈哈哈！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "冬麥斯",
        "words": "[FFFFFFFF]──！",
        "unit_id": 9711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]嘎啊────！！",
        "unit_id": 2411,
        "voice": "vo_adv_5118072_007"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]\n有個會動的巨大捕獸夾────？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]爸爸，",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]你安靜。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]……事情就是這樣，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]這是我的父親。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]這樣是哪樣呀！？",
        "unit_id": 125611,
        "voice": "vo_adv_5118072_009"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]不、",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]不過……",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]事情背後難免會有些隱情嘛！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那我也自我介紹吧！",
        "unit_id": 125611,
        "voice": "vo_adv_5118072_010"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n我是碧卡拉，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]來自東國的鼠神宮喔！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]來吧，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]跟我來個初次相遇的握手！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]這位爸爸就……",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]送你一個眨眼代替♪",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]妳就是那位有名的，",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]鼠神宮的碧卡拉嗎……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n我有耳聞許多關於妳的事……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]也難怪我從妳身上感受到力量。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]看來出聲叫住妳是對的。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]確實，",
        "unit_id": 2411,
        "voice": "vo_adv_5118072_012"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]這傢伙潛藏著不少力量啊。",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]\n雖然，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]還比不上我啦！",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]這樣一直誇，我會害羞的啦！",
        "unit_id": 125611,
        "voice": "vo_adv_5118072_013"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]所以呢，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]為什麼妳要出聲叫住我呀？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]嗯，",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]其實是……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n我想邀請",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]碧卡拉務必來試試看這邊的這一個占卜道具。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]這……",
        "unit_id": 125611,
        "voice": "vo_adv_5118072_015"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是水晶之類的嗎？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]看起來是挺奇特的道具呢。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]這是",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]我最近拿到手的道具。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]只要將手靠近水晶，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]其就會放射出十道光輝……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n可以藉著那些光輝的",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]顏色和比例來占卜運勢。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]感覺是很炫目的演出方式呢！",
        "unit_id": 125611,
        "voice": "vo_adv_5118072_017"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]如果是這樣，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我確實會想嘗試看看喔！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我看看……",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是不是像這樣就可以了？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]這、",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]這是……！",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]竟、",
        "unit_id": 2411,
        "voice": "vo_adv_5118072_019"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]竟然……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]全都是七彩光輝──！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哎呀呀！",
        "unit_id": 125611,
        "voice": "vo_adv_5118072_020"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n瞧你們的反應，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我是不是做出什麼不得了的事呢？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]七彩光輝代表運勢非常強，",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_021"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]其次是金色、",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]最後才是藍色光輝……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n沒想到妳的結果",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]竟然十道全是七彩光輝……！",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]也就是說，",
        "unit_id": 125611,
        "voice": "vo_adv_5118072_022"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我的運勢超級好對吧！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]不過，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]這也是理所當然的事喔。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n畢竟我可是──",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]Lucky！",
        "unit_id": 125611,
        "voice": "vo_adv_5118072_023"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]Cookie！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]碧奇！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n所以囉♪",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n哈哈！",
        "unit_id": 125611
    },
    {
        "type": "background",
        "background": "500035"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]接著，當天晚上──"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]時間也已經很晚了……",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]今天就差不多到這裡吧，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]爸爸。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]也是！",
        "unit_id": 2411,
        "voice": "vo_adv_5118072_025"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]\n就趕快把店收一收，",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]去找身材豐滿的大姐姐一起吃飯──",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]爸爸……？",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_026"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]噫～！",
        "unit_id": 2411,
        "voice": "vo_adv_5118072_027"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]忍好恐──",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]\n嗯？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]\n這個氣息是……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]……我也感受到了。",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n是非常強烈的陰之氣息……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]會是有什麼煩惱的人嗎……？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]今天也好累人唷……",
        "unit_id": 125614,
        "voice": "vo_adv_5118072_029"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]雖然老鼠耳朵成功賣光是很不錯啦……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]總之去買點起司就回家吧……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]那個……",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n不好意思，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]那邊的……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]呃……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]黑髮少女。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n方便打擾妳一下嗎？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]……！？",
        "unit_id": 125614,
        "voice": "vo_adv_5118072_031"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n是、",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是在說人家嗎……？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]是的。",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n那個……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]如果不介意，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]可以讓我替妳占卜嗎？",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]若是妳有什麼煩惱，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]我相信可以幫上忙的。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]咦，",
        "unit_id": 125614,
        "voice": "vo_adv_5118072_033"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]人家沒有任何煩惱呀……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]但應該是我看起來太陰沉，讓對方這麼覺得了……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n不能讓她因此浪費時間在我身上……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那、",
        "unit_id": 125614,
        "voice": "vo_adv_5118072_034"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那個……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]\n人家可以使用",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]擺在那邊的奇特水晶進行占卜嗎……？",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]如果是這個，",
        "unit_id": 125614,
        "voice": "vo_adv_5118072_035"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]只要把手靠過去很快就可以結束了……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]妳想進行運勢占卜嗎？",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]那麼……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]還請將手放過來，靠近水晶。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]好、",
        "unit_id": 125614,
        "voice": "vo_adv_5118072_037"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]好的……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]這、",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_038"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]這是……！",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]竟、",
        "unit_id": 2411,
        "voice": "vo_adv_5118072_039"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]竟然全部……",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]都是藍色──！？",
        "unit_id": 2411
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "[FFFFFFFF]\n這運勢根本弱到爆了啊！！",
        "unit_id": 2411
    },
    {
