        "words": "[FFFFFFFF]是的。",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_045"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]這也並非什麼高價的物品。",
