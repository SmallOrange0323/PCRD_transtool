        "words": "[FFFFFFFF]爸爸！",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_040"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]運、",
        "unit_id": 125614,
        "voice": "vo_adv_5118072_041"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]運勢……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]弱到爆……",
        "unit_id": 125614
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]那、",
        "unit_id": 103113,
        "voice": "vo_adv_5118072_042"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]那個……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]還請不要太過沮喪。",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n畢竟一個人的運勢是會變化的……",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]今天只是碰巧運勢較差，",
        "unit_id": 103113
    },
    {
        "type": "dialogue",
