[
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "愉快……",
        "unit_id": 133911,
        "voice": "vo_adv_5201333_000"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真愉快！",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "敵人的強度自不用說，",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "能與七冠並肩作戰發揮力量的愉悅更是難以言喻──！",
        "unit_id": 133911
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我是沒有那般享樂的感想。",
        "unit_id": 133811,
        "voice": "vo_adv_5201333_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n畢竟對手非常強。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我會全力以赴，",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不會有多餘的試探。",
        "unit_id": 133811
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "其實，",
        "unit_id": 133711,
        "voice": "vo_adv_5201333_002"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "考量會對周遭造成的影響，",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n同時一邊考慮風險一邊戰鬥才是我的作風。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "……不過啊。",
        "unit_id": 133711,
        "voice": "vo_adv_5201333_003"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "抱歉，我現在",
        "unit_id": 133711,
        "voice": "vo_adv_5201333_004"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "要毫不保留地打倒你。",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "\n",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "雖然以迷宮的解法而言是犯規的──",
        "unit_id": 133711
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "──但我要破壞所有牆壁，",
        "unit_id": 133711,
        "voice": "vo_adv_5201333_005"
    },
    {
        "type": "dialogue",
        "name": "拉比林斯達",
        "words": "毫無拐彎抹角地打倒你！",
        "unit_id": 133711
    }
]