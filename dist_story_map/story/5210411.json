[
    {
        "type": "background",
        "background": "502710"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "拜訪吉歐‧格黑納的日子",
        "unit_id": 137412,
        "voice": "vo_adv_5210411_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "感覺既漫長又短暫，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "今天就要告一段落了呢。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "小霞，",
        "unit_id": 136212,
        "voice": "vo_adv_5210411_001"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "要回蘭德索爾了嗎？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n好寂寞喔……",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "是啊。",
        "unit_id": 137412,
        "voice": "vo_adv_5210411_002"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我一定會再來的。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我已經徹底喜歡上這個世界了，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "而且還有見習助手拿娜小姐在嘛。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "嗯！",
        "unit_id": 136212,
        "voice": "vo_adv_5210411_003"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "……對了！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n下次拿娜我們，",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "也去蘭德索爾玩吧！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "小阿！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我、",
        "unit_id": 136011,
        "voice": "vo_adv_5210411_004"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "我嗎？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "會不會，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "造成困擾呢……？",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "別說什麼造成困擾了。",
        "unit_id": 137412,
        "voice": "vo_adv_5210411_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我非常歡迎喔。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也有很多想介紹給妳認識的夥伴呢。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那麼，",
        "unit_id": 136011,
        "voice": "vo_adv_5210411_006"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "總有一天我一定",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "會去拜訪的……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……嗚……",
        "unit_id": 136011
    },
    {
        "type": "background",
        "background": "502250"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "哇哇，",
        "unit_id": 136212,
        "voice": "vo_adv_5210411_007"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "小阿怎麼了！？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "肚子痛嗎？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是為什麼呢……",
        "unit_id": 136011,
        "voice": "vo_adv_5210411_008"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "眼淚湧了上來……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "\n感覺就像一直以來，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "希冀的事情……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "實現了一樣……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "太誇張了啦小阿！",
        "unit_id": 136212,
        "voice": "vo_adv_5210411_009"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "去別的世界什麼的",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "很簡單的！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "只要在那邊也交朋友就好了嘛！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "原來是那樣啊……",
        "unit_id": 136011,
        "voice": "vo_adv_5210411_010"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "原來只要那樣，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "就好了啊……",
        "unit_id": 136011
    },
    {
        "type": "background",
        "background": "502710"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "煩惱這種事，",
        "unit_id": 137412,
        "voice": "vo_adv_5210411_011"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "說不定也就如此單純呢。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "只要有獨一無二的「某個人」陪在身邊，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一切都會好起來。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "對我來說，",
        "unit_id": 136011,
        "voice": "vo_adv_5210411_012"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "那就是，",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "小拿和",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "騎士先生……",
        "unit_id": 136011
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "咦？",
        "unit_id": 136212,
        "voice": "vo_adv_5210411_013"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "先不提小騎士，",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "拿娜也是？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "拿娜有做什麼嗎……？",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "呵呵，",
        "unit_id": 137412,
        "voice": "vo_adv_5210411_014"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "回到蘭德索爾之後，",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n我得準備很多甜甜圈才行呢。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "為了讓妳們隨時來都沒問題。",
        "unit_id": 137412
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "真的嗎！？",
        "unit_id": 136212,
        "voice": "vo_adv_5210411_015"
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "萬歲──！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "\n太好了呢小阿！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "拿娜",
        "words": "好期待喔～！！",
        "unit_id": 136212
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "……",
        "unit_id": 136011,
        "voice": "vo_adv_5210411_016"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅",
        "words": "是啊！",
        "unit_id": 136011
    }
]