[
    {
        "type": "still",
        "still": "520306201"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "波波爺爺的",
        "unit_id": 9212,
        "voice": "vo_adv_5203066_000"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "「克蘿茜大解密」",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "要開始啦～！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n把老夫解析的",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "古代兵器",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "巨型軀體的詳細資訊，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n用大家都能懂的方式",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "慢～慢仔細地講解給大家聽喔。",
        "unit_id": 9212
    },
    {
        "type": "still",
        "still": "520306601"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這次要講解的是，",
        "unit_id": 9212,
        "voice": "vo_adv_5203066_001"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "「巨型飛彈」。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n這是搭載在巨型克蘿茜胸部的",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "超強火力砲彈！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n為了能夠打倒所有敵人，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "老夫盡可能地",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "增加火藥量了！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我有問題",
        "unit_id": 134511,
        "voice": "vo_adv_5203066_002"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我有問題，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "想要問波波爺爺，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "為什麼要在胸部放飛彈呢？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯，",
        "unit_id": 9212,
        "voice": "vo_adv_5203066_003"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "那是因為……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "克蘿茜、",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "碧。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n如果是妳們，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "看起來就有",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "銳利爪牙的魔物",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n和並非如此的魔物，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "妳們會更警戒哪邊？",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "正常來說，",
        "unit_id": 134612,
        "voice": "vo_adv_5203066_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "會是有銳利爪牙的魔物……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "吧。",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n啊，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就是所謂的陷阱題嗎？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "嗯，",
        "unit_id": 9212,
        "voice": "vo_adv_5203066_005"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就是這樣。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n露出武器的話",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就會把注意力放在上面……",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n那麼反過來將其藏起的話，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "就可以讓對方大意，",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "這也是一種戰略。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "俗話說",
        "unit_id": 134511,
        "voice": "vo_adv_5203066_006"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "有能力的老鷹會將爪子藏起來，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這就是關鍵時刻的必殺技對吧！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原來如此……",
        "unit_id": 134612,
        "voice": "vo_adv_5203066_007"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "優點我理解了，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "但是，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n還是有個令我在意的地方。",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 134612,
        "voice": "vo_adv_5203066_008"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "我會乘坐的駕駛艙，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "也在胸部附近對吧？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "要是不小心受到攻擊，",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "不會引爆嗎？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "……………………",
        "unit_id": 9212,
        "voice": "vo_adv_5203066_009"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個，",
        "unit_id": 134612,
        "voice": "vo_adv_5203066_010"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "波波爺爺？",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個沉默是什麼意思……",
        "unit_id": 134612
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "很好，",
        "unit_id": 9212,
        "voice": "vo_adv_5203066_011"
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "稍微",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "加裝一下胸部裝甲吧。",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "\n感謝妳",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "波波爺爺",
        "words": "來自現場的寶貴意見！",
        "unit_id": 9212
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "等等，",
        "unit_id": 134612,
        "voice": "vo_adv_5203066_012"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請回答我啊～～～！？",
        "unit_id": 134612
    },
    {
        "type": "still",
        "still": "end"
    }
]