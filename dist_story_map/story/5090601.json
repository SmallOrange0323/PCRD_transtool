    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳真的來啦！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗯，",
        "unit_id": 121512,
        "voice": "vo_adv_5090601_001"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那當然，",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "因為是祈梨約我的啊。",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……不過，",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "為什麼",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "會叫我穿",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怪盜服過來呢？",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n祈梨也是穿怪盜服……",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "其實啊……",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我想委託步未未",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "執行超級極惡任務哦！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "咦！？",
        "unit_id": 121512,
        "voice": "vo_adv_5090601_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "超級極惡任務……！？",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那到底是",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎樣的……！？",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "聽了可別嚇到哦。",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個超級極惡任務──",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是跟我一起",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "偷偷潛入老大的",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "祕密房間！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "帆稀小姐的房間……！？",
        "unit_id": 121512,
        "voice": "vo_adv_5090601_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對！",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話雖如此，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "也不是要去偷老大的東西。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我只是想一起潛入房間，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "跟步未未拍張照片而已。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n換句話說，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就是一種試膽大會！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "被發現我們那麼做，",
        "unit_id": 121512,
        "voice": "vo_adv_5090601_007"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n帆稀小姐會很生氣吧……？",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話、",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話是沒錯……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這是我一生一次的請求！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n希望妳能跟我潛入老大的祕密房間！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "當怪盜都辦成那麼厲害的事了，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這不是會讓人想以某種形式留下來嗎？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所以，",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我想在最後穿著這件衣服，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n將進行怪盜活動的瞬間拍成照片保存……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我想把回憶",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "化為實體留存下來啊！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "嗯……",
        "unit_id": 121512,
        "voice": "vo_adv_5090601_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……步未未，",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳還是不願意嗎？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "只要帆稀小姐沒發現的話……",
        "unit_id": 121512,
        "voice": "vo_adv_5090601_013"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n反正只是拍張照片……",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "應該不會……",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "造成麻煩吧……？",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哦，",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "步未未，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳終於有意願了啊！",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……哦，",
        "unit_id": 1,
        "voice": "vo_adv_5090601_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怪盜團",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "再次集結喵？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這個聲音是……",
        "unit_id": 121512,
        "voice": "vo_adv_5090601_016"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "幻影貓！？",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n沒看到人……",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "妳",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "怎麼會來這裡？",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "沒什麼，",
        "unit_id": 1,
        "voice": "vo_adv_5090601_017"
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "我剛好有點事喵。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "\n我確實拿到關於那群惡徒的資料了喵。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "\n這樣假預告信的事我們就互不相欠喵。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看來老大她……",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n又在我們不知情的狀況下",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "擅自作主了……",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "話說……",
        "unit_id": 1,
        "voice": "vo_adv_5090601_019"
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "馬上就是點心時間了喵。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "所以說，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "快來吃這個喵！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……桌子上",
        "unit_id": 121512,
        "voice": "vo_adv_5090601_020"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "什麼時候",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "多出了鯛魚燒！？",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "這是我請的喵♪",
        "unit_id": 1,
        "voice": "vo_adv_5090601_021"
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "就為他人懲罰壞蛋這點，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "妳們跟我很像喵。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "\n換句話說……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "妳們可以說是我的後輩也不為過喵！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "因此，",
        "unit_id": 1,
        "voice": "vo_adv_5090601_022"
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "那些鯛魚燒",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "算妳們後輩特別價格喵！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "突然擺出前輩的架子，",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "請的東西還要跟人收錢！？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這傢伙",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到底是怎麼搞的！？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但是，",
        "unit_id": 121512,
        "voice": "vo_adv_5090601_024"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "看起來好好吃……",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "那個，",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我就把錢放在桌子上囉，",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n幻影貓。",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……不過，",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "說得也是，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n在執行重要工作前會很想要吃甜的，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n所以要我花錢也是可以啦？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "喵哈哈，",
        "unit_id": 1,
        "voice": "vo_adv_5090601_026"
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "謝謝惠顧！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "\n",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "那麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "怪盜團，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "幻影貓",
        "words": "祝妳們好運喵！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……她好像走掉了。",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個貓女",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到底是怎樣啊？",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……算了，別管她，",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "來吃鯛魚燒吧。",
        "unit_id": 121611
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "……哇，",
        "unit_id": 121512,
        "voice": "vo_adv_5090601_028"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "這個鯛魚燒",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "好好吃哦……♪",
        "unit_id": 121512
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真的耶……！",
        "unit_id": 121611,
        "voice": "vo_adv_5090601_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n竟然能滿足我這個美食家的味蕾，",
        "unit_id": 121611
    },
    {
