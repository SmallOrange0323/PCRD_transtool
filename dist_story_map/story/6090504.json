    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "……正月の予定ですか？",
        "unit_id": 115011,
        "voice": "vo_adv_6056504_000"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "いえ、",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "特には何も。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n季節ごとの行事に興じる暇も、",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "あまりありませんから。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "ええ、",
        "unit_id": 115011,
        "voice": "vo_adv_6056504_001"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "やることは山積みです。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\nむろん、",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "そのために貴方にも色々と動いてもらうつもりですから。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "……大いに期待していますよ。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "これからの貴方の働きに。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "諦めなさい。",
        "unit_id": 115011,
        "voice": "vo_adv_6056504_002"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "そんな子犬のような目で訴えても",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "無駄ですよ。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "はあ、",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "仕方ありませんね……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "新年のお参りくらいなら、",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n付き合ってあげても構いません……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "貴方もやるようになりましたね。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "……まったく、",
        "unit_id": 115011,
        "voice": "vo_adv_6056504_003"
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "貴方という人は。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "ですが",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "私といえども、",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "時には休息が必要なのも認めましょう。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "ただし、",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "ネネカ",
        "words": "正月だからといって怠けすぎはいけませんよ？",
        "unit_id": 115011
    }
]