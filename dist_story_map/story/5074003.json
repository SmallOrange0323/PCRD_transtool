[
    {
        "type": "background",
        "background": "501380"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "深月成功完成困難的手術，風評更加提升了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而也因此變得更為忙碌。"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "真傷腦筋，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_000"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "已經這麼晚了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "自從上次之後，變得能離開診察室走動這點是很好，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但卻是要我接連進行手術。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那個院長，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_001"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "完全就是打算把我給累死吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "完全沒問題。",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_002"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "比起要和我那些公會成員相處，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n這邊的工作",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "根本是休閒活動。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "只是，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_003"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "有其他問題要擔心。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "沒錯，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_004"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這才是難關。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雖然從來看診的患者身上問出了很多事情，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n但就是沒有牽涉到頭目的關鍵情報。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "問題出在沒有足夠的人手能進行調查，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_005"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n很遺憾的，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要找這種時候能依靠的人才，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我實在沒有頭緒。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不能找【暮光流星群】的成員，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_006"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n她們在能力",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "以及性格上都太過極端了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要是真的找不到，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可能就得請你找朋友來幫忙了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……莫非，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_007"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就是那位與你一樣，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "同為大江戶町英雄的忍者嗎？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "可是，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "她看起來",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "似乎不太適合從事諜報活動……",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "等一下！",
        "unit_id": 1,
        "voice": "vo_adv_5074003_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你們是不是忘了",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這裡就有一位",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "可靠的美麗英雄啦？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這聲音莫非是……",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_009"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "對了，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "她上次說過會再來的。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我都忘光了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雪，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_010"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很抱歉，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "應付妳不是我的專業，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n妳可以去找其他人嗎？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪　",
        "words": "醫生，",
        "unit_id": 1,
        "voice": "vo_adv_5074003_011"
    },
    {
        "type": "dialogue",
        "name": "雪　",
        "words": "妳確定要這樣冷落我嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪　",
        "words": "先看看這個",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪　",
        "words": "再說吧！",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "501380"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "很高興妳有這份心意，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_012"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但我們不缺人手喔。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不可以說謊喔。",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_013"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "醫生，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳從早上到現在",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "接連動了好幾次手術，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n今天根本就不在診察室裡嘛。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "害我啊，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_014"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "一直痴痴地在等妳耶。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "所以被妳發現我其實很忙了。",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_015"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但我還是不懂，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "為什麼妳想要幫助我呢？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我雖然跟妳不太熟，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_016"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "但妳看起來不是那種憂國憂民、",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "孜孜不倦的人吧？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_017"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我只是",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "想讓妳當我的主治醫師才這麼說的，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "而且",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "護理師的衣服很可愛不是嗎？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我一直都很想穿一次看看呢♪",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "毫不隱瞞自己的欲望，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_018"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我不討厭妳這種直率性格。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳很適合加入",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "【暮光流星群】喔。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是不是？",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_019"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我就知道",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳是個好醫生。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "現在我知道妳的目的了。",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_020"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們並不是來做慈善事業的。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而是另有目的",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "才潛入這間醫院臥底的。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們越是接近真相，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_021"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n就越有可能遭遇危險喔？",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_022"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "醫生妳不知道嗎？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也和",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這個人一樣，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n是這城鎮的英雄之一喔。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "不過，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_023"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "像戰鬥這種暴力的事情我都交給夥伴，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n要是遇到危險，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我也會全都交給醫生的喔。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……這麼誠實反而爽快。",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_024"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "再問下去就真的太麻煩了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "好吧，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那就麻煩妳幫點忙了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳總算肯答應啦？",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_025"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要我做什麼儘管說吧。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "妳現在去每間病房逛逛，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_026"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "讓住院病患",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "欣賞欣賞妳的美貌。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n然後順便跟他們",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "閒話家常一下吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來如此，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_027"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那些病患因為長期住院而鬱悶，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳是要我用美貌為他們打氣吧？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "美麗",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_028"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "勝過任何藥劑。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這差事",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只有我能做到呢。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那麼，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我這就出發！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也只能這樣了。",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_029"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "畢竟她並不是真正的護理師，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n我不期待她能勝任一般護理師的職務。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "不過，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_030"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "也許有些事情只有她能夠辦到。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "……算了，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "還是別過度期待，看看狀況吧。",
        "unit_id": 117511
    },
    {
        "type": "still",
        "still": "507400301"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳好！",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_031"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "治療時間到囉！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "哎呀呀，",
        "unit_id": 1,
        "voice": "vo_adv_5074003_032"
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "好可愛的護理師啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "\n但妳說治療……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "這種時間還有巡診嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "巡診？",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_033"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我不知道那是什麼意思，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的工作是",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "散發美麗！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "來，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好好欣賞我的美麗，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "趕快恢復健康吧！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "哎呀呀，",
        "unit_id": 1,
        "voice": "vo_adv_5074003_034"
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "真是謝謝妳。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "\n妳有這份心意，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "我好開心呀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "因為這間醫院，",
        "unit_id": 1,
        "voice": "vo_adv_5074003_035"
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "總有種",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "令人喘不過氣的感覺。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是喔，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_036"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這樣啊。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_5074003_037"
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "妳是這裡的護理師，卻沒發現嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為人家是",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_038"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "光鮮亮麗的新人護理師嘛♪",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "原來是這樣。",
        "unit_id": 1,
        "voice": "vo_adv_5074003_039"
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "其實這間醫院",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "不久之前換了新的院長。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "\n雖然醫院的風評變得不錯，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "\n但醫師和護理師們卻都顯得有些陰沉。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "並不是說他們態度很差",
        "unit_id": 1,
        "voice": "vo_adv_5074003_040"
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "或是診察很隨便，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "不是這種感覺，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "\n而是他們看起來好像很難受。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "我們原本就是",
        "unit_id": 1,
        "voice": "vo_adv_5074003_041"
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "因為不明原因住進來的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "\n看到他們這樣也覺得很難受呀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "咦？",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_042"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這位奶奶，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "妳不知道自己得什麼病嗎？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "是啊。",
        "unit_id": 1,
        "voice": "vo_adv_5074003_043"
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "住在附近的小姐",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "和我常光顧的店家老闆，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "\n也都有了同樣症狀。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "最近",
        "unit_id": 1,
        "voice": "vo_adv_5074003_044"
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "鎮上的氣氛也不太好。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "\n真不知道我們大江戶町發生了什麼事……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "真是的，",
        "unit_id": 1,
        "voice": "vo_adv_5074003_045"
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "瞧我一直抱怨些無趣的事……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "\n真不好意思啊。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "能和妳這麼",
        "unit_id": 1,
        "voice": "vo_adv_5074003_046"
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "開朗又漂亮的孩子聊天，我實在太開心了。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "\n可以的話，下次再來找我聊聊吧。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "當然沒問題！",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_047"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "畢竟這就是",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的工作嘛。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "啊，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還有，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "奶奶妳很快就不用再抱怨囉。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者1",
        "words": "什麼？",
        "unit_id": 1,
        "voice": "vo_adv_5074003_048"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "因為",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_049"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這裡有鎮上的英雄",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "和名醫啊♪",
        "unit_id": 117611
    },
    {
        "type": "background",
        "background": "501401"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "哼哼～♪",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_050"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "看著我的美貌逐漸傳播給大家，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "感覺真棒。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "話說回來，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_051"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那位老奶奶的臉色也不太好呢。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n感覺住院的人",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "比醫院外面的人還要嚴重……？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "嗯？",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_052"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那是……",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "嗯──",
        "unit_id": 1,
        "voice": "vo_adv_5074003_053"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "什麼都沒有耶。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "\n應該是跑進這裡了啊……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "小弟弟，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_054"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你在這裡做什麼！？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "哇！",
        "unit_id": 1,
        "voice": "vo_adv_5074003_055"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "大、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "大姐姐，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "妳是誰……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我是",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_056"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這世上最美的護理師，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "雪！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "真的……",
        "unit_id": 1,
        "voice": "vo_adv_5074003_057"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這無情的懷疑眼神，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_058"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "有點傷感情啊。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "算了，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "要求小孩子瞬間理解我的美，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n可能太難了點吧。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好啦，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_059"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "別待在這黑漆漆的地方，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n到比較亮的外面去，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好好欣賞我的美貌吧！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "呃──",
        "unit_id": 1,
        "voice": "vo_adv_5074003_060"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "那不重要啦，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "我",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "得找出幽靈才行。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "幽靈？",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_061"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "嗯。",
        "unit_id": 1,
        "voice": "vo_adv_5074003_062"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "一到半夜",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "就會有人進來這個房間，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "\n但是房裡卻都找不到。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "所以那個",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "肯定是幽靈啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "幽靈，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_063"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是吧……",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "啊，",
        "unit_id": 1,
        "voice": "vo_adv_5074003_064"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "妳一臉就是不信！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "我是說真的啦！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "\n這裡還能聽見呻吟聲！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "你誤會了，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_065"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我的美貌優先順序",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "居然輸給了幽靈，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n我只是不太能接受這個事實罷了……",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "呃，",
        "unit_id": 1,
        "voice": "vo_adv_5074003_066"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "妳在計較這個？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "大姐姐妳真的好怪喔……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "小弟弟，",
        "unit_id": 512,
        "voice": "vo_adv_5074003_067"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "你在那裡做什麼？",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "呀啊！",
        "unit_id": 1,
        "voice": "vo_adv_5074003_068"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "院、",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "院長……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "不可以在醫院裡亂晃喔。",
        "unit_id": 512,
        "voice": "vo_adv_5074003_069"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "\n趕快回去你的病房。",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "嗯、",
        "unit_id": 1,
        "voice": "vo_adv_5074003_070"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "嗯……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "那麼，",
        "unit_id": 512,
        "voice": "vo_adv_5074003_071"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "這位小姐，",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "妳是那個女醫師派來的吧？",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我不懂你在說什麼耶？",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_072"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我只是來探望",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "這孩子而已啊？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "有人穿這樣來探病的嗎？",
        "unit_id": 512,
        "voice": "vo_adv_5074003_073"
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "\n快帶著那孩子",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "院長",
        "words": "離開這裡。",
        "unit_id": 512
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "那個醫生是怎樣？",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_074"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "態度好差喔。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n看到我",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "居然連一句可愛都不說，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "肯定有問題！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "我、",
        "unit_id": 1,
        "voice": "vo_adv_5074003_075"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "我也不太清楚，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "只是那個人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "雖然對我們很好，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "\n卻對醫師和護理師都很嚴格。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "所以",
        "unit_id": 1,
        "voice": "vo_adv_5074003_076"
    },
    {
        "type": "dialogue",
        "name": "住院患者2",
        "words": "我也不太喜歡他。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "是喔，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_077"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "原來是這樣。",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "總之",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我先回去跟醫生報告吧。",
        "unit_id": 117611
    },
    {
        "type": "background",
        "background": "501382"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "好的，",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_078"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "事情就是這樣，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我已經盡情地",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "去散播完我的美囉！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "\n",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "只要繼續保持下去，",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "大家一轉眼就能出院啦！",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "怎麼樣？",
        "unit_id": 117611,
        "voice": "vo_adv_5074003_079"
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "醫生？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "我是不是",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "雪",
        "words": "還挺有用處的啊？",
        "unit_id": 117611
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "是啊，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_080"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "老實說，",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我沒想到妳居然這麼能幹。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這才是最重要的。",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_081"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "因為閒聊時",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "能引出他們每天察覺的小細節、",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n毫無虛偽的真心話、",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "或是令人感興趣的話題啊。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "而我們",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_082"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "要找尋的真相",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "就藏在這些閒聊之中。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "\n",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "雪她成功探出這些情報了。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "那麼，",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_083"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "我們也出發吧。",
        "unit_id": 117511
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "這還用問嗎？",
        "unit_id": 117511,
        "voice": "vo_adv_5074003_084"
    },
    {
        "type": "dialogue",
        "name": "深月",
        "words": "當然是去找幽靈囉。",
        "unit_id": 117511
    }
]