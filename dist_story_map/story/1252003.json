    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "現在也沒有客人，為什麼……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是給我的嗎？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……可以嗎？",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_062"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "謝謝你。",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_063"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就讓我坦率地接受你的好意吧。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為今天",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "稍微有點累了哪……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼～",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_064"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼～",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咕嚕……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊～～～",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "甜甜的，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真好喝啊，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "喝完後我也來收拾吧……",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_065"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我休息就好？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是的，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不用這麼顧慮我啦。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_066"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真好喝哪，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這個……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這就是所謂工作後的一杯嗎。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呼呼～",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_067"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "甜味和香味滲到骨子裡去了……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不只是身體，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這味道讓心裡也都暖暖的呢。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……也是呢。",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_068"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "一回神才發現，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我總是覺得該自己一個人達成目標……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n明明不用勉強自己，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "向周遭的人求助也是可以的。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為總是別人來找我諮商，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_069"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n這樣的我就必須堅強，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不能依賴他人……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n可能我以前都是這樣想的。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "今天一整天",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_070"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我可是",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "深深體會學習到了這件事。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而且，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_071"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我又再次了解到，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n他人為我沖的咖啡是多麼地美味。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……好。",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_072"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n也為了明天……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就讓我",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "再休息一下吧……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "幾天後，{player}去了店裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看見了正在沖咖啡的莫妮卡。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "歡迎光臨──",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_073"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咦，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "什麼啊，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "原來是閣下。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你說客人變少了？",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_074"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真失禮。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我希望你說的不是客人變少，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "而是說我接待客人的速度變快喔。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "呵呵，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_075"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我上次有說吧？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n要學會求助這件事。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不只是珠希，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_076"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我請公會成員的大家",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "都來幫忙了。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為這裡是公會的辦事處呢。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "唔，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_077"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "啊，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "稍等一下。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我得在咖啡冷掉之前送過去。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這位婦人",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_078"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "久等了。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "本店的原創咖啡。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "哎呀，",
        "unit_id": 611,
        "voice": "vo_adv_1252003_079"
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "謝謝妳。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "請慢用。",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_080"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有任何問題",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "隨時跟我說。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……為什麼閣下",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_081"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "要微笑地看向這邊？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我只是很普通地送咖啡而已喔。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "多虧有大家的幫忙，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_082"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n閣下不用急著工作也沒關係。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_083"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也為閣下沖一杯吧。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "之前那件事",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_084"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "還沒有好好向你道謝呢。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "謝謝你，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "託你的福，我打開了我的眼界。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那時你幫我沖的那杯咖啡",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_085"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真的很好喝。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為那杯咖啡肯定",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也注入了閣下的體貼吧。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_086"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "希望我們店能夠提供這樣的咖啡。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我想提供一個可以撫慰疲憊的心情、",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "令人感到安心的場所。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……我已經做到了？",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_087"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真是的閣下，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "就像你為我沖的那杯咖啡一樣，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n你對我太寬容了喔。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "來，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_088"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "對於我是不是真的能提供這樣的咖啡，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n等你喝完這杯再說吧。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在你喝咖啡的同時，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_089"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也有事情",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "想要和閣下商量。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你當然",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "會聽我說的吧？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "邊這麼說邊微笑的莫妮卡。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}回以相同的笑容，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n點頭同意她說的話。"
    }
]