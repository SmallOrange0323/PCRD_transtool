[
    {
        "type": "background",
        "background": "501950"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這天，光顧「Naschkatze」的客人絡繹不絕。"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你總算來了！",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_000"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n今天場面超級混亂。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "如果你能來幫忙就太好了！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我晚點再跟你解釋！",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_001"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "快點，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "幫我把這個送去窗邊那桌。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n加糖的原創咖啡兩杯，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "然後是餅乾。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "謝謝，",
        "unit_id": 414,
        "voice": "vo_adv_1252003_002"
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "咦",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "咦？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "\n莫妮卡呢？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "剛剛看起來很忙呢～",
        "unit_id": 1211,
        "voice": "vo_adv_1252003_003"
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "\n今天會不會來我們這邊呢。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "閣下，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_004"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "抱歉。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "接著幫我把這個送去裡邊的四人桌──",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "送好後，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "幫我在這杯花草茶裡倒入熱水，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n然後送去",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "入口那邊的沙發桌。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "你說今天看起來相當忙碌？",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是啊，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "發生了一些事……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "那個那個，莫妮卡，",
        "unit_id": 1511,
        "voice": "vo_adv_1252003_006"
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "可以聽我說一下嗎？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "\n",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "我想跟妳說",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "我家老公的事情！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "\n他下班一到家就直接在沙發上睡著……！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "要吃白飯嗎？",
        "unit_id": 1511,
        "voice": "vo_adv_1252003_007"
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "還是要吃配菜？",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "\n我問他這些，",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "他也完全不回應！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那真是辛苦啊。",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……不過，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "白飯和配菜",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是只能選擇其中一種的嗎……？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "哎呀，",
        "unit_id": 1511,
        "voice": "vo_adv_1252003_009"
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "這麼一說也是呢！",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "顧客3",
        "words": "但是重點不是這個……",
        "unit_id": 1511
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "啊，",
        "unit_id": 414,
        "voice": "vo_adv_1252003_010"
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "也可以聽我說嗎？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "最近採購的價格又變高了……",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "\n",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "莫妮卡這邊",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "顧客1",
        "words": "也有採購的煩惱嗎？",
        "unit_id": 414
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "我也有煩惱……",
        "unit_id": 1211,
        "voice": "vo_adv_1252003_011"
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "\n",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "那個那個，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "今年春天流行的洋裝，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "\n粉紅色跟黃綠色，",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "顧客2",
        "words": "妳覺得哪一個好～？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我、",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_012"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我知道了。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n我會聽你們說的，再等一下。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n凡事都要照順序來，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "這是從小就該學習的規矩對吧！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們公會的辦事處",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_013"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "確實就是大家休息的場所，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n然後變成咖啡廳。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "讓居民商量自己的困擾",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也跟委託相關，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n因此這裡是跟城鎮居民有所聯繫的重要場所。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然諮商這件事本身是沒有問題的……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n但經過口耳相傳，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "回過神來客人就已經絡繹不絕了。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但是",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_015"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也不能不理會需要幫助的居民啊。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "所以",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "只能一個一個聽聽他們的煩惱。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_016"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "咖啡準備好了。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "可以幫我",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "把這個送去給那位婦女嗎？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我去",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "聽聽剛才那些人的煩惱。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "哎呀，",
        "unit_id": 611,
        "voice": "vo_adv_1252003_017"
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "謝謝你。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "……不過我等了很久呢……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "感覺最近",
        "unit_id": 611,
        "voice": "vo_adv_1252003_018"
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "咖啡的味道變了……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "\n而且",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "店裡的氣氛也變得不一樣，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "總覺得好像很辛苦呢……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "是不是發生了什麼事呢？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "啊，",
        "unit_id": 611,
        "voice": "vo_adv_1252003_019"
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "抱歉呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "我只是有一點擔心。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "顧客4",
        "words": "打擾你工作，真抱歉。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "好，",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_020"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "解決一件事了。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "接著下一件吧。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "雖然還有很多事情要解決……",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不過腳踏實地完成工作",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "才是所謂的軍人！",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "呼、",
        "unit_id": 4911,
        "voice": "vo_adv_1252003_021"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "呼……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n這裡也沒有……！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "怎麼了！？",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_022"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n怎麼一臉驚慌的樣子，",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "究竟發生什麼事了。",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不、",
        "unit_id": 4911,
        "voice": "vo_adv_1252003_023"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "不好意思！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "有沒有看到我們家女兒？",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我一不留神她就不見了！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "常常來我們店裡的",
        "unit_id": 125212,
        "voice": "vo_adv_1252003_024"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那孩子嗎？",
        "unit_id": 125212
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "是的……！",
        "unit_id": 4911,
        "voice": "vo_adv_1252003_025"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "今天早上她就一直想來，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n所以我就以為她肯定會來這裡……",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "啊啊，",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "怎麼辦！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "我那時候",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "有好好看著的話……！",
        "unit_id": 4911
    },
    {
        "type": "dialogue",
