[
    {
        "type": "background",
        "background": "500122"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "【美食殿堂】一行人\n抽到了「迷人的南國之旅」的隔天。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人、",
        "unit_id": 1,
        "voice": "vo_adv_1076001_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "晚安。",
        "unit_id": 1,
        "voice": "vo_adv_1076001_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下是可可蘿，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您永遠的忠實隨從。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不好意思這麼晚打擾。",
        "unit_id": 1,
        "voice": "vo_adv_1076001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人您",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "已經在休息了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果主人還醒著的話，",
        "unit_id": 1,
        "voice": "vo_adv_1076001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n能否和主人借用一點時間……？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的。",
        "unit_id": 1,
        "voice": "vo_adv_1076001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n那麼，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就容在下打擾了……♪",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就、",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是說呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您應該對於",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下為什麼要打扮成這個樣子，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n感到很困惑吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "前幾天",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【美食殿堂】的大家",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起抽到了頭獎……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因此主人和在下這個週末，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n不是要和大家參加一個名為",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「迷人的南國之旅」的活動嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根據目前所聽到的說法，",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎會有去海邊玩等等的活動。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n如此一來便需要準備泳裝，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n【咲戀育幼院】",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "的大家是這樣和在下說的……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因此今日就",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和咲戀小姐還有大家",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一起去買了泳裝。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然主人",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "剛好要忙其它事，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以沒辦法一起去。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下對於適不適合這件泳裝，",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還有主人喜不喜歡感到有些",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不安……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以在下，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "穿來給主人看看。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人覺得，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還、",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還適合在下嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下因為",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不太了解流行時尚，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "自己也不太會判斷……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以是咲戀小姐和大家幫忙選的，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n雖然大家都稱讚道",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "很可愛很可愛。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但如果主人不滿意的話，",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也就沒有什麼意義了……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為讓主人開心，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就是構成在下全部的要素啊。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真、",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真的嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "太好了……♪",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嘻嘻。",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這下在下安心了",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "，主人。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "原本非常不安的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "對了……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下連主人的泳裝",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也一起採買了哦。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為這件",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "完全是根據在下的喜好選的，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n所以選了和在下成對的款式",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是不好意思……♪",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如果主人不喜歡的話，",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "之後重新再去買一次吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這次的旅行因為",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "住宿費等等的全部都免費，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以就算多花一點錢",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也沒關係的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也需要旅行袋等諸多用品，",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一起去把",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其它的必需品買齊吧。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_020"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n主人，真的很令人期待呢……♪",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "…………",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_021"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有點擔心一件事。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下因為是在",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_023"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "深山裡長大的，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以沒有去海邊玩的經驗。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然有在這附近的瑪爾傑海岸沙灘上",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "散步過。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過對於能否好好地游泳這件事，",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_024"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "實在沒什麼自信。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "萬一想游泳",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "卻溺水的話……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就會掃了",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "大家難得開心出來旅行的興致呢。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唉呀，",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也露出了不安的表情……",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "因為主人",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "喪失了記憶的關係吧，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n已經不記得游泳的方法了嗎？",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但主人是",
        "unit_id": 107611,
        "voice": "vo_adv_1076001_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "無所不能、相當優秀的人，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n一定能",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好好地游泳的。",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若因為喪失記憶，",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "忘記游泳的方法",
        "unit_id": 107611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
