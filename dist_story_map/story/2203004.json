    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可等人被某人陷害，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n差點害「帕菲之城」坍塌，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n因此受到萊拉耶爾等人懷疑。"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "220300302"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了取回信任，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一行人和卡邦庫爾族的少女庫露露同行，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n前往被魔物占據的「大夢想樂園」。"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "still",
        "still": "220300401"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "然而，因為碰上了在阿斯特朗"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n不曾遇過的蜘蛛型魔物，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一行人被迫陷入了前所未有的苦戰。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "大家！",
        "unit_id": 105811,
        "voice": "vo_adv_2203004_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
