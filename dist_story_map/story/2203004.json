        "voice": "vo_adv_2203004_064"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n這次非得讓騎士們自己深入險境，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n請他們取回",
