        "voice": "vo_adv_2203004_068"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n因為「我」，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "身為一國之主",
