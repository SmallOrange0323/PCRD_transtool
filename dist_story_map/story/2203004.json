    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "…………",
        "unit_id": 126511,
        "voice": "vo_adv_2203004_013"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……在「大夢想樂園」的戰鬥，",
        "unit_id": 126511,
        "voice": "vo_adv_2203004_014"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n似乎已經開始了……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "看來，",
        "unit_id": 126511,
        "voice": "vo_adv_2203004_015"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "他們已經陷入了苦戰……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "若不是從騎士們的世界跑來的魔物，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "那難道是從「那邊」來的？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n像這樣一次流入如此大量的魔物，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我記得以往沒有發生過……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……再加上，",
        "unit_id": 126511,
        "voice": "vo_adv_2203004_016"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n騎士們",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "並不曉得，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n我正透過交給庫露露的",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "通訊魔法道具，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "聽著他們的對話……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "雖然拜託琳德和烏爾姆，",
        "unit_id": 126511,
        "voice": "vo_adv_2203004_017"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "她們就能在不被任何人發現的情況下，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n順利替我完成任務。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "但她們兩個，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "還只是孩子……",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "我不希望她們因為這種狡猾的方法，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "弄髒了自己的雙手。",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……可是……",
        "unit_id": 126511,
        "voice": "vo_adv_2203004_018"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "──公主殿下～？",
        "unit_id": 126411,
        "voice": "vo_adv_2203004_019"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "公～主～殿～下～！",
