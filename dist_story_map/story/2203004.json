        "voice": "vo_adv_2203004_001"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "對對對對不起！",
        "unit_id": 130911,
        "voice": "vo_adv_2203004_002"
    },
    {
        "type": "dialogue",
        "name": "庫露露",
        "words": "\n都怪我，害你們需要來保護我～！！",
        "unit_id": 130911
    },
