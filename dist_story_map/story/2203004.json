        "voice": "vo_adv_2203004_021"
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "\n妳剛剛，",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "說了什麼？",
        "unit_id": 126511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我果然還是",
        "unit_id": 126411,
        "voice": "vo_adv_2203004_022"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不能去幫騎士先生他們嗎？",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就算魔物先生來到城裡，",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n只要沃爾加諾他們在就沒問題吧！",
        "unit_id": 126411
    },
    {
        "type": "dialogue",
        "name": "萊拉耶爾",
        "words": "……",
