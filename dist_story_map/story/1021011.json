        "voice": "vo_adv_1021011_021"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "現、",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "現在就去嗎……！？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n但是，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "票怎麼辦……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
