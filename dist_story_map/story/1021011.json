        "voice": "vo_adv_1021011_020"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "更不敢報名甄選了……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n可、",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "可是……",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我卻又無法放棄……！",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "咦……？",
