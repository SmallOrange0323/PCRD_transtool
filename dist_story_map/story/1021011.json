        "type": "dialogue",
        "name": "胡桃",
        "words": "……奇怪？",
        "unit_id": 102131,
        "voice": "vo_adv_1021011_013"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "還有另一道影子？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "啊",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "是哥哥！？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "你怎麼會在這裡！？",
