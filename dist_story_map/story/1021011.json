    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了慈善義演，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}這天也陪胡桃對練，"
    },
    {
        "type": "dialogue",
