        "voice": "vo_adv_1021011_014"
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "因為我看起來沒什麼精神，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "就去了我家……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n然後，",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我媽媽",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "告訴了你",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "我在這裡……？",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "\n",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "哥哥",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "在為我擔心呀♪",
        "unit_id": 102131
    },
    {
        "type": "dialogue",
        "name": "胡桃",
        "words": "其實，",
