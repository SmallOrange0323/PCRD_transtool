    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵、呵、呵……",
        "unit_id": 100911,
        "voice": "vo_adv_5008101_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n我乃安妮羅潔‧馮‧修特帕魯！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n人稱",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "疾風之冥姬！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "被貧窮壓得喘不過氣的杏奈美眉為了求一份工作，",
        "unit_id": 101311,
        "voice": "vo_adv_5008101_001"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而前往了溪谷洞窟。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "而那悽涼的背影，",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "便是她",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "最後的身影了……",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "完。",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "七七香，",
        "unit_id": 100911,
        "voice": "vo_adv_5008101_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不要把話講得這麼可怕啊。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "雖然沒錢倒是真的……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "然而，",
        "unit_id": 100911,
        "voice": "vo_adv_5008101_003"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "看看這個！",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n藉由這尋求志願者的公告，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我的困境也將獲得淨化。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "呵、呵、呵……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我都快被自己的強運給閃瞎了呢。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "若翻成人話，",
        "unit_id": 101311,
        "voice": "vo_adv_5008101_004"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "撿到意外還不賴的打工傳單所以安啦！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "\n",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "――是這樣的意思吧♪",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還真一如往常的熱鬧呢，",
        "unit_id": 105611,
        "voice": "vo_adv_5008101_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "妳們幾個。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "哦哦，",
        "unit_id": 101311,
        "voice": "vo_adv_5008101_006"
    },
    {
        "type": "dialogue",
        "name": "七七香",
        "words": "流夏大姐來啦～！",
        "unit_id": 101311
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別叫我大姊頭呀……",
        "unit_id": 105611,
        "voice": "vo_adv_5008101_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "話又說來這還真是巧呢，",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "大家都有事前往同樣的方向。",
        "unit_id": 105611
    },
    {
        "type": "dialogue",
        "name": "流夏、修特帕魯、七七香",
        "words": "下回，",
        "unit_id": 1,
        "voice": "vo_adv_5008101_008"
    },
    {
        "type": "dialogue",
        "name": "流夏、修特帕魯、七七香",
        "words": "「暮光破壞者」",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "來吧，",
        "unit_id": 105611,
        "voice": "vo_adv_5008101_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "就讓我們一起踏上冒險的旅程吧！",
        "unit_id": 105611
    }
]