[
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "閉幕式啊……",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯，",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那時候也發生很多事呢。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "對啊，",
        "unit_id": 116211,
        "voice": "vo_adv_5064606_001"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n是超大型的笨蛋事件呢。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "先是這個在這邊這樣那樣，",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "那個又在那邊那樣這樣。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "全是指示代名詞，",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "根本沒有敘述重點嘛。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "所謂的模糊不清。",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "沒啦，我也是在替妳們著想啊。",
        "unit_id": 116211,
        "voice": "vo_adv_5064606_004"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "妳們也不太想回想起來吧？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n琪愛兒逃跑",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "跟優妮學姐的黏土像失控亂來之類的。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "有發生那種事嗎？",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "咦，",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我沒有任何印象呢。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "我記得最後的演唱會上，",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_007"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n克蘿依學姐倒是意外地很起勁耶。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就是說啊。",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我記得克蘿依的舞步意外地華麗呢。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "那是什麼時候練習的啊？",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_009"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "看起來絕對不是",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "隨興演出的等級對吧。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊？",
        "unit_id": 116211,
        "voice": "vo_adv_5064606_010"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "什麼？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n妳們對我在半夜偷練用途不明的舞蹈有什麼意見嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "啊啊？妳們",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "是想打架嗎？",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "要打的話",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就到外面去啊。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "哎呀～",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_011"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "說起來還是很有趣的嘛，",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "這個聖學祭。",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不准無視我啊妳這傢伙。",
        "unit_id": 116211,
        "voice": "vo_adv_5064606_012"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n要打的話",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "就來啊妳這傢伙。",
        "unit_id": 116211
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "明年也",
        "unit_id": 116311,
        "voice": "vo_adv_5064606_013"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "大家一起切嚕地參加祭典吧！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "好朋友社是永遠不滅的！",
        "unit_id": 116311
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是啊，",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n優妮們是永遠不滅──",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "──咦？",
        "unit_id": 116411,
        "voice": "vo_adv_5064606_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n等等。",
        "unit_id": 116411
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "明年我不就畢業了嗎？",
        "unit_id": 116411
    }
]