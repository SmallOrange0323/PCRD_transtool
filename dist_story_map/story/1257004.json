[
    {
        "type": "background",
        "background": "500371"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被花凜叫了出來，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再次造訪了公會管理協會。"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您好。",
        "unit_id": 118511,
        "voice": "vo_adv_1257004_000"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "謝謝您",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "在百忙之中撥冗赴約。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我的冒險者實習已經結束了，",
        "unit_id": 118511,
        "voice": "vo_adv_1257004_001"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n所以想跟您報告一下。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊，",
        "unit_id": 118511,
        "voice": "vo_adv_1257004_002"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "請不要誤會。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "絕對不是負面意義。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "應該說是",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "完成目的後，順利畢業吧。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "多虧跟您一起冒險，",
        "unit_id": 118511,
        "voice": "vo_adv_1257004_003"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我學到了不少東西。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我會將這份經驗",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "好好運用在今後的業務上。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不，",
        "unit_id": 118511,
        "voice": "vo_adv_1257004_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "沒有那回……",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "不如說，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "對我而言，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "面對冒險總是勇往直前的您，看起來才閃閃發光喔。",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "倒不如說，",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "您真的在發光？",
        "unit_id": 118511
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "啊……！",
        "unit_id": 118511
    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}受到佳凜邀約，來到了鬧區。"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "您好。",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_005"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "時間正好。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "真不愧是您。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我今天是",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_006"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "希望能和您吃頓美食，聊聊天，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n才會找您出來……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "沒什麼好隱瞞的，",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_007"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "坦白回答的話……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "是的，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "您說的對。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我隸屬的人才發掘公司",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_008"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n也曾挖角過年紀比您小的人士。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "您還是學生，不必顧慮太多啦。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我明白您的各種擔憂，",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_009"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不過今天就一起吃頓飯吧！",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "其實，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我已經預約了這附近的知名餐廳。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這家店要是錯過這次，就不曉得何時才預約得到。",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_010"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "所以！",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "您務必要來！",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我們走吧！",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被佳凜的氣勢壓倒，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n決定跟著她一起走。"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "就是這家店……",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_011"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "奇怪？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n看板沒有拿出來，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "也沒有半個客人。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "現在是營業時間，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我應該也完成預約了……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這是……",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_012"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "有公告呢。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n「本日，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "由於主廚突然生病，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "臨時停業」……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n咦咦！？",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我從之前",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_013"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "就對這家店很感興趣，已經搜尋過了……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n全部的美食評論網站，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "評價都超過四星喔。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我配合預約好的套餐，",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_014"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "甚至計算卡路里到個位數，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n晨跑的距離也",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "配合卡路里作了調整……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "突然生病也沒辦法。",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_015"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "希望對方能早日康復吧。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "說的也是。",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_016"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "那麼，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我來搜尋看看附近的店家吧。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "「目前所在地、",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "午餐、",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "高評價」……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "對了，您知道嗎？",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_017"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n可以從搜尋引擎，避開以促銷為目的的情報……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "呀啊！",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "哇！",
        "unit_id": 1,
        "voice": "vo_adv_1257004_018"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "啊啊！",
        "unit_id": 1,
        "voice": "vo_adv_1257004_019"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "對不起！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n真是的！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "我說過不要在這種人多的地方奔跑吧？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n請問，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "您有沒有受傷？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "沒事，",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_020"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我沒有受傷……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "不好了！",
        "unit_id": 1,
        "voice": "vo_adv_1257004_021"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "手機摔到黑屏了……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n過來，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "好好跟大姐姐道歉！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "對不起……",
        "unit_id": 1,
        "voice": "vo_adv_1257004_022"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "真的非常抱歉。",
        "unit_id": 1,
        "voice": "vo_adv_1257004_023"
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "\n我會賠償您的，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "請給我您的聯絡方式……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不用了不用了，",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_024"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "不要緊的。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n我想說可能會發生這種事，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "已經有投保了。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "您不必支付",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我的維修與更換的費用。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "母親",
        "words": "可是……",
        "unit_id": 1,
        "voice": "vo_adv_1257004_025"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "真的沒關係啦。",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_026"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "再說，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "小孩子的工作就是要充滿活力。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "\n",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "但是，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "這樣很危險，",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "下次奔跑時請好好看著前面喔。",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "小孩",
        "words": "好──！",
        "unit_id": 1,
        "voice": "vo_adv_1257004_027"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "對不起，",
        "unit_id": 118531,
        "voice": "vo_adv_1257004_028"
    },
    {
        "type": "dialogue",
        "name": "佳凜",
        "words": "我的裝置已經無法搜尋了……",
        "unit_id": 118531
    },
    {
        "type": "dialogue",
        "name": "佳凜",
