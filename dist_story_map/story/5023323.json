[
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "喂，",
        "unit_id": 110911,
        "voice": "vo_adv_5023323_000"
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "它暴走得很誇張耶！？",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "\n",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "琪愛兒",
        "words": "太扯了吧～！",
        "unit_id": 110911
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "各位，危險啊！　",
        "unit_id": 110711,
        "voice": "vo_adv_5023323_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請退到後面！！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不過，",
        "unit_id": 111011,
        "voice": "vo_adv_5023323_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "現在也沒辦法講這種話了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "眼前有這麼一大筆錢……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哎呀，我什麼都沒說。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "不過說真的，",
        "unit_id": 110811,
        "voice": "vo_adv_5023323_003"
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "現在已經不是說什麼要捕捉它的時候了？",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "\n",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "克蘿依",
        "words": "弄不好的話我們恐怕會反過來變成它的獵物。",
        "unit_id": 110811
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "原本那麼小株的曼德拉草，",
        "unit_id": 110711,
        "voice": "vo_adv_5023323_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "竟然會變這樣……",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "至少讓我幫你解脫吧……！",
        "unit_id": 110711
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "嗯……",
        "unit_id": 111011,
        "voice": "vo_adv_5023323_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我沒辦法背叛溫柔的碧，做出那種行為。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我們也",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "尊重她的意志吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "前往最後一役吧！　",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優妮們，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "使出全力解放吧！",
        "unit_id": 111011
    }
]