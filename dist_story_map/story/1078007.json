[
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "今天也一如往常勤奮打工的凱留與{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n兩人正一起在休息。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呼，",
        "unit_id": 107812,
        "voice": "vo_adv_1078007_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "今天客人也很多呢……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "應該說",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺客人變得比我剛開始打工時還多了。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "什麼？",
        "unit_id": 107812,
        "voice": "vo_adv_1078007_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這怎麼可能。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不過",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我在工作時的確會",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感受到奇妙的視線，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n或是有人來找我說話呢。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣的話，",
        "unit_id": 107812,
        "voice": "vo_adv_1078007_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不就是我自己給自己增加工作的，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "討厭！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……可是",
        "unit_id": 107812,
        "voice": "vo_adv_1078007_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然滿累人的，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但這樣的工作比想像中還開心呢。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或許是以前",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也做過一些不可告人的工作，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以才更這麼覺得吧。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算如此，忙過頭也很麻煩呢……",
        "unit_id": 107812,
        "voice": "vo_adv_1078007_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不覺得今天的陽光特別大嗎？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……不對，",
        "unit_id": 107812,
        "voice": "vo_adv_1078007_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這不是陽光……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀啊！",
        "unit_id": 107812
    },
    {
        "type": "background",
        "background": "510350"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "欸，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_006"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你最近總是跟我在一起吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n你很閒嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "沒有朋友嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "別用問題反問我的問題！",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_007"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "話說，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "當然不是了啊！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不對，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "應該",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "算是吧……？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我們三不五時會像這樣見面，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_008"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "還一起去過海邊了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嗯～",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我好像也不太清楚耶。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……我們當時走了那麼久的路，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_009"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "等到的時候天都已經完全黑了，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n還真虧你",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "能露出一臉在回想美好回憶的表情耶。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_010"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不可思議地是",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我也覺得很愉快呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然那樣也讓人很滿足，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_011"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過很難說是有真正去海邊玩過呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n畢竟又沒穿泳裝，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "而且也沒有到海裡去玩。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "所以",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_012"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我遲早要",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "自己存錢實現這個願望。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "到時候我也會找你的。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n反正你也很閒吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這可不行。",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_013"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你的提議，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_014"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "嗯……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那個，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我是覺得很開心。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但是讓你幫我出錢，感覺好像不太對。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "唉，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_015"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "由曾經想敲詐你的我這麼說，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "還真沒說服力。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "真是的，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_016"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你到底是有多爛好人啦。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我就算說不行，感覺你也不會聽……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "對了！",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_017"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n正好那邊有賣彩券的地方，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我們去買彩券吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "所以你也出一半的錢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這樣姑且就能當作他有幫過忙，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_018"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n而且100日圓程度的話，我也不需要太在意。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……沒想到",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_019"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "居然真的中獎了。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然不是什麼大錢，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但對國中生來說也算是一筆不錯的臨時收入。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "因為根本沒想到會中獎，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_020"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "所以完全沒想過這筆錢要怎麼用呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "怎麼辦？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "要不去吃漢堡吧？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "泳裝？",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_021"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這的確是差不多夠買泳裝的錢……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n而且",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你也幫忙出了一半的錢，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n所以你也有權利決定這筆錢要怎麼用。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "那麼",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_022"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "去泳裝店吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你要是敢選像之前那種沒品味的泳裝，我可不放過你！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "……真是服了。",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_023"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我只顧著想要買泳裝，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n結果徹底忘了現在不是那種季節。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "畢竟是這種時期，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_024"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "種類和款式不多也是當然的呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "再說",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就算買了泳裝",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "去海邊，也不可能下水游泳啊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "季節問題又不是你的錯。",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_025"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "而且",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "錢又不會消失，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "只要先存起來就行了呀。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_026"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "難得天外飛了一個幸運機會，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n如果什麼都不做感覺也很浪費呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "雖然是不會花大錢去玩，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_027"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但去附近的海邊玩……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "對了！",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "欸，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_028"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我剛好有個想法。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………"
    },
    {
        "type": "still",
        "still": "107800701"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "趁勢就來到隔壁鎮的室內游泳池了。",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_029"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n我已經有多久",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "沒來過這種地方了呢？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "謝謝。",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_030"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過租借的泳裝也沒有什麼適不適合的吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "話又說回來，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_031"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "原本是想代替海邊才來的，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n結果這裡既沒有自然景色，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "也沒有像水上樂園那種能玩樂的遊樂設施。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "泳裝也完全不是我喜歡的類型，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_032"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "老實說和我的理想相去甚遠。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "但是",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_033"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不知為何",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我卻完全不討厭。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "何止如此，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我甚至感到非常滿足。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n……啊，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "原來如此。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "這肯定是因為有他陪在我身邊。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "真正重要的事，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_034"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "大概不是去哪裡，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n或是花了多少錢……",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "其實",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "是和他在一起吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我因為周圍環境的關係，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_035"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "擅自把自己當成了悲劇的女主角，",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "不過我似乎也單純到這點程度",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "就能滿足了呢。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我很感謝他讓我注意到這一點。",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_036"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "可是",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "我不太想這麼",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "坦率地承認。",
        "unit_id": 106031
    },
    {
        "type": "still",
        "still": "107800702"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "欸，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_037"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你快點",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "教我怎麼游泳吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n否則去海邊卻不會游泳，不就全都白搭了嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "咦？",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_038"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你也不會游泳嗎？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你都高中生了，還真沒出息耶。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "你這樣子還打算跟我去海邊啊？",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "算了，",
        "unit_id": 106031,
        "voice": "vo_adv_1078007_039"
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "一起來練習吧。",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "\n那麼首先是",
        "unit_id": 106031
    },
    {
        "type": "dialogue",
        "name": "希留耶",
        "words": "練習踢水！",
        "unit_id": 106031
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1078007_040"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦你了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然看著凱留後",
        "unit_id": 190011,
        "voice": "vo_adv_1078007_041"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "讓人覺得心裡感到難過，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n已經不是一兩次的事了……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但每當那時候她身邊都有你在，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "我真的覺得太好了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "和你相遇後",
        "unit_id": 190011,
        "voice": "vo_adv_1078007_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她確實開始改變了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "她變得不是詛咒自己的處境，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "而是挺身面對困境。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "想必她的未來",
        "unit_id": 190011,
        "voice": "vo_adv_1078007_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "肯定就在你身上。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要與她共同邁進、",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "戰鬥，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "接著迎接幸福結局喔！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以",
        "unit_id": 190011,
        "voice": "vo_adv_1078007_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "今天就到這裡。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你要加油喔～",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯，",
        "unit_id": 107812,
        "voice": "vo_adv_1078007_045"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "奇怪？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我睡著了……？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n居然會在休息時睡著，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我到底是有多累啊。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話說，",
        "unit_id": 107812,
        "voice": "vo_adv_1078007_046"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我覺得又夢到在其他世界的自己了。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "夢裡我還是一樣不回家在外頭閒晃，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "然後……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "欸，",
        "unit_id": 107812,
        "voice": "vo_adv_1078007_047"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這世界的我過得還算幸福，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳也要相信那邊的那傢伙，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好好過活喔。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那一定就是",
        "unit_id": 107812,
        "voice": "vo_adv_1078007_048"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "通往幸福的捷徑。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 107812,
        "voice": "vo_adv_1078007_049"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有小睡過感覺暢快多了，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來勤奮工作吧。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在前往憧憬的南島前，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "可沒有空能夠停下來休息！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "凱留如此說道，並露出開朗的表情笑了起來。"
    }
]