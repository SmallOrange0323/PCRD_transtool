    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "{player}主人……",
        "unit_id": 105931,
        "voice": "vo_adv_4010174_000"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "呵呵，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "約定碰面這件事",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真是令人內心雀躍呢。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "而且",
        "unit_id": 105931,
        "voice": "vo_adv_4010174_001"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "又是在自己生日的時候，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n連等待的時間",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "都像是美好的禮物般……♪",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "不會，",
        "unit_id": 105931,
        "voice": "vo_adv_4010174_002"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您是",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "我的主人。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "要是您先到了，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "我反而會感到困擾。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "而且……",
        "unit_id": 105931,
        "voice": "vo_adv_4010174_003"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "從遠處過來的您，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n在看到我時",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "微笑的那一瞬間。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "我就是",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "想看到那個。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "謝謝您，",
        "unit_id": 105931,
        "voice": "vo_adv_4010174_004"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人……♪",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您還像這樣準備了給我的禮物，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "我真的",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "感到很幸福……！",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "……那個。",
        "unit_id": 105931,
        "voice": "vo_adv_4010174_005"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n都讓您為我慶祝，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "還送禮了。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "我又要做出這種請求的話，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "實在是有些惶恐……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "可以將您今天一整天的時間",
        "unit_id": 105931,
        "voice": "vo_adv_4010174_006"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "都給我嗎？",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "您",
        "unit_id": 105931,
        "voice": "vo_adv_4010174_007"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "如此忙碌，",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n我知道這請求",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "過於奢侈了……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真的嗎……！？",
        "unit_id": 105931,
        "voice": "vo_adv_4010174_008"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "我",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "真的可以",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "這麼幸福嗎……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "那麼，",
        "unit_id": 105931,
        "voice": "vo_adv_4010174_009"
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "主人。",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n今天的我",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "可能會有些任性……",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "\n還請您",
        "unit_id": 105931
    },
    {
        "type": "dialogue",
        "name": "可蘿",
        "words": "多加擔待了……♪",
        "unit_id": 105931
    }
]