[
    {
        "type": "dialogue",
        "name": "魔物群",
        "words": "────咕哦哦哦哦哦！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "等等等這這這魔物的數量是怎麼回事！",
        "unit_id": 128011,
        "voice": "vo_adv_5132321_000"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n就算是因惡性通膨而印太多的鈔票，\n也不會不斷冒出這麼多啊！？",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "雖然剛剛那一群",
        "unit_id": 6111,
        "voice": "vo_adv_5132321_001"
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "就這樣直接經過了，",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "\n",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "但認為",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "這次也會……",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "秘書",
        "words": "看來是預估得太天真了呢。",
        "unit_id": 6111
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次的魔物們",
        "unit_id": 127911,
        "voice": "vo_adv_5132321_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n似乎被那隻巴西利斯克觸發了殘暴性！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n看來是不會放過我們的啊！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "啊啊，真是夠了，",
        "unit_id": 128011,
        "voice": "vo_adv_5132321_003"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "實在麻煩！",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但是，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "果然還是不能放著不管呢……",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "沒錯，",
        "unit_id": 127911,
        "voice": "vo_adv_5132321_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要是湧入城中之類的，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那才真的會演變為嚴重的事態。",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "而且……",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "而且？",
        "unit_id": 128011,
        "voice": "vo_adv_5132321_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那群魔物",
        "unit_id": 127911,
        "voice": "vo_adv_5132321_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "相當好吃喔！",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我們一邊討伐，",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也一邊同時取得食材吧☆",
        "unit_id": 127911
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "唉……",
        "unit_id": 128011,
        "voice": "vo_adv_5132321_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我就覺得會變成這樣。",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "好的，",
        "unit_id": 128011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "既然如此就上吧！",
        "unit_id": 128011
    }
