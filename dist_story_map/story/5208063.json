[
    {
        "type": "background",
        "background": "502660"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在另一天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜請志那都帶她遊覽了東國。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來在遠離城鎮後，",
        "unit_id": 108912,
        "voice": "vo_adv_5208063_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有這麼一片寧靜的地方呀。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "志那都，",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "妳之前是想帶我來這裡嗎？",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是啊，",
        "unit_id": 135612,
        "voice": "vo_adv_5208063_001"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "我想說兩人一起釣魚或許不錯。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n在這裡",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "也可以悠閒地聊個天……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是不是",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "太無聊了呢？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "沒那回事，",
        "unit_id": 108912,
        "voice": "vo_adv_5208063_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我最喜歡釣魚了。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也很樂意跟妳悠閒自在地聊聊。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要釣魚的話，",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在這附近釣怎麼樣？",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哦，",
        "unit_id": 6411,
        "voice": "vo_adv_5208063_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看來",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我妨礙到妳們了啊。",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n需要我換個位置嗎？",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是先來的人啊……",
        "unit_id": 135612,
        "voice": "vo_adv_5208063_004"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "你不用那麼顧慮我們。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "先不說這個，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "怎麼樣？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "這裡釣得到嗎？",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯，",
        "unit_id": 6411,
        "voice": "vo_adv_5208063_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "還算過得去啦……",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "咦，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "慢著慢著，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n妳不是",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "管理者志那都大人嗎！？",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哦哦，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "今天還真走運啊！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嘿嘿，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "看來今天一定能大豐收！！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "不對，",
        "unit_id": 135612,
        "voice": "vo_adv_5208063_006"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "是前管理者。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……而且我記得，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "你是……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我記得",
        "unit_id": 108912,
        "voice": "vo_adv_5208063_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個人是",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和正。",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n他是在大間海域當漁夫的大海男兒──",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "啊！",
        "unit_id": 6411,
        "voice": "vo_adv_5208063_008"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "麻煩人物追過來了！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "那，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "我要",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "先溜囉！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "請您留步──！！",
        "unit_id": 1,
        "voice": "vo_adv_5208063_009"
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "\n您又打扮成那樣跑出城了……！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "今天我一定不會讓您逃掉的，",
        "unit_id": 1,
        "voice": "vo_adv_5208063_010"
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "和正公──！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "和正公……",
        "unit_id": 135612,
        "voice": "vo_adv_5208063_011"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "對了，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "那個男人。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n他是有著「雷鳴之白髯公」這外號的將軍，",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "\n東國第八代將軍──",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "和正公啊。",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "將軍！？",
        "unit_id": 108912,
        "voice": "vo_adv_5208063_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他、",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "他看起來並不像那種人啊……",
        "unit_id": 108912
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "嘿嘿，",
        "unit_id": 6411,
        "voice": "vo_adv_5208063_013"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "這座城鎮對我而言",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "有點",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "太拘束了！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "我要出海去！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n然後把傳說中的巨大金槍鮪",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "釣上來！！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "對了！！",
        "unit_id": 6411,
        "voice": "vo_adv_5208063_014"
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n從今天開始，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "將軍的位子就讓給志那都大人了！！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "\n",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "事情就是這樣，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "之後就麻煩妳囉，",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "和正",
        "words": "新將軍！！",
        "unit_id": 6411
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……什麼？",
        "unit_id": 135612,
        "voice": "vo_adv_5208063_015"
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "真是個亂來的將軍……",
        "unit_id": 1,
        "voice": "vo_adv_5208063_016"
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "不過，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "\n志那都大人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "既是前管理者，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "也是這世界的救世主。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "\n作為將軍",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "可說是再適合不過了──",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "……別看我。",
        "unit_id": 135612,
        "voice": "vo_adv_5208063_017"
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "拜託您了！！",
        "unit_id": 1,
        "voice": "vo_adv_5208063_018"
    },
    {
        "type": "dialogue",
        "name": "奉行",
        "words": "\n志那都將軍！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "慢、",
        "unit_id": 135612,
        "voice": "vo_adv_5208063_019"
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "慢著……",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "志那都",
        "words": "別把我扛起來！",
        "unit_id": 135612
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……她當上將軍了……",
        "unit_id": 108912,
        "voice": "vo_adv_5208063_020"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "志那都就這樣成為了東國第九代將軍，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n但她之後抓住了逃跑的和正，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "把將軍的位子還了回去。"
    }
]