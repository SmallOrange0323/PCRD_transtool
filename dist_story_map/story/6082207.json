    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "お化け屋敷も始まって、",
        "unit_id": 114011,
        "voice": "vo_adv_6050207_000"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ようやくこの衣装にも慣れてきたかな。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ドレスに身を包んで人を驚かすなんて、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\nなかなかできることじゃないから、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "面白い経験だよ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "少しだけ。",
        "unit_id": 114011,
        "voice": "vo_adv_6050207_001"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "あ、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "いや、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "あくまでお化け屋敷の中だけだよ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n普段からいたずらするなんて……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ああ、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "でも",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n貴族の連中を相手にいたずらしてみるのは、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "いいかもしれないね。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "い、",
        "unit_id": 114011,
        "voice": "vo_adv_6050207_002"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "一応私なりに努力しているんだ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "キミには通じていない、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "のかな？　",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "えっと、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "じゃあ、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "その……",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ダメだ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "キミ相手に演技なんて、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "上手くできそうにないよ。",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "ツムギもそう言っていたね。",
        "unit_id": 114011,
        "voice": "vo_adv_6050207_003"
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "最初は楽しめるわけないと思っていたけど、",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "\n",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "私にも",
        "unit_id": 114011
    },
    {
        "type": "dialogue",
        "name": "レイ",
        "words": "意外といたずらっこの才能があったのかな？",
        "unit_id": 114011
