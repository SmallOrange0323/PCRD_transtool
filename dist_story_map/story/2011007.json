[
    {
        "type": "background",
        "background": "500570"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然是可喜可賀",
        "unit_id": 104711,
        "voice": "vo_adv_2011007_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "可喜可賀的氣氛……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我也很討厭像這樣壞人好事，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是我不能就這樣放過你們呢。",
        "unit_id": 104711
    },
    {
        "type": "background",
        "background": "500570"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "呵呵。",
        "unit_id": 105911,
        "voice": "vo_adv_2011007_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n終於，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "變回了像往常一樣的貪吃佩可小姐了呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實……",
        "unit_id": 105911,
        "voice": "vo_adv_2011007_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n因為被囚禁了好一陣子，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以有點軟腳了對吧？",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "讓主人來抱著您，",
        "unit_id": 105911,
        "voice": "vo_adv_2011007_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下認為似乎也是合情合理的呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不是呀～",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實我也沒有被關那麼久就是了呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但如果沒有穿上『皇家裝備』，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我的",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "運動能力可就是在平均值之下的呀。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果能夠抱著我走，",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_005"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "可就真是幫了大忙呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我可要再抱緊一點囉，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱緊～♪",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈～",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對不起♪",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "哦哦？",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_007"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然你都這樣講了，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就恭敬不如從命囉……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "抱緊緊♪",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "欸嘿嘿。",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_008"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "其實，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我因為沒什麼力氣了，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "所以如果不抱緊一點就會掉下去了……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n而且",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是在說出類似於愛的告白之後，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "總覺得氣氛好像有點尷尬呀。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105911,
        "voice": "vo_adv_2011007_009"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那名為『皇家裝備』之物，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倘若可以還想把它給收回呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟到逃出之前，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可能還得",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和警衛兵屢次交戰呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而在下和主人，",
        "unit_id": 105911,
        "voice": "vo_adv_2011007_010"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也都差不多到極限了……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所以若貪吃佩可小姐您能一塊戰鬥，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "情況將會改善許多。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～呣……",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_011"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在我被關起來的時候，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n『皇家裝備』被他們給沒收了就是。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果沒有被送到別的地方的話，",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_012"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n我想大概",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會在『王宮』的寶物庫裡才對。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對我來說，",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_013"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這可就像自家後院，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那裡要怎麼去我都一清二楚唷。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n只要稍微繞點路",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就可以去拿回來了，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "要怎麼辦呢？",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "以我個人來說，想把這件事先放一邊，",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_014"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n還是希望先讓{player}你們能夠沒事逃出去就好。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "但如果我不能夠戰鬥的話，",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "逃脫的難易度卻又會上升不少……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真讓人傷透腦筋呢。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "從頭到尾，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這次完全就只是",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在拖你們的後腿呀，真抱歉。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "絕對沒有。",
        "unit_id": 105911,
        "voice": "vo_adv_2011007_016"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是為了一報總是受到您幫助的恩情唷，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "貪吃佩可小姐。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在這難以分清東西南北的都會蘭德索爾之中，",
        "unit_id": 105911,
        "voice": "vo_adv_2011007_017"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n若當初就只有在下和主人兩人，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一定早就不知道該何去何從了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而託了和【美食殿堂】大家交流的福，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "才能夠安然地過生活呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "如此大恩大義，",
        "unit_id": 105911,
        "voice": "vo_adv_2011007_018"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不報可不行呢。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是受點小傷、",
        "unit_id": 105911,
        "voice": "vo_adv_2011007_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "一點勞累，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又或者多少冒點危險",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "都只是小事一件。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這點事和將奇異料理送進嘴裡所抱的覺悟比起來，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "根本就還不算些什麼。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈。",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_020"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真的變得很堅強了呢，",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是可靠呀……",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你們兩位。",
        "unit_id": 105813
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105813,
        "voice": "vo_adv_2011007_021"
    }
]