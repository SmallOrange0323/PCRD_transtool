    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "你想要更了解雷姆？",
        "unit_id": 109811,
        "voice": "vo_adv_6017305_000"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雖然我不知道你知道這個要做什麼，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不過我就告訴你吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "想知道什麼就儘管問拉姆吧。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "嗯。",
        "unit_id": 109811,
        "voice": "vo_adv_6017305_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "她真的是個完美的妹妹。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n家事做得好，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "懂得體貼他人，人又善良。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真的和拉姆一模一樣。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雷姆喜歡的人",
        "unit_id": 109811,
        "voice": "vo_adv_6017305_002"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "當然是我拉姆啊。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "雖然她最近好像跟眼神兇惡的男人走得很近。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "她是我心愛的妹妹。",
        "unit_id": 109811,
        "voice": "vo_adv_6017305_003"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "這一點是不會變的。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "所以，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "不管發生什麼事我都會保護她。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "就算捨棄一切，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "也絕對會守護到底。",
        "unit_id": 109811
    }
]