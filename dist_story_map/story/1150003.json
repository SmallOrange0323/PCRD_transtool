[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "吃飽喝足的似似花和{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n再次漫步於繁華街上。"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那麼，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "接下來要去買什麼呢？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n難得有個人能幫忙提東西，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n似乎是個",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "買大型物品的好機會呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我想想，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "把書架上的整排書都買下來好像不錯。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n椅子也差不多該換新了，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還有──",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "跟你開玩笑的。",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我本來就沒對你的力氣抱有期待。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那邊的服裝店",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "在做新年特賣呢，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們去看看吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "跟我來。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不好意思，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請問女裝區在──",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "哎呀！",
        "unit_id": 411,
        "voice": "vo_adv_1150003_005"
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "真是可愛的小妹妹呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "\n和服很適合妳哦，",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "是媽媽幫妳穿的嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我再問一次，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請問女裝區在哪裡？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "和哥哥一起用壓歲錢買東西",
        "unit_id": 411,
        "voice": "vo_adv_1150003_007"
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "很開心吧？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "有沒有拿到很多壓歲錢呀？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "呵呵，",
        "unit_id": 411,
        "voice": "vo_adv_1150003_008"
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "想裝小大人的樣子真可愛。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "\n正好到了想穿成熟服裝的年紀呢。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_009"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我都說了……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "但是，",
        "unit_id": 411,
        "voice": "vo_adv_1150003_010"
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "那邊的女裝",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "對小妹妹來說還太早了哦？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "\n",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "我帶妳去兒童服裝區吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "那裡有非常多可愛的衣服，",
        "unit_id": 411,
        "voice": "vo_adv_1150003_011"
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "\n和哥哥一起慢慢挑吧。",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_012"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "無法溝通呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "算了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "小妹妹？",
        "unit_id": 411,
        "voice": "vo_adv_1150003_013"
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "這就要走了嗎？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "女性店員",
        "words": "\n……有這麼想穿大人的衣服啊？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……真是的，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_014"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真讓人困擾。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒人教過",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那位店員，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n不能以外表判斷一個人嗎？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想到她用那種待客方式",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還能拿到工資，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就一肚子火。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我創造出的冒牌貨，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_017"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都能做得比她更好吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "啊，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "乾脆用冒牌貨換掉她好了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……說得也是。",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我有點太激動了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n再繼續為那種胡言亂語而發火，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n就太拉低自己的格調了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我甚至有點開始埋怨",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_019"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剛剛的自己考慮不周，\n誇口說要",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "讓你見識真正的購物了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "轉換心情，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_020"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "去別間店吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n對了，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那種能享受閒暇時光的娛樂項目好像不錯。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "娛樂項目中有許多和體格沒什麼關係的活動，對我來說正合適。",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_021"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "特別是「遊戲」",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "，對玩家的容貌體型幾乎沒有任何要求，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是最令人滿意的娛樂活動。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "還有，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_022"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我們分頭進下一間店吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n像剛才那樣和你走在一起，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "又有可能會被誤認成兄妹。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請你自己在旁邊逛吧。",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_023"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那麼，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我先走了。",
        "unit_id": 115011
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "歡迎光臨！",
        "unit_id": 1411,
        "voice": "vo_adv_1150003_024"
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "哦，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "小妹妹真了不起呢，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "\n竟然自己出來買東西。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "有沒有拿到很多壓歲錢啊？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "唔，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_025"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這裡也是……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我要保持冷靜……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那個，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "請問遊戲區在……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "遊戲啊？",
        "unit_id": 1411,
        "voice": "vo_adv_1150003_026"
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "可是",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "對小妹妹妳來說會不會太困難啦？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "我們店裡有很可愛的人偶，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "\n還有很多鈴鈴噹的周邊商品喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_027"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我不需要。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我想買遊戲──",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "對了，",
        "unit_id": 1411,
        "voice": "vo_adv_1150003_028"
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "這個很適合小妹妹妳！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "看！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "是兒童福袋！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "\n裡面有人偶和首飾，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "還有一些簡單的小遊戲喔！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_029"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我已經",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "忍無可忍了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我無法容許這傢伙繼續胡說八道。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n讓我把整間店轟飛……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你要做什麼。",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我要把這傢伙燒成灰……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "哎呀，",
        "unit_id": 1411,
        "voice": "vo_adv_1150003_031"
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "不逛了嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "\n下次再來啊～！",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_032"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "已經夠了吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我都乖乖跟你出來了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n差不多該放手了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我果然不該自己出來購物。",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_033"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n應該像往常一樣",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "派那些複製品出來就好了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……對，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_034"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就是因為這樣。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n每次購物都會遇上像剛才那樣的事，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n所以平時都交給複製品們去辦。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這些對外表的種種偏見，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_035"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我本來以為\n我在那一側的世界早已習慣到能無動於衷了……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "果然討厭的事情還是勉強不來啊。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "話說回來，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_036"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "NPC的對話模式",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n比我記憶中的版本更加單一。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我記得應該也會有無視外觀的對話才對……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "比起這個，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_037"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "新年才剛開始，我就已經火冒三丈了……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就算回剛才的店裡，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_038"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也只會被強迫推銷那個福袋吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "只好去別間店──",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_039"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "果然還是回剛剛那間店好了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n放心吧，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我不會把那個店長燒成灰燼的……",
        "unit_id": 115011
    },
    {
        "type": "background",
        "background": "500370"
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "歡迎光臨！",
        "unit_id": 1411,
        "voice": "vo_adv_1150003_040"
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "啊，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "是剛才的小妹妹啊。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "決定好要買什麼了嗎？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是啊……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_041"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我要買一包",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這邊的福袋。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n錢就放在這裡了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "謝謝惠顧！",
        "unit_id": 1411,
        "voice": "vo_adv_1150003_042"
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "歡迎再來啊！",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很遺憾，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_043"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我不會再來了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n多加強你看人的眼光吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "好、",
        "unit_id": 1411,
        "voice": "vo_adv_1150003_044"
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "好的……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "那個眼神",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "真是太嚇人了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "\n該不會，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "她其實是成年人吧……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "男性店員",
        "words": "怎麼可能嘛！",
        "unit_id": 1411
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_045"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "收下吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這是",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "送給「你」的禮物。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "畢竟，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_046"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這可是「兒童」福袋嘛。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n身為「大人」的我，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是不需要這種東西的。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "快打開看看吧……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_047"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n裡面全是些適合你這樣年紀孩子的東西喔。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "…………",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_048"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_049"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "啊啊，是嗎。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n真是的，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這種回答是要我做何反應啊。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這樣就一點也不有趣了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒想到你竟然聽不懂諷刺……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_050"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不過，倒是讓我",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "失去使壞的興致了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我只是在遷怒你而已。",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_051"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "身為大人的我，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "把福袋轉送給小孩子的你，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n這樣即使不浪費這個福袋，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "也能糟蹋那店長的用意，對吧？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……看來，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_052"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "想靠消遣你排解我的怒氣，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n從根本上就是錯的。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那個福袋裡的東西，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "都隨你處置吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……我像這樣嘲笑他人的稚氣，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_053"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n也沒什麼資格指責別人呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "差點就要淪落到和那個店長一樣的境地了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你剛剛",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_054"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "說什麼……？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你這個人真的是……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那麼，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你打算如何排解呢？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那是",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_055"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剛才買的撲克牌……",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n難不成你想挑戰我？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_056"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "好吧。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n我會讓你輸到抱頭求饒，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n再也不敢挑戰我為止。",
        "unit_id": 115011
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "──這下就結束了。",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_057"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我已經57連勝了呢。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你以為靠遊戲就能贏過我嗎？",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_058"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "給我記好了。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n在遊戲上",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "和七冠單挑，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是十分魯莽的博奕喔。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……竟然笑了，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_059"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "剛才的牌局中有什麼好笑的事嗎？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還是因為自己輸得太過徹底，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n已經神智不清了呢？",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_060"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是啊，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我很開心喔。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "但是，",
        "unit_id": 115011,
        "voice": "vo_adv_1150003_061"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "要是你實力更強的話，我會更開心的。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "所以，",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你要盡快爬到我所在的高度喔。",
        "unit_id": 115011
    },
    {
        "type": "dialogue",
