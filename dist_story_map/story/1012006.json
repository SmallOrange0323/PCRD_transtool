[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "初音和栞一起來買東西。"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "小栞！",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "妳買到想要的書了嗎？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯，我找到了喔。",
        "unit_id": 103811,
        "voice": "vo_adv_1012006_001"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "「睡美人」……我從以前就很想看。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是喔～，是怎麼樣的故事？",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_002"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "嗯……是陷入永眠的公主",
        "unit_id": 103811,
        "voice": "vo_adv_1012006_003"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "因為王子的一吻而醒過來的故事喔。",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n接、接吻而醒過來……！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "……？",
        "unit_id": 103811,
        "voice": "vo_adv_1012006_005"
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "\n",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "栞",
        "words": "姊姊，妳怎麼了？",
        "unit_id": 103811
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒、沒什麼喔！ 嗯！",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊哈哈哈～……",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "隔天――"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "今、今天要和他去買東西呢……",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_007"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚……怎麼辦？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "明明完全沒關聯，但聽小栞說了書的內容後，",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_008"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n就浮現出他的臉……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為我也很常睡著嘛……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "或、或許，我使用超能力後睡著，",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_009"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n擔心我醒不過來的他，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "會會會、會吻……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是說，",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_010"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n他怎麼可能那麼做嘛～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我、我在想什麼啊……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_011"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "早、早安～……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……咦？ 我看起來沒什麼精神？",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_012"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒、沒那回事喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難得來玩，要玩得開心點才行！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，對了！ 要不要去吃東西？",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_013"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我帶了很多零用錢喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n喏，你看你看～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚哇！ 好、好強的風！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_014"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我的錢都飛走了！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呵～呵～呵～，但是沒關係！",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_015"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n只要用超能力把錢拉回來――",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呃，等一下等一下！",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_016"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n使用超能力的話，會睡著喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那、那樣的話……會、會被吻……！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "咦？ ",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_017"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我、我沒打算做什麼喔！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "既然已經飛得那麼遠了，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n即使用我的超能力也很難拿回來吧……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因、因為這樣，這次只好放棄……",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_018"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚……我的零用錢～",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n虧我這麼努力地存……",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500130"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──呱歐歐歐歐歐",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "哇哇！ 這、這次是魔物！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_019"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "用超能力逃走……",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_020"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "是不行的，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n所以我們用跑的逃走吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……你問我不瞬間移動嗎？",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_021"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "今、今天沒那種心情！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好啦好啦，快一點～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼……太好了。",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_022"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "今天似乎有辦法不使用超能力，順利度過一整天。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呀！ 好、好大隻的蜜蜂！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_023"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "不要過來～！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊，牠好像要刺你！？",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_024"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "這、這樣的話！ 嘿噫！",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500211"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "好了，因為瞬間移動了，",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_025"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n蜜蜂就無法追到這裡來了吧！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……呃，",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_026"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n不、不小心使用超能力了！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "怎、怎怎怎、怎麼辦……變得好想睡……",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_027"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "呼嚕呼嚕……",
        "unit_id": 101211
    },
    {
        "type": "background",
        "background": "500212"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "啊！ 我……睡著了？",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_028"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "你在等我睡醒……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那、那個……",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_029"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n嗯，就是……你、你有沒有，",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n吻……吻我之類的……？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒、沒事！ 沒什麼！",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_030"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n沒有就好！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "對不起，問了奇怪的問題！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也、也是呢！",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_031"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n你怎麼可能那麼做嘛！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚嗚……我今天一整天何必這麼心跳不已呢……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……啊，太好了。",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_032"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "也、也是呢。怎麼會因為我沒醒來就吻我呢。",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n那只是書中的故事而已……",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但、但是……如果是你……",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_033"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗚、嗚哇啊啊！",
        "unit_id": 101211,
        "voice": "vo_adv_1012006_034"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我在想什麼啊！？",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n好、好害羞！！",
        "unit_id": 101211
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "初音臉紅了好一陣子，\n無法與{player}四目相接。"
    }
]