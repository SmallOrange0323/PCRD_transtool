    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "飛奔出公會之家的優衣，\n過了一段時間後回到公會之家內，順利的完成料理。"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好的，抱歉讓各位久等了。",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_000"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "特製的蛋包飯完成了呦。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我等好久啦！",
        "unit_id": 104311,
        "voice": "vo_adv_1002003_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣的做菜功力可比大廚師，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你可以好好期待喔！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "才沒有這回事呢。",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_002"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "因為我的老家是開餐廳的，所以自然而然就學會了。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n我對料理也不是很講究的呦？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……我說優衣。妳剛剛為什麼突然飛奔出去啊？",
        "unit_id": 104311,
        "voice": "vo_adv_1002003_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n發生什麼事了嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": " 妳們兩人吵架了？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那、那個……",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_004"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呃……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我還想說抓好飯菜應該做好了的時機回來的說～",
        "unit_id": 104311,
        "voice": "vo_adv_1002003_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘛，反正能像這樣飽餐一頓所以我是不介意啦♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真是的，真琴妳呀……",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉呀！特地煮的飯菜會冷掉的。",
        "unit_id": 104311,
        "voice": "vo_adv_1002003_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們快開動吧！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "說的也是呢。",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_008"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "騎士先生也請不要客氣。",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "如果有做出合你喜好的口味就好了呢……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那我就不客氣啦～……",
        "unit_id": 104311,
        "voice": "vo_adv_1002003_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯！真好吃！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不愧是優衣。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "如果每天都能讓我吃到就好了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就算妳奉承我，也不會有什麼甜頭喔？",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……被餵食？就是這招！",
        "unit_id": 104311,
        "voice": "vo_adv_1002003_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我說啊，反正機會難得，不如叫優衣餵你吃吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這樣的話會變得更好吃喔！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "真琴！？",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_012"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "妳突然胡言亂語什麼呀！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "抱、抱歉呢騎士先生。剛才是真琴在開玩笑的！",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_013"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "請不要介意，好嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "咦咦咦！",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_014"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "就算你這麼說，但是……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（既然是騎士先生特地提出的心願，我是很想幫他實現……",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_015"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗚嗚……但還是十分難為情呀～！）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（……可是，如果這時候不鼓起勇氣的話，",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_016"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "在戰鬥的時候肯定也是同樣重蹈覆轍……！）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……騎士先生。我想嘗試看看。",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_017"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n為了能好好地餵你吃飯，",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "我會努力的！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說的好啊，優衣！加油啊！",
        "unit_id": 104311,
        "voice": "vo_adv_1002003_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "（……咦？",
        "unit_id": 104311,
        "voice": "vo_adv_1002003_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好像和我想像的氣氛不太一樣耶……？）",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "嗯！……",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_020"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那我上了！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "來，",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_021"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "張嘴呦～啊～……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……還，還可以嗎？",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_022"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "好吃嗎？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "太好了呢……",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_023"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "那我就開動囉。",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_024"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……嗯，很好吃呢♪",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "一開始還擔心味道可能會偏重，這樣的話應該……",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "……",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_025"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "（我剛才，用了餵騎士先生吃飯的湯匙，",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_026"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n就這樣自己吃了……！？",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "\n",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "這不是間接接……！）",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊，",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_027"
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "哇哇哇哇……！",
        "unit_id": 100211
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "啊嗚……",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "優衣！？妳怎麼了！",
        "unit_id": 104311,
        "voice": "vo_adv_1002003_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "振作點啊！　優衣！！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "優衣",
        "words": "呼……呼……",
        "unit_id": 100211,
        "voice": "vo_adv_1002003_030"
    }
]