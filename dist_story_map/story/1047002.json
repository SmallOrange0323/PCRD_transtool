[
    {
        "type": "background",
        "background": "500090"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "…………",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……哎呀少年，你好。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_001"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "昨天，平安地回到旅館了嗎？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_002"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是嗎。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "太好了太好了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為近來蘭德索爾的治安正在惡化呢，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我很擔心你是否會被歹徒襲擊之類的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……真對不起呢，少年。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_005"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你說，為何要道歉嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。因為治安的惡化，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_006"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n是該守護城鎮和平的……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我們【王宮騎士團】的管理不善。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然我們也增加巡邏，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_007"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並且嚴加取締了",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但由於經歷了長久的和平時代，預算被削減，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_008"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n人員也幾乎都是經驗不足的生手。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "無法應付急遽增加的奇怪事件及犯罪，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n一直處於被先發制人的狀態。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "對此抱有不安的能人們，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_010"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n自己組成了守護城鎮的自衛公會……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但這些公會們互相發生衝突，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_011"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n反而擾亂了秩序。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是種惡性循環。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然也知道這樣下去不行……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但首先，我們【王宮騎士團】，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_013"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n必須先振作起來才行呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_014"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n說了和你無關的事呢，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為一直沉默的站著，所以很渴望能說話呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "比起那個。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_015"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你，找我有什麼事嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "難不成，又迷路了嗎？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_016"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然帶路不是我的工作……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n不過，因為我有空閒，是能幫你畫地圖的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_017"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n啊啊，是來為昨天道謝的？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那還真是謝謝你，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_018"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "特地這麼多禮……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真有禮貌呢，少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然並沒有做什麼值得讓人道謝的事，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_019"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但能幫上別人的忙，我還是很高興的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_020"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你說為了表達謝意，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n要送我禮物……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "謝、謝謝你。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_021"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真誇張呢，只是為你指路而已……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總覺得，有些害羞呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你，到底要送給我什麼呢？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "蛋糕？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_023"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n謝謝。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然我不太能吃甜食。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_024"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n聽同居人說，女孩子都喜歡甜食……？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然我已經不是會被稱為女「孩子」的年齡了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不過，我外表看來很強悍對吧？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_026"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因此，很難得會被當成女孩子對待……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n總覺得有點開心呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "哎呀，為何一直盯著我看……？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_027"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "咦？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n你對戴著頭盔，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n要怎麼吃東西感到很有興趣？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，我只是打算",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_029"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n帶回自己家後脫掉頭盔再普通的吃掉而已。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "真對不起呢。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_030"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n由於某些緣故，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我不想被任何人看見我頭盔底下的面貌。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "蝴蝶結髮帶？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_031"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n啊，是繫在頭髮上的東西吧，我知道。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_032"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為我從孩提時代開始，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n在家裡以外的地方總是一直戴著頭盔……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "髮飾之類的，我自己是不買的。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_033"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這好像是我有生以來初次接觸到喔，蝴蝶結髮帶。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_034"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n因為某些緣故，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我是不會在他人面前脫下頭盔的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "所以即使收到髮帶，也沒有辦法配戴……",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但是收到禮物我很高興喔，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我會帶回家繫起來看看的。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_036"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我已經不是適合繫上可愛蝴蝶結的年齡了。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但像這樣，看見其他女孩子繫著還是感到羨慕。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因此，我非常高興。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_037"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n謝謝你，少年。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_038"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n雖然我稍微有所戒備……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n但你，似乎只是為了道謝而來呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "雖然我也曾想，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_039"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n禮物盒裡也許設置了炸彈。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n看來是想太多了呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不行啊……",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_040"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n疑心病重是職業病呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你明明只是",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_041"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n率直的來表現出感謝的心意而已呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "希望你原諒我曾懷疑你，少年。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_042"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "但是沒有辦法。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_043"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我肩負著守護這座王宮的使命。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n這是從代代祖先繼承下來的，守衛的工作。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我若是倒下，王宮以及這個國家的全部，都將置身險境。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n為了阻止這樣的悲劇，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n無論今天、明天、後天……我都會一直佇立於此。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……你認為是個寂寞的人生嗎，少年？",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "呵呵。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_046"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n真對不起呢。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n問了你難以回答的問題。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒事的。",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_047"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我很滿足哦，對這個人生。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "被託付重要的工作，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_048"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像這樣令人引以為傲的事，也能成為心裡的撫慰。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "因為即便僅是站立於此，",
        "unit_id": 104711,
        "voice": "vo_adv_1047002_049"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n也能與像你這樣的好孩子相遇呢。",
        "unit_id": 104711
    }
]