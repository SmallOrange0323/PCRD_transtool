[
    {
        "type": "background",
        "background": "500430"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──在露娜之塔的某個樓層。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n那裡響起了壞蛋們的悲鳴。"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "嘎",
        "unit_id": 1,
        "voice": "vo_adv_7027003_000"
    },
    {
        "type": "dialogue",
        "name": "兩人",
        "words": "呀──！！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可惡～！",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_001"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n從剛剛開始就老是被魔物追著跑耶！？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是妳戰鬥的方式太招搖了吧！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喊著「天樓霸斷劍」什麼的，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n同時又胡亂發出超醒目的斬擊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那樣一來",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "整個樓層的魔物",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n當然都會發現我們啊！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是喔……",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_004"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，我只好負起責任啦！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這裡我來想辦法！",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_005"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你們先走吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不行，不可以！",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓妳單獨行動的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我看事情肯定會變得更糟糕！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那種事……",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也許會發生？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "畢竟我無法分辨陷阱嘛。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看來妳能理解呢。",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "所有人一起走吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我們可是命運共同體呢！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "命運共同體……",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這話聽起來很棒耶！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "可是啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算這樣逃下去，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也會很快被追上喔？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼！",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我可是天才呢！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n想說可能會有這種情況，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "已經預先準備好了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n……用這個",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "特製煙霧彈！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "魔物們，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "看我的厲害！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──咕喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "很好，",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "進行得很順利！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "趁魔物找不到我們的空檔，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "快走吧！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔呃！？",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "該怎麼說呢……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就像完美地忘記這東西的存在……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "現在才想起來之類的……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哈哈！",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳還真是狡猾耶，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "祈梨！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳對我的做法",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_014"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有什麼意見嗎！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不是，正好相反！",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我喜歡這種很像是壞蛋的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "戰鬥方式！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔……",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_016"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我說，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳還挺了解的嘛！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n沒錯，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我們又不是什麼正義的夥伴！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不管什麼事能做就會去做！",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_017"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n當然，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是在沒有違反壞蛋美學的",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "範疇內！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呼。",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看來是甩開了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "祈梨，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳比我想得還厲害喔。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不愧是未來的",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "Big Boss耶！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼哼……",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_019"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳可以再多誇一點！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n誇我這個",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "大天才祈梨大人！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過嘛，",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳也還算努力就是了？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "以妳至今的功勞來看，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要我稍微誇獎妳也行喔，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "矛依未。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "只不過！",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_021"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "拜託妳，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n別再用那把誇張大的劍胡亂招搖地戰鬥了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就算妳這麼說，",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_022"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但我不擅長小家子氣的戰鬥方式耶……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且跟{player}敵對的時候開始，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我戰鬥就是這種風格了。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……嗯嗯？",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_023"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳說敵對……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n矛依未，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳曾經與小哥為敵！？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要說敵對嘛，",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "該怎麼說……",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "算了，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "都過去了！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "發生過很多事嘛！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那麼……",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_025"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要是又發生了很多事，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n有可能又與小哥為敵嗎？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂喂喂，",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_026"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我以前也說過吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我的對手",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "僅限壞人！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是這樣就好了……",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_027"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟壞蛋的話不可信。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……妳記好囉，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "矛依未。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "萬一，",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_028"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳又與小哥為敵的話……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "到那時候，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我會率先當妳的對手！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……但我明明比妳",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_029"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "要強得多的說？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那……",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_030"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那種事，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我才不管！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……祈梨，妳變了呢。",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_031"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是朝好的方向改變喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_032"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "妳說我變了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "口氣聽起來就像是妳知道以前的我……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抱歉抱歉，",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_033"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這說法害妳混亂了吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過啊，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n居然想為了某人而跟比自己更強的傢伙而戰，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n之前的妳不會這麼想對吧？",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "妳變成了在重要時刻能展現勇氣，",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_034"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "溫柔而堅強的壞蛋呢。",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我認為像妳這樣的人，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就應該成為Big Boss喔！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喔、",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_035"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "喔喔～？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n妳意外地有眼光呢！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "祈梨，加油吧。",
        "unit_id": 106113,
        "voice": "vo_adv_7027003_036"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n成為Big Boss，",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是妳的夢想對吧！",
        "unit_id": 106113
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不用妳說我也會變成Big Boss的！",
        "unit_id": 106611,
        "voice": "vo_adv_7027003_037"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟其他人可沒有像我這樣",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "具備成為Big Boss的器量！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是在露娜之塔，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n響起了未來的Big Boss（？）的揚聲高笑。"
    }
]