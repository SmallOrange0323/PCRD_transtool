        "voice": "vo_adv_1227001_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不，",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那是……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個……",
