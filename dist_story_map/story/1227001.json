    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我本來",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就還不太能使出困難的魔法吧……",
        "unit_id": 103611
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個人的……",
