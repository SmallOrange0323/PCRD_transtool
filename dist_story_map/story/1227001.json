    {
        "type": "dialogue",
        "name": "旁白",
        "words": "精靈族學校位於遠離蘭德索爾的森林中。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n鏡華所在的那間教室裡，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n精靈族的孩子們今天也快樂地勤奮學習著。"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "那麼，各位，",
        "unit_id": 6511,
        "voice": "vo_adv_1227001_000"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n下次假期過後，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "夏令營終於要開始了。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "如我之前也說明過的，",
        "unit_id": 6511,
        "voice": "vo_adv_1227001_001"
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "這次的目的地是海邊。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n對居住在森林中的我們精靈族來說，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "那是不熟悉的區域。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "\n",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "要確實訂定計畫，",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "老師",
        "words": "並好好準備喔。",
        "unit_id": 6511
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "是──！",
        "unit_id": 1,
        "voice": "vo_adv_1227001_002"
    },
