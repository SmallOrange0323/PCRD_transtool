        "name": "鏡華",
        "words": "也對啊……",
        "unit_id": 103611,
        "voice": "vo_adv_1227001_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要是沒有那個人的力量，",
