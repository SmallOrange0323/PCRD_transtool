[
    {
        "type": "background",
        "background": "502330"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哈囉──",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_000"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你過得還好嗎？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "菲歐跟帆稀好像都不在呢？",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_001"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你迷路了對吧？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呀哈哈♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就算在熟悉的城鎮，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "變成這副模樣會迷路也不意外啊♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哎呀呀，",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_002"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "被抓到了♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "要被送去給可～怕的姐姐了～♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不過，",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_003"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你竟然用雙手緊緊抓住穿泳裝的女孩子，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真是過分的對待呢？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是個出色的變態可疑分子",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊～",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嘿咻，",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_004"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "成功逃脫♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n你太好搞定了啦。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "話說回來，想必",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_005"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你不會游泳吧？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "雖然水有施加安全措施，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n但邊走還是要邊好好確認腳邊啦。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "走路走得搖搖晃晃的，還要一邊找我，",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_006"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "簡直太危險了。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊～？",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_007"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n哪可能啊。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我只是來嘲笑少根筋的你而已啦。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "……不過，",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_008"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "也是因為要是你出了什麼事，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n菲歐那傢伙會傷心就是了。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "真是的，",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_009"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "像你這樣的傢伙究竟是哪裡好了啊～？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我完全搞不懂。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "是不是看得更仔細一點就會明白了？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "讓我稍微看清楚一下你的臉。",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_010"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗯嗯，",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_011"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "哦──",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n原來如此呢～？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "額頭看起來很好塗鴉。",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_012"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "臉頰的彈性一般般。",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_013"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "眼睛……",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_014"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "純真純真的呢。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "喂，",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_015"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "別把臉轉過去，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我現在正在看耶。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "還是說怎樣？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你害羞了？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "根本沒必要事到如今才害羞吧。",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_016"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n我們的關係可是甚至放進過嘴裡不是嗎？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊，",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你還記得嗎？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n就是你把我弄得渾身都是口水的那次。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就是用這張嘴！",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_017"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "看招看招♪",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n嘴唇竟然這麼軟嘟嘟的！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "嗚呀",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_018"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊！？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你在搞什麼鬼啊，真是～～～！",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_019"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你又害我濕答答了啦！",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊？",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_020"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "因為我搔你鼻子？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n把錯推給別人可真有膽量呢～？",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "啊～啊，",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_021"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "總之我要去洗身體了。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "我還真是被你弄髒的命",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "呢。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "遭遇過這種事的",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_022"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "就只有我吧～",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "不，我也不需要那種特別感就是了。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "那我要走了，",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_023"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n畢竟菲歐跟帆稀好像來到附近了。",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "你們會合後再來追我吧♪",
        "unit_id": 190912,
        "voice": "vo_adv_5150069_024"
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "\n",
        "unit_id": 190912
    },
    {
        "type": "dialogue",
        "name": "涅比亞",
        "words": "掰掰～♪",
        "unit_id": 190912
    }
]