    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳說得是。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "經過這次的調查，",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_047"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "銷路看來能獲得擴展，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n上了軌道之後，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "交易量應該也會逐步增加。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "經濟振興的程度甚至有可能超出我們的預想。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為了美好的將來，",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_048"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們現在要好好努力才行。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "…",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "…對了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "等這個企劃上了軌道，",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_049"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們就擴大事業範圍吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n有我們聯手",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "應該還能做到更多不同的事。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "當然，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "資金周轉方面",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就交給我秋乃‧紫藤來辦！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說到這個啊……",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_050"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳沒興趣嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_051"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼會。",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_052"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我覺得是很棒的計畫。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "可是啊，",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_053"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果我把全部精力都放在工作上……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n很可能",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就會疏忽育幼院的事了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對我來說，",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_054"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n最重要的還是",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咲戀育幼院的",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "孩子們。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n如果忙到沒辦法和那些孩子見面，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就本末倒置了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "當然我也喜歡做生意喔？",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_055"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "正是因為喜歡，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以才想在順利開展後，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n把這次的事業，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "後續都交給秋乃。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀……",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_056"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_057"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "已經找到對自己來說重要的事了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "她看起來好耀眼……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_058"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是否也擁有著呢？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n有可以像咲戀那樣",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "能理直氣壯說出是「最重要」的事物……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n像咲戀那樣……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_059"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不知不覺就用了這種方式思考的我，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真的有和我視作對手的咲戀",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "站在同樣的高度上競爭嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃……？",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_060"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "抱歉拒絕妳了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "但是幫點忙不是問題的！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "隨時都可以來找我！",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_061"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n好嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……好的。",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_062"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我會照妳說的做的。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵。",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500093"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束試行運作的３人在找出企劃的問題點後加以改善，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n製作出正式的企劃書。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了提交文件，他們來到了王宮。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n然而──"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "到底是怎麼一回事！？",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_063"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n怎麼會有人提出",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "和我們這份完全一樣的企劃書……！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果負責人說的話是真的……",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_064"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n在提出企劃的階段，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像就有",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "和我們相似的點子出現。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n但是就算這樣，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我無法理解",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼會長得一模一樣。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "更有甚者，",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_065"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那份企劃",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "已經開始得到各處的承認了？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這怎麼可能，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "太奇怪了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "原本應該願意協助我們的那些商人，",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_066"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n現在好像也都支持那邊的計畫。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這樣看來……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是被收買了吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我們被擺了一道。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "小咲戀，太好了，",
        "unit_id": 104711,
        "voice": "vo_adv_1809002_067"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我正在找妳。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n還有少年你和……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這位是",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "秋乃小姐吧？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳在找我，",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_068"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是指",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有什麼事嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒錯，",
        "unit_id": 104711,
        "voice": "vo_adv_1809002_069"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有事想知會妳一聲。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還記得在妳仍是副團長的時候，",
        "unit_id": 104711,
        "voice": "vo_adv_1809002_070"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n團裡有個連劍都揮不太起來的貴族嗎？",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_071"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不記得了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n為了鍍金加入【王宮騎士團】",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "作威作福的傢伙",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也不只一個兩個。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是說那樣的傢伙",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_072"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一個個都被我抓住濫用職權的把柄了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "沒記錯的話，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "應該都被派到邊荒地區去了吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "在那之中，",
        "unit_id": 104711,
        "voice": "vo_adv_1809002_073"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "有個人似乎又回到了蘭德索爾。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n並且……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是以公共事業企劃參加者的身分回來，",
        "unit_id": 104711,
        "voice": "vo_adv_1809002_074"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n就是小咲戀你所參加的",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "那個企劃。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "咲戀、秋乃",
        "words": "什麼……？",
        "unit_id": 1,
        "voice": "vo_adv_1809002_075"
    }
]