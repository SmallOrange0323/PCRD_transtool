[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "秋乃、咲戀"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "以及{player}３人，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了試行運作他們所提出的企劃，往來各地運輸食材。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唔──",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "照地圖看來……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "下一個目的地",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "馬上就會到了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "比我預想的",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "快了好多呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n離開村子後",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "才過不到幾個小時。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為我們用了幾條安全的捷徑。",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "即使每段路程節省的時間不多，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總和來算，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n仍可以大幅減短所需的時間。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是所謂聚沙成塔，積少成多囉。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要讓這次的企劃案上軌道，",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "像這樣的路線調查也是必須的……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然比不上飛空艇的速度，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "多多少少還是能派上用場。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "多多少少……",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳真是太客氣了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我可是親身體驗到",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "做過那些調查的成果。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這絕對是有益的情報。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "本小姐掛保證。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我啊，",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "自從開始這趟旅程",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就一直受到感動喔？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不只是因為有捷徑可走。",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "對於妳創新的提案與做法，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還有各種細心的考量，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "總是感到十分佩服。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "相比起來我就……",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "提案也不被採用，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "還是個路痴。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n連在交涉的場合",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "都說了一些牛頭不對馬嘴的話……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊……",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳那時提出了各式各樣的方案呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然其中有不少超過預算……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "像是個人用的小型飛空艇量產計畫",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等等。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "嗚嗚……",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真是太丟人現眼了。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我覺得那個點子本身是很有趣的，",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "只是這次不太有辦法採納。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也從秋乃那些我想不到的",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大膽想法得到過助益，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "比起局限於小地方，這樣不是比較好嗎。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咲戀……",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_012"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我明白了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n往後，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我身為顧問，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n會繼續一個接著一個",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "提出各種意見的！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵，",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對嘛。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這才像",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "秋乃會說的話。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "兩位，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請看前方！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "目的地的村莊",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "已經出現在視野中了！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們快點走吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "她能恢復精神真是太好了……",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "等等！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "妳要往哪去啊，秋乃！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不是那邊！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "走反了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "反了！",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500330"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "３人抵達目的地村莊，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在當地商人的介紹下，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n來到使用當地特產的店家用餐。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我開動了。",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊呣…………",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好好吃啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "多麼有深度的味道……",
        "unit_id": 103211,
        "voice": "vo_adv_1809002_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "乍看之下",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只是熟悉的菜色，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n沒想到吃起來",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "卻和平常的完全不同……！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "太好了，看來這些菜有受到各位的青睞。",
        "unit_id": 1411,
        "voice": "vo_adv_1809002_018"
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "畢竟",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "使用了一些市面上不太常見的食材……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "\n原先還擔心",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "要是不合胃口的話怎麼辦才好。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "市面上不太常見……",
        "unit_id": 102811,
        "voice": "vo_adv_1809002_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n明明這麼好吃，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "怎麼會呢？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "因為可以收成的時期",
        "unit_id": 1411,
        "voice": "vo_adv_1809002_020"
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "有限。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "而且",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "產量也少。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "要當作商品來賣，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "供給不夠穩定……",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "\n所以我過去",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "一直沒有積極地向人推銷。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "不過，",
        "unit_id": 1411,
        "voice": "vo_adv_1809002_021"
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "各位的企劃如果實現，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "就是另一回事了。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "\n畢竟可以不用再拘泥於大宗訂單。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "只帶少量也沒關係，",
        "unit_id": 1411,
        "voice": "vo_adv_1809002_022"
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "時間對得上就能保持在新鮮的狀態出貨。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "\n非常有嘗試看看的價值。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "\n",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "請務必",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "當地商人",
        "words": "讓我協助企劃的推展。",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "咲戀、秋乃",
        "words": "……！",
        "unit_id": 1,
        "voice": "vo_adv_1809002_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀、秋乃",
        "words": "\n",
        "unit_id": 1
    },
