    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "不思議な結晶に触れ、様々な思い出を感じたムイミ。"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "これで……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_000"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "全部か。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "思い出が次から次に浮かび上がってきて……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_001"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ははっ……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "すごく、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "なつかしいな……",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "きついこともあったけど……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_002"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "楽しかったな。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nどれだけ思い返しても、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "楽しい気分になる。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "でも……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_003"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "その思い出の中で、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n立ち止まってるわけにはいかないんだ。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "これからアタシを待つ未来がどんなものだって、",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_004"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n逃げたりしない。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "アタシは進むぞ。",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_005"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nこの楽しかった思い出を超える未来を、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "作るために。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "さぁ、",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_006"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "起きろアタシ！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\nのんびり寝てたら、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "オクトーに笑われちゃうぞ……！",
        "unit_id": 106116
    },
    {
        "type": "background",
        "background": "501322"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "……ん……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_007"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ああ……",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_008"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "なんだ、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "オマエか。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "心配してくれたのか？　",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "へへ、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "ありがとな！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "\n",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "でも、",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "全然大丈夫。",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "──アタシは",
        "unit_id": 106116,
        "voice": "vo_adv_5111609_009"
    },
    {
        "type": "dialogue",
        "name": "ムイミ",
        "words": "絶好調だ！",
        "unit_id": 106116
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "未来で新しい思い出を作るという意思を携え、"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\nムイミは迷いなく進むのであった。"
    }
]