        "name": "富美惠",
        "words": "\n",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "「逆轉＜顛倒＞」善惡，",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "富美惠",
        "words": "胡扯什麼宏大的「陰謀論＜妄想＞」──",
        "unit_id": 18211
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "閉嘴，",
