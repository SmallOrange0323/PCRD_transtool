[
    {
        "type": "background",
        "background": "500016"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "在這座島嶼的生活",
        "unit_id": 101411,
        "voice": "vo_adv_5092411_000"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就到今天了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "發生太多事情，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n這幾天時間充實得像是過了好幾個月一樣呢。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是啊，",
        "unit_id": 103111,
        "voice": "vo_adv_5092411_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然並非都是開心的事，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過在迎來結束時",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "還是會很捨不得。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "那當然啦。",
        "unit_id": 100911,
        "voice": "vo_adv_5092411_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "一開始是靈媒師消失，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還有密室事件、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "三項測驗",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n加上原生生物的襲擊、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "古代遺跡的困難陷阱、",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "和邪龍死鬥。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "還有──",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "杏奈，妳太誇張了，",
        "unit_id": 103111,
        "voice": "vo_adv_5092411_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太誇張了啦。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哇，",
        "unit_id": 100911,
        "voice": "vo_adv_5092411_004"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "糟糕，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "不小心說出我想寫的題材了……",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不過，",
        "unit_id": 101411,
        "voice": "vo_adv_5092411_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "一想到回到蘭德索爾之後",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我們又要回歸各自的生活，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n就覺得有點寂寞呢……",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哼，",
        "unit_id": 100911,
        "voice": "vo_adv_5092411_006"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "妳在說什麼。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我們可是同生共死的夥伴，",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n如此強大的緣分",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "是不可能這麼簡單地被切斷的。",
        "unit_id": 100911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "杏奈說得沒錯。",
        "unit_id": 103111,
        "voice": "vo_adv_5092411_007"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就算暫時離別，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我們的靈魂",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "一定會互相吸引，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓我們再次相遇的。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "哈哈，",
        "unit_id": 101411,
        "voice": "vo_adv_5092411_008"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳們兩個都這麼說的話那一定沒錯。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n感傷就到此為止，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "好好享受在島上最後的時間吧！",
        "unit_id": 101411
    }
]