    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "吶，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "你是來找我玩的嗎？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "那個，",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_002"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜我……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n到剛剛為止，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "都在這裡玩唷。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n然後，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "現在要開始吃飯了。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥要吃嗎？",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_003"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "三明治。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "嗯！",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_004"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "那麼，",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_005"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我給你一半吧！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n快吃吧！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "呵呵。",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_006"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n好吃吧。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不是唷！",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_007"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "總是呢，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "會放在",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我家門前呢。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜我……",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_008"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "知道的唷。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n是老婆婆",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "她放的呢。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "之前，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我從窗戶看到的。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "老婆婆她、",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_009"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "討厭露娜吧。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "因為她馬上就跑掉了……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n明明露娜，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "很想要一起玩的說……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "但是，",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_010"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜喜歡這個三明治！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "因為和媽媽做的三明治味道很像！",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "而且……",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_011"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n在吃的時候，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "一點都不寂寞呢。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不是一個人唷。",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_012"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "爸爸和媽媽也在唷。",
        "unit_id": 111412,
        "voice": "vo_adv_1114003_013"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……只是現在不會跟我說話了。",
        "unit_id": 111412,
        "voice": "vo_adv_1114003_014"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "媽媽很擅長料理喔！",
        "unit_id": 111412,
        "voice": "vo_adv_1114003_015"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜也",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "稍微會一點唷。",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n雖然只是在旁邊幫忙而已……",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "還有，",
        "unit_id": 111412,
        "voice": "vo_adv_1114003_016"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "也會陪我一起出門。",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜，",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "那個……",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "最喜歡",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "跟爸爸媽媽一起出門了。",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……其實啊",
        "unit_id": 111412,
        "voice": "vo_adv_1114003_017"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n爸爸跟媽媽，",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "有跟露娜說過唷。",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "就算死掉",
        "unit_id": 111412,
        "voice": "vo_adv_1114003_018"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "也會跟露娜永遠在一起。",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……所以，",
        "unit_id": 111412,
        "voice": "vo_adv_1114003_019"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "會一直都在一起唷。",
        "unit_id": 111412
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "但是，",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_020"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "爸爸跟媽媽",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "都不會跟我說話了……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n露娜，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "好寂寞……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "所以，",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_021"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我很想要有朋友……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "但是……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……大哥哥",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_022"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "為什麼不死掉呢？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……騙人。",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_023"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "明明，",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_024"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "死了就可以一直在一起，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "爸爸跟媽媽有說過啊。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "所以，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "我們就是一直在一起呀。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "老婆婆也是，",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_025"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥也是……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n都可能會離開我不知道去哪裡吧。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n也可能，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不會再給我三明治……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……也不會再跟我玩呢。",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_026"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "可是，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "如果死掉的話就可以一直在一起唷……",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "露娜，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "也就再也不會寂寞了呢。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……真的嗎？",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_027"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_028"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……露娜，",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "有點搞不太懂。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "不過，",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_029"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "大哥哥",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "會一直是我的朋友嗎？",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_030"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "……那麼，",
        "unit_id": 111411,
        "voice": "vo_adv_1114003_031"
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "來玩吧。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "\n",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "露娜",
        "words": "來玩你追我跑吧。",
        "unit_id": 111411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和露娜一起玩耍。"
    },
    {
        "type": "background",
        "background": "500132"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "要返回蘭德索爾的{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在歸途中看見那位老婆婆。"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "噢……",
        "unit_id": 611,
        "voice": "vo_adv_1114003_032"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是你呀。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "看樣子……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "你跟那個孩子相處得不錯。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……太好了。",
        "unit_id": 611,
        "voice": "vo_adv_1114003_033"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n有你在，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我就能安心了呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "老婆婆如此說著的時候，從她身上傳來微微的香氣。\n這個味道是……"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……是的。",
        "unit_id": 611,
        "voice": "vo_adv_1114003_034"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "我所能做的，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "就只有這種事呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "至少可以贖罪。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "其實不管烤了多少個麵包……",
        "unit_id": 611,
        "voice": "vo_adv_1114003_035"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n……都沒辦法彌補犯下的罪過。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n就算明白這點，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "但我還是想繼續下去。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……你見過那個孩子的父母了吧？",
        "unit_id": 611,
        "voice": "vo_adv_1114003_036"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n那個孩子啊，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "是死靈術師呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那個孩子自己",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "好像沒有發現……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "父母過世時……",
        "unit_id": 611,
        "voice": "vo_adv_1114003_037"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n那個孩子",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "大概使用了自己的力量。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n然後，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "就變成如今的模樣……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……對那個孩子來說，",
        "unit_id": 611,
        "voice": "vo_adv_1114003_038"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "死亡就是永遠唷。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n會變成那樣子，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "都是我的錯。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……",
        "unit_id": 611,
        "voice": "vo_adv_1114003_039"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……不好意思呢。",
        "unit_id": 611,
        "voice": "vo_adv_1114003_040"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那個孩子，",
        "unit_id": 611,
        "voice": "vo_adv_1114003_041"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "真的很像呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "跟我的孫子呀。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n真的很像呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……",
        "unit_id": 611,
        "voice": "vo_adv_1114003_042"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "……很討厭吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n老人家講這些陰沉的話很不好吧。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "今後",
        "unit_id": 611,
        "voice": "vo_adv_1114003_043"
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "那個孩子也拜託你了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "請一定",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "老奶奶",
        "words": "要再過來唷。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "老婆婆消失在森林之外。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n一邊思考能為露娜與老婆婆做什麼事，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}也離開了森林。"
    }
