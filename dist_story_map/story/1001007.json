    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──武鬥會當天。\n日和很順利地不斷晉級，終於晉級到決賽了。"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "很痛痛痛……",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "哈哈哈，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "已經全身遍體麟傷了呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這種集合了來自全大陸強者的大會，",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n果然無法輕鬆取勝呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然到目前為止設法贏了過來……",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但現在全身四處疼痛不堪，沒辦法隨心所欲的活動呀……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過，終於能晉級決賽了……！",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n下一戰也要……努力取勝……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……騎士先生，果然還是趕不及嗎。",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不會的，騎士先生一定會來的。就算是決賽完了才到也好。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "到那個時候，我會讓騎士先生看到我獲得優勝的一刻……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……好～！ 得加把勁呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_005"
    },
    {
        "type": "dialogue",
        "name": "播報員",
        "words": "那麼就從現在開始，進行決勝戰！",
        "unit_id": 311,
        "voice": "vo_adv_1001007_006"
    },
    {
        "type": "dialogue",
        "name": "播報員",
        "words": "\n有請選手……進場！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好的！",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_007"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n現在要上了！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500380"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊……！",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_008"
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "怎樣了！？就這點本事嗎！",
        "unit_id": 911,
        "voice": "vo_adv_1001007_009"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（這個人……很強！",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_010"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……明明應該和我一樣傷痕累累疲憊不堪的說……！）",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "妳看起來挺累的嘛……",
        "unit_id": 911,
        "voice": "vo_adv_1001007_011"
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "\n至今為止的比試讓妳消耗了不少體力吧？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "但我是不會手下留情的！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "求、",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_012"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "求之不得！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n如果不是全力以赴的對手的話，就算蠃了我也不會高興！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（…",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_013"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "…雖然我裝作沒事脫口而出這樣的話……、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n但其實已經沒什麼體力了……）",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "我要上了！",
        "unit_id": 911,
        "voice": "vo_adv_1001007_014"
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "\n",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "就這樣畫下句點吧！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（這樣下去的話……！",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_015"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我不甘心……！　我不甘心啊，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生……！）",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（……這個聲音是……騎士先生？",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_016"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n　從哪裡傳來的呢……？）",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（啊……我看到了。是騎士先生……",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_017"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "　騎士先生來了呢……騎士先生趕上了！）",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（騎士先生正看著……正看著我呢！",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_018"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n　所以，無論如何……）",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我絕不能輸！",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_019"
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "嗚啊！ 什、什麼……？",
        "unit_id": 911,
        "voice": "vo_adv_1001007_020"
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "\n妳從哪冒出這股力量……！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我可不能讓騎士先生看到我丟人的一面！",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_021"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我要上了唷！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "我可還沒完啊！",
        "unit_id": 911,
        "voice": "vo_adv_1001007_022"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不……",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_023"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不痛！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這種程度……沒事，完全不痛不癢呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "對戰對手",
        "words": "嗚哦啊啊啊啊……！",
        "unit_id": 911,
        "voice": "vo_adv_1001007_024"
    },
    {
        "type": "dialogue",
        "name": "播報員",
        "words": "成功擊倒！",
        "unit_id": 311,
        "voice": "vo_adv_1001007_025"
    },
    {
        "type": "dialogue",
        "name": "播報員",
        "words": "\n日和選手獲得優勝！ 恭喜妳了！！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生……我成功了！",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_026"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我成功勝出了……！",
        "unit_id": 100111
    },
    {
        "type": "background",
        "background": "500042"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我回來了～……騎士先生，真是感謝。",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_027"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果不借騎士先生肩膀撐著，我連好好走路都沒辦法……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒、沒事……",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_028"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "因為獲得優勝的高興心情比疼痛更強烈呀！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊嗚！　很痛痛痛……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "謝謝騎士先生……！",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_029"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "都是因為騎士先生來看我呀……！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "決賽的時候呀，途中差點就要輸了……",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_030"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n說真的已經覺得沒辦法了，就快要放棄投降了呢。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "不過呀，就在那個時候我聽到了騎士先生的聲音，",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_031"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n體內便湧出力量了唷……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以，這次能獲勝都是因為多虧了騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以……",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_032"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n有句話……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我想跟騎士先生說……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "啊、咦……？",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_033"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n一看到騎士先生、的臉……覺得很安心，就突然沒力氣了……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "……抱歉，我今天就這樣直接睡囉……",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_034"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "眼晴、都……睜不開了呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士、先生……",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_035"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n騎士先生的加油，讓我真的很……高興……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "呼……呼……",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_036"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "（謝謝了呢，騎士先生……）",
        "unit_id": 100111,
        "voice": "vo_adv_1001007_037"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "日和在{player}的胳臂中，\n看起來十分幸福地熟睡著。"
    }
]