        "name": "禊",
        "words": "\n就當作是答謝你今天陪禊來，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "還有你平常總是幫助禊！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯！",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_065"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊希望哥哥能收下！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊今天跟哥哥開心地冒險過了，光是這樣禊就非常滿足了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_066"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "既然哥哥收下禮物了，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "希望從今以後，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥也能陪禊一起玩、一起冒險！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n欸嘿嘿！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在重新認識到有比寶物還更重要的東西後，"
    },
    {
        "type": "dialogue",
