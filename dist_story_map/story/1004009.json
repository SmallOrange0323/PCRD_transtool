[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}在城中購物時，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n發現了似乎很高興的禊。"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "欸嘿嘿～",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_000"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "禊一直都很想要這種魔物的擺飾呢～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "看來這下子又能對哥哥惡作劇了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥會露出怎樣的表情呢？",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_001"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n禊等不及想看看了～♪",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "……啊，",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_002"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過禊在陷阱地洞裡出不來的時候，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好像是哥哥他",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "救禊出來的。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "他那時似乎很努力地在找禊……",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_003"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n平常也總是願意陪禊一起玩……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是不是應該送他什麼回禮比較好呢？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇！？",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_004"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "什麼嘛，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "原來是哥哥啊～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你才是呢，在這種地方做什麼呀？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這是什麼？",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_005"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這不是這附近的地圖嗎？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n這種東西根本沒必要……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n上面好像有很多標記。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這個標記該不會是！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哇！",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_006"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好棒好棒！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真好呢～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_007"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "但是哥哥你說",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這是你買的對吧？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "總覺得這張地圖還挺新的……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "你是不是被騙了呀？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "是這樣嗎？",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_008"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那麼真的是貨真價實的藏寶圖嗎～？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n而且比較大的標記是在很遠的山，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "搞不好真的有寶藏在那裡呢……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯～",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_009"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不去確認看看是不會知道的！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們兩人一起去確認吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n哥哥你也是禊探險隊的一員，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "可不能獨占寶物哦！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "咦？",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_010"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "原來是那樣嗎？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那你要先說嘛～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n欸嘿嘿。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那麼禊探險隊，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "出發～！",
        "unit_id": 100411
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "雖然很小，",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_011"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "但這裡也是有叉叉記號的地點呢。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這種地方會有寶物嗎～？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "明明聽說能一夜致富的，",
        "unit_id": 1011,
        "voice": "vo_adv_1004009_012"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n結果根本找不到魔石嘛！",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "\n",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "這樣看來果然我們也該去山上……",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "我剛才不是說過了嗎？",
        "unit_id": 311,
        "voice": "vo_adv_1004009_013"
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "那邊已經被挖得一乾二淨了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n既然如此，還不如在礦脈的周邊尋找還比較有希望。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性２",
        "words": "只要能找到幾顆，就能夠賺到錢了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "唉……",
        "unit_id": 1011,
        "voice": "vo_adv_1004009_014"
    },
    {
        "type": "dialogue",
        "name": "男性１",
        "words": "知道了啦。",
        "unit_id": 1011
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_015"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "那些人好像也在找寶物！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們也不能輸給他們！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "才沒那回事呢！",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_016"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "既然不在這裡的話，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們就去其他地方找找看吧！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "要走囉，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "哥哥！",
        "unit_id": 100411
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "嗯～",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_017"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "這裡好像也沒有。",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "完全找不到呢～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "老大，",
        "unit_id": 811,
        "voice": "vo_adv_1004009_018"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "差不多該放棄了吧～",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n都已經這麼努力地找了，卻還是找不到，",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n看來這裡已經沒有希望了啦～",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性4",
        "words": "吵死了！",
        "unit_id": 911,
        "voice": "vo_adv_1004009_019"
    },
    {
        "type": "dialogue",
        "name": "男性4",
        "words": "再挖深一點的話，搞不好就能找到了不是嗎？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性4",
        "words": "\n有時間動嘴巴的話，還不如快給我動手！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "啊，",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_020"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "又有在找寶物的人了！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "但是果然這裡也沒有嗎～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "男性4",
        "words": "啊？",
        "unit_id": 911,
        "voice": "vo_adv_1004009_021"
    },
    {
        "type": "dialogue",
        "name": "男性4",
        "words": "為什麼有小鬼在這裡？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "會不會是在玩的時候迷路到這裡了？",
        "unit_id": 811,
        "voice": "vo_adv_1004009_022"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "才不是呢！",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_023"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們是來找寶物的～！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "男性4",
        "words": "妳說什麼？",
        "unit_id": 911,
        "voice": "vo_adv_1004009_024"
    },
    {
        "type": "dialogue",
        "name": "男性4",
        "words": "妳以為你們這些小鬼，用那種玩耍的心態能找到嗎！？",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性4",
        "words": "\n就連我們這麼努力地找可都找不到啊！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "老、",
        "unit_id": 811,
        "voice": "vo_adv_1004009_025"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "老大！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "稍微冷靜點吧！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n就算遷怒小孩子也是找不到的啊！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性4",
        "words": "吵死了！",
        "unit_id": 911,
        "voice": "vo_adv_1004009_026"
    },
    {
        "type": "dialogue",
        "name": "男性4",
        "words": "我們去別的地方找，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性4",
        "words": "跟我來！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "是、",
        "unit_id": 811,
        "voice": "vo_adv_1004009_027"
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "是的！",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "哎呀～",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "真不好意思啊。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n老大",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "他因為在山上四處找了很久還是沒有收穫，所以變得有些暴躁。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "男性3",
        "words": "\n那就再見了。",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "為什麼大家這麼急躁呢～？",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_028"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "明明尋寶是很開心的事呀，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "真是莫名其妙～",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "不過，",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_029"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "既然也不在這裡的話，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n我們還沒找的地方就剩下……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "山上？",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "雖然那些大叔似乎是從山上來的，",
        "unit_id": 100411,
        "voice": "vo_adv_1004009_030"
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "\n但是我們還沒去看過呢……",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "好！",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
        "words": "我們走吧，",
        "unit_id": 100411
    },
    {
        "type": "dialogue",
        "name": "禊",
