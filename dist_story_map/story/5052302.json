        "voice": "vo_adv_5052302_001"
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "Lovely★莫妮卡！",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "\n反逆獸",
        "unit_id": 114311
    },
    {
        "type": "dialogue",
        "name": "Shiny★智",
        "words": "不會乖乖束手就擒的。",
