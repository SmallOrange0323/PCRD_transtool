        "voice": "vo_adv_5052302_002"
    },
    {
        "type": "dialogue",
        "name": "Misty★霞",
        "words": "似乎變得更強了呢……！",
        "unit_id": 112211
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "敵人越變越強了呢……！",
