        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n有我魔法提督在場，",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "絕不容許你繼續作惡下去！",
