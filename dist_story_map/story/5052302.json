    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "不過，",
        "unit_id": 112311
    },
    {
        "type": "dialogue",
        "name": "Purely★栞",
        "words": "我們可是也在持續進步的……！",
