        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n我就來回應妳的志氣吧！",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "閃耀吧，",
        "unit_id": 114211,
        "voice": "vo_adv_5052302_005"
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "愛之力！",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "\n──可愛閃光！",
        "unit_id": 114211
    },
    {
        "type": "dialogue",
        "name": "反逆獸",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 14111
    },
    {
        "type": "dialogue",
        "name": "Lovely★莫妮卡",
        "words": "由我擔任先鋒！",
