[
    {
        "type": "background",
        "background": "500790"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "這一天，雪菲和{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了尋找記憶的線索，到街上四處走走。"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……前面就是、",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "王宮……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_001"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "再怎麼樣，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n也不可能用「想找回記憶」這種理由，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n跑進王宮裡四處走動吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不了……",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然貪吃佩可小姐",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "應該會很爽快地答應……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但還是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "算了吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "如果我真的",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_003"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "和王宮的人有關聯的話，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n王宮早就對外",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "發布搜索令了吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "況且……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我曾經",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_004"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "背負過",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「暗殺王族未遂」的嫌疑。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "雖然已經撤銷通緝了，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n但我也不想引起不必要的騷動。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯……",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_005"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那個，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "因為我可以想起……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "自、",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "自己變成小嬰兒時候的事。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以，",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_006"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我也記得",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "自己在王宮的地牢裡，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n被那個討人厭的貴族當作通緝犯對待的事。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過……",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我還是不明白，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n失去記憶前的自己，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n為什麼會盯上那個叫做霸瞳皇帝的人……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "吶，{player}。",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n你們",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "曾經和霸瞳皇帝交戰過吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "為什麼呢？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……是呀。",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_009"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我常聽人說",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "霸瞳皇帝是個邪惡又殘忍的人。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就連凱留",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也被他利用了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不僅奪走貪吃佩可小姐雙親的王族權力，",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_010"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n還對士兵和貴族進行洗腦，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n消除與貪吃佩可小姐相關的記憶，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "最後",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "甚至痛下殺手……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "果然……",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_011"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是個",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "十惡不赦的人呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "無論他的目的是什麼，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "都讓貪吃佩可小姐陷入了殘酷的困境。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n對我來說，他也是個不可饒恕的對象。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那麼……",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "過去的我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也是想要打倒壞人嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n如果是這樣，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那或許……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那還有轉圜的餘地。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "嗯。",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n如果",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這就是原因的話，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我和{player}你們",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就是相同的立場了呀。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "最害怕的就是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怜小姐的",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "擔憂成真。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "萬一",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「失去記憶前的自己」……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是你們的敵人。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但也不能說",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_016"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "完全沒有這種可能性吧？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "如果",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「以前的我」會盯上霸瞳皇帝的原因，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n既不是因為他是壞人，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也不是因為他是貪吃佩可小姐的敵人……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……而是因為",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "他是「七冠」之一的話。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這樣……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "你那個可麗餅店的好朋友，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n也是「以前的我」的敵人。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……如果",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_018"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "真的是這樣的話……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n我會是……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "{player}的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "…………",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_019"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……「以前的我」",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……到底是",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "怎麼回事呀。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "居然會從比那座城堡還要高的……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "「索爾之塔」",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "掉下來。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……為什麼呢……？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n雖然貪吃佩可小姐",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n應該也會很爽快地答應吧……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但是……",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_022"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那座塔裡",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有很強大的魔物四處徘徊。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "也不能保證",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "那裡一定有找回記憶的線索。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……我不希望",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "大家為了我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "冒生命危險。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "所以……",
        "unit_id": 106412,
        "voice": "vo_adv_1064002_023"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我打算暫時",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "先在安全的地方走走看看。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n這座城鎮也很大，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n搞不好",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "城外也會有線索呀。",
