[
    {
        "type": "background",
        "background": "501001"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "這場戰役，",
        "unit_id": 4611,
        "voice": "vo_adv_5042411_000"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "終於快結束了呢……",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "……我要先向你們",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "道個謝。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n你們明明只是被我牽扯進來的，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "謝謝你們還願意",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "和我一起戰鬥。",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "……愛麗絲，",
        "unit_id": 112911,
        "voice": "vo_adv_5042411_001"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "不需要道謝啦。",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我才想向妳說謝謝呢。",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "我獲得了許多經驗……",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "現在",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "成長了很多！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "對啊對啊。",
        "unit_id": 100113,
        "voice": "vo_adv_5042411_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是我們自己決定要戰鬥的。",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n而且……",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "雖然發生了很多事，但還是滿有趣的啊♪",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我、",
        "unit_id": 113011,
        "voice": "vo_adv_5042411_003"
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我也是，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "雖然一開始突然跑來陌生的地方時我很害怕，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "但能跟璃乃妳們聊天……",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "和妳們",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "感情變好，",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "\n",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "步未",
        "words": "我真的很開心……！",
        "unit_id": 113011
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 106612,
        "voice": "vo_adv_5042411_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "直到最後妳們還是悠悠哉哉的。",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我一點都不覺得有趣，",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "反而吃盡苦頭了啦。",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我不想再忍受這種遭遇了！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "……雖然嘴上這麼說，",
        "unit_id": 106711,
        "voice": "vo_adv_5042411_005"
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "但祈梨其實",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "帆稀",
        "words": "\n很享受當女王的生活啦～♪",
        "unit_id": 106711
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不、",
        "unit_id": 106612,
        "voice": "vo_adv_5042411_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不要多嘴好嗎！",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……不過",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "確實是不錯",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啦。",
        "unit_id": 106612
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "妳們……",
        "unit_id": 4611,
        "voice": "vo_adv_5042411_007"
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "呵呵，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n既然如此，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "那就借我使喚妳們到最後吧！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "\n",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "走囉，",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "愛麗絲",
        "words": "去和黑之王一決勝負！",
        "unit_id": 4611
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "好！",
        "unit_id": 112911,
        "voice": "vo_adv_5042411_008"
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "\n我們去完美地拯救世界，",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "璃乃",
        "words": "迎接快樂的結局吧！",
        "unit_id": 112911
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "喔～！",
        "unit_id": 1,
        "voice": "vo_adv_5042411_009"
    }
]