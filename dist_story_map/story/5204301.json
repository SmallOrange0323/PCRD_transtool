        "words": "\n",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "我是天才鍊金術師瑪莉絲黛菈！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "\n",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "這種程度的鍊金術，",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "瑪莉絲黛菈",
        "words": "對我來說小菜一碟啦！",
        "unit_id": 53111
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "哇──",
        "unit_id": 132411,
        "voice": "vo_adv_5204301_002"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好厲害！",
