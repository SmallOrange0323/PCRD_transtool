        "voice": "vo_adv_5204301_004"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n做好覺悟了吧……",
        "unit_id": 132311
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "祖母！！",
