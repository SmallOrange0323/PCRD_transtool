        "voice": "vo_adv_1027008_000"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今天一定要讓您喝下我所製作的藥。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這可是精心製作的喲。",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_001"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只要喝了這藥，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人的心就是我的了……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n嘻嘻嘻……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼，",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_002"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請用。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您喝下這藥吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……為、",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_003"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為什麼您不喝呢？\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我特地為了{player}大人您――",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀……",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_004"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這道光是？\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "之前好像也",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "發生過類似的事……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好、",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_005"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好剌眼……\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "呀啊啊啊！",
        "unit_id": 102711
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_006"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "快要完成了……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_007"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是{player}大人您呀。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "打擾了……\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我稍微借用了一下您的廚房。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您問我是怎樣進入屋子裡……",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_008"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "的嗎？\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請不用在意。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只要兩人彼此相愛，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_009"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就可以跨越任何障礙。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒錯……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "即使是玄關的鑰匙，\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也無法分開我們兩人的。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "實在非常抱歉，\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_010"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我還差一點點就能完成準備工作。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在此之前請您耐心等待……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來吧，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_011"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您聞一下這個味道……\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是不是漸漸變得想睡了？",
        "unit_id": 102732
    },
    {
        "type": "still",
        "still": "102700801"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_012"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您醒來了嗎？",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "假如您跑掉的話我會很困擾的，\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_013"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因此我把您稍微綁起來了……\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "很擅長綑綁的。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "剛好菜已經做好了。\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_014"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "地中海風味意大利燉飯……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這是自信之作唷。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "別看我這樣，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_015"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "其實我很擅長做飯呢。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為料理跟調製藥品差不多……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "哎呀，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_016"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也是有這種手段呢……\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在好像很好吃的菜餚內，",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "悄悄加入媚藥……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請您放心。\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_017"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這道料理之中",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "並沒有放入奇怪的東西。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "為了{player}大人，我可是做得非常美味呢。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果您覺得無法相信的話，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_018"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我就來試毒一下……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "啊嗯。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗯～",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_019"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好吃……\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "連我自己",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "都覺得好吃。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "看吧，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_020"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我什麼事都沒有。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您能相信我了吧？",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……可是呢，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_021"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我不能讓您白白享受這道料理。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這道料理是獎勵。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_022"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "今天想要來\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "幫忙{player}大人溫習功課……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "根據我聽說到的消息，\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_023"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您正為了準備考試而非常辛苦……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人的痛苦就是我的痛苦。\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_024"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "所以",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我決定來幫助您溫習功課。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因此就是",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_025"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這道料理該登場的時候了。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "獎勵與處罰的搭配對學習很有效果……\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_026"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果您答對我的問題，\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "就可以吃這道料理。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "但只要您答錯任何一道問題……\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_027"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我想您還是不要知道比較好。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼呢，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_028"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我現在要出題了。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為我會擔心{player}大人的身體，\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "所以請您千萬不要答錯了……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼呢，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_029"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "首先從基本問題開始……\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "一個直徑為10公分的球體，表面面積是多少？",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……咦？",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_030"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您說這不是基礎問題……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嗎？\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒有這回事，",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果是{player}大人的話，\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這種程度只是入門的入門而已。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "來吧，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_031"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請作答……？",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "100π……",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_032"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "沒錯，",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "答對了。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "接下來，是下一道問題……",
        "unit_id": 102732
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_033"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真不愧是您。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "直到目前為止全部都答對了。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼呢，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_034"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "接下來是最後一道問題……\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是有關費馬最後定理的問題。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您在驚訝什麼？\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_035"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您說這不是高中生水準的問題？",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我不希望{player}大人",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_036"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "只擁有普通高中生的水準而已。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "所以呢，",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我要出題了。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在下列有關費馬最後定理的陳述中，\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_037"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "包含了有錯誤的內容……\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請問在A和B的內容中，",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "是哪一個有錯呢？",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "好了，",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_038"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人、",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "請回答吧。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "如果不快點的話就沒時間了呦？\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "3……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "2……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "1……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真不愧是{player}大人！\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_039"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "答對了。",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "其實兩者都是對的。\n",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_040"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您竟然識破了……",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "真是厲害。\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "那麼呢，",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "作為獎勵請您品嘗這道料理 ――",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……哎呀？",
        "unit_id": 102732,
        "voice": "vo_adv_1027008_041"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人真是的，\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "竟然高興到哭出來……\n",
        "unit_id": 102732
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您就這麼想吃我煮的料理呢。",
        "unit_id": 102732
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好的，",
        "unit_id": 190011,
        "voice": "vo_adv_1027008_042"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦了。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "惠理子這個人……\n",
        "unit_id": 190011,
        "voice": "vo_adv_1027008_043"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還是老樣子",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "非常可怕呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就算是為了提高你的成績，\n",
        "unit_id": 190011,
        "voice": "vo_adv_1027008_044"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "但是居然將你綑綁起來，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還威脅你……！",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "不過呢，",
        "unit_id": 190011,
        "voice": "vo_adv_1027008_045"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "也是她非常認真地愛著你，\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "所以才會有這樣的行動吧。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "從這個角度來看的話，我很羨慕你喔。\n",
        "unit_id": 190011,
        "voice": "vo_adv_1027008_046"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "雖然這份愛是有點沉重……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "哎呀，",
        "unit_id": 190011,
        "voice": "vo_adv_1027008_047"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果她能稍微變得正常一點的話，\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "應該會是一個很好的孩子，\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你就努力看看吧？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "那麼，",
        "unit_id": 190011,
        "voice": "vo_adv_1027008_048"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這次就先聊到這裡。\n",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "掰掰囉♪",
        "unit_id": 190011
    },
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……\n",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_049"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "{player}大人，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您醒來了嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "不，",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_050"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我什麼都沒做呦。\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我也是睡到剛剛才醒來……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我作了一個非常甜美的夢。\n",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_051"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我為{player}大人您做了料理……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_052"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "您說是讀書的獎勵",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "……嗎？\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "總覺得我們好像作了相同的夢呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "以前好像",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_053"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "也發生過類似的事情……\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我與{player}大人之間，\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "果然是由命運彼此相繫在一起的呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "咦？",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_054"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "在吃到料理之前就醒了……？\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "這樣的話，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我現在就做給您吃吧？\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我借用一下廚房呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "機會難得，\n",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_055"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "我就把今天做好的藥加到菜裡面……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "嘻嘻……",
        "unit_id": 102711,
        "voice": "vo_adv_1027008_056"
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "開玩笑的。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "因為是{player}大人的要求，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "惠理子",
        "words": "\n我當然會做出非常美味的料理。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在這之後，\n兩人就像平常一樣，\n一起享受惠理子做的美味菜餚。"
    }
]