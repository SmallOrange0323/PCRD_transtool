[
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "真琴和{player}結束與魔物們的激戰，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n回到了蘭德索爾。而後真琴似乎很難為情地，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n提及了剛剛安博等人所說的約會一事。"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊──",
        "unit_id": 129811,
        "voice": "vo_adv_1298004_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "該怎麼說呢……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n剛剛",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓你配合新人們的奇怪興致，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "抱歉了啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的……",
        "unit_id": 129811,
        "voice": "vo_adv_1298004_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "佐藤她們喜歡談戀愛話題這點讓人很困擾啊。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我跟你明明就",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不、",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不可能……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "去約會什麼的啊……",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……算了，",
        "unit_id": 129811,
        "voice": "vo_adv_1298004_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不說那個了。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "必須",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "感謝你幫我擊退魔物才行呢。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "等一下你要是有空，",
        "unit_id": 129811,
        "voice": "vo_adv_1298004_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就順便",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "來我家一趟吧。",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我會做你想吃的東西給你♪",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……你說很期待我的料理？",
        "unit_id": 129811,
        "voice": "vo_adv_1298004_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哈哈，",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可以好好期待喔？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n因為我已經大致知道你偏好的調味了！",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嗯？",
        "unit_id": 129811,
        "voice": "vo_adv_1298004_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你是",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "怎麼回事？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "總覺得你在發光耶……？",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你果然",
        "unit_id": 129811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "讓人搞不懂……！",
        "unit_id": 129811
    },
    {
        "type": "background",
        "background": "510220"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你說有事找我商量……",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "到底是什麼啊？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我想你八成是找錯商量的對象",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "了喔。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……你說作為平日的謝禮，",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要送點心給優衣當禮物！？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說的好！",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我對你",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "刮目相看了喔！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n想送禮物就代表",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你在意優衣對吧！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "夥伴……",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "算了，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不管怎樣都好。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n這下似乎總算能前進一步了啊……！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "既然要送點心，",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就必須是特別的東西才行呢。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要做出符合優衣喜好的點心喔！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那種事",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是理所當然的吧！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n做出滿懷心意的點心交給她吧！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "作法那些全部都由我來教你！",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n放學後",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就到你家進行特訓吧！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你可別逃跑喔！",
        "unit_id": 104331
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好，",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "買了很多的食材，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "都準備好了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "多虧有我才省下一筆錢，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要感謝我喔？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那種事是常識吧？",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖說不論是飯還是點心，好吃都是最重要的，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n但也不能無視價格啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……喔。",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "比起那種事",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我們趕快開始做點心吧。",
        "unit_id": 104331
    },
    {
        "type": "still",
        "still": "129800401"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼，",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "圍裙穿好了呢。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "從現在開始，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就把我當成魔鬼教官吧！！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "在你能做出配得上優衣的點心之前，",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我會徹底地反覆訓練你的！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "給我做好心理準備！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦，",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "很有幹勁嘛。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "值得好好讚許♪",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n總之，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不必太擔心。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我不會刁難你。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這次",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要讓你做起司蛋糕。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n難度沒有那麼高，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就算是初學者也很難失敗。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "所以說，",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你不要太緊張了啊。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那麼",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就立刻開始做吧。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "首先，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "從把餅乾搗碎",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "做出基底的部分開始。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊啊，",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "搗成稍粗一點的碎片就可以了喔。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……話說回來，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我可以",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "稍微問一下嗎？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "現在",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "跟優衣",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是什麼樣的感覺？",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣啊這樣啊，",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯……！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n氣氛感覺相當不賴呢！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "為什麼啦！",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我也一起去的話不就白費了嗎！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "給我跟優衣兩個人去冒險，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "聽懂了嗎！",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……嗯？",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你好像把餅乾搗好了呢。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣的話，",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "接下來……",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……到這邊",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "就差不多都做完了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n接下來只要在烤箱裡烤一會就好了。",
        "unit_id": 104331
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哈，",
        "unit_id": 104331,
        "voice": "vo_adv_1298004_027"
    },
