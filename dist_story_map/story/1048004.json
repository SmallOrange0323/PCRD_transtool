        "voice": "vo_adv_1048004_037"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你也做了一樣的夢嗎？",
        "unit_id": 104811,
        "voice": "vo_adv_1048004_038"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "也有這樣不可思議的事情呢……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不管怎麼說，我做了沒有效率的事情……",
        "unit_id": 104811,
        "voice": "vo_adv_1048004_039"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不、不過都是因為你想要",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n把頭伸到那種地方……再怎麼說那也太……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
