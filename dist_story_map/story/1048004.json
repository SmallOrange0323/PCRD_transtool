    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那麼，今天也要訓練喔！",
        "unit_id": 104811,
        "voice": "vo_adv_1048004_000"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "試試接我一擊吧！",
        "unit_id": 104811
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "不錯嘛！ 刀刃的交會之處火花四散呢！",
        "unit_id": 104811,
        "voice": "vo_adv_1048004_001"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……咦？ 不是火花？",
        "unit_id": 104811,
        "voice": "vo_adv_1048004_002"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這道光完全沒有消失啊。",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "而且變得越來越大……",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呀啊啊啊啊啊！",
        "unit_id": 104811,
        "voice": "vo_adv_1048004_003"
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼、",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_004"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呼……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還、還有追來嗎……？",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_005"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……！ 你、你！",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": " 安、安靜一下！",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我要封住你的嘴喔！",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，對了，用這個背擋住的話！",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_007"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你！ 讓我躲在你的背後一下吧！",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……！ ",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_008"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "來了！",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "喔喔喔喔喔――！ 美冬，",
        "unit_id": 1231,
        "voice": "vo_adv_1048004_009"
    },
    {
        "type": "dialogue",
        "name": "女性１",
        "words": "妳在哪裡―――！",
        "unit_id": 1231
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "說不定在那裡喔！ 去找吧――！",
        "unit_id": 1,
        "voice": "vo_adv_1048004_010"
    },
    {
        "type": "dialogue",
        "name": "女性２",
        "words": "\n嗚喔喔喔喔喔喔喔――――！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……呼，似乎總算是避開她們了呢。",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦，你問我剛剛成群的女孩子是怎麼了嗎？",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_012"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個啊……我在打工的地方呼籲改善女性的工作環境，",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_013"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n為了提高工資而努力後，不知不覺間，",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就像那樣開始受到女孩子們仰慕…",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "…",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "明天在打工的地方有個舞會……",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_014"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "結果想要我當舞伴的邀請蜂擁而至，",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n變成那個樣子了呢……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "咦……？ 我、我才沒和男孩子……說過話呢。",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_015"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n除了你以外……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那個，等等，",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n不要用那種同情的眼神看我啊！？",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，那些孩子們回來了！",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_016"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n這次……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "進到那邊的小巷避開她們吧！",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你也一起進來！",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_017"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "……雖然順勢進來了……",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_018"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但是這條小巷好窄啊……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "這、這也是不得已的事，",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_019"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n我就這麼順勢拉你進來了！",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "啊，你的頭還露在外面！",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_020"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "如、如果不再靠近一點是藏不住的喔！",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_021"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "還、還有露出一點嗎？",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_022"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要更有效率地躲起來，",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "就要把這隻手臂像這樣，",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "繞過頭……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "等、等一下，總覺得身體好熱啊！？",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_023"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但、但是還不夠有效率呢。",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_024"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "要更有效率地躲起來，只要把你的頭，",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n那個……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "伸、伸到我的大腿之間的話……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我、我知道了。",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_025"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n你、",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "你就這樣低下頭，在、在我的……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "大腿",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n之間……",
        "unit_id": 104831
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "果、果然還是不行――――",
        "unit_id": 104831,
        "voice": "vo_adv_1048004_026"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "！",
        "unit_id": 104831
    },
    {
        "type": "background",
        "background": "510290"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "美冬用力把{player}的頭推回原處的瞬間，\n兩人從小巷裡被拋了出去。"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "呀啊！ ",
