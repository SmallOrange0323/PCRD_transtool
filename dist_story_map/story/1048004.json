    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "剛剛的情景，是我依照你和美冬的『記憶碎片』",
        "unit_id": 190011,
        "voice": "vo_adv_1048004_033"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n創造出來的『夢』唷。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "話雖如此，",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你還真是佔了不少好處呢。算了，沒關係。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "如果你收集到更多的『記憶碎片』，",
        "unit_id": 190011,
        "voice": "vo_adv_1048004_034"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n我就會再讓你做『夢』的。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你和許多女孩在一起的『夢』做得越多……",
        "unit_id": 190011,
        "voice": "vo_adv_1048004_035"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
