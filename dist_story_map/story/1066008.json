[
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在蘭德索爾的巷弄中走著的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n被一個充滿朝氣的叫喚聲攔了下來。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 106611,
        "voice": "vo_adv_1066008_000"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我找你好久了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然你一直都很閒的話，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就不能在更好找的地方閒晃嗎！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哎呀呀，",
        "unit_id": 106611,
        "voice": "vo_adv_1066008_001"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對了。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼哼……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你就儘管搖著尾巴高興吧，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我今天啊……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要來請你吃飯！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我之前在火山那裡覺醒，",
        "unit_id": 106611,
        "voice": "vo_adv_1066008_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n為了保護小哥，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就把魔物揍一頓扔出去、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "再揍一頓再扔出去的事情，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你應該還記得吧？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我有啦！",
        "unit_id": 106611,
        "voice": "vo_adv_1066008_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "哼哼哼，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然我一擊就把它解決掉，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n所以沒有揍也沒有扔就是了！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "沒錯沒錯！",
        "unit_id": 106611,
        "voice": "vo_adv_1066008_004"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不愧是小哥！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n理解力真快，讓我省了不少麻煩。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……不過，",
        "unit_id": 106611,
        "voice": "vo_adv_1066008_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個覺醒實際上和嘉夜夜的一樣，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n好像都不算是真正的覺醒……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我把當時為保護小哥而戰的事，",
        "unit_id": 106611,
        "voice": "vo_adv_1066008_006"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "告訴老大和嘉夜夜之後，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n她們竟然給了我薪水和零用錢喔。",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "欸嘿嘿嘿……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……但是，",
        "unit_id": 106611,
        "voice": "vo_adv_1066008_007"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "扣掉之前不小心亂買東西花的錢，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n現在應該已經所剩無幾了……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，能拿到錢",
        "unit_id": 106611,
        "voice": "vo_adv_1066008_008"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "多少也有一點點",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是因為小哥的關係，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n所以今天就由我來請客！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "作為幫派分子，",
        "unit_id": 106611,
        "voice": "vo_adv_1066008_009"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可不能做出把錢留到隔天這種丟臉的行為！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "來吧，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要把錢一口氣花光光！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這就是我",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "邁向幫派之路的第一步！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥，",
        "unit_id": 106611,
        "voice": "vo_adv_1066008_010"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我知道你很高興，",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但也不至於高興到發光……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "光？",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小、",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥！",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n怎麼好像",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "又在發光……",
        "unit_id": 106611
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "了……",
        "unit_id": 106611
    },
    {
        "type": "background",
        "background": "510370"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "來到動漫商店的{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n看見了一個熟悉的身影。"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那、",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_011"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有什麼事嗎……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n為什麼從剛剛開始就一直盯著我看……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你再這樣下去我要叫人了……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……啥？",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_012"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼最強的阿斯特朗玩家祈梨，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我不認識那種人喔～？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n話說回來，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥你是哪位啊～？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……我不認識那個人耶……",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_013"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n你、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你認錯人了喔？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "這位客人？",
        "unit_id": 1,
        "voice": "vo_adv_1066008_014"
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "請問發生什麼事了嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫呀？",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_015"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "那個男生，",
        "unit_id": 1,
        "voice": "vo_adv_1066008_016"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "好像不認識這個女孩子，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "卻一直纏著她……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "您沒事吧，",
        "unit_id": 1,
        "voice": "vo_adv_1066008_017"
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "客人。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "\n……請不要在我們店裡搭訕。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦？",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_018"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "好像有很多人誤以為，",
        "unit_id": 1,
        "voice": "vo_adv_1066008_019"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "會出現在這種店裡的人，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n都是些很好騙到手的宅宅呢！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "事事事、",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_020"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "事情不是這樣的……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "你要是再纏著她的話，",
        "unit_id": 1,
        "voice": "vo_adv_1066008_021"
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "我就叫警察來了喔？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦咦咦！？",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_022"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這樣我會很困擾……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "別擔心，",
        "unit_id": 1,
        "voice": "vo_adv_1066008_023"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "我們都站在妳這邊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n束手就擒吧，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "搭訕男！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "雖然的確是誤會沒錯，",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_024"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但在這種情況下也很難說清楚……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "竟然還向那個女孩子搭話！",
        "unit_id": 1,
        "voice": "vo_adv_1066008_025"
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "看來你是講不聽呢。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就、",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_026"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就算你這樣看著我，我也沒辦法啦小哥……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "竟然還擅自叫了那個女孩子的名字！",
        "unit_id": 1,
        "voice": "vo_adv_1066008_027"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n真是讓人看不下去了！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "店長！",
        "unit_id": 1,
        "voice": "vo_adv_1066008_028"
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "叫警察……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "請、",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_029"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "請等一下！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那個……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這位小哥",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是我認識的人！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "咦？",
        "unit_id": 1,
        "voice": "vo_adv_1066008_030"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "是這樣嗎？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n那妳為什麼……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "啊！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "……我知道了……",
        "unit_id": 1,
        "voice": "vo_adv_1066008_031"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "那種不想被熟人發現",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n自己在買同人誌",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "的心情……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "我能夠體會呢……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "唉……",
        "unit_id": 1,
        "voice": "vo_adv_1066008_032"
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "如果是這樣的話……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "動畫店員",
        "words": "\n請妳下次別再做這種事了喔？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我明白了……",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_033"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "這位小哥也是。",
        "unit_id": 1,
        "voice": "vo_adv_1066008_034"
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "\n打擾正在物色同人誌的人",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "女顧客",
        "words": "可是很失禮的喔？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥要好好反省喔，",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_035"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也要道歉嗎！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚嗚嗚……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "對不起……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真的是添了大麻煩啦！",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_036"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "噫？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我、",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我也是嗎？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗚嗚……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真對不起，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "給你們添麻煩了……",
        "unit_id": 106631
    },
    {
        "type": "background",
        "background": "510071"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真是的！",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_037"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥害我臉丟大了啦！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我再也不敢去那間店了！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊嗚嗚……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那裡可是有很多別的地方都買不到的東西耶……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "不過，",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_038"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "幸好我今天已經買到這個了，就算了吧……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "什麼啊。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n小哥該不會也覺得同人誌",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是個見不得人的東西吧！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那是錯誤觀念啦！",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_039"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這本",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "《龍膽掃帚的",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "阿斯特朗冒險日記》",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n可是很健全的讀物喔。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你看！",
        "unit_id": 106631
    },
    {
        "type": "still",
        "still": "106600801"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊──",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_040"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我終於買到了！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n在這個年代裡，沒有在任何活動中販售，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "甚至連電子版書籍都沒有！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這種只透過寄售的同人誌，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "可是非常稀有的喔。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦，",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_041"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥完全不知道嗎！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n啥？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "真的嗎？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "咦咦咦咦咦？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥，",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_042"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你竟然不認識「龍膽掃帚」老師嗎！？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n這也太不可思議了吧？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "你太外行了啦，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "外行！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n根本就是個假玩家！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這位老師之前在知名的SNS網站上傳插畫日記，",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_043"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n但是馬上就刪除了。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "統整老師作品的網站也一下就不見了……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "有謠言說，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "他甚至還拒絕了阿斯特朗月刊的取材邀約……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "能讀到",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_044"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這位身分不明的神秘作家，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "「龍膽掃帚」老師\n作品的管道，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "就只有這本統整了老師插畫日記的同人誌！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n而且還有附上未公開的內容喔！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "……不過，",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_045"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "要是小哥無論如何都想要讀讀看的話，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我也可以借你看看喔？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "畢竟不明白它有趣之處的這種事，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "已經可以算是一種罪了……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "小哥就一邊感謝我那比神秘森林還要寬闊的胸懷一邊讀吧！",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_046"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n好了，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "去坐在那裡讀！",
        "unit_id": 106631
    },
    {
        "type": "background",
        "background": "510071"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔～嗯，",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_047"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "話說回來，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "「龍膽掃帚」老師",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n究竟是個怎麼樣的人呢……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她一定是個",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_048"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "很會照顧別人、既溫柔又美麗的人……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n肯定和那個給了我龍人角色，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總是嘻嘻笑的奇怪阿姨差很多！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "嗯？",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個未公開內容裡的……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "是誰啊，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這個小不點。",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "「這是我疼愛的孩子的肖像畫喔～",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_049"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n她有些傻乎乎的，",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "讓人無法置之不理呢♪",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n雖然現在和我還不太親近，不過那正是她的可愛之處～」",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "唔～！",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_050"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這傢伙也太不知感恩了吧！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n光是能被「龍膽掃帚」老師關心",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n就已經夠讓人羨慕了！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她怎麼可以如此無禮！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "啊啊～",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_051"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "好嫉妒喔～！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我身邊就只有那個總是嘻嘻笑的阿姨啊！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是，",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_052"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "我才不會認輸呢！",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我要用那個阿姨給我的龍人角色向上爬……",
        "unit_id": 106631
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "成為阿斯特朗裡的大人物，",
        "unit_id": 106631,
        "voice": "vo_adv_1066008_053"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n和「龍膽掃帚」老師見面！",
        "unit_id": 106631
    },
    {
        "type": "background",
        "background": "500270"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "好了，",
        "unit_id": 190011,
        "voice": "vo_adv_1066008_054"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "辛苦囉。",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "你只要和祈梨待在一起\n就總是會被捲入麻煩中呢……",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "還有，那個插畫日記裡出現的孩子，",
        "unit_id": 190011,
        "voice": "vo_adv_1066008_055"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "\n你不覺得很眼熟嗎？",
        "unit_id": 190011
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "這種情況",
        "unit_id": 190011,
        "voice": "vo_adv_1066008_056"
    },
    {
        "type": "dialogue",
        "name": "愛梅斯",
        "words": "就叫做當局者迷吧。",
