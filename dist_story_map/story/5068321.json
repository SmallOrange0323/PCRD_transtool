[
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "唔唔唔唔唔……",
        "unit_id": 14912,
        "voice": "vo_adv_5068321_000"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我不要！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我絕對不要！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n我",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "想跟小孩子玩～！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請停止吧……",
        "unit_id": 116713,
        "voice": "vo_adv_5068321_001"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那樣只會害孩子們傷心難過……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n拜託了，",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "請聽我們說話吧……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "聽妳在胡說八道！",
        "unit_id": 14912,
        "voice": "vo_adv_5068321_002"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "我可是最棒的玩具喔！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n孩子們也",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "超愛我的！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "……看來",
        "unit_id": 7311,
        "voice": "vo_adv_5068321_003"
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "必須要助妳們一臂之力了。",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "無敵好朋友號",
        "words": "\n就讓它見識一下我們的友情吧！",
        "unit_id": 7311
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "無敵好朋友號……！",
        "unit_id": 116713,
        "voice": "vo_adv_5068321_004"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "你願意跟我們一起戰鬥對吧……！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "就大家一起同心協力",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "加油吧！",
        "unit_id": 116713
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "哼……！",
        "unit_id": 14912,
        "voice": "vo_adv_5068321_005"
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "才100隻合體的玩具是能做什麼？",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "\n我的身體可是有1000隻！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "這一聽就知道",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "機械玩具王",
        "words": "誰比較優秀吧！",
        "unit_id": 14912
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "那可不好說。",
        "unit_id": 116911,
        "voice": "vo_adv_5068321_006"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "數量是比不上你，",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "但友情足以彌補那一點！",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "\n",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "玩具王，",
        "unit_id": 116911
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "我們會讓你親身體驗到那點！",
        "unit_id": 116911
    }
]