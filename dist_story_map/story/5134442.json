[
    {
        "type": "background",
        "background": "500553"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那個呀，",
        "unit_id": 128411,
        "voice": "vo_adv_5134442_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "老實說呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "結果，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我到最後一刻都在宇宙空間",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "跟隕石展開激戰！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "大概",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "真的只是作了個夢而已！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "嗯，",
        "unit_id": 128511,
        "voice": "vo_adv_5134442_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "我也很抱歉，說了那種亂來的話。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n本來只是",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "想緩解初音的緊張而已。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "請你當作沒有作過那個夢，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "忘掉吧。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "但是",
        "unit_id": 128311,
        "voice": "vo_adv_5134442_002"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "這不是成功消除不安了嗎？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "她現在的臉色也比剛剛好多了。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "因為的確有成功破壞隕石了。",
        "unit_id": 128411,
        "voice": "vo_adv_5134442_003"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n雖然沒辦法採用相同的方法，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "但我已經有足夠的自信了！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那樣就夠了。",
        "unit_id": 128511,
        "voice": "vo_adv_5134442_004"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "本來",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是想讓你放鬆，好面對正式作戰的時候。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "接下來就只剩下在現實中粉碎隕石了。",
        "unit_id": 128311,
        "voice": "vo_adv_5134442_005"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n我們一起上的話，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "一定會有辦法的。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n不知道啦，大概。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯",
        "unit_id": 128411,
        "voice": "vo_adv_5134442_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "嗯！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就重新來一次……",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我們大家",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "一起去破壞隕石吧～！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "３人",
        "words": "喔～！！",
        "unit_id": 1,
        "voice": "vo_adv_5134442_007"
    }
]