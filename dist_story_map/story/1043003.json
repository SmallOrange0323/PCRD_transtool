[
    {
        "type": "background",
        "background": "500050"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "～……♪",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_000"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n好像聽到大門被打開的聲音？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "明明就有擺出「準備中」的看板，",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_002"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n偶爾還是有看都不看就進來的傢伙呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "真是的，好麻煩啊……？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "難得有「享樂」的心情的說。",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "哦唷，可不能忘了待客微笑～？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "歡迎光臨～♪",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_004"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不好意思，還沒到開店的時間……",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_005"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n欸，唉呀？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}！\n店裡還在準備你就跑過來……",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_006"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我們這裡是晚上才開始營業的哦，我說過好多次了吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "話說，是不是因為之前請你吃了晚飯……",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嘗到甜頭後，又想跑過來白吃嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我可沒有人好到",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_008"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n會免費招待你那麼多次哦？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這不是錢的問題啦",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_009"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你也想想這樣會給我們添麻煩的。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好吧，算了。",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_010"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你肚子餓了對吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯……沒有下次了，",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_011"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就只有這一次，再請你吃點東西也行？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "畢竟和人一起吃飯吃得比較香呢。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "欸……？",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_012"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那、那個？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你你你、你是什麼意思！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，怎麼會……",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_013"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n糟糕了，這樣會惹優衣生氣……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "那個，是我聽錯了吧？",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_014"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你再說一次看看，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "………",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_015"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "…",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "雖、雖然不太懂你在說什麼。",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_016"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要是你肚子餓了，要不要吃點東西……？",
        "unit_id": 104311
    },
    {
        "type": "still",
        "still": "104300301"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_017"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n喂喂，不要進來廚房啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "你啊，",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n總是做一些常識不知道掉到哪去的舉動呢……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n要是你沒有禮貌，我就禁止你來我們店裡哦？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯嗯，你說「這個是在做什麼」嗎？",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_019"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n啊啊，不要看！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呃呃，這是那個？　因、因為材料有剩！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯、嗯。",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_020"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我在做餅乾啦……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不是，不是居酒屋的餐點啦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_021"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n居酒屋的餐點裡，怎麼可能會有可愛的餅乾對吧。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "做、做些點心什麼的，是我的興趣……",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_022"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n很、很怪是吧？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "不適合對吧，你想笑也沒關係啦？",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_023"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n哇啊啊，我的女漢子形象……！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "咦，你想要嚐嚐看味道？",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_024"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n是、是可以……？",
        "unit_id": 104311
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "好吃嗎？",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_025"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這樣啊，太好了……♪",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_026"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你說要是給其他客人吃也會大受歡迎嗎？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "唉呀～還沒有好到能拿去賣的程度啦。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "喂，不要一直大口大口地吃。",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_027"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n{player}，你的肚子真的很餓啊……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是沒關係，你覺得好吃我就開心了。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "自己吃自己做的東西果然很空虛呢。",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_028"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "要是有人替我嚐嚐味道，我就會充滿幹勁。",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "嗯？",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你說隨時都能來試吃？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "{player}，你不要得意忘形了哦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n你就只會為了吃飯跑過來……",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "是沒有關係啦。",
        "unit_id": 104311,
        "voice": "vo_adv_1043003_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n也不是什麼天大的麻煩。",
        "unit_id": 104311
    }
]