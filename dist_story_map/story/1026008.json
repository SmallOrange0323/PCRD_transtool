    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在回去的路上熟睡了？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣啊。",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_073"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "謝謝你哦，{player}。",
