    {
        "type": "dialogue",
        "name": "鈴",
        "words": "{player}也吃吧！",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n雖然其實是不想分給任何人的，",
