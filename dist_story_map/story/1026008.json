[
    {
        "type": "background",
        "background": "500011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊～訓練好辛苦……",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "結果從早到晚都在練習揮槍啊～",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n手臂的肌肉都浮腫起來了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這樣的話到了明天，",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n肌肉會相當痠痛呦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦……",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}，你說什麼？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你問我充分地運動後不覺得心情很暢快嗎？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "哎呀……",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_004"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我沒辦法理解那種，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n熱血運動族般的反應呢。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，能把麻煩事解決，",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_005"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n心情也是有點舒爽啦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我可不想做第二次呦～",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "說真的。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然我的努力有得到認可，",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_006"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n【哞哞自衛隊】的訓練只到今天就結束了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但下個月……活動報告時不露個臉的話，",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_007"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n訓練就要變成兩倍。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "所謂兩倍，",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_008"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "就是要揮槍200次？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n那樣的話手臂就要掉下來了……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然大家說，每天只要踏實鍛鍊一下肌肉的話，",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_009"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就能從容地完成練習了。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但我可沒那種力氣啦～",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_010"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "話說，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "奇怪？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你為什麼在笑呢？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真過分啊～明明人家正感到痛苦。",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_011"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，我變得比平常還愛說話？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "果然是因為運動身體的關係，",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_012"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n情緒也跟著高漲起來了吧？",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "可能是地獄訓練順利完成，",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_013"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n充滿了成就感也說不定。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然一點也不開心，",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_014"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n只感覺到痛苦。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是。",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_015"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n做好該做的事，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n然後像這樣和{player}一起走在回家的路上……",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "總覺得有點不錯呢。",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_016"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n我一直，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "很憧憬像這樣子的感覺。",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚哇！？",
        "unit_id": 102611,
        "voice": "vo_adv_1026008_017"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你又在發光了啦！",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不要突然發光，",
        "unit_id": 102611
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "會嚇人一跳的……！",
        "unit_id": 102611
    },
    {
        "type": "background",
        "background": "510080"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嘿咻～",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_018"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咿、",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼呼……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n欸咻～",
        "unit_id": 102631
    },
    {
        "type": "still",
        "still": "102600801"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "做紅豆麵包，比想像的還要辛苦呢，",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_019"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這是相當需要體力的勞動啊……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n手臂好像要掉下來了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦……",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_020"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n你說什麼，{player}？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n看起來有模有樣的？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不要光說感想，來幫忙啦～",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_021"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還有因為我累了，你去隨便買個紅豆麵包回來。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n為了紓解壓力我想暴飲暴食。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯……也對呢，",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_022"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為現在在做紅豆麵包，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n如果先吃了店裡賣的商品，感動就會減少了呢。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是，我現在就想吃嘛。",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_023"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n好想吃紅豆麵包～",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n啊啊因為戒斷症狀手臂開始發抖了。",
        "unit_id": 102631
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "啊對了，做到一半就可以了，直接開動吧。",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_024"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "美式鬆餅不也是，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n在煎之前的狀態是最好吃的嗎。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "繼生巧克力、生牛奶糖之後，接著是生紅豆麵包！",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_025"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n這個會流行呦……☆",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呵呵呵。",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_026"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n如果這個很美味的話，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n下次開始就可以省去烤這個步驟了。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真是個一石二鳥的好主意呢～",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_027"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n{player}也這麼想的吧？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好。",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_028"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n決定了的話就快點，我開動～了……♪",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嚼嚼。",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_029"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚噁～",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_030"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "黏糊糊的好難吃。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "果然是不烤不行的啊。",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_031"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n任何事情都沒有捷徑呢，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n生活在世上還真艱辛啊。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "再來，",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_032"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "要把",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "紅豆餡放進",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "麵團裡……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼嚕……♪",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_033"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼嚕、",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_034"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "呼嚕……♪",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……嗚啊？",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_035"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n咦，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我睡著了？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我好像咚一聲的失去意識了～",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_036"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n因為今天進行了名為製作紅豆麵包的嚴酷勞動，",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n把體力用光了呢。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "但是現在，睡著的話是不行的。",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_037"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n在紅豆麵包烤好之前要醒著才行。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗯？",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_038"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n哇啊，什麼？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n不要搖我的肩膀啦～{player}？",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咦，我站著睡著了？",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_039"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "嗚～好像是因為體力到達極限而睡著了……",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "謝謝你叫醒我哦，{player}。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還有，生紅豆麵包並不好吃，",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_040"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n所以還是好好的烤吧。",
        "unit_id": 102631
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "在這個狀態下把它吃完就太浪費了呢。",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_041"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……好。",
        "unit_id": 102631,
        "voice": "vo_adv_1026008_042"
    },
    {
        "type": "dialogue",
