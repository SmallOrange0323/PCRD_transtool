[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "[FFFFFFFF]在鍊金術師的宅邸激戰的幾天後──"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n[FFFFFFFF]{player}等人離開智慧森林，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n[FFFFFFFF]在蘭德索爾附近稍作休息。"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]嗯～！",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_000"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n[FFFFFFFF]來到這一帶，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]就有回到蘭德索爾的感覺呢～",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是這樣嗎？",
        "unit_id": 125611,
        "voice": "vo_adv_5118007_001"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我還無法區分呢。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]真想快點習慣這裡，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]體會跟妳同樣的感受啊！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]碧卡拉沒問題的！",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_002"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]之後在蘭德索爾自在地生活，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]很快就會習慣喔！",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哈哈！",
        "unit_id": 125611,
        "voice": "vo_adv_5118007_003"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]對這裡的所有人來說，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]蘭德索爾果然是烏～托邦呢。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]烏～托邦？",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_004"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]大家，",
        "unit_id": 125711,
        "voice": "vo_adv_5118007_005"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]茶泡好了喔～",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]來，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]請喝。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]謝謝妳！",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_006"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]茶很燙，請小心。",
        "unit_id": 125711,
        "voice": "vo_adv_5118007_007"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]話說，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]你們在聊什麼呢？",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]呼～",
        "unit_id": 125611,
        "voice": "vo_adv_5118007_008"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]呼～",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]呼～",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]啊，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]我們在聊烏～托邦……",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]唔，好燙！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]話說回來……",
        "unit_id": 125611,
        "voice": "vo_adv_5118007_009"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]吉塔，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]幸好劍有找回來呢！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]那是妳愛用的劍吧？",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]嗯！",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_010"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n[FFFFFFFF]有拿回來讓我鬆了一口氣。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]是、",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_011"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]是嗎？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]嘿嘿嘿……",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我是很高興，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]但我不能帶走那把法杖啊。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]畢竟那是莫夫收集的贓物之一呢。",
        "unit_id": 125711,
        "voice": "vo_adv_5118007_012"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]沒想到會在宅邸裡發現山積的贓物呢。",
        "unit_id": 125611,
        "voice": "vo_adv_5118007_013"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]也因此無法視而不見，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]結果害我們得來收拾殘局，不過……",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]【王宮騎士團】正在相對較近的地區",
        "unit_id": 125711,
        "voice": "vo_adv_5118007_014"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]遠征，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n[FFFFFFFF]算是不幸中的大幸呢。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]羈押工作交接也進行得很順利。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]不只是因為幸運喔。",
        "unit_id": 125611,
        "voice": "vo_adv_5118007_015"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]要是沒有花凜在，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]肯定會花上更多時間呀。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]替莫夫急救的人也是花凜小姐呢。",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_016"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n[FFFFFFFF]技術完美到",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]跟【王宮騎士團】一起來的醫生",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]都非常訝異……",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]花凜果然是萬事通呢。",
        "unit_id": 125611,
        "voice": "vo_adv_5118007_017"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]真的很厲害喔！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]替人急救也是",
        "unit_id": 125711,
        "voice": "vo_adv_5118007_018"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]我的工作之一。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]更何況……",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n[FFFFFFFF]莫夫的傷勢也很輕呀。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]嗯，",
        "unit_id": 125611,
        "voice": "vo_adv_5118007_019"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]他真是有夠耐打呢。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]直接被那種威力的攻擊打到，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]竟然還能保有一命……",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]不對，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]厲害的是他的魔導具吧。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]不過，",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_020"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]幸好他還活著。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]只要還活著，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]相信也有可能會改變想法。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]既然莫夫執著於知識，",
        "unit_id": 125711,
        "voice": "vo_adv_5118007_021"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]那就很有可能呢。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]實際上，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]他鍊金術師的實力是貨真價實的。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]畢竟他解讀過去的鍊金術師遺留的資料，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]理解了全部。",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]只要沒走錯路，",
        "unit_id": 125611,
        "voice": "vo_adv_5118007_022"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]他或許就能對人類做出貢獻，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]是嗎。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]總之，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]只能祈禱他從煩惱中獲得解放了呢。",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]這麼說來……",
        "unit_id": 125711,
        "voice": "vo_adv_5118007_023"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n[FFFFFFFF]吉塔小姐，",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "[FFFFFFFF]飛空艇的事已經釋懷了嗎？",
        "unit_id": 125711
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]啊哈哈，",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_024"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]勉強啦。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n[FFFFFFFF]畢竟那是事件的證據，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我不能帶走啊。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]會被【王宮騎士團】的人罵的。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]而且……",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_025"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n[FFFFFFFF]害飛空艇變成那樣子……",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我真不知道該拿什麼臉見它……",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]哎呀哎呀？",
        "unit_id": 125611,
        "voice": "vo_adv_5118007_026"
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]吉塔，",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]陰沉的表情並不適合妳喔！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "\n[FFFFFFFF]我想飛空艇",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "碧卡拉",
        "words": "[FFFFFFFF]一定也會原諒妳的！",
        "unit_id": 125611
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]是、",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_027"
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]是嗎……？",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]……嗯。",
        "unit_id": 105712,
        "voice": "vo_adv_5118007_028"
    },
    {
