        "voice": "vo_adv_1124500_007"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "以後也會全心全意努力的！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "不管是作為偶像",
