    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "辛苦了♪",
        "unit_id": 112411,
        "voice": "vo_adv_1124500_000"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "你想跟我說的事情是什麼呢？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "難道是",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "有任務要委託我嗎？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是的話我已經準備好了喔！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我會帶著",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "滿分的笑容努力的！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "哇啊，",
        "unit_id": 112411,
        "voice": "vo_adv_1124500_001"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我好高興♪",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "你連禮物都準備了嗎？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "居然能收到這樣的祝福……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "非常感謝你！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我呢，",
        "unit_id": 112411,
        "voice": "vo_adv_1124500_002"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "像這樣感受到別人的溫柔時……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "心裡就會覺得很溫暖，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "然後湧出一股",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "「想要再更努力」的力量。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "今天也多虧了你，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n我得到了很多力量可以繼續努力喔！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "欸嘿嘿，",
        "unit_id": 112411,
        "voice": "vo_adv_1124500_003"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "笑容就是我的優點呀♪",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n這樣就能讓你高興的話，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我也很開心喔！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "可是",
        "unit_id": 112411,
        "voice": "vo_adv_1124500_004"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "怎麼突然這麼說呢？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "因為是我的生日……？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "哇哇，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "還有禮物！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我才該跟你道謝呢！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "非常謝謝你！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "是這樣嗎？",
        "unit_id": 112411,
        "voice": "vo_adv_1124500_005"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "這樣的話我就……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "為了讓你能夠努力，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我就努力幫你加油吧！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "話說回來，",
        "unit_id": 112411,
        "voice": "vo_adv_1124500_006"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "你是要努力什麼呢？",
