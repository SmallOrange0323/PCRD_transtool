    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哥哥依然睡得很熟……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "雖然哥哥的睡臉很可愛……",
