    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "但哥哥什麼反應都沒有，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就算做了惡作劇，也一點都不有趣呀……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n……茜里",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "好寂寞哦。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "……既然如此，",
        "unit_id": 100611,
        "voice": "vo_adv_5084607_002"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里也稍微認真一點！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "因為哥哥一直以來",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "都在一旁守護著茜里……",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "所以現在輪到茜里來看照哥哥了！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "茜里會打扮得漂漂亮亮，等著哥哥的。",
