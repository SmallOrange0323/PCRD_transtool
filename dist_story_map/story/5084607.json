        "voice": "vo_adv_5084607_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n哥哥快點醒來，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "請讓茜里做好多好多惡作劇吧。",
        "unit_id": 100611
