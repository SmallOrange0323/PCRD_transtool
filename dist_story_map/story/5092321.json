    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "哇啊！",
        "unit_id": 121911,
        "voice": "vo_adv_5092321_000"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好、",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "好險……",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "竟然有超高火力雷射兵器，",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "挺有一套的嘛。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "既然如此",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我就用魔法來個正面對決吧！",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "請別這麼做。",
        "unit_id": 122011,
        "voice": "vo_adv_5092321_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要是兩股強大的力量碰撞在一起，",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n周圍可是會遭受到",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "無法想像的巨大傷害。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這、",
        "unit_id": 121911,
        "voice": "vo_adv_5092321_002"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "這樣啊……",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我難得可以表現的說……",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "不用擔心，",
        "unit_id": 101411,
        "voice": "vo_adv_5092321_003"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "這場戰鬥的關鍵",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "還是杏奈喔。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n妳看，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "因為剛剛高威力的攻擊，",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n守護者的反應似乎變慢了。",
        "unit_id": 101411
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這是絕佳的機會。",
        "unit_id": 122011,
        "voice": "vo_adv_5092321_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "由我和霞用最大攻擊",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "打頭陣。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "然後",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "就請杏奈給它最後一擊吧。",
        "unit_id": 122011
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "包在我身上，",
        "unit_id": 121911,
        "voice": "vo_adv_5092321_005"
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "讓妳看看我的壓箱寶。",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "\n",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "我要叫它後悔",
        "unit_id": 121911
    },
    {
        "type": "dialogue",
        "name": "修特帕魯",
        "words": "讓我認真起來！",
        "unit_id": 121911
    }
]