[
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這裡就是",
        "unit_id": 126011,
        "voice": "vo_adv_9006606_000"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "阿剌克涅的巢穴最深處──",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n這裡面",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "裝飾著好驚人的寶石和黃金呢……",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "金光閃閃。",
        "unit_id": 126111,
        "voice": "vo_adv_9006606_001"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "除了從庫露露小姐那裡偷來的魔寶石，",
        "unit_id": 125811,
        "voice": "vo_adv_9006606_002"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n敵人似乎還蒐集了無數的金銀財寶……",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "比起什麼寶石──",
        "unit_id": 105811,
        "voice": "vo_adv_9006606_003"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "雪菲！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n妳在哪裡！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抱歉讓您久等了，",
        "unit_id": 105911,
        "voice": "vo_adv_9006606_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雪菲小姐……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有──",
        "unit_id": 106011,
        "voice": "vo_adv_9006606_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "趕緊滾出來，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "阿剌克涅！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我要宰了妳！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "…………呵。",
        "unit_id": 1,
        "voice": "vo_adv_9006606_006"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "呵呵、",
        "unit_id": 136013,
        "voice": "vo_adv_9006606_007"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "哈哈哈……",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n擅自闖入吾的牢獄之中──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n竟然還敢",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "如此高聲地大放厥詞。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那就是阿剌克涅女士……！",
        "unit_id": 125811,
        "voice": "vo_adv_9006606_008"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "多麼龐大的身軀啊……！",
        "unit_id": 125811
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "太過，",
        "unit_id": 126111,
        "voice": "vo_adv_9006606_009"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n巨大。",
        "unit_id": 126111
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "在這狹小的地洞中，",
        "unit_id": 136013,
        "voice": "vo_adv_9006606_010"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "沒有任何款待──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n吾就針對這點致個歉吧。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n呵呵。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不需要那種東西……！",
        "unit_id": 106011,
        "voice": "vo_adv_9006606_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n乖乖認命",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "把雪菲還給我們！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這裡可沒有",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "保護妳的夥伴了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "夥伴──？",
        "unit_id": 136013,
        "voice": "vo_adv_9006606_012"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n呵呵，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n妳說那個傳令、",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "盜賊們",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "和寶石蜘蛛是吾的夥伴？",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "別說笑了。",
        "unit_id": 136013,
        "voice": "vo_adv_9006606_013"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "那些傢伙不過是棋子罷了……",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n但吾不否認那是群無能之徒，連在吾消化完畢前的時間",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n都無法爭取。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "怎麼會……",
        "unit_id": 126011,
        "voice": "vo_adv_9006606_014"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n居然說為自己戰鬥的人們",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n是棋子",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "跟無能之徒……！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "不明白的話，",
        "unit_id": 136013,
        "voice": "vo_adv_9006606_015"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "吾就告訴你們吧──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n對吾來說，你們也只是",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "敵方的棋子罷了。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦……！？",
        "unit_id": 126011,
        "voice": "vo_adv_9006606_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也就是說，",
        "unit_id": 105811,
        "voice": "vo_adv_9006606_017"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳甚至不認為我們是敵人嗎……！？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "打亂吾算計的，",
        "unit_id": 136013,
        "voice": "vo_adv_9006606_018"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "僅僅是那位名為厄莉絲的前管理者的介入。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n而吾的對手從一開始──",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "便只有那位鐵皇女一人。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "安涅默涅",
        "words": "…………",
        "unit_id": 129613,
        "voice": "vo_adv_9006606_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哼……",
        "unit_id": 106011,
        "voice": "vo_adv_9006606_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n少看不起人了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "既然妳的身軀大成這副德性，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就表示妳的腳邊很多破綻吧！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "像你們這樣的存在，",
        "unit_id": 136013,
        "voice": "vo_adv_9006606_021"
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "吾連小瞧的意思都沒有。",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "\n不過在吾消化完畢前，",
        "unit_id": 136013
    },
    {
        "type": "dialogue",
        "name": "阿剌克涅女士",
        "words": "就來跟吾玩玩吧……！",
        "unit_id": 136013
    }
]