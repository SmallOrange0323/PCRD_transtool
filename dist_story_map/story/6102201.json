[
    {
        "type": "background",
        "background": "501870"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "這種祭典，",
        "unit_id": 123511,
        "voice": "vo_adv_6102201_000"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "真的會讓人很興奮呢～",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n氣氛和平時的蘭德索爾完全不一樣。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不管是遊戲展示會，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "還是舞台那邊",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "都好熱鬧喔。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "是啊，",
        "unit_id": 123511,
        "voice": "vo_adv_6102201_001"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我很喜歡各種活動喔。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "雖然覺得出門很麻煩就是了。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n像偶像音樂節之類的，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "偶爾也會一時興起就跑去。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n真的閒到不行的時候，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我有時候也會去參加【動物苑】的活動。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "如果可以不用幫忙護衛的話，",
        "unit_id": 123511,
        "voice": "vo_adv_6102201_002"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "我是那麼打算的啦。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "平時也沒什麼機會可以近距離看到輝美參加活動，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n就這點來說，的確值得好好享受呢。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "你想吃文化祭美食嗎？",
        "unit_id": 123511,
        "voice": "vo_adv_6102201_003"
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "現場也來了許多攤販，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "好像不錯呢。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "不過，要是有紅豆麵包或橡子攤販就再好不過了。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "\n",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "……兩種都沒有？",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "那麼，",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "咖哩也可以吧。",
        "unit_id": 123511
    },
    {
        "type": "dialogue",
        "name": "鈴",
        "words": "畢竟是經典料理嘛。",
        "unit_id": 123511
    }
]