[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "好好享受了花祭的真步與{player}。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n坐在長椅上的兩人，欣賞著祭典並快樂地聊天。"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "呵呵，",
        "unit_id": 116011,
        "voice": "vo_adv_1160004_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是段夢一般的時間呢。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生做給人家的花冠，",
        "unit_id": 116011,
        "voice": "vo_adv_1160004_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家會當成寶物的。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就像玻璃鞋一樣，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "要替它施展不會消失的魔法♪",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "哎呀？",
        "unit_id": 116011,
        "voice": "vo_adv_1160004_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "是怎麼回事呢？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n明明都還沒有施展魔法，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "花冠就",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "閃閃發亮著……",
        "unit_id": 116011
    },
    {
        "type": "background",
        "background": "510124"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您來了呀♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒事的，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "並沒有任何不對。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "只是人家太過興奮，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不小心提前太多時間來了而已。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "話雖如此，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_005"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但王子先生也很早來呢。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您也很",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "期待今天嗎？",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "畢竟",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也是當到而已。",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_006"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……哈啾！",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……嗚嗚，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_007"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "請不要用那麼懷疑的眼神",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來看人家。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n也沒辦法不提早來吧。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "畢竟今天……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "今天可是",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_008"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "和王子先生的",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "夢幻約會呀♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "其實",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_009"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家為了今天，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n特別",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "準備了特別的衣服喔。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_010"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那是只能在",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真步真步王國相傳的，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n某個特別場所才能夠穿上，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以要先保密♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "那麼，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_011"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就招待王子先生",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n到真步真步王國的",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "神殿吧♪",
        "unit_id": 101031
    },
    {
        "type": "still",
        "still": "116000401"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_012"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n歡迎來到",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真步真步王國的神殿～♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……說笑的。",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_013"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n現今只要預約，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就能租到",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這種婚禮會場喔。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "好像也常用來",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "舉辦角色扮演的活動，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以人家就申請了♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_014"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真沒想到，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n竟然能借到",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這麼美妙的地方……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不只氣氛不同，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "感覺就像",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的在辦婚禮一樣呢♪",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而且，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_015"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "工作人員",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還準備了花。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但是……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……那個呀，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_016"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "有個夢想。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n在婚禮上，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "穿著自己做的禮服，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "跟夢中注定的人",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "結為連理……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這樣子的夢。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家知道",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_017"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "距離夢想實現",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "還需要很久。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……但是，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "抱著姑且一試心態",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "申請的會場",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "竟然預約成功了，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n讓人家",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "想稍微偷看一下",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "自己的夢想。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_018"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就順勢",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "邀請了王子先生，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在王子先生回答人家之前，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家實在是",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "焦慮到不行。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "說可以陪人家來的時候，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的非常開心。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "因為太開心了，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_019"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "每天一針一線",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "努力地",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "製作了禮服……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "但來到這裡，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "穿上服裝後，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家終於明白了。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家根本做不出",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "夢想中的東西。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_020"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會更努力學習裁縫的。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不是為了繼承家業，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而是為了自己……",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現實世界",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_021"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒有灰姑娘的魔法師，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n不像童話故事那樣，沒有人會把人家變成公主。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以人家要自己成為魔法師，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "做出世界上最好看的禮服。",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "在此對真步真步王國的神殿發誓，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_022"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "會為了實現夢想",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "而努力！",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所以說，",
        "unit_id": 101031,
        "voice": "vo_adv_1160004_023"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然想",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "和王子先生一起，",
        "unit_id": 101031
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n開心地舉行模仿婚禮之類的……",
        "unit_id": 101031
    },
    {
