[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "Un、Deux、",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "Trois……♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "Un、Deux、",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "Trois……♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "旋轉，接著轉身……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "回頭的同時，斬下！",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呼唔……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真討厭，實在煩人。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "從剛才開始出現的全都是蟲類的魔物。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n雖然不是什麼危險的對手。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過數量很多，麻煩到極點了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我再怎麼甩開或砍倒，牠們又會一隻隻地靠近……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "雖然想無視弱小的牠們衝過去，但是魔物畢竟是魔物，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要是不小心，我也是會受重傷的呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且在運送重要「商品」的途中，",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也不能太過貿然行事……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "每次魔物一出現，",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我就必須停下貨車來處理魔物。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再這樣下去，天就要黑了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n天色暗下來後，比較強大的魔物似乎也會開始活動，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "明明得加快腳步的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不要啊，我可不想受困在這種毛骨悚然的地方。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "早知道會這樣，就不該省錢，多雇用個護衛就好了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過啊，要是花了那些經費，就存不了錢了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我也不能讓鈴莓和孩子們做危險的工作。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……哦唷。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉唉，討厭，蟲又靠過來了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n嘿咻～♪",
        "unit_id": 102811
    },
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是沒完沒了的，要是有準備殺蟲劑就好了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "話說回來，出現的怎麼淨是些蟲呢……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "難道說，是運送的「商品」的關係？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "說不定是這個「商品」發出的甜香吸引這些蟲靠近。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "既然是這樣，如果事先把商品包起來，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不讓氣味外洩就好了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯。我先記住該反省的地方，下次好好活用吧。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總之，現在得趕緊離開森林……",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "魔物再怎麼樣纏人也不會追到城鎮吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯？",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n咦，那邊的草叢有動靜！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "似乎……不是蟲呢，更大的動物躲在那邊嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果只是路人，直接攻擊他就糟了，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我應該先試著搭話吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喂，有人在那邊嗎？",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要是不回答，我就判斷你是魔物然後攻擊哦！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……是人的聲音，",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "太好了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n保險起見先確認，果然是正確的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對不起。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我不會攻擊你的，能請你從草叢裡出來嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呀……！？",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "果然是魔物？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呃，應該是……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "人類吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，能不要發出讓人混淆的聲音嗎？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉呀，你……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我想想，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "名字確實是叫{player}對吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，請不要嚇我啊。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}，你究竟在森林裡做什麼？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "總不可能是在這種魔物四處遊蕩的地方散步吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯哼……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n為了賺點錢，所以接了簡單的工作啊。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n狩獵大量特定的蟲，收集蟲的體液作為化妝品的原料？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "所以就遵從委託人的建議……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "四處散佈特殊調合的藥劑，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好讓這些蟲大量聚集？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯哼。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n也就是說這附近聚集了這麼多蟲，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n都是因為你的關係吧……？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好個大麻煩呀，真是的。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過算了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "恰巧踏進這種地方來，算是我運氣不好。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "恣意責怪他人就不優雅了。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不對，危機就是轉機呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "欸，{player}……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_028"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n如果不介意的話，要不要讓我幫忙？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "交換條件就是希望你幫忙拉貨車。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "由你來運送貨車。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_029"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n讓我狩獵靠近的那些蟲。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再把被打倒的蟲裝進袋子裡，一同放上貨車，就能大量運送了。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一舉兩得對吧。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_030"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n這種條件如何？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個交易對彼此都有好處對吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且你看起來動作很遲鈍……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_031"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n似乎沒抓到多少蟲的樣子。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再這樣下去，可就無法好好完成委託了是吧？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "工作就得好好地做才行哦。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_032"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就當作是之前你替我撿到文件的回禮，我就來幫你的忙。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不對，是彼此互相幫助吧♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "OK？",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_033"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼，就算成交了喔♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "來這裡的路上，我已經打倒很多蟲了……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_034"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n要是有派得上用場的蟲，你就直接把殘骸撿起來吧。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在這個空檔，",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_035"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n我也會適時地狩獵一下那些蟲的。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "Un、Deux、",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_036"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "Trois……♪",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈。我還記得……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_037"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n小時候會和關係很好的男孩子，像這樣一起抓蟲呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "他也是個遲鈍的傢伙呢～完全抓不到蟲。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過。",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_038"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n一到了緊要關頭就會很可靠，",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我對他有一點點心動呢。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真令人懷念呀……",
        "unit_id": 102811,
        "voice": "vo_adv_1028002_039"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那個男孩子，現在在哪裡做些什麼事呢？",
        "unit_id": 102811
    }
]