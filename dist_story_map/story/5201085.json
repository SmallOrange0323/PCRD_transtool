[
    {
        "type": "background",
        "background": "510460"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "教授，",
        "unit_id": 107031,
        "voice": "vo_adv_5201085_000"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "可以打擾一下嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "什麼事？",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_001"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n我從妳的氣息中微微感受到怒氣，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "若是要向我挑戰，我隨時都奉陪。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "很遺憾，",
        "unit_id": 107031,
        "voice": "vo_adv_5201085_002"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這個問題無法用暴力解決。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是關於",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這份獸人族設計圖。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……哦。",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "人類的耳朵",
        "unit_id": 107031,
        "voice": "vo_adv_5201085_004"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "和獸人的耳朵，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "總計會有四隻耳朵。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "這非常沒有意義。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "根本不合理。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "！",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_005"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "拉基尼卡東，",
        "unit_id": 107031,
        "voice": "vo_adv_5201085_006"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "你參與了獸人族的設計對吧？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n難道，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是你允許他們戴著像裝飾一樣的獸耳嗎？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n還是說，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "是你認同他們不上不下地留著人類的耳朵呢？",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……傷腦筋，",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_007"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "還真是嚴苛的說法啊。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "像這種事",
        "unit_id": 107031,
        "voice": "vo_adv_5201085_008"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我想確實弄清楚。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "……獸人族",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_009"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "有四隻耳朵",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "是有原因的。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "原因……？",
        "unit_id": 107031,
        "voice": "vo_adv_5201085_010"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "那是野獸的耳朵和人類的耳朵，",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_011"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "分別具有不同的功能。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "野獸的耳朵",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_012"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "所具備的功能，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n是適於聽取對野獸而言",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "必要的聲音，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n例如野獸同類的嚎叫",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "和大自然中細微的環境音等等。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "人類的耳朵",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_013"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "則專精於人類之間",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "最常使用的交流方式，",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n也就是",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "用來進行「對話」的功能。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "無論哪一種，",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_014"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "都絕不是不必要的東西。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "……原來如此。",
        "unit_id": 107031,
        "voice": "vo_adv_5201085_015"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n是在環境中",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "劃分出功能啊。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "的確，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "依種族實現獨特的功能性進化是理所當然的……",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "做出不請自來的質問真不好意思，",
        "unit_id": 107031,
        "voice": "vo_adv_5201085_016"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "教授。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我已經了解了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "提出疑問的行為",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_017"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "是很值得讚賞的。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "\n",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "只是沒想到我竟然會被當成",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "像學生一樣對待。",
        "unit_id": 107331
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "呵呵，",
        "unit_id": 107031,
        "voice": "vo_adv_5201085_018"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真不愧是教授。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n那麼，",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "我就先告辭了。",
        "unit_id": 107031
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "…………",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_019"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "以當場捏造來說，",
        "unit_id": 107331,
        "voice": "vo_adv_5201085_020"
    },
    {
        "type": "dialogue",
        "name": "拉基尼卡東",
        "words": "還真是不錯的設定啊。",
        "unit_id": 107331
    }
]