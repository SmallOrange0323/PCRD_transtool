    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "……那個。",
        "unit_id": 131611,
        "voice": "vo_adv_5148074_000"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n關於這張照片，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我們到底",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n要怎麼回想評論才好呢……？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我想想啊～",
        "unit_id": 131213,
        "voice": "vo_adv_5148074_001"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n突然出現的自稱忍者",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "讓我們圍爐取暖了……",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "這樣",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就可以了吧？",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不，",
        "unit_id": 131111,
        "voice": "vo_adv_5148074_002"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那很莫名其妙耶～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我的棉花糖也被燒焦了啊～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是說。",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "帶她過來的",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "是小莉莉吧。",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "不是，",
        "unit_id": 131611,
        "voice": "vo_adv_5148074_003"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "該說是一回過神來她就已經在了嗎……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n在我在做生營火準備的時候，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n她說著只要用忍術的話",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那種事情Too Easy……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "但是，",
        "unit_id": 131213,
        "voice": "vo_adv_5148074_004"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "我覺得很有趣喔♪",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "就算全身都著火了還能露出沒事的表情，",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n那不正是東國的神祕的感覺嗎──",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "順帶一提，",
        "unit_id": 131111,
        "voice": "vo_adv_5148074_005"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "小妮諾她",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "真的是東國人嗎？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n看起來像假的吧？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我、",
        "unit_id": 131611,
        "voice": "vo_adv_5148074_006"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我也不清楚……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "在東國",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "用火遁之術煮飯叫做炒飯是也！",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n……她也有這麼向我說就是了。",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "因為我想絕對沒有那種事情，",
        "unit_id": 131213,
        "voice": "vo_adv_5148074_007"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n所以我覺得她只是假裝自己是東國人而已喔★",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "啊～但是，",
        "unit_id": 131111,
        "voice": "vo_adv_5148074_008"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "我家也有喜歡假裝是東國人的人啊～",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n雖然她跟小妮諾沒什麼交集，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "但是也跟姊姊講吧♪",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "我記得",
        "unit_id": 131611,
        "voice": "vo_adv_5148074_009"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "涅妃‧涅羅小姐也對東國",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n有興趣對吧……？",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "沒錯。",
        "unit_id": 131111,
        "voice": "vo_adv_5148074_010"
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "不過，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "那種很盛大的花招她會喜歡嗎？",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "\n該怎麼說呢，",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "涅婭",
        "words": "她好像比較喜歡更有風情的東西。",
        "unit_id": 131111
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "在討論風情以前，",
        "unit_id": 131213,
        "voice": "vo_adv_5148074_011"
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "應該要先去確認",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "\n她的忍術",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "美空",
        "words": "是不是真的是東國來的比較好吧～",
        "unit_id": 131213
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那、",
        "unit_id": 131611,
        "voice": "vo_adv_5148074_012"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那部分",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "就相信本人說的話吧……",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "因為她是兄長大人的朋友，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "所以一定，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那個，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "對她本人來說，",
        "unit_id": 131611
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "那就是東國的忍者……！",
        "unit_id": 131611
    },
    {
        "type": "still",
        "still": "end"
    }
]