        "type": "dialogue",
        "name": "青年殭屍",
        "words": "\n",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "我到底",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "都做了些什麼……",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "\n這種事情……",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "不管怎麼道歉都……",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "──請抬起頭來。",
