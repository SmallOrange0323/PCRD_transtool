        "voice": "vo_adv_1380003_045"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n我",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "並不打算責備各位。",
