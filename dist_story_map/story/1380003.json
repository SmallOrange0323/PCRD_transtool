    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "寫信",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "或者派人出去……",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "卻都",
