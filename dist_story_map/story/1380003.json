        "voice": "vo_adv_1380003_047"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "更早一點",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "傾聽各位的聲音了……",
