    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "只有兩位前往村子……",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n這種事我可不同意！",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "那村子的代表",
        "unit_id": 52612,
        "voice": "vo_adv_1380003_003"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "也沒有參加",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "前幾天的晚宴。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n如今殺手的委託失敗，",
        "unit_id": 52612
