    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "\n",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "……對吧？",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "公主殿下啊……",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……",
        "unit_id": 133111,
        "voice": "vo_adv_1380003_034"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是我",
        "unit_id": 133111,
        "voice": "vo_adv_1380003_035"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "容許「黃泉的餐桌」",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "獨斷專制的時候嗎。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n還是巨鯨城",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "被芙蕾雅奪走的時候。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……不對。",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我甚至最近",
