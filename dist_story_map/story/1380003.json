    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是我。",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……見到各個世界的公主，",
