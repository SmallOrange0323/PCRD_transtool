    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "自己盡是不足之處。",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "若是……",
        "unit_id": 138011,
        "voice": "vo_adv_1380003_049"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我能擁有像涅妃‧涅羅皇女般",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "壓倒性的力量。",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "若是……",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我能擁有像萊拉耶爾公主般",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "包容大家的品德。",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n若是……",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我能擁有像貪吃佩可公主般",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "吸引眾人的開朗……",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "若要細數不足之處，",
        "unit_id": 138011,
        "voice": "vo_adv_1380003_050"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "根本數不完。",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "……可是，",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n即便如此，",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我還是決定了。",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "吉歐‧尼布爾黑爾",
        "unit_id": 138011,
        "voice": "vo_adv_1380003_051"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "是所有靈魂",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "漂流所至之地，",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n那麼我就要用這股力量，",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n為居住在此的",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "所有人民",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "帶來安寧。",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "包容、",
        "unit_id": 138011,
        "voice": "vo_adv_1380003_052"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "接受一切，",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "並平等地尊重生命。",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n懷著這樣的慈愛之心……",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我下定決心",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "要守護好這個世界。",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我正是",
        "unit_id": 138011,
        "voice": "vo_adv_1380003_053"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "吉歐‧尼布爾黑爾的公主，",
