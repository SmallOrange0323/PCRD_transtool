    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "或許正在進一步謀劃造反行動。",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n要去那樣的地方……",
        "unit_id": 52612
