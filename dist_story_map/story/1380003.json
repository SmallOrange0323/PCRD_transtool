        "type": "dialogue",
        "name": "青年殭屍",
        "words": "\n",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "所以……",
        "unit_id": 314
    },
    {
        "type": "dialogue",
        "name": "青年殭屍",
        "words": "我們試著",
