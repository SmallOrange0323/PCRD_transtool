        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我深知現在的自己",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "還不足以",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "擔此重任……！",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "但是，",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "總有一天……",
