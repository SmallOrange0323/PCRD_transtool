        "voice": "vo_adv_1380003_046"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "有身為公主的自覺，",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n能以更強大、",
