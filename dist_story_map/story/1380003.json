        "voice": "vo_adv_1380003_043"
    },
    {
        "type": "dialogue",
        "name": "村人殭屍",
        "words": "喂，",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "村人殭屍",
        "words": "\n想不到她會來到這種邊陲之地",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "村人殭屍",
        "words": "拯救",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "村人殭屍",
        "words": "我們……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "村人殭屍",
        "words": "\n我們",
