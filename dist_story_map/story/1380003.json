    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n這就是",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "我的驕傲……！",
