    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "所以，",
        "unit_id": 138011
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n該道歉的人",
