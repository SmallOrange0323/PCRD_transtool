        "voice": "vo_adv_1380003_001"
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "出現在晚宴上的暗殺者，",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "薇歐莉特",
        "words": "\n就是在這個村子接下殺害我的委託──",
        "unit_id": 133111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "background",
        "background": "502460"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "……不、",
        "unit_id": 52612,
        "voice": "vo_adv_1380003_002"
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "不行！",
        "unit_id": 52612
    },
    {
        "type": "dialogue",
        "name": "杜蘭",
        "words": "\n薇歐莉特公主和騎士閣下，",
        "unit_id": 52612
