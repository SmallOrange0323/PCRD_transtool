    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]前途感覺困難重重呢，",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]啊哈哈……",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]放心吧，",
        "unit_id": 103211,
        "voice": "vo_adv_5118063_025"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]吉塔。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]並非任何事",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]打從一開始就是一帆風順的啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]\n這世界可沒簡單到",
