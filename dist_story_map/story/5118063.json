        "words": "[FFFFFFFF]\n",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]都是我不知道的事情，非常有參考價值。",
        "unit_id": 105712
    },
    {
        "type": "dialogue",
        "name": "吉塔",
        "words": "[FFFFFFFF]我有想過光買飛空艇是不行的……",
