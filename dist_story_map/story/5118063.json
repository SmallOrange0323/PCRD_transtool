    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]能輕鬆賺大錢喔！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]重要在於",
        "unit_id": 103211,
        "voice": "vo_adv_5118063_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]無論遇上任何困難，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]都會往前跨出去。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]而妳的那一步",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]早已經跨出了──",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "[FFFFFFFF]那就是想飛上天空的",
