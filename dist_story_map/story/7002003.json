    {
        "type": "dialogue",
        "name": "茜里",
        "words": "哇！　",
        "unit_id": 100611,
        "voice": "vo_adv_7002003_000"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "居然掉出了這麼多……！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "姊姊，",
        "unit_id": 100611,
        "voice": "vo_adv_7002003_001"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "剛才從魔物身上的這顆石頭，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n我感受到了強大的魔力欸？　",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "而且竟然有這麼多♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真的欸，",
        "unit_id": 102211,
        "voice": "vo_adv_7002003_002"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "只要有了這個，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "公會長的魔力或許就能恢復回來了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "說得對呢！　",
        "unit_id": 100611,
        "voice": "vo_adv_7002003_003"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "把它們都帶回去吧。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "呵呵，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "快讓公會長的魔力恢復，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n要是能實現我們的願望就好了～",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "…………",
        "unit_id": 102211,
        "voice": "vo_adv_7002003_004"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "伊莉亞的魔力一恢復，",
        "unit_id": 102211,
        "voice": "vo_adv_7002003_005"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n如果以『傳說的吸血鬼』的力量",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "治好我怕生的個性……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我就能",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "坦率地把自己的心意",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "傳達出去了。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "其實自己想辦法多努力一點就好了，",
        "unit_id": 102211,
        "voice": "vo_adv_7002003_006"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n就是",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "缺了點自信……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "不知道伊莉亞的魔力能否快點恢復回來呢",
        "unit_id": 100611,
        "voice": "vo_adv_7002003_007"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "這樣一來茜里，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "就能變成世界第一可愛了～♪",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "真是的……",
        "unit_id": 102211,
        "voice": "vo_adv_7002003_008"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里的願望",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "還真是輕鬆愉快呢。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如果茜里變成世界第一可愛，",
        "unit_id": 100611,
        "voice": "vo_adv_7002003_009"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n雙胞胎的姊姊也會變得同樣可愛了啊！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "\n",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "如此一來姊姊也能更有自信，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "或許就可以治好怕生的性格了！",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "欸！？　",
        "unit_id": 102211,
        "voice": "vo_adv_7002003_010"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "突然間說些什麼啊！？",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "咦？　",
        "unit_id": 100611,
        "voice": "vo_adv_7002003_011"
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "才不是突然呢，",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "茜里",
        "words": "我一直以來都是這麼想的。",
        "unit_id": 100611
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里……",
        "unit_id": 102211,
        "voice": "vo_adv_7002003_012"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里真是的，",
        "unit_id": 102211,
        "voice": "vo_adv_7002003_013"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我還在想你為什麼突然說這些話，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n原來想的都是這些事情啊……",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "茜里，",
        "unit_id": 102211,
        "voice": "vo_adv_7002003_014"
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "謝謝你。",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "\n",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "為了茜里，",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "我",
        "unit_id": 102211
    },
    {
        "type": "dialogue",
        "name": "依里",
        "words": "一定要治好我怕生的個性……！",
        "unit_id": 102211
    }
]