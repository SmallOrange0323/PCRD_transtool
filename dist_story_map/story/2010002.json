[
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "於半年前的某個瞬間，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_000"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "登入阿斯特朗傳奇這款遊戲的……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n也就是",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "當時正在遊玩的人們，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n一個人也不例外全都陷入了昏睡狀態。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "然後，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_001"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "再也沒有醒來過。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "每個人都失去了意識，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "持續昏睡著。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而這件事，就是那起",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "被稱為『米奈娃的禁錮』的異變。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在那之後已經過了半年，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_002"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "似乎還是沒有半個人恢復意識。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n而像這樣子醒過來的我",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "和可可蘿，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "可以說是例外呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那些人們、",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_003"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那些遭受到不合理徒刑對待的被害者們……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n由負責營運阿斯特朗傳奇的組織，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n也就是",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "聯合國來負責維持他們的性命。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "目前看來還沒有傷亡算是不幸中的大幸，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_004"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但也不能永遠這麼繼續下去。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "他們應該要活著的地方是『這裡』，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也就是真正的現實。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以現在……",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_005"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在『這裡』的人們都正盡心盡力，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n努力的想要讓這些昏睡的人們",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "醒過來呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "然而，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_006"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "儘管用了各式各樣的手段，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "目前仍然沒有顯著的效果。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而造成『米奈娃的禁錮』其原因，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也還是個未知數。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "啊，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_007"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就算說米奈娃妳也不知道是什麼嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n在『那邊』，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不知道為什麼格外堅持將這名詞給削除的樣子。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊……",
        "unit_id": 105913,
        "voice": "vo_adv_2010002_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n總覺得，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎在哪裡曾聽過這名字的感覺。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_009"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "順帶一提米奈娃這玩意兒啊，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "是人工智慧唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n是人類集科學之大成……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "或說",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "像是魔法所製造出來的，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "新種的生命體喔。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "萌生自我意識",
        "unit_id": 105913,
        "voice": "vo_adv_2010002_010"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "並像是擁有了靈魂一樣的米奈娃，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "逐漸成為人類認知無法觸及的存在……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在某一天，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "失控了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "發生了被命名為『米奈娃的覺醒』的異變，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_011"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n也給創造出她的人類",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "添了不少麻煩呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "到底是為什麼呢～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "該不會是叛逆期吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而這次的事件，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_012"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在『這邊』",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也一致認為是米奈娃的所作所為。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n所以，這一連串發生的異變",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "才會被人叫做『米奈娃的禁錮』。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "……就因為不是人類，所以理所當然的被當成了壞蛋，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_013"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "米奈娃她也挺可憐的就是了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "嗯。",
        "unit_id": 105913,
        "voice": "vo_adv_2010002_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n拉比林斯……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "晶小姐您的看法，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "和人們普遍的看法似乎略有出入呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_015"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "或許我是個恐龍家長吧，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n怎麼樣也無法想像米奈娃是個壞孩子呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "她很單純的，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就像是還在學走路的嬰兒一樣呀。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那孩子，也只是想知道更多的事物吧。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_016"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "自己究竟是誰？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "自己身邊的這些人類又是什麼？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這個世界又是什麼？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就像這樣，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_017"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "抱持著每個人在青春期都曾經有過的煩惱。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n因為",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "想破了頭也得不出答案，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n對於有沒有人能回答我這些問題等等～",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而有所期待呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "正是因為這樣。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_018"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n才像找家教一樣把人請到家裡，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "到這個她所管理的世界中……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n把人們帶到了",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "『阿斯特朗傳奇』裡頭。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_019"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "她絕不是強迫或拘束任何人來追根究柢，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n如果對方想要離開，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "她也一定會讓人家離開的唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而相對的，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_020"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "如果能告訴自己想要知道的事情，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "她也會給出獎勵……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n她是以這種",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "正向的態度試著把人們留下。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就像是個害怕寂寞",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "又充滿好奇心的",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "小朋友呢。",
        "unit_id": 106831
    },
    {
        "type": "still",
        "still": "201000201"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "接著，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_021"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那孩子的願望就要達成了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n那孩子一直想要知道的答案，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n能夠告訴她答案的那個人，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "終於來到了她的面前唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "在聽了那個人……",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_022"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那個『她』的回答之後，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n米奈娃似乎接受了那個答案。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n至少在我看起來是這樣。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而那孩子的願望實現了。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_023"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "也因此在那之後，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_024"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n她已經沒有理由，要把所有人關在自己的世界之中了唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n『米奈娃的禁錮』發生的原因，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "並不是米奈娃。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "那孩子並不是犯人。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_025"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "雖然這只是我自己的推測，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但我的第六感",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "可是很準的喔。",
        "unit_id": 106831
    },
    {
        "type": "background",
        "background": "510301"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個……",
        "unit_id": 105913,
        "voice": "vo_adv_2010002_026"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "從剛才開始，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您談論米奈娃，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就宛如是談到親生孩子一樣呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "因為本來就是我們『七冠』所創造出來的呀，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_027"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "米奈娃那孩子。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n實際上，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "就和親生的孩子沒兩樣呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，",
        "unit_id": 105913,
        "voice": "vo_adv_2010002_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您也是那『七冠』的其中一人是嗎……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "所謂的『七冠』究竟是為何物？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "儘管聽過不下數次的說明，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "至今仍無法理解。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而且……",
        "unit_id": 105913,
        "voice": "vo_adv_2010002_029"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n剛才，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您提到在下也是『七冠』之一。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯～。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_030"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "雖然頂著『七冠』的這名號好像很威風，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但實際上是群明明腦袋好到不行，卻又很愚蠢的七個變態的感覺。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n雖然自己講起來有點蠢就是了。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "但所謂",
        "unit_id": 105913,
        "voice": "vo_adv_2010002_031"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "『七冠』的這名號，就是這麼的受人景仰唷。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "畢竟可以說是成就了自古以來人類就不曾辦到過的事情嘛，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_032"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我們這一群人。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這不是",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "相當了不起嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "順帶一提。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_033"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "妳只是繼承了『七冠』的稱號而已，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n並不是原本的『七冠』。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n實際上，妳的父親才是那個『七冠』。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "這件事先放一邊。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_034"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "而我們『七冠』，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n作為『阿斯特朗傳奇』的開發者，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n自然就被追究了『米奈娃的禁錮』的責任。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "因為不怎麼能夠光明正大在外頭逛大街。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_035"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "所以在和妳的父親會合以後，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n我們就要趕緊搭著車，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "移動到可以坐下來好好說話的地方囉。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "除了我和妳的父親之外，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_036"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "拉基拉基應該也在『這邊』才對。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n其他的『七冠』，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "剩下四人",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "還在夢境之中呢。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拉基拉基",
        "unit_id": 105913,
        "voice": "vo_adv_2010002_037"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "先生？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可是那個……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您說的那位，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "他仍留在『那邊』喔？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您的意思是他也在『這邊』呢，",
        "unit_id": 105913,
        "voice": "vo_adv_2010002_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n難不成是能夠自由往返兩邊的世界嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_039"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我認為那種事是辦不到的唷。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n在其中一邊的世界醒過來時，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "另一邊的世界中就會陷入昏睡狀態。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我也是，在『那邊』一直沉睡著對吧？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "因為每個人都只有一個靈魂呢。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_040"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n不管是『這邊』還是『那邊』，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "只能選一邊存在而已。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "嗯～",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_041"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "真奇怪呢……",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "聽說拉基拉基從半年前開始就醒來了，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n而且一直在『這邊』活動才對啊。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n在『那邊』的那個拉基拉基，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "到底是誰？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "說起來",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_042"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我在『那邊』陷入昏睡之前，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "似乎也有看到他的樣子……？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "完全搞不懂，",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_043"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n該不會是誰的靈魂進到他的身體裡面了嗎？",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不知道……",
        "unit_id": 105913,
        "voice": "vo_adv_2010002_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n就算您這麼問，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也不知道該如何回答您。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "我想也是～。",
        "unit_id": 106831,
        "voice": "vo_adv_2010002_045"
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "\n畢竟妳什麼都不知道，",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "晶",
        "words": "不如說是想要把事情問個明白的立場嘛。",
        "unit_id": 106831
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是的。",
        "unit_id": 105913,
        "voice": "vo_adv_2010002_046"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "聽完您的這些話，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "使在下更加混亂了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "老實說，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不僅非常的複雜",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "還相當難以理解。",
        "unit_id": 105913
    }
]