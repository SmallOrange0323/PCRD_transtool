[
    {
        "type": "dialogue",
        "name": "純",
        "words": "很好，",
        "unit_id": 104715,
        "voice": "vo_adv_5094322_000"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "接二連三冒出來的手下們",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "也大部分都清掉了。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n接著只剩老大",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "和牠身旁的兩個手下……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n唔？",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "蘑菇老大的舉止有些可疑呢。",
        "unit_id": 122211,
        "voice": "vo_adv_5094322_001"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n看起來似乎在對後方的手下作出指示……？",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "那個手下所拿的武器前端……",
        "unit_id": 122111,
        "voice": "vo_adv_5094322_002"
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "是不是聚集了不少孢子？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "\n",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "該不會，",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "碧",
        "words": "牠們打算把那個丟向我們……？",
        "unit_id": 122111
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "嗯，",
        "unit_id": 104715,
        "voice": "vo_adv_5094322_003"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "這個可能性很高。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n而且……",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "從剛才開始，",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我的身體便開始有些許的麻痺感。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n或許原因就出在那些孢子上。",
        "unit_id": 104715
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "畢竟毒蘑菇十之八九會讓人麻痺呢……",
        "unit_id": 122211,
        "voice": "vo_adv_5094322_004"
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "\n",
        "unit_id": 122211
    },
    {
        "type": "dialogue",
        "name": "優花梨",
        "words": "我們瞄準後方的手下攻擊吧！",
        "unit_id": 122211
    }
]