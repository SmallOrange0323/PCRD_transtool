        "words": "愛蜜莉雅大人，",
        "unit_id": 109811,
        "voice": "vo_adv_5017204_001"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n那個方向會回到馬車那裡喔。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "咦、",
        "unit_id": 109911,
        "voice": "vo_adv_5017204_002"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是、",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是這樣嗎！？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "\n",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那麼",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "是這邊……嗎？",
        "unit_id": 109911
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "愛蜜莉雅大人，",
        "unit_id": 109711,
        "voice": "vo_adv_5017204_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n往那個方向走的話，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "就會走出村子。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "…………",
        "unit_id": 109911,
        "voice": "vo_adv_5017204_004"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "真是的，",
        "unit_id": 109811,
        "voice": "vo_adv_5017204_005"
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "您這個樣子真叫人放心不下。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "\n愛蜜莉雅大人，",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "拉姆",
        "words": "您還是不要走在前面比較好。",
        "unit_id": 109811
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "那個，",
        "unit_id": 109711,
        "voice": "vo_adv_5017204_006"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這裡就由對魔女氣味比較熟悉的",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n雷姆來帶路吧……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "…………",
        "unit_id": 109911,
        "voice": "vo_adv_5017204_007"
    },
    {
        "type": "dialogue",
        "name": "愛蜜莉雅",
        "words": "那就麻煩妳了。",
        "unit_id": 109911
    }
