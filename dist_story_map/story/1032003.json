[
    {
        "type": "background",
        "background": "500170"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}被秋乃約出來，\n而來到了森林的入口。"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人，非常感謝您",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_000"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n今天應邀前來。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦，你問我有什麼事？",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_001"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "其實，我想要進行",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n克服路痴的特訓呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "所以，我想說如果可以，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n希望{player}大人能擔任本小姐的指導員……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可以嗎！？",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是太好了！這才是本小姐的騎士候選人嘛！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "有任何人遇到困難，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人都會毫不猶豫地伸出援手……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這種寬大的心胸也讓本小姐很讚賞啊。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "那麼，作為謝禮",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_005"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n請受下這些錢吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n雖然只是微薄謝禮，但應該夠買一艘小型飛空艇……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不願收下！？",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_006"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n啊啊，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "多麼高潔的人啊……！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "越來越想讓你當我的騎士了呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……比起那個，我得先說明",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_007"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n今天要用什麼方法，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n來克服路痴的問題呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "等一下，我們要",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_008"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "進入這座森林之中。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請看看這張地圖。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "照地圖顯示，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_009"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n從這個森林的入口筆直往前之後，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n好像會有一棵大樹呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只要我能走到那棵大樹的地方，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_010"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n再平安無事回來的話，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就能夠證明本小姐克服了路痴問題！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "由於這基本上算是我的特訓，所以我想先走在前面，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_011"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n而你跟在本小姐後面。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這樣可以嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "回答得真好呢！",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_012"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n那麼，我們走囉。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "出發吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是奇怪呢……我明明只是照著地圖前進，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_013"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n現在竟然完全找不到路……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你、你那是什麼眼神啊！",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_014"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我也不是什麼都沒想，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就這樣一直走啊！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "你聽到本小姐有多聰明，可不要嚇到！",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "其實……我一路上都有留下標記呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呵呵呵……到這裡的路上，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_016"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我都撒了紙鈔作為標記啦！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "只要回頭一看，就能看到星星點點的紙鈔……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_017"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我、",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_018"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我沒料到會被風吹走的這件事啊……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n紙鈔全部都被吹走了啦……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒辦法了。",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_019"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n今天就放棄前往大樹，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就從這裡回去吧……",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500171"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真是奇怪呢……我還以為我們正筆直地走回去，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_020"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n但越是前進，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n就越往森林深處去的樣子……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我本來都不知道……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_021"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n這座森林一定有著廣大的腹地，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n而且還是座被施了魔法的迷路森林……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "太陽也差不多要下山，天色要變暗了……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_022"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n要怎麼辦呢……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "有了，我燃燒紙鈔做為燈火就好啦！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是這樣嗎……如果你這樣說的話……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_023"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "原來庶民們就算覺得暗，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n也不會把錢拿來燒啊…",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "…",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就是說呀！我曾經聽過以前的貴族們",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_024"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n會燃燒紙鈔來照亮暗處的故事呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我手上，已經沒有紙鈔了……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_025"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒辦法了……我們再繼續走吧……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_026"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊……剛才的是……那個……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_027"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n你該不會聽到了吧？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是、是我的肚子……發出來的聲音啦……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_028"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真是害羞……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我果然成了你的絆腳石呢……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_029"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n再這樣下去的話，我們兩個人都會遇難……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n然後就此死去也說不一定……？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "如果，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_030"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人把我棄之於此，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我也不介意。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就算只有{player}大人逃出去，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n只要能夠活下去的話……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "謝謝你……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_031"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "{player}大人為什麼，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_032"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n會這麼的溫柔呢……？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "暫且不說公會成員……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_033"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n至今為止，接近我的人幾乎都是",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n以父親大人或是我的金錢為目的……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……真的越來越想讓你當我的騎士，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_034"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n留在我身邊了呢。",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "腳下也變得越來越暗了……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_035"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n為了不要跟你走散，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我可以邊抓著你的衣角邊走嗎？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "謝謝你……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_036"
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "我們已經……持續走了幾個小時了呢……",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_037"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我的腳差不多到極限了……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……{player}大人？",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_038"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n你在一臉認真地考慮些什麼呢……？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "筆直地往前走？咦、",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_039"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "哇、你這麼大力拉著我的手……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "……我知道了，就交給你了。",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_040"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n不管怎麼樣，都筆直地往前走吧！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦？你這麼突然在做什麼呢？",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_041"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n將一路上生長著的樹枝跟藤蔓，用成像是繩子一樣……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊！邊將這個筆直地放長，邊前進的話，",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_042"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "至少就不會再回到相同的地方了呢！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "真不愧是{player}大人！",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_043"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "十分鐘後……"
    },
    {
        "type": "background",
        "background": "500172"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "啊！看到燈光了！",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_044"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "是森林的出口啊―――！",
        "unit_id": 103211
    },
    {
        "type": "background",
        "background": "500142"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "終於逃脫出來啦―――！",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_045"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n真不愧是{player}大人啊――！",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "可是，要怎麼從這裡到城鎮……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "小姐你們，為什麼會在公園裡面",
        "unit_id": 1411,
        "voice": "vo_adv_1032003_046"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n弄得滿身樹葉的……？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咦、咦？你是城鎮上的人嗎？",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_047"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我、我們在森林裡迷路了……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "你們迷路了？",
        "unit_id": 1411,
        "voice": "vo_adv_1032003_048"
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n這個公園只要十五分鐘，",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "大叔",
        "words": "\n就能從頭走到尾了喔？",
        "unit_id": 1411
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎、",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_049"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "怎麼會……",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n我的路痴問題有這麼嚴重……？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "告、",
        "unit_id": 103211,
        "voice": "vo_adv_1032003_050"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "告訴我這不是真的，",
        "unit_id": 103211
    },
    {
