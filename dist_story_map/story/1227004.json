    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "夏令營的最後一天，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克服了困難的鏡華，開始準備收拾回到精靈之森。"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所有人",
        "unit_id": 122711,
        "voice": "vo_adv_1227004_000"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "都到齊了嗎？",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "是～！",
        "unit_id": 5412,
        "voice": "vo_adv_1227004_001"
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "\n到齊了，",
        "unit_id": 5412
    },
    {
        "type": "dialogue",
        "name": "女子",
        "words": "隊長！",
        "unit_id": 5412
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "打掃工具也都拿來了！",
        "unit_id": 5312,
        "voice": "vo_adv_1227004_002"
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "\n",
        "unit_id": 5312
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "隨時都可以開始打掃，",
        "unit_id": 5312
    },
    {
        "type": "dialogue",
        "name": "男子",
        "words": "隊長！",
        "unit_id": 5312
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那、",
        "unit_id": 122711,
        "voice": "vo_adv_1227004_003"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個……",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請別再叫隊長了。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那種稱呼",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我已經無所謂了。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "真是的！",
        "unit_id": 122711,
        "voice": "vo_adv_1227004_004"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n連{player}都這樣～！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……咳咳。",
        "unit_id": 122711,
        "voice": "vo_adv_1227004_005"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那麼，",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "現在開始進行夏令營最後一天的打掃。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "讓這裡比我們來之前更乾淨，",
        "unit_id": 122711,
        "voice": "vo_adv_1227004_006"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n然後心情愉快地回學校吧♪",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "打掃",
        "unit_id": 122711,
        "voice": "vo_adv_1227004_007"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "開始～！",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "孩子們",
        "words": "好──！",
        "unit_id": 1,
        "voice": "vo_adv_1227004_008"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "啊！",
        "unit_id": 122711,
        "voice": "vo_adv_1227004_009"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你是這邊喔。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n請跟我來。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為是你，",
        "unit_id": 122711,
        "voice": "vo_adv_1227004_010"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n所以搞不好",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "會迷路或玩樂吧。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我會在你身邊",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "緊盯著你的。",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "聽好囉？",
        "unit_id": 122711,
        "voice": "vo_adv_1227004_011"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n要讓這個海邊",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "乾淨得閃閃發光──",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n總覺得",
        "unit_id": 122711
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "已經在發光了……？",
        "unit_id": 122711
    },
    {
        "type": "background",
        "background": "510250"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "雖然媽媽帶我來海邊是很好……",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_012"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但一個人練習游泳可能會很寂寞。",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_013"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n可是，",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "媽媽又必須看著東西……",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "海邊",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_014"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "比我想像的還要多人啊……",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要是突然",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "被不認識的人搭話，該怎麼辦……！",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "！",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_015"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "剛剛聽到後面傳來的聲音……",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_016"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是在對我說嗎？",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n這難不成",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "就是所謂的搭訕？",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "明明是這種小孩子……",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "難不成",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是變態嗎！？　",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "連我的名字都知道！？",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_017"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n是變態",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "跟蹤狂！？",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不、",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不可以回頭，",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "不然我可能會被帶走……！　",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎、",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_018"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "怎麼辦……！",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要、",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "要逃跑嗎？",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但要是被他追上來，",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "憑小孩子的速度……！",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "媽、",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "媽媽───！　",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呀─────！",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_019"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n變態可疑分子─────！",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請別碰我！",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_020"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我要按響警報器了喔！",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "而且，",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_021"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我可是有一個更厲害的變態可疑分子呢！",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n那個人可是",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "非常厲害的變態可疑分子啊！",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……話說，",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_022"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦……？",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "你不就是本人嗎！",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_023"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請不要做出令人誤會的舉動！",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我真的差點就要按響警報器了！",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還……",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_024"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "還真巧",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "呢。",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n竟然在這種地方遇見……",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "咦？",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_025"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你問我在做什麼，",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "看了我這身打扮還不知道嗎？",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請、",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_026"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "請別目不轉睛地盯著我看。",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你的眼神很下流。",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我要叫人了喔。",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……你說可愛的事，",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_027"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我就謝謝你了。",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "…………",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_028"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "那個……",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_029"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是為了練習游泳才來的。",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "學校馬上就要",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_030"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "開始泳池的課程了，",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "但對於能不能在大家面前好好地游，",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我感到有點不安……",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n我又不太想",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "被看見丟臉的一面。",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "因為",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_031"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "我在學校是一個成熟又可靠的人。",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "……你那個眼神",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_032"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "是怎樣？",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "所以……",
        "unit_id": 122731,
        "voice": "vo_adv_1227004_033"
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "該怎麼說呢……",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "\n你願意的話，",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "可不可以……",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
        "words": "幫忙我",
        "unit_id": 122731
    },
    {
        "type": "dialogue",
        "name": "鏡華",
