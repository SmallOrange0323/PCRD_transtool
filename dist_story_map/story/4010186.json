[
    {
        "type": "background",
        "background": "509014"
    },
    {
        "type": "background",
        "background": "510280"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我說你呀，",
        "unit_id": 105631,
        "voice": "vo_adv_4010186_000"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不用那麼勉強哦？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n雖然說今天是我的生日。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你的心意我很高興，",
        "unit_id": 105631,
        "voice": "vo_adv_4010186_001"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "但是沒必要",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "為了選禮物",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "而連續跑了這麼多家店吧……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n簡單一點的也沒關係哦？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……真是的，",
        "unit_id": 105631,
        "voice": "vo_adv_4010186_002"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "這種時候你會變得很頑固呢。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我知道了，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也會認真考慮的。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "要是顧慮太多而選了便宜的東西，",
        "unit_id": 105631,
        "voice": "vo_adv_4010186_003"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "他大概也不會接受吧。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "既然如此，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我也",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "試著跟這孩子撒嬌一下吧。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我想想……",
        "unit_id": 105631,
        "voice": "vo_adv_4010186_004"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "衣服之類的？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "以福袋那時候的情況來看，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你的衣服品味",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "稍微有點脫線。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "那麼",
        "unit_id": 105631,
        "voice": "vo_adv_4010186_005"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "飾品",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "類的……？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "嗯──",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "可是我",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "對那種東西有點……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "啊！？",
        "unit_id": 105631,
        "voice": "vo_adv_4010186_006"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n你、",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "認真的！？",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不，",
        "unit_id": 105631,
        "voice": "vo_adv_4010186_007"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我想你沒有",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "別的意思……",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n害我",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "剛剛慌了一下。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你這男人，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "真是對心臟很不好呢。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "……戒指，",
        "unit_id": 105631,
        "voice": "vo_adv_4010186_008"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "是嗎。",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你、",
        "unit_id": 105631,
        "voice": "vo_adv_4010186_009"
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "你那是",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "什麼表情！",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "戒、",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "戒指",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "還",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不行買啦！",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "好了，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "下一間下一間！",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "我",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "不會再客氣了！",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "\n要來把你的錢包",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "花光光，",
        "unit_id": 105631
    },
    {
        "type": "dialogue",
        "name": "流夏",
        "words": "做好覺悟吧！",
        "unit_id": 105631
    }
]