    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我們",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "睡著了嗎……？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n而且，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "還夢到了奇妙的夢……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "沒想到在夢裡也度過了快樂的新年",
        "unit_id": 112111,
        "voice": "vo_adv_1121004_055"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n這也是",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "一種啟示嗎……？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "……啊，",
        "unit_id": 112111,
        "voice": "vo_adv_1121004_056"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "對了。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "回育幼院後，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n要不要做年糕給孩子們吃？",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "畢竟連夢裡都出現了，",
        "unit_id": 112111,
        "voice": "vo_adv_1121004_057"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "我想一定是很值得慶祝的事。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "兩個人一起做很多年糕，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓大小姐也嚇一跳吧！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "呵呵，",
        "unit_id": 112111,
        "voice": "vo_adv_1121004_058"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "那回去的時候",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就去買做年糕的材料吧！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n也得去買調味料，",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "砂糖、醬油、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "黃豆粉、",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "海苔……",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "得準備很多種才行。",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "就像在夢裡一樣，兩人一起搗年糕，",
        "unit_id": 112111,
        "voice": "vo_adv_1121004_059"
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "\n",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "鈴莓",
        "words": "讓孩子們開心一下吧！",
        "unit_id": 112111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在從神殿回去的路上，鈴莓感覺很愉快地笑著，\n而{player}就這樣握起她的手，和她一起去購物了。"
    }
