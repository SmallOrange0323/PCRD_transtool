        "words": "呼、",
        "unit_id": 115811,
        "voice": "vo_adv_5061203_000"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呼……",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "終、",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "終於",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "擊倒她了……",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "呿，",
        "unit_id": 115911,
        "voice": "vo_adv_5061203_001"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "這個公主殿下",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "實在是強得嚇人。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真的呢。",
        "unit_id": 116011,
        "voice": "vo_adv_5061203_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "她不只是強而已。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "像她這樣可愛的孩子，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真想邀請她",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "來真步真步王國。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "……從以前就只聽說過不打不相識，",
        "unit_id": 115911,
        "voice": "vo_adv_5061203_003"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "說要邀請對方到自己國家去的，我還是頭一次聽到。",
        "unit_id": 115911
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呵呵，",
        "unit_id": 115811,
        "voice": "vo_adv_5061203_004"
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "這樣也不錯啊。",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "好啦，",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "接下來就好好跟她聊聊……",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "呃、",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "奇怪？",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "公主殿下不見了！",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "\n說不定是在我們說話時往裡頭跑了……",
        "unit_id": 115811
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "我們快追上去吧！",
        "unit_id": 115811
    }
]