    {
        "type": "dialogue",
        "name": "旁白",
        "words": "回家途中的{player}"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n感覺好像有人在叫他而停下了腳步。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "哦，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "找到了、找到了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂～！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "喂，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_001"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "那邊那個，就是在叫你！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n別假裝沒聽到！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯！",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你記得我嗎？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是我呀！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啥？",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_003"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣啊……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我沒說過自己的名字嗎。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的mimi也有收到通知吧？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我叫諾維……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯？",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "什麼啦。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n咦？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "不能說那個名字嗎？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "為什麼……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_005"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這樣啊。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "得保密才行的嘛。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好險好險……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "唉……",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_006"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "如果是你的話應該無所謂吧。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我的名字叫做……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "矛依未。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊？",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_007"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你問我為什麼讀同一間學校",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "卻沒有穿制服？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那是因為……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_008"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我要怎麼回答啊？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_009"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣啊……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個嘛……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為我回家",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "換過衣服了呀！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "稍微想一下就知道了吧？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嘿嘿！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "哦，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "對了。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為今天是我第一次遇見你的紀念日呀。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我想說見一面也好，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就過來了。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是新年的時候嗎？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "原來如此，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "從你的角度來看是這樣啊。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "算了，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "別在意那種小細節啦。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n晶的公主騎……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喂，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你從剛才開始就一直在幹嘛呀！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我話才講到一半耶。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "呃，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這個也不能講的嗎？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊啊……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這樣很無聊耶！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "喔，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我只是在講電話啦。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "難道你是在擔心我嗎？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你還真是個",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "老好人呢。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊～",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "知道了知道了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我要回去了啦！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我的搭檔囉囉嗦嗦嘮嘮叨叨的",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "，我要走了。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "反正也見到你了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就這樣，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "下次見囉！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我在阿斯特朗傳奇",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "等你哦！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}走掉後……"
    },
    {
        "type": "background",
        "background": "510240"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "算了，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "今天就先這樣吧。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "距離第一次戰鬥到現在已經這麼久了啊。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "唉……",
        "unit_id": 106231,
        "voice": "vo_adv_9006010_020"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "什麼叫「今天就先這樣」啊，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "諾維姆。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n萬一我們的真實身分暴露了怎麼辦啊。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n做事之前多想想吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊哈哈哈，",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_021"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "抱歉抱歉。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "尾狗刀你自己也很好奇的吧？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "晶的公主騎士……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "在你看來，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼樣？",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "明明諾維姆的樣子",
        "unit_id": 106231,
        "voice": "vo_adv_9006010_022"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "這麼可疑卻絲毫沒有動搖……",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n要麼是個厲害的大人物，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "要麼只是",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "很遲鈍。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "嗯，",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "他應該屬於後者吧。",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "怎麼樣？",
        "unit_id": 106231,
        "voice": "vo_adv_9006010_023"
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "\n只是聊聊幾句",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "詠斗",
        "words": "就心滿意足了嗎？",
        "unit_id": 106231
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯。",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_024"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n我好像有點知道",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "為什麼晶會對他這麼熱衷了。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但",
        "unit_id": 106131,
        "voice": "vo_adv_9006010_025"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我是不會客氣的！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "下次見面時，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "贏的一定是我們！！",
