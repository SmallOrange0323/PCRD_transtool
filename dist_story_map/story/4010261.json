    {
        "type": "dialogue",
        "name": "愛來",
        "words": "咦？",
        "unit_id": 135531,
        "voice": "vo_adv_4010261_000"
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "這裡……",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "不是那邊的世界嗎？",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n這不是我「準備」的啊……",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n這個夢",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "應該是有人讓我做的吧？",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "嗯……",
        "unit_id": 135531,
        "voice": "vo_adv_4010261_001"
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "那邊那個是──{player}！",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "哈哈，",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "好久不見！",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "居然在這種地方遇見，還真是巧呢。",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "你在做什麼？",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "……咦，",
        "unit_id": 135531,
        "voice": "vo_adv_4010261_002"
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "生日？",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n我的……？",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "啊哈～",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "原來如此……",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "是這種「設定」啊～",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "不！",
        "unit_id": 135531,
        "voice": "vo_adv_4010261_003"
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "沒有沒有沒有！",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n沒有的事！",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "就是今天沒錯啦～！",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "不過，",
        "unit_id": 135531,
        "voice": "vo_adv_4010261_004"
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "對啊……",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "哈哈哈。",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "我從來沒想過",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "自己居然也會有「生日」。",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n我真的真的真～",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "的",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "很高興喔！",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "因為",
        "unit_id": 135531,
        "voice": "vo_adv_4010261_005"
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "這個生日是我存在於此的證明。",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "而且不是由別人，而是由你來為我慶生，",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "所以這是我最快樂的一天♪",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "好！",
        "unit_id": 135531,
        "voice": "vo_adv_4010261_006"
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "那麼",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "一開始要先去哪？",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n我們就玩到累癱為止吧！",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "如果你玩累了，不小心睡著的話，",
        "unit_id": 135531,
        "voice": "vo_adv_4010261_007"
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "我就背你回去♪",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n當作過去的回禮？",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "我開玩笑的，",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "哈哈哈！",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "……欸。",
        "unit_id": 135531,
        "voice": "vo_adv_4010261_008"
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "要讓姐姐我的這一天生日",
        "unit_id": 135531
    },
    {
        "type": "dialogue",
        "name": "愛來",
        "words": "\n變得像夢一樣喔♪",
        "unit_id": 135531
    }
]