[
    {
        "type": "background",
        "background": "501032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]雖然說順利除靈完了……",
        "unit_id": 127112,
        "voice": "vo_adv_6124103_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]但沒想到這之前所遇到的靈異現象，",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]全都是父親幹的好事。",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]我想稍微給他一點教訓，",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]但是該怎麼做才好呢？",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]",
        "unit_id": 127112,
        "voice": "vo_adv_6124103_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]原來如此，",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]那真是個好點子！",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n[FFFFFFFF]讓他變成冰冷的骸骨，",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]深受頭痛之苦吧。",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]雖然說是頭痛，",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]但如果是父親，",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]因為他只有頭所以是全身痛呢……",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]",
        "unit_id": 127112,
        "voice": "vo_adv_6124103_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]也就是像沙浴那樣吧。",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n[FFFFFFFF]的確，",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]這很適合拿來當作懲罰也說不定呢。",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]……啊。",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]但是父親他，",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]沒有身體。",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]",
        "unit_id": 127112,
        "voice": "vo_adv_6124103_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]呵呵……",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]真像你會說出的回答呢。",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]真希望父親也能學習你這種氣度。",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]看在你這麼溫柔的分上，",
        "unit_id": 127112
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "[FFFFFFFF]這次我就原諒他吧。",
        "unit_id": 127112
    }
]