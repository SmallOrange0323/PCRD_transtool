    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "「看起來很好吃」",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就是這種感覺啊！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我也要開動了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "啊呣……",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_052"
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "啊，",
        "unit_id": 413,
        "voice": "vo_adv_1345002_053"
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "那樣一口吞進去的話……",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嗯嗯嗯……",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_054"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "內部感應器出現了強烈的反應！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我第一次感受到這種刺激！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n……這就是「好吃」的感覺嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "奇怪……？",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_055"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n總覺得",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "肚子附近好像有個功能第一次啟動了。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n食物裝進了袋子裡，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "體內氣壓好像減少了一部分……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生，",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_056"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "「好吃」就是這種感覺嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n在騎士先生的體內，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "也會有袋子打開、",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "壓力下降的現象嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "奇、",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_057"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "奇怪？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "好像又有其他功能啟動了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n軀體的正中央部分打開了……！？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇，",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_058"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "肚子上的門掉出了真空包裝！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "剛才吃下的食物被完整地包裝起來了！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "好厲害！",
        "unit_id": 413,
        "voice": "vo_adv_1345002_059"
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "簡直就像在做便當一樣。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "\n機械人族",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "真的很不可思議呢……",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來有這種新功能呀～！",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_060"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "看來似乎還有很多我不知道的事！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "……啊。",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_061"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不過，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這樣",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我有享受到餐點嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n雖然真空包裝帶來的刺激，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "確實是全新的體驗……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "但好像跟我看著【美食殿堂】的各位，",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_062"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n一直很嚮往，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "覺得",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "「真好～」的感覺",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "不太一樣……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "……嗯～",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_063"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "心裡",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "有一種堆積了重物的感覺。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n不是食物，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "而是另一種沉甸甸的壓迫感。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這到底是什麼呢……？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "悲傷？",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_064"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n這就是",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "悲傷的感覺嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我不具備流眼淚的機能，",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_065"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n所以不了解悲傷的感覺……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n該不會，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這也算是一種成長吧？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "真是這樣的話，",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_066"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "成長明明應該是很開心的事，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n但胸口內側卻感覺沉甸甸的。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n沒想到不只有開心，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "還真是難懂呢……",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "騎士先生",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_067"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "也有體會過",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n像這樣",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "沉重的心情嗎？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n那一定",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "很難受吧？",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "悲傷的感覺",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_068"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就像一個大蛋糕一樣呢。",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n既然可以和騎士先生一起分享，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n那我",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就算感到悲傷也沒關係！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "嘿嘿♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "因為是【美食殿堂】，",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_069"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "所以我本來想和大家一起吃飯，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n但是不要緊♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "就算沒辦法像大家一樣吃飯，",
        "unit_id": 413,
        "voice": "vo_adv_1345002_070"
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "\n克蘿茜小姐和{player}",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "\n今天也還是一起用餐了喔。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "是這樣嗎？",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_071"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這麼說來，",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_072"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我聽說【美食殿堂】是大家圍著餐桌吃飯，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n一起品嚐美食的公會！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "這樣的話，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我也達成了一半呢♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "雖然和大家有不一樣的地方……",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_073"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n但",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我會和騎士先生一起吃飯，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "所以也是",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "【美食殿堂】的一員吧！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "……嘿嘿，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "謝謝你們！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我打起精神了♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "感謝招待！",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_074"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n謝謝妳幫忙我",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "一起挑戰！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "只是粗茶淡飯而已。",
        "unit_id": 413,
        "voice": "vo_adv_1345002_075"
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "\n看來我的料理",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "似乎有好好變成「養分」呢。",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "\n",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "呵呵，",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "餐廳的女店長",
        "words": "真是太好了……",
        "unit_id": 413
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "原來如此♪",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_076"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "就算是長途冒險，只要有乾糧，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n就不用太擔心能量耗盡吧！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "那麼，",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "我要來做很多的包裝囉～♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "哇♪",
        "unit_id": 134511,
        "voice": "vo_adv_1345002_077"
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n我第一次吃的飯菜",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "可以讓騎士先生吃到呢！",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "\n",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "克蘿茜",
        "words": "你願意品嘗的話我會很開心的♪",
        "unit_id": 134511
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "透過在蘭德索爾的活動，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n克蘿茜又進一步確認了自身的成長。"
    },
    {
        "type": "dialogue",
