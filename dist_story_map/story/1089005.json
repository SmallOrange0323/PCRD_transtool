[
    {
        "type": "background",
        "background": "500010"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "蘭德索爾的街市道路被年底忙碌的氣氛包圍。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n{player}在其中一處，發現了正在購物的怜。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "要帶去的東西",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "差不多就這些吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n有什麼需要的去那邊也可以買……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是你啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是準備要去工作嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "辛苦了，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你還是一樣勤奮呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也是，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "昨天結束了",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "公會接取的工作。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n現在正為",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "新年假期",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "做各種準備。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我還有",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "其他",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想要買齊",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "的東西。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "難得碰上了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們稍微邊走",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "邊聊吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "準備迎接新年，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_005"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "大家都興奮得心情浮躁的這氛圍……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真不錯呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n如祭典前夕般的期待感",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "一直持續著。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "和家人一同悠閒度過，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或是和好友一同出遊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n大家都會各自度過不同的新年吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_007"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你年底",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "有什麼計畫嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n像是要去哪裡，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "或是要和誰一起過。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣啊……",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……其實，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_009"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我打算",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "暫時到大江戶去過年。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "並非有什麼特別的要事，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_010"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n偶爾離開蘭德索爾悠然度過",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "應該也不錯，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n就是有這樣的想法罷了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且……",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "待在蘭德索爾的話，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n無論如何都會受到父親的干涉。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n至少新年假期中，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我希望能忘掉家裡的束縛。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_012"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也不是要抱著消極的心情去的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在那邊有各式各樣想嘗試的事，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n旅館也已經預約完成了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "獨自一人旅行這種經驗",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "也不常有，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n也不能說沒有不安的地方……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我會的。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我不是這個意思，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n雖然我突然說這種話，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可能會讓你感到困惑……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你的關心。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不是煩惱，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "其實是有",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想拜託你的事情，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那個……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "如果可以，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_018"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你要不要也一起去？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你想想，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "在大江戶過年聽起來很有趣對吧？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊啊，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你會覺得驚訝也很正常。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也覺得這有點突然。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當然不會勉強你。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "畢竟提案得很臨時，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你想拒絕也沒關係──",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可、",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_020"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "可以嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太、",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "太好了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "咳……",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "看到你這麼興致勃勃，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不枉費我這樣約你了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "鼓起勇氣來問真是太好了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們會搭馬車過去，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "當天就在馬車轉運站集合吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n你的房間我會向那邊的旅館說一聲，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "麻煩你準備好自己的行李。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那麼，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "再見了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……可以再次和他一起，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "度過新年了，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗎……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呵呵。",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500890"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "到了隔天。怜動身前往和{player}約好集合的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n馬車轉運站。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "事前準備花了點時間，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "稍微晚了一些呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不過動作快一點的話應該還趕得上……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "怜小姐，",
        "unit_id": 1111,
        "voice": "vo_adv_1089005_025"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您是要去哪裡呢。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你們是……",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_026"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "父親的僕人啊。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "要說前面有什麼的話，",
        "unit_id": 1211,
        "voice": "vo_adv_1089005_027"
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "應該就是要離開王都的馬車轉運站了。",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "\n難道您在這個時期要去旅行？",
        "unit_id": 1211
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你都明白了，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就讓我過去吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "恕我辦不到。",
        "unit_id": 1111,
        "voice": "vo_adv_1089005_029"
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "\n",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "怜小姐也需要出席",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "新年舉辦的聚會，",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "男追兵",
        "words": "\n老爺應該有通知您了。",
        "unit_id": 1111
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "聚會的事，",
        "unit_id": 100311,
        "voice": "vo_adv_1089005_030"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我應該已經拒絕過了。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "這樣的話，",
        "unit_id": 1211,
        "voice": "vo_adv_1089005_031"
    },
    {
        "type": "dialogue",
        "name": "女追兵",
        "words": "您應該也知道老爺沒有准許您不參加吧？",
        "unit_id": 1211
    },
    {
