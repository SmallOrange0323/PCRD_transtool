    {
        "type": "dialogue",
        "name": "旁白",
        "words": "復活祭之後。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n剎鬼在整理棺材裡的陪葬品時──"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "……？",
        "unit_id": 135912,
        "voice": "vo_adv_5209061_000"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "為什麼，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "會有這個……？",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "是雪野寫的信啊。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "我來看看……",
        "unit_id": 135912
    },
    {
        "type": "still",
        "still": "520906101"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "致",
        "unit_id": 135812,
        "voice": "vo_adv_5209061_001"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂最喜歡的剎鬼：",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "坦白說，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "由於事出突然，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "至今儂仍沒有什麼實感。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n到了明天，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "妳",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "是不是會像平常一樣，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "出現跟儂",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "打招呼呢。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂心裡",
        "unit_id": 135812,
        "voice": "vo_adv_5209061_002"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "一直有這樣的感覺。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "要真是如此就好了。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "剎鬼妳還記得嗎。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "埋在久遠冰河裡的時間膠囊。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "妳和儂",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "在小時候約好了，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "長大後要一起",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "打開呢。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂放的",
        "unit_id": 135812,
        "voice": "vo_adv_5209061_003"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "是信和玩具，要給將來的自己。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "記得剎鬼放的",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "是信和短刀吧。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "妳在那時候就很帥氣了。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "從那麼小的時候",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "到現在，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "剎鬼",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "都是儂",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "崇拜的對象。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "並且，",
        "unit_id": 135812,
        "voice": "vo_adv_5209061_004"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "在往後，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "妳永遠都會是儂最喜歡的朋友。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "雖然想到長大後，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "只有儂一個人打開時間膠囊，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "就覺得很寂寞，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "但",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "這是儂家兩人的約定呢。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂也很好奇剎鬼在信裡寫了什麼。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "所以就算儂感到寂寞，",
        "unit_id": 135812,
        "voice": "vo_adv_5209061_005"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "也會期盼未來，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "像剎鬼一樣堅強地活下去。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "真的很謝謝妳。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "儂絕對不會",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "忘記剎鬼的。",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n雪野敬啟　",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "　",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "　",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "　",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "　",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "　接續其二",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "（",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "果然還是寫不夠",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "）",
        "unit_id": 135812
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "「其二」……",
        "unit_id": 135912,
        "voice": "vo_adv_5209061_006"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "怎麼會有一整捆。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "喂，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "竟然到「一百」啊……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "呵。",
        "unit_id": 135912,
        "voice": "vo_adv_5209061_007"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "真是的……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "機會難得，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "就全部讀過吧。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "咦，",
        "unit_id": 135812,
        "voice": "vo_adv_5209061_008"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "剎鬼……！？",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n那、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "那個是……",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "喔、",
        "unit_id": 135912,
        "voice": "vo_adv_5209061_009"
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "喔，",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "雪野。",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "\n",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "謝謝",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "剎鬼",
        "words": "妳的信……",
        "unit_id": 135912
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "呀啊啊～",
        "unit_id": 135812,
        "voice": "vo_adv_5209061_010"
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "\n感、",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "感覺好害羞，",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "雪野",
        "words": "妳不要再讀了～！",
        "unit_id": 135812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在那之後，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "「給剎鬼的信，其一到一百 by 雪野」"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n就這麼被雪野"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "封印在久遠冰河的深處。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n在意後續內容的剎鬼，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "似乎露出了感到可惜的表情。"
    }
]