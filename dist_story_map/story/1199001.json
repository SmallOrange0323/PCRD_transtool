        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n這點小事，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "完全不要緊……",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "啊痛",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "痛……",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "有那麼痛嗎？",
        "unit_id": 119911,
        "voice": "vo_adv_1199001_019"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "那麼，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "就快把宮子的布丁交出來，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n然後回家休息吧。",
