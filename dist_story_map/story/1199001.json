    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "如果是聖誕老人，一定會實現宮子的願望！",
        "unit_id": 100711,
        "voice": "vo_adv_1199001_004"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n聖誕老人會把布丁作為禮物送至世界各地，",
