    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "是個好人喲～♪",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……咦？",
        "unit_id": 100711,
        "voice": "vo_adv_1199001_005"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "聖誕老人",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "除了布丁以外，也會送其他禮物？",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子以前都不知道。",
