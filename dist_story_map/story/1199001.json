    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "特地在大冷天排隊去買！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子要珍惜地小口小口吃它喲。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "嚼嚼嚼嚼……",
