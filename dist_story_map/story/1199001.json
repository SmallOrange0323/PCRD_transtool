    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "一定是聖誕老人來了喲！",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子要去外面看看～！",
