        "voice": "vo_adv_1199001_010"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "布丁～♪",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "……咦？",
