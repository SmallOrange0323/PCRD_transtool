        "voice": "vo_adv_1199001_006"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "說到聖誕老人，宮子想起來了！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n之前穿過的那件衣服，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "和聖誕老人穿的很像。",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "穿上那個，",
        "unit_id": 100711,
        "voice": "vo_adv_1199001_007"
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "聖誕老人一定能看出，",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n宮子到底有多期待",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "聖誕老人的到來！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
