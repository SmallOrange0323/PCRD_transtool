    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "不，",
        "unit_id": 3911,
        "voice": "vo_adv_1199001_020"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "不能休息啊……",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n世界各地的",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "孩子們都還在",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "期待著禮物……",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "唔喔！",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "閃到腰了……！",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "我、",
