    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "已經吃完了！",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 100711
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子要再去買一次！",
