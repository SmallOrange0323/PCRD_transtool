    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "如此一來不管怎麼看，",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "宮子都是世界第一的聖誕老人的粉絲來的～",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "\n",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "所以希望他早點來",
        "unit_id": 119911
    },
    {
        "type": "dialogue",
        "name": "宮子",
        "words": "送宮子布丁喲！",
