        "voice": "vo_adv_1199001_021"
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "果然",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "還是，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n沒辦法再繼續送了……",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "\n",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "少年們啊，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "抱歉，",
        "unit_id": 3911
    },
    {
        "type": "dialogue",
        "name": "聖誕老人",
        "words": "我有個請求……",
