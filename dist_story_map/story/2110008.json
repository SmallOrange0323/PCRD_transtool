[
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──在尾狗刀對獸人族之國發動襲擊的不久之前。"
    },
    {
        "type": "background",
        "background": "500213"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "凱留、"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雪菲"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "與純，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n急著趕回蘭德索爾。"
    },
    {
        "type": "still",
        "still": "211000801"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "──「冰霜之路」！",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "咻咻☆",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_001"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n好快～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "如果是平坦的地方，",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "凍結地面──",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "在貨車車底裝上冰刀",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "滑行就行了……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我的魔法帶來的氣浪會成為推進力！",
        "unit_id": 106011,
        "voice": "vo_adv_2110008_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過遇到陡峭的上坡與森林，就得繞路，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "或是強行──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "唔！",
        "unit_id": 104711,
        "voice": "vo_adv_2110008_004"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n前面",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "馬上就遇到了坡道！",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～真是的！",
        "unit_id": 106011,
        "voice": "vo_adv_2110008_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n只能強行用魔法連貨車一起推動衝刺了！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n待會車子會搖晃，大家要找個地方",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "抓好喔！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可、雪菲",
        "words": "哇啊啊啊～！",
        "unit_id": 1,
        "voice": "vo_adv_2110008_006"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "still",
        "still": "211000801"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呼……",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n方法雖然粗暴，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "但前進了一大段路呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好痛……",
        "unit_id": 106011,
        "voice": "vo_adv_2110008_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n一屁股跌坐下去壓扁尾巴了，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "妳們兩個",
        "unit_id": 104711,
        "voice": "vo_adv_2110008_009"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "都連續地在持續使用魔法，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我想最好找個地方休息一下。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "既然是這樣，",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_010"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那由我在後面推貨車吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還是從前面拖曳比較好？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是個好主意♪",
        "unit_id": 106011,
        "voice": "vo_adv_2110008_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這樣我和雪菲都可以輕鬆了～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "怎麼能讓陛下",
        "unit_id": 104711,
        "voice": "vo_adv_2110008_012"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "去做這種……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n像拉車馬或雪橇狗般的舉動。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n有需要的時候，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "就讓我來吧。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不要緊。",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "接下來一段路都是平緩的下坡……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n鋪出冰路之後，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "就不用再花費多少魔力。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "更重要的是……",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_014"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我想快點趕回去。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "請讓我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "再努力一會吧。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為用來返回公會小屋的空間跳躍結界，",
        "unit_id": 106011,
        "voice": "vo_adv_2110008_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n還是被【憤怒‧軍團】破壞的狀態，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒有時間修復啊～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果能用那個，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就可以再輕鬆一點了……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼，",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "在下坡路段期間……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n來吃便當",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "補給能量吧♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真琴",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有準備三明治讓我帶來喔♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是燒肉三明治呢。",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_017"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "請給我",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "一個。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗯～♪　",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_018"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "獸人族之國的肉類料理，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n在醬料與調味料方面下了功夫，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很好吃呢～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "來，小凱留也嚐嚐♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂！？",
        "unit_id": 106011,
        "voice": "vo_adv_2110008_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我自己會吃，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別把食物硬塞進別人嘴裡啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "醬料會灑出來啦！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……",
        "unit_id": 104711,
        "voice": "vo_adv_2110008_020"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "純？",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_021"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n妳不吃嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "不，那個，",
        "unit_id": 104711,
        "voice": "vo_adv_2110008_022"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "我……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊～那傢伙呢，",
        "unit_id": 106011,
        "voice": "vo_adv_2110008_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n不願意在別人面前脫下頭盔。",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這樣很不禮貌喔～",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呃，",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_024"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n就是常在戰場……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "的精神嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒有那麼",
        "unit_id": 104711,
        "voice": "vo_adv_2110008_025"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "了不起。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我只是有點",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "難為情而已……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "是這樣啊。",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_026"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "儘管我之前並不知道，",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "對不起。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我把純小姐那一份",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_027"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也留好了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請晚點悄悄地吃喔☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "感謝您的關懷，",
        "unit_id": 104711,
        "voice": "vo_adv_2110008_028"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "陛下。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯……",
        "unit_id": 106011,
        "voice": "vo_adv_2110008_029"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n味道還可以，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是在搖晃得這麼厲害的貨車上，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吃東西很不方便呢……",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那麼",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_030"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "我來抱著妳吧，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這麼一來",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就能穩住姿勢了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊？",
        "unit_id": 106011,
        "voice": "vo_adv_2110008_031"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n喂，",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別說莫名其妙的話──",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊！",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_032"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "真是的，小凱留，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請安分一點～♪",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "危險！",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_033"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n前面有岩石──！",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "呀啊啊啊啊！？",
        "unit_id": 1,
        "voice": "vo_adv_2110008_034"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………\n……"
    },
    {
        "type": "background",
        "background": "500032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "於是，半天後──"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "用全速",
        "unit_id": 104711,
        "voice": "vo_adv_2110008_035"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "趕回了蘭德索爾雖然很好……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "市民1",
        "words": "呼～",
        "unit_id": 811,
        "voice": "vo_adv_2110008_036"
    },
    {
        "type": "dialogue",
        "name": "市民1",
        "words": "有夠累～",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "市民1",
        "words": "\n今天也努力幹活了一整天呢～",
        "unit_id": 811
    },
    {
        "type": "dialogue",
        "name": "市民2",
        "words": "好，",
        "unit_id": 911,
        "voice": "vo_adv_2110008_037"
    },
    {
        "type": "dialogue",
        "name": "市民2",
        "words": "日薪也領到手了，",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "市民2",
        "words": "\n找家店喝一杯吧，兄弟！",
        "unit_id": 911
    },
    {
        "type": "dialogue",
        "name": "市民3",
        "words": "哎呀～",
        "unit_id": 411,
        "voice": "vo_adv_2110008_038"
    },
    {
        "type": "dialogue",
        "name": "市民3",
        "words": "那邊的幾位大哥～",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "市民3",
        "words": "\n來我們店裡坐坐如何～？",
        "unit_id": 411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……總覺得",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_039"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "城裡的狀況平靜得讓人有點脫力呢。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是啊──",
        "unit_id": 106012,
        "voice": "vo_adv_2110008_040"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n雖然我們已透過【哞哞自衛隊】聯絡網，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n得知蘭德索爾並未被厄莉絲等人佔據",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "的消息了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "姑且不論王宮那邊……",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_041"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n是他們對城鎮造成的損害",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "沒有那麼大嗎？",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "一定是這樣。",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_042"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這多虧了大家的努力！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……咦？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "團長～！",
        "unit_id": 711,
        "voice": "vo_adv_2110008_043"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "陛下～！",
        "unit_id": 712,
        "voice": "vo_adv_2110008_044"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "是你們。",
        "unit_id": 104711,
        "voice": "vo_adv_2110008_045"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n太好了，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "你們都平安無事。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "才不是沒事呢～！",
        "unit_id": 711,
        "voice": "vo_adv_2110008_046"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n很多人都負傷了！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "能夠正常行動的人員，",
        "unit_id": 712,
        "voice": "vo_adv_2110008_047"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "大約是部隊全體的半數。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n陛下與團長都不在的期間，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "我們在行政長官的指揮下，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n從事救援行動與",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "取締趁火打劫的宵小……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "你提到行政長官，",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_048"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這表示",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "克蕾琪塔小姐也沒事吧。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "饒了我吧，",
        "unit_id": 711,
        "voice": "vo_adv_2110008_049"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "我真不想在不習慣的部門被人肆意使喚啊！",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n那個秘書，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "做出的指示很準確，卻不近人情又嚴格……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n雖然她很可愛啦……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "要是秘書",
        "unit_id": 712,
        "voice": "vo_adv_2110008_050"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "也像克莉絲提娜前副團長那樣，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n再隨興一點就好了。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n雖然她很可愛啦……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個，",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_051"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "各位。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n王宮那邊的情況怎麼樣了呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "王宮嗎？",
        "unit_id": 711,
        "voice": "vo_adv_2110008_052"
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n雖然我們",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "一直在城鎮裡四處奔波，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "\n不太清楚……",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "至少",
        "unit_id": 712,
        "voice": "vo_adv_2110008_053"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "好像沒有發生騷動。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n那隻超巨大的魔物",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "也在不知不覺間消失了。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "大家",
        "words": "…………",
        "unit_id": 1,
        "voice": "vo_adv_2110008_054"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "……陛下。",
        "unit_id": 104711,
        "voice": "vo_adv_2110008_055"
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "看來暫時",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "沒有厄莉絲一黨的威脅……",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n我",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "想回去指揮士兵。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "畢竟小智與茉莉",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "還需要徹底靜養，",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "純",
        "words": "\n暫時應該無法從珊托魯斯歸返。",
        "unit_id": 104711
    },
    {
        "type": "dialogue",
        "name": "士兵",
        "words": "真是救星～！",
        "unit_id": 711,
        "voice": "vo_adv_2110008_056"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "只要有團長盯著，",
        "unit_id": 712,
        "voice": "vo_adv_2110008_057"
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "街上的地痞流氓們，",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "隊長",
        "words": "\n應該也無法輕舉妄動了。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好的，純小姐，",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "城鎮這邊就拜託妳了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n那麼，我們",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "前往王宮吧！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲、凱留",
        "words": "嗯。",
        "unit_id": 1,
        "voice": "vo_adv_2110008_059"
    },
    {
        "type": "background",
        "background": "500802"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……唉～唉。",
        "unit_id": 106012,
        "voice": "vo_adv_2110008_060"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這不是到處都是破洞與裂縫嗎。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n光是維修費",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就不知道要花多少錢……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_061"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "情況和那些軍人說的一樣。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "王宮前方的廣場也",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "空無一人……",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呢。",
        "unit_id": 106412
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太安靜了，",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_062"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "安靜得令人發寒。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n平常即使在這個時段，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "明明也會有再多一點人路過的……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對呀。",
        "unit_id": 106012,
        "voice": "vo_adv_2110008_063"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n頂多只有",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "四處散落著萬能人偶的碎片……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "嗯……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "吶，",
        "unit_id": 106012,
        "voice": "vo_adv_2110008_064"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雪菲。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這塊劍的碎片……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "啊……",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_065"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這是……",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_066"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n贊恩先生所用佩劍的",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "劍尖部分……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "對吧……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……哥哥……",
        "unit_id": 106412,
        "voice": "vo_adv_2110008_067"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "贊恩……",
        "unit_id": 106012,
        "voice": "vo_adv_2110008_068"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n那個……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不在",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n是有人",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "將他搬離了這裡嗎……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_069"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這個、",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "說不定……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n贊恩先生他",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "自己去找醫生──",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂……！",
        "unit_id": 106012,
        "voice": "vo_adv_2110008_070"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚咕！",
        "unit_id": 105812,
        "voice": "vo_adv_2110008_071"
    },
    {
