    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}和【美食殿堂】的成員一起，\n在蘭德索爾的鬧區邊走邊吃著。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嚼嚼嚼☆",
        "unit_id": 105812,
        "voice": "vo_adv_4004001_000"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n嗯——，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "這裡的饅頭，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "超好吃！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "太讚了吧☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，",
        "unit_id": 106012,
        "voice": "vo_adv_4004001_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那是第幾個了啊。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n妳是不會吃膩嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人也來品嚐吧。",
        "unit_id": 105913,
        "voice": "vo_adv_4004001_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n來，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊——……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n請張開嘴巴。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在{player}張開嘴巴的同時，\n嘈雜的巨響一起震驚了這一帶。"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "！？",
        "unit_id": 105913,
        "voice": "vo_adv_4004001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請小心！",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……好、",
        "unit_id": 105812,
        "voice": "vo_adv_4004001_004"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "好像平靜下來了呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "剛剛的搖晃，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "到底是發生了什麼事……？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是普通的地震吧？",
        "unit_id": 106012,
        "voice": "vo_adv_4004001_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還是說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是妳的肚子在叫吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "也許是這樣呢～",
        "unit_id": 105812,
        "voice": "vo_adv_4004001_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "饅頭太好吃了，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "還想再多吃點呢～",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咦，",
        "unit_id": 105913,
        "voice": "vo_adv_4004001_007"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個是……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "大家，",
        "unit_id": 190811,
        "voice": "vo_adv_4004001_008"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "發生了不得了的事！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "花凜小姐，",
        "unit_id": 105812,
        "voice": "vo_adv_4004001_009"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "阿囉哈～☆",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "竟然那麼慌張的樣子，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "很難得呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是、",
        "unit_id": 190811,
        "voice": "vo_adv_4004001_010"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是非常不得了的緊急狀況！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "剛剛的震動是因為",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "突然從蘭德索爾遙遠的西邊出現，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n與王宮一樣大的",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "未知巨大物體的攻擊！",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "花凜小姐，",
        "unit_id": 105913,
        "voice": "vo_adv_4004001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請冷靜下來。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "妳說的未知物體是……？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "沒有",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "更詳細的情報嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "那個……",
        "unit_id": 190811,
        "voice": "vo_adv_4004001_012"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們【公會管理協會】掌握到的情報……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n只知道那個東西所造成的損害一面擴大，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "並一面",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "朝著這裡過來\n",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "而已……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是是。",
        "unit_id": 106012,
        "voice": "vo_adv_4004001_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n於是",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就和平常一樣",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "想要委託調查和討伐，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒錯吧。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是的。",
        "unit_id": 190811,
        "voice": "vo_adv_4004001_014"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n只是這次因為敵人很棘手，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "所以【公會管理協會】",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "正在四處號召",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n所有的公會。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊，",
        "unit_id": 105812,
        "voice": "vo_adv_4004001_015"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "請看天空！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　好像有什麼飛過來了！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "貪吃佩可一行人仰望的天空，下起了謎樣的液體。\n被太陽光映照著，顯得十分閃亮。"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊啊——！",
        "unit_id": 105812,
        "voice": "vo_adv_4004001_016"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　街上變得黏答答",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "濕淋淋的～！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "饅頭店屋也變得濕淋淋的，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n這樣的話，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "就不能再來一份了耶……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "嗚嗚……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好臭——！",
        "unit_id": 106012,
        "voice": "vo_adv_4004001_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這是什麼，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "魔物的口水……？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "哦欸欸～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "預估最多只剩下24小時……",
        "unit_id": 190811,
        "voice": "vo_adv_4004001_018"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n這是我們僅剩的緩衝時間了。",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "明天的這個時候，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n能夠活著站在這個蘭德索爾的人",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "已經一個都沒有了吧……",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳形容得很誇張，",
        "unit_id": 106012,
        "voice": "vo_adv_4004001_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "反正也不是什麼大事吧？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再說了",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "像王宮般大的東西，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼可能突然出現――",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "我們比平常準備了更多的……",
        "unit_id": 190811,
        "voice": "vo_adv_4004001_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊？",
        "unit_id": 106012,
        "voice": "vo_adv_4004001_021"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "是指這次的報酬。",
        "unit_id": 190811,
        "voice": "vo_adv_4004001_022"
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "\n因為是蘭德索爾的危機，",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "花凜",
        "words": "當然也會準備相對應的――",
        "unit_id": 190811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真、",
        "unit_id": 106012,
        "voice": "vo_adv_4004001_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的嗎？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就算妳等等說——！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "　",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "其實是騙人的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也不管唷！？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "別慢吞吞的，要走囉！",
        "unit_id": 106012
    }
]