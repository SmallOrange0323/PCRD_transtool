[
    {
        "type": "dialogue",
        "name": "初音",
        "words": "肚子也吃飽了，",
        "unit_id": 128411,
        "voice": "vo_adv_5134204_000"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "感覺開始睏起來了呢～",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n這次的預知夢，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "如果可以夢到像是預演的內容就好了。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "事到如今",
        "unit_id": 128511,
        "voice": "vo_adv_5134204_001"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "也很難大幅改變作戰計畫呢……",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "再說了，",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "許願的數量也是有限的。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n要把全部人都送上宇宙是不可能的。",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "而且穿越大氣層的時候應該會很熱，",
        "unit_id": 128411,
        "voice": "vo_adv_5134204_002"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "難得的新年和服可能會燒焦呢。",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "總而言之，",
        "unit_id": 128311,
        "voice": "vo_adv_5134204_003"
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "能請妳再睡一次嗎？",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "\n",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "既然作戰內容無法改變，",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "祈梨",
        "words": "那就只能請妳作原本的夢了。",
        "unit_id": 128311
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "沒問題，",
        "unit_id": 128411,
        "voice": "vo_adv_5134204_004"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "我這次一定可以的！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n在夢到圓滿的結局之前，",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n我會繼續努力，不會放棄的！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "就是這股氣勢，拜託妳了。",
        "unit_id": 128511,
        "voice": "vo_adv_5134204_005"
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "\n",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "那麼",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "霞",
        "words": "妳準備好要再睡一次了嗎？",
        "unit_id": 128511
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "當然！",
        "unit_id": 128411,
        "voice": "vo_adv_5134204_006"
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "\n",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "那麼",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "就再一次鼓起幹勁……！",
        "unit_id": 128411
    },
    {
        "type": "dialogue",
        "name": "初音",
        "words": "……呼嚕♪",
        "unit_id": 128411,
        "voice": "vo_adv_5134204_007"
    }
]