        "type": "dialogue",
        "name": "未央",
        "words": "在正式甄選會上，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n我們唱出了那首明明沒聽過卻唱得出來的歌。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "原本還只是依稀覺得奇怪，",
        "unit_id": 112511,
        "voice": "vo_adv_5036001_010"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "這時就更加確信了。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我們果然",
        "unit_id": 112411,
        "voice": "vo_adv_5036001_011"
    },
