        "type": "dialogue",
        "name": "凜",
        "words": "還舉辦了快閃演唱會。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n雖然為了要當上偶像所經歷的那些時間",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n非常的辛苦……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "但似乎比想像中的還要有趣。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "不過……",
        "unit_id": 112411,
        "voice": "vo_adv_5036001_008"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "越是努力想去成為偶像。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n我們就",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "越是覺得哪裡怪怪的……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "感覺，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n有某種異樣感徘徊在心裡。",
        "unit_id": 112411
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
