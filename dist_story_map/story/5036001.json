        "type": "dialogue",
        "name": "凜",
        "words": "加上我，凜。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n我們三人組成了一個公會，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "【new generations】。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "原本身為冒險者的我們，",
        "unit_id": 112411,
        "voice": "vo_adv_5036001_005"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n有一天，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "得知了何謂偶像……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "於是",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "就下定了決心，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "「我們也來當偶像吧！」",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "接著在【美食殿堂】的大家，",
        "unit_id": 112611,
        "voice": "vo_adv_5036001_006"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n還有綠色的醜……",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "皮喵太的協助下，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我們",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "決定要去參加新人偶像的甄選大會了！",
        "unit_id": 112611
