        "name": "凱留",
        "words": "……哇呀啊啊啊！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "小凱留！？",
        "unit_id": 105811,
        "voice": "vo_adv_5036001_036"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "凱──哈啾──！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "之後，",
        "unit_id": 1,
        "voice": "vo_adv_5036001_037"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我們在花粉的濃霧之中……",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "奮戰了許久，",
        "unit_id": 1,
        "voice": "vo_adv_5036001_038"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "終於讓小鎮的人們得以逃脫。",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "但是無論怎麼找，",
        "unit_id": 1,
        "voice": "vo_adv_5036001_039"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "都找不到凱留……",
        "unit_id": 1
    },
    {
        "type": "background",
        "background": "500920"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "離了這麼遠的話，",
        "unit_id": 105812,
        "voice": "vo_adv_5036001_040"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n暫時應該就安全了才對……",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "有、",
        "unit_id": 1,
        "voice": "vo_adv_5036001_041"
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "有誰！",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "少女",
        "words": "\n有誰有看到我的搭檔嗎！？",
        "unit_id": 1
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "那些球根小傢伙……！",
        "unit_id": 611,
        "voice": "vo_adv_5036001_042"
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "\n竟然把偶像小花苞們，全都抓走了！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "審查員",
        "words": "怎麼會發生這種事呀！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "現在失去行蹤的，",
        "unit_id": 112611,
        "voice": "vo_adv_5036001_043"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n好像不只凱留凱留一個人而已的樣子！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個",
        "unit_id": 105913,
        "voice": "vo_adv_5036001_044"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "長著臉的球根魔物",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "抓著人類，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n將她們帶到巨大化的「小花苞」裡了——",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n目擊者",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是這麼描述的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "怎麼會這樣！",
        "unit_id": 112411,
        "voice": "vo_adv_5036001_045"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n那不就表示……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "凱留\n也被「盆栽小花」給抓走了嗎！？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "「盆栽小花」……",
        "unit_id": 105913,
        "voice": "vo_adv_5036001_046"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那個……",
        "unit_id": 105812,
        "voice": "vo_adv_5036001_047"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "有件事我很在意，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n為什麼妳們幾位，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n會知道那隻魔物的名字呢？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這個嘛……",
        "unit_id": 112611,
        "voice": "vo_adv_5036001_048"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "我也還搞不清楚的時候，",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "這個名字就直接衝出口了。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n就和我很自然地就喊出",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "澀凜凜、島村村的感覺一樣。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我也一樣。",
        "unit_id": 112511,
        "voice": "vo_adv_5036001_049"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n總覺得，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "有一種令人懷念的感覺……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "嗯……",
        "unit_id": 112511,
        "voice": "vo_adv_5036001_050"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n明明感覺",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "就快想起很多事了。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "只要有什麼契機的話說不定……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "啊，",
        "unit_id": 112411,
        "voice": "vo_adv_5036001_051"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "那個……！",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n我剛剛，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "有稍微瞄到了一點。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我想那個或許",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "能夠成為想起來的契機也說不定……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "妳看到了什麼東西呢？",
        "unit_id": 105812,
        "voice": "vo_adv_5036001_052"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n卯月。",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "雖然妳們可能無法相信，",
        "unit_id": 112411,
        "voice": "vo_adv_5036001_053"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "但是在花粉濃霧的另一邊……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "在盆栽小花的根部，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n有著和這個地方不一樣，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "另外一個世界的景色。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "雖然只有稍微瞄到一眼，",
        "unit_id": 112411,
        "voice": "vo_adv_5036001_054"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "但是，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我卻有一種非常非常懷念的感覺。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "然後……",
        "unit_id": 112411,
        "voice": "vo_adv_5036001_055"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我想到了。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n會不會那一邊是……",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "我們現在雖然忘掉了，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n但其實是我們原本生活的世界呢。",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不一樣的世界……",
        "unit_id": 112511,
        "voice": "vo_adv_5036001_056"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "原本生活的世界……",
        "unit_id": 112611,
        "voice": "vo_adv_5036001_057"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "如果真的是這樣，",
        "unit_id": 105812,
        "voice": "vo_adv_5036001_058"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那會讓人很驚訝呢！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……話說回來",
        "unit_id": 105812,
        "voice": "vo_adv_5036001_059"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "……我們之前，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是不是也有遇過",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n從其他世界到這裡來的人呀？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "　小可蘿？",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔呣……",
        "unit_id": 105913,
        "voice": "vo_adv_5036001_060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "確實，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎是有過類似的事情。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "倘若如此……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "【new generations】的各位。",
        "unit_id": 105913,
        "voice": "vo_adv_5036001_061"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n儘管仍是推測，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "然而此事可能性",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "似乎不低。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "為什麼啊？",
        "unit_id": 112611,
        "voice": "vo_adv_5036001_062"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n可蘿可蘿。",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "若如方才那位擔任評審的婦人所言，",
        "unit_id": 105913,
        "voice": "vo_adv_5036001_063"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n「小花苞」似乎從許久以前",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就存在於這個小鎮。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "的確，那位婆婆她，",
        "unit_id": 112511,
        "voice": "vo_adv_5036001_064"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n有說過這樣的話……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣的「小花苞」，",
        "unit_id": 105913,
        "voice": "vo_adv_5036001_065"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n為什麼會突然",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "成長成為「盆栽小花」呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "或許……",
        "unit_id": 105913,
        "voice": "vo_adv_5036001_066"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是因為聽見了各位的歌聲也說不定。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n這是在下的臆測。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "咦咦咦～？",
        "unit_id": 112611,
        "voice": "vo_adv_5036001_067"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n是我們害的嗎！？",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "不，",
        "unit_id": 112511,
        "voice": "vo_adv_5036001_068"
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "應該不是。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "「盆栽小花」是",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "和我們一樣從那個世界過來的，",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "\n所以才會對我們的歌聲起反應……",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "凜",
        "words": "我想她大概是這個意思吧。",
        "unit_id": 112511
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "啊，是這樣啊！",
        "unit_id": 112611,
        "voice": "vo_adv_5036001_069"
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "\n",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "未央",
        "words": "對不起呀可蘿可蘿！",
        "unit_id": 112611
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不會。",
        "unit_id": 105913,
        "voice": "vo_adv_5036001_070"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也不過只是提出了自己的推測而已。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "嗯……",
        "unit_id": 112411,
        "voice": "vo_adv_5036001_071"
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "雖然還想不太起來，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "但我們所住的世界，",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "卯月",
        "words": "\n會長出那麼奇怪的植物嗎？",
        "unit_id": 112411
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這個嘛……",
        "unit_id": 105913,
        "voice": "vo_adv_5036001_072"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
