[
    {
        "type": "background",
        "background": "501030"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "今天就是在「實現願望的海岸」",
        "unit_id": 135111,
        "voice": "vo_adv_5206411_000"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "度過的最後一天了……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "話說回來，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "最後",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "好像沒有實現",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "任何人的願望……？",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "……嗯。",
        "unit_id": 135211,
        "voice": "vo_adv_5206411_001"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n哥。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "依然是。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "旱鴨子。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "結果",
        "unit_id": 135111,
        "voice": "vo_adv_5206411_002"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "還是恢復原狀了呢。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "比起來到這裡之前，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "感覺心情暢快多了。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "嗯。",
        "unit_id": 135211,
        "voice": "vo_adv_5206411_003"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n我也是。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "厄莉絲呢？",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是呢……",
        "unit_id": 135011,
        "voice": "vo_adv_5206411_004"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "我也下定決心，",
        "unit_id": 135011,
        "voice": "vo_adv_5206411_005"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "要捨棄過往的留戀了。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "並且從今以後，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "以不一樣的方式活下去……",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "和騎士先生一起……",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "……是呢。",
        "unit_id": 135011,
        "voice": "vo_adv_5206411_006"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我想確實是個不錯的暑假。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "小樂",
        "words": "噗噗～！",
        "unit_id": 9512,
        "voice": "vo_adv_5206411_007"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "呵呵，",
        "unit_id": 135111,
        "voice": "vo_adv_5206411_008"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "而且也更了解彼此了呢。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "說起來，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "厄莉絲小姐",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "這之後有什麼打算？",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "總之，",
        "unit_id": 135011,
        "voice": "vo_adv_5206411_009"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "會先回城堡一趟。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n對我來說，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有必要進行修復的睡眠。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "城堡。",
        "unit_id": 135211,
        "voice": "vo_adv_5206411_010"
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "\n好奇。",
        "unit_id": 135211
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "…………",
        "unit_id": 135011,
        "voice": "vo_adv_5206411_011"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "有興趣的話，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "改天可以招待妳們來作客。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "到時候，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "也準備妳們喜歡的魔物料理吧。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "好期待。",
        "unit_id": 135211,
        "voice": "vo_adv_5206411_012"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "謝謝妳。",
        "unit_id": 135111,
        "voice": "vo_adv_5206411_013"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "不過，",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "我並沒有特別",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "喜歡魔物料理……",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "是這樣嗎……？",
        "unit_id": 135011,
        "voice": "vo_adv_5206411_014"
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n我記得妳津津有味地吃著烏賊魔物的料理……",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "\n而且確實，",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "厄莉絲",
        "words": "還小嬰兒化了。",
        "unit_id": 135011
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "……看來果然，",
        "unit_id": 135111,
        "voice": "vo_adv_5206411_015"
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "有需要更深入了解彼此呢。",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "\n",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "今天也來",
        "unit_id": 135111
    },
    {
        "type": "dialogue",
        "name": "雪菲",
        "words": "盡情地聊天吧！",
        "unit_id": 135111
    }
]