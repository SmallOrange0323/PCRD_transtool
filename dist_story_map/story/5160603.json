[
    {
        "type": "background",
        "background": "502170"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "その日メドゥーサ、モニカ、サレンはネフィ＝ネラに呼び出され"
    },
    {
        "type": "dialogue",
        "name": "ナレーション",
        "words": "\n鬼岩城塞へと赴いた。"
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "モニカ殿。",
        "unit_id": 129711,
        "voice": "vo_adv_5160603_000"
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "サレン殿。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\n御足労誠に痛み入り申す。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "ああ序に、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "メドゥーサ奴も喃。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ヒトのこと呼びつけておいて、",
        "unit_id": 133612,
        "voice": "vo_adv_5160603_001"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ついで扱いすんじゃないわよっ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "アタシ、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "そんな暇じゃないんだけど。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "つまらない用事だったら許さないんだからね！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "お気になさらずに、",
        "unit_id": 133212,
        "voice": "vo_adv_5160603_002"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ネフィ＝ネラ殿。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n暇に飽かせて当てどなく祭りを見て回ってただけなので。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "な、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "メドゥーサ？",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "い、",
        "unit_id": 133612,
        "voice": "vo_adv_5160603_003"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "言わなくていいでしょそんなこと！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ネフィ＝ネラのせいでしばらくランドソルで暮らすハメになったから",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "\n",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "『こっち』を見納めしとこうとか、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "そんなこと思ってないんだから！",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "──コロコロコロ。",
        "unit_id": 129711,
        "voice": "vo_adv_5160603_004"
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "蠢動る蛇の化生の割に、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "直な娘で在り申す。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\n",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "わっちの用向きは明快至極。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "ランドソルの賀正の慣習に則り",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\nお前さまらに『御年玉』なる宝を賜さんと思い侍り。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "え、",
        "unit_id": 133512,
        "voice": "vo_adv_5160603_005"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "お、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "お年玉！？　",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "あの、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "お気持ちはうれしいですけど、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\nあたしたちはもう、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "お年玉をもらうような年齢では……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "う、",
        "unit_id": 133212,
        "voice": "vo_adv_5160603_006"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "うむ。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "こんな成りだが、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "一応大人ではあるので……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "えー、",
        "unit_id": 133612,
        "voice": "vo_adv_5160603_007"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "いいじゃない、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "もらっておきなさいよ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "蛇の末子の言う通りであり申す。",
        "unit_id": 129711,
        "voice": "vo_adv_5160603_008"
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\nお前さまらが一角の人物で在らせられるは先刻承知。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\n為れど此度は、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "カノン奴の不始末の詫びも兼ねます也。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "此の機に報恩叶いますれば、",
        "unit_id": 129711,
        "voice": "vo_adv_5160603_009"
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "わっちの面子も立つと云ふもの。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\n其れに古来より遠慮は無沙汰、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "湯の辞儀は水になるとの金言在らば。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\nモニカ殿、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "サレン殿。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "どうぞ御笑納下さります様、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "お頼み申し上げ奉る。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "で、",
        "unit_id": 133512,
        "voice": "vo_adv_5160603_010"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "でも……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なあ……",
        "unit_id": 133212,
        "voice": "vo_adv_5160603_011"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ありがたいけど……",
        "unit_id": 133512,
        "voice": "vo_adv_5160603_012"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "他国の要人からのお年玉なんて、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "いいのかしら。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n一応あたし、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "今回は公務員で来たわけだし。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n収賄で外交問題とかになったりしないかしら？　",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "一国の姫君から直々に褒美を賜ることになるとは……",
        "unit_id": 133212,
        "voice": "vo_adv_5160603_013"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n場合によっては武器を新調できるかもしれんし、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nカフェに新商品を入れられるかもしれんぞ……！？　",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "……いやいやいや。",
        "unit_id": 133212,
        "voice": "vo_adv_5160603_014"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "期待し過ぎてはいかん。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nネフィ＝ネラ殿がいかに気前が良くとも、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "所詮はお年玉。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nしばらくの間おやつが豪華になるだけでも、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "十分というものだろう。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "なに悩んでんの？　",
        "unit_id": 133612,
        "voice": "vo_adv_5160603_015"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "いらないならアタシが全部もらっちゃうわよ。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "こぉれメドゥーサや。",
        "unit_id": 129711,
        "voice": "vo_adv_5160603_016"
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "欲の皮を張るで無し。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\n汝の取り分は此方に候。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\n無駄遣いをしてはならぬぞえ。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ふーん、",
        "unit_id": 133612,
        "voice": "vo_adv_5160603_017"
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "なかなかキレイじゃない。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "ま、",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "メドゥーサ",
        "words": "一個でガマンしてあげる。",
        "unit_id": 133612
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あ、",
        "unit_id": 133212,
        "voice": "vo_adv_5160603_018"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あの、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ええと……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nネ、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ネフィ＝ネラ殿？　",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "こ、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "この金色の玉は……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "文字通り──",
        "unit_id": 129711,
        "voice": "vo_adv_5160603_019"
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "御年『玉』であり申す。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "ジオ・ゲヘナの地下より",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\n掘り出されたる鉱石を鋳溶かし、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "磨きに磨きを掛けた有様は正に珠玉。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "\n職人の技巧が光る黄金の輝き、",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "ネフィ＝ネラ",
        "words": "実に美事な仕事に御座候。",
        "unit_id": 129711
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "あ、",
        "unit_id": 133212,
        "voice": "vo_adv_5160603_020"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そ、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "そうか、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "お年玉、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "か。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なるほど……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n確かに玉というのは縁起物でもあるしー……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "ありがとうございます。",
        "unit_id": 133512,
        "voice": "vo_adv_5160603_021"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "これは……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "きれいですね……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n一点の曇りもないわ。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "な、",
        "unit_id": 133212,
        "voice": "vo_adv_5160603_022"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "なあサレン。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nこの玉って……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "もしかして、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "すごく高価な物では……",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "……そうね……本物の金、",
        "unit_id": 133512,
        "voice": "vo_adv_5160603_023"
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "だと思うわ。",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "\n混ざりもののない、",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "サレン",
        "words": "純度の高い金ね……",
        "unit_id": 133512
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "ひえぇ……",
        "unit_id": 133212,
        "voice": "vo_adv_5160603_024"
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\nランドソルでなら、",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "いくらになることか。",
        "unit_id": 133212
    },
    {
        "type": "dialogue",
        "name": "モニカ",
        "words": "\n……",
        "unit_id": 133212
    },
    {
