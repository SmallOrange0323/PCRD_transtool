[
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "大家",
        "unit_id": 102811,
        "voice": "vo_adv_0000420_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "都還活著吧！？",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "咲戀小姐！",
        "unit_id": 105911,
        "voice": "vo_adv_0000420_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您也安然無恙呢……！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "勉勉強強吧！",
        "unit_id": 102811,
        "voice": "vo_adv_0000420_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，有一群強大的魔物",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "正朝著蘭德索爾前進――",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不久前我從秋乃那收到了這樣的聯絡。",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "咿――！",
        "unit_id": 103211,
        "voice": "vo_adv_0000420_003"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n怎麼回事呀怎麼回事呀，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "為什麼從被我們破壞的",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n魔像裡頭，",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "會冒出如此多的魔物啊！？",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "秋乃，",
        "unit_id": 101011,
        "voice": "vo_adv_0000420_004"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "能否稍微靜一靜呢？",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n妳會害霞",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "和我的通訊魔法",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "受到干擾的唷。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "我們正在聯絡",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可能會願意來幫忙的人。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我是",
        "unit_id": 105311,
        "voice": "vo_adv_0000420_005"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "【純白之翼 蘭德索爾分部】的",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n莫妮卡‧拜斯溫特！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n在首都郊外",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "也已經確認到出現了相同的魔物！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "只要能打倒那些魔物的話，",
        "unit_id": 105811,
        "voice": "vo_adv_0000420_006"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n牠們就沒辦法把魔力送給霸瞳皇帝，",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "結界的力量應該也會變弱才對！",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "妾身們也被那狐狸精",
        "unit_id": 104411,
        "voice": "vo_adv_0000420_007"
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "擺過一道呢。",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "\n",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "若能打她個出其不意的話，",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "伊莉亞",
        "words": "沒什麼比這更令人愉快的了！",
        "unit_id": 104411
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "……哼。",
        "unit_id": 106915,
        "voice": "vo_adv_0000420_008"
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "無謂的掙扎。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n那些魔物是用凝聚的魔力所做出來的傀儡唷。",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "\n就算被打倒了，",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "霸瞳皇帝",
        "words": "也能夠立刻復活！",
        "unit_id": 106915
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那麼，",
        "unit_id": 100511,
        "voice": "vo_adv_0000420_009"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不斷地把牠們揍飛，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n揍到牠們被完全殲滅就可以了！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "讓妳看看我們的厲害～！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "莉瑪",
        "words": "嚐嚐我的毛茸茸攻擊♪",
        "unit_id": 105211,
        "voice": "vo_adv_0000420_010"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "絕不會讓妳",
        "unit_id": 104811,
        "voice": "vo_adv_0000420_011"
    },
    {
        "type": "dialogue",
        "name": "美冬",
        "words": "再繼續攻擊蘭德索爾了！",
        "unit_id": 104811
    },
    {
        "type": "dialogue",
        "name": "珠希",
        "words": "我要在這裡阻止妳喵！",
        "unit_id": 104611,
        "voice": "vo_adv_0000420_012"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拜託了，",
        "unit_id": 105911,
        "voice": "vo_adv_0000420_013"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "各位！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這當然！",
        "unit_id": 102811,
        "voice": "vo_adv_0000420_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n畢竟那裡",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有著我們必須回去的家啊！",
        "unit_id": 102811
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "喔～呵呵呵，",
        "unit_id": 103211,
        "voice": "vo_adv_0000420_015"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就包在我們的身上吧♪",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 103211
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "要上了唷～！",
        "unit_id": 103211
    }
]