    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n各位──！！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喂，你們幾個！",
        "unit_id": 106012,
        "voice": "vo_adv_2201002_079"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n現在可不是悠哉吃章魚燒的時候了啦──！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "咦？",
        "unit_id": 125812,
        "voice": "vo_adv_2201002_080"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n凱留小姐，",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "還有貪吃佩可小姐？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "各位怎麼那麼慌張？",
        "unit_id": 126012,
        "voice": "vo_adv_2201002_081"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是發生什麼事了嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "關於這點！",
        "unit_id": 105812,
        "voice": "vo_adv_2201002_082"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n是因為我說服失敗了……！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "遠處傳來的聲音",
        "words": "陛下───！",
        "unit_id": 1,
        "voice": "vo_adv_2201002_083"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦？",
        "unit_id": 126012,
        "voice": "vo_adv_2201002_084"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n好像有人在叫妳……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們就是要逃離那傢伙啦！",
        "unit_id": 106012,
        "voice": "vo_adv_2201002_085"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，你們也快點跑起來！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "普蕾西亞",
        "words": "瞭。",
        "unit_id": 126112,
        "voice": "vo_adv_2201002_086"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "難道說，",
        "unit_id": 125812,
        "voice": "vo_adv_2201002_087"
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "是因為貪吃佩可小姐",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "莉莉",
        "words": "\n要處理政務，所以沒有空嗎……！？",
        "unit_id": 125812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不，",
        "unit_id": 105812,
        "voice": "vo_adv_2201002_088"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "那方面完全沒有問題！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "不過，我只是說我要暫時離開城鎮，",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n行政長官就說她也要同行，勸都勸不聽！",
        "unit_id": 105812
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦……！？",
        "unit_id": 126012,
        "voice": "vo_adv_2201002_089"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那傢伙雖然是個笨蛋，",
        "unit_id": 106012,
        "voice": "vo_adv_2201002_090"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但卻超有行動力，所以很難應付呢……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒辦法了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你們聽好，拎上可蘿仔後就直接出發囉！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "可璃亞、莉莉",
        "words": "咦咦咦……！？",
        "unit_id": 1,
        "voice": "vo_adv_2201002_091"
    }
]