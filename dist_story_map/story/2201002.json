        "type": "dialogue",
        "name": "凱留",
        "words": "她搞不好會說「我也要跟隨陛下～！」",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就跟著過來了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "啊哈哈……",
