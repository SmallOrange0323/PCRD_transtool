        "voice": "vo_adv_2201002_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "特別是那個狸貓眼鏡。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n要是妳明說自己要去冒險，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
