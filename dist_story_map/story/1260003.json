    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "結束打工的可璃亞和{player}，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n為了在回去吉歐‧提格尼亞前買好伴手禮，而來到了鬧區。"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵♪",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_000"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n這個飾品",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "一定很適合普蕾西亞！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這邊的髮飾",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "莉莉戴起來應該會很好看……♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "還有請哥哥給我建議，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_001"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "挑選好要給【美食殿堂】成員的伴手禮，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n如果大家喜歡的話就太好了♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "因為都是吃的，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "所以肯定會馬上被吃光光吧……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "好～了，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_002"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "其他還有什麼要買的──",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……啊，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_003"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥你看！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n這個貓咪的布偶，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n不覺得長得很像之前那隻貓咪嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵呵，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_004"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "真可愛呢。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_005"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "犒賞自己嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n你說我買的都是要送給別人的伴手禮……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是嗎？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呵呵，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥觀察得很仔細呢♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "可是，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_006"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我還想買伴手禮給吉歐‧提格尼亞的大家，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n所以自己的份",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就先忍忍吧♪",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_007"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "才沒有那回事──",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……我",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_008"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "又不小心在哥哥面前",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n裝作一副乖寶寶的樣子了。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……呼，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_009"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我決定了……！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_010"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "從現在起，直到回去吉歐‧提格尼亞為止，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n都不當好孩子了！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "沒錯，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_011"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我要當個普通的女孩子！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不管發生什麼事，我都──",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "嘿……",
        "unit_id": 611,
        "voice": "vo_adv_1260003_012"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "咻……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "呼，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "好重啊……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……！？",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_013"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那、",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_014"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "那位老婆婆背著好大的包袱……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "呼……",
        "unit_id": 611,
        "voice": "vo_adv_1260003_015"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "呼……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "嘿……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "咻……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_016"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "嘿……",
        "unit_id": 611,
        "voice": "vo_adv_1260003_017"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "咻……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "唷……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不對，這跟裝好孩子什麼的無關，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_018"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n根本就只是個討厭的人……！！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "老婆婆～！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我來幫妳～！！",
        "unit_id": 126012
    },
    {
        "type": "background",
        "background": "501580"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "呼……",
        "unit_id": 611,
        "voice": "vo_adv_1260003_019"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "幫了我一個大忙呢。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "真的很謝謝",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "你們兩個。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "對了，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "給你們我田裡採收的蔬菜當作謝禮吧……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不不不，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_020"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不必費心了。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……奇怪，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "老婆婆妳怎麼了？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n臉色突然沉下來……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "哎呀，",
        "unit_id": 611,
        "voice": "vo_adv_1260003_021"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "真糟糕，上了年紀就會變得健忘起來……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n我現在沒有可以分給你們的蔬菜了。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "……我就是因為這樣，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "才會到城裡買這個的。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_022"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "妳說這個包袱嗎。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n裡面裝的是……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呃～這是",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "什麼啊？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哦，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_023"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "原來是這樣啊。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……也就是說，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "老婆婆的田地",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "遭到害獸破壞了……？",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "啊啊，",
        "unit_id": 611,
        "voice": "vo_adv_1260003_024"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "是啊。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "好不容易用心種出來的蔬菜全被毀了……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "可是，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我沒有力氣去驅趕害獸……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "所以我才買了這個陷阱，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "但或許只是圖個心安而已。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "對了，",
        "unit_id": 611,
        "voice": "vo_adv_1260003_025"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我手邊還有剩下一些受損的蔬菜。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "請看這個……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "真是可恨的害獸。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……！",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_026"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "竟然留下了這麼大的齒痕和爪痕……！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這個該不會",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不是害獸，而是……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "果然……",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_027"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "什麼……",
        "unit_id": 611,
        "voice": "vo_adv_1260003_028"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "你說魔物！？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "等一下，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "對象是魔物的話，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "那這個陷阱",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n能起得了作用嗎……？",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這個……",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_029"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "可能有點困難呢。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "去向公會管理協會",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n提出討伐委託或許會比較好。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "原來如此……",
        "unit_id": 611,
        "voice": "vo_adv_1260003_030"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "請實力高強的冒險者來處理啊……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "可是，我的手頭並不寬裕，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n實在拿不出",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "付給冒險者的報酬……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……！",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_031"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就、",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_032"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "就是說呢。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我們都已經幫一半了……！",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "老婆婆，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這件事情就交給我們處理吧。",
        "unit_id": 126012
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這裡就是老婆婆的田地是吧。",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_033"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我們先躲在岩石後面",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "稍微觀察一下情況吧。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "…………",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_034"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……果然。",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_035"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n哥哥",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "很厲害呢。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_036"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "自從和哥哥來到蘭德索爾之後，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n就更加深了這個想法。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "不管是打工的時候、",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_037"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "還是遇見棄貓的時候、",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "甚至現在也是。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n碰上事情的時候，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n哥哥總是會毫不猶豫地選擇幫助他人。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對於擔心別人眼光的我來說，",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_038"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n哥哥的存在十分耀眼……",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "而我……",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_039"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對那樣子的哥哥──",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "！！",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_040"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是魔物！",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "出現了呢……！！",
        "unit_id": 126013
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "唔唔！？",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_041"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "好強大的力量……！",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_042"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這隻魔物",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "似乎比想像中還要強非常多……！",
        "unit_id": 126013
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥！！",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_043"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n別一個人逞強！",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這隻魔物果然",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_044"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "非常強……！",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "輕而易舉就躲開了哥哥的劍，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "而且攻擊也很強烈……！　",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥漸漸地被壓制了……",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_045"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n這樣下去的話……！　",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……由我來",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_046"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n幫助哥哥",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……！！",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……對不起，",
        "unit_id": 126011,
        "voice": "vo_adv_1260003_047"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "魔物先生。",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n你會這麼做",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "可能也有你的理由，",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "但是──",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "要是你打算破壞老婆婆的田地、",
        "unit_id": 126011,
        "voice": "vo_adv_1260003_048"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n傷害我最重要的哥哥，",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n那麼我即使變成壞孩子，",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "也要阻止你搗亂……！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥……！",
        "unit_id": 126011,
        "voice": "vo_adv_1260003_049"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n把強化之力用在我身上！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……！",
        "unit_id": 126011,
        "voice": "vo_adv_1260003_050"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "謝謝你，",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n那麼──",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我要上了！",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "喝啊──！！",
        "unit_id": 126011,
        "voice": "vo_adv_1260003_051"
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "魔物",
        "words": "──嘎喔喔喔喔喔！",
        "unit_id": 1611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呼……",
        "unit_id": 126011,
        "voice": "vo_adv_1260003_052"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "呼……",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "打倒魔物了。",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥，",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "謝謝你的幫助。",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……",
        "unit_id": 126011,
        "voice": "vo_adv_1260003_053"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "這下就能放心了。",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n老婆婆一定也會很開心──",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "噫……",
        "unit_id": 611,
        "voice": "vo_adv_1260003_054"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "噫噫噫！！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "老婆婆！？",
        "unit_id": 126011,
        "voice": "vo_adv_1260003_055"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n妳怎麼會在這裡……",
        "unit_id": 126011
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我……",
        "unit_id": 611,
        "voice": "vo_adv_1260003_056"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我因為擔心所以才跑來阻止你們……！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n想要跟你們說我會準備好酬勞，去委託公會管理協會處理。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "不，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "那些事現在都不重要！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "妳那個模樣……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "我就算想忘也忘不掉……！",
        "unit_id": 611,
        "voice": "vo_adv_1260003_057"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "妳是當時，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "把城鎮搞得天翻地覆的──",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "惡魔……",
        "unit_id": 611,
        "voice": "vo_adv_1260003_058"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "──！",
        "unit_id": 126011,
        "voice": "vo_adv_1260003_059"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥……",
        "unit_id": 126011,
        "voice": "vo_adv_1260003_060"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "……說起來我住在城鎮的朋友，",
        "unit_id": 611,
        "voice": "vo_adv_1260003_061"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n說你們或許",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "不是什麼壞人……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "雖然他們這樣講，",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "但你們是騙不了我的……！",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……老婆婆。",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_062"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對不起嚇到妳了。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n我這就離開，",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "還請妳原諒。",
        "unit_id": 126013
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "再見……！",
        "unit_id": 126013,
        "voice": "vo_adv_1260003_063"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "……怎、",
        "unit_id": 611,
        "voice": "vo_adv_1260003_064"
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "怎麼回事。",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "\n態度這麼溫順……",
        "unit_id": 611
    },
    {
        "type": "dialogue",
        "name": "奶奶",
        "words": "……",
        "unit_id": 611,
        "voice": "vo_adv_1260003_065"
    },
