        "voice": "vo_adv_1260003_067"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "…………",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_068"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我在！！？",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_069"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n……啊，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥，不好意思。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "對不起，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_070"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我只是稍微……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n有點沮喪。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我想幫助別人……",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_071"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "想幫上老婆婆的忙，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "結果",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "卻反而嚇到人家了……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "因為我的關係，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_072"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "老婆婆……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "嗚嗚……",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_073"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "咦……？",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_074"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……啊。",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_075"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "是啊……",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_076"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "說",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "的沒錯。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "啊啊，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥果然很厲害呢。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……我終於明白了。",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_077"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥幫助別人的時候，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n肯定不是想藉由做好事得到誇獎",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "才那麼做的。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "因為心裡沒有那種盤算，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_078"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "所以哥哥總是能夠當機立斷，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n為了別人挺身而出……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "一定是這樣沒錯。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "──擁有堅強的內心，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_079"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "而不會動搖。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "正因為哥哥是這樣的人，",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n大家才會自然而然地被你給吸引。",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "莉莉、",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_080"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "【美食殿堂】的大家……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……還有……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "我也……",
        "unit_id": 126012
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "……謝謝你，",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_081"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哥哥！",
        "unit_id": 126012
    },
