    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "哇啊……",
        "unit_id": 126012,
        "voice": "vo_adv_1260003_084"
    },
    {
        "type": "dialogue",
        "name": "可璃亞",
        "words": "\n你是什麼時候跑去買的？",
