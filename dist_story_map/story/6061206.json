    {
        "type": "dialogue",
        "name": "真步",
        "words": "魔物的公主……",
        "unit_id": 116011,
        "voice": "vo_adv_6061206_000"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "同樣身為公主，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "卻跟人家完全不一樣。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "原來也有那樣的公主啊。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "……難不成王子先生",
        "unit_id": 116011,
        "voice": "vo_adv_6061206_001"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "喜歡那種類型的公主？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "若是這樣，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家也要跟香織學空手道……",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "您只是說說自己看到的感想？",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "真是太好了～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "一定沒問題的。",
        "unit_id": 116011,
        "voice": "vo_adv_6061206_002"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "所謂的羈絆，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n無論經過多少歲月",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "都不會毀壞喔。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "沒錯，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "如果擁有人家跟王子先生這樣的羈絆，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就什～麼都不用擔心了。",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這是個好點子呢～♪",
        "unit_id": 116011,
        "voice": "vo_adv_6061206_003"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "魔物的公主",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "雖然既強悍又是個美人，",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n卻少了點",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "身為公主所需的",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "可愛度～",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "讓人家會好～好地",
        "unit_id": 116011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "指導她變得真步真步的喔～♪",
        "unit_id": 116011
    }
]