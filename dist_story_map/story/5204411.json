        "voice": "vo_adv_5204411_000"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "開心的冒險也結束了啊。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "欸，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "露易！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "彩羽還想要冒險！",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n畢竟年輕的奶奶也很有趣，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "對吧♪",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "才不有趣。",
        "unit_id": 132312,
        "voice": "vo_adv_5204411_001"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n到底是有多悲情，",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n居然得跟自己的親祖母爭奪達令啊……",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "……不過，",
        "unit_id": 132412,
        "voice": "vo_adv_5204411_002"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n祖母竟然",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "也有那樣的黑歷史時代，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n讓我有點吃驚。",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "……不過",
        "unit_id": 132512,
        "voice": "vo_adv_5204411_003"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "老實說，跟露易一模一樣就是了。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "啊！？",
        "unit_id": 132312,
        "voice": "vo_adv_5204411_004"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "\n哪裡像啊！？",
        "unit_id": 132312
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "這個嘛──！",
        "unit_id": 132412,
        "voice": "vo_adv_5204411_005"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "很毒舌、",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "會說自己是天才、",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "一下子就會得意忘形、",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "悶騷、",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "好騙、",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "愛生氣、",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "被盯著看就會害羞的地方，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "也都跟露易一模一樣♪",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "這幾乎都是壞話吧！？",
        "unit_id": 132312,
        "voice": "vo_adv_5204411_006"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "啊哈哈！",
        "unit_id": 132412,
        "voice": "vo_adv_5204411_007"
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "\n",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "不過呢不過呢，",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "最像的部分是～",
        "unit_id": 132412
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "哦，",
        "unit_id": 132512,
        "voice": "vo_adv_5204411_008"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "是先讓人失落，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "最後再吹捧的說話技巧啊。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "\n挺行的嘛，彩羽。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "好，",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "妳說吧。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "彩羽",
        "words": "角很帥的部分♪",
        "unit_id": 132412,
        "voice": "vo_adv_5204411_009"
    },
    {
        "type": "dialogue",
        "name": "露易絲瑪莉",
        "words": "我開心不起來！！",
        "unit_id": 132312,
        "voice": "vo_adv_5204411_010"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "呵呵，",
        "unit_id": 132512,
        "voice": "vo_adv_5204411_011"
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "有種「回歸日常了呢」",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
        "name": "苑",
        "words": "的感覺。",
        "unit_id": 132512
    },
    {
        "type": "dialogue",
