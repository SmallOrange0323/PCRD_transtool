    {
        "type": "dialogue",
        "name": "旁白",
        "words": "當某位少女正獨自一人走在街道上時。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊……",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_000"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我命中注定的人……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您現在在哪裡做些什麼呢？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "好想早點與您相見……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嘻嘻。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "占卜師",
        "words": "那個……",
        "unit_id": 103111,
        "voice": "vo_adv_1027001_001"
    },
    {
        "type": "dialogue",
        "name": "占卜師",
        "words": "那邊那位小姐……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "占卜師",
        "words": "\n妳要占卜一下嗎？",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "占卜……？",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_002"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然我有興趣，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但是我現在身上沒有錢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "占卜師",
        "words": "不用錢的。",
        "unit_id": 103111,
        "voice": "vo_adv_1027001_003"
    },
    {
        "type": "dialogue",
        "name": "占卜師",
        "words": "\n",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "占卜師",
        "words": "我父親堅持說想要幫妳占卜，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "占卜師",
        "words": "請務必試看看。",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "你的……",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_004"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "爸爸？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就是我！",
        "unit_id": 103111,
        "voice": "vo_adv_1027001_005"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n我想要幫小姐妳占卜一下！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我看看……",
        "unit_id": 103111,
        "voice": "vo_adv_1027001_006"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "原來是這樣，",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "我知道了！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n小姐妳今天會遇上",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "命中注定的對象！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "命中注定的對象……！？",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_007"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嘻嘻……",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_008"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "是這樣嗎，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "終於。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "終於……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "能夠相見了呢……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "沒錯，",
        "unit_id": 103111,
        "voice": "vo_adv_1027001_009"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "那位命中注定的對象……",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "就是我了！",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n可以的話，接下來跟我去喝杯茶——",
        "unit_id": 103111
    },
    {
        "type": "dialogue",
        "name": "占卜師",
        "words": "爸爸……",
        "unit_id": 103111,
        "voice": "vo_adv_1027001_010"
    },
    {
        "type": "dialogue",
        "name": "占卜師",
        "words": "她已經走了唷。",
        "unit_id": 103111
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "{player}發現一位昏倒在路邊的女孩。"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚…………",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_011"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗚、",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_012"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "嗯……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我、",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我居然……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "……哎呀，",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_013"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您是？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我剛剛是不是昏倒了……？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "在那邊昏倒了……？",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_014"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "剛才在照顧我嗎？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "謝謝您。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "為什麼",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_015"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我會昏倒了呢？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這麼說來……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "我",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "把藥……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "生病？",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_016"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "啊，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您以為我本身患了病，",
        "unit_id": 102711
