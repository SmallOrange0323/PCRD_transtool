    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為藥吃完所以昏倒了？",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "要解釋也麻煩……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "您就當是這樣吧。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "雖然話是這麼說，",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_017"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "但我也太大意了。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "竟然不小心",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "聞到自己製作的毒藥……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因為瘴氣太強而昏倒了呢。",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "因自己興趣製作的毒藥",
        "unit_id": 102711,
        "voice": "vo_adv_1027001_018"
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "而昏倒，",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "這還是第一次……",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "\n",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "今天真是",
        "unit_id": 102711
    },
    {
        "type": "dialogue",
        "name": "？？？",
        "words": "奇怪的一天呢。",
        "unit_id": 102711
    },
