[
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105911,
        "voice": "vo_adv_2002003_000"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "請躲到這裡來！",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在戰鬥已經開始的現在，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n我們實在是幫不上什麼太大的忙。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊啊，怎麼會發生這種事情……？",
        "unit_id": 105911,
        "voice": "vo_adv_2002003_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您、",
        "unit_id": 105911,
        "voice": "vo_adv_2002003_002"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您有什麼根據……",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "唔唔。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人您，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "有些時候真的樂觀過頭了。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雖然，",
        "unit_id": 105911,
        "voice": "vo_adv_2002003_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這一點也有值得信賴的地方。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "不過說實話，",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下不覺得現在的狀況可以樂觀以對了。",
        "unit_id": 105911
    },
    {
        "type": "still",
        "still": "200200301"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "多讓我享受一點吧！",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_004"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "給我在生死之間刀劍交鋒的快感，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n以及活著的真實感吧！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "如果讓我失望的話，",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_005"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n那只能用你們的鮮血來滿足我了！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "來吧，要是有密技或必殺技的話，快使出來吧！",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_006"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可惡……得意忘形了，這傢伙！",
        "unit_id": 104311,
        "voice": "vo_adv_2002003_007"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n半開玩笑的到處侵犯別人的地盤，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不要給我太囂張啊！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴，不可以一個人衝上去啦～",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_008"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "我來擾亂速度，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n真琴趁機使出致命一擊……",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "哎呀呀？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "喂、喂……",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_009"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "把作戰通通說出來，我也不會誇獎妳們的哦。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我聽說【哞哞自衛隊】是【動物苑】裡面的",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_010"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n武鬥派公會，所以很期待呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊，真失望",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "沒有互相合作，也不熟練更沒有戰鬥意志！",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_011"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "只會村民百姓之間的吵架嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "這樣可是贏不了真正的騎士和軍人的！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500060"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "喔～？",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_012"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n我都跟真琴聯手了，卻還是這麼劣勢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "（總覺得怪怪的～",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_013"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這個人明明看起來沒有用眼睛盯著我的動作，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但拳頭和飛踢卻好像被她很巧妙地避開了，都打不到耶？）",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "（她的攻擊也很不自然～",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_014"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n在室內用那麼大把的劍應該很礙手礙腳才對，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但她胡亂揮出的一擊卻能準確地打到我跟真琴。）",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "（我們完全無法攻擊到對方，",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_015"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但對方過來的攻擊卻百發百中。",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這種感覺好像被物理法則決定了一樣～？）",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "（這一點都不合理～感覺有些圈套……",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_016"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "但現在實在沒有餘力可以確認～）",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "真琴！",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_017"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "這個奇襲讓我們的架勢整個都亂了，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n應該先放棄公會小屋暫時撤退才是～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n就由我們兩個來拚命確保真步他們的退路吧～！",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊？",
        "unit_id": 104311,
        "voice": "vo_adv_2002003_018"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n難道妳想夾著尾巴逃跑嗎，人家都到門前大鬧特鬧了！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n我可無法忍受被這樣小看，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "至少也要揍他們一拳……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "如果是一對一的話還好……",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_019"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但因為是公會之間的鬥爭，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n在掉入陷阱的那一刻起，就是我們輸了呢～",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "接著應該把傷害降到最低，撤退比較好吧～？",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_020"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "哎呀？",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_021"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "看來妳和外表相反，還算有點腦袋呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "不過很可惜，我是不會讓妳逃走的！",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_022"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "因為妳可是我期待已久才拿到的玩具呢……☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "呃！？",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_023"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "好危險！為什麼這樣的距離和姿勢會受到攻擊呢～？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "（嗯～果然敵人的攻擊就一定會打中～",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_024"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n好奇怪啊～）",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "（因為我都習慣活用輕盈的身體，",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_025"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n一邊躲開一邊毆打敵人的關係嗎……？",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "一直防禦實在有點不習慣呢～）",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "（我是徒手空拳，對方拿著大劍……",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_026"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n現在勉強還能回擊或防禦，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n但這樣下去恐怕會被幹掉呀？）",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "（忍耐也有個限度，會撐不下去的呀～",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_027"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "可惡啊～爺爺和奶奶傳授給我的空手道明明就是最強的！）",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "（不過……",
        "unit_id": 101711,
        "voice": "vo_adv_2002003_028"
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n不搞清楚敵人奇妙的攻擊和防禦策略的話，",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "香織",
        "words": "\n可是會越來越糟呢～）",
        "unit_id": 101711
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "香織，閃開！",
        "unit_id": 104311,
        "voice": "vo_adv_2002003_029"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n不管怎麼說，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n那傢伙也是無法同時攻擊和防禦的！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "我就持續猛烈地攻擊，",
        "unit_id": 104311,
        "voice": "vo_adv_2002003_030"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n藉此阻止那傢伙的攻勢！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n喝啊啊啊……！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "公主則為我和香織施展強化及回復魔法！",
        "unit_id": 104311,
        "voice": "vo_adv_2002003_031"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n若還有餘力的話，",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n就將那些圍住公會之家的傢伙都趕走，以確保退路！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "啊，嗯！",
        "unit_id": 101011,
        "voice": "vo_adv_2002003_032"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "了解。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "大鬧一場果然還是真琴最在行了♪",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家果真還是太嫩了。",
        "unit_id": 101011,
        "voice": "vo_adv_2002003_033"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n看來還是不擅長和別人吵架呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "不過現在不是說這些喪氣話的時候……",
        "unit_id": 101011,
        "voice": "vo_adv_2002003_034"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生，你們請躲在人家的後面。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "唔唔，",
        "unit_id": 101011,
        "voice": "vo_adv_2002003_035"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在沒有空來慢慢說明了。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n聽話，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "現在先相信人家，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "照人家說的去做。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "拜託您了，",
        "unit_id": 101011,
        "voice": "vo_adv_2002003_036"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "王子先生。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "看見自己的地盤",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "被如此糟蹋，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n人家也不打算",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "坐以待斃。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "至少要，",
        "unit_id": 101011,
        "voice": "vo_adv_2002003_037"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "全力的抵抗呢。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n既然身為【哞哞自衛隊】的公會長的話。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "嗯。",
        "unit_id": 101011,
        "voice": "vo_adv_2002003_038"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n這樣的話……",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "就用王子先生的力量，",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n來強化人家吧。",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "人家要同時展開魔法。",
        "unit_id": 101011,
        "voice": "vo_adv_2002003_039"
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "\n",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "真步",
        "words": "這時候會毫無防禦力，請保護人家唷～",
        "unit_id": 101011
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "啊哈哈☆ 這些傢伙",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_040"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n雖然看起來都沒在思考，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但看來對戰鬥的敏銳度是一流的呢！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "太有趣了，這就是獸人啊！",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_041"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "兼具了野獸的本能和強度，以及人類的知性和柔軟！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "真開心呢，不論何時和未知的強敵戰鬥真是讓人興奮！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "太雀躍了，戰鬥就得要這樣才行啊！",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_042"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n讓我更加樂在其中吧，來吧……☆",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "我覺得簡單結束的話太可惜了，",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_043"
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n所以一直手下留情……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "但看來是不用客氣了。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "克莉絲提娜",
        "words": "讓我也稍微使出真本事吧！",
        "unit_id": 107111,
        "voice": "vo_adv_2002003_044"
    },
