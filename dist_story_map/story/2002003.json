    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "可惡，這可不是人類的力氣呢！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n只是受了這傢伙的一擊，就覺得有點站不穩了！？",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "啊哈哈，我也開始樂在其中了！",
        "unit_id": 104311,
        "voice": "vo_adv_2002003_046"
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "香織，這傢伙的大劍由我來擋！",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "\n",
        "unit_id": 104311
    },
    {
        "type": "dialogue",
        "name": "真琴",
        "words": "妳就活用妳的長處，四處移動並持續進攻吧！",
        "unit_id": 104311
    },
