[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "解決了走失的問題，\n咲戀與{player}在海灘上放鬆。"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好了，",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_000"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要做些什麼呢……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不好不好。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "把重要的事情給忘了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我記得包包裡……",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_001"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個這個。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很在意這個小瓶子嗎？",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_002"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這個",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "叫做『防曬油』，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是有防曬效果的乳液。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n不過還是試作品。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "之前鈴莓",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_003"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "在海之家打工時，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "有說過曬傷的肌膚刺刺的很痛",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對吧？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我一直有在想。",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_004"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果有比市面上的防曬用品",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n效果更好的東西就好了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因此，",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_005"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我便到處尋找能夠預防曬傷的藥草，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n經過調合的結果",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是這個了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "難得來到海邊了，",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_006"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "得試試看才行呢。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果能證實效果，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "這也能是",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "一筆不錯的生意吧？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是這麼回事，",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_007"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "首先從手開始……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "比想像中",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "更冰涼呢。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是因為藥草的成分吧。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "全身也都要塗到……",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_008"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺不錯。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "再來是――",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "吶，{player}。",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_009"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你可以",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "用這防曬油",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "幫我塗背後嗎？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝。",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_010"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "麻煩你了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嘿咻……",
        "unit_id": 110311
    },
    {
        "type": "still",
        "still": "110300201"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我想你應該知道，",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_011"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "如果敢碰奇怪的地方，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我可不會輕易放過你喔？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我會不會太信任他了？",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_012"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要這人潮混雜之中",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "尋找鈴莓",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "也很不容易。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "而且，",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_013"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}這傢伙也不可能會做出奇怪的舉動吧。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "……啊啊，",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_014"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "是這樣啊。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對{player}",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感到放心啊……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "嗯……！　",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_015"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊、",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "對不起，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我只是覺得很癢。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n對對，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "就是這個感覺，麻煩你了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "要避免有地方漏掉，",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_016"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "每個地方都要塗到喔……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呵呵。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "感覺就好像",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "變成女王了呢。",
        "unit_id": 110311
    },
    {
        "type": "still",
        "still": "110300202"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呀！？\n喂、",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_017"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "喂！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "誰說你可以把",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n手伸到泳裝底下的啊！？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？　",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_018"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "因為那是沒塗到的地方？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那麼說是沒錯……",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_019"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呀！？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真、",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "害人家發出怪聲音了啦！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "把手指伸進女孩子的泳裝是怎麼一回事，",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_020"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n你好歹也注意一下吧？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "呀啊啊！？",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_021"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "笨、",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "笨蛋，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你又伸進來了啦！？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "咦？　",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_022"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "剛才只是手指滑掉了？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "真是的，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "很容易讓人誤會耶！",
        "unit_id": 110311
    },
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "still",
        "still": "end"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "唉。",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_023"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "為什麼在開始玩之前我就得這麼累啊……",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "不過",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你確實",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "好像沒有地方漏塗，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "謝謝。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那就",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_024"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "作為嘗試，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "到那附近散步",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "做日光浴吧！",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "{player}就慢慢享受……",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_025"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "欸，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "什麼？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n難道",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你打算跟過來嗎？",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "你說擔心我……",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_026"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "啊哈哈，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "我又不是小孩子，",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "才不會走丟啦。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "\n",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "那我先走了。",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "接下來，",
        "unit_id": 110311,
        "voice": "vo_adv_1103002_027"
    },
    {
        "type": "dialogue",
        "name": "咲戀",
        "words": "哪裡有可以悠閒度過的地方――",
        "unit_id": 110311
    },
    {
        "type": "dialogue",
        "name": "鬧事者",
        "words": "喔！　",
        "unit_id": 911,
        "voice": "vo_adv_1103002_028"
    },
    {
