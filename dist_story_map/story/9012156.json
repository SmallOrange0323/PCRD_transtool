[
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "聽好了，",
        "unit_id": 106011,
        "voice": "vo_adv_9012156_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "下次再搗亂就把你燒成焦炭！",
        "unit_id": 106011
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看來牠已經深刻反省了，",
        "unit_id": 105911,
        "voice": "vo_adv_9012156_001"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n懂得給予原諒也是非常重要的。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n畢竟在殘酷的沙漠裡生活，想必也很艱困。",
        "unit_id": 105911
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "會肚子餓也是人之常情，",
        "unit_id": 105811,
        "voice": "vo_adv_9012156_002"
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n但不可以搶別人的東西喔。",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "\n",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "貪吃佩可",
        "words": "記住了嗎？",
        "unit_id": 105811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "妳這張嘴，",
        "unit_id": 106011,
        "voice": "vo_adv_9012156_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "昨天才把我的點心全部吃光，還真敢說……",
        "unit_id": 106011
    }
]