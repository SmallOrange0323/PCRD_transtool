[
    {
        "type": "background",
        "background": "500960"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "露娜之塔？",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_000"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_001"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我太驚訝了，同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n真沒想到會從你口中聽到那個名字。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "看來身為「優妮博士」的共同研究者，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_002"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你似乎開始多少有學習考古的意願了啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n值得讚賞，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我就摸摸你的頭吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_003"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學弟很抱歉。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我實在不忍摘除你那才剛萌芽的向學心，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n但就算是我，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在這世上也有一兩件無法教你的事情。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "比如說，露娜之塔──",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_004"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這就是其中之一。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "學會也只是對其進行了諸多推論，但研究卻毫無進展。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在文獻上也只能看到名字，那可是座謎團重重的",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "夢幻遺跡。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "……咦？",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_005"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "真的？",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_006"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦啊啊啊啊！",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_007"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我也要我也要！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我也想去那裡！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哦，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_008"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "請你別說什麼繭居族辦不到這種不識趣的話啊，同志。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "太古的浪漫在呼喚我。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n若是那裡有學問，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那我就會闔上書本，開起門扉喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "夢幻遺跡、",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_009"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "未知的怪異",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "和稀有的研究素材……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n啊啊，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "想必這會是一趟滿足我學術方面好奇心的探索之旅吧！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼同志，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "帶我一起去吧！",
        "unit_id": 111011
    },
    {
        "type": "background",
        "background": "500420"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喂，同志……",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_010"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你為什麼要帶我一起來……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "喝……",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_011"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "呼……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我沒聽說竟然會是這種森林深處……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n我可是個徹頭徹尾的繭居族耶……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你這傢伙是想殺了我嗎……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_012"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我那時候",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "或許的確是受到學術方面的興奮影響，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n而多少變得比較亢奮才開口說了大話，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但那當然只是一時的心血來潮，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你要阻止我啊。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哇～到終點了～",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_013"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是喔，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_014"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n那我們回去吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你那什麼反應。",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_015"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你別歪著頭一副想說",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n「這傢伙到底在說什麼？」的態度。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，我說的是理所當然的吧。",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_016"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n來到這裡的路程，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就已經耗費了我們大半的體力。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "在這種下進入聚集了大量魔物的魔物巢穴，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "根本等於是自殺行為。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_017"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我先說清楚了，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這可不是我幼稚的任性喔。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "{player}這是考量到你的安全後，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所做出的艱難決定。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可惡，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_018"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好不容易都來到這裡了……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "但是，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我不能讓可愛的學弟暴露在危險之中……！",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "哼，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_019"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這我都知道。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n你只是一心想著不希望給學姐添麻煩，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "所以在那虛張聲勢而已。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不不，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_020"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你不需要全都說出來。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我知道，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我都知道。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "我非常清楚你真正的想法。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "不不不，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_021"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "沒關係，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "你什麼都別再說了。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n全部都當作是優妮學姐的任性也無所謂，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n所以你不需要感到愧疚。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "好，就讓我們挺起胸膛，堂堂正正地回去吧。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "欸～",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_022"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "就這樣──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n為了可愛的學弟，",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "優妮學姐懷著遺憾踏上了歸途。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "可喜可賀可喜可──",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "不用擔心！",
        "unit_id": 104911,
        "voice": "vo_adv_7015000_023"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我來了！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "什麼？",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_024"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "弟弟，",
        "unit_id": 104911,
        "voice": "vo_adv_7015000_025"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你累了嗎？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n要不要我揹你？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "還是用抱的比較好？",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "可以為你做任何事喔！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "你要進入那座塔尋找記憶的線索對吧？",
        "unit_id": 104911,
        "voice": "vo_adv_7015000_026"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我也會和你一起進去，全部交給我吧！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "姐姐我會用姐姐力量進行姐姐突擊的！",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "那麼，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_027"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "依照慣例，她看起來應該是和你有關的人吧……",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "\n",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "她是誰呢？",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "這個突然出現還自己硬要貼過來的高個女。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我是{player}的姐姐！",
        "unit_id": 104911,
        "voice": "vo_adv_7015000_028"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "啊，",
        "unit_id": 111011,
        "voice": "vo_adv_7015000_029"
    },
    {
        "type": "dialogue",
        "name": "優妮",
        "words": "是。",
        "unit_id": 111011
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "妳是他學校的學姐對吧！",
        "unit_id": 104911,
        "voice": "vo_adv_7015000_030"
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "\n",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "沒有問題，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
        "name": "靜流",
        "words": "我有盡姐姐的義務，",
        "unit_id": 104911
    },
    {
        "type": "dialogue",
