[
    {
        "type": "background",
        "background": "500040"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生",
        "unit_id": 100111,
        "voice": "vo_adv_5084602_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還沒有醒來呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗚～～",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "好擔心哦……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "拿不出精神呀……",
        "unit_id": 100111,
        "voice": "vo_adv_5084602_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "是因為騎士先生過去一直都在身邊的關係嗎？",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n這種時候，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "要是騎士先生能露出笑容的話……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "唔～～",
        "unit_id": 100111,
        "voice": "vo_adv_5084602_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "但是、但是，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "如果我是這副模樣的話，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n反而會讓騎士先生擔心呢……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯，",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "決定了。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "為了讓騎士先生在醒來的時候",
        "unit_id": 100111,
        "voice": "vo_adv_5084602_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "能露出笑容……",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我得用充滿精神、",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "最燦爛的笑臉迎接騎士先生！",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "所以要趕快醒來哦，",
        "unit_id": 100111,
        "voice": "vo_adv_5084602_004"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "騎士先生。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我們再一起去冒險吧。",
        "unit_id": 100111
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我和大家會等著的。",
        "unit_id": 100111
    }
]