[
    {
        "type": "background",
        "background": "500540"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "怜為了前往祖父的技法書中記載的"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "古老流派修練場，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n與{player}一同向著與王都相隔遙遠的雪山而去。"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "根據技法書的記載，",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_000"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n這座山上應該有個修練場……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "但如此險要之地，",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_001"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我實在不認為古今以來",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "曾有人居住在這裡。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "你還好吧？",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_002"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "會不會覺得冷？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "姑且是有",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "施了點聊以慰藉的防寒魔法。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯，",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_003"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我也沒事。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n山間的天氣變化莫測，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們邊留意彼此的情況邊上山吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "嗯？",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_004"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "那是……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n人嗎……？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "你好。",
        "unit_id": 311,
        "voice": "vo_adv_1803003_005"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "請問你們今天",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是打算登山嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是的，",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_006"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們想去位於山頂的修練場。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "修練場……",
        "unit_id": 311,
        "voice": "vo_adv_1803003_007"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是嗎？",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我記得曾有傳說提到過那樣的場所。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但是，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "現在山頂上沒有任何人居住喔。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "怎麼會……",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_008"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是準確的情報嗎？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "是的。",
        "unit_id": 311,
        "voice": "vo_adv_1803003_009"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我就住在山腳下的村莊，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n以管理這座山為生，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n我已經確認過山頂確實沒人居住了。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那裡不是人人都能輕易往來的地方。",
        "unit_id": 311,
        "voice": "vo_adv_1803003_010"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "雖然的確",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "留有建築物的痕跡，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "但如果你們是來尋找什麼人的話，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n前往山頂恐怕也是白費工夫。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這樣",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_011"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "啊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就算你說的是事實，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我也想親眼確認看看。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們還是要登頂看看。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "我知道了。",
        "unit_id": 311,
        "voice": "vo_adv_1803003_012"
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "那我就先下山了，",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性",
        "words": "\n請你們多加小心。",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "謝謝你。",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_013"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我們繼續前進吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……呼、",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_014"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "呼。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "空氣",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "越來越稀薄了……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "能在這種地方",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "修練的劍士，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n絕對",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是位",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "身手不凡之輩……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這裡",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_015"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就是山頂啊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n連座建築物",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "都沒有呢。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這是……",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_016"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "柱子的殘骸。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "原來",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "真的曾經有人居住啊……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "哈哈，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這可真是大老遠的",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "白跑了一趟呢……",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "下起暴風雪就不妙了。",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_017"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們快下山吧。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "光是確認了事實，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就不算",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "毫無所獲──",
        "unit_id": 100311
    },
    {
        "type": "background",
        "background": "500543"
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "──汝",
        "unit_id": 712,
        "voice": "vo_adv_1803003_018"
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "是渴望探求劍術巔峰之輩嗎？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "！？",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_019"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是誰！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "──汝是",
        "unit_id": 712,
        "voice": "vo_adv_1803003_020"
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "渴望探求劍術巔峰之輩嗎？",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "這個騎士",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_021"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "是從哪冒出來的！？",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n而且，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "天氣突然惡化了！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我們是見到幻覺了嗎……！？　",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "回答吾等的問題。",
        "unit_id": 711,
        "voice": "vo_adv_1803003_022"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "還有一個人！？",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_023"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不，",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不只一個人！",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我們已經被包圍了嗎──！　",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "……我",
        "unit_id": 100311,
        "voice": "vo_adv_1803003_024"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "想探求劍術的巔峰。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我正是",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "為此而來。",
        "unit_id": 100311
    },
    {
        "type": "dialogue",
        "name": "騎士3",
        "words": "是嗎……",
        "unit_id": 711,
        "voice": "vo_adv_1803003_025"
    },
    {
        "type": "dialogue",
        "name": "騎士3",
        "words": "很遺憾，",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士3",
        "words": "此地興旺的流派早已沒落。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士3",
        "words": "\n汝所追求的強大",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士3",
        "words": "已經不復存在了。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "修練場腐朽不堪，",
        "unit_id": 711,
        "voice": "vo_adv_1803003_026"
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "登峰造極的劍技",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "也已消逝雪中。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "\n老老實實地下山去吧。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "此等建言也是為了汝，",
        "unit_id": 712,
        "voice": "vo_adv_1803003_027"
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "若汝等還想保住一命……",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "苟且保住的命我才不稀罕！",
        "unit_id": 100312,
        "voice": "vo_adv_1803003_028"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n我從",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "踏入這座山的那一刻起，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "就已經下定決心了！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "……那麼，與吾等一戰吧。",
        "unit_id": 712,
        "voice": "vo_adv_1803003_029"
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "\n就讓吾等",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士1",
        "words": "來見識汝的決心。",
        "unit_id": 712
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "擊敗吾等之時，",
        "unit_id": 711,
        "voice": "vo_adv_1803003_030"
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "\n汝的劍術",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士2",
        "words": "必會臻至更高的境界。",
        "unit_id": 711
    },
    {
        "type": "dialogue",
        "name": "騎士3",
        "words": "接招吧──！",
        "unit_id": 711,
        "voice": "vo_adv_1803003_031"
    },
    {
        "type": "background",
        "background": "500543"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "唔！",
        "unit_id": 100312,
        "voice": "vo_adv_1803003_032"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "好快！",
        "unit_id": 100312,
        "voice": "vo_adv_1803003_033"
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "而且好沉重！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "不會錯的，這絕對是來自劍的攻擊！",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "\n",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
        "name": "怜",
        "words": "我還以為是魔物之類的在搞鬼，",
        "unit_id": 100312
    },
    {
        "type": "dialogue",
