[
    {
        "type": "background",
        "background": "500361"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "打工休息的日子，凱留獨自在公會小屋中讀著雜誌。"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呵呵，",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_000"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "果然南島的海很美呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "雖然將去海邊作為大前提，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但去那裡要做什麼才是個問題。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "租借休閒用的小船",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_001"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和潛水體驗……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喔～",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "連遊覽船都有啊，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還不錯耶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "再來就是住宿的地方。",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_002"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我當然不會在住宿費上吝嗇的，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我要享受高檔飯店和豪華晚餐！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對了，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也得學好用餐禮儀才行呢。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "接下來",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_003"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是絕對不能遺忘的伴手禮！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n必買的點心自然不用說，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還有可愛的雜貨也絕對要買到。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_004"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "光是想像就令人整顆心都飛到南島了～♪",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "呀啊啊！？",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_005"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你、",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你別嚇人啦！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我宰了你喔！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真是的……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你這種地方",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的都不會改耶。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "咦？",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_006"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你問我在做什麼？",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就跟你看到的一樣，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我在做假想訓練。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n如果想在南島盡情玩樂，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就必須仔細調查，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n並且制定詳盡的計畫。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "所以",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_007"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我以人身在其境的感覺做各種想像，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這樣才能事先排除在當地發生的疏失。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "話雖這麼說，",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_008"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但我前陣子才終於剛收到了打工的薪水，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n這還是很久之後的事就是了。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我說啊，",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_009"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說得倒是很輕鬆，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但預算……",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真的？",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_010"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "……說得也是，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我也想先到當地去看看，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果是當天來回，也能夠節省旅費。",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "最重要的是，",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_011"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在想像各種事情後，就令人感到心動不已，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好想立刻就衝到當地……！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好吧，",
        "unit_id": 106012,
        "voice": "vo_adv_1078008_012"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我接受你的提議！",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你可是提議的人，",
        "unit_id": 106012
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "要好好陪我體驗喔！",
        "unit_id": 106012
    },
    {
        "type": "background",
        "background": "500710"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是……",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_013"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "是大海耶～！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "啊啊，",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_014"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我終於來到憧憬的南島了……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n瑪爾傑海岸也滿開心的，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過怎麼說呢……",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這裡會",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有種湧上心頭的興奮感呢！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺天空的藍",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_015"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "和吹拂過臉頰的風，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "全部都不一樣！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎、",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "怎麼辦？",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我還什麼都沒做",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就超開心的耶！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "對啊，",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_016"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "差點就要",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "在大家面前徹底暴露自己鄉巴佬的醜態了。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果是貪吃佩可，她絕對會捉弄我的。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "不過",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_017"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "多虧如此，我在正式旅行時應該能表現出從容的態度。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "你說得沒錯，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有來先這裡真是太好了。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好了，",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_018"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我們可沒時間一直沉浸在感動之中。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我們是當天來回，而且預算有限，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "盡可能行動到最後一刻吧！",
        "unit_id": 107812
    },
    {
        "type": "background",
        "background": "500690"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "好吃～♪",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_019"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n菜單本身和我們打工的地方差不多，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n但或許是調味料不同，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "感覺別有一番風味呢。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這個黑糖的甜點我是第一次吃，",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_020"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "還不錯呢。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n等回去後去告訴店長吧。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "喔～",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_021"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "有感覺不錯的工藝品耶。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "以這地方流傳的神獸為主題創作的，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "真有趣呢。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "價格也很平易近人，",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_022"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "買回去送給前輩他們吧。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "那麼，",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_023"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "享受過地方美食，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "也買好伴手禮了。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "這些都還只是開場，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "說到南島最值得一玩的",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "──就是海邊啊！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "如果沒去海邊，",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_024"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "就沒資格跟人說什麼南島！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "只是很可惜，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "因為預算關係，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "沒辦法玩要花錢的遊樂設施，",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "但是到海裡玩水是免費的！",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "而且，",
        "unit_id": 107812,
        "voice": "vo_adv_1078008_025"
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "我有帶我最愛的游泳圈。",
        "unit_id": 107812
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n我做好萬全準備要盡情享受南島了！",
