    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "來南島後心情放鬆多了，",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "\n所以我希望你能當成是我不小心說溜嘴，聽我說。",
        "unit_id": 107811
    },
    {
        "type": "dialogue",
        "name": "凱留",
        "words": "謝謝，",
