[
    {
        "type": "background",
        "background": "505032"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在鎮上的人逐漸聚集而來之後，\n萬聖節舞會終於開始了――"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？　",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_000"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們也想好好地跟大家一起跳舞，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣啊……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "說得也是呢。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "是的。",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_001"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "幽靈們說舞會感覺很好玩，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "很羨慕大家……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "聽他們這麼說感覺有點落寞呢。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然說也是可以像剛剛那樣，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_002"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "讓他們附身到我身上跳舞，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "但一次也只能讓一個人跳到舞。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "實在很想幫幫大家，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_003"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但是該怎麼做才好呢……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "咦？　",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_004"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "能讓幽靈們可以放心跳舞的地方",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗎？",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我知道了。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣的話，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們就去那邊吧。",
        "unit_id": 108111
    },
    {
        "type": "background",
        "background": "500264"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這個靈異地點，即使在靈能力者當中也沒有多少人知道。",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_005"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果要和幽靈們跳舞的話，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這裡是最適合的地方。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "忍，妳想得太週到了！　",
        "unit_id": 2412,
        "voice": "vo_adv_1081003_006"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "如果是這裡的話，不但沒人，",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n也超適合當作舞會會場！",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "嗯……",
        "unit_id": 2412,
        "voice": "vo_adv_1081003_007"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "不過，",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "既然有這機會，就要找來很多幽靈，",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n辦個盛大的舞會。",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那是……",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_008"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "說的也是。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "那麼",
        "unit_id": 2412,
        "voice": "vo_adv_1081003_009"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "『這裡是舞會會場』得這麼去宣傳一下才行呢。",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n用幽靈們也能瞭解的方法。",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "宣傳？　",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_010"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣的話……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們來做南瓜燈籠吧。",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_011"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n那是象徵萬聖節的應景道具。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "而且，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_012"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那個還有可以吸引善良靈魂，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "驅除惡靈的效果。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我想這樣大家也會比較放心。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "謝謝你。",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_013"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼，我們就去附近的農場吧。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n還是得先準備南瓜才行呢。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "拿到了很多因為外觀破損",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_014"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以沒辦法拿去賣的南瓜耶。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "雖然我是第一次做南瓜燈籠，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_015"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n但還是會努力加油的。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嗯……嘿咻。",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_016"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這邊要像",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "吧……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "嘿。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如何呢？　",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_017"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "先完成了第一個。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_018"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我就把這當作是在誇獎我吧。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "想說做得誇張一點，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_019"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n比較適合拿來驅除惡靈。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "所以刻意這麼做的。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "比我還漂亮？　",
        "unit_id": 2412,
        "voice": "vo_adv_1081003_020"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "怎麼可能會……",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "喔，嗯。",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n真不愧是忍，",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "真的是很棒的南瓜燈籠呢。",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "是說小伙子啊，",
        "unit_id": 2412,
        "voice": "vo_adv_1081003_021"
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "你覺得我適合用「漂亮」兩個字來形容的嗎！？",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "\n嗚哇，",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "好噁心！　",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "骷髏老爸",
        "words": "別過來這邊！",
        "unit_id": 2412
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呵呵……",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_022"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "爸爸，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "感覺你好像很開心。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太好了呢。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "因為算是很習慣雕刻了。",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_023"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "畢竟常會接到製作詛咒雕像的工作。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不過還請放心。",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_024"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "在做這個的時候沒有加上詛咒唷。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "……啊，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_025"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "這樣啊。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不會，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_026"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "不好意思。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "仔細想想，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n我好像從來沒有用這種心情來進行雕刻呢。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "像今天這樣，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_027"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "想讓幽靈們開心一下……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "為了其他人的幸福拿起雕刻刀，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我想都是過去從未有過的經驗。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我……",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_028"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "想要讓更多幽靈，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "都聚集到這裡來。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "然後，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_029"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "如果大家都能玩得開心，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那就好了……",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "來，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_030"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我們繼續動手吧。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "得多做一些南瓜燈籠才行。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "呼……",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_031"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "總算及時完成",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "準備了呢。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "那麼，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_032"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "要來點亮南瓜燈籠囉――",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "各位",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_033"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "晚安。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "今天歡迎大家來參加萬聖節舞會，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_034"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n希望大家都能玩得愉快。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "{player}，",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_035"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "你能看得到幽靈嗎？",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "太好了……",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_036"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "透過南瓜燈籠發出的光，",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "\n好像讓大家順利地顯現在現世了。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "居然能聚集到這麼多幽靈……",
        "unit_id": 108111,
        "voice": "vo_adv_1081003_037"
    },
    {
        "type": "dialogue",
        "name": "忍",
        "words": "我真是太開心了。",
        "unit_id": 108111
    },
    {
        "type": "dialogue",
        "name": "男性亡靈",
        "words": "喔喔～",
        "unit_id": 311,
        "voice": "vo_adv_1081003_038"
    },
    {
        "type": "dialogue",
        "name": "男性亡靈",
        "words": "沒想到有機會參加這種舞會！",
        "unit_id": 311
    },
    {
        "type": "dialogue",
        "name": "男性亡靈",
