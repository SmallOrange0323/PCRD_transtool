    {
        "type": "dialogue",
        "name": "日和",
        "words": "就只有我的衣服",
        "unit_id": 100113,
        "voice": "vo_adv_6042301_000"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "沒什麼變化……",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "難得有這個機會，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我也好想穿和平時不同的服裝喔～",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "怎麼說呢，",
        "unit_id": 100113,
        "voice": "vo_adv_6042301_001"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "看起來很強的服裝！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "像帆稀小姐她們一樣的龍啊，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "或是像",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "獅子的服裝之類的！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗷嗚～！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我要吃掉你囉～！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "開玩笑的♪",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "咦，",
        "unit_id": 100113,
        "voice": "vo_adv_6042301_002"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "真的嗎！？",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "欸嘿嘿～♪",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "既然騎士先生都這麼說了，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n穿著這套服裝好像也不錯♪",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "這個嘛，",
        "unit_id": 100113,
        "voice": "vo_adv_6042301_003"
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "衣服褲子都變成了條紋樣式，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "還有",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "我的尾巴也變成了條紋狀，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "耳朵也……",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "嗯！",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "\n我也不是很清楚，",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "總之就是",
        "unit_id": 100113
    },
    {
        "type": "dialogue",
        "name": "日和",
        "words": "全身上下都充滿了條紋唷！",
        "unit_id": 100113
    }
]