    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "ずっと",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "ショーグンの家来でいるために、",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "必ずや",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
