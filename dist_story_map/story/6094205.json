    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "この世の天下統一が先デス！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "\nあの世を満喫するためにも、",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "生きている間に",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "人生を",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "全うしたいデス！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "ナ、",
