        "words": "オニは",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "手強い相手デスが、",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "のんびり暮らせるように",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "戦うしかありまセン！",
        "unit_id": 117811
    },
    {
