        "voice": "vo_adv_6076205_001"
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "極楽デスか！　",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "それは",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "楽しみデス！",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "\n",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "とても気になりマスが、",
        "unit_id": 117811
    },
    {
        "type": "dialogue",
        "name": "ニノン",
        "words": "まずは",
