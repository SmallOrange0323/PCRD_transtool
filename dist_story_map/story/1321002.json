[
    {
        "type": "background",
        "background": "500160"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "雷姆來調查「夏日海邊」了。"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n她第一個選的娛樂是──"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "把拇指",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_000"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "放在上面，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n剩下的四根手指從下面……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "握住。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "握法是這樣嗎？",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_001"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這就是「海釣」的基礎嗎。",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "但是──",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "從這",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_003"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "深不見底的廣大海洋中，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n真的有辦法釣到魚嗎？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆有點擔心。",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_004"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "但是，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆也聽大家說了很多海釣的樂趣。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "說到蘭德索爾的海就是海釣。",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_005"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "特別是夏天，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "魚的活動變得活躍，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "可以釣到很多魚，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "如此一般，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "海之家的客人們是這樣跟雷姆說的。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "正因為如此，",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_006"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因為想讓昂他們也能享受，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n所以雷姆才會像這樣先來體驗，但是……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "等到像這樣，",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_007"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "看到寬廣的海之後，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "身為初學者的雷姆就擔心起來了，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆真的做得到嗎。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "謝謝你。",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_008"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "全仰賴你了喔。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_009"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "嗯嗯，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "握好釣竿……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "像是要把東西拋向遠方一樣地，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "揮出去……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "嗎。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這難道是……",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_010"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "總之先試試看吧。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n──嘿呀！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "咦！？",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_011"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不、",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不好意思！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n雷姆做錯了嗎……？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是真的嗎……！",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_012"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "太好了。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆就覺得它拿起來，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "跟雷姆平常用的道具很像啊！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "就是護身用的鐵球。",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_013"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "接下來就等魚上鉤了對吧。",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_014"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n魚上鉤之後就配合釣竿，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "等針勾住之後把魚釣上來……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "就算能聽懂，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "但是實際動手感覺很難呢。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n────！"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這、",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_015"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這是──！？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "釣竿",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_016"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "突然變重了。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n這是上鉤了嗎！？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "上鉤之後就配合釣竿，",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_017"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n直接把它釣上來──",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "呀啊！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "啊……",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_018"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "釣到了……！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是大小適中的魚呢！",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_019"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "拿去做料理的話應該很好吃呢。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆是第一次喔。",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_020"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "剛剛雷姆太著急，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "沒有轉收線器就釣上來了。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "下次雷姆會冷靜地",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "用你教的方式做做看。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "把魚餌",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_021"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "勾上去。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "第二釣，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "要拋了喔！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "像拋鐵球一樣……",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_022"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "嘿呀！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──────────────！"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "──！"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n────！"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這次的魚",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_023"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "比剛剛的魚大了三倍左右呢。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這樣應該就能讓大家都吃飽了。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "只是碰巧的啦。",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_024"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昂跟姊姊",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "應該能釣得更好吧。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……但是，",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_025"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這難道是……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n把魚勾拋得越遠，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "也就是說",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "越離開海岸，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n釣到大魚的可能性就會上升，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是那樣嗎？",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……原來如此。",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_026"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "果然是那樣嗎。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因為……",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_027"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昂是男孩子，",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n所以雷姆覺得他可能會想釣大魚。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請務必帶雷姆去！",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_028"
    },
    {
        "type": "background",
        "background": "501190"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "…………"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "哇……",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_029"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "好厲害啊。",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_030"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n不管看向哪邊都是",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "海、",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "海、",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "海。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "只看得到海啊！",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "而且",
        "unit_id": 132112,
        "voice": "vo_adv_1321002_031"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這個",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "名叫「漁船」的交通工具。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n明明是在水上卻能跑這麼快……",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "昂一定會很高興的。",
        "unit_id": 132112
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "突然拜託他們",
        "unit_id": 132112,
