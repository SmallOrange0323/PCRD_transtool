    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "呼……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "好一個龐然大物……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "半吊子的手段可沒辦法打倒牠呢……",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "保險起見，要確保退路才行──",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "真是稀奇。",
        "unit_id": 126611,
        "voice": "vo_adv_5122302_001"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "像秋乃這樣的人，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "居然會說起喪氣話。",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳、",
        "unit_id": 126711,
        "voice": "vo_adv_5122302_002"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "妳在說什麼啊？",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "本小姐我",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "才沒有說喪氣話……！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "那可真是失禮了。",
        "unit_id": 126611,
        "voice": "vo_adv_5122302_003"
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "不愧是大有來歷的紫藤家千金，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "\n",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "相信只要有妳出馬，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "區區島鯨",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "就跟水蚤一樣，",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "似似花",
        "words": "沒錯吧？",
        "unit_id": 126611
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒、",
        "unit_id": 126711,
        "voice": "vo_adv_5122302_004"
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "沒錯，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "這是當然的，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "就如同妳說的那樣♪",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "\n",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "不需要退路！",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "各位，",
        "unit_id": 126711
    },
    {
        "type": "dialogue",
        "name": "秋乃",
        "words": "請跟上本小姐！",
        "unit_id": 126711
    },
    {
