[
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "在四周無人的空曠平原上，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n傳來了響亮的叫喊聲。"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "哼、",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_000"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喝！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n吃我這招啊啊啊！",
        "unit_id": 106114
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "太慢了！",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_001"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n這種程度的攻擊，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "連隻小飛蟲都殺不死！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "怎麼了怎麼了，",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_002"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆妳在幹嘛？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n……是在罷工抗議嗎？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "最好、",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_003"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "是啦！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n唔喔喔喔呀啊啊啊啊！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "哼，",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_004"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "喊得挺大聲的嘛！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "但如果只會憑藉氣勢──",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "下場就是這樣！",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "唔呃呃呃",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_005"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "呃───！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "唉～唉～",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_006"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "被打飛得還真遠。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "話說剛剛",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "絕對防禦是有發動的吧？",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n那怎麼可能打中嘛。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "咳咳……",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_007"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "可是啊──",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "你聽到不會手癢嗎？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "叫絕對防禦這種名稱，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "就是會讓人想破解看看吧？",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "呵。",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_008"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "諾維姆，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "妳真傻。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n就是因為無法破解才叫絕對啊。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "不過妳那種反骨精神，",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_009"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "我也不是不能理解。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "接下來呢？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "要繼續試嗎？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "嗯，",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_010"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "那當然！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n啊，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "對了，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "尾狗刀你也──",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "躡手躡腳、",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_011"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "躡手躡腳……",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "喂，站住，",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_012"
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "別想跑！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "快，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "尾狗刀你也來幫忙！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "\n我們兩個人合力，",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "搞不好就能破解「絕對」！",
        "unit_id": 106114
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "妳在說什麼啊，",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_013"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我聽不懂妳的意思──",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "我是說只要我們合力，沒有什麼是辦不到的！",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_014"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "……唉。",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_015"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "好吧，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我知道了。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "\n雖然很麻煩，",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "但我就幫妳吧。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "呵，",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_016"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "不管要來多少人都無妨！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "那麼，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "我來發動能力……",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "諾維姆，",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_017"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "就是現在。",
        "unit_id": 106211
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "咦？",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_018"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "啊？",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_019"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "喂，等一下，尾狗刀！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n不是說要破解絕對防禦嗎！？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n我都還沒發動能力──",
        "unit_id": 107111
    },
    {
        "type": "background",
        "background": "500140"
    },
    {
        "type": "dialogue",
        "name": "尾狗刀",
        "words": "我又沒有想破解的意思──",
        "unit_id": 106211,
        "voice": "vo_adv_5111603_020"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "你這個人～！",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_021"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n諾維姆，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "這樣妳也無所謂嗎！？",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "諾維姆",
        "words": "真不愧是尾狗刀！",
        "unit_id": 106114,
        "voice": "vo_adv_5111603_022"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "……原來如此，",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_023"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "看來妳比我想的還蠢。",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "\n",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "算了，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "那我也不能輸給你們！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "諾維姆、",
        "unit_id": 107111,
        "voice": "vo_adv_5111603_024"
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "尾狗刀，",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "誓約女君",
        "words": "我可不會手下留情喔！",
        "unit_id": 107111
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "看著對自己發起挑戰的諾維姆和尾狗刀，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n誓約女君一臉愉悅地舉起了武器。"
    }
]