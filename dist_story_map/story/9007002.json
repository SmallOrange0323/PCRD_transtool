    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "為了捕捉5.5周年的魔物，"
    },
    {
        "type": "dialogue",
        "name": "旁白",
        "words": "\n茉莉、莫妮卡和克蕾琪塔三人在王城前的廣場四處走動。"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "5.5周年紀念的魔物～！",
        "unit_id": 100511,
        "voice": "vo_adv_9007002_000"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n5.5周年紀念的魔物在哪裡啊～！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "給我等一下，",
        "unit_id": 118011,
        "voice": "vo_adv_9007002_001"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "隨從一號。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "在這種大街上亂嚷嚷，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "魔物也不可能出現的啦。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n守衛多少也是有在做事的。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我就說了我不是隨從一號啦！",
        "unit_id": 100511,
        "voice": "vo_adv_9007002_002"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "話說回來，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "連生態都不太了解的魔物，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n是要怎麼找啊？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯……",
        "unit_id": 105311,
        "voice": "vo_adv_9007002_003"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n現在也沒有什麼線索，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "看來只能腳踏實地找了。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "「腳踏實地」啊……",
        "unit_id": 118011,
        "voice": "vo_adv_9007002_004"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "做生意的話，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "那也不失為一個方法。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但若是陛下的敕命，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我就想要盡可能以最快速度解決。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "沒錯，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這都是為了證明我的忠心耿耿……！！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "事情沒那麼簡單啦。",
        "unit_id": 100511,
        "voice": "vo_adv_9007002_005"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "這種時候，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "靠的就是努力和毅力！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "唔哦哦哦！",
        "unit_id": 100511,
        "voice": "vo_adv_9007002_006"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n一直找一直找，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "找到天涯海角啦！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "5.5周年紀念的魔物在哪裡啊～！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我就說了！",
        "unit_id": 118011,
        "voice": "vo_adv_9007002_007"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "在這裡亂嚷嚷也沒用的啦！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n隨從二號！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "妳也說說她",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "幾句吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳自己不也是在亂嚷嚷嗎！？",
        "unit_id": 105311,
        "voice": "vo_adv_9007002_008"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "是說，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我也不是妳的隨從二號啊……",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在像無頭蒼蠅般亂找之前，",
        "unit_id": 105311,
        "voice": "vo_adv_9007002_009"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "首先",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "去問這個城鎮的居民蒐集目擊情報吧。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n既然傳聞這些魔物叫聲奇特，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "那有人看過也不足為奇。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "了解！",
        "unit_id": 100511,
        "voice": "vo_adv_9007002_010"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "靠著努力和毅力，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "一直問一直問，問到天涯海角！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "雖然這沒辦法說是太聰明的手段，",
        "unit_id": 118011,
        "voice": "vo_adv_9007002_011"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "但也沒辦法了。",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "俗話說欲速則不達，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "就以最快速度問完吧！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "茉莉、克蕾琪塔",
        "words": "「5.5周年紀念的魔物在哪裡啊～！？」\n「5.5周年紀念的魔物在哪裡呢～！？」",
        "unit_id": 1,
        "voice": "vo_adv_9007002_012"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "嗯嗯……",
        "unit_id": 9211,
        "voice": "vo_adv_9007002_013"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "妳們問有著奇特叫聲的魔物啊。",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我之前",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "確實有看到。",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真、",
        "unit_id": 105311,
        "voice": "vo_adv_9007002_014"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "真的嗎！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "在哪裡看到的？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "在城鎮外面。",
        "unit_id": 9211,
        "voice": "vo_adv_9007002_015"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "不過，",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n有別的人馬",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "捉到那隻魔物了。",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我記得那是",
        "unit_id": 9211,
        "voice": "vo_adv_9007002_016"
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "被邀請到王城的一行人……",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "\n",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "對了，",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "老人",
        "words": "我記得好像有說，是貪吃佩可一行人的樣子？",
        "unit_id": 9211
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "咦咦～～！？",
        "unit_id": 100511,
        "voice": "vo_adv_9007002_017"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "公主殿下也在找那些魔物哦～～！？",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那這樣被他們給搶先了……",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "嗯……",
        "unit_id": 105311,
        "voice": "vo_adv_9007002_018"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "因為她有說過，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "希望大家一起分頭找嘛。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我聽說那種魔物還有很多隻。",
        "unit_id": 105311,
        "voice": "vo_adv_9007002_019"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "不是在這裡瞎耗的時候了，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "繼續搜索吧！",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "那當然！",
        "unit_id": 100511,
        "voice": "vo_adv_9007002_020"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我要拚命擠出",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "更多更多努力和毅力囉～～！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳的精神可嘉，",
        "unit_id": 105311,
        "voice": "vo_adv_9007002_021"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "但可不能盲目亂衝。",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "克蕾琪塔小姐，",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我們就先蒐集情報──",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "嘎喀……！！",
        "unit_id": 118011,
        "voice": "vo_adv_9007002_022"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "呦呦呦……",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "克、",
        "unit_id": 105311,
        "voice": "vo_adv_9007002_023"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "克蕾琪塔小姐？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "妳怎麼了？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "\n",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "我聽到妳的嘴裡發出從未聽過的效果音！？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "我真是失策……！",
        "unit_id": 118011,
        "voice": "vo_adv_9007002_024"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n為了打聽情報虛耗時間，",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "結果勞煩陛下親自出馬……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "這是我一生的失敗！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "是殃及子孫的恥辱……！",
        "unit_id": 118011
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有、",
        "unit_id": 105311,
        "voice": "vo_adv_9007002_025"
    },
    {
        "type": "dialogue",
        "name": "莫妮卡",
        "words": "有必要這麼誇張嗎……？",
        "unit_id": 105311
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "不能氣餒啊，",
        "unit_id": 100511,
        "voice": "vo_adv_9007002_026"
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "克蕾琪塔小姐！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n這點失敗馬上就能挽回的！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "\n不是我在自誇，",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "茉莉",
        "words": "我的失敗可不會這麼小兒科！",
        "unit_id": 100511
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "真的完全不該自誇耶！？",
        "unit_id": 118011,
        "voice": "vo_adv_9007002_027"
    },
    {
        "type": "dialogue",
        "name": "克蕾琪塔",
        "words": "\n是說",
