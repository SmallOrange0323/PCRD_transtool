    },
    {
        "type": "dialogue",
        "name": "蘭法、千歌",
        "words": "……唔！",
        "unit_id": 134411,
        "voice": "vo_adv_5202401_005"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "剛剛的聲音……",
        "unit_id": 134311,
        "voice": "vo_adv_5202401_006"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n千歌妳，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "也有聽見嗎……？",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "嗯……",
        "unit_id": 134411,
        "voice": "vo_adv_5202401_007"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n看來精靈的失控",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "還沒有完全平息呢。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不過，",
        "unit_id": 134411,
        "voice": "vo_adv_5202401_008"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "這次一定要讓這件事平息。",
        "unit_id": 134411
