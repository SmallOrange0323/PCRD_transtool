    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "不能再讓損害擴大了。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "為了",
