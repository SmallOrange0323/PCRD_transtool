        "voice": "vo_adv_5202401_009"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "村子裡的",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "大家……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n我也會加油",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "的……！",
        "unit_id": 134311
    }
