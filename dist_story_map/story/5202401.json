        "voice": "vo_adv_5202401_003"
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "是村裡的大家",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "千歌",
        "words": "\n覺得特訓應該很辛苦，所以送來給我們的喔。",
        "unit_id": 134411
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "這樣",
        "unit_id": 134311,
        "voice": "vo_adv_5202401_004"
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "呀……？",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "\n……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "那麼……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "我會好好地，",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "蘭法",
        "words": "享用的……",
        "unit_id": 134311
    },
    {
        "type": "dialogue",
        "name": "扭曲的音寵之精靈",
