    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "本当に",
        "unit_id": 113911,
        "voice": "vo_adv_6050110_000"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "帰っちゃった……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "んですよね？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\nあんまり実感ないですね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "また明日も会えるような。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "霊界にですか？　",
        "unit_id": 113911,
        "voice": "vo_adv_6050110_001"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "嫌ですよ！　",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "い、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "行くのが嫌なんじゃなくて、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\nすぐに会いに来たと思われるのが恥ずかしいだけです。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "もう少し時間が経てば……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "それはそのとき考えましょう。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "え～",
        "unit_id": 113911,
        "voice": "vo_adv_6050110_002"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "来年もやるつもりですか～？",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "きっと来年は",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "あの子たちが楽しませてくれますよ。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "私はそう信じてます。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "また会えるからって",
        "unit_id": 113911,
        "voice": "vo_adv_6050110_003"
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "さみしくないわけじゃ……",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "あ、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "いや別にさみしくなんかないですよ。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "\n",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "でも、",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "そうですね。",
        "unit_id": 113911
    },
    {
        "type": "dialogue",
        "name": "ツムギ",
        "words": "また会える日が楽しみです。",
        "unit_id": 113911
    }
]