    },
    {
        "type": "background",
        "background": "510300"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "居然會約在這種鬧區見面，",
        "unit_id": 103731,
        "voice": "vo_adv_4010194_000"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n還真難得……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "還是來自那個人的邀約。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天是我的生日。",
        "unit_id": 103731,
        "voice": "vo_adv_4010194_001"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但那個人卻什麼都沒說……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "就是這個意思對吧？　",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵。",
        "unit_id": 103731,
        "voice": "vo_adv_4010194_002"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "光是這樣等著，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "臉頰就會不自覺地微笑，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "可是這樣子，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "又會被捲入那個人的步調。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "來稍微……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "捉弄一下他好了。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "呵呵，",
        "unit_id": 103731,
        "voice": "vo_adv_4010194_003"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要我等多久都可以。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n因為",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天是跟你的生日約會啊。",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "……",
        "unit_id": 103731,
        "voice": "vo_adv_4010194_004"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你會",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "讓我感到心跳加速對吧？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你那是什麼自信……！？",
        "unit_id": 103731,
        "voice": "vo_adv_4010194_005"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "要是平常的話，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "在我說出約會時，你就會開始手忙腳亂、",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n舉止可疑的說……！　",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "咦？",
        "unit_id": 103731,
        "voice": "vo_adv_4010194_006"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "手臂……！？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這樣子",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "從旁看來，不就完全是……！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "而且還說",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "「首先」，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是代表還會更進一步嗎……！？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "怎麼辦，",
        "unit_id": 103731,
        "voice": "vo_adv_4010194_007"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "今天的他跟平常好不一樣……！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "是因為",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我說了要讓我心跳加速～",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "的關係嗎！？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "明明只是打算稍微捉弄一下而已，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "他卻當真了……！　",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "等等等等！",
        "unit_id": 103731,
        "voice": "vo_adv_4010194_008"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n雖然我有點憧憬，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "但在大街上被這樣做，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "心跳會加速過頭的！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "真是的，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你完全不知道控制分寸……！",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "雖然我很高興",
        "unit_id": 103731,
        "voice": "vo_adv_4010194_009"
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "你對我的生日",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "這麼全力以赴，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n但能再稍微",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "一步一步按照順序來嗎？",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "\n",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "至於",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "公主抱……",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "如果是在四下無人的地方，",
        "unit_id": 103731
    },
    {
        "type": "dialogue",
        "name": "智",
        "words": "我可能會希望你做。",
        "unit_id": 103731
    },
    {
        "type": "background",
        "background": "509011"
    },
    {
        "type": "background",
        "background": "510030"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "接下來就是最後的彎道……",
        "unit_id": 106131,
        "voice": "vo_adv_4010194_010"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那麼，就在通過這裡的瞬間──",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "油門踩到底！　",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "──好耶，",
        "unit_id": 106131,
        "voice": "vo_adv_4010194_011"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是我贏了！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n這樣一來勝率剛好各半！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我不是說了嗎，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這東西只要熟悉後，馬上就能贏的！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "不過話說回來，",
        "unit_id": 106131,
        "voice": "vo_adv_4010194_012"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "居然有一天能像這樣跟你玩著這種遊戲……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "啊，不是，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是我這邊的事，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你可以不用在意。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "沒想到會在這種地方跟你巧遇……",
        "unit_id": 106131,
        "voice": "vo_adv_4010194_013"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "而且",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "居然還問我",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "「對遊戲中心有沒有興趣？」。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "接著還像這樣一起玩，",
        "unit_id": 106131,
        "voice": "vo_adv_4010194_014"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "你果然是個超級老好人……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "是說雖然現在說這個有點晚了，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n但在這一邊，還是別跟這傢伙太有瓜葛比較好吧？　",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "……不過，",
        "unit_id": 106131,
        "voice": "vo_adv_4010194_015"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "偶爾像這樣子也不錯啦。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為今天可是",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我的生日啊♪",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯？",
        "unit_id": 106131,
        "voice": "vo_adv_4010194_016"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "怎麼了，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "看你嚇了一跳。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我以前從來沒說過啊，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "也沒必要特地去說就是了。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "嗯～",
        "unit_id": 106131,
        "voice": "vo_adv_4010194_017"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "被你這樣當面慶祝，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "感覺真奇怪……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n不過，謝謝你。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "其實啊，",
        "unit_id": 106131,
        "voice": "vo_adv_4010194_018"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "剛剛尾狗……",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我的夥伴也有幫我慶祝。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n「生日快樂」",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這句話真不錯。",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "雖然有點不好意思，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "但即使這樣還是很高興，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "感覺很舒服！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "所以啊，",
        "unit_id": 106131,
        "voice": "vo_adv_4010194_019"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "因為生日這天是很特別的，",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n可以做些跟平常不一樣的事！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "就先當成那樣吧！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "這是你說的哦。",
        "unit_id": 106131,
        "voice": "vo_adv_4010194_020"
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "那就再來比一次賽車吧！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "我絕對要贏過你！",
        "unit_id": 106131
    },
    {
        "type": "dialogue",
        "name": "矛依未",
        "words": "\n臣服在我的生日之力下吧！",
        "unit_id": 106131
    }
]