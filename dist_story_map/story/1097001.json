    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "呼～",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_000"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "洗好的衣服也晾完了。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n這樣",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "早上的工作就結束了呢。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "姊姊",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_001"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "還和鈴莓小姐在一起嗎？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n愛蜜莉雅大人",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "似乎也在陪孩子們玩耍。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……沒有事情可以做了。",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_002"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n實在讓人靜不下來……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "啊。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_003"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "可以請您彎下腰來嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好的，",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_004"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "謝謝您。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n您的臉頰上",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "黏著早餐的飯粒。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這樣子就……",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_005"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "好，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "拿下來了。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n看起來",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "又更加威風凜凜了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "別這麼說，",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_006"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這沒有什麼值得道謝的。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是服侍主人的人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這是應該的事。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "真是了不起的想法呢，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_007"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆深感佩服。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "啊，",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_008"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雷姆小姐，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "早安。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_009"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "可可蘿小姐、{player}先生，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n你們早安。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雖然只是湊巧看到，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_010"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n但是兩位的關係",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "真的很要好呢。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "關係要好……",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_011"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "看起來是那個樣子嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "只是誠心誠意地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在服侍主人而已……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_012"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這非常了不起。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "也要向妳看齊才行。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這麼說來，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_013"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "請問兩位是什麼關係呢？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下是奉愛梅斯大人之命，",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_014"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n作為嚮導",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "來服侍主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下遵從其神諭",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_015"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "而與主人相遇。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "但是，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "現在則是真心地",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "服侍著主人。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "原來如此，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_016"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是這樣的緣由呢。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "……",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_017"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "不好意思，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_018"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "可可蘿小姐。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n如果可以的話，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "能不能",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "暫時讓雷姆接替妳的職責呢？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "接替職責，",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_019"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是的。",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_020"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n雷姆我們自從在這裡接受照顧以來，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n便承蒙各位的好意",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "在育幼院幫忙。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "並不是對職責有所不滿，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_021"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "而是很擔心這樣下去",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "自身的女僕力會衰退。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "女、",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_022"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "女僕力",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是嗎？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那個",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "是什麼樣的力量呢？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "根據昴告訴雷姆關於女僕力的說明，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_023"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "想要服侍某個人的心意",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "就是女僕力的根源。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "而失去那心意的女僕，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_024"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n將無法再自稱為是女僕……",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "居、",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_025"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "居然有這麼可怕的事情嗎……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "因此，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_026"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "到中午前的一小段時間就好了。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n在這段時間裡，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "是否能讓我接替妳的職責呢？",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "這件事",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_027"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "並不是在下能自行決定的……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "您覺得如何？",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人，",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_028"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "真是出色的決斷力。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n明白了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "在下也贊成。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "當然，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_029"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆會誠心誠意",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "接下這項職責的。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "那麼，",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_030"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "也取得主人的許可了，",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "就答應",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雷姆小姐的請求吧。",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "其實我們",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_031"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "\n剛好打算要去採買育幼院的物資……",
        "unit_id": 105913
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "我明白了。",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_032"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n這份工作，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雷姆會確實承接的。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "和{player}先生兩個人\n一起加油！",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_033"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "主人就麻煩您了，",
        "unit_id": 105913,
        "voice": "vo_adv_1097001_034"
    },
    {
        "type": "dialogue",
        "name": "可可蘿",
        "words": "雷姆小姐。",
        "unit_id": 105913
    },
    {
        "type": "background",
        "background": "500030"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "啊，",
        "unit_id": 109711,
        "voice": "vo_adv_1097001_035"
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "雖然接下了採買的工作，",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "\n",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "但這真是個盲點呢。",
        "unit_id": 109711
    },
    {
        "type": "dialogue",
        "name": "雷姆",
        "words": "這個世界的東西，",
